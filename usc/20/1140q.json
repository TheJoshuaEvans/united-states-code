{"tag":"section","attrib":{"id":"id0d7d7699-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q"},"text":null,"children":[{"tag":"num","attrib":{"value":"1140q"},"text":"§ 1140q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National technical assistance center; coordinating center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d7d769a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Center","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7d769b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1140r"},"text":"section 1140r of this title","children":[],"tail":", the Secretary shall award a grant to, or enter into a contract or cooperative agreement with, an eligible entity to provide for the establishment and support of a National Center for Information and Technical Support for Postsecondary Students with Disabilities (in this subsection referred to as the “National Center”). The National Center shall carry out the duties set forth in paragraph (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d769c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program under this section shall be administered by the office in the Department that administers other postsecondary education programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d769d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subpart, the term “eligible entity” means an institution of higher education, a nonprofit organization, or partnership of two or more such institutions or organizations, with demonstrated expertise in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7d769e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting students with disabilities in postsecondary education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d769f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical knowledge necessary for the dissemination of information in accessible formats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d76a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" working with diverse types of institutions of higher education, including community colleges; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d76a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the subjects supported by the grants, contracts, or cooperative agreements authorized in subparts 1, 2, and 3.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d76a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of the National Center shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7d76a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to students and families","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Center shall provide information and technical assistance to students with disabilities and the families of students with disabilities to support students across the broad spectrum of disabilities, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d7d76a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information to assist individuals with disabilities who are prospective students of an institution of higher education in planning for postsecondary education while the students are in secondary school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d76a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information and technical assistance provided to individualized education program teams (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1414/d/1"},"text":"section 1414(d)(1) of this title","children":[],"tail":") for secondary school students with disabilities, and to early outreach and student services programs, including programs authorized under subparts 2, 4, and 5 of part A of subchapter IV, to support students across a broad spectrum of disabilities with the successful transition to postsecondary education;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d76a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research-based supports, services, and accommodations which are available in postsecondary settings, including services provided by other agencies such as vocational rehabilitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d76a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on student mentoring and networking opportunities for students with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d76a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective recruitment and transition programs at postsecondary educational institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d76a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to institutions of higher education","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Center shall provide information and technical assistance to faculty, staff, and administrators of institutions of higher education to improve the services provided to, the accommodations for, the retention rates of, and the completion rates of, students with disabilities in higher education settings, which may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d7d76aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collection and dissemination of best and promising practices and materials for accommodating and supporting students with disabilities, including practices and materials supported by the grants, contracts, or cooperative agreements authorized under subparts 1, 2, and 3;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d76ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development and provision of training modules for higher education faculty on exemplary practices for accommodating and supporting postsecondary students with disabilities across a range of academic fields, which may include universal design for learning and practices supported by the grants, contracts, or cooperative agreements authorized under subparts 1, 2, and 3; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d76ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of technology-based tutorials for higher education faculty and staff, including new faculty and graduate students, on best and promising practices related to support and retention of students with disabilities in postsecondary education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d76ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information collection and dissemination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Center shall be responsible for building, maintaining, and updating a database of disability support services information with respect to institutions of higher education, or for expanding and updating an existing database of disabilities support services information with respect to institutions of higher education. Such database shall be available to the general public through a website built to high technical standards of accessibility practicable for the broad spectrum of individuals with disabilities. Such database and website shall include available information on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d7d76ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disability documentation requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d76af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support services available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d76b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" links to financial aid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d76b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accommodations policies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d76b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accessible instructional materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d76b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other topics relevant to students with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d76b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information in the report described in subparagraph (E).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d76b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disability support services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Center shall work with organizations and individuals with proven expertise related to disability support services for postsecondary students with disabilities to evaluate, improve, and disseminate information related to the delivery of high quality disability support services at institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d76b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than three years after the establishment of the National Center, and every two years thereafter, the National Center shall prepare and disseminate a report to the Secretary and the authorizing committees analyzing the condition of postsecondary success for students with disabilities. Such report shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d7d76b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of the activities and the effectiveness of the programs authorized under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d76b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annual enrollment and graduation rates of students with disabilities in institutions of higher education from publicly reported data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d76b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for effective postsecondary supports and services for students with disabilities, and how such supports and services may be widely implemented at institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d76ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations on reducing barriers to full participation for students with disabilities in higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d76bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/E/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of strategies with a demonstrated record of effectiveness in improving the success of such students in postsecondary education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d76bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/a/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staffing of the Center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In hiring employees of the National Center, the National Center shall consider the expertise and experience of prospective employees in providing training and technical assistance to practitioners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7d76bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordinating center","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7d76be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “eligible entity” means an entity, or a partnership of entities, that has demonstrated expertise in the fields of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7d76bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d76c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the education of students with intellectual disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d76c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of comprehensive transition and postsecondary programs for students with intellectual disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d76c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluation and technical assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d76c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From amounts appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1140r"},"text":"section 1140r of this title","children":[],"tail":", the Secretary shall enter into a cooperative agreement, on a competitive basis, with an eligible entity for the purpose of establishing a coordinating center for institutions of higher education that offer inclusive comprehensive transition and postsecondary programs for students with intellectual disabilities, including institutions participating in grants authorized under subpart 2, to provide—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7d76c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations related to the development of standards for such programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d76c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance for such programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d76c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluations for such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d76c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program under this subsection shall be administered by the office in the Department that administers other postsecondary education programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d76c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall enter into a cooperative agreement under this subsection for a period of five years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d76c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements of cooperative agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The eligible entity entering into a cooperative agreement under this subsection shall establish and maintain a coordinating center that shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7d76ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the technical assistance entity for all comprehensive transition and postsecondary programs for students with intellectual disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d76cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance regarding the development, evaluation, and continuous improvement of such programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d76cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop an evaluation protocol for such programs that includes qualitative and quantitative methodologies for measuring student outcomes and program strengths in the areas of academic enrichment, socialization, independent living, and competitive or supported employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d76cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist recipients of grants under subpart 2 in efforts to award a meaningful credential to students with intellectual disabilities upon the completion of such programs, which credential shall take into consideration unique State factors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d76ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop recommendations for the necessary components of such programs, such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d7d76cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/5/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic, vocational, social, and independent living skills;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d76d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/5/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluation of student progress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d76d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/5/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" program administration and evaluation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d76d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/5/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" student eligibility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d76d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/5/E/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issues regarding the equivalency of a student’s participation in such programs to semester, trimester, quarter, credit, or clock hours at an institution of higher education, as the case may be;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7fe6d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze possible funding streams for such programs and provide recommendations regarding the funding streams;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7fe6d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop model memoranda of agreement for use between or among institutions of higher education and State and local agencies providing funding for such programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7fe6d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/5/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop mechanisms for regular communication, outreach and dissemination of information about comprehensive transition and postsecondary programs for students with intellectual disabilities under subpart 2 between or among such programs and to families and prospective students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7fe6d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/5/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" host a meeting of all recipients of grants under subpart 2 not less often than once each year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7fe6d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/5/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" convene a workgroup to develop and recommend model criteria, standards, and components of such programs as described in subparagraph (E), that are appropriate for the development of accreditation standards, which workgroup shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d7fe6d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/5/J/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an expert in higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7fe6da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/5/J/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an expert in special education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7fe6db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/5/J/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a disability organization that represents students with intellectual disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7fe6dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/5/J/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative from the National Advisory Committee on Institutional Quality and Integrity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7fe6dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/5/J/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative of a regional or national accreditation agency or association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7fe6de-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140q/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than five years after the date of the establishment of the coordinating center under this subsection, the coordinating center shall report to the Secretary, the authorizing committees, and the National Advisory Committee on Institutional Quality and Integrity on the recommendations of the workgroup described in paragraph (5)(J).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d7fe6df-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s777"},"text":"Pub. L. 89–329, title VII, § 777","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVII/s709/2"},"text":"Pub. L. 110–315, title VII, § 709(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3373"},"text":"122 Stat. 3373","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d7fe6e0-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d7fe6e1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d7fe6e2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s777"},"text":"section 777 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1132h–6"},"text":"section 1132h–6 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
