{"tag":"section","attrib":{"id":"id0e51b625-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7908a"},"text":null,"children":[{"tag":"num","attrib":{"value":"7908a"},"text":"§ 7908a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military recruiter access to secondary school campuses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each local educational agency receiving assistance under this chapter shall provide military recruiters the same access to the campus of each secondary school served by the local educational agency for the purpose of recruiting students who are at least 17 years of age that is provided to any prospective employer, institution of higher education, or other recruiter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e51b626-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8528A"},"text":"Pub. L. 89–10, title VIII, § 8528A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s533/a"},"text":"Pub. L. 118–159, div. A, title V, § 533(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1887"},"text":"138 Stat. 1887","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e51b627-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e51b628-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e51b629-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s533/b"},"text":"Pub. L. 118–159, div. A, title V, § 533(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1887"},"text":"138 Stat. 1887","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tV/s533/b"},"text":"“The amendment made by subsection (a) [enacting this section] shall take effect one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0e51b62a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Compliance Monitoring and Reporting","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s533/c"},"text":"Pub. L. 118–159, div. A, title V, § 533(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1887"},"text":"138 Stat. 1887","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tV/s533/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“On an annual basis, the Secretary of Defense shall—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect information from military recruiters regarding the compliance of local educational agencies with the requirements of section 8528A of the Elementary and Secondary Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7908a"},"text":"20 U.S.C. 7908a","children":[],"tail":"] (as added by subsection (a)); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" based on such information, prepare and submit to the Committees on Armed Services of the Senate and House of Representatives a report that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies each local educational agency that the Secretary determines to be in violation of such section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explains the reasons for such determination.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
