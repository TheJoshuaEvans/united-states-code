{"tag":"section","attrib":{"id":"id0d0fc00e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"1078–6"},"text":"§ 1078–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Default reduction program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d0fc00f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other repayment incentives","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d0fc010-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale or assignment of loan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d0fc011-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each guaranty agency, upon securing 9 payments made within 20 days of the due date during 10 consecutive months of amounts owed on a loan for which the Secretary has made a payment under paragraph (1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078/c"},"text":"section 1078(c) of this title","children":[],"tail":", shall—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0d0fc012-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if practicable, sell the loan to an eligible lender; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d0fc013-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning ","children":[{"tag":"date","attrib":{"date":"2014-07-01"},"text":"July 1, 2014","children":[],"tail":", assign the loan to the Secretary if the guaranty agency has been unable to sell the loan under clause (i)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d0fc014-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monthly payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Neither the guaranty agency nor the Secretary shall demand from a borrower as monthly payment amounts described in subparagraph (A) more than is reasonable and affordable based on the borrower’s total financial circumstances. With respect to a borrower who has 1 or more loans made under part D on or after ","children":[{"tag":"date","attrib":{"date":"2027-07-01"},"text":"July 1, 2027","children":[],"tail":" that are described in subparagraph (A), the total monthly payment of the borrower for all such loans shall not be less than $10."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d0fc015-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer reporting agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the sale or assignment of the loan, the Secretary, guaranty agency or other holder of the loan shall request any consumer reporting agency to which the Secretary, guaranty agency or holder, as applicable, reported the default of the loan, to remove the record of the default from the borrower’s credit history.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d0fc016-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties upon sale","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a loan sold under subparagraph (A)(i)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d0fc017-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the guaranty agency—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d0fc018-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/1/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, in the case of a sale made on or after ","children":[{"tag":"date","attrib":{"date":"2014-07-01"},"text":"July 1, 2014","children":[],"tail":", repay the Secretary 100 percent of the amount of the principal balance outstanding at the time of such sale, multiplied by the reinsurance percentage in effect when payment under the guaranty agreement was made with respect to the loan; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d0fc019-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/1/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may, in the case of a sale made on or after ","children":[{"tag":"date","attrib":{"date":"2014-07-01"},"text":"July 1, 2014","children":[],"tail":", in order to defray collection costs—"}],"tail":null},{"tag":"item","attrib":{"id":"id0d0fc01a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/1/D/i/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charge to the borrower an amount not to exceed 16 percent of the outstanding principal and interest at the time of the loan sale; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id0d0fc01b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/1/D/i/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain such amount from the proceeds of the loan sale; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d0fc01c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary shall reinstate the Secretary’s obligation to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d0fc01d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/1/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimburse the guaranty agency for the amount that the agency may, in the future, expend to discharge the guaranty agency’s insurance obligation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d0fc01e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/1/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay to the holder of such loan a special allowance pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087–1"},"text":"section 1087–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d0fc01f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties upon assignment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a loan assigned under subparagraph (A)(ii)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d0fc020-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the guaranty agency shall add to the principal and interest outstanding at the time of the assignment of such loan an amount equal to the amount described in subparagraph (D)(i)(II)(aa); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d0fc021-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall pay the guaranty agency, for deposit in the agency’s Operating Fund established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1072b"},"text":"section 1072b of this title","children":[],"tail":", an amount equal to the amount added to the principal and interest outstanding at the time of the assignment in accordance with clause (i)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d0fc022-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible lender limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A loan shall not be sold to an eligible lender under subparagraph (A)(i) if such lender has been found by the guaranty agency or the Secretary to have substantially failed to exercise the due diligence required of lenders under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d0fc023-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Default due to error","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A loan that does not meet the requirements of subparagraph (A) may also be eligible for sale or assignment under this paragraph upon a determination that the loan was in default due to clerical or data processing error and would not, in the absence of such error, be in a delinquent status.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d0fc024-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of proceeds of sales","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts received by the Secretary pursuant to the sale of such loans by a guaranty agency under paragraph (1)(A)(i) shall be deducted from the calculations of the amount of reimbursement for which the agency is eligible under paragraph (1)(D)(ii)(I) for the fiscal year in which the amount was received, notwithstanding the fact that the default occurred in a prior fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d0fc025-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Borrower eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any borrower whose loan is sold or assigned under paragraph (1)(A) shall not be precluded by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1091"},"text":"section 1091 of this title","children":[],"tail":" from receiving additional loans or grants under this subchapter (for which he or she is otherwise eligible) on the basis of defaulting on the loan prior to such loan sale or assignment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d0fc026-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of general loan conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A loan that is sold or assigned under paragraph (1) shall, so long as the borrower continues to make scheduled repayments thereon, be subject to the same terms and conditions and qualify for the same benefits and privileges as other loans made under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d0fc027-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A borrower may obtain the benefits available under this subsection with respect to rehabilitating a loan (whether by loan sale or assignment) only one time per loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d0fc028-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Satisfactory repayment arrangements to renew eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each guaranty agency shall establish a program which allows a borrower with a defaulted loan or loans to renew eligibility for all subchapter IV student financial assistance (regardless of whether the defaulted loan has been sold to an eligible lender or assigned to the Secretary) upon the borrower’s payment of 6 consecutive monthly payments. The guaranty agency shall not demand from a borrower as a monthly payment amount under this subsection more than is reasonable and affordable based upon the borrower’s total financial circumstances. A borrower may only obtain the benefit of this subsection with respect to renewed eligibility once.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d0fc029-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial and economic literacy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each program described in subsection (b) shall include making available financial and economic education materials for a borrower who has rehabilitated a loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d0fc02a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s428F"},"text":"Pub. L. 89–329, title IV, § 428F","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s402/a"},"text":"Pub. L. 99–498, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1394"},"text":"100 Stat. 1394","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/50/s10/u"},"text":"Pub. L. 100–50, § 10(u)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-06-03"},"text":"June 3, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/346"},"text":"101 Stat. 346","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tII/s2005/a"},"text":"Pub. L. 101–239, title II, § 2005(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2116"},"text":"103 Stat. 2116","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s420"},"text":"Pub. L. 102–325, title IV, § 420","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/534"},"text":"106 Stat. 534","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/c/38"},"text":"Pub. L. 103–208, § 2(c)(38)","children":[],"tail":"–(40), "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2466"},"text":"107 Stat. 2466","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s421"},"text":"Pub. L. 105–244, title IV, § 421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1696"},"text":"112 Stat. 1696","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/tVIII/s8014/h"},"text":"Pub. L. 109–171, title VIII, § 8014(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/171"},"text":"120 Stat. 171","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s426"},"text":"Pub. L. 110–315, title IV, § 426","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3235"},"text":"122 Stat. 3235","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tIV/s402/d/1"},"text":"Pub. L. 111–39, title IV, § 402(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1941"},"text":"123 Stat. 1941","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/67/dA/tV/s501"},"text":"Pub. L. 113–67, div. A, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1186"},"text":"127 Stat. 1186","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVIII/s82003/a/1"},"text":"Pub. L. 119–21, title VIII, § 82003(a)(1)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/348"},"text":"139 Stat. 348","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d0fc02b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id0d0fc02c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment of Subsection (a)(5)","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVIII/s82003/a/1"},"text":"Pub. L. 119–21, title VIII, § 82003(a)(1)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/348"},"text":"139 Stat. 348","children":[],"tail":", provided that, effective on "},{"tag":"date","attrib":{"date":"2027-07-01"},"text":"July 1, 2027","children":[],"tail":", and applicable with respect to any loan made, insured, or guaranteed under this subchapter, subsection (a)(5) of this section is amended by striking “one time” and inserting “two times”. See 2025 Amendment notes below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d0fc02d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d0fc02e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s82003/b"},"text":"Pub. L. 119–21, § 82003(b)","children":[],"tail":", inserted at end “With respect to a borrower who has 1 or more loans made under part D on or after "},{"tag":"date","attrib":{"date":"2027-07-01"},"text":"July 1, 2027","children":[],"tail":" that are described in subparagraph (A), the total monthly payment of the borrower for all such loans shall not be less than $10.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s82003/a/1"},"text":"Pub. L. 119–21, § 82003(a)(1)","children":[],"tail":", substituted “two times” for “one time”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/67/s501/1"},"text":"Pub. L. 113–67, § 501(1)","children":[],"tail":", added cl. (ii) and struck out former cl. (ii) which read as follows: “on or before "},{"tag":"date","attrib":{"date":"2011-09-30"},"text":"September 30, 2011","children":[],"tail":", assign the loan to the Secretary if—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(I) the Secretary has determined that market conditions unduly limit a guaranty agency’s ability to sell loans under clause (i); and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(II) the guaranty agency has been unable to sell loans under clause (i).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(D)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/67/s501/2"},"text":"Pub. L. 113–67, § 501(2)","children":[],"tail":", added cl. (i) and struck out former cl. (i) which read as follows: “the guaranty agency—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(I) shall repay the Secretary 81.5 percent of the amount of the principal balance outstanding at the time of such sale, multiplied by the reinsurance percentage in effect when payment under the guaranty agreement was made with respect to the loan; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(II) may, in order to defray collection costs—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(aa) charge to the borrower an amount not to exceed 18.5 percent of the outstanding principal and interest at the time of the loan sale; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(bb) retain such amount from the proceeds of the loan sale; and”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s402/d/1/A/i"},"text":"Pub. L. 111–39, § 402(d)(1)(A)(i)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) related to the sale of a loan by a guaranty agency or the Secretary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s402/d/1/A/ii"},"text":"Pub. L. 111–39, § 402(d)(1)(A)(ii)","children":[],"tail":", substituted “paragraph (1)(A)(i)” for “paragraph (1) of this subsection” and “paragraph (1)(D)(ii)(I)” for “paragraph (1)(B)(ii) of this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s402/d/1/A/iii/II"},"text":"Pub. L. 111–39, § 402(d)(1)(A)(iii)(II)","children":[],"tail":", substituted “sale or assignment.” for “sale.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s402/d/1/A/iii/I"},"text":"Pub. L. 111–39, § 402(d)(1)(A)(iii)(I)","children":[],"tail":", which directed substitution of “sold or assigned under paragraph (1)(A)” for “sold under paragraph (2)”, was executed by making the substitution for “sold under paragraph (1)” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s402/d/1/A/iv"},"text":"Pub. L. 111–39, § 402(d)(1)(A)(iv)","children":[],"tail":", substituted “that is sold or assigned under paragraph (1)” for “which is sold under paragraph (1) of this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s402/d/1/A/v"},"text":"Pub. L. 111–39, § 402(d)(1)(A)(v)","children":[],"tail":", inserted “(whether by loan sale or assignment)” after “rehabilitating a loan”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s402/d/1/B"},"text":"Pub. L. 111–39, § 402(d)(1)(B)","children":[],"tail":", inserted “or assigned to the Secretary” after “sold to an eligible lender”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s426/1/A"},"text":"Pub. L. 110–315, § 426(1)(A)","children":[],"tail":", inserted at end “Upon the sale of the loan to an eligible lender, the guaranty agency or other holder of the loan shall request any consumer reporting agency to which the guaranty agency or holder, as applicable, reported the default of the loan, to remove the record of default from the borrower’s credit history.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s426/1/B"},"text":"Pub. L. 110–315, § 426(1)(B)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s426/2"},"text":"Pub. L. 110–315, § 426(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s8014/h/1"},"text":"Pub. L. 109–171, § 8014(h)(1)","children":[],"tail":", substituted “9 payments made within 20 days of the due date during 10 consecutive months” for “consecutive payments for 12 months”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s8014/h/2"},"text":"Pub. L. 109–171, § 8014(h)(2)","children":[],"tail":", (3), added subpar. (C) and redesignated former subpar. (C) as (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" substituted “Satisfactory repayment arrangements to renew eligibility” for “Special rule” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/c/38"},"text":"Pub. L. 103–208, § 2(c)(38)","children":[],"tail":", substituted “paragraph (1) of this subsection” for “this paragraph” and “this subsection” for “this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/c/39"},"text":"Pub. L. 103–208, § 2(c)(39)","children":[],"tail":", substituted “paragraph (1) of this subsection” for “this paragraph”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/c/40"},"text":"Pub. L. 103–208, § 2(c)(40)","children":[],"tail":", inserted at end “A borrower may only obtain the benefit of this subsection with respect to renewed eligibility once.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s420/1"},"text":"Pub. L. 102–325, § 420(1)","children":[],"tail":"–(3), redesignated subsec. (b) as (a), in par. (1)(A) substituted “Each guaranty agency shall enter into an agreement with the Secretary which shall provide that upon” for “Upon” and inserted provision at end that neither the guaranty agency nor the Secretary demand from the borrower as monthly payments more than is reasonable and affordable based upon the borrower’s total financial circumstances, in par. (3) inserted “or grants” after “loans”, and struck out former subsec. (a) which related to program requirements for the default reduction program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s420/4"},"text":"Pub. L. 102–325, § 420(4)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" amended section generally, substituting provisions relating to default reduction program for former provisions relating to rehabilitation of defaulted loans."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/50"},"text":"Pub. L. 100–50","children":[],"tail":" redesignated subsec. (c) as (b) and struck out former subsec. (b) which read as follows: “The loans which shall be eligible for rehabilitation under this section shall be only those loans which are made to borrowers who, at the time of default on the loan, are unemployed or institutionalized.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d0fc02f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d0fc030-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVIII/s82003/a/3"},"text":"Pub. L. 119–21, title VIII, § 82003(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/348"},"text":"139 Stat. 348","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVIII/s82003/a/3"},"text":"“The amendments made by this subsection [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087dd"},"text":"section 1087dd of this title","children":[],"tail":"] shall take effect beginning on "},{"tag":"date","attrib":{"date":"2027-07-01"},"text":"July 1, 2027","children":[],"tail":", and shall apply with respect to any loan made, insured, or guaranteed under title IV of the Higher Education Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070"},"text":"20 U.S.C. 1070","children":[],"tail":" et seq.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d0fc031-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/67/dA/tV/s501"},"text":"Pub. L. 113–67, div. A, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1186"},"text":"127 Stat. 1186","children":[],"tail":", provided that the amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/113/67/s501"},"text":"section 501 of Pub. L. 113–67","children":[],"tail":" are effective "},{"tag":"date","attrib":{"date":"2014-07-01"},"text":"July 1, 2014","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d0fc032-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/tIV/s402/d/2"},"text":"Pub. L. 111–39, title IV, § 402(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1942"},"text":"123 Stat. 1942","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/39/tIV/s402/d/2"},"text":"“The amendments made by paragraph (1) [amending this section] shall be effective on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":"], and shall apply to any loan on which monthly payments described in section 428F(a)(1)(A) ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1078–6/a/1/A"},"text":"42 U.S.C. 1078–6(a)(1)(A)","children":[],"tail":"] were paid before, on, or after such date of enactment.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d0fc033-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171"},"text":"Pub. L. 109–171","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2006-07-01"},"text":"July 1, 2006","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/s8001/c"},"text":"section 8001(c) of Pub. L. 109–171","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"section 1002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d0fc034-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d0fc035-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208"},"text":"Pub. L. 103–208","children":[],"tail":" effective as if included in the Higher Education Amendments of 1992, "},{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s5/a"},"text":"section 5(a) of Pub. L. 103–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1051"},"text":"section 1051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d0fc036-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/50"},"text":"Pub. L. 100–50","children":[],"tail":" effective as if enacted as part of the Higher Education Amendments of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/50/s27"},"text":"section 27 of Pub. L. 100–50","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0d0fc037-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Publicity Through Communications Media of Availability of Default Reduction Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tII/s2005/b"},"text":"Pub. L. 101–239, title II, § 2005(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2118"},"text":"103 Stat. 2118","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/239/tII/s2005/b"},"text":"“The Secretary of Education shall, from funds available through student loan collections, commencing not less than 30 days before the beginning of the default reduction program required by the amendment made by this section [amending this section], and continuing throughout the duration of such program, widely publicize (through various communications media) the availability of the default reduction program.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
