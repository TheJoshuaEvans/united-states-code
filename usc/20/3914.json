{"tag":"section","attrib":{"id":"id0de18ec8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3914"},"text":null,"children":[{"tag":"num","attrib":{"value":"3914"},"text":"§ 3914.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Materials development and methods research for mathematics, science, and engineering","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de18ec9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3914/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization to award competitive grants; covered institutions, businesses, etc.; purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Foundation is authorized, in accordance with the provisions of this subchapter, to award competitive grants to institutions of higher education, businesses, nonprofit private organizations, local education agencies, professional engineering and scientific associations, museums, libraries, public broadcasting entities (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s397/11"},"text":"section 397(11) of title 47","children":[],"tail":"), and appropriate State agencies—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de18eca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3914/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for instructional curriculum improvement and faculty development in mathematics, science, and engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18ecb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3914/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for programs designed to enhance public understanding of mathematics, science, and engineering, including the use of public broadcasting entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18ecc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3914/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for research on methods of instruction and educational programs in mathematics, science, engineering, and critical foreign languages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de18ecd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3914/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of studies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Studies conducted under subsection (a)(3) may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de18ece-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3914/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" teaching and learning research and its application to local and private sector instructional materials development and to improved teacher training programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18ecf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3914/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on the use of local and informal science education activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18ed0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3914/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on recruitment, retention, and improvement of mathematics, science, engineering, and critical languages faculties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18ed1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3914/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analysis of materials and methods for mathematics, science, and engineering education used in other countries and their potential application in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de18ed2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3914/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching grant requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds awarded for such competitive grants shall be expended through a system requiring matching of the grant. The minimum amount required as a match shall be equal to a percentage of the grant that is determined by the Foundation. Funds made available for matching purposes may include in-kind services or other resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de18ed3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3914/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Materials or methods research application requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making grant applications for materials or methods research for the purposes described in subsections (a)(1) and (a)(3), the Foundation shall assure the involvement of appropriate State or local education agencies in the case of applications submitted by other entities described in subsection (a), or that one or more of such other entities will be consulted in the case of applications submitted by State or local education agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de18ed4-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tI/s104"},"text":"Pub. L. 98–377, title I, § 104","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/159/tII/s201"},"text":"Pub. L. 99–159, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-22"},"text":"Nov. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/895"},"text":"99 Stat. 895","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de18ed5-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de18ed6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0de18ed7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3914, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tI/s114"},"text":"Pub. L. 98–377, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-11"},"text":"Aug. 11, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1269"},"text":"98 Stat. 1269","children":[],"tail":", related to cooperation with business concerns, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/99/159/s201"},"text":"section 201 of Pub. L. 99–159","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3913/c"},"text":"section 3913(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
