. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":" substituted “2016” for “2015”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/174"},"text":"Pub. L. 113–174","children":[],"tail":" substituted “2015” for “2014”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" amended section generally, revising provisions relating to the National Advisory Committee on Institutional Quality and Integrity and extending its termination date from "},{"tag":"date","attrib":{"date":"2004-09-30"},"text":"Sept. 30, 2004","children":[],"tail":", to "},{"tag":"date","attrib":{"date":"2014-09-30"},"text":"September 30, 2014","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cbeb9a6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cbeb9a7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/tI/s106/c"},"text":"Pub. L. 110–315, title I, § 106(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3093"},"text":"122 Stat. 3093","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/315/tI/s106/c"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2009-01-01"},"text":"January 1, 2009","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0cbeb9a8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Committee","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75/dB/tIII/s305"},"text":"Pub. L. 119–75, div. B, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-02-03"},"text":"Feb. 3, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/305"},"text":"140 Stat. 305","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/75/dB/tIII/s305"},"text":"“Section 114(f) of the HEA [Higher Education Act of 1965] (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1011c/f"},"text":"20 U.S.C. 1011c(f)","children":[],"tail":") shall be applied by substituting ‘2026’ for ‘2021’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/47/dD/tIII/s305"},"text":"Pub. L. 118–47, div. D, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-23"},"text":"Mar. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/692"},"text":"138 Stat. 692","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dH/tIII/s305"},"text":"Pub. L. 117–328, div. H, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4897"},"text":"136 Stat. 4897","chi