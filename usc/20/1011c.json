{"tag":"section","attrib":{"id":"id0cbeb970-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1011c"},"text":"§ 1011c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Advisory Committee on Institutional Quality and Integrity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cbeb971-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Department a National Advisory Committee on Institutional Quality and Integrity (in this section referred to as the “Committee”) to assess the process of accreditation and the institutional eligibility and certification of institutions of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"section 1002 of this title","children":[],"tail":") under subchapter IV."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cbeb972-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cbeb973-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall have 18 members, of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cbeb974-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" six members shall be appointed by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cbeb975-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" six members shall be appointed by the Speaker of the House of Representatives, three of whom shall be appointed on the recommendation of the majority leader of the House of Representatives, and three of whom shall be appointed on the recommendation of the minority leader of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cbeb976-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" six members shall be appointed by the President pro tempore of the Senate, three of whom shall be appointed on the recommendation of the majority leader of the Senate, and three of whom shall be appointed on the recommendation of the minority leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbeb977-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Individuals shall be appointed as members of the Committee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cbeb978-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the basis of the individuals’ experience, integrity, impartiality, and good judgment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cbeb979-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from among individuals who are representatives of, or knowledgeable concerning, education and training beyond secondary education, representing all sectors and types of institutions of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"section 1002 of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cbeb97a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the basis of the individuals’ technical qualifications, professional standing, and demonstrated knowledge in the fields of accreditation and administration in higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbeb97b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (5), the term of office of each member of the Committee shall be for six years, except that any member appointed to fill a vacancy occurring prior to the expiration of the term for which the member’s predecessor was appointed shall be appointed for the remainder of such term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbeb97c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy on the Committee shall be filled in the same manner as the original appointment was made not later than 90 days after the vacancy occurs. If a vacancy occurs in a position to be filled by the Secretary, the Secretary shall publish a Federal Register notice soliciting nominations for the position not later than 30 days after being notified of the vacancy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbeb97d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The terms of office for the initial members of the Committee shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cbeb97e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three years for members appointed under paragraph (1)(A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cbeb97f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four years for members appointed under paragraph (1)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cbeb980-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" six years for members appointed under paragraph (1)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbeb981-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Committee shall select a chairperson from among the members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cbeb982-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cbeb983-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary with respect to establishment and enforcement of the standards of accrediting agencies or associations under subpart 2 of part H of subchapter IV;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbeb984-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary with respect to the recognition of a specific accrediting agency or association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbeb985-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary with respect to the preparation and publication of the list of nationally recognized accrediting agencies and associations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbeb986-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary with respect to the eligibility and certification process for institutions of higher education under subchapter IV, together with recommendations for improvements in such process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbeb987-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" advise the Secretary with respect to the relationship between—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cbeb988-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accreditation of institutions of higher education and the certification and eligibility of such institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cbeb989-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State licensing responsibilities with respect to such institutions; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbeb98a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out such other advisory functions relating to accreditation and institutional eligibility as the Secretary may prescribe by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cbeb98b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meeting procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cbeb98c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cbeb98d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biannual meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall meet not less often than twice each year, at the call of the Chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cbeb98e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall submit the date and location of each meeting in advance to the Secretary, and the Secretary shall publish such information in the Federal Register not later than 30 days before the meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbeb98f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agenda","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cbeb990-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The agenda for a meeting of the Committee shall be established by the Chairperson and shall be submitted to the members of the Committee upon notification of the meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cbeb991-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity for public comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The agenda shall include, at a minimum, opportunity for public comment during the Committee’s deliberations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbeb992-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary’s designee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate an employee of the Department to serve as the Secretary’s designee to the Committee, and the Chairperson shall invite the Secretary’s designee to attend all meetings of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbeb993-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall apply to the Committee, except that ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of title 5","children":[],"tail":" shall not apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cbeb994-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report and notice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cbeb995-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall annually publish in the Federal Register—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cbeb996-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a list containing, for each member of the Committee—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cbeb997-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the member’s name;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cbeb998-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the expiration of the member’s term of office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cbeb999-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/e/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the individual described in subsection (b)(1) who appointed the member; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cbeb99a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a solicitation of nominations for each expiring term of office on the Committee of a member appointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbeb99b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than the last day of each fiscal year, the Committee shall make available an annual report to the Secretary, the authorizing committees, and the public. The annual report shall contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cbeb99c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed summary of the agenda and activities of, and the findings and recommendations made by, the Committee during the fiscal year preceding the fiscal year in which the report is made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cbeb99d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the date and location of each meeting during the fiscal year preceding the fiscal year in which the report is made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cbeb99e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the members of the Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cbeb99f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the functions of the Committee, including any additional functions established by the Secretary through regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cbeb9a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall terminate on ","children":[{"tag":"date","attrib":{"date":"2021-09-30"},"text":"September 30, 2021","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002029"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002029"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Termination of Committee note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cbeb9a1-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s114"},"text":"Pub. L. 89–329, title I, § 114","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tI/s101/a"},"text":"Pub. L. 105–244, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1592"},"text":"112 Stat. 1592","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tI/s106/a"},"text":"Pub. L. 110–315, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3090"},"text":"122 Stat. 3090","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/174/s1"},"text":"Pub. L. 113–174, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-09-26"},"text"