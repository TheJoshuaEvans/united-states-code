{"tag":"section","attrib":{"id":"id0ded9d27-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4441"},"text":null,"children":[{"tag":"num","attrib":{"value":"4441"},"text":"§ 4441.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program for Native Hawaiian and Alaska Native culture and arts development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ded9d28-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4441/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Interior is authorized to make grants for the purpose of supporting programs for Native Hawaiian or Alaska Native culture and arts development to any nonprofit organization or institution which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ded9d29-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4441/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" primarily serves and represents Native Hawaiians or Alaska Natives, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ded9d2a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4441/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been recognized by the Governor of the State of Hawaii or the Governor of the State of Alaska, as appropriate, for the purpose of making such organization or institution eligible to receive such grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ded9d2b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4441/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants made under subsection (a) shall, to the extent deemed possible by the Secretary and the recipient of the grant, be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ded9d2c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4441/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide scholarly study of, and instruction in, Native Hawaiian or Alaska Native art and culture,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ded9d2d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4441/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish programs which culminate in the awarding of degrees in the various fields of Native Hawaiian or Alaska Native art and culture, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ded9d2e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4441/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish centers and programs with respect to Native Hawaiian or Alaska Native art and culture that are similar in purpose to the centers and programs described in subsections (b) and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4417"},"text":"section 4417 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ded9d2f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4441/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ded9d30-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4441/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any organization or institution which is the recipient of a grant made under subsection (a) shall establish a governing board to manage and control the program with respect to which such grant is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ded9d31-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4441/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For any grants made with respect to Native Hawaiian art and culture, the members of the governing board which is required to be established under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ded9d32-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4441/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include Native Hawaiians and individuals widely recognized in the field of Native Hawaiian art and culture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ded9d33-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4441/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve for a fixed term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ded9d34-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4441/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For any grants made with respect to Alaska Native art and culture, the members of the governing board which is required to be established under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ded9d35-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4441/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include Alaska Natives and individuals widely recognized in the field of Alaska Native art and culture,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ded9d36-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4441/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent the Eskimo, Indian and Aleut cultures of Alaska, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ded9d37-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4441/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve for a fixed term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ded9d38-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/498/tXV/s1521"},"text":"Pub. L. 99–498, title XV, § 1521","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1610"},"text":"100 Stat. 1610","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/239/tVII/s722/2"},"text":"Pub. L. 103–239, title VII, § 722(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-05-04"},"text":"May 4, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/606"},"text":"108 Stat. 606","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/74/dC/tI/s128"},"text":"Pub. L. 119–74, div. C, title I, § 128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-01-23"},"text":"Jan. 23, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/125"},"text":"140 Stat. 125","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ded9d39-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ded9d3a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0ded9d3b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2026—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/74/s128/1"},"text":"Pub. L. 119–74, § 128(1)","children":[],"tail":", struck out “private,” before “nonprofit organization” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/74/s128/2/A/i"},"text":"Pub. L. 119–74, § 128(2)(A)(i)","children":[],"tail":", substituted “include Native Hawaiians and” for “be Native Hawaiians or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/74/s128/2/A/ii"},"text":"Pub. L. 119–74, § 128(2)(A)(ii)","children":[],"tail":", (B), (D), redesignated subpar. (E) as (B) and struck out former subpar. (B) which read as follows: “include a representative of the Office of Hawaiian Affairs of the State of Hawaii,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/74/s128/2/B"},"text":"Pub. L. 119–74, § 128(2)(B)","children":[],"tail":", struck out subpars. (C) and (D) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) include the president of the University of Hawaii,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) include the president of the Bishop Museum, and”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/74/s128/2/A/ii"},"text":"Pub. L. 119–74, § 128(2)(A)(ii)","children":[],"tail":", (C), (D), struck out “of office” after “fixed term” and redesignated subpar. (E) as (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/239"},"text":"Pub. L. 103–239","children":[],"tail":" amended section generally, substituting provisions relating to development program for Native Hawaiian and Alaska Native culture and arts for provisions relating to development program for Native Hawaiian culture and arts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0ded9d3c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0ded9d3d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/239/s801"},"text":"Pub. L. 103–239, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-05-04"},"text":"May 4, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/607"},"text":"108 Stat. 607","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/239/s801"},"text":"“This Act [see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6101"},"text":"section 6101 of this title","children":[],"tail":"] shall take effect on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1994-05-04"},"text":"May 4, 1994","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
