{"tag":"section","attrib":{"id":"id0e350630-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7421"},"text":null,"children":[{"tag":"num","attrib":{"value":"7421"},"text":"§ 7421.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this subpart to support the efforts of local educational agencies, Indian tribes and organizations, and other entities in developing elementary school and secondary school programs for Indian students that are designed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e350631-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7421/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the unique cultural, language, and educational needs of such students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e350632-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7421/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that all students meet the challenging State academic standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e350633-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVI/s6111"},"text":"Pub. L. 89–10, title VI, § 6111","children":[],"tail":", formerly title VII, § 7111, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVII/s701"},"text":"Pub. L. 107–110, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1908"},"text":"115 Stat. 1908","children":[],"tail":"; renumbered title VI, § 6111, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVI"},"text":"Pub. L. 114–95, title VI","children":[],"tail":", §§ 6001(a), (b)(1), 6002(c), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2046"},"text":"129 Stat. 2046","children":[],"tail":", 2047.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e350634-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e350635-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e350636-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7421, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVII/s7111"},"text":"Pub. L. 89–10, title VII, § 7111","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3719"},"text":"108 Stat. 3719","children":[],"tail":", related to financial assistance for bilingual education, prior to the general amendment of former subchapter VII of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s6111"},"text":"section 6111 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7301"},"text":"section 7301 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e350637-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/c"},"text":"Pub. L. 114–95, § 6002(c)","children":[],"tail":", amended section generally. Prior to amendment, text read as follows: “It is the purpose of this subpart to support local educational agencies in their efforts to reform elementary school and secondary school programs that serve Indian students in order to ensure that such programs—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) are based on challenging State academic content and student academic achievement standards that are used for all students; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) are designed to assist Indian students in meeting those standards.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e350638-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e350639-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs 