{"tag":"section","attrib":{"id":"id0c772908-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s51"},"text":null,"children":[{"tag":"num","attrib":{"value":"51"},"text":"§ 51.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Library","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Regents shall make, from the interest of the fund, an appropriation, not exceeding an average of $25,000 annually, for the gradual formation of a library composed of valuable works pertaining to all departments of human knowledge.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c772909-3a70-11f1-a648-bee82ed8a795"},"text":"(R.S. § 5587.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c77290a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c77290b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0c77290c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5587 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1846-08-10/ch178/s8"},"text":"act Aug. 10, 1846, ch. 178, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/9/105"},"text":"9 Stat. 105","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0c77290d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0c77290e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Public Use of Research and Study Facilities of Certain Institutions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Under provisions of R.S. § 94 and ","children":[{"tag":"ref","attrib":{"href":"/us/act/1875-03-03/ch179"},"text":"act Mar. 3, 1875, ch. 179","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/18/512"},"text":"18 Stat. 512","children":[],"tail":", the Joint Committee on the Library of Congress was authorized to extend the use of the Library to the Regents of the Smithsonian Institution. These provisions were not classified to the Code, being rendered superfluous by a general declaration of public policy by Congress, by a joint resolution adopted "},{"tag":"date","attrib":{"date":"1892-04-12"},"text":"Apr. 12, 1892","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/27/395"},"text":"27 Stat. 395","children":[],"tail":", to the effect that facilities for study and research in the Library of Congress, the National Museum, and similar institutions shall be afforded investigators, students, etc., in the several states and territories as well as in the District of Columbia."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
