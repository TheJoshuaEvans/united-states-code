{"tag":"section","attrib":{"id":"id0dda8a5d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3473"},"text":null,"children":[{"tag":"num","attrib":{"value":"3473"},"text":"§ 3473.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reorganization of Department","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dda8a5e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3473/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization; limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized, subject to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3412/f"},"text":"section 3412(f) of this title","children":[],"tail":", to allocate or reallocate functions among the officers of the Department, and to establish, consolidate, alter, or discontinue such organizational entities within the Department as may be necessary or appropriate, but the authority of the Secretary under this subsection does not extend to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dda8a5f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3473/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any office, bureau, unit, or other entity transferred to the Department and established by statute or any function vested by statute in such an entity or officer of such an entity, except as provided in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dda8a60-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3473/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the abolition of organizational entities established by this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dda8a61-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3473/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alteration of the delegation of functions to any specific organizational entity required by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dda8a62-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3473/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alteration, consolidation, or discontinuance of statutory and organizational entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dda8a63-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3473/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may, in accordance with paragraph (2) of this subsection, consolidate, alter, or discontinue any of the following statutory entities, or reallocate any functions vested by statute in the following statutory entities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dda8a64-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3473/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of English Language Acquisition, Language Enhancement, and Academic Achievement for Limited English Proficient Students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dda8a65-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3473/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Teacher Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dda8a66-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3473/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Community College Unit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dda8a67-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3473/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Center for Education Statistics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dda8a68-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3473/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Institute of Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dda8a69-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3473/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Environmental Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dda8a6a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3473/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Consumers’ Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dda8a6b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3473/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Indian Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dda8a6c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3473/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Career Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dda8a6d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3473/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Non-Public Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dda8a6e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3473/b/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the bureau for the education and training for the handicapped; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dda8a6f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3473/b/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administrative units for guidance and counseling programs, the veterans’ cost of instruction program, and the program for the gifted and talented children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dda8a70-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3473/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may alter, consolidate, or discontinue any organizational entity continued within the Department and described in paragraph (1) of this subsection or reallocate any function vested by statute in such an entity, upon the expiration of a period of ninety days after the receipt by the Committee on Labor and Human Resources of the Senate and the Committee on Education and Labor of the House of Representatives of notice given by the Secretary containing a full and complete statement of the action proposed to be taken pursuant to this subsection and the facts and circumstances relied upon in support of such proposed action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dda8a71-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIV/s413"},"text":"Pub. L. 96–88, title IV, § 413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/684"},"text":"93 Stat. 684","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/496/tII/s202"},"text":"Pub. L. 96–496, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-04"},"text":"Dec. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2593"},"text":"94 Stat. 2593","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/e/tVII/s709/c"},"text":"Pub. L. 104–208, div. A, title I, § 101(e) [title VII, § 709(c)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-233"},"text":"110 Stat. 3009–233","children":[],"tail":", 3009–313; "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1072/b"},"text":"Pub. L. 107–110, title X, § 1072(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2089"},"text":"115 Stat. 2089","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dda8a72-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dda8a73-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0dda8a74-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":" substituted “Office of English Language Acquisition, Language Enhancement, and Academic Achievement for Limited English Proficient Students” for “Office of Bilingual Education”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1)(H) to (M). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" redesignated subpars. (I) to (M) as (H) to (L), respectively, and struck out former subpar. (H) which authorized Secretary to consolidate, alter, discontinue, or reallocate any functions vested by statute in Office of Libraries and Learning Resources."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/496"},"text":"Pub. L. 96–496","children":[],"tail":" redesignated subpar. (N) as (M) and struck out former subpar. (M), which authorized the Secretary to reallocate the functions or to alter or discontinue the Institute of Museum Services."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0dda8a75-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id0dda8a76-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Education and Labor of House of Representatives changed to Committee on Education and the Workforce of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Labor and Human Resources of Senate changed to Committee on Health, Education, Labor, and Pensions of Senate by Senate Resolution No. 20, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-19"},"text":"Jan. 19, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0dda8a77-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0dda8a78-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"National Institute of Education","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Institute of Education was established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1221e"},"text":"section 1221e of this title","children":[],"tail":" which as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tXIV/s1401/a"},"text":"Pub. L. 99–498, title XIV, § 1401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1589"},"text":"100 Stat. 1589","children":[],"tail":", provided objectives and duties for the Office of Educational Research and Improvement and established the National Advisory Council on Educational Research and Improvement, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/s1401/b"},"text":"section 1401(b) of Pub. L. 99–498","children":[],"tail":" transferred the property and records of the National Institute of Education to the Office of Educational Research and Improvement."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0dda8a79-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Office of Migrant Education","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/511/tVII/s701/b"},"text":"Pub. L. 98–511, title VII, § 701(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2405"},"text":"98 Stat. 2405","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/511/tVII/s701/b"},"text":"“For the purposes of section 413(a) of the Department of Education Organization Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3473"},"text":"20 U.S.C. 3473","children":[],"tail":"), the Office of Migrant Education shall be considered to be an organizational entity established by such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3401"},"text":"20 U.S.C. 3401","children":[],"tail":" et seq.] and shall not be subject to the reorganizational authority of the Secretary of Education under that section or any other provision of law.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
