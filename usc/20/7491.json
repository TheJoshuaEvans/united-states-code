{"tag":"section","attrib":{"id":"id0e39e894-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7491"},"text":null,"children":[{"tag":"num","attrib":{"value":"7491"},"text":"§ 7491.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e39e895-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7491/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adult","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “adult” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e39e896-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7491/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has attained the age of 16 years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e897-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7491/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has attained an age that is greater than the age of compulsory school attendance under an applicable State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e39e898-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7491/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Free public education","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “free public education” means education that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e39e899-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7491/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided at public expense, under public supervision and direction, and without tuition charge; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e89a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7491/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided as elementary or secondary education in the applicable State or to preschool children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e39e89b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7491/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Indian” means an individual who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e39e89c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7491/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a member of an Indian tribe or band, as membership is defined by the tribe or band, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e39e89d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7491/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any tribe or band terminated since 1940; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e39e89e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7491/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any tribe or band recognized by the State in which the tribe or band resides;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e89f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7491/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a descendant, in the first or second degree, of an individual described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e8a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7491/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considered by the Secretary of the Interior to be an Indian for any purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e8a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7491/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Eskimo, Aleut, or other Alaska Native; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e8a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7491/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of an organized Indian group that received a grant under the Indian Education Act of 1988 as in effect the day preceding ","children":[{"tag":"date","attrib":{"date":"1994-10-20"},"text":"October 20, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e39e8a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7491/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Traditional leaders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “traditional leaders” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2902"},"text":"section 2902 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e39e8a4-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVI/s6151"},"text":"Pub. L. 89–10, title VI, § 6151","children":[],"tail":", formerly title VII, § 7151, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVII/s701"},"text":"Pub. L. 107–110, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1931"},"text":"115 Stat. 1931","children":[],"tail":"; renumbered title VI, § 6151, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVI/s6001/a"},"text":"Pub. L. 114–95, title VI, § 6001(a)","children":[],"tail":", (b)(1), § 6002(s), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2046"},"text":"129 Stat. 2046","children":[],"tail":", 2062.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e39e8a5-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e39e8a6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e39e8a7-3a70-11f1-a648-bee82