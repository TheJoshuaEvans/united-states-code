{"tag":"section","attrib":{"id":"id0ca6ebad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s925"},"text":null,"children":[{"tag":"num","attrib":{"value":"925"},"text":"§ 925.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget request for school construction funds for Director of Dependents’ Education","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President shall include in his budget for each fiscal year a separate request for funds for construction of school facilities by the Director.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0ca6ebae-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXIV/s1406"},"text":"Pub. L. 95–561, title XIV, § 1406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2367"},"text":"92 Stat. 2367","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
