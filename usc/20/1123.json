{"tag":"section","attrib":{"id":"id0d6f1de4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1123"},"text":null,"children":[{"tag":"num","attrib":{"value":"1123"},"text":"§ 1123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Language resource centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d6f1de5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Language resource centers authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make grants to and enter into contracts with institutions of higher education, or consortia of such institutions, for the purpose of establishing, strengthening, and operating a small number of national language resource and training centers, which shall serve as resources to improve the capacity to teach and learn foreign languages effectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6f1de6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The activities carried out by the centers described in subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6f1de7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1123/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include effective dissemination efforts, whenever appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1de8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1123/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d6f1de9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1123/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct and dissemination of research on new and improved teaching methods, including the use of advanced educational technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1dea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1123/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and dissemination of new teaching materials reflecting the use of such research in effective teaching strategies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1deb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1123/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development, application, and dissemination of performance testing appropriate to an educational setting for use as a standard and comparable measurement of skill levels in all languages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1dec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1123/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training of teachers in the administration and interpretation of performance tests, the use of effective teaching strategies, and the use of new technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1ded-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1123/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a significant focus on the teaching and learning needs of the less commonly taught languages, including an assessment of the strategic needs of the United States, the determination of ways to meet those needs nationally, and the publication and dissemination of instructional materials in the less commonly taught languages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1dee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1123/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and dissemination of materials designed to serve as a resource for foreign language teachers at the elementary and secondary school levels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1def-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1123/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operation of intensive summer language institutes to train advanced foreign language students, to provide professional development, and to improve language instruction through preservice and inservice language training for teachers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6f1df0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1123/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under this section shall reflect the purposes of this part and be made on such conditions as the Secretary determines to be necessary to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6f1df1-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s603"},"text":"Pub. L. 89–329, title VI, § 603","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVI/s601"},"text":"Pub. L. 105–244, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1777"},"text":"112 Stat. 1777","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVI"},"text":"Pub. L. 110–315, title VI","children":[],"tail":", §§ 603, 610(a), "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3336"},"text":"122 Stat. 3336","children":[],"tail":", 3338.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d6f1df2-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d6f1df3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d6f1df4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1123, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s603"},"text":"Pub. L. 89–329, title VI, § 603","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tVI/s601/a"},"text":"Pub. L. 96–374, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1466"},"text":"94 Stat. 1466","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tVI/s603"},"text":"Pub. L. 99–498, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1515"},"text":"100 Stat. 1515","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tVI/s601"},"text":"Pub. L. 102–325, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/722"},"text":"106 Stat. 722","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/j/12"},"text":"Pub. L. 103–208, § 2(j)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2481"},"text":"107 Stat. 2481","children":[],"tail":", authorized grants for language resource centers, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1123, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s603"},"text":"Pub. L. 89–329, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1262"},"text":"79 Stat. 1262","children":[],"tail":", related to the State plans for carrying out the program of equipment grants to institutions of higher education, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/96/374"},"text":"Pub. L. 96–374","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d6f1df5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s610/a"},"text":"Pub. L. 110–315, § 610(a)","children":[],"tail":", substituted “consortia” for “combinations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s603"},"text":"Pub. L. 110–315, § 603","children":[],"tail":", inserted “reflect the purposes of this part and” after “section shall”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
