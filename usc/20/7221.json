{"tag":"section","attrib":{"id":"id0e291edf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221"},"text":null,"children":[{"tag":"num","attrib":{"value":"7221"},"text":"§ 7221.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this part to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e291ee0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the United States education system and education opportunities for all people in the United States by supporting innovation in public education in public school settings that prepare students to compete and contribute to the global economy and a stronger Nation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e291ee1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide financial assistance for the planning, program design, and initial implementation of charter schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e291ee2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the number of high-quality charter schools available to students across the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e291ee3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the impact of charter schools on student achievement, families, and communities, and share best practices between charter schools and other public schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e291ee4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage States to provide support to charter schools for facilities financing in an amount more nearly commensurate to the amount States typically provide for traditional public schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e291ee5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand opportunities for children with disabilities, English learners, and other traditionally underserved students to attend charter schools and meet the challenging State academic standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e291ee6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support efforts to strengthen the charter school authorizing process to improve performance management, including transparency, oversight and monitoring (including financial audits), and evaluation of such schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e291ee7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support quality, accountability, and transparency in the operational performance of all authorized public chartering agencies, including State educational agencies, local educational agencies, and other authorizing entities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e291ee8-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4301"},"text":"Pub. L. 89–10, title IV, § 4301","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4301/1"},"text":"Pub. L. 114–95, title IV, § 4301(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1993"},"text":"129 Stat. 1993","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e291ee9-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e291eea-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e291eeb-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7221, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4301"},"text":"Pub. L. 89–10, title IV, § 4301","children":[],"tail":", formerly title V, § 5201, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1788"},"text":"115 Stat. 1788","children":[],"tail":"; renumbered title IV, § 4301, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/t