{"tag":"section","attrib":{"id":"id0c799a7f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s71a"},"text":null,"children":[{"tag":"num","attrib":{"value":"71a"},"text":"§ 71a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additions; payment of construction costs from trust funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Trustees of the National Gallery of Art are authorized to construct within the area reserved as a site for future additions by the third sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s71"},"text":"section 71 of this title","children":[],"tail":" one or more buildings to serve as additions to the National Gallery of Art. The cost of constructing any such building shall be paid from trust funds administered by such Trustees. The plans and specifications for any such building shall be approved by the Commission of Fine Arts and the National Capital Planning Commission."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c799a80-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/376/s1"},"text":"Pub. L. 90–376, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-05"},"text":"July 5, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/286"},"text":"82 Stat. 286","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c799a81-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c799a82-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0c799a83-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-03-24/ch50"},"text":"act Mar. 24, 1937, ch. 50","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/51"},"text":"50 Stat. 51","children":[],"tail":", which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0c799a84-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0c799a85-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Jurisdiction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/376/s4"},"text":"Pub. L. 90–376, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-05"},"text":"July 5, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/286"},"text":"82 Stat. 286","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/376/s4"},"text":"“The Commissioner [Mayor] of the District of Columbia is authorized to transfer to the United States such jurisdiction as the District of Columbia may have over any of the property within the area referred to in the first section of this Act [this section].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0c799a86-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Public Utility: Payment of Cost of Relocation or Protection From Trust Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/376/s5"},"text":"Pub. L. 90–376, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-05"},"text":"July 5, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/286"},"text":"82 Stat. 286","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/376/s5"},"text":"“If any public utility (whether privately or publicly owned) located within the area referred to in the first section of this Act [this section] is required to be relocated or protected by reason of the construction within such area of any addition to the National Gallery of Art, the cost of such relocation or protection shall be paid from trust funds administered by the Trustees of the National Gallery of Art.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
