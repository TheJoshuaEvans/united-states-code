{"tag":"section","attrib":{"id":"id0e2e0139-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243"},"text":null,"children":[{"tag":"num","attrib":{"value":"7243"},"text":"§ 7243.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e2e013a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submissions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each statewide organization, or a consortium of such organizations, that desires a grant under this part shall submit an application to the Secretary at such time and in such manner as the Secretary may require, which shall include the information described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2e013b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application submitted under subsection (a) shall include, at a minimum, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2e013c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the applicant’s approach to family engagement in education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e013d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of how the State educational agency and any partner organization will support the statewide family engagement center that will be operated by the applicant including a description of the State educational agency and any partner organization’s commitment of such support.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e013e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A description of the applicant’s plan for building a statewide infrastructure for family engagement in education, that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2e013f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management and governance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e0140-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statewide leadership; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e0141-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" systemic services for family engagement in education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e0142-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the applicant’s demonstrated experience in providing training, information, and support to State educational agencies, local educational agencies, schools, educators, parents, and organizations on family engagement in education policies and practices that are effective for parents (including low-income parents) and families, parents of English learners, minorities, students with disabilities, homeless children and youth, children and youth in foster care, and migrant students, including evaluation results, reporting, or other data exhibiting such demonstrated experience.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e0143-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the steps the applicant will take to target services to low-income students and parents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e0144-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An assurance that the applicant will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2e0145-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish a special advisory committee, the membership of which includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e2e0146-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parents, who shall constitute a majority of the members of the special advisory committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2e0147-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of education professionals with expertise in improving services for disadvantaged children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2e0148-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of local elementary schools and secondary schools, including students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2e0149-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/6/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of the business community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2e014a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/6/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of State educational agencies and local educational agencies;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e014b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use not less than 65 percent of the funds received under this part in each fiscal year to serve local educational agencies, schools, and community-based organizations that serve high concentrations of disadvantaged students, including students who are English learners, minorities, students with disabilities, homeless children and youth, children and youth in foster care, and migrant students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e014c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate a statewide family engagement center of sufficient size, scope, and quality to ensure that the center is adequate to serve the State educational agency, local educational agencies, and community-based organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e014d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the statewide family engagement center will retain staff with the requisite training and experience to serve parents in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e014e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve urban, suburban, and rural local educational agencies and schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e014f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" work with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e2e0150-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/6/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other statewide family engagement centers assisted under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2e0151-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/6/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parent training and information centers and community parent resource centers assisted under sections 1471 and 1472 of this title;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e0152-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use not less than 30 percent of the funds received under this part for each fiscal year to establish or expand technical assistance for evidence-based parent education programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e0153-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/6/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assistance to State educational agencies, local educational agencies, and community-based organizations that support family members in supporting student academic achievement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e0154-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/6/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with State educational agencies, local educational agencies, schools, educators, and parents to determine parental needs and the best means for delivery of services to address such needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e0155-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/6/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct sufficient outreach to assist parents, including parents who the applicant may have a difficult time engaging with a school or local educational agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e0156-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/6/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct outreach to low-income students and parents, including low-income students and parents who are not proficient in English.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e0157-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assurance that the applicant will conduct training programs in the community to improve adult literacy, including financial literacy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2e0158-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7243/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants for activities described in this part, the Secretary shall give priority to statewide family engagement centers that will use funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7244"},"text":"section 7244 of this title","children":[],"tail":" for evidence-based activities, which, for the purposes of this part is defined as activities meeting the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801/21/A/i"},"text":"section 7801(21)(A)(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e2e0159-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4503"},"text":"Pub. L. 89–10, title IV, § 4503","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4501"},"text":"Pub. L. 114–95, title IV, § 4501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2017"},"text":"129 Stat. 2017","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e2e015a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e2e015b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e2e015c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 7243 to 7243c were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"Pub. L. 114–95, § 5","children":[],"tail":", title IV, § 4001(b)(1)(C), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1806"},"text":"129 Stat. 1806","children":[],"tail":", 1967, effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7243, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5411"},"text":"Pub. L. 89–10, title V, § 5411","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1811"},"text":"115 Stat. 1811","children":[],"tail":", related to programs authorized."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7243a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5412"},"text":"Pub. L. 89–10, title V, § 5412","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1812"},"text":"115 Stat. 1812","children":[],"tail":", related to applications for awards."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7243b, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5413"},"text":"Pub. L. 89–10, title V, § 5413","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1812"},"text":"115 Stat. 1812","children":[],"tail":", related to program requirements."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7243c, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5414"},"text":"Pub. L. 89–10, title V, § 5414","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1813"},"text":"115 Stat. 1813","children":[],"tail":", related to studies of national significance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e2e015d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e2e015e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
