{"tag":"section","attrib":{"id":"id0d9c6f40-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1402"},"text":null,"children":[{"tag":"num","attrib":{"value":"1402"},"text":"§ 1402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Special Education Programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d9c6f41-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1402/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be, within the Office of Special Education and Rehabilitative Services in the Department of Education, an Office of Special Education Programs, which shall be the principal agency in the Department for administering and carrying out this chapter and other programs and activities concerning the education of children with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9c6f42-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1402/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office established under subsection (a) shall be headed by a Director who shall be selected by the Secretary and shall report directly to the Assistant Secretary for Special Education and Rehabilitative Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9c6f43-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1402/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary and uncompensated services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":", the Secretary is authorized to accept voluntary and uncompensated services in furtherance of the purposes of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9c6f44-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s603"},"text":"Pub. L. 91–230, title VI, § 603","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2659"},"text":"118 Stat. 2659","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9c6f45-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9c6f46-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d9c6f47-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1402, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s603"},"text":"Pub. L. 91–230, title VI, § 603","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/17/tI/s101"},"text":"Pub. L. 105–17, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-04"},"tex