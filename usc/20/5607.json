{"tag":"section","attrib":{"id":"id0df71252-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607"},"text":null,"children":[{"tag":"num","attrib":{"value":"5607"},"text":"§ 5607.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures and audit of Trust Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0df71253-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall pay from the interest and earnings of the Trust Fund such sums as the Board determines are necessary and appropriate to enable the Foundation to carry out the provisions of this chapter, including a reasonable amount for official reception and representation expenses, as determined by the Board, not to exceed $5,000 for a fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0df71254-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit by Government Accountability Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The activities of the Foundation and the Center under this chapter may be audited by the Government Accountability Office under such rules and regulations as may be prescribed by the Comptroller General of the United States. Representatives of the Government Accountability Office shall have access to all books, accounts, records, reports filed and all other papers, things, or property belonging to or in use by the Foundation and the Center, pertaining to such federally assisted activities and necessary to facilitate the audit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0df71255-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/259/s9"},"text":"Pub. L. 102–259, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-03-19"},"text":"Mar. 19, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/83"},"text":"106 Stat. 83","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/156/s9/b"},"text":"Pub. L. 105–156, § 9(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-02-11"},"text":"Feb. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/12"},"text":"112 Stat. 12","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/90/s8"},"text":"Pub. L. 111–90, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-11-03"},"text":"Nov. 3, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2978"},"text":"123 Stat. 2978","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0df71256-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0df71257-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0df71258-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/90"},"text":"Pub. L. 111–90","children":[],"tail":" inserted before period at end “, including a reasonable amount for official reception and representation expenses, as determined by the Board, not to exceed $5,000 for a fiscal year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in heading and in two places in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/156"},"text":"Pub. L. 105–156","children":[],"tail":" substituted “Trust Fund” for “Fund”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
