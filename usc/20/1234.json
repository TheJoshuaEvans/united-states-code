{"tag":"section","attrib":{"id":"id0d97b4ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234"},"text":null,"children":[{"tag":"num","attrib":{"value":"1234"},"text":"§ 1234.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Administrative Law Judges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d97b4bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish in the Department of Education an Office of Administrative Law Judges (hereinafter in this subchapter referred to as the “Office”) which shall conduct—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d97b4bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recovery of funds hearings pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1234a"},"text":"section 1234a of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d97b4bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withholding hearings pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1234d"},"text":"section 1234d of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d97b4be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cease and desist hearings pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1234e"},"text":"section 1234e of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d97b4bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other proceedings designated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b4c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The administrative law judges (hereinafter “judges”) of the Office shall be appointed by the Secretary in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3105"},"text":"section 3105 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b4c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment requirements; chief judge","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The judges shall be officers or employees of the Department. The judges shall meet the requirements imposed for administrative law judges pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3105"},"text":"section 3105 of title 5","children":[],"tail":". In choosing among equally qualified candidates for such positions the Secretary shall give favorable consideration to the candidates’ experience in State or local educational agencies and their knowledge of the workings of Federal education programs in such agencies. The Secretary shall designate one of the judges of the Office to be the chief judge."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b4c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment of judges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of conducting hearings described in subsection (a), the chief judge shall assign a judge to each case or class of cases. A judge shall be disqualified in any case in which the judge has a substantial interest, has been of counsel, is or has been a material witness, or is so related to or connected with any party or the party’s attorney as to make it improper for the judge to be assigned to the case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b4c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and evidentiary functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The judge shall review and may require that evidence be taken on the sufficiency of the preliminary departmental determination as set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1234a"},"text":"section 1234a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b4c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conduct of proceedings; costs and fees of parties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d97b4c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The proceedings of the Office shall be conducted according to such rules as the Secretary shall prescribe by regulation in conformance with the rules relating to hearings in title 5, sections 554, 556, and 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d97b4c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of title 5, section 504, relating to costs and fees of parties, shall apply to the proceedings before the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b4c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discovery; scope, time, etc.; issue and enforcement of subpoenas","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d97b4c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In order to secure a fair, expeditious, and economical resolution of cases and where the judge determines that the discovered information is likely to elicit relevant information with respect to an issue in the case, is not sought primarily for the purposes of delay or harassment, and would serve the ends of justice, the judge may order a party to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d97b4c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produce relevant documents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d97b4ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" answer written interrogatories that inquire into relevant matters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d97b4cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have depositions taken.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The judge shall set a time limit of 90 days on the discovery period. The judge may extend this period for good cause shown. At the request of any party, the judge may establish a specific schedule for the conduct of discovery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d97b4cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to carry out the provisions of subsections (f)(1) and (g)(1), the judge is authorized to issue subpoenas and apply to the appropriate court of the United States for enforcement of a subpoena. The court may enforce the subpoena as if it pertained to a proceeding before that court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b4cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mediation of disputes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a process for the voluntary mediation of disputes pending before the Office. The mediator shall be agreed to by all parties involved in mediation and shall be independent of the parties to the dispute. In the mediation of disputes the Secretary shall consider mitigating circumstances and proportion of harm pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1234b"},"text":"section 1234b of this title","children":[],"tail":". In accordance with rule 408 of the Federal Rules of Evidence, evidence of conduct or statements made in compromise negotiations shall not be admissible in proceedings before the Office. Mediation shall be limited to 120 days, except that the mediator may grant extensions of such period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b4ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Professional personnel; employment, assignment, or transfer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall employ, assign, or transfer sufficient professional personnel, including judges of the Office, to ensure that all matters brought before the Office may be dealt with in a timely manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d97b4cf-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/tIV/s451"},"text":"Pub. L. 90–247, title IV, § 451","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXII/s1232"},"text":"Pub. L. 95–561, title XII, § 1232","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2346"},"text":"92 Stat. 2346","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/tIII/s3501/a"},"text":"Pub. L. 100–297, title III, § 3501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/349"},"text":"102 Stat. 349","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d97b4d0-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d97b4d1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d97b4d2-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Evidence, referred to in subsec. (h), are set out in the Appendix to Title 28, Judiciary and Judicial Procedure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d97b4d3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297"},"text":"Pub. L. 100–297","children":[],"tail":" amended section generally, substituting provisions relating to Office of Administrative Law Judges for provisions relating to Education Appeal Board."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d97b4d4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d97b4d5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297/tIII/s3501/b"},"text":"Pub. L. 100–297, title III, § 3501(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/357"},"text":"102 Stat. 357","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/297/tIII/s3501/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the amendments made by this section [enacting sections 1234f to 1234i of this title and amending this section and sections 1232d and 1234a to 1234e of this title] shall be effective 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by this part [part D (§ 3501) of title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297"},"text":"Pub. L. 100–297","children":[],"tail":", enacting sections 1234f to 1234i of this title and amending this section and sections 1232d and 1234a to 1234e of this title] shall not apply to any case in which the recipient, prior to the effective date of this part, received a written notice that such recipient must return funds to the Department.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d97b4d6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter effective 120 days after ","children":[{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/561/s1261"},"text":"section 1261 of Pub. L. 95–561","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232c"},"text":"section 1232c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
