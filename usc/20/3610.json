{"tag":"section","attrib":{"id":"id0ddcd4e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3610"},"text":null,"children":[{"tag":"num","attrib":{"value":"3610"},"text":"§ 3610.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ddcd4e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3610/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “asbestos” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ddcd4e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3610/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chrysotile, amosite, or crocidolite; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ddcd4e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3610/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in fibrous form, tremolite, anthophyllite, or actinolite;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddcd4ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3610/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Attorney General” means the Attorney General of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddcd4eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3610/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “imminent hazard to the health and safety” means, for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3605"},"text":"section 3605 of this title","children":[],"tail":", that an asbestos material is, according to standards established by the Secretary, friable or easily damaged, or within easy reach of students or otherwise susceptible to damage (including damage from water or air circulation) which could result in the dispersal of asbestos fibers into the school environment;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddcd4ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3610/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “local educational agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ddcd4ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3610/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any local educational agency as defined in section 198(a)(10) ","children":[{"tag":"ref","attrib":{"idref":"fn002152"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002152"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Elementary and Secondary Education Act of 1965;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ddcd4ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3610/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the governing authority of any nonprofit elementary or secondary school;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddcd4ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3610/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “nonprofit elementary or secondary school” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ddcd4f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3610/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any elementary or secondary school (as defined in section 198(a)(7) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of the Elementary and Secondary Education Act of 1965) owned and operated by one or more nonprofit corporations or associations no part of the net earnings of which inures, or may lawfully inure, to the benefit of any private shareholder or individual, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ddcd4f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3610/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any school of any agency of the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddcd4f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3610/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “school buildings” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ddcd4f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3610/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" structures suitable for use as classrooms, laboratories, libraries, school eating facilities, or facilities used for the preparation of food;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ddcd4f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3610/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any gymnasium or other facility which is specially designed for athletic or recreational activities for an academic course in physical education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ddcd4f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3610/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other facilities used for the instruction of students, for research, or for the administration of educational or research programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ddcd4f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3610/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintenance, storage, or utility facilities essential to the operation of the facilities described in subparagraphs (A) through (C) of this paragraph;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddcd4f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3610/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Education, or his designee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddcd4f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3610/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means each of the several States, the District of Columbia, the Commonwealth of Puerto Rico, Guam, American Samoa, the Virgin Islands, the Northern Mariana Islands, the Trust Territory of the Pacific Islands, the Bureau of Indian Affairs, and the Office of Overseas Schools of the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddcd4f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3610/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State educational agency” has the same meaning given such term by section 198(a)(17) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of the Elementary and Secondary Education Act of 1965."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ddcd4fa-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/270/s11"},"text":"Pub. L. 96–270, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-14"},"text":"June 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/496"},"text":"94 Stat. 496","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ddcd4fb-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ddcd4fc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0ddcd4fd-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 198 of the Elementary and Secondary Education