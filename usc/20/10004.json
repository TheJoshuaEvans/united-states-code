{"tag":"section","attrib":{"id":"id0e70af01-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10004"},"text":null,"children":[{"tag":"num","attrib":{"value":"10004"},"text":"§ 10004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds by institutions of higher education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e70af02-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A public institution of higher education that receives funds under this chapter shall use the funds for education and general expenditures, and in such a way as to mitigate the need to raise tuition and fees for in-State students, or for modernization, renovation, or repair of institution of higher education facilities that are primarily used for instruction, research, or student housing, including modernization, renovation, and repairs that are consistent with a recognized green building rating system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e70af03-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution of higher education may not use funds received under this chapter to increase its endowment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e70af04-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10004/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional prohibition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No funds awarded under this chapter may be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e70af05-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10004/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maintenance of systems, equipment, or facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e70af06-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10004/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modernization, renovation, or repair of stadiums or other facilities primarily used for athletic contests or exhibitions or other events for which admission is charged to the general public; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e70af07-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10004/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" modernization, renovation, or repair of facilities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e70af08-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10004/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used for sectarian instruction or religious worship; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e70af09-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10004/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which a substantial portion of the functions of the facilities are subsumed in a religious mission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e70af0a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tXIV/s14004"},"text":"Pub. L. 111–5, div. A, title XIV, § 14004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/281"},"text":"123 Stat. 281","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
