{"tag":"section","attrib":{"id":"id0cec0b85-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–26"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070a–26"},"text":"§ 1070a–26.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 21st Century Scholar Certificates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cec0b86-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–26/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity that receives a grant under this division shall provide certificates, to be known as 21st Century Scholar Certificates, to all students served by the eligible entity who are participating in a program under this division.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cec0b87-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–26/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A 21st Century Scholar Certificate shall be personalized for each student and indicate the amount of Federal financial aid for college and the estimated amount of any scholarship provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–25"},"text":"section 1070a–25 of this title","children":[],"tail":", if applicable, that a student may be eligible to receive."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cec0b88-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s404F"},"text":"Pub. L. 89–329, t