{"tag":"section","attrib":{"id":"id0d6a6347-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1103a"},"text":"§ 1103a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver authority and reporting requirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d6a6348-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver requirements; need-based assistance students","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may waive the requirements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1101a/a/2/A/i"},"text":"section 1101a(a)(2)(A)(i) of this title","children":[],"tail":" in the case of an institution—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6a6349-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is extensively subsidized by the State in which the institution is located and charges low or no tuition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a634a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that serves a substantial number of low-income students as a percentage of the institution’s total student population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a634b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is contributing substantially to increasing higher education opportunities for educationally disadvantaged, underrepresented, or minority students, who are low-income individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a634c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is substantially increasing higher educational opportunities for individuals in rural or other isolated areas which are unserved by postsecondary institutions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a634d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wherever located, if the Secretary determines that the waiver will substantially increase higher education opportunities appropriate to the needs of Hispanic Americans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6a634e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver determinations; expenditures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6a634f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive the requirements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1101a/a/2/A/ii"},"text":"section 1101a(a)(2)(A)(ii) of this title","children":[],"tail":" if the Secretary determines, based on persuasive evidence submitted by the institution, that the institution’s failure to meet the requirements is due to factors which, when used in the determination of compliance with the requirements, distort such determination, and that the institution’s designation as an eligible institution under part A is otherwise consistent with the purposes of this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a6350-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit to Congress every other year a report concerning the institutions that, although not satisfying the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1101a/a/2/A/ii"},"text":"section 1101a(a)(2)(A)(ii) of this title","children":[],"tail":", have been determined to be eligible institutions under part A. Such report shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d6a6351-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the factors referred to in paragraph (1) that were considered by the Secretary as factors that distorted the determination of compliance with clauses (i) and (ii) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1101a/a/2/A"},"text":"section 1101a(a)(2)(A) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6a6352-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain a list of each institution determined to be an eligible institution under part A including a statement of the reasons for each such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6a6353-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tV/s522"},"text":"Pub. L. 89–329, title V, § 522","children":[],"tail":", formerly § 512, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tV/s501"},"text":"Pub. L. 105–244, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1772"},"text":"112 Stat. 1772","children":[],"tail":"; renumbered § 522, "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tV/s502/a/2"},"text":"Pub. L. 110–315, title V, § 502(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3331"},"text":"122 Stat. 3331","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d6a6354-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d6a6355-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d6a6356-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1103a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/