{"tag":"section","attrib":{"id":"id0e567232-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9101"},"text":null,"children":[{"tag":"num","attrib":{"value":"9101"},"text":"§ 9101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e567233-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determined to be obscene","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “determined to be obscene” means determined, in a final judgment of a court of record and of competent jurisdiction in the United States, to be obscene.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e567234-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Digital literacy skills","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “digital literacy skills” means the skills associated with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e567235-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9101/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using technology to enable users to find, evaluate, organize, create, and communicate information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e58e136-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9101/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing digital citizenship and the responsible use of technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e58e137-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the Institute appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9103"},"text":"section 9103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e58e138-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9101/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final judgment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “final judgment” means a judgment that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e58e139-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9101/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not reviewed by any other court that has authority to review such judgment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e58e13a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9101/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not reviewable by any other court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e58e13b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9101/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” means any tribe, band, nation, or other organized group or community, including any Alaska native village, regional corporation, or village corporation (as defined in, or established pursuant to, the Alaska Native Claims Settlement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.)), which is recognized as eligible for the special programs and services provided by the United States to Indians because of their status as Indians."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e58e13c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9101/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institute","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Institute” means the Institute of Museum and Library Services established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9102"},"text":"section 9102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e58e13d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9101/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Museum and Library Services Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Museum and Library Services Board” means the National Museum and Library Services Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9105a"},"text":"section 9105a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e58e13e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9101/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obscene","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “obscene” means, with respect to a project, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e58e13f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9101/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average person, applying contemporary community standards, would find that such project, when taken as a whole, appeals to the prurient interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e58e140-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9101/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such project depicts or describes sexual conduct in a patently offensive way; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e58e141-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9101/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such project, when taken as a whole, lacks serious literary, artistic, political, or scientific value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e58e142-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/462/tII/s202"},"text":"Pub. L. 94–462, title II, § 202","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/e/tVII/s702"},"text":"Pub. L. 104–208, div. A, title I, § 101(e) [title VII, § 702]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-233"},"text":"110 Stat. 3009–233","children":[],"tail":", 3009–294; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/81/tI/s101"},"text":"Pub. L. 108–81, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-25"},"text":"Sept. 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/992"},"text":"117 Stat. 992","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/340/tI/s101"},"text":"Pub. L. 111–340, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3595"},"text":"124 Stat. 3595","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/410/s2"},"text":"Pub. L. 115–410, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5412"},"text":"132 Stat. 5412","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e58e143-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e58e144-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e58e145-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Alaska Native Claims Settlement Act, referred to in par. (5), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203"},"text":"Pub. L. 92–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"Dec. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/688"},"text":"85 Stat. 688","children":[],"tail":", which is classified generally to chapter 33 (§ 1601 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"section 1601 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e58e146-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/462/s202"},"text":"section 202 of Pub. L. 94–462","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s961"},"text":"section 961 of this title","children":[],"tail":" prior to the general amendment of title II of "},{"tag":"ref","attrib":{"href":"/us/pl/94/462"},"text":"Pub. L. 94–462","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e58e147-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/410/s2/1"},"text":"Pub. L. 115–410, § 2(1)","children":[],"tail":", substituted “means the skills associated with—” and subpars. (A) and (B) for “means the skills associated with using technology to enable users to find, evaluate, organize, create, and communicate information.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/410/s2/2"},"text":"Pub. L. 115–410, § 2(2)","children":[],"tail":", struck out “by the Secretary of the Interior” after “which is recognized”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Pars. (2) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/340"},"text":"Pub. L. 111–340","children":[],"tail":" added par. (2) and redesignated former pars. (2) to (7) as (3) to (8), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/81/s101/1"},"text":"Pub. L. 108–81, § 101(1)","children":[],"tail":", added par. (1) and struck out heading and text of former par. (1). Text read as follows: “The term ‘Commission’ means the National Commission on Libraries and Information Science established under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1502"},"text":"section 1502 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/81/s101/2"},"text":"Pub. L. 108–81, § 101(2)","children":[],"tail":"–(4), added pars. (3) and (4), redesignated former par. (3) as (5), and struck out heading and text of former par. (4). Text read as follows: “The term ‘Museum Board’ means the National Museum Services Board established under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9175"},"text":"section 9175 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/81/s101/5"},"text":"Pub. L. 108–81, § 101(5)","children":[],"tail":", added pars. (6) and (7)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e58e148-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e58e149-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/81/tV/s506"},"text":"Pub. L. 108–81, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-25"},"text":"Sept. 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1005"},"text":"117 Stat. 1005","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/81/tV/s506"},"text":"“The amendments made by this Act [enacting sections 9105a and 9107 to 9109 of this title, amending this section, sections 956a, 974, 1503 to 1505, 9102, 9103, 9106, 9121 to 9123, 9131, 9134, 9141, 9162, 9171 to 9173, and 9176 of this title, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s170"},"text":"section 170 of Title 26","children":[],"tail":", Internal Revenue Code, repealing sections 9174 and 9175 of this title, enacting provisions set out as a note under this section, and repealing provisions set out as notes under sections 9102, 9103, and 9105 of this title] shall take effect on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2003-09-25"},"text":"Sept. 25, 2003","children":[],"tail":"], except that the amendments made by sections 203, 204, and 305 of this Act [amending sections 9123, 9131, and 9176 of this title] shall take effect on "},{"tag":"date","attrib":{"date":"2003-10-01"},"text":"October 1, 2003","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"to