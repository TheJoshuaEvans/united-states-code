{"tag":"section","attrib":{"id":"id0d95443d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1232h"},"text":"§ 1232h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of pupil rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d95443e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection of instructional materials by parents or guardians","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All instructional materials, including teacher’s manuals, films, tapes, or other supplementary material which will be used in connection with any survey, analysis, or evaluation as part of any applicable program shall be available for inspection by the parents or guardians of the children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d95443f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limits on survey, analysis, or evaluations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No student shall be required, as part of any applicable program, to submit to a survey, analysis, or evaluation that reveals information concerning—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d954440-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" political affiliations or beliefs of the student or the student’s parent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d954441-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mental or psychological problems of the student or the student’s family;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d954442-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sex behavior or attitudes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d954443-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" illegal, anti-social, self-incriminating, or demeaning behavior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d954444-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" critical appraisals of other individuals with whom respondents have close family relationships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d954445-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legally recognized privileged or analogous relationships, such as those of lawyers, physicians, and ministers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d954446-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" religious practices, affiliations, or beliefs of the student or student’s parent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d954447-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" income (other than that required by law to determine eligibility for participation in a program or for receiving financial assistance under such program),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"without the prior consent of the student (if the student is an adult or emancipated minor), or in the case of an unemancipated minor, without the prior written consent of the parent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d954448-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of local policies concerning student privacy, parental access to information, and administration of certain physical examinations to minors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d954449-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development and adoption of local policies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsections (a) and (b), a local educational agency that receives funds under any applicable program shall develop and adopt policies, in consultation with parents, regarding the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d95444a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d95444b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right of a parent of a student to inspect, upon the request of the parent, a survey created by a third party before the survey is administered or distributed by a school to a student; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d95444c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any applicable procedures for granting a request by a parent for reasonable access to such survey within a reasonable period of time after the request is received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d95444d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Arrangements to protect student privacy that are provided by the agency in the event of the administration or distribution of a survey to a student containing one or more of the following items (including the right of a parent of a student to inspect, upon the request of the parent, any survey containing one or more of such items):","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d97b44e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Political affiliations or beliefs of the student or the student’s parent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d97b44f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mental or psychological problems of the student or the student’s family.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d97b450-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sex behavior or attitudes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d97b451-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Illegal, anti-social, self-incriminating, or demeaning behavior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d97b452-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Critical appraisals of other individuals with whom respondents have close family relationships.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d97b453-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Legally recognized privileged or analogous relationships, such as those of lawyers, physicians, and ministers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d97b454-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/1/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Religious practices, affiliations, or beliefs of the student or the student’s parent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d97b455-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/1/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Income (other than that required by law to determine eligibility for participation in a program or for receiving financial assistance under such program).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d97b456-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d97b457-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right of a parent of a student to inspect, upon the request of the parent, any instructional material used as part of the educational curriculum for the student; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d97b458-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any applicable procedures for granting a request by a parent for reasonable access to instructional material within a reasonable period of time after the request is received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d97b459-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The administration of physical examinations or screenings that the school or agency may administer to a student.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d97b45a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The collection, disclosure, or use of personal information collected from students for the purpose of marketing or for selling that information (or otherwise providing that information to others for that purpose), including arrangements to protect student privacy that are provided by the agency in the event of such collection, disclosure, or use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d97b45b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d97b45c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right of a parent of a student to inspect, upon the request of the parent, any instrument used in the collection of personal information under subparagraph (E) before the instrument is administered or distributed to a student; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d97b45d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any applicable procedures for granting a request by a parent for reasonable access to such instrument within a reasonable period of time after the request is received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d97b45e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parental notification","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d97b45f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of policies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The policies developed by a local educational agency under paragraph (1) shall provide for reasonable notice of the adoption or continued use of such policies directly to the parents of students enrolled in schools served by that agency. At a minimum, the agency shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d97b460-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such notice at least annually, at the beginning of the school year, and within a reasonable period of time after any substantive change in such policies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d97b461-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer an opportunity for the parent (and for purposes of an activity described in subparagraph (C)(i), in the case of a student of an appropriate age, the student) to opt the student out of participation in an activity described in subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d97b462-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of specific events","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The local educational agency shall directly notify the parent of a student, at least annually at the beginning of the school year, of the specific or approximate dates during the school year when activities described in subparagraph (C) are scheduled, or expected to be scheduled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d97b463-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities requiring notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following activities require notification under this paragraph:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d97b464-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Activities involving the collection, disclosure, or use of personal information collected from students for the purpose of marketing or for selling that information (or otherwise providing that information to others for that purpose).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d97b465-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The administration of any survey containing one or more items described in clauses (i) through (viii) of paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d97b466-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any nonemergency, invasive physical examination or screening that is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d97b467-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/2/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required as a condition of attendance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d97b468-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/2/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administered by the school and scheduled by the school in advance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d97b469-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/2/C/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not necessary to protect the immediate health and safety of the student, or of other students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d97b46a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing policies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local educational agency need not develop and adopt new policies if the State educational agency or local educational agency has in place, on ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":", policies covering the requirements of paragraph (1). The agency shall provide reasonable notice of such existing policies to parents and guardians of students, in accordance with paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d97b46b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d97b46c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational products or services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1)(E) does not apply to the collection, disclosure, or use of personal information collected from students for the exclusive purpose of developing, evaluating, or providing educational products or services for, or to, students or educational institutions, such as the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d97b46d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" College or other postsecondary education recruitment, or military recruitment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d97b46e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Book clubs, magazines, and programs providing access to low-cost literary products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d97b46f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Curriculum and instructional materials used by elementary schools and secondary schools.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d97b470-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tests and assessments used by elementary schools and secondary schools to provide cognitive, evaluative, diagnostic, clinical, aptitude, or achievement information about students (or to generate other statistically useful data for the purpose of securing such tests and assessments) and the subsequent analysis and public release of the aggregate data from such tests and assessments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d97b471-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/4/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The sale by students of products or services to raise funds for school-related or education-related activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d97b472-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/4/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Student recognition programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d97b473-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State law exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of this subsection—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d97b474-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be construed to preempt applicable provisions of State law that require parental notification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d97b475-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not apply to any physical examination or screening that is permitted or required by an applicable State law, including physical examinations or screenings that are permitted without parental notification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d97b476-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d97b477-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d97b478-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not supersede ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232g"},"text":"section 1232g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d97b479-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1)(D) does not apply to a survey administered to a student in accordance with the Individuals with Disabilities Education Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"20 U.S.C. 1400","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d97b47a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rights provided to parents under this section transfer to the student when the student turns 18 years old, or is an emancipated minor (under an applicable State law) at any age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d97b47b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall annually inform each State educational agency and each local educational agency of the educational agency’s obligations under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232g"},"text":"section 1232g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d97b47c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State educational agency or local educational agency may use funds provided under part A of title IV of the Elementary and Secondary Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7101"},"text":"20 U.S.C. 7101","children":[],"tail":" et seq.] to enhance parental involvement in areas affecting the in-school privacy of students."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d97b47d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d97b47e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Instructional material","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “instructional material” means instructional content that is provided to a student, regardless of its format, including printed or representational materials, audio-visual materials, and materials in electronic or digital formats (such as materials accessible through the Internet). The term does not include academic tests or academic assessments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d97b47f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Invasive physical examination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “invasive physical examination” means any medical examination that involves the exposure of private body parts, or any act during such examination that includes incision, insertion, or injection into the body, but does not include a hearing, vision, or scoliosis screening.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d97b480-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local educational agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “local educational agency” means an elementary school, secondary school, school district, or local board of education that is the recipient of funds under an applicable program, but does not include a postsecondary institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d97b481-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “parent” includes a legal guardian or other person standing in loco parentis (such as a grandparent or stepparent with whom the child lives, or a person who is legally responsible for the welfare of the child).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d97b482-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “personal information” means individually identifiable information including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d97b483-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/6/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a student or parent’s first and last name;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d97b484-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/6/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a home or other physical address (including street name and the name of the city or town);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d97b485-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/6/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a telephone number; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d97b486-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/6/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Social Security identification number.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d97b487-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “student” means any elementary school or secondary school student.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d97b488-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/c/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “survey” includes an evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b489-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Educational agencies and institutions shall give parents and students effective notice of their rights under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b48a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall take such action as the Secretary determines appropriate to enforce this section, except that action to terminate assistance provided under an applicable program shall be taken only if the Secretary determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d97b48b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there has been a failure to comply with such section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d97b48c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with such section cannot be secured by voluntary means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b48d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232h/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office and review board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish or designate an office and review board within the Department of Education to investigate, process, review, and adjudicate violations of the rights established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d97b48e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/tIV/s445"},"text":"Pub. L. 90–247, title IV, § 445","children":[],"tail":", formerly § 439, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/380/tV/s514/a"},"text":"Pub. L. 93–380, title V, § 514(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/574"},"text":"88 Stat. 574","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXII/s1250"},"text":"Pub. L. 95–561, title XII, § 1250","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2355"},"text":"92 Stat. 2355","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/227/tX/s1017"},"text":"Pub. L. 103–227, title X, § 1017","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"Mar. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/268"},"text":"108 Stat. 268","children":[],"tail":"; renumbered § 445, "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tII/s212/b/1"},"text":"Pub. L. 103–382, title II, § 212(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3913"},"text":"108 Stat. 3913","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1061"},"text":"Pub. L. 107–110, title X, § 1061","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2083"},"text":"115 Stat. 2083","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/mm/5"},"text":"Pub. L. 114–95, title IX, § 9215(mm)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2176"},"text":"129 Stat. 2176","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d97b48f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d97b490-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d97b491-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Individuals with Disabilities Education Act, referred to in subsec. (c)(5)(A)(ii), is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230"},"text":"Pub. L. 91–230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/175"},"text":"84 Stat. 175","children":[],"tail":", which is classified generally to chapter 33 (§ 1400 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Elementary and Secondary Education Act of 1965, referred to in subsec. (c)(5)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-04-11"},"text":"Apr. 11, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/27"},"text":"79 Stat. 27","children":[],"tail":". Part A of title IV of the Act is classified generally to part A (§ 7101 et seq.) of subchapter IV of chapter 70 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d97b492-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/s445"},"text":"section 445 of Pub. L. 90–247","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1233d"},"text":"section 1233d of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d97b493-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (c)(5)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" substituted “part A of title IV” for “part A of title V”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(1) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110/s1061/1"},"text":"Pub. L. 107–110, § 1061(1)","children":[],"tail":", added pars. (1) to (8) and struck out former pars. (1) to (7) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) political affiliations;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) mental and psychological problems potentially embarrassing to the student or his family;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) sex behavior and attitudes;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) illegal, anti-social, self-incriminating and demeaning behavior;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) critical appraisals of other individuals with whom respondents have close family relationships;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) legally recognized privileged or analogous relationships, such as those of lawyers, physicians, and ministers; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(7) income (other than that required by law to determine eligibility for participation in a program or for receiving financial assistance under such program),”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110/s1061/2"},"text":"Pub. L. 107–110, § 1061(2)","children":[],"tail":", (3), added subsec. (c) and redesignated former subsecs. (c) to (e) as (d) to (f), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/227"},"text":"Pub. L. 103–227","children":[],"tail":" amended section generally, substituting in subsec. (a), provisions relating to inspection of instructional materials by parents or guardians for similar provisions, in subsec. (b), provisions relating to limits on survey, analysis, or evaluations for provisions relating to psychiatric or psychological examinations, testing, or treatment, and adding subsecs. (c) to (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561"},"text":"Pub. L. 95–561","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading"