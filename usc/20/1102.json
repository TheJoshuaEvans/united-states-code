{"tag":"section","attrib":{"id":"id0d6a62fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1102"},"text":null,"children":[{"tag":"num","attrib":{"value":"1102"},"text":"§ 1102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this part are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6a62ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand postbaccalaureate educational opportunities for, and improve the academic attainment of, Hispanic students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a6300-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand the postbaccalaureate academic offerings and enhance the program quality in the institutions of higher education that are educating the majority of Hispanic college students and helping large numbers of Hispanic and low-income students complete postsecondary degrees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6a6301-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tV/s511"},"text":"Pub. L. 89–329, title V, § 511","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tV/s502/a/3"},"text":"Pub. L. 110–315, title V, § 502(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3331"},"text":"122 Stat. 3331","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d6a6