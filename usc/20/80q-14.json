{"tag":"section","attrib":{"id":"id0c87f2be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"80q–14"},"text":"§ 80q–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c87f2bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–14/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Board of Regents” means the Board of Regents of the Smithsonian Institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f2c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–14/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Board of Trustees” means the Board of Trustees of the National Museum of the American Indian;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f2c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–14/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “burial site” means a natural or prepared physical location, whether below, on, or above the surface of the earth, into which, as a part of a death rite or ceremony of a culture, individual human remains are deposited;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f2c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–14/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “funerary object” means an object that, as part of a death rite or ceremony of a culture, is intentionally placed with individual human remains, either at the time of burial or later;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f2c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–14/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Heye Foundation assets” means the collections, endowment, and all other property of the Heye Foundation (other than the interest of the Heye Foundation in Audubon Terrace) described in the Memorandum of Understanding between the Smithsonian Institution and the Heye Foundation, dated ","children":[{"tag":"date","attrib":{"date":"1989-05-08"},"text":"May 8, 1989","children":[],"tail":", and the schedules attached to such memorandum;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f2c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–14/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Heye Museum” means the Museum of the American Indian, Heye Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f2c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–14/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Indian” means a member of an Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f2c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–14/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Indian tribe” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f2c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–14/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “National Museum” means the National Museum of the American Indian established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s80q–1"},"text":"section 80q–1 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f2c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–14/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Native American” means an individual of a tribe, people, or culture that is indigenous to the Americas and such term includes a Native Hawaiian; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f2c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–14/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Native Hawaiian” means a member or descendant of the aboriginal people who, before 1778, occupied and exercised sovereignty in the area that now comprises the State of Hawaii.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c8a3bba-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/185/s16"},"text":"Pub. L. 101–185, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1346"},"text":"103 Stat. 1346","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
