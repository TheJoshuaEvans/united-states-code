{"tag":"section","attrib":{"id":"id0d59c144-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093"},"text":null,"children":[{"tag":"num","attrib":{"value":"1093"},"text":"§ 1093.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distance education demonstration programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d59c145-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d59c146-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to allow demonstration programs that are strictly monitored by the Department of Education to test the quality and viability of expanded distance education programs currently restricted under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c147-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for increased student access to higher education through distance education programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c148-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to help determine—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d59c149-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most effective means of delivering quality education via distance education course offerings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c14a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific statutory and regulatory requirements which should be altered to provide greater access to high quality distance education programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c14b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate level of Federal assistance for students enrolled in distance education programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d59c14c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration programs authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d59c14d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with the provisions of subsection (d), the Secretary is authorized to select institutions of higher education, systems of such institutions, or consortia of such institutions for voluntary participation in a Distance Education Demonstration Program that provides participating institutions with the ability to offer distance education programs that do not meet all or a portion of the sections or regulations described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c14e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to waive for any institution of higher education, system of institutions of higher education, or consortium participating in a Distance Education Demonstration Program, the requirements of section 1087","children":[{"tag":"i","attrib":{},"text":"ll","children":[],"tail":"(5) "},{"tag":"ref","attrib":{"idref":"fn002107"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002107"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title as the section relates to computer costs, sections 1088(a) and 1088(b) of this title as such sections relate to requirements for a minimum number of weeks of instruction, sections 1002(a)(3)(A), 1002(a)(3)(B), and 1091("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1) of this title, or one or more of the regulations prescribed under this part or part F which inhibit the operation of quality distance education programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c14f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible applicants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d59c150-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraphs (B), (C), and (D), only an institution of higher education that is eligible to participate in programs under this subchapter shall be eligible to participate in the demonstration program authorized under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c151-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution of higher education described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002/a/1/C"},"text":"section 1002(a)(1)(C) of this title","children":[],"tail":" shall not be eligible to participate in the demonstration program authorized under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c152-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), an institution of higher education that meets the requirements of subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"section 1002 of this title","children":[],"tail":", other than the requirement of paragraph (3)(A) or (3)(B) of such subsection, and that provides a 2-year or 4-year program of instruction for which the institution awards an associate or baccalaureate degree, shall be eligible to participate in the demonstration program authorized under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c153-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this paragraph, Western Governors University shall be considered eligible to participate in the demonstration program authorized under this section. In addition to the waivers described in paragraph (2), the Secretary may waive the provisions of subchapter I and this part and part H of this subchapter for such university that the Secretary determines to be appropriate because of the unique characteristics of such university. In carrying out the preceding sentence, the Secretary shall ensure that adequate program integrity and accountability measures apply to such university’s participation in the demonstration program authorized under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d59c154-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d59c155-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each institution, system, or consortium of institutions desiring to participate in a demonstration program under this section shall submit an application to the Secretary at such time and in such manner as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c156-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d59c157-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the institution, system, or consortium’s consultation with a recognized accrediting agency or association with respect to quality assurances for the distance education programs to be offered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c158-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the statutory and regulatory requirements described in subsection (b)(2) or, if applicable, subsection (b)(3)(D) for which a waiver is sought and the reasons for which the waiver is sought;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c159-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the distance education programs to be offered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c15a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the students to whom distance education programs will be offered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c15b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the institution, system, or consortium will offer full cooperation with the ongoing evaluations of the demonstration program provided for in this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c15c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d59c15d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d59c15e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the first year of the demonstration program authorized under this section, the Secretary is authorized to select for participation in the program not more than 15 institutions, systems of institutions, or consortia of institutions. For the third year of the demonstration program authorized under this section, the Secretary may select not more than 35 institutions, systems, or consortia, in addition to the institutions, systems, or consortia selected pursuant to the preceding sentence, to participate in the demonstration program if the Secretary determines that such expansion is warranted based on the evaluations conducted in accordance with subsections (f) and (g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c15f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting institutions to participate in the demonstration program in the first or succeeding years of the program, the Secretary shall take into account—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d59c160-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and quality of applications received;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c161-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department’s capacity to oversee and monitor each institution’s participation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c162-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an institution’s—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d59c163-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial responsibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d59c164-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative capability; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d59c165-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/d/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" program or programs being offered via distance education; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c166-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring the participation of a diverse group of institutions with respect to size, mission, and geographic distribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d59c167-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available to the public and to the authorizing committees a list of institutions, systems or consortia selected to participate in the demonstration program authorized by this section. Such notice shall include a listing of the specific statutory and regulatory requirements being waived for each institution, system or consortium and a description of the distance education courses to be offered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d59c168-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations and reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d59c169-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall evaluate the demonstration programs authorized under this section on an annual basis. Such evaluations specifically shall review—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d59c16a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the institution, system or consortium has met the goals set forth in its application to the Secretary, including the measures of program quality assurance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c16b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and types of students participating in the programs offered, including the progress of participating students toward recognized certificates or degrees and the extent to which participation in such programs increased;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c16c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issues related to student financial assistance for distance education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c16d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective technologies for delivering distance education course offerings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c16e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/f/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which statutory or regulatory requirements not waived under the demonstration program present difficulties for students or institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c16f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy analysis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall review current policies and identify those policies that present impediments to the development and use of distance education and other nontraditional methods of expanding access to education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c170-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide reports to the authorizing committees on an annual basis regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d59c171-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demonstration programs authorized under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c172-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and types of students receiving assistance under this subchapter for instruction leading to a recognized certificate, as provided for in section 1091(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1) of this title, including the progress of such students toward recognized certificates and the degree to which participation in such programs leading to such certificates increased."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d59c173-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the demonstration program authorized under this section, the Secretary shall, on a continuing basis—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d59c174-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assure compliance of institutions, systems or consortia with the requirements of this subchapter (other than the sections and regulations that are waived under subsections (b)(2) and (b)(3)(D));","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c175-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c176-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor fluctuations in the student population enrolled in the participating institutions, systems or consortia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c177-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with appropriate accrediting agencies or associations and appropriate State regulatory authorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d59c178-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Distance education” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this section, the term “distance education” means an educational process that is characterized by the separation, in time or place, between instructor and student. Such term may include courses offered principally through the use of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d59c179-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" television, audio, or computer transmission, such as open broadcast, closed circuit, cable, microwave, or satellite transmission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c17a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" audio or computer conferencing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c17b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" video cassettes or discs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c17c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" correspondence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d59c17d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s486"},"text":"Pub. L. 89–329, title IV, § 486","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s407/a"},"text":"Pub. L. 99–498, title IV, § 407(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1487"},"text":"100 Stat. 1487","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s489"},"text":"Pub. L. 102–325, title IV, § 489","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/624"},"text":"106 Stat. 624","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s488"},"text":"Pub. L. 105–244, title IV, § 488","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1746"},"text":"112 Stat. 1746","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tI/s103/b/12"},"text":"Pub. L. 110–315, title I, § 103(b)(12)","children":[],"tail":", title IV, § 491, "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3090"},"text":"122 Stat. 3090","children":[],"tail":", 3307.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d59c17e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d59c17f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d59c180-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1087","children":[{"tag":"i","attrib":{},"text":"ll","children":[],"tail":" of this title, referred to in subsec. (b)(2), was generally amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tVII/s702/b"},"text":"Pub. L. 116–260, div. FF, title VII, § 702(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3138"},"text":"134 Stat. 3138","children":[],"tail":". For a similar provision to former par. (5), see subsec. (a)(6) of section 1087"},{"tag":"i","attrib":{},"text":"ll","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d59c181-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1093, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s486"},"text":"Pub. L. 89–329, title IV, § 486","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tIV/s451/a"},"text":"Pub. L. 96–374, title IV, § 451(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1450"},"text":"94 Stat. 1450","children":[],"tail":", related to training in financial aid and student support services, prior to the general revision of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d59c182-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s103/b/12"},"text":"Pub. L. 110–315, § 103(b)(12)","children":[],"tail":", substituted “authorizing committees” for “Committee on Labor and Human Resources of the Senate and the Committee on Education and the Workforce of the House of Representatives”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s491"},"text":"Pub. L. 110–315, § 491","children":[],"tail":", substituted “Annual reports” for “Reports” in heading, in subpar. (B) redesignated cls. (i) and (ii) as subpars. (A) and (B), respectively, and adjusted their margins, and substituted “The Secretary shall provide reports to the authorizing committees on an annual basis” for former subpar. (A) which required Secretary to report to congressional committees on evaluations of demonstration programs and for introductory provisions of former subpar. (B) which related to additional annual reports."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" amended section catchline and text generally. Prior to amendment, section authorized Secretary to make grants to nonprofit private organizations to provide training for student financial aid administrators and TRIO personnel."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":" struck out “and student support” after “aid” in section catchline and amended text generally, substituting present provisions for former subsec. (a) relating to program authority, subsec. (b) relating to use of funds, and subsec. (c) relating to authorization of appropriations."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d59c183-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d59c184-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
