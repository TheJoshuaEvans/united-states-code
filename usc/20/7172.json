{"tag":"section","attrib":{"id":"id0e26d628-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172"},"text":null,"children":[{"tag":"num","attrib":{"value":"7172"},"text":"§ 7172.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e26d629-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7176"},"text":"section 7176 of this title","children":[],"tail":" for any fiscal year, the Secretary shall reserve—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e26d62a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amounts as may be necessary to make continuation awards to subgrant recipients under covered programs (under the terms of those grants);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d62b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 1 percent for national activities, which the Secretary may carry out directly or through grants and contracts, such as providing technical assistance to eligible entities carrying out programs under this part or conducting a national evaluation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d62c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 1 percent for payments to the outlying areas and the Bureau of Indian Education, to be allotted in accordance with their respective needs for assistance under this part, as determined by the Secretary, to enable the outlying areas and the Bureau to carry out the purpose of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e26d62d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State allotments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e26d62e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7176"},"text":"section 7176 of this title","children":[],"tail":" for any fiscal year and remaining after the Secretary makes reservations under subsection (a), the Secretary shall allot to each State for the fiscal year an amount that bears the same relationship to the remainder as the amount the State received under subpart 2 of part A of subchapter I for the preceding fiscal year bears to the amount all States received under that subpart for the preceding fiscal year, except that no State shall receive less than an amount equal to one-half of 1 percent of the total amount made available to all States under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d62f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallotment of unused funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State does not receive an allotment under this part for a fiscal year, the Secretary shall reallot the amount of the State’s allotment to the remaining States in accordance with this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e26d630-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e26d631-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State that receives an allotment under this part shall reserve not less than 93 percent of the amount allotted to such State under subsection (b), for each fiscal year for awards to eligible entities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7174"},"text":"section 7174 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d632-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State educational agency may use not more than 2 percent of the amount made available to the State under subsection (b) for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e26d633-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administrative costs of carrying out its responsibilities under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d634-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and implementing a rigorous peer-review process for subgrant applications described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7174/b"},"text":"section 7174(b) of this title","children":[],"tail":" (including consultation with the Governor and other State agencies responsible for administering youth development programs and adult learning activities); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d635-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" awarding of funds to eligible entities (in consultation with the Governor and other State agencies responsible for administering youth development programs and adult learning activities).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d636-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State educational agency may use not more than 5 percent of the amount made available to the State under subsection (b) for the following activities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e26d637-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Monitoring and evaluating programs and activities assisted under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d638-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing capacity building, training, and technical assistance under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d639-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conducting a comprehensive evaluation (directly, or through a grant or contract) of the effectiveness of programs and activities assisted under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d63a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing training and technical assistance to eligible entities that are applicants for or recipients of awards under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d63b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ensuring that any eligible entity that receives an award under this part from the State aligns the activities provided by the program with the challenging State academic standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d63c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ensuring that any such eligible entity identifies and partners with external organizations, if available, in the community.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d63d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/c/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Working with teachers, principals, parents, the local workforce, the local community, and other stakeholders to review and improve State policies and practices to support the implementation of effective programs under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d63e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/c/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinating funds received under this part with other Federal and State funds to implement high-quality programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d63f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7172/c/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing a list of prescreened external organizations, as described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7173/a/11"},"text":"section 7173(a)(11) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e26d640-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4202"},"text":"Pub. L. 89–10, title IV, § 4202","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIV/s401"},"text":"Pub. L. 107–110, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1766"},"text":"115 Stat. 1766","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4201/a"},"text":"Pub. L. 114–95, title IV, § 4201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1984"},"text":"129 Stat. 1984","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e26d641-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e26d642-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e26d643-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" amended section generally. Prior to amendment, section related to allotments to States."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e26d644-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e26d645-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
