{"tag":"section","attrib":{"id":"id0d78bb58-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136"},"text":null,"children":[{"tag":"num","attrib":{"value":"1136"},"text":"§ 1136.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal educational opportunity program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d78bb59-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a program to be known as the “Thurgood Marshall Legal Educational Opportunity Program” designed to provide low-income, minority, or disadvantaged secondary school and college students with the information, preparation, and financial assistance to gain access to and complete law school study and admission to law practice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d78bb5a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A secondary school student or college student is eligible for assistance under this section if the student is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d78bb5b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from a low-income family;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb5c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a minority; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb5d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from an economically or otherwise disadvantaged background.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d78bb5e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract or grant authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to enter into a contract with, or make a grant to, the Council on Legal Education Opportunity, for a period of not less than 5 years—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d78bb5f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify secondary school and college students who are from low-income families, are minorities, or are from disadvantaged backgrounds described in subsection (b)(3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb60-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prepare such students for successful completion of a baccalaureate degree and for study at accredited law schools, and to assist them with the development of analytical skills, writing skills, and study methods to enhance the students’ success in, and promote the students’ admission to and completion of, law school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb61-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist such students to select the appropriate law school, make application for entry into law school, and receive financial assistance for such study;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb62-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide support services to such students who are first-year law students to improve retention and success in law school studies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb63-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to motivate and prepare such students—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d78bb64-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to law school studies and practice in low-income communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb65-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide legal services to low-income individuals and families; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb66-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to award Thurgood Marshall Fellowships to eligible law school students—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d78bb67-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who participated in summer institutes under subsection (d)(6) and who are enrolled in an accredited law school; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb68-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who have successfully completed a comparable summer institute program that is certified by the Council on Legal Education Opportunity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d78bb69-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services provided","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the purposes described in subsection (c), the contract or grant shall provide for the delivery of services through pre-college programs, undergraduate prelaw information resource centers, summer institutes, midyear seminars, and other educational activities, conducted under this section. Such services may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d78bb6a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information and counseling regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d78bb6b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accredited law school academic programs, especially tuition, fees, and admission requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb6c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" course work offered and required for law school graduation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb6d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" faculty specialties and areas of legal emphasis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb6e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pre-college and undergraduate preparatory courses in analytical and writing skills, study methods, and course selection;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb6f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summer academic programs for secondary school students who have expressed interest in a career in the law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb70-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tutoring and academic counseling, including assistance in preparing for bar examinations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb71-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prelaw mentoring programs, involving law school faculty, members of State and local bar associations, and retired and sitting judges, justices, and magistrates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb72-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in identifying preparatory courses and material for the law school aptitude or admissions tests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb73-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summer institutes for Thurgood Marshall Fellows that expose the Fellows to a rigorous curriculum that emphasizes abstract thinking, legal analysis, research, writing, and examination techniques; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb74-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" midyear seminars and other educational activities that are designed to reinforce reading, writing, and studying skills of Thurgood Marshall Fellows and Associates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d78bb75-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of provision of services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The services described in subsection (d) may be provided—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d78bb76-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to the period of law school study, including before and during undergraduate study;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb77-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the period of law school study; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb78-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the period following law school study and prior to taking a bar examination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d78bb79-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subcontracts and subgrants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of planning, developing, or delivering one or more of the services described in subsection (d), the Council on Legal Education Opportunity shall enter into subcontracts with, and make subgrants to, institutions of higher education, law schools, public and private agencies and organizations, national and State bar associations, and combinations of such institutions, schools, agencies, organizations, and associations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d78bb7a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowships and stipends","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall annually establish the maximum fellowship to be awarded, and the maximum stipend to be paid (including allowances for participant travel and for the travel of the dependents of the participant), to Thurgood Marshall Fellows or Associates for the period of participation in summer institutes, midyear seminars, and bar preparation seminars. A Thurgood Marshall Fellow or Associate may be eligible for such a fellowship or stipend only if the Fellow or Associate maintains satisfactory academic progress toward the Juris Doctor or Bachelor of Laws degree, as determined by the respective institutions (except with respect to a law school graduate enrolled in a bar preparation course).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d78bb7b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $5,000,000 for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d78bb7c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s721"},"text":"Pub. L. 89–329, title VII, § 721","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVII/s701"},"text":"Pub. L. 105–244, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1794"},"text":"112 Stat. 1794","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVII/s704/a"},"text":"Pub. L. 110–315, title VII, § 704(a)","children":[],"tail":"–(h), "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3347"},"text":"122 Stat. 3347","children":[],"tail":", 3348; "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tVII/s701/1"},"text":"Pub. L. 111–39, title VII, § 701(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1954"},"text":"123 Stat. 1954","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d78bb7d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d78bb7e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d78bb7f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1136, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tXI/s1101"},"text":"Pub. L. 89–329, title XI, § 1101","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tXI/s1101"},"text":"Pub. L. 102–325, title XI, § 1101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/784"},"text":"106 Stat. 784","children":[],"tail":", stated findings of Congress, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"Pub. L. 105–244, § 3","children":[],"tail":", title VII, § 702, "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1585"},"text":"112 Stat. 1585","children":[],"tail":", 1803, effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1136, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tXI/s1101"},"text":"Pub. L. 89–329, title XI, § 1101","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tXI/s1101"},"text":"Pub. L. 99–498, title XI, § 1101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib"