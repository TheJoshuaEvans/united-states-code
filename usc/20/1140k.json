{"tag":"section","attrib":{"id":"id0d7d761a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140k"},"text":null,"children":[{"tag":"num","attrib":{"value":"1140k"},"text":"§ 1140k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of student with a print disability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In this subpart, the term “student with a print disability” means a student with a disability who experiences barriers to accessing instructional material in nonspecialized formats, including an individual described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t17/s121/d/2"},"text":"section 121(d)(2) of title 17","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d7d761b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s771"},"text":"Pub. L. 89–329, title VII, § 771","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVII/s709/2"},"text":"Pub. L. 110–315, title VII, § 709(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3367"},"text":"122 Stat. 3367","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d7d761c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d7d761d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d7d761e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t17/s121/d"},"text":"Section 121(d) of title 17","children":[],"tail":", referred to in text, was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/261/s2/a/1/D"},"text":"Pub. L. 115–261, § 2(a)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-09"},"text":"Oct. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3667"},"text":"132 Stat. 3667","children":[],"tail":", and no longer defines blind or other persons with disabilities. However, "},{"tag":"ref","attrib":{"href":"/us/usc/t17/s121/d"},"text":"section 121(d) of title 17","children":[],"tail":", as amended, does define “eligible person” to include blind persons, persons with visual impairment or perceptual or reading disability, and persons with other physical disabilities that inhibit reading skills."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d7d761f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s771"},"text":"section 771 of Pub. L. 89–329","children":[],"tail":" was renumbered section 781, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1141"},"text":"section 1141 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s771"},"text":"section 771 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1132h"},"text":"section 1132h of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s771"},"text":"section 771 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1132d–11"},"text":"section 1132d–11 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/96/374"},"text":"Pub. L. 96–374","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
