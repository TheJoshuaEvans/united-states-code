{"tag":"section","attrib":{"id":"id0daac839-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1440"},"text":null,"children":[{"tag":"num","attrib":{"value":"1440"},"text":"§ 1440.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payor of last resort","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0daac83a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1440/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonsubstitution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1443"},"text":"section 1443 of this title","children":[],"tail":" may not be used to satisfy a financial commitment for services that would have been paid for from another public or private source, including any medical program administered by the Secretary of Defense, but for the enactment of this subchapter, except that whenever considered necessary to prevent a delay in the receipt of appropriate early intervention services by an infant, toddler, or family in a timely fashion, funds provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1443"},"text":"section 1443 of this title","children":[],"tail":" may be used to pay the provider of services pending reimbursement from the agency that has ultimate responsibility for the payment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daac83b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1440/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligations related to and methods of ensuring services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daac83c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1440/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishing financial responsibility for services","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daac83d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1440/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Executive Officer of a State or designee of the officer shall ensure that an interagency agreement or other mechanism for interagency coordination is in effect between each public agency and the designated lead agency, in order to ensure—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0daac83e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1440/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of, and financial responsibility for, services provided under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0daac83f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1440/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such services are consistent with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1435"},"text":"section 1435 of this title","children":[],"tail":" and the State’s application pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1437"},"text":"section 1437 of this title","children":[],"tail":", including the provision of such services during the pendency of any such dispute."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daac840-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1440/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency between agreements or mechanisms under subchapter II","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer of a State or designee of the officer shall ensure that the terms and conditions of such agreement or mechanism are consistent with the terms and conditions of the State’s agreement or mechanism under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1412/a/12"},"text":"section 1412(a)(12) of this title","children":[],"tail":", where appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daac841-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1440/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement for services by public agency","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daac842-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1440/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a public agency other than an educational agency fails to provide or pay for the services pursuant to an agreement required under paragraph (1), the local educational agency or State agency (as determined by the Chief Executive Officer or designee) shall provide or pay for the provision of such services to the child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daac843-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1440/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such local educational agency or State agency is authorized to claim reimbursement for the services from the public agency that failed to provide or pay for such services and such public agency shall reimburse the local educational agency or State agency pursuant to the terms of the interagency agreement or other mechanism required under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daac844-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1440/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of paragraph (1) may be met through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daac845-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1440/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State statute or regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daac846-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1440/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" signed agreements between respective agency officials that clearly identify the responsibilities of each agency relating to the provision of services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daac847-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1440/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate written methods as determined by the Chief Executive Officer of the State or designee of the officer and approved by the Secretary through the review and approval of the State’s application pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1437"},"text":"section 1437 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daac848-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1440/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of other benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to permit the State to reduce medical or other assistance available or to alter eligibility under title V of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s701"},"text":"42 U.S.C. 701","children":[],"tail":" et seq.] (relating to maternal and child health) or title XIX of the Social Security Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.] (relating to medicaid for infants or toddlers with disabilities) within the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0daac849-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s640"},"text":"Pub. L. 91–230, title VI, § 640","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2757"},"text":"118 Stat. 2757","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0daac84a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0daac84b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0daac84c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":", as amended. Titles V and XIX of the Act are classified generally to subchapters V (§ 701 et seq.) and XIX (§ 1396 et seq.), respectively, of chapter 7 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0daac84d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1440, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s640"},"text":"Pub. L. 91–230, title VI, § 640","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/17/tI/s101"},"text":"Pub. L. 105–17, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-04"},"text":"June 4, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/116"},"text":"111 Stat. 116","children":[],"tail":", related to the payor of last resort, prior to the general amendment of subchapters I to IV of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/108/446"},"text":"Pub. L. 108–446","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
