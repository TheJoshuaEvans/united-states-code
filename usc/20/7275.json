{"tag":"section","attrib":{"id":"id0e304b49-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275"},"text":null,"children":[{"tag":"num","attrib":{"value":"7275"},"text":"§ 7275.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full-service community schools","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e304b4a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that desires a grant under this subpart for activities described in this section shall submit an application to the Secretary at such time and in such manner as the Secretary may require. The Secretary shall require that each such application include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e304b4b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the eligible entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304b4c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A memorandum of understanding among all partner entities in the eligible entity that will assist the eligible entity to coordinate and provide pipeline services and that describes the roles the partner entities will assume.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304b4d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the capacity of the eligible entity to coordinate and provide pipeline services at 2 or more full-service community schools.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304b4e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A comprehensive plan that includes descriptions of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e304b4f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The student, family, and school community to be served, including demographic information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304b50-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A needs assessment that identifies the academic, physical, nonacademic, health, mental health, and other needs of students, families, and community residents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304b51-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Annual measurable performance objectives and outcomes, including an increase in the number and percentage of families and students targeted for services each year of the program, in order to ensure that children are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e304b52-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/a/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepared for kindergarten;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e304b53-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/a/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieving academically; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e304b54-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/a/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safe, healthy, and supported by engaged parents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304b55-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Pipeline services, including existing and additional pipeline services, to be coordinated and provided by the eligible entity and its partner entities, including an explanation of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e304b56-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/a/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" why such services have been selected;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e304b57-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/a/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how such services will improve student academic achievement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e304b58-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/a/4/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how such services will address the annual measurable performance objectives and outcomes established under subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304b59-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Plans to ensure that each full-service community school site has a full-time coordinator of pipeline services at such school, including a description of the applicable funding sources, plans for professional development for the personnel managing, coordinating, or delivering pipeline services, and plans for joint utilization and management of school facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304b5a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/a/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Plans for annual evaluation based upon attainment of the performance objectives and outcomes described in subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304b5b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/a/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Plans for sustaining the programs and services described in this subsection after the grant period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304b5c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assurance that the eligible entity and its partner entities will focus services on schools eligible for a schoolwide program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6314/b"},"text":"section 6314(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e304b5d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this subpart for activities described in this section, the Secretary shall give priority to eligible entities that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e304b5e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e304b5f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will serve a minimum of 2 or more full-service community schools eligible for a schoolwide program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6314/b"},"text":"section 6314(b) of this title","children":[],"tail":", as part of a community- or district-wide strategy; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304b60-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include a local educational agency that satisfies the requirements of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e304b61-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subparagraph (A), (B), or (C) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7345/b/1"},"text":"section 7345(b)(1) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e304b62-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subparagraphs (A) and (B) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7351/b/1"},"text":"section 7351(b)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304b63-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consortiums comprised of a broad representation of stakeholders or consortiums demonstrating a history of effectiveness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304b64-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will use funds for evidence-based activities described in subsection (e), defined for purposes of this paragraph as activities meeting the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801/21/A/i"},"text":"section 7801(21)(A)(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e304b65-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may authorize an eligible entity receiving a grant under this subpart for activities described in this section to use not more than 10 percent of the total amount of grant funds for planning purposes during the first year of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e304b66-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not award a grant under this subpart for activities described in this section to an eligible entity in an amount that is less than $75,000 for each year of the grant period, subject to the availability of appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e304b67-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under this subpart for activities described in this section shall be used to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e304b68-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate not less than 3 existing pipeline services, as of the date of the grant award, and provide not less than 2 additional pipeline services, at 2 or more public elementary schools or secondary schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304b69-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, integrate multiple pipeline services into a comprehensive, coordinated continuum to achieve the annual measurable performance objectives and outcomes under subsection (a)(4)(C) to meet the holistic needs of children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304b6a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, coordinate and integrate services provided by community-based organizations and government agencies with services provided by specialized instructional support personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e304b6b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations by the institute of education sciences","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Institute of Education Sciences, shall conduct evaluations of the effectiveness of grants under this subpart for activities described in this section in achieving the purpose described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7271/2"},"text":"section 7271(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e304b6c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations by grantees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require each eligible entity receiving a grant under this subpart for activities described in this section to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e304b6d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct annual evaluations of the progress achieved with the grant toward the purpose described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7271/2"},"text":"section 7271(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304b6e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use such evaluations to refine and improve activities carried out through the grant and the annual measurable performance objectives and outcomes under subsection (a)(4)(C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304b6f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the results of such evaluations publicly available, including by providing public notice of such availability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e304b70-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to alter or otherwise affect the rights, remedies, and procedures afforded school or local educational agency employees under Federal, State, or local laws (including applicable regulations or court orders) or under the terms of collective bargaining agreements, memoranda of understanding, or other agreements between such employees and their employers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e304b71-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7275/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement, not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available to an eligible entity through a grant under this subpart for activities described in this section may be used only to supplement, and not supplant, any other Federal, State, or local funds that would otherwise be available to carry out the activities assisted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e304b72-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4625"},"text":"Pub. L. 89–10, title IV, 