{"tag":"section","attrib":{"id":"id0de18faf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3996"},"text":null,"children":[{"tag":"num","attrib":{"value":"3996"},"text":"§ 3996.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An applicant within a State that desires to receive a grant under this part ","children":[{"tag":"ref","attrib":{"idref":"fn002161"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002161"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall submit an application prepared in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3995"},"text":"section 3995 of this title","children":[],"tail":" to the State educational agency for approval. Each application with respect to funds for improvement of elementary and secondary resources under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3994/b/1"},"text":"section 3994(b)(1) of this title","children":[],"tail":" shall be submitted jointly by the local educational agency and each business concern or other party that is to participate in the activities for which assistance is sought."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0de18fb0-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tIII/s326"},"text":"Pub. L. 98–377, title III, § 326","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tVI/s6031/a/2"},"text":"Pub. L. 100–418, title VI, § 6031(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1482"},"text":"102 Stat. 1482","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de18fb1-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de18fb2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0de18fb3-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in text, was in the original “this chapter” and was translated as reading “this part” to reflect the probable intent of Congress because title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377"},"text":"Pub. L. 98–377","children":[],"tail":", which comprises this subchapter, does not contain chapters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
