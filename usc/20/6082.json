{"tag":"section","attrib":{"id":"id0dfbce4f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6082"},"text":null,"children":[{"tag":"num","attrib":{"value":"6082"},"text":"§ 6082.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dfbce50-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6082/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Children","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “children” means individuals who have not attained the age of 18.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dfbce51-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6082/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Children’s services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “children’s services” means the provision on a routine or regular basis of health, day care, education, or library services—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dfbce52-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6082/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that are funded, after ","children":[{"tag":"date","attrib":{"date":"1994-03-31"},"text":"March 31, 1994","children":[],"tail":", directly by the Federal Government or through State or local governments, by Federal grant, loan, loan guarantee, or contract programs—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0dfbce53-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6082/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administered by either the Secretary of Health and Human Services or the Secretary of Education (other than services provided and funded solely under titles XVIII and XIX of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq., 1396 et seq.]); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dfbce54-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6082/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administered by the Secretary of Agriculture in the case of a clinic (as defined in 7 CFR 246.2) under section 17(b)(6) of the Child Nutrition Act of 1966 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1786/b/6"},"text":"42 U.S.C. 1786(b)(6)","children":[],"tail":"), or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dfbce55-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6082/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are provided in indoor facilities that are constructed, operated, or maintained with such Federal funds, as determined by the appropriate Secretary in any enforcement action under this subchapter,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that nothing in clause (ii) of subparagraph (A) is intended to include facilities (other than clinics) where coupons are redeemed under the Child Nutrition Act of 1966 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"42 U.S.C. 1771","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dfbce56-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6082/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means any State or local subdivision thereof, agency of such State or subdivision, corporation, or partnership that owns or operates or otherwise controls and provides children’s services or any individual who owns or operates or otherwise controls and provides such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dfbce57-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6082/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indoor facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “indoor facility” means a building that is enclosed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dfbce58-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6082/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dfbce59-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/227/tX/s1042"},"text":"Pub. L. 103–227, title X, § 1042","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"Mar. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/271"},"text":"108 Stat. 271","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dfbce5a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dfbce5b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0dfbce5c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Child Nutrition Act of 1966, referred to in par. (2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/642"},"text":"Pub. L. 89–642","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-11"},"text":"Oct. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/885"},"text":"80 Stat. 885","children":[],"tail":", which is classified generally to chapter 13A (§ 1771 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"section 1771 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in par. (2)(A)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Titles XVIII and XIX of the Social Security Act are classified generally to subchapters XVIII (§ 1395 et seq.) and XIX (§ 1396 et seq.) of chapter 7 of Title 42. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This subchapter, referred to in par. (2)(B), was in the original “this title”, meaning title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/227"},"text":"Pub. L. 103–227","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"Mar. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/265"},"text":"108 Stat. 265","children":[],"tail":", which enacted this subchapter and "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3351"},"text":"section 3351 of this title","children":[],"tail":", amended sections 1107, 1232h, 2421, 3381 to 3384, and 3386 of this title, sections 1632, 1633, and 1635 of Title 29, Labor, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11903a"},"text":"section 11903a of Title 42","children":[],"tail":", and enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s2701"},"text":"section 2701 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11901"},"text":"section 11901 of Title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
