{"tag":"section","attrib":{"id":"id0c74dfce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s42"},"text":null,"children":[{"tag":"num","attrib":{"value":"42"},"text":"§ 42.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Regents; members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c74dfcf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s42/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The business of the Institution shall be conducted at the city of Washington by a Board of Regents, named the Regents of the Smithsonian Institution, to be composed of the Vice President, the Chief Justice of the United States, three Members of the Senate, three Members of the House of Representatives, and nine other persons, other than Members of Congress, two of whom shall be resident in the city of Washington, and seven of whom shall be inhabitants of some State, but no two of them of the same State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c74dfd0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s42/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of law, the Board of Regents of the Smithsonian Institution may modify the number of members, manner of appointment of members, or tenure of members, of the boards or commissions under the jurisdiction of the Smithsonian Institution, other than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c74dfd1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s42/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board of Regents of the Smithsonian Institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c74dfd2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s42/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the boards or commissions of the National Gallery of Art, the John F. Kennedy Center for the Performing Arts, and the Woodrow Wilson International Center for Scholars.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c74dfd3-3a70-11f1-a648-bee82ed8a795"},"text":"(R.S. § 5580; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1894-03-12/ch36"},"text":"Mar. 12, 1894, ch. 36","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/41"},"text":"28 Stat. 41","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/551/s1/a"},"text":"Pub. L. 91–551, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-15"},"text":"Dec. 15, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1439"},"text":"84 Stat. 1439","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tIII/s355"},"text":"Pub. L. 105–277, div. A, § 101(e) [title III, § 355]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–303.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c74dfd4-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c74dfd5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0c74dfd6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5580 derived from acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1846-08-10/ch178/s3"},"text":"Aug. 10, 1846, ch. 178, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/9/103"},"text":"9 Stat. 103","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1865-01-10/ch11"},"text":"Jan. 10, 1865, ch. 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/420"},"text":"13 Stat. 420","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1871-03-20/ch1"},"text":"Mar. 20, 1871, ch. 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/17/1"},"text":"17 Stat. 1","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0c74dfd7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/551"},"text":"Pub. L. 91–551","children":[],"tail":" authorized three additional persons on the Board of Regents."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1894—Act ","children":[{"tag":"date","attrib":{"date":"1894-03-12"},"text":"Mar. 12, 1894","children":[],"tail":", struck out “the governor of the District of Columbia” after “the Chief Justice of the United States,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
