{"tag":"section","attrib":{"id":"id0db46437-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1701"},"text":null,"children":[{"tag":"num","attrib":{"value":"1701"},"text":"§ 1701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0db46438-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entitlement to equal educational opportunity; neighborhood as appropriate basis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress declares it to be the policy of the United States that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db46439-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all children enrolled in public schools are entitled to equal educational opportunity without regard to race, color, sex, or national origin; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db4643a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the neighborhood is the appropriate basis for determining public school assignments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db4643b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to carry out this policy, it is the purpose of this subchapter to specify appropriate remedies for the orderly removal of the vestiges of the dual school system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0db4643c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/380/tII/s202"},"text":"Pub. L. 93–380, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/514"},"text":"88 Stat. 514","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0db4643d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0db4643e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0db4643f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on and after sixtieth day after ","children":[{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/380/s2/c"},"text":"section 2(c) of Pub. L. 93–380","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1221–1"},"text":"section 1221–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id0db46440-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/380/tII/s201"},"text":"Pub. L. 93–380, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/514"},"text":"88 Stat. 514","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/380/tII/s201"},"text":"“This title [enacting this chapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1228"},"text":"section 1228 of this title","children":[],"tail":" and amending "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1608"},"text":"section 1608 of this title","children":[],"tail":"] may be cited as the ‘Equal Educational Opportunities Act of 1974’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
