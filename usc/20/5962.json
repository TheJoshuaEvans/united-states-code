{"tag":"section","attrib":{"id":"id0df9841f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5962"},"text":null,"children":[{"tag":"num","attrib":{"value":"5962"},"text":"§ 5962.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safe schools program authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0df98420-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5962/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0df98421-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5962/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From funds appropriated pursuant to the authority of subsection (b)(1), the Secretary shall make competitive grants to eligible local educational agencies to enable such agencies to carry out projects and activities designed to achieve Goal Six ","children":[{"tag":"ref","attrib":{"idref":"fn002193"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002193"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Goal Seven”."}],"tail":" of the National Education Goals by helping to ensure that all schools are safe and free of violence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df98422-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5962/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant duration and amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants under this subchapter may not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0df98423-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5962/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two fiscal years in duration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df98424-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5962/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df98425-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5962/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, grants under this subchapter shall be awarded to eligible local educational agencies serving rural, as well as urban, areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0df98426-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5962/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations and reservation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0df98427-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5962/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $50,000,000 for fiscal year 1994 to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df98428-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5962/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized in each fiscal year to reserve not more than 10 percent of the amount appropriated pursuant to the authority of paragraph (1) to carry out national activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5966"},"text":"section 5966 of this title","children":[],"tail":", of which 50 percent of such amount shall be available in such fiscal year to carry out the program described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s5966/b"},"text":"section 5966(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0df98429-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/227/tVII/s702"},"text":"Pub. L. 103–227, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"Mar. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/204"},"text":"108 Stat. 204","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
