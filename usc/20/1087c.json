{"tag":"section","attrib":{"id":"id0d2c6fdc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1087c"},"text":"§ 1087c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of institutions for participation and origination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d2c6fdd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall enter into agreements pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087d/a"},"text":"section 1087d(a) of this title","children":[],"tail":" with institutions of higher education to participate in the direct student loan program under this part, and agreements pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087d/b"},"text":"section 1087d(b) of this title","children":[],"tail":" with institutions of higher education, or consortia thereof, to originate loans in such program, for academic years beginning on or after "},{"tag":"date","attrib":{"date":"1994-07-01"},"text":"July 1, 1994","children":[],"tail":". Alternative origination services, through which an entity other than the participating institution at which the student is in attendance originates the loan, shall be provided by the Secretary, through 1 or more contracts under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087f/b"},"text":"section 1087f(b) of this title","children":[],"tail":" or such other means as the Secretary may provide, for students attending participating institutions that do not originate direct student loans under this part. Such agreements for the academic year 1994–1995 shall, to the extent feasible, be entered into not later than "},{"tag":"date","attrib":{"date":"1994-01-01"},"text":"January 1, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d2c6fde-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d2c6fdf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each institution of higher education desiring to participate in the direct student loan program under this part shall submit an application satisfactory to the Secretary containing such information and assurances as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d2c6fe0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall select institutions for participation in the direct student loan program under this part, and shall enter into agreements with such institutions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087d/a"},"text":"section 1087d(a) of this title","children":[],"tail":", from among those institutions that submit the applications described in paragraph (1), and meet such other eligibility requirements as the Secretary shall prescribe."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d2c6fe1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria for origination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d2c6fe2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may enter into a supplemental agreement with an institution (or a consortium of such institutions) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d2c6fe3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087c/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an agreement under subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002082"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002082"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 1087d(a) of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d2c6fe4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087c/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" desires to originate loans under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d2c6fe5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087c/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the criteria described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d2c6fe6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may approve an institution to originate loans only if such institution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d2c6fe7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not on the reimbursement system of payment for any of the programs under subpart 1 or 3 of part A, part C, or part E of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d2c6fe8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not overdue on program or financial reports or audits required under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d2c6fe9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087c/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not subject to an emergency action, or a limitation, suspension, or termination under section 1078(b)(1)(T), 1082(h), or 1094(c) of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d2c6fea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087c/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the opinion of the Secretary, has not had severe performance deficiencies for any of the programs under this subchapter, including such deficiencies demonstrated by audits or program reviews submitted or conducted during the 5 calendar years immediately preceding the date of application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d2c6feb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087c/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides an assurance that such institution has no delinquent outstanding debts to the Federal Government, unless such debts are being repaid under or in accordance with a repayment arrangement satisfactory to the Federal Government, or the Secretary in the Secretary’s discretion determines that the existence or amount of such debts has not been finally determined by the cognizant Federal agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d2c6fec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087c/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets such other criteria as the Secretary may establish to protect the financial interest of the United States and to promote the purposes of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d2c6fed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not select an institution of higher education for participation under this section unless such institution is an eligible institution under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1085/a"},"text":"section 1085(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d2c6fee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consortia","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to such requirements as the Secretary may prescribe, eligible institutions of higher education (as determined under subsection (d)) with agreements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087d/a"},"text":"section 1087d(a) of this title","children":[],"tail":" may apply to the Secretary as consortia to originate loans under this part for students in attendance at such institutions. Each such institution shall be required to meet the requirements of subsection (c) with respect to loan origination."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d2c6fef-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s453"},"text":"Pub. L. 89–329, title IV, § 453","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s404"},"text":"Pub. L. 99–498, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1438"},"text":"100 Stat. 1438","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s451"},"text":"Pub. L. 102–325, title IV, § 451","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/569"},"text":"106 Stat. 569","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tIV/s4021"},"text":"Pub. L. 103–66, title IV, § 4021","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/342"},"text":"107 Stat. 342","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/e"},"text":"Pub. L. 103–208, § 2(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2470"},"text":"107 Stat. 2470","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s451"},"text":"Pub. L. 105–244, title IV, § 451","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1715"},"text":"112 Stat. 1715","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tIV/s404/b/1"},"text":"Pub. L. 111–39, title IV, § 404(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1946"},"text":"123 Stat. 1946","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d2c6ff0-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d2c6ff1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d2c6ff2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2"},"text":"section 2 of Pub. L. 103–208","children":[],"tail":" (which was effective as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":") was executed to this section as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d2c6ff3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1087c, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s453"},"text":"Pub. L. 89–329, title IV, § 453","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/575/tI/s141"},"text":"Pub. L. 90–575, title I, § 141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-16"},"text":"Oct. 16, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1032"},"text":"82 Stat. 1032","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/318/tI/s136/b/2"},"text":"Pub. L. 92–318, title I, § 136(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/272"},"text":"86 Stat. 272","children":[],"tail":", authorized grants and contracts for training and research in cooperative education programs, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/482/tI/s129/a"},"text":"Pub. L. 94–482, title I, § 129(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2144"},"text":"90 Stat. 2144","children":[],"tail":", eff. 30 days after "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d2c6ff4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" struck out par. (3). Text read as follows: “The Secretary shall promulgate and publish in the Federal Register regulations governing the approval of institutions to originate loans under this part in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087g/a/2"},"text":"section 1087g(a)(2) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s451/a"},"text":"Pub. L. 105–244, § 451(a)","children":[],"tail":", amended heading, redesignated par. (1) as entire subsec., and struck out pars. (2) to (4) which provided for transition from loan programs under part B of this subchapter to direct student loan program under this part and defined term “new student loan volume”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s451/b"},"text":"Pub. L. 105–244, § 451(b)","children":[],"tail":", substituted “prescribe.” for “prescribe, by, to the extent possible—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A)(i) categorizing such institutions according to anticipated loan volume, length of academic program, control of the institution, highest degree offered, size of student enrollment, geographic location, annual loan volume, and default experience; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) beginning in academic year 1995–1996 selecting institutions that are reasonably representative of each of the categories described pursuant to clause (i); and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) if the Secretary determines it necessary in order to carry out the purposes of subparagraph (A) and attain such reasonable representation (as required by subparagraph (A)), selecting additional institutions.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s451/c/1/A"},"text":"Pub. L. 105–244, § 451(c)(1)(A)","children":[],"tail":", (B), substituted “Selection criteria” for “Transition selection criteria” in heading and “The Secretary” for “For academic year 1994–1995, the Secretary” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s451/c/1/E"},"text":"Pub. L. 105–244, § 451(c)(1)(E)","children":[],"tail":", redesignated subpar. (B) as (A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s451/c/1/C"},"text":"Pub. L. 105–244, § 451(c)(1)(C)","children":[],"tail":", struck out subpar. (A) which read as follows: “made loans under part E of this subchapter in academic year 1993–1994 and did not exceed the applicable maximum default rate under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087bb/g"},"text":"section 1087bb(g) of this title","children":[],"tail":" for the most recent fiscal year for which data are available;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B) to (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s451/c/1/E"},"text":"Pub. L. 105–244, § 451(c)(1)(E)","children":[],"tail":", redesignated subpars. (C), (D), and (F) as (B) to (D), respectively. Former subpar. (B) redesignated (A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s451/c/1/E"},"text":"Pub. L. 105–244, § 451(c)(1)(E)","children":[],"tail":", redesignated subpar. (G) as (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s451/c/1/D"},"text":"Pub. L. 105–244, § 451(c)(1)(D)","children":[],"tail":", struck out subpar. (E) which read as follows: “in the opinion of the Secretary, has not had significant deficiencies identified by a State postsecondary review entity under subpart 1 of part H of this subchapter;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(F) to (H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s451/c/1/E"},"text":"Pub. L. 105–244, § 451(c)(1)(E)","children":[],"tail":", redesignated subpars. (G) and (H) as (E) and (F), respectively. Former subpar. (F) redesignated (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s451/c/2"},"text":"Pub. L. 105–244, § 451(c)(2)","children":[],"tail":", struck out “after transition” after “approval” in heading and substituted “The Secretary” for “For academic year 1995–1996 and subsequent academic years, the Secretary” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" amended section generally, substituting provisions relating to selection of institutions for participation and origination for former provisions relating to selection by Secretary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208"},"text":"Pub. L. 103–208","children":[],"tail":" amended subpar. (B) generally. Prior to amendment, subpar. (B) read as follows: “if the Secretary determines it necessary to carry out the purposes of this part, selecting additional institutions.” See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":" amended section generally, substituting provisions relating to selection by the Secretary for former provisions relating to agreements with institutions of higher education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d2c6ff5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d2c6ff6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" effective as if enacted on the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/s3"},"text":"section 3 of Pub. L. 111–39","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d2c6ff7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p