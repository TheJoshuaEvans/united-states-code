{"tag":"section","attrib":{"id":"id0c74dfe9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s46"},"text":null,"children":[{"tag":"num","attrib":{"value":"46"},"text":"§ 46.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Board of Regents shall take charge of the building and property of the institution, and shall, under their direction, make a fair and accurate record of all their proceedings, to be preserved in the institution until no longer needed in conducting current business; and shall also discharge the duties of librarian and of keeper of the museum, and may, with the consent of the Board of Regents, employ assistants.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c74dfea-3a70-11f1-a648-bee82ed8a795"},"text":"(R.S. § 5583; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1951-10-25/ch562/s2/4"},"text":"Oct. 25, 1951, ch. 562, § 2(4)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/639"},"text":"65 Stat. 639","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c74dfeb-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c74dfec-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0c74dfed-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5583 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1846-08-10/ch178/s7"},"text":"act Aug. 10, 1846, ch. 178, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/9/105"},"text":"9 Stat. 105","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0c74dfee-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1951—Act ","children":[{"tag":"date","attrib":{"date":"1951-10-25"},"text":"Oct. 25, 1951","children":[],"tail":", inserted “until no longer needed in conducting current business”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
