hildren":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/247"},"text":"86 Stat. 247","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cddb3f7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(7)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s320/4"},"text":"Pub. L. 110–315, § 320(4)","children":[],"tail":", substituted “subparagraph (D)” for “subparagraph (E)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s317"},"text":"Pub. L. 110–315, § 317","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s308/a"},"text":"Pub. L. 105–244, § 308(a)","children":[],"tail":", amended heading and text of subsec. (a) generally. Prior to amendment, text read as follows: “Any institution which is eligible for assistance under this subchapter shall submit to the Secretary an application for assistance at such time, in such form, and containing such information, as may be necessary to enable the Secretary to evaluate its need for assistance. Subject to the availability of appropriations to carry out this subchapter, the Secretary may approve an application for a grant under this subchapter if the application meets the requirements of subsection (b) of this section and shows that the applicant is eligible for assistance in accordance with the part of this subchapter under which the assistance is sought.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s308/b"},"text":"Pub. L. 105–244, § 308(b)","children":[],"tail":", inserted “, D or E” after “part C”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6).