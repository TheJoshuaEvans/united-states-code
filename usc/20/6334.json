{"tag":"section","attrib":{"id":"id0e0c96a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334"},"text":null,"children":[{"tag":"num","attrib":{"value":"6334"},"text":"§ 6334.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concentration grants to local educational agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e0c96a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for and amount of grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0c96a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0c96a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as otherwise provided in this paragraph, each local educational agency which is eligible for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333"},"text":"section 6333 of this title","children":[],"tail":" for any fiscal year is eligible for an additional grant under this section for that fiscal year if the number of children counted under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333/c"},"text":"section 6333(c) of this title","children":[],"tail":" in the agency exceeds either—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0e0c96a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6,500; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0c96a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 15 percent of the total number of children aged 5 through 17 in the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0c96a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6332"},"text":"section 6332 of this title","children":[],"tail":", no State shall receive less than the lesser of—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0e0c96a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 0.25 percent of the total amount allocated to States under this section for fiscal year 2001, plus 0.35 percent of the total amount allocated to States under this section in excess of the amount allocated for fiscal year 2001; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0c96a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the average of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e0c96aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334/a/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount calculated under clause (i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e0c96ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334/a/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the greater of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id0e0c96ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334/a/1/B/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $340,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id0e0c96ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334/a/1/B/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of children in such State counted for purposes of this section in that fiscal year multiplied by 150 percent of the national average per-pupil payment made with funds available under this section for that year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c96ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each county or local educational agency eligible to receive an additional grant under this section for any fiscal year, the Secretary shall determine the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0c96af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of children counted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333/c"},"text":"section 6333(c) of this title","children":[],"tail":" for that fiscal year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0c96b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333/a/1/B"},"text":"section 6333(a)(1)(B) of this title","children":[],"tail":" for each State except the Commonwealth of Puerto Rico, and the amount in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333/a/4"},"text":"section 6333(a)(4) of this title","children":[],"tail":" for the Commonwealth of Puerto Rico."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c96b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the additional grant for which an eligible local educational agency or county is eligible under this section for any fiscal year shall be an amount which bears the same ratio to the amount available to carry out this section for that fiscal year as the product determined under paragraph (2) for such local educational agency for that fiscal year bears to the sum of such products for all local educational agencies in the United States for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c96b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local allocations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0c96b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grant amounts under this section shall be determined in accordance with section 6333(a)(2), (3), and (4) of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0c96b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For any fiscal year for which the Secretary allocates funds under this section on the basis of counties, a State may reserve not more than 2 percent of its allocation under this section to make grants to local educational agencies that meet the criteria of paragraph (1)(A)(i) or (ii) and are in ineligible counties that do not meet these criteria.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0c96b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any State for which on ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":", the number of children counted under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333/c"},"text":"section 6333(c) of this title","children":[],"tail":" is less than 0.25 percent of the number of those children counted for all States, the State educational agency shall allocate funds under this section among the local educational agencies in the State either—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0c96b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with paragraphs (2) and (4) of subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c96b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6334/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on their respective concentrations and numbers of children counted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333/c"},"text":"section 6333(c) of this title","children":[],"tail":", except that only those local educational agencies with concentrations or numbers of children counted under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333/c"},"text":"section 6333(c) of this title","children":[],"tail":" that exceed the statewide average percentage of such children or the statewide average number of such children shall receive any funds on the basis of this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e0c96b8-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1124A"},"text":"Pub. L. 89–10, title I, § 1124A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1521"},"text":"115 Stat. 1521","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e0c96b9-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e0c96ba-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e0c96bb-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6334, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1124A"},"text":"Pub. L. 89–10, title I, § 1124A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3569"},"text":"108 Stat. 3569","children":[],"tail":", related to concentration grants to local educational agencies, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
