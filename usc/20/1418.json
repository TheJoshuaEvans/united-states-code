{"tag":"section","attrib":{"id":"id0da856d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418"},"text":null,"children":[{"tag":"num","attrib":{"value":"1418"},"text":"§ 1418.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0da856d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State that receives assistance under this subchapter, and the Secretary of the Interior, shall provide data each year to the Secretary of Education and the public on the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0da856d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0da856da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The number and percentage of children with disabilities, by race, ethnicity, limited English proficiency status, gender, and disability category, who are in each of the following separate categories:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0da856db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Receiving a free appropriate public education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da856dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Participating in regular education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da856dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In separate classes, separate schools or facilities, or public or private residential facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da856de-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each year of age from age 14 through 21, stopped receiving special education and related services because of program completion (including graduation with a regular secondary school diploma), or other reasons, and the reasons why those children stopped receiving special education and related services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da856df-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/a/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0da856e0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/a/1/A/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Removed to an interim alternative educational setting under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1415/k/1"},"text":"section 1415(k)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0da856e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/a/1/A/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The acts or items precipitating those removals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0da856e2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/a/1/A/v/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of children with disabilities who are subject to long-term suspensions or expulsions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da856e3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number and percentage of children with disabilities, by race, gender, and ethnicity, who are receiving early intervention services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da856e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number and percentage of children with disabilities, by race, gender, and ethnicity, who, from birth through age 2, stopped receiving early intervention services because of program completion or for other reasons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da856e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The incidence and duration of disciplinary actions by race, ethnicity, limited English proficiency status, gender, and disability category, of children with disabilities, including suspensions of 1 day or more.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da856e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number and percentage of children with disabilities who are removed to alternative educational settings or expelled as compared to children without disabilities who are removed to alternative educational settings or expelled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da856e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of due process complaints filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1415"},"text":"section 1415 of this title","children":[],"tail":" and the number of hearings conducted."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da856e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of hearings requested under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1415/k"},"text":"section 1415(k) of this title","children":[],"tail":" and the number of changes in placements ordered as a result of those hearings."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da856e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of mediations held and the number of settlement agreements reached through such mediations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da856ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number and percentage of infants and toddlers, by race, and ethnicity, who are at risk of having substantial developmental delays (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1432"},"text":"section 1432 of this title","children":[],"tail":"), and who are receiving early intervention services under subchapter III."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da856eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other information that may be required by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da856ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0da856ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of identifiable data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The data described in subsection (a) shall be publicly reported by each State in a manner that does not result in the disclosure of data identifiable to individual children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da856ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sampling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may permit States and the Secretary of the Interior to obtain the data described in subsection (a) through sampling.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da856ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide technical assistance to States to ensure compliance with the data collection and reporting requirements under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da856f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disproportionality","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0da856f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State that receives assistance under this subchapter, and the Secretary of the Interior, shall provide for the collection and examination of data to determine if significant disproportionality based on race and ethnicity is occurring in the State and the local educational agencies of the State with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0da856f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of children as children with disabilities, including the identification of children as children with disabilities in accordance with a particular impairment described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1401/3"},"text":"section 1401(3) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da856f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the placement in particular educational settings of such children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da856f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the incidence, duration, and type of disciplinary actions, including suspensions and expulsions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da856f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and revision of policies, practices, and procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a determination of significant disproportionality with respect to the identification of children as children with disabilities, or the placement in particular educational settings of such children, in accordance with paragraph (1), the State or the Secretary of the Interior, as the case may be, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0da856f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the review and, if appropriate, revision of the policies, procedures, and practices used in such identification or placement to ensure that such policies, procedures, and practices comply with the requirements of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da856f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require any local educational agency identified under paragraph (1) to reserve the maximum amount of funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1413/f"},"text":"section 1413(f) of this title","children":[],"tail":" to provide comprehensive coordinated early intervening services to serve children in the local educational agency, particularly children in those groups that were significantly overidentified under paragraph (1); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da856f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1418/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the local educational agency to publicly report on the revision of policies, practices, and procedures described under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0da856f9-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s618"},"text":"Pub. L. 91–230, title VI, § 618","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2738"},"text":"118 Stat. 2738","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0da856fa-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0da856fb-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0da856fc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1418, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s618"},"text":"Pub. L. 91–230, title VI, § 618","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/17/tI/s101"},"text":"Pub. L. 105–17, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-04"},"text":"June 4, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/101"},"text":"111 Stat. 101","children":[],"tail":", related to program information, prior to the general amendment of subchapters I to IV of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/108/446"},"text":"Pub. L. 108–446","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1418, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s618"},"text":"Pub. L. 91–230, title VI, § 618","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/142/s5/a"},"text":"Pub. L. 94–142, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-29"},"text":"Nov. 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/791"},"text":"89 Stat. 791","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/199"},"text":"Pub. L. 98–199","children":[],"tail":", §§ 3(b), 8, "},{"tag":"date","attrib":{"date":"1983-12-02"},"text":"Dec. 2, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1358"},"text":"97 Stat. 1358","children":[],"tail":", 1360; "},{"tag":"ref","attrib":{"href":"/us/pl/99/457/tIV/s406"},"text":"Pub. L. 99–457, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-08"},"text":"Oct. 8, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1174"},"text":"100 Stat. 1174","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/630/tI/s102/h"},"text":"Pub. L. 100–630, title I, § 102(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3295"},"text":"102 Stat. 3295","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/476/tII/s203"},"text":"Pub. L. 101–476, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-30"},"text":"Oct. 30, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1112"},"text":"104 Stat. 1112","children":[],"tail":", related to evaluation and program information, prior to the general amendment of subchapters I to IV of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/17"},"text":"Pub. L. 105–17","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tai