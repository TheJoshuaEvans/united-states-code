{"tag":"section","attrib":{"id":"id0cdb4240-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1066c"},"text":"§ 1066c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on Federal insurance for bonds issued by designated bonding authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cdb4241-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At no time shall the aggregate principal amount of outstanding bonds insured under this part together with any accrued unpaid interest thereon exceed $1,100,000,000, of which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cdb4242-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $733,333,333 shall be used for loans to eligible institutions that are private historically Black colleges and universities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb4243-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $366,666,667 shall be used for loans to eligible institutions which are historically Black public colleges and universities.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of paragraphs (1) and (2), Lincoln University of Pennsylvania is an historically Black public institution. No institution of higher education that has received assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s123"},"text":"section 123 of this title","children":[],"tail":" shall be eligible to receive assistance under this part."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cdb4244-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on credit authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the Secretary to issue letters of credit and insurance under this part is effective only to the extent provided in advance by appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cdb4245-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Religious activity prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No loan may be made under this part for any educational program, activity or service related to sectarian instruction or religious worship or provided by a school or department of divinity or to an institution in which a substantial portion of its functions is subsumed in a religious mission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cdb4246-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discrimination prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No loan may be made to an institution under this part if the institution discriminates on account of race, color, religion, national origin, sex (to the extent provided in title IX of the Education Amendments of 1972 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1681"},"text":"20 U.S.C. 1681","children":[],"tail":" et seq.]), or disabling condition; except that the prohibition with respect to religion shall not apply to an institution which is controlled by or which is closely identified with the tenets of a particular religious organization if the application of this section would not be consistent with the religious tenets of such organization."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cdb4247-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s344"},"text":"Pub. L. 89–329, title III, § 344","children":[],"tail":", formerly title VII, § 724, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tVII/s704"},"text":"Pub. L. 102–325, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/745"},"text":"106 Stat. 745","children":[],"tail":"; renumbered title III, § 344, "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIII/s301/a/3"},"text":"Pub. L. 105–244, title III, § 301(a)(3)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1636"},"text":"112 Stat. 1636","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIII/s314/c"},"text":"Pub. L. 110–315, title III, § 314(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3181"},"text":"122 Stat. 3181","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cdb4248-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cdb4249-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0cdb424a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Education Amendments of 1972, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/318"},"text":"Pub. L. 92–318","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/235"},"text":"86 Stat. 235","children":[],"tail":". Title IX of the Act, known as the Patsy Takemoto Mink Equal Opportunity in Education Act, is classified principally to chapter 38 (§ 1681 et seq.) of this title. For complete classification of title IX to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1681"},"text":"section 1681 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0cdb424b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1132c–3"},"text":"section 1132c–3 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cdb424c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s344"},"text":"section 344 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1069"},"text":"section 1069 of this title","children":[],"tail":" prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cdb424d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s314/c/1"},"text":"Pub. L. 110–315, § 314(c)(1)","children":[],"tail":", substituted “$1,100,000,000” for “$375,000,000” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s314/c/2"},"text":"Pub. L. 110–315, § 314(c)(2)","children":[],"tail":", substituted “$733,333,333” for “$250,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s314/c/3"},"text":"Pub. L. 110–315, § 314(c)(3)","children":[],"tail":", substituted “$366,666,667” for “$125,000,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
