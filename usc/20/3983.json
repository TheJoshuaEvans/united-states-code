{"tag":"section","attrib":{"id":"id0de18f21-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3983"},"text":null,"children":[{"tag":"num","attrib":{"value":"3983"},"text":"§ 3983.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de18f22-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3983/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized, in accordance with the provisions of this part, to make grants to applicants to pay the Federal share of the costs of the activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3984"},"text":"section 3984 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de18f23-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3983/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $50,000,000 for each of the fiscal years 1986 and 1987. There are authorized to be appropriated to carry out the provisions of this part $15,000,000 for fiscal year 1989 and such sums as may be necessary for each of the fiscal years 1990, 1991, 1992, and 1993.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de18f24-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tIII/s304"},"text":"Pub. L. 98–377, title III, § 304","children":[],"tail"