{"tag":"section","attrib":{"id":"id0cf337b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–36"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070d–36"},"text":"§ 1070d–36.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility of scholars","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cf337b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–36/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High school graduation or equivalent and admission to institution required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each student awarded a scholarship under this subpart shall be a graduate of a public or private secondary school (or a home school, whether treated as a home school or a private school under State law) or have the equivalent of a certificate of graduation as recognized by the State in which the student resides and must have been admitted for enrollment at an institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cf337b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–36/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection based on promise of academic achievement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each student awarded a scholarship under this subpart must demonstrate outstanding academic achievement and show promise of continued academic achievement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cf337ba-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s419F"},"text":"Pub. L. 89–329, title IV, § 419F","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s401/a"},"text":"Pub. L. 99–498, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1344"},"text":"100 Stat. 1344","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s409/a"},"text":"Pub. L. 110–315, title IV, § 409(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3225"},"text":"122 Stat. 3225","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cf337bb-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cf337bc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cf337bd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1070d–36, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s419F"},"text":"Pub. L. 89–329, title IV, § 419F","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/558/tVIII/s801/a"},"text":"Pub. L. 98–558, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2901"},"text":"98 Stat. 2901","children":[],"tail":", related to eligibility of students for scholarships under Robert C. Byrd Honors Scholarship Program, prior to the general revision of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cf337be-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" inserted “(or a home school, whether treated as a home school or a private school under State law)” after “public or private secondary school”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
