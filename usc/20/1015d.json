,"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tIII/s7316/b"},"text":"Pub. L. 118–31, div. G, title III, § 7316(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1033"},"text":"137 Stat. 1033","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dG/tIII/s7316/b"},"text":"“The amendments made by subsection (a) [amending this section] shall take effect at each public institution of higher education in a State that receives assistance under the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"20 U.S.C. 1001","children":[],"tail":" et seq.) for the first period of enrollment at such institution that begins after "},{"tag":"date","attrib":{"date":"2024-07-01"},"text":"July 1, 2024","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cc3748f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXII/s6206/b"},"text":"Pub. L. 117–81, div. F, title LXII, § 6206(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2392"},"text":"135 Stat. 2392","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dF/tLXII/s6206/b"},"text":"“The amendments made by subsection (a) [amending this section] shall take effect at each public institution of higher education in a State that receives assistance under the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href