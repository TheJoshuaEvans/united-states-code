{"tag":"section","attrib":{"id":"id0cc37480-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1015d"},"text":"§ 1015d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In-State tuition rates for members of qualifying Federal service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cc37481-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a member of a qualifying Federal service whose domicile or permanent duty station is in a State that receives assistance under this chapter, such State shall not charge such member (or the spouse or dependent child of such member) tuition for attendance at a public institution of higher education in the State at a rate that is greater than the rate charged for residents of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc37482-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a member of a qualifying Federal service (or the spouse or dependent child of a member) pays tuition at a public institution of higher education in a State at a rate determined by subsection (a), the provisions of subsection (a) shall continue to apply to such member, spouse, or dependent while continuously enrolled at that institution, notwithstanding a subsequent change in the permanent duty station of the member to a location outside the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc37483-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect at each public institution of higher education in a State that receives assistance under this chapter for the first period of enrollment at such institution that begins after ","children":[{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc37484-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “member of a qualifying Federal service” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cc37485-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the armed forces (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of title 10","children":[],"tail":") who is on active duty for a period of more than 30 days (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of title 10","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc37486-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the Foreign Service (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3903"},"text":"section 3903 of title 22","children":[],"tail":") who is on active duty for a period of more than 30 days; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc37487-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015d/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer or employee of an element of the intelligence community (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of title 50","children":[],"tail":") who serves in a position of employment in such element for a period of more than 30 days."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cc37488-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s135"},"text":"Pub. L. 89–329, title I, § 135","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tI/s114"},"text":"Pub. L. 110–315, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3111"},"text":"122 Stat. 3111","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXII/s6206/a"},"text":"Pub. L. 117–81, div. F, title LXII, § 6206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2392"},"text":"135 Stat. 2392","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tIII/s7316/a"},"text":"Pub. L. 118–31, div. G, title III, § 7316(a)","c