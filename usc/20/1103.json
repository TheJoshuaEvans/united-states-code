{"tag":"section","attrib":{"id":"id0d6a632a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103"},"text":null,"children":[{"tag":"num","attrib":{"value":"1103"},"text":"§ 1103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility; applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d6a632b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutional eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Hispanic-serving institution desiring to receive assistance under this subchapter shall submit to the Secretary such enrollment data as may be necessary to demonstrate that the institution is a Hispanic-serving institution as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1101a"},"text":"section 1101a of this title","children":[],"tail":", along with such other data and information as the Secretary may by regulation require."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6a632c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6a632d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any institution which is eligible for assistance under this subchapter shall submit to the Secretary an application for assistance at such time, in such form, and containing such information, as may be necessary to enable the Secretary to evaluate the institution’s need for assistance. Subject to the availability of appropriations to carry out this subchapter, the Secretary may approve an application for a grant under this subchapter only if the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d6a632e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application meets the requirements of subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6a632f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution is eligible for assistance in accordance with the provisions of this subchapter under which the assistance is sought.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a6330-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preliminary applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1), the Secretary may develop a preliminary application for use by Hispanic-serving institutions applying under this subchapter prior to the submission of the principal application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6a6331-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Hispanic-serving institution, in the institution’s application for a grant, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6a6332-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth, or describe how the institution will develop, a comprehensive development plan to strengthen the institution’s academic quality and institutional management, and otherwise provide for institutional self-sufficiency and growth (including measurable objectives for the institution and the Secretary to use in monitoring the effectiveness of activities under this subchapter);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a6333-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a 5-year plan for improving the assistance provided by the Hispanic-serving institution to Hispanic students and other low-income individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a6334-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth policies and procedures to ensure that Federal funds made available under this subchapter for any fiscal year will be used to supplement and, to the extent practical, increase the funds that would otherwise be made available for the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1101/b"},"text":"section 1101(b) of this title","children":[],"tail":", and in no case supplant those funds;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a6335-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth policies and procedures for evaluating the effectiveness in accomplishing the purpose of the activities for which a grant is sought under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a6336-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for such fiscal control and fund accounting procedures as may be necessary to ensure proper disbursement of and accounting for funds made available to the institution under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a6337-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that the institution will comply with the limitations set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1103e"},"text":"section 1103e of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a6338-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describe in a comprehensive manner any proposed project for which funds are sought under the application and include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d6a6339-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the various components of the proposed project, including the estimated time required to complete each such component;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6a633a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any development project that consists of several components (as described by the institution pursuant to subparagraph (A)), a statement identifying those components which, if separately funded, would be sound investments of Federal funds and those components which would be sound investments of Federal funds only if funded under this subchapter in conjunction with other parts of the development project (as specified by the institution);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6a633b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/c/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation by the institution of the priority given any proposed project for which funds are sought in relation to any other projects for which funds are sought by the institution under this subchapter, and a similar evaluation regarding priorities among the components of any single proposed project (as described by the institution pursuant to subparagraph (A));","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6a633c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/c/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed budget showing the manner in which funds for any proposed project would be spent by the institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6a633d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/c/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed description of any activity which involves the expenditure of more than $25,000, as identified in the budget referred to in subparagraph (D);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a633e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for making reports, in such form and containing such information, as the Secretary may require to carry out the Secretary’s functions under this subchapter, including not less than one report annually setting forth the institution’s progress toward achieving the objectives for which the funds were awarded and for keeping such records and affording such access to such records, as the Secretary may find necessary to assure the correctness and verification of such reports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a633f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include such other information as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6a6340-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to applications for assistance under this section, the Secretary shall give priority to an application that contains satisfactory evidence that the Hispanic-serving institution has entered into or will enter into a collaborative arrangement with at least one local educational agency or community-based organization to provide such agency or organization with assistance (from funds other than funds provided under this subchapter) in reducing dropout rates for Hispanic students, improving rates of academic achievement for Hispanic students, and increasing the rates at which Hispanic secondary school graduates enroll in higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6a6341-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use the most recent and relevant data concerning the number and percentage of students receiving need-based assistance under subchapter IV in making eligibility determinations and shall advance the base-year for the determinations forward following each annual grant cycle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6a6342-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tV/s521"},"text":"Pub. L. 89–329, title V, § 521","children":[],"tail":", formerly § 511, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tV/s501"},"text":"Pub. L. 105–244, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1770"},"text":"112 Stat. 1770","children":[],"tail":"; renumbered § 521 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tV"},"text":"Pub. L. 110–315, title V","children":[],"tail":", §§ 502(a)(2), (b)(2), 503, "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3331"},"text":"122 Stat. 3331","children":[],"tail":", 3333.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d6a6343-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d6a6344-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d6a6345-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1103, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tV/s511"},"text":"Pub. L. 89–329, title V, § 511","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tV/s501/a"},"text":"Pub. L. 102–325, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/674"},"text":"106 Stat. 674","children":[],"tail":", established program of grants for National Teacher Academies, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1103, ","children":[{"tag":"ref","attrib":{"