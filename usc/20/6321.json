{"tag":"section","attrib":{"id":"id0e0a25e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321"},"text":null,"children":[{"tag":"num","attrib":{"value":"6321"},"text":"§ 6321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e0a25e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of effort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local educational agency may receive funds under this part for any fiscal year only if the State educational agency involved finds that the local educational agency has maintained the agency’s fiscal effort in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7901"},"text":"section 7901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0a25e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal funds to supplement, not supplant, non-Federal funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0a25e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State educational agency or local educational agency shall use Federal funds received under this part only to supplement the funds that would, in the absence of such Federal funds, be made available from State and local sources for the education of students participating in programs assisted under this part, and not to supplant such funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0a25e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To demonstrate compliance with paragraph (1), a local educational agency shall demonstrate that the methodology used to allocate State and local funds to each school receiving assistance under this part ensures that such school receives all of the State and local funds it would otherwise receive if it were not receiving assistance under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0a25e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No local educational agency shall be required to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0a25ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify that an individual cost or service supported under this part is supplemental; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0a25eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide services under this part through a particular instructional method or in a particular instructional setting in order to demonstrate such agency’s compliance with paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0a25ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to authorize or permit the Secretary to prescribe the specific methodology a local educational agency uses to allocate State and local funds to each school receiving assistance under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0a25ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timeline","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A local educational agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0a25ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall meet the compliance requirement under paragraph (2) not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"December 10, 2015","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0a25ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may demonstrate compliance with the requirement under paragraph (1) before the end of such 2-year period using the method such local educational agency used on the day before ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"December 10, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0a25f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comparability of services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0a25f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0a25f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comparable services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraphs (4) and (5), a local educational agency may receive funds under this part only if State and local funds will be used in schools served under this part to provide services that, taken as a whole, are at least comparable to services in schools that are not receiving funds under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0a25f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantially comparable services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the local educational agency is serving all of such agency’s schools under this part, such agency may receive funds under this part only if such agency will use State and local funds to provide services that, taken as a whole, are substantially comparable in each school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0a25f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local educational agency may meet the requirements of subparagraphs (A) and (B) on a grade-span by grade-span basis or a school-by-school basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0a25f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written assurance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0a25f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equivalence","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A local educational agency shall be considered to have met the requirements of paragraph (1) if such agency has filed with the State educational agency a written assurance that such agency has established and implemented—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e0a25f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local educational agency-wide salary schedule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0a25f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a policy to ensure equivalence among schools in teachers, administrators, and other staff; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0c95f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a policy to ensure equivalence among schools in the provision of curriculum materials and instructional supplies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0c95fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this subsection, in the determination of expenditures per pupil from State and local funds, or instructional salaries per pupil from State and local funds, staff salary differentials for years of employment shall not be included in such determinations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0c95fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local educational agency need not include unpredictable changes in student enrollment or personnel assignments that occur after the beginning of a school year in determining comparability of services under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c95fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures and records","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each local educational agency assisted under this part shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0c95fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop procedures for compliance with this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0c95fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain records that are updated biennially documenting such agency’s compliance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c95ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not apply to a local educational agency that does not have more than one building for each grade span.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c9600-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of determining compliance with paragraph (1), a local educational agency may exclude State and local funds expended for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0c9601-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" language instruction educational programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0c9602-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the excess costs of providing services to children with disabilities as determined by the local educational agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0c9603-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6321/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of complying with subsections (b) and (c), a State educational agency or local educational agency may exclude supplemental State or local funds expended in any school attendance area or school for programs that meet the intent and purposes of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e0c9604-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1118"},"text":"Pub. L. 89–10, title I, § 1118","children":[],"tail":", formerly § 1120A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1511"},"text":"115 Stat. 1511","children":[],"tail":"; renumbered § 1118 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tI"},"text":"Pub. L. 114–95, title I","children":[],"tail":", §§ 1000(4), 1012, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1814"},"text":"129 Stat. 1814","children":[],"tail":", 1874.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e0c9605-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e0c9606-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e0c9607-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6321, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1120"},"text":"Pub. L. 89–10, title I, § 1120","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3557"},"text":"108 Stat. 3557","children":[],"tail":", related to participation of children enrolled in private schools, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s1118"},"text":"section 1118 of Pub. L. 89–10","children":[],"tail":" was renumbered section 1116 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6318"},"text":"section 6318 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s1118"},"text":"section 1118 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6319"},"text":"section 6319 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e0c9608-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1012/1"},"text":"Pub. L. 114–95, § 1012(1)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7901"},"text":"section 7901 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1012/2"},"text":"Pub. L. 114–95, § 1012(2)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which consisted of pars. (1) and (2) relating to general use of funds only to supplement and not to supplant non-Federal funds and special rule that no local educational agency be required to provide services through a particular instructional method or in a particular instructional setting."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e0c9609-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e0c960a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
