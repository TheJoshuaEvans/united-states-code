{"tag":"section","attrib":{"id":"id0e5426d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7929"},"text":null,"children":[{"tag":"num","attrib":{"value":"7929"},"text":"§ 7929.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Analysis and periodic review of departmental guidance","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall develop procedures for the approval and periodic review of significant guidance documents that include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e5426d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7929/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate approval processes within the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5426da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7929/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate identification of the agency or office issuing the documents, the activities to which and the persons to whom the documents apply, and the date of issuance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5426db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7929/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a publicly available list to identify those significant guidance documents that were issued, revised, or withdrawn within the past year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5426dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7929/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an opportunity for the public to request that an agency modify or rescind an existing significant guidance document.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e5426dd-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8549"},"text":"Pub. L. 89–10, title VIII, § 8549","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII/s8041"},"text":"Pub. L. 114–95, title VIII, § 8041","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2121"},"text":"129 Stat. 2121","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e5426de-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e5426df-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e5426e0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
