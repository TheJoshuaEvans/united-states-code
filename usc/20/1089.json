{"tag":"section","attrib":{"id":"id0d46ae9a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089"},"text":null,"children":[{"tag":"num","attrib":{"value":"1089"},"text":"§ 1089.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Master calendar","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d46ae9b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary required to comply with schedule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To assure adequate notification and timely delivery of student aid funds under this subchapter, the Secretary shall adhere to the following calendar dates in the year preceding the award year:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d46ae9c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Development and distribution of Federal and multiple data entry forms—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d46ae9d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by February 1: first meeting of the technical committee on forms design of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d46ae9e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by March 1: proposed modifications, updates, and notices pursuant to sections 1087rr and 1090(a)(5) ","children":[{"tag":"ref","attrib":{"idref":"fn002096"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002096"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title published in the Federal Register;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d46ae9f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by June 1: final modifications, updates, and notices pursuant to sections 1087rr and 1090(a)(5) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title published in the Federal Register;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d46aea0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by August 15: application for Federal student assistance and multiple data entry data elements and instructions approved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d46aea1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by August 30: final approved forms delivered to servicers and printers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d46aea2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by October 1: Federal and multiple data entry forms and instructions printed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d46aea3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by November 1: Federal and multiple data entry forms, instructions, and training materials distributed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d46aea4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Allocations of campus-based and Pell Grant funds—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d46aea5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by August 1: distribution of institutional application for campus-based funds (FISAP) to institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d46aea6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by October 1: final date for submission of FISAP by institutions to the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d46aea7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by November 15: edited FISAP and computer printout received by institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d46aea8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by December 1: appeals procedures received by institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d46aea9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by December 15: edits returned by institutions to the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d46aeaa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by February 1: tentative award levels received by institutions and final Pell Grant payment schedule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d46aeab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by February 15: closing date for receipt of institutional appeals by the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d46aeac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by March 1: appeals process completed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d46aead-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by April 1: final award notifications sent to institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d46aeae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/a/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by June 1: Pell Grant authorization levels sent to institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d46aeaf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, to the extent practicable, notify eligible institutions, guaranty agencies, lenders, interested software providers, and, upon request, other interested parties, by December 1 prior to the start of an award year of minimal hardware and software requirements necessary to administer programs under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d46aeb0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall attempt to conduct training activities for financial aid administrators and others in an expeditious and timely manner prior to the start of an award year in order to ensure that all participants are informed of all administrative requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d46aeb1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing for reallocations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any funds reallocated under section 1070b–3(d), 1087–52(d), or 1087bb(i) of this title, the Secretary shall reallocate such funds at any time during the course of the year that will best meet the purpose of the programs under subpart 3 of part A, part C, and part E, respectively. However, such reallocation shall occur at least once each year, not later than September 30 of that year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d46aeb2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delay of effective date of late publications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d46aeb3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), any regulatory changes initiated by the Secretary affecting the programs under this subchapter that have not been published in final form by November 1 prior to the start of the award year shall not become effective until the beginning of the second award year after such November 1 date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d46aeb4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d46aeb5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may designate any regulatory provision that affects the programs under this subchapter and is published in final form after November 1 as one that an entity subject to the provision may, in the entity’s discretion, choose to implement prior to the effective date described in paragraph (1). The Secretary may specify in the designation when, and under what conditions, an entity may implement the provision prior to that effective date. The Secretary shall publish any designation under this subparagraph in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d46aeb6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an entity chooses to implement a regulatory provision prior to the effective date described in paragraph (1), as permitted by subparagraph (A), the provision shall be effective with respect to that entity in accordance with the terms of the Secretary’s designation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d46aeb7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall notify the authorizing committees when a deadline included in the calendar described in subsection (a) is not met. Nothing in this section shall be interpreted to penalize institutions or deny them the specified times allotted to enable them to return information to the Secretary based on the failure of the Secretary to adhere to the dates specified in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d46aeb8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance calendar","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Prior to the beginning of each award year, the Secretary shall provide to institutions of higher education a list of all the reports and disclosures required under this chapter. The list shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d46aeb9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date each report or disclosure is required to be completed and to be submitted, made available, or disseminated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d46aeba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the required recipients of each report or disclosure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d46aebb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any required method for transmittal or dissemination of each report or disclosure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d46aebc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the content of each report or disclosure sufficient to allow the institution to identify the appropriate individuals to be assigned the responsibility for such report or disclosure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d46aebd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" references to the statutory authority, applicable regulations, and current guidance issued by the Secretary regarding each report or disclosure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d46aebe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1089/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information which is pertinent to the content or distribution of the report or disclosure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d46aebf-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s482"},"text":"Pub. L. 89–329, title IV, § 482","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s407/a"},"text":"Pub. L. 99–498, title IV, § 407(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1477"},"text":"100 Stat. 1477","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/50/s15/2"},"text":"Pub. L. 100–50, § 15(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-06-03"},"text":"June 3, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/355"},"text":"101 Stat. 355","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s482"},"text":"Pub. L. 102–325, title IV, § 482","children":[],"tail":", "},{"ta