{"tag":"section","attrib":{"id":"id0d92f986-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1232b"},"text":"§ 1232b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labor standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All laborers and mechanics employed by contractors or subcontractors on all construction and minor remodeling projects assisted under any applicable program shall be paid wages at rates not less than those prevailing on similar construction and minor remodeling in the locality as determined by the Secretary of Labor in accordance with sections 3141–3144, 3146, and 3147 of title 40. The Secretary of Labor shall have, with respect to the labor standards specified in this section, the authority and functions set forth in Reorganization Plan Numbered 14 of 1950 and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3145"},"text":"section 3145 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d92f987-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/tIV/s439"},"text":"Pub. L. 90–247, title IV, § 439","children":[],"tail":", formerly § 423, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/230/tIV/s401/a/10"},"text":"Pub. L. 91–230, title IV, § 401(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/169"},"text":"84 Stat. 169","children":[],"tail":"; renumbered § 433, "},{"tag":"ref","attrib":{"href":"/us/pl/92/318/tIII/s301/a/1"},"text":"Pub. L. 92–318, title III, § 301(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/326"},"text":"86 Stat. 326","children":[],"tail":"; renumbered § 439 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tII"},"text":"Pub. L. 103–382, title II","children":[],"tail":", §§ 212(b)(1), 261(d), "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3913"},"text":"108 Stat. 3913","children":[],"tail":", 3927.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d92f988-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d92f989-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d92f98a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Reorganization Plan Numbered 14 of 1950, referred to in text, is set out in the Appendix to Title 5, Government Organization and Employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d92f98b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Sections 3141–3144, 3146, and 3147 of title 40” substituted for “the Davis-Bacon Act, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s276a"},"text":"40 U.S.C. 276a","children":[],"tail":"—276a–5)” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s3145"},"text":"section 3145 of title 40","children":[],"tail":"” substituted for “"},{"tag":"ref","attrib":{"href":"/us/act/1934-06-13/s2"},"text":"section 2 of the Act of June 13, 1934","children":[],"tail":", as amended ("},{"tag":"ref","attrib":{"href":"/