{"tag":"section","attrib":{"id":"id0d7b2c0c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1137"},"text":null,"children":[{"tag":"num","attrib":{"value":"1137"},"text":"§ 1137.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions for subparts 1 through 4","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d7b2c0d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1137/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordinated administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the purpose described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1133/1"},"text":"section 1133(1) of this title","children":[],"tail":", the Secretary shall provide for coordinated administration and regulation of graduate programs assisted under subparts 1 through 4 of this part with other Federal programs providing assistance for graduate education in order to minimize duplication and improve efficiency to ensure that the programs are carried out in a manner most compatible with academic practices and with the standard timetables for applications for, and notifications of acceptance to, graduate programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7b2c0e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1137/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hiring authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of carrying out subparts 1 through 4 of this part, the Secretary shall appoint, without regard to the provisions of title 5 that govern appointments in the competitive service, such administrative and technical employees, with the appropriate educational background, as shall be needed to assist in the administration of such parts ","children":[{"tag":"ref","attrib":{"idref":"fn002115"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002115"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subparts”."}],"tail":". The employees shall be paid without regard to the provisions of chapter 51 and subchapter III of chapter 53 of such title relating to classification and General Schedule pay rates."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7b2c0f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1137/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use for religious purposes prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No institutional payment or allowance under section 1134b(b) or 1135d(a) of this title shall be paid to a school or department of divinity as a result of the award of a fellowship under subpart 1 or 2 of this part, respectively, to an individual who is studying for a religious vocation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7b2c10-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1137/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall evaluate the success of assistance provided to individuals under subpart 1, 2, 3, or 4 of this part with respect to graduating from their degree programs, and placement in faculty and professional positions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d7b2c11-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s731"},"text":"Pub. L. 89–329, title VII, § 731","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVII/s701"},"text":"Pub. L. 105–244, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1795"},"text":"112 Stat. 1795","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVII"},"text":"Pub. L. 110–315, title VII","children":[],"tail":", §§ 704(i), 706(a)(2), (3), "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3348"},"text":"122 Stat. 3348","children":[],"tail":", 3349.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d7b2c12-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d7b2c13-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d7b2c14-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1137, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tXI/s1121"},"text":"Pub. L. 89–329, title XI, § 1121","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tXI/s1101"},"text":"Pub. L. 102–325, title XI, § 1101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992"