trib":{"href":"/us/pl/110/315/s706/a/2"},"text":"Pub. L. 110–315, § 706(a)(2)","children":[],"tail":", substituted “subparts 1 through 4” for “subparts 1, 2, and 3” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s706/a/3/A"},"text":"Pub. L. 110–315, § 706(a)(3)(A)","children":[],"tail":", substituted “subparts 1 through 4” for “subparts 1, 2, and 3”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s706/a/3/B"},"text":"Pub. L. 110–315, § 706(a)(3)(B)","children":[],"tail":", substituted “subpart 1, 2, 3, or 4” for “subpart 1, 2, or 3”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s704/i"},"text":"Pub. L. 110–315, § 704(i)","children":[],"tail":", struck out subsec. (e). Prior to amendment, text read as follows: “The Secretary, using funds appropriated to carry out subparts 1 and 2 of this part, and before awarding any assistance under such parts to a recipient that did not receive assistance under part C or D of title IX (as such parts were in effect prior to "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"October 7, 1998","children":[],"tail":") shall continue to provide funding to recipients of assistance under such part C or D (as so in effect), as the case may be, pursuant to any multiyear award of such assistance.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
