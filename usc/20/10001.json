{"tag":"section","attrib":{"id":"id0e70aed3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10001"},"text":null,"children":[{"tag":"num","attrib":{"value":"10001"},"text":"§ 10001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e70aed4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10001/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outlying areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount appropriated to carry out this chapter, the Secretary of Education shall first allocate up to one-half of 1 percent to the outlying areas on the basis of their respective needs, as determined by the Secretary, in consultation with the Secretary of the Interior, for activities consistent with this chapter under such terms and conditions as the Secretary may determine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e70aed5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10001/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration and oversight","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, in addition, reserve up to $14,000,000 for administration and oversight of this chapter, including for program evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e70aed6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10001/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation for additional programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After reserving funds under subsections (a) and (b), the Secretary shall reserve $5,000,000,000 for grants under sections 10006 and 10007 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e70aed7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10001/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State allocations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After carrying out subsections (a), (b), and (c), the Secretary shall allocate the remaining funds made available to carry out this chapter to the States as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e70aed8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10001/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 61 percent on the basis of their relative population of individuals aged 5 through 24.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e70aed9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10001/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 39 percent on the basis of their relative total population.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e70aeda-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10001/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From funds allocated under subsection (d), the Secretary shall make grants to the Governor of each State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e70aedb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10001/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governor shall return to the Secretary any funds received under subsection (e) that the Governor does not award as subgrants or otherwise commit within two years of receiving such funds, and the Secretary shall reallocate such funds to the remaining States in accordance with subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e70aedc-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tXIV/s14001"},"text":"Pub. L. 111–5, div. A, title XIV, § 14001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/279"},"text":"123 Stat. 279","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
