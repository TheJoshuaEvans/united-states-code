7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2104"},"text":"90 Stat. 2104","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/43/s1/a/15"},"text":"Pub. L. 95–43, § 1(a)(15)","children":[],"tail":"–(17), "},{"tag":"date","attrib":{"date":"1977-06-15"},"text":"June 15, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/214"},"text":"91 Stat. 214","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/566/s5/b/2"},"text":"Pub. L. 95–566, § 5(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2403"},"text":"92 Stat. 2403","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tIV/s412/a"},"text":"Pub. L. 96–374, title IV, § 412(a)","children":[],"tail":", (b), (f), title XIII, § 1391(a)(1), "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1416"},"text":"94 Stat. 1416","children":[],"tail":", 1417, 1503; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tV/s535/a"},"text":"Pub. L. 97–35, title V, § 535(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/455"},"text":"95 Stat. 455","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXVI/s16013/e/1"},"text":"Pub. L. 99–272, title XVI, § 16013(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/341"},"text":"100 Stat. 341","children":[],"tail":", limited Federal loan insurance, prior to the general revision of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cfa63c7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1)(A)(i)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s8005/a/1"},"text":"Pub. L. 109–171, § 8005(a)(1)","children":[],"tail":", substituted “$3,500” for “$2,625”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A)(ii)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s8005/a/2"},"text":"Pub. L. 109–171, § 8005(a)(2)","children":[],"tail":", substituted “$4,500” for “$3,500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1)(A)(i)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s415/1/A"},"text":"Pub. L. 105–244, § 415(1)(A)","children":[],"tail":", inserted “and” after semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A)(i)(II), (III). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s415/1/B"},"text":"Pub. L. 105–244, § 415(1)(B)","children":[],"tail":", added subcl. (II) and struck out former subcls. (II) and (III) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(II) $1,750, if such student is enrolled in a program whose length is less than one academic year, but at least ⅔ of such an academic year; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(III) $875, if such student is enrolled in a program whose length is less than ⅔, but at least ⅓, of such an academic year;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A)(iii)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s415/2"},"text":"Pub. L. 105–244, § 415(2)","children":[],"tail":", inserted “and” after semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(1)(A)(ii), (iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/c/2/A"},"text":"Pub. L. 103–208, § 2(c)(2)(A)","children":[],"tail":", added cls. (ii) and (iii) and struck out former cls. (ii) and (iii) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the case of a student who has successfully completed such first year but has not successfully completed the remainder of a program of undergraduate study—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(I) $3,500, if such student is enrolled in a program whose length is at least one academic year in length (as determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1088"},"text":"section 1088 of this title","children":[],"tail":");"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(II) $2,325, if such student is enrolled in a program whose length is less than one academic year, but at least ⅔ of such an academic year; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(III) $1,175, if such student is enrolled in a program whose length is less than ⅔, but at least ⅓, of such an academic year;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) in the case of a student at an eligible institution who has successfully completed such first and second year but has not successfully completed the remainder of a program of undergraduate study—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(I) $5,500, if such student is enrolled in a program whose length is at least one academic year in length (as determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1088"},"text":"section 1088 of this title","children":[],"tail":");"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(II) $3,675, if such student is enrolled in a program whose length is less than one academic year, but at least ⅔ of such an academic year; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(III) $1,825, if such student is enrolled in a program whose length is less than ⅔, but at least ⅓, of such an academic year; and”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/c/2/B"},"text":"Pub. L. 103–208, § 2(c)(2)(B)","children":[],"tail":", substituted a period for semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/c/3"},"text":"Pub. L. 103–208, § 2(c)(3)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s413/1"},"text":"Pub. L. 102–325, § 413(1)","children":[],"tail":", added cls. (i) to (iv) and struck out former cls. (i) to (iii) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) $2,625, in the case of a student who has not successfully completed the first and second year of a program of undergraduate education;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) $4,000, in the case of a student who has successfully completed such first and second year but who has not successfully completed the remainder of a program of undergraduate education; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) $7,500, in the case of a graduate or professional student (as defined in regulations of the Secretary).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s413/2"},"text":"Pub. L. 102–325, § 413(2)","children":[],"tail":", added cls. (i) and (ii) and concluding provision and struck out former cls. (i) and (ii) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) $17,250, in the case of any student who has not successfully completed a program of undergraduate education, excluding loans made under section 1078–1 or 1078–2 of this title; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) $54,750, in the case of any graduate or professional student (as defined by regulations of the Secretary and including any loans which are insured by the Secretary under this part, or by a guaranty agency, made to such person before he or she became a graduate or professional student), excluding loans made under section 1078–1 or 1078–2 of this title.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/50/s10/a/1"},"text":"Pub. L. 100–50, § 10(a)(1)","children":[],"tail":", inserted “, excluding loans made under section 1078–1 or 1078–2 of this title” after “undergraduate education”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/50/s10/a/2"},"text":"Pub. L. 100–50, § 10(a)(2)","children":[],"tail":", inserted “, excluding loans made under section 1078–1 or 1078–2 of this title” after “graduate or professional student)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cfa63c8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cfa63c9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/tVIII/s8005/e"},"text":"Pub. L. 109–171, title VIII, § 8005(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/159"},"text":"120 Stat.