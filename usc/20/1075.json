{"tag":"section","attrib":{"id":"id0cfa639d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075"},"text":null,"children":[{"tag":"num","attrib":{"value":"1075"},"text":"§ 1075.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on individual federally insured loans and on Federal loan insurance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cfa639e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual and aggregate limits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cfa639f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual limits","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cfa63a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The total of loans made to a student in any academic year or its equivalent (as determined by the Secretary) which may be covered by Federal loan insurance under this part may not exceed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cfa63a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a student at an eligible institution who has not successfully completed the first year of a program of undergraduate education—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0cfa63a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/a/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,500, if such student is enrolled in a program whose length is at least one academic year in length (as determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1088"},"text":"section 1088 of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0cfa63a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/a/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such student is enrolled in a program of undergraduate education which is less than one academic year, the maximum annual loan amount that such student may receive may not exceed the amount that bears the same ratio to the amount specified in subclause (I) as the length of such program measured in semester, trimester, quarter, or clock hours bears to one academic year;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cfa63a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a student at an eligible institution who has successfully completed such first year but has not successfully completed the remainder of a program of undergraduate education—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0cfa63a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/a/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,500; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0cfa63a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/a/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such student is enrolled in a program of undergraduate education, the remainder of which is less than one academic year, the maximum annual loan amount that such student may receive may not exceed the amount that bears the same ratio to the amount specified in subclause (I) as such remainder measured in semester, trimester, quarter, or clock hours bears to one academic year;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cfa63a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a student at an eligible institution who has successfully completed the first and second years of a program of undergraduate education but has not successfully completed the remainder of such program—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0cfa63a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/a/1/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,500; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0cfa63a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/a/1/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such student is enrolled in a program of undergraduate education, the remainder of which is less than one academic year, the maximum annual loan amount that such student may receive may not exceed the amount that bears the same ratio to the amount specified in subclause (I) as such remainder measured in semester, trimester, quarter, or clock hours bears to one academic year; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cfa63aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a graduate or professional student (as defined in regulations of the Secretary) at an eligible institution, $8,500.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cfa63ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The annual insurable limits contained in subparagraph (A) shall not apply in cases where the Secretary determines, pursuant to regulations, that a higher amount is warranted in order to carry out the purpose of this part with respect to students engaged in specialized training requiring exceptionally high costs of education. The annual insurable limit per student shall not be deemed to be exceeded by a line of credit under which actual payments by the lender to the borrower will not be made in any year in excess of the annual limit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cfa63ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of subparagraph (A), the number of years that a student has completed in a program of undergraduate education shall include any prior enrollment in an eligible program of undergraduate education for which the student was awarded an associate or baccalaureate degree, if such degree is required by the institution for admission to the program in which the student is enrolled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cfa63ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate limits","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cfa63ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The aggregate insured unpaid principal amount for all such insured loans made to any student shall not at any time exceed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cfa63af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $23,000, in the case of any student who has not successfully completed a program of undergraduate education, excluding loans made under section 1078–1 ","children":[{"tag":"ref","attrib":{"idref":"fn002053"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002053"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or 1078–2 of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cfa63b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $65,500, in the case of any graduate or professional student (as defined by regulations of the Secretary) and (I) including any loans which are insured by the Secretary under this section, or by a guaranty agency, made to such student before the student became a graduate or professional student),","children":[{"tag":"ref","attrib":{"idref":"fn002054"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002054"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. There is no opening parenthesis."}],"tail":" but (II) excluding loans made under section 1078–1 "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" or 1078–2 of this title,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that the Secretary may increase the limit applicable to students who are pursuing programs which the Secretary determines are exceptionally expensive.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cfa63b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may increase the aggregate insurable limit applicable to students who are pursuing programs which the Secretary determines are exceptionally expensive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cfa63b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Level of insurance coverage based on default rate","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cfa63b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction for defaults in excess of 5 or 9 percent","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cfa63b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subparagraph (B), the insurance liability on any loan insured by the Secretary under this part shall be 100 percent of the unpaid balance of the principal amount of the loan plus interest, except that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cfa63b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if, for any fiscal year, the total amount of payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1080"},"text":"section 1080 of this title","children":[],"tail":" by the Secretary to any eligible lender as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1085/d/1/D"},"text":"section 1085(d)(1)(D) of this title","children":[],"tail":" exceeds 5 percent of the sum of the loans made by such lender which are insured by the Secretary and which were in repayment at the end of the preceding fiscal year, the insurance liability under this subsection for that portion of such excess which represents loans insured after the applicable date with respect to such loans, as determined under subparagraph (C), shall be equal to 90 percent of the amount of such portion; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cfa63b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if, for any fiscal year, the total amount of such payments to such a lender exceeds 9 percent of such sum, the insurance liability under this subsection for that portion of such excess which represents loans insured after the applicable date with respect to such loans, as determined under subparagraph (C), shall be equal to 80 percent of the amount of such portion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cfa63b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subparagraph (A), the provisions of clauses (i) and (ii) of such subparagraph shall not apply to an eligible lender as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1085/d/1/D"},"text":"section 1085(d)(1)(D) of this title","children":[],"tail":" for the fiscal year in which such lender begins to carry on a loan program insured by the Secretary, or for any of the 4 succeeding fiscal years."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cfa63b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The applicable date with respect to a loan made by an eligible lender as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1085/d/1/D"},"text":"section 1085(d)(1)(D) of this title","children":[],"tail":" shall be—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0cfa63b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 90th day after the adjournment of the next regular session of the appropriate State legislature which convenes after ","children":[{"tag":"date","attrib":{"date":"1976-10-12"},"text":"October 12, 1976","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cfa63ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the primary source of lending capital for such lender is derived from the sale of bonds, and the constitution of the appropriate State prohibits a pledge of such State’s credit as security against such bonds, the day which is one year after such 90th day.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cfa63bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of amounts in repayment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subsection, the sum of the loans made by a lender which are insured by the Secretary and which are in repayment shall be the original principal amount of loans made by such lender which are insured by the Secretary reduced by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cfa63bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount the Secretary has been required to pay to discharge his or her insurance obligations under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cfa63bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the original principal amount of loans insured by the Secretary which have been fully repaid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cfa63be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the original principal amount insured on those loans for which payment of first installment of principal has not become due pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1077/a/2/B"},"text":"section 1077(a)(2)(B) of this title","children":[],"tail":" or such first installment need not be paid pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1077/a/2/C"},"text":"section 1077(a)(2)(C) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cfa63bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the original principal amount of loans repaid by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087"},"text":"section 1087 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cfa63c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to assignees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this subsection, payments by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1080"},"text":"section 1080 of this title","children":[],"tail":" to an assignee of the lender with respect to a loan shall be deemed payments made to such lender."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cfa63c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1075/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pledge of full faith and credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The full faith and credit of the United States is pledged to the payment of all amounts which may be required to be paid under the provisions of section 1080 or 1087 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cfa63c2-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s425"},"text":"Pub. L. 89–329, title IV, § 425","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s402/a"},"text":"Pub. L. 99–498, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1359"},"text":"100 Stat. 1359","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/50/s10/a"},"text":"Pub. L. 100–50, § 10(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-06-03"},"text":"June 3, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/341"},"text":"101 Stat. 341","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s413"},"text":"Pub. L. 102–325, title IV, § 413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/512"},"text":"106 Stat. 512","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/c/2"},"text":"Pub. L. 103–208, § 2(c)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2460"},"text":"107 Stat. 2460","children":[],"tail":", 2461; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s415"},"text":"Pub. L. 105–244, title IV, § 415","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1679"},"text":"112 Stat. 1679","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/tVIII/s8005/a"},"text":"Pub. L. 109–171, title VIII, § 8005(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/158"},"text":"120 Stat. 158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cfa63c3-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cfa63c4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0cfa63c5-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078–1"},"text":"Section 1078–1 of this title","children":[],"tail":", referred to in subsec. (a)(2)(A), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tIV/s4047/b"},"text":"Pub. L. 103–66, title IV, § 4047(b)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/364"},"text":"107 Stat. 364","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1994-07-01"},"text":"July 1, 1994","children":[],"