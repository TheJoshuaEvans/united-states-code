{"tag":"section","attrib":{"id":"id0e32bc67-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345"},"text":null,"children":[{"tag":"num","attrib":{"value":"7345"},"text":"§ 7345.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of applicable funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e32bc68-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative uses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e32bc69-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, an eligible local educational agency may use the applicable funding that the agency is eligible to receive from the State educational agency for a fiscal year to carry out local activities authorized under any of the following provisions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e32bc6a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part A of subchapter I.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e32bc6b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part A of subchapter II.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e32bc6c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subchapter III.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e32bc6d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part A or B of subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e32bc6e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible local educational agency shall notify the State educational agency of the local educational agency’s intention to use the applicable funding in accordance with paragraph (1), by a date that is established by the State educational agency for the notification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e32bc6f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e32bc70-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A local educational agency shall be eligible to use the applicable funding in accordance with subsection (a) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e32bc71-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e32bc72-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e32bc73-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345/b/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of students in average daily attendance at all of the schools served by the local educational agency is fewer than 600; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e32bc74-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345/b/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each county in which a school served by the local educational agency is located has a total population density of fewer than 10 persons per square mile; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e32bc75-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all of the schools served by the local educational agency are designated with a locale code of 41, 42, or 43, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e32bc76-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency meets the criteria established in subparagraph (A)(i) and the Secretary, in accordance with paragraph (2), grants the local educational agency’s request to waive the criteria described in subparagraph (A)(ii); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e32bc77-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the local educational agency is a member of an educational service agency that does not receive funds under this subpart and the local educational agency meets the requirements of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e32bc78-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine whether to waive the criteria described in paragraph (1)(A)(ii) based on a demonstration by the local educational agency, and concurrence by the State educational agency, that the local educational agency is located in an area defined as rural by a governmental agency of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e32bc79-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable funding defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “applicable funding” means funds provided under any of the following provisions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e32bc7a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part A of subchapter II.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e32bc7b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part A of subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e32bc7c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State educational agency that receives applicable funding for a fiscal year shall disburse the applicable funding to local educational agencies for alternative uses under this section for the fiscal year at the same time as the State educational agency disburses the applicable funding to local educational agencies that do not intend to use the applicable funding for such alternative uses for the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e32bc7d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Applicable funding under this section shall be available to carry out local activities authorized under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e32bc7e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5211"},"text":"Pub. L. 89–10, title V, § 5211","children":[],"tail":", formerly title VI, § 6211, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVI/s601"},"text":"Pub. L. 107–110, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1891"},"text":"115 Stat. 1891","children":[],"tail":"; renumbered title V, § 5211, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tV"},"text":"Pub. L. 114–95, title V","children":[],"tail":", §§ 5001(a)(3), 5003(1), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2039-2041"},"text":"129 Stat. 2039–2041","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e32bc7f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e32bc80-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e32bc81-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s5211"},"text":"section 5211 of Pub. L. 89–10","children":[],"tail":" was renumbered section 4311 and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7221j"},"text":"section 7221j of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e32bc82-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5003/1/A"},"text":"Pub. L. 114–95, § 5003(1)(A)","children":[],"tail":", added subpars. (A) to (D) and struck out former subpars. (A) to (E) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) Part A of subchapter I of this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) Part A or D of subchapter II of this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) Subchapter III of this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) Part A or B of subchapter IV of this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) Part A of subchapter V of this chapter.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5003/1/B/i"},"text":"Pub. L. 114–95, § 5003(1)(B)(i)","children":[],"tail":", struck out “school” before “locale code” and substituted “41, 42, or 43, as determined by the Secretary;” for “7 or 8, as determined by the Secretary; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5003/1/B/ii"},"text":"Pub. L. 114–95, § 5003(1)(B)(ii)","children":[],"tail":", (iii), added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5003/1/C"},"text":"Pub. L. 114–95, § 5003(1)(C)","children":[],"tail":", added pars. (1) and (2) and struck out former pars. (1) to (3) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Subpart 2 of this part and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6762/a/2/A"},"text":"section 6762(a)(2)(A) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7114"},"text":"Section 7114 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) Part A of subchapter V of this chapter.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e32bc83-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e32bc84-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
