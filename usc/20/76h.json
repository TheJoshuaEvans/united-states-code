{"tag":"section","attrib":{"id":"id0c7be3e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h"},"text":null,"children":[{"tag":"num","attrib":{"value":"76h"},"text":"§ 76h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Trustees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c7be3ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c7be3eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Smithsonian Institution a bureau, which shall be directed by a board to be known as the Trustees of the John F. Kennedy Center for the Performing Arts (hereafter in this subchapter referred to as the “Board”), whose duty it shall be to maintain and administer the John F. Kennedy Center for the Performing Arts and site thereof as the National Center for the Performing Arts, a living memorial to John Fitzgerald Kennedy, and to execute such other functions as are vested in the Board by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c7be3ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall be composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c7be3ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Health and Human Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c7be3ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Librarian of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c7be3ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c7be3f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the Commission of Fine Arts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c7be3f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Mayor of the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c7be3f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Superintendent of Schools of the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c7be3f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the National Park Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c7be3f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c7be3f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Smithsonian Institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c7be3f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/a/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0c7be3f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/a/2/J/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Speaker and the Minority Leader of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c7be3f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/a/2/J/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chairman and ranking minority member of the Committee on Transportation and Infrastructure of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c7be3f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/a/2/J/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three additional Members of the House of Representatives appointed by the Speaker of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c7be3fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/a/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0c7be3fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/a/2/K/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Majority Leader and the Minority Leader of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c7be3fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/a/2/K/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chairman and ranking minority member of the Committee on Environment and Public Works of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c7be3fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/a/2/K/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three additional Members of the Senate appointed by the President of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c7be3fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/a/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" thirty-six general trustees, who shall be citizens of the United States, to be appointed in accordance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c7be3ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General trustees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The general trustees shall be appointed by the President of the United States. Each trustee shall hold office as a member of the Board for a term of 6 years, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c7be400-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any member appointed to fill a vacancy occurring before the expiration of the term for which the predecessor of the member was appointed shall be appointed for the remainder of the term;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c7be401-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member shall continue to serve until the successor of the member has been appointed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c7be402-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term of office of a member appointed before ","children":[{"tag":"date","attrib":{"date":"1994-07-21"},"text":"July 21, 1994","children":[],"tail":", shall expire as designated at the time of appointment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c7be403-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee on the Arts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be an Advisory Committee on the Arts composed of such members as the President of the United States may designate, to serve at the pleasure of the President. Persons appointed to the Advisory Committee on the Arts, including officers or employees of the United States, shall be persons who are recognized for their knowledge of, or experience or interest in, one or more of the arts in the fields covered by the John F. Kennedy Center for the Performing Arts. The President shall designate the Chairman of the Advisory Committee on the Arts. In making such appointments the President shall give consideration to such recommendations as may from time to time be submitted to him by leading national organizations in the appropriate art fields. The Advisory Committee on the Arts shall advise and consult with the Board and make recommendations to the Board regarding existing and prospective cultural activities to be carried out by the John F. Kennedy Center for the Performing Arts. The Advisory Committee on the Arts shall assist the Board in carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s76k/a"},"text":"section 76k(a) of this title","children":[],"tail":". Members of the Advisory Committee on the Arts shall serve without compensation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c7be404-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/874/s2"},"text":"Pub. L. 85–874, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1698"},"text":"72 Stat. 1698","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/100"},"text":"Pub. L. 88–100","children":[],"tail":", §§ 1, 2, "},{"tag":"date","attrib":{"date":"1963-08-19"},"text":"Aug. 19, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/128"},"text":"77 Stat. 128","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/260/s1/2"},"text":"Pub. L. 88–260, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-01-23"},"text":"Jan. 23, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/4"},"text":"78 Stat. 4","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/279/s2/b/1"},"text":"Pub. L. 103–279, § 2(b)(1)","children":[],"tail":", (c), (d), "},{"tag":"date","attrib":{"date":"1994-07-21"},"text":"July 21, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1409"},"text":"108 Stat. 1409","children":[],"tail":", 1410; "},{"tag":"ref","attrib":{"href":"/us/pl/107/117/dD/tII/s201/a"},"text":"Pub. L. 107–117, div. D, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"Jan. 10, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2353"},"text":"115 Stat. 2353","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/338/s2"},"text":"Pub. L. 110–338, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3731"},"text":"122 Stat. 3731","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c7be405-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c7be406-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0c7be407-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(2)(J)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/338"},"text":"Pub. L. 110–338","children":[],"tail":" substituted “Transportation and Infrastructure” for “Public Works and Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/117"},"text":"Pub. L. 107–117","children":[],"tail":" designated existing provisions as par. (1), inserted par. heading, struck out “hereby” before “established”, struck out second sentence, and added par. (2). Prior to amendment, second sentence read as follows: “The Board shall be composed as follows: The Secretary of Health and Human Services, the Librarian of Congress, the Director of the United States Information Agency, the Chairman of the Commission of Fine Arts, the Mayor of the District of Columbia, the Superintendent of Schools of the District of Columbia, the Director of the National Park Service, the Secretary of Education, the Secretary of the Smithsonian Institution, the chairman and ranking minority member of the Committee on Public Works and Transportation of the House of Representatives and 3 additional Members of the House of Representatives appointed by the Speaker of the House of Representatives, and the chairman and ranking minority member of the Committee on Environment and Public Works of the Senate and 3 additional Members of the Senate appointed by the President of the Senate ex officio; and thirty general trustees who shall be citizens of the United States, to be chosen as hereinafter provided.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/279/s2/b/1/A"},"text":"Pub. L. 103–279, § 2(b)(1)(A)","children":[],"tail":", substituted section catchline for former section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/279/s2/b/1/A"},"text":"Pub. L. 103–279, § 2(b)(1)(A)","children":[],"tail":", inserted heading, in first sentence inserted “as the National Center for the Performing Arts, a living memorial to John Fitzgerald Kennedy,” after “and site thereof”, and in second sentence substituted “Superintendent of Schools of the District of Columbia” for “Chairman of the District of Columbia Recreation Board” and “the chairman and ranking minority member of the Committee on Public Works and Transportation of the House of Representatives and 3 additional Members of the House of Representatives appointed by the Speaker of the House of Representatives, and the chairman and ranking minority member of the Committee on Environment and Public Works of the Senate and 3 additional Members of the Senate appointed by the President of the Senate” for “three Members of the Senate appointed by the President of the Senate, and three Members of the House of Representatives appointed by the Speaker of the House of Representatives”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/279/s2/c"},"text":"Pub. L. 103–279, § 2(c)","children":[],"tail":", inserted heading and amended text generally. Prior to amendment, text read as follows: “The general trustees shall be appointed by the President of the United States and each such trustee shall hold office as a member of the Board for a term of ten years, except that (1) any member appointed to fill a vacancy occurring prior to the expiration of the term for which his predecessor was appointed shall be appointed for the remainder of such term, (2) the terms of any members appointed prior to "},{"tag":"date","attrib":{"date":"1963-08-19"},"text":"August 19, 1963","children":[],"tail":", shall expire as designated by the President at the time of appointment, and (3) the terms of the first fifteen members appointed to the Board pursuant to the amendments made by the National Cultural Center Amendments Act of 1963 shall expire, as designated by the President at the time of appointment, three on "},{"tag":"date","attrib":{"date":"1964-09-01"},"text":"September 1, 1964","children":[],"tail":", three on "},{"tag":"date","attrib":{"date":"1966-09-01"},"text":"September 1, 1966","children":[],"tail":", three on "},{"tag":"date","attrib":{"date":"1968-09-01"},"text":"September 1, 1968","children":[],"tail":", three on "},{"tag":"date","attrib":{"date":"1970-09-01"},"text":"September 1, 1970","children":[],"tail":", and three on "},{"tag":"date","attrib":{"date":"1972-09-01"},"text":"September 1, 1972","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/279/s2/d"},"text":"Pub. L. 103–279, § 2(d)","children":[],"tail":", inserted heading, inserted “of the United States” before “may designate” in first sentence, substituted “carried out by the John” for “carried on in the John” in fifth sentence, and struck out before period at end of last sentence “, but each member of such Committee shall be reimbursed for travel, subsistence, and other necessary expenses incurred by him in connection with the work of such Committee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsecs. (a), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/260"},"text":"Pub. L. 88–260","children":[],"tail":" substituted “John F. Kennedy Center for the Performing Arts” for “National Cultural Center” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/100/s1"},"text":"Pub. L. 88–100, § 1","children":[],"tail":", substituted “thirty” for “fifteen” after “ex officio; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/100/s2"},"text":"Pub. L. 88–100, § 2","children":[],"tail":", inserted provisions governing the terms of the additional fifteen general trustees added to the Board by "},{"tag":"ref","attrib":{"href":"/us/pl/88/100/s1"},"text":"section 1 of Pub. L. 88–100","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0c7be408-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0c7be409-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/279/s2/b/2"},"text":"Pub. L. 103–279, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-21"},"text":"July 21, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1410"},"text":"108 Stat. 1410","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/279/s2/b/2"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Superintendent of schools of the district of columbia","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by paragraph (1)(C)(i) [amending this section] shall take effect on the date of expiration of the term of the Chairman of the District of Columbia Recreation Board serving as a trustee of the John F. Kennedy Center for the Performing Arts on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1994-07-21"},"text":"July 21, 1994","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members of congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by paragraph (1)(C)(ii) [amending this section] shall take effect on the date of enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0c7be40a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tVI/s601"},"text":"Pub. L. 116–94, div. P, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3194"},"text":"133 Stat. 3194","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/94/dP/tVI/s601"},"text":"“This title [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s76r"},"text":"section 76r of this title","children":[],"tail":" and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s76j"},"text":"section 76j of this title","children":[],"tail":"] may be cited as the ‘John F. Kennedy Center Reauthorization Act of 2019’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0c7be40b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/131/s1"},"text":"Pub. L. 112–131, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-06-08"},"text":"June 8, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/377"},"text":"126 Stat. 377","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/131/s1"},"text":"“This Act [amending sections 76i and 76r of this title] may be cited as the ‘John F. Kennedy Center Reauthorization Act of 2012’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0c7be40c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/338/s1"},"text":"Pub. L. 110–338, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3731"},"text":"122 Stat. 3731","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/338/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s76m"},"text":"section 76m of this title","children":[],"tail":", amending this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s76r"},"text":"section 76r of this title","children":[],"tail":", and enacting provisions set out as a note under this section] may be cited as the ‘John F. Kennedy Center Reauthorization Act of 2008’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0c7be40d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/410/s1"},"text":"Pub. L. 108–410, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2303"},"text":"118 Stat. 2303","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/410/s1"},"text":"“This Act [amending sections 76q–1 and 76r of this title] may be cited as the ‘John F. Kennedy Center Reauthorization Act of 2004’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0c7be40e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/224/s1"},"text":"Pub. L. 107–224, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-18"},"text":"Sept. 18, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1340"},"text":"116 Stat. 1340","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/224/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s76q–1"},"text":"section 76q–1 of this title","children":[],"tail":" and amending sections 76j, 76r, and 76s of this title] may be cited as the ‘John F. Kennedy Center Plaza Authorization Act of 2002’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0c7be40f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/226/s1"},"text":"Pub. L. 105–226, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1513"},"text":"112 Stat. 1513","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/226/s1"},"text":"“This Act [amending sections 76j, 76","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":", and 76r of this title] may be cited as the ‘John F. Kennedy Center for the Performing Arts Authorization Act of 1998’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0c7be410-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/95/s1"},"text":"Pub. L. 105–95, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-19"},"text":"Nov. 19, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2148"},"text":"111 Stat. 2148","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/95/s1"},"text":"“This Act [amending sections 76i to 76k and 76s of this title and section 193v of former Title 40, Public Buildings, Property, and Works] may be cited as the ‘John F. Kennedy Center Parking Improvement Act of 1997’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0c7be411-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/279/s1"},"text":"Pub. L. 103–279, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-21"},"text":"July 21, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1409"},"text":"108 Stat. 1409","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/279/s1"},"text":"“This Act [enacting sections 76r and 76s of this title, amending this section, sections 76j, 76k, 76","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":", and 76p of this title, and sections 193r, 193u, and 193v of former Title 40, Public Buildings, Property, and Works, enacting provisions set out as notes under this section, and amending provisions set out as a note under this section] may be cited as the ‘John F. Kennedy Center Act Amendments of 1994’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0c7be412-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tI/s101/c"},"text":"Pub. L. 98–473, title I, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1837"},"text":"98 Stat. 1837","children":[],"tail":", 1876, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/473/tI/s101/c"},"text":"“The following [amending section 76","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title] may be cited as ‘The John F. Kennedy Center Act Amendments of 1984’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0c7be413-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1963 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/88/100/s5"},"text":"Pub. L. 88–100, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-08-19"},"text":"Aug. 19, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/128"},"text":"77 Stat. 128","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/88/100/s5"},"text":"“This Act [amending this section and sections 76","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" and 76m of this title] may be cited as the ‘National Cultural Center Amendments Act of 1963’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id0c7be414-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1(a), formerly § 1, of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/874"},"text":"Pub. L. 85–874","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/88/260/s1/1"},"text":"Pub. L. 88–260, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-01-23"},"text":"Jan. 23, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/4"},"text":"78 Stat. 4","children":[],"tail":"; redesignated § 1(a), "},{"tag":"ref","attrib":{"href":"/us/pl/103/279/s2/a/1"},"text":"Pub. L. 103–279, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-21"},"text":"July 21, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1409"},"text":"108 Stat. 1409","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/279/s2/a/1"},"text":"“This Act [enacting this subchapter] may be cited as the ‘John F. Kennedy Center Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0c7be415-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Existing Authorities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/338/s5"},"text":"Pub. L. 110–338, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3732"},"text":"122 Stat. 3732","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/338/s5"},"text":"“Nothing in this Act [see Short Title of 2008 Amendment note above] limits or otherwise affects the authority or responsibility of the National Capital Planning Commission or the Commission of Fine Arts.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0c7be416-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Terms of Office for New General Trustees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/117/dD/tII/s201/b"},"text":"Pub. L. 107–117, div. D, title II, § 201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"Jan. 10, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2354"},"text":"115 Stat. 2354","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/117/dD/tII/s201/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Section 2(b) of the John F. Kennedy Center Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s76h/b"},"text":"20 U.S.C. 76h(b)","children":[],"tail":") shall apply to each general trustee of the John F. Kennedy Center for the Performing Arts whose position is established by the amendment made by subsection (a)(2) [amending this section] (referred to in this subsection as a ‘new general trustee’), except that the initial term of office of each new general trustee shall—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commence on the date on which the new general trustee is appointed by the President; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminate on ","children":[{"tag":"date","attrib":{"date":"2007-09-01"},"text":"September 1, 2007","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0c7be417-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Cultural Center; Designation or References","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/88/260/s2"},"text":"Pub. L. 88–260, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-01-23"},"text":"Jan. 23, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/5"},"text":"78 Stat. 5","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/88/260/s2"},"text":"“In addition to the amendments made by the first section of this Act [enacting sections 76n to 76q, and amending sections 76h to 76q of this title], any designation or reference to the National Cultural Center in any other law, map, regulation, document, record, or other paper of the United States shall be held to designate or refer to such Center as the John F. Kennedy Center for the Performing Arts.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0c7be418-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/874/s1/b"},"text":"Section 1(b) of Pub. L. 85–874","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/103/279/s2/a/2"},"text":"Pub. L. 103–279, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-21"},"text":"July 21, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1409"},"text":"108 Stat. 1409","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/279/s2/a/2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the late John Fitzgerald Kennedy served with distinction as President of the United States and as a Member of the Senate and the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the untimely death of John Fitzgerald Kennedy the United States and the world have suffered a great loss;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the late John Fitzgerald Kennedy was particularly devoted to education and cultural understanding and the advancement of the performing arts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is fitting and proper that a living institution of the performing arts, designated as the National Center for the Performing Arts, named in the memory and honor of this great leader, shall serve as the sole national monument to his memory within the District of Columbia and its environs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such a living memorial serves all of the people of the United States by preserving, fostering, and transmitting the performing arts traditions of the people of the United States and other countries by producing and presenting music, opera, theater, dance, and other performing arts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such a living memorial should be housed in the John F. Kennedy Center for the Performing Arts, located in the District of Columbia.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
