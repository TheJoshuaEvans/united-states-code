{"tag":"section","attrib":{"id":"id0c8cadca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s81"},"text":null,"children":[{"tag":"num","attrib":{"value":"81"},"text":"§ 81.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration by Regents of Smithsonian Institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The National Zoological Park is placed under the direction of the Regents of the Smithsonian Institution, who are authorized to transfer to it any living specimens, whether of animals or plants, in their charge, to accept gifts for the park at their discretion, in the name of the United States, to make exchanges of specimens, and to administer and improve the said Zoological Park for the advancement of science and the instruction and recreation of the people.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c8cadcb-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1890-04-30/ch173/s2"},"text":"Apr. 30, 1890, ch. 173, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/78"},"text":"26 Stat. 78","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/360"},"text":"Pub. L. 87–360","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-10-04"},"text":"Oct. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/779"},"text":"75 Stat. 779","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c8cadcc-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c8cadcd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0c8cadce-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1961—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/360"},"text":"Pub. L. 87–360","children":[],"tail":" inserted “and improve” after “administer”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0c8cadcf-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0c8cadd0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Central Parking Facility","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/178"},"text":"Pub. L. 115–178","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-01"},"text":"June 1, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1379"},"text":"132 Stat. 1379","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/178"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This Act may be cited as the ‘Smithsonian National Zoological Park Central Parking Facility Authorization Act’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FACILITY FOR IMPROVED VISITOR EXPERIENCE AND ACCESS AT THE NATIONAL ZOOLOGICAL PARK.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In order to improve visitor experience and multi-modal access to the Smithsonian National Zoological Park, the Board of Regents of the Smithsonian Institution is authorized to plan, design, and construct a central parking facility on National Zoological Park property in the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Central Parking Facility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The facility authorized under this section may include parking, transportation improvements, visitor amenities including restrooms, a pedestrian bridge to a midpoint entry of the National Zoological Park, and ancillary works to accommodate alternative uses of the facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Construction of the facility described in this section shall be conducted with funds from nonappropriated sources.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0c8cadd1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Establishment of Parks","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Zoological Park was established under provisions of the District of Columbia Appropriation Act for the Fiscal Year 1890, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1889-03-02/ch370/s4"},"text":"act Mar. 2, 1889, ch. 370, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/25/808"},"text":"25 Stat. 808","children":[],"tail":", which constituted a commission to select from a certain district along Rock Creek a tract of land, including a section of the creek, suitable for a zoological park, and to purchase the land so selected, or take proceedings for the condemnation thereof, the United States to have title to the land on payment therefor to the owners."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Rock Creek Park was established by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1890-09-27/ch1001"},"text":"act Sept. 27, 1890, ch. 1001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/492"},"text":"26 Stat. 492","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Potomac Park was established by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1897-03-03/ch375"},"text":"act Mar. 3, 1897, ch. 375","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/29/624"},"text":"29 Stat. 624","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0c8cadd2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Addition of Lands","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Certain parcels of land were added to the National Zoological Park by acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-05/ch235/s1"},"text":"June 5, 1920, ch. 235, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/892"},"text":"41 Stat. 892","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1921-03-04/ch161/s1"},"text":"Mar. 4, 1921, ch. 161, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/1384"},"text":"41 Stat. 1384","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0c8cadd3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Connecting Parkway","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions for a parkway connecting Potomac Park with Zoological Park and Rock Creek Park were made by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch147/s27"},"text":"act Mar. 4, 1913, ch. 147, § 27","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/885"},"text":"37 Stat. 885","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
