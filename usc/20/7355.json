{"tag":"section","attrib":{"id":"id0e3505ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7355"},"text":null,"children":[{"tag":"num","attrib":{"value":"7355"},"text":"§ 7355.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual average daily attendance determination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e3505eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7355/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Census determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each local educational agency desiring a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7345a"},"text":"section 7345a of this title","children":[],"tail":" and each local educational agency or specially qualified agency desiring a grant under subpart 2 of this part shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e3505ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7355/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than December 1 of each year, conduct a census to determine the number of students in average daily attendance in kindergarten through grade 12 at the schools served by the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3505ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7355/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than March 1 of each year, submit the number described in paragraph (1) to the Secretary (and to the State educational agency, in the case of a local educational agency seeking a grant under subpart (2)).","children":[{"tag":"ref","attrib":{"idref":"fn002222"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002222"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subpart 2).”"}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e3505ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7355/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that a local educational agency or specially qualified agency has knowingly submitted false information under subsection (a) for the purpose of gaining additional funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7345a"},"text":"section 7345a of this title","children":[],"tail":" or subpart 2 of this part, then the agency shall be fined an amount equal to twice the difference between the amount the agency received under this section and the correct amount the agency would have received under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7345a"},"text":"section 7345a of this title","children":[],"tail":" or subpart 2 of this part if the agency had submitted accurate information under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e3505ef-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5231"},"text":"Pub. L. 89–10, title V, § 5231","children":[],"tail":", formerly title VI, § 6231, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVI/s601"},"text":"Pub. L. 107–110, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1897"},"text":"115 Stat. 1897","children":[],"tail":"; renumbered title V, § 5231, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tV/s5001/a/5"},"text":"Pub. L. 114–95, title V, § 5001(a)(5)","children":[],"tail":", (b)(2), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2039"},"text":"129 Stat. 2039","children":[],"tail":", 2040.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e3505f0-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e3505f1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e3505f2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s5231"},"text":"section 5231 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7223j"},"text":"section 7223j of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e3505f3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5001/b/2"},"text":"Pub. L. 114–95, § 5001(b)(2)","children":[],"tail":", made technical amendment to references in original act which appear in text as references to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7345a"},"text"