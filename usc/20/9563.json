{"tag":"section","attrib":{"id":"id0e64c830-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9563"},"text":null,"children":[{"tag":"num","attrib":{"value":"9563"},"text":"§ 9563.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e64c831-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9563/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e64c832-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9563/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out its missions, the National Center for Education Evaluation and Regional Assistance may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e64c833-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9563/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct or support evaluations consistent with the Center’s mission as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9561/b"},"text":"section 9561(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e64c834-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9563/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate programs under title I of the Elementary and Secondary Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"20 U.S.C. 6301","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e64c835-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9563/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, examine evaluations conducted or supported by others in order to determine the quality and relevance of the evidence of effectiveness generated by those evaluations, with the approval of the Director;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e64c836-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9563/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the activities of the National Center for Education Evaluation and Regional Assistance with other evaluation activities in the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e64c837-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9563/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and, where feasible, supplement Federal education program evaluations, particularly those by the Department, to determine or enhance the quality and relevance of the evidence generated by those evaluations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e64c838-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9563/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish evaluation methodology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e64c839-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9563/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Director in the preparation of the biennial report, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9519"},"text":"section 9519 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c83a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9563/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each evaluation conducted by the National Center for Education Evaluation and Regional Assistance pursuant to paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e64c83b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9563/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adhere to the highest possible standards of quality for conducting scientifically valid education evaluation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e64c83c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9563/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be subject to rigorous peer-review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e64c83d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9563/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of evaluations under the Elementary and Secondary Education Act of 1965","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Evaluation and Regional Assistance Commissioner, consistent with the mission of the National Center for Education Evaluation and Regional Assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9561/b"},"text":"section 9561(b) of this title","children":[],"tail":", shall administer all operations and contracts associated with evaluations authorized by section 8601 of the Elementary and Secondary Education Act of 1965 ["},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7981"},"text":"20 U.S.C. 7981","children":[],"tail":"] and administered by the Department as of "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"November 5, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e64c83e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s173"},"text":"Pub. L. 107–279, title I, § 173","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1964"},"text":"116 Stat. 1964","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/ff/2"},"text":"Pub. L. 114–95, title IX, § 9215(ff)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2174"},"text":"129 Stat. 2174","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e64c83f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e64c840-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e64c841-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Elementary and Secondary Education Act of 1965, referred to in subsec. (a)(1)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-04-11"},"text":"Apr. 11, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/27"},"text":"79 Stat. 27","children":[],"tail":". Title I of the Act is classified generally to subchapter I (§ 6301 et seq.) of chapter 70 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e64c842-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" substituted “section 8601 of the Elementary and Secondary Education Act of 1965” for “part E of title I of the Elementary and Secondary Education Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6491"},"text":"20 U.S.C. 6491","children":[],"tail":" et seq.)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e64c843-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment"