{"tag":"section","attrib":{"id":"id0d6f1e70-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1128a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1128a"},"text":"§ 1128a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" American overseas research centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d6f1e71-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1128a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Centers authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make grants to and enter into contracts with any American overseas research center that is a consortium of institutions of higher education (hereafter in this section referred to as a “center”) to enable such center to promote postgraduate research, exchanges and area studies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6f1e72-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1128a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants made and contracts entered into pursuant to this section may be used to pay all or a portion of the cost of establishing or operating a center or program, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6f1e73-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1128a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of faculty and staff stipends and salaries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e74-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1128a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of faculty, staff, and student travel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e75-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1128a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of the operation and maintenance of overseas facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e76-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1128a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of teaching and research materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e77-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1128a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of acquisition, maintenance, and preservation of library collections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e78-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1128a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of bringing visiting scholars and faculty to a center to teach or to conduct research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e79-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1128a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of organizing and managing conferences; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e7a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1128a/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of publication and dissemination of material for the scholarly and general public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6f1e7b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1128a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall only award grants to and enter into contracts with centers under this section that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6f1e7c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1128a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive more than 50 percent of their funding from public or private United States sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e7d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1128a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a permanent presence in the country in which the center is located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e7e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1128a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are organizations described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":" which are exempt from taxation under section 501(a) of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6f1e7f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1128a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make grants for the establishment of new centers. The grants may be used to fund activities that, within 1 year, will result in the creation of a center described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6f1e80-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1128a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each center desiring to receive a grant or contract under this section shall submit an application to the Secretary at such time, in such manner, and accompanied by such information and assurances as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6f1e81-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s609"},"text":"Pub. L. 89–329, title VI, § 609","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVI/s601"},"text":"Pub. L. 105–244, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1782"},"text":"112 Stat. 1782","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVI/s608"},"text":"Pub. L. 110–315, title VI, § 608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3338"},"text":"122 Stat. 3338","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d6f1e82-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d6f1e83-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d6f1e84-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s609"},"text":"section 609 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1126"},"text":"section 1126 of this title","children":[],"tail":", prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s609"},"text":"section 609 of Pub. L. 89–329","children":[],"tail":", title VI, "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1266"},"text":"79 Stat. 1266","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/318/tI/s131/d/2/D"},"text":"Pub. L. 92–318, title I, § 131(d)(2)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/260"},"text":"86 Stat. 260","children":[],"tail":", prohibited equipment grants for sectarian instruction or religious worship and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1129"},"text":"section 1129 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/96/374"},"text":"Pub. L. 96–374","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d6f1e85-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
