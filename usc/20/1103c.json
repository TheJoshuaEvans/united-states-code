{"tag":"section","attrib":{"id":"id0d6a6365-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1103c"},"text":"§ 1103c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative arrangements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d6a6366-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants to encourage cooperative arrangements with funds available to carry out this subchapter, between Hispanic-serving institutions eligible for assistance under this subchapter, and between such institutions and institutions not receiving assistance under this subchapter, for the activities described in sections 1101b and 1102b of this title so that the resources of the cooperating institutions might be combined and shared in order to achieve the purposes of this subchapter, to avoid costly duplicative efforts, and to enhance the development of Hispanic-serving institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6a6367-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall give priority to grants for the purposes described under subsection (a) whenever the Secretary determines that the cooperative arrangement is geographically and economically sound or will benefit the applicant Hispanic-serving institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6a6368-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants to Hispanic-serving institutions having a cooperative arrangement may be made under this section for a period determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1101d"},"text":"section 1101d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6a6369-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tV/s524"},"text":"Pub. L. 89–329, title V, § 524","children":[],"tail":", formerly § 514, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tV/s501"},"text":"Pub. L. 105–244, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1773"},"text":"112 Stat. 1773","children":[],"tail":"; renumbered § 524 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tV"},"text":"Pub. L. 110–315, title V","children":[],"tail":", §§ 502(a)(2), 504, "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3331"},"text":"122 Stat. 3331","children":[],"tail":", 3333.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d6a636a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d6a636b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text