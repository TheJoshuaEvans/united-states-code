{"tag":"section","attrib":{"id":"id0e3505d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7351c"},"text":null,"children":[{"tag":"num","attrib":{"value":"7351c"},"text":"§ 7351c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each State educational agency or specially qualified agency that receives a grant under this subpart shall prepare and submit an annual report to the Secretary. The report shall describe—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e3505d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7351c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the report is submitted by a State educational agency, the method the State educational agency used to award grants to eligible local educational agencies, and to provide assistance to schools, under this subpart;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3505d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7351c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how local educational agencies and schools used funds provided under this subpart; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3505d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7351c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree to which progress has been made toward meeting the objectives and outcomes described in the application submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7351b"},"text":"section 7351b of this title","children":[],"tail":", including having all students in the State or the area served by the specially qualified agency, as applicable, meet the challenging State academic standards."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e3505d9-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5224"},"text":"Pub. L. 89–10, title V, § 5224","children":[],"tail":", formerly title VI, § 6224, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVI/s601"},"text":"Pub. L. 107–110, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1896"},"text":"115 Stat. 1896","children":[],"tail":"; renumbered title V, § 5224, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tV"},"text":"Pub. L. 114–95, title V","children":[],"tail":", §§ 5001(a)(4), 5003(7), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2039"},"text":"129 Stat. 2039","children":[],"tail":", 2040, 2044.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e3505da-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e3505db-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e3505dc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s5224"},"text":"section 5224 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7223c"},"text":"section 7223c of this title","c