{"tag":"section","attrib":{"id":"id0d78bb24-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1135b"},"text":"§ 1135b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d78bb25-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make grants to academic departments, programs and units of institutions of higher education on the basis of applications submitted in accordance with subsection (b). Applications shall be ranked on program quality by review panels of nationally recognized scholars and evaluated on the quality and effectiveness of the academic program and the achievement and promise of the students to be served. To the extent possible (consistent with other provisions of this section), the Secretary shall make awards that are consistent with recommendations of the review panels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d78bb26-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An academic department, program or unit of an institution of higher education, in the department, program or unit’s application for a grant, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d78bb27-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the current academic program of the applicant for which the grant is sought;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb28-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assurances that the applicant will provide, from other non-Federal sources, for the purposes of the fellowship program under this subpart an amount equal to at least 25 percent of the amount of the grant received under this subpart, which contribution may be in cash or in kind, fairly valued;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb29-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth policies and procedures to assure that, in making fellowship awards under this subpart, the institution will seek talented students from traditionally underrepresented backgrounds, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb2a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the number, types, and amounts of the fellowships that the applicant intends to offer with grant funds provided under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb2b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" set forth policies and procedures to assure that, in making fellowship awards under this subpart, the institution will make awards to individuals who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d78bb2c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135b/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have financial need, as determined under part F of subchapter IV;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb2d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135b/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have excellent academic records in their previous programs of study; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb2e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135b/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plan to pursue the highest possible degree available in their course of study at the institution;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb2f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135b/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth policies and procedures to ensure that Federal funds made available under this subpart for any fiscal year will be used to supplement and, to the extent practical, increase the funds that would otherwise be made available for the purpose of this subpart and in no case to supplant those funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb30-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135b/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assurances that, in the event that funds made available to the academic department, program or unit under this subpart are insufficient to provide the assistance due a student under the commitment entered into between the academic department, program or unit and the student, the academic department, program or unit will, from any funds available to the department, program or unit, fulfill the commitment to the student;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb31-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135b/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that the applicant will comply with the limitations set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1135d"},"text":"section 1135d of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb32-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135b/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assurances that the academic department will provide at least 1 year of supervised training in instruction for students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb33-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135b/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include such other information as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d78bb34-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s713"},"text":"Pub. L. 89–329, title VII, § 713","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVII/s701"},"text":"Pub. L. 105–244, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1791"},"text":"112 Stat. 1791","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVII/s703/e/3"},"text":"Pub. L. 110–315, title VII, § 703(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3347"},"text":"122 Stat. 3347","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d78bb35-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d78bb36-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d78bb37-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in section 1134","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 1135b, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tX/s1021"},"text":"Pub. L. 89–329, title X, § 1021","children":[],"ta