{"tag":"section","attrib":{"id":"id0e51b5e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7906"},"text":null,"children":[{"tag":"num","attrib":{"value":"7906"},"text":"§ 7906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited uses of funds","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No funds under this chapter may be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e51b5ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7906/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for construction, renovation, or repair of any school facility, except as authorized under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e51b5eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7906/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for transportation unless otherwise authorized under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e51b5ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7906/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop or distribute materials, or operate programs or courses of instruction directed at youth, that are designed to promote or encourage sexual activity, whether homosexual or heterosexual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e51b5ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7906/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to distribute or to aid in the distribution by any organization of legally obscene materials to minors on school grounds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e51b5ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7906/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide sex education or HIV-prevention education in schools unless that instruction is age appropriate and includes the health benefits of abstinence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e51b5ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7906/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to operate a program of contraceptive distribution in schools; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e51b5f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7906/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the provision to any person of a dangerous weapon, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s930/g/2"},"text":"section 930(g)(2) of title 18","children":[],"tail":", or training in the use of a dangerous weapon, except that this paragraph shall not apply to the use of funds under this chapter for activities carried out under programs authorized by this chapter that are otherwise permissible under such programs and that provide students with educational instruction or educational enrichment activities, such as archery, hunting, other shooting sports, or culinary arts."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e51b5f1-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8526"},"text":"Pub. L. 89–10, title VIII, § 8526","children":[],"tail":", formerly title IX, § 9526, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIX/s901"},"text":"Pub. L. 107–110, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1982"},"text":"115 Stat. 1982","children":[],"tail":"; renumbered title VIII, § 8526, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII"},"text":"Pub. L. 114–95, title VIII","children":[],"tail":", §§ 8001(a)(6), 8022, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2088"},"text":"129 Stat. 2088","children":[],"tail":", 2089, 2112; "},{"tag":"ref","attrib":{"href":"/us/pl/117/159/dA/tIII/s13401"},"text":"Pub. L. 117–159, div. A, title III, § 13401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-06-25"},"text":"June 25, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1338"},"text":"136 Stat. 1338","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/17/s2"},"text":"Pub. L. 118–17, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-10-06"},"text":"Oct. 6, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/102"},"text":"137 Stat. 102","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e51b5f2-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e51b5f3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e51b5f4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7906, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIX/s9206"},"text":"Pub. L. 89–10, title IX, § 9206","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3800"},"text":"108 Stat. 3800","children":[],"tail":", authorized grants for a Native Hawaiian higher education program, prior to the general amendment of former subchapter IX of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e51b5f5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/17"},"text":"Pub. L. 118–17","children":[],"tail":" inserted before period at end “, except that this paragraph shall not apply to the use of funds under this chapter for activities carried out under programs authorized by this chapter that are otherwise permissible under such programs and that provide students with educational instruction or educational enrichment activities, such as archery, hunting, other shooting sports, or culinary arts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/159"},"text":"Pub. L. 117–159","children":[],"tail":" added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8022"},"text":"Pub. L. 114–95, § 8022","children":[],"tail":", substituted “Prohibited uses of funds” for “General prohibitions” in section catchline, in subsec. (a), struck out “(a) Prohibition” before introductory provisions, substituted “No funds under this chapter may be used” for “None of the funds authorized under this chapter shall be used” in introductory provisions, added pars. (1) and (2) and redesignated former pars. (1) to (4) as (3) to (6), respectively, and struck out subsec. (b). Prior to amendment, text of subsec. (b) read as follows: “Nothing in this section shall be construed to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) authorize an officer or employee of the Federal Government to mandate, direct, review, or control a State, local educational agency, or school’s instructional content, curriculum, and related activities;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) limit the application of the General Education Provisions Act;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) require the distribution of scientifically or medically false or inaccurate materials or to prohibit the distribution of scientifically or medically true or accurate materials; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) create any legally enforceable right.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e51b5f6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e51b5f7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
