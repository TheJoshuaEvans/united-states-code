{"tag":"section","attrib":{"id":"id0ce99b1d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070a–24"},"text":"§ 1070a–24.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ce99b1e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each eligible entity receiving a grant under this division shall provide comprehensive mentoring, outreach, and supportive services to students participating in the programs under this division. Such activities shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cec0b1f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing information regarding financial aid for postsecondary education to participating students in the cohort described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–22/d/1/A"},"text":"section 1070a–22(d)(1)(A) of this title","children":[],"tail":" or to priority students described in subsection (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b20-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Encouraging student enrollment in rigorous and challenging curricula and coursework, in order to reduce the need for remedial coursework at the postsecondary level.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b21-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Improving the number of participating students who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cec0b22-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain a secondary school diploma; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0b23-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete applications for and enroll in a program of postsecondary education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b24-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an eligible entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–21/c/1"},"text":"section 1070a–21(c)(1) of this title","children":[],"tail":", providing for the scholarships described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–25"},"text":"section 1070a–25 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cec0b25-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible activities for States and partnerships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under this division may use grant funds to carry out one or more of the following activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cec0b26-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing tutors and mentors, who may include adults or former participants of a program under this division, for eligible students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b27-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conducting outreach activities to recruit priority students described in subsection (d) to participate in program activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b28-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing supportive services to eligible students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b29-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supporting the development or implementation of rigorous academic curricula, which may include college preparatory, Advanced Placement, or International Baccalaureate programs, and providing participating students access to rigorous core academic courses that reflect challenging State academic standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b2a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Supporting dual or concurrent enrollment programs between the secondary school and institution of higher education partners of an eligible entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–21/c/2"},"text":"section 1070a–21(c)(2) of this title","children":[],"tail":", and other activities that support participating students in—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cec0b2b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meeting challenging State academic standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0b2c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" successfully applying for postsecondary education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0b2d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" successfully applying for student financial aid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0b2e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing graduation and career plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b2f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing special programs or tutoring in science, technology, engineering, or mathematics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b30-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an eligible entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–21/c/2"},"text":"section 1070a–21(c)(2) of this title","children":[],"tail":", providing support for scholarships described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–25"},"text":"section 1070a–25 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b31-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Introducing eligible students to institutions of higher education, through trips and school-based sessions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b32-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Providing an intensive extended school day, school year, or summer program that offers—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cec0b33-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional academic classes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0b34-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance with college admission applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b35-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Providing other activities designed to ensure secondary school completion and postsecondary education enrollment of at-risk children, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cec0b36-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of at-risk children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0b37-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after-school and summer tutoring;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0b38-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance to at-risk children in obtaining summer jobs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0b39-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0b3a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/10/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial literacy and economic literacy education or counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0b3b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/10/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" volunteer and parent involvement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0b3c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/10/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging former or current participants of a program under this division to serve as peer counselors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0b3d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/10/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" skills assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0b3e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/10/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal and family counseling, and home visits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0b3f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/10/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" staff development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0b40-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/10/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs and activities described in this subsection that are specially designed for students who are limited English proficient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b41-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enabling eligible students to enroll in Advanced Placement or International Baccalaureate courses, or college entrance examination preparation courses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b42-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing services to eligible students in the participating cohort described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–22/d/1/A"},"text":"section 1070a–22(d)(1)(A) of this title","children":[],"tail":", through the first year of attendance at an institution of higher education."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b43-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fostering and improving parent and family involvement in elementary and secondary education by promoting the advantages of a college education, and emphasizing academic admission requirements and the need to take college preparation courses, through parent engagement and leadership activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b44-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Disseminating information that promotes the importance of higher education, explains college preparation and admission requirements, and raises awareness of the resources and services provided by the eligible entities to eligible students, their families, and communities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b45-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/b/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event that matching funds described in the application are no longer available, engaging entities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–21/c/2"},"text":"section 1070a–21(c)(2) of this title","children":[],"tail":" in a collaborative manner to provide matching resources and participate in other activities authorized under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cec0b46-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional permissible activities for States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the required activities described in subsection (a) and the permissible activities described in subsection (b), an eligible entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–21/c/1"},"text":"section 1070a–21(c)(1) of this title","children":[],"tail":" receiving funds under this division may use grant funds to carry out one or more of the following activities:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cec0b47-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Providing technical assistance to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cec0b48-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secondary schools that are located within the State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0b49-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partnerships described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–21/c/2"},"text":"section 1070a–21(c)(2) of this title","children":[],"tail":" that are located within the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b4a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing professional development opportunities to individuals working with eligible cohorts of students described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–22/d/1/A"},"text":"section 1070a–22(d)(1)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b4b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing administrative support to help build the capacity of eligible entities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–21/c/2"},"text":"section 1070a–21(c)(2) of this title","children":[],"tail":" to compete for and manage grants awarded under this division."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b4c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing strategies and activities that align efforts in the State to prepare eligible students to attend and succeed in postsecondary education, which may include the development of graduation and career plans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b4d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Disseminating information on the use of scientifically valid research and best practices to improve services for eligible students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b4e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cec0b4f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Disseminating information on effective coursework and support services that assist students in obtaining the goals described in subparagraph (B)(ii).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0b50-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Identifying and disseminating information on best practices with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cec0b51-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/c/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing parental involvement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cec0b52-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/c/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparing students, including students with disabilities and students who are limited English proficient, to succeed academically in, and prepare financially for, postsecondary education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b53-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Working to align State academic standards and curricula with the expectations of postsecondary institutions and employers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b54-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing alternatives to traditional secondary school that give students a head start on attaining a recognized postsecondary credential (including an industry-recognized certificate, an apprenticeship, or an associate’s or a bachelor’s degree), including school designs that give students early exposure to college-level courses and experiences and allow students to earn transferable college credits or an associate’s degree at the same time as a secondary school diploma.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b55-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Creating community college programs for drop-outs that are personalized drop-out recovery programs that allow drop-outs to complete a regular secondary school diploma and begin college-level work.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cec0b56-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority students","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For eligible entities not using a cohort approach, the eligible entity shall treat as a priority student any student in secondary school who is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cec0b57-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible to be counted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333/c"},"text":"section 6333(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b58-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible for assistance under a State program funded under part A or E of title IV of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s601"},"text":"42 U.S.C. 601","children":[],"tail":" et seq., 670 et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b59-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible for assistance under subtitle B of title VII of the McKinney-Vento Homeless Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11431"},"text":"42 U.S.C. 11431","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b5a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise considered by the eligible entity to be a disconnected student.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cec0b5b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–24/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowable providers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of eligible entities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–21/c/1"},"text":"section 1070a–21(c)(1) of this title","children":[],"tail":", the activities required by this section may be provided by service providers such as community-based organizations, schools, institutions of higher education, public and private agencies, nonprofit and philanthropic organizations, businesses, institutions and agencies sponsoring programs authorized under subpart 4, and other organizations the State determines appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cec0b5c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s404D"},"text":"Pub. L. 89–329, title IV, § 404D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s403"},"text":"Pub. L. 105–244, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1659"},"text":"112 Stat. 1659","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tVII/s752/b/8"},"text":"Pub. L. 106–78, title VII, § 752(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1169"},"text":"113 Stat. 1169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s404/d"},"text":"Pub. L. 110–315, title IV, § 404(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"r