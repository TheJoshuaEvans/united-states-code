{"tag":"section","attrib":{"id":"id0c77292e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s57"},"text":null,"children":[{"tag":"num","attrib":{"value":"57"},"text":"§ 57.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disbursements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever money is required for the payment of the debts or performance of the contracts of the institution, incurred or entered into in conformity with the provisions of sections 41 to 46, 48, 50, 51 to 53, 54 to 57, and 67 of this title, or for making the purchases and executing the objects authorized by said sections, the Board of Regents, or the executive committee thereof, may certify to the chancellor and secretary of the board that such sum of money is required, whereupon they shall examine the same, and, if they shall approve thereof, shall certify the same to the proper officer of the Treasury for payment. The board shall submit to Congress, at each session thereof, a report of the operations, expenditures, and condition of the institution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c77292f-3a70-11f1-a648-bee82ed8a795"},"text":"(R.S. § 5593.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c772930-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c772931-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0c772932-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5593 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1846-08-10/ch178/s3"},"text":"act Aug. 10, 1846, ch. 178, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/9/103"},"text":"9 Stat. 103","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0c772933-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0c772934-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in this section relating to submitting a report to Congress at each session of Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and page 192 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
