{"tag":"section","attrib":{"id":"id0dad38c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451"},"text":null,"children":[{"tag":"num","attrib":{"value":"1451"},"text":"§ 1451.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose; definition of personnel; program authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dad38c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this part is to assist State educational agencies in reforming and improving their systems for personnel preparation and professional development in early intervention, educational, and transition services in order to improve results for children with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dad38c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this part the term “personnel” means special education teachers, regular education teachers, principals, administrators, related services personnel, paraprofessionals, and early intervention personnel serving infants, toddlers, preschoolers, or children with disabilities, except where a particular category of personnel, such as related services personnel, is identified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dad38c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dad38c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (d), for any fiscal year for which the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1455"},"text":"section 1455 of this title","children":[],"tail":", that remains after the Secretary reserves funds under subsection (e) for the fiscal year, is less than $100,000,000, the Secretary shall award grants, on a competitive basis, to State educational agencies to carry out the activities described in the State plan submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1453"},"text":"section 1453 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad38c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under paragraph (1), the Secretary may give priority to State educational agencies that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dad38c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are in States with the greatest personnel shortages; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate the greatest difficulty meeting the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1412/a/14"},"text":"section 1412(a)(14) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad38cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make a grant to each State educational agency selected under paragraph (1) in an amount for each fiscal year that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dad38cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $500,000, nor more than $4,000,000, in the case of the 50 States, the District of Columbia, and the Commonwealth of Puerto Rico; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $80,000 in the case of an outlying area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad38ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase in amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may increase the amounts of grants under paragraph (4) to account for inflation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad38cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall determine the amount of a grant under paragraph (1) after considering—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dad38d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funds available for making the grants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relative population of the State or outlying area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of activities proposed by the State or outlying area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/c/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alignment of proposed activities with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1412/a/14"},"text":"section 1412(a)(14) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/c/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alignment of proposed activities with the State plans and applications submitted under sections 6311 and 6611(d) ","children":[{"tag":"ref","attrib":{"idref":"fn002128"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002128"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" respectively, of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/c/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use, as appropriate, of scientifically based research activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dad38d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formula grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dad38d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraphs (2) and (3), for the first fiscal year for which the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1455"},"text":"section 1455 of this title","children":[],"tail":", that remains after the Secretary reserves funds under subsection (e) for the fiscal year, is equal to or greater than $100,000,000, and for each fiscal year thereafter, the Secretary shall allot to each State educational agency, whose application meets the requirements of this part, an amount that bears the same relation to the amount remaining as the amount the State received under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1411/d"},"text":"section 1411(d) of this title","children":[],"tail":" for that fiscal year bears to the amount of funds received by all States (whose applications meet the requirements of this part) under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1411/d"},"text":"section 1411(d) of this title","children":[],"tail":" for that fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad38d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allotments for States that received competitive grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dad38d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount allotted under this subsection to any State educational agency that received a competitive multi-year grant under subsection (c) for which the grant period has not expired shall be not less than the amount specified for that fiscal year in the State educational agency’s grant award document under that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each such State educational agency shall use the minimum amount described in subparagraph (A) for the activities described in the State educational agency’s competitive grant award document for that year, unless the Secretary approves a request from the State educational agency to spend the funds on other activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad38db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allotment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of any State educational agency’s allotment under this subsection for any fiscal year shall not be less than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dad38dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the greater of $500,000 or ½ of 1 percent of the total amount available under this subsection for that year, in the case of each of the 50 States, the District of Columbia, and the Commonwealth of Puerto Rico; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $80,000, in the case of an outlying area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad38de-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct benefit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In using grant funds allotted under paragraph (1), a State educational agency shall, through grants, contracts, or cooperative agreements, undertake activities that significantly and directly benefit the local educational agencies in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dad38df-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation awards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dad38e0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this part, from funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1455"},"text":"section 1455 of this title","children":[],"tail":" for each fiscal year, the Secretary shall reserve the amount that is necessary to make a continuation award to any State educational agency (at the request of the State educational agency) that received a multi-year award under this subchapter (as this subchapter was in effect on the day before "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"December 3, 2004","children":[],"tail":"), to enable the State educational agency to carry out activities in accordance with the terms of the multi-year award."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad38e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1451/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State educational agency that receives a continuation award under paragraph (1) for any fiscal year may not receive any other award under this part for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dad38e2-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s651"},"text":"Pub. L. 91–230, title VI, § 651","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2765"},"text":"118 Stat. 2765","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/ss/6"},"text":"Pub. L. 114–95, title IX, § 9215(ss)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2183"},"text":"129 Stat. 2183","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dad38e3-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dad38e4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0dad38e5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1451, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s651"},"text":"Pub. L. 91–230, title VI, § 651","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/17/tI/s101"},"text":"Pub. L. 105–17, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-04"},"text":"June 4, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/123"},"text":"111 Stat. 123","children":[],"tail":", related to the findings and purposes of part A of former subchapter IV of this chapter, prior to the general amendment of subchapters I to IV of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/108/446"},"text":"Pub. L. 108–446","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1451, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s651"},"text":"Pub. L. 91–230, title VI, § 651","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/186"},"text":"84 Stat. 186","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/630/tI/s106/b"},"text":"Pub. L. 100–630, title I, § 106(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3300"},"text":"102 Stat. 3300","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/476/tVI/s601"},"text":"Pub. L. 101–476, title VI, § 601","children":[],"tail":", title IX, § 901(b)(150), "},{"tag":"date","attrib":{"date":"1990-10-30"},"text":"Oct. 30, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1138"},"text":"104 Stat. 1138","children":[],"tail":", 1149; "},{"tag":"ref","attrib":{"href":"/us/pl/102/119/s25/b"},"text":"Pub. L. 102–119, § 25(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-07"},"text":"Oct. 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/607"},"text":"105 Stat. 607","children":[],"tail":", related to the purposes of former subchapter VI of this chapter, which included promoting general welfare of deaf and hard of hearing individuals and visually impaired individuals and educational advancement of individuals with disabilities, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/17/tII/s203/c"},"text":"Pub. L. 105–17, title II, § 203(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-04"},"text":"June 4, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/157"},"text":"111 Stat. 157","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0dad38e6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (c)(5)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" substituted “and 6611(d)” for “and 6612,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0dad38e7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0dad38e8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0dad38e9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Part effective ","children":[{"tag":"date","attrib":{"date":"2005-07-01"},"text":"July 1, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/s302/a"},"text":"section 302(a) of Pub. L. 108–446","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
