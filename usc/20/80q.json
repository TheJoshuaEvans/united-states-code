{"tag":"section","attrib":{"id":"id0c8581d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q"},"text":null,"children":[{"tag":"num","attrib":{"value":"80q"},"text":"§ 80q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c8581d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is no national museum devoted exclusively to the history and art of cultures indigenous to the Americas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8581d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" although the Smithsonian Institution sponsors extensive Native American programs, none of its 19 museums, galleries, and major research facilities is devoted exclusively to Native American history and art;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8581da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Heye Museum in New York, New York, one of the largest Native American collections in the world, has more than 1,000,000 art objects and artifacts and a library of 40,000 volumes relating to the archaeology, ethnology, and history of Native American peoples;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8581db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Heye Museum is housed in facilities with a total area of 90,000 square feet, but requires a minimum of 400,000 square feet for exhibition, storage, and scholarly research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8581dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the bringing together of the Heye Museum collection and the Native American collection of the Smithsonian Institution would—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c8581dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create a national institution with un­rivaled capability for exhibition and research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8581de-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give all Americans the opportunity to learn of the cultural legacy, historic grandeur, and contemporary culture of Native Americans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8581df-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide facilities for scholarly meetings and the performing arts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8581e0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available curatorial and other learning opportunities for Indians; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8581e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make possible traveling exhibitions to communities throughout the Nation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8581e2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by order of the Surgeon General of the Army, approximately 4,000 Indian human remains from battlefields and burial sites were sent to the Army Medical Museum and were later transferred to the Smithsonian Institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8581e3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through archaeological excavations, individual donations, and museum donations, the Smithsonian Institution has acquired approximately 14,000 additional Indian human remains;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8581e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the human remains referred to in paragraphs (6) and (7) have long been a matter of concern for many Indian tribes, including Alaska Native Villages, and Native Hawaiian communities which are determined to provide an appropriate resting place for their ancestors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8581e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of the origins of such human remains is essential to addressing that concern; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8581e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an extraordinary site on the National Mall in the District of Columbia (U.S. Government Reservation No. 6) is reserved for the use of the Smithsonian Institution and is available for construction of the National Museum of the American Indian.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c8581e7-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/185/s2"},"text":"Pub. L. 101–185, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1336"},"text":"103 Stat. 1336","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c8581e8-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0c8581e9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0c8581ea-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/70/s1"},"text":"Pub. L. 113–70, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1208"},"text":"127 Stat. 1208","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/70/s1"},"text":"“This Act [amending provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s80q–5"},"text":"section 80q–5 of this title","children":[],"tail":"] may be cited as the ‘Native American Veterans’ Memorial Amendments Act of 2013’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0c8581eb-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/278/s1/a"},"text":"Pub. L. 104–278, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3355"},"text":"110 Stat. 3355","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/278/s1/a"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s80q–9a"},"text":"section 80q–9a of this title","children":[],"tail":" and amending sections 80q–3, 80q–9, and 80q–10 of this title] may be cited as the ‘National Museum of the American Indian Act Amendments of 1996’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id0c8581ec-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/185/s1"},"text":"Pub. L. 101–185, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1336"},"text":"103 Stat. 1336","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/185/s1"},"text":"“This Act [enacting this subchapter] may be cited as the ‘National Museum of the American Indian Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
