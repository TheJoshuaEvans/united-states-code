{"tag":"section","attrib":{"id":"id0ccaa188-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1022b"},"text":"§ 1022b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ccaa189-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration; number of awards; payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ccaa18a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under this part shall be awarded for a period of five years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccaa18b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible partnership may not receive more than one grant during a five-year period. Nothing in this subchapter shall be construed to prohibit an individual member, that can demonstrate need, of an eligible partnership that receives a grant under this subchapter from entering into another eligible partnership consisting of new members and receiving a grant with such other eligible partnership before the five-year period described in the preceding sentence applicable to the eligible partnership with which the individual member has first partnered has expired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ccaa18c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ccaa18d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Panel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide the applications submitted under this part to a peer review panel for evaluation. With respect to each application, the peer review panel shall initially recommend the application for funding or for disapproval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccd118e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in funding applications under this part, shall give priority—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ccd118f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to eligible partnerships that include an institution of higher education whose teacher preparation program has a rigorous selection process to ensure the highest quality of students entering such program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ccd1190-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0ccd1191-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022b/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to applications from broad-based eligible partnerships that involve businesses and community organizations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ccd1192-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022b/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to eligible partnerships so that the awards promote an equitable geographic distribution of grants among rural and urban areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccd1193-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine, based on the peer review process, which applications shall receive funding and the amounts of the grants. In determining grant amounts, the Secretary shall take into account the total amount of funds available for all grants under this part and the types of activities proposed to be carried out by the eligible partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ccd1194-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ccd1195-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible partnership receiving a grant under this part shall provide, from non-Federal sources, an amount equal to 100 percent of the amount of the grant, which may be provided in cash or in-kind, to carry out the activities supported by the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccd1196-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive all or part of the matching requirement described in paragraph (1) for any fiscal year for an eligible partnership if the Secretary determines that applying the matching requirement to the eligible partnership would result in serious hardship or an inability to carry out the authorized activities described in this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ccd1197-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible partnership that receives a grant under this part may use not more than two percent of the funds provided to administer the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ccd1198-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tII/s203"},"text":"Pub. L. 89–329, title II, § 203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tII/s201/2"},"text":"Pub. L. 110–315, title II, § 201(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3145"},"text":"122 Stat. 3145","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ccd1199-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ccd119a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0ccd119b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s203"},"text":"section 203 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1023"},"text":"section 1023 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s203"},"text":"section 203 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1023"},"text":"section 1023 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s203"},"text":"section 203 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1023"},"text":"section 1023 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/96/374"},"text":"Pub. L. 96–374","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
