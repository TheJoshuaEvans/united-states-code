{"tag":"section","attrib":{"id":"id0cdb4273-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1066f"},"text":"§ 1066f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" HBCU Capital Financing Advisory Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cdb4274-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Department of Education, the Historically Black College and Universities Capital Financing Advisory Board (hereinafter in this part referred to as the “Advisory Board”) which shall provide advice and counsel to the Secretary and the designated bonding authority as to the most effective and efficient means of implementing construction financing on African American college campuses, and advise the Congress of the United States regarding the progress made in implementing this part. The Advisory Board shall meet with the Secretary at least twice each year to advise him as to the capital needs of historically Black colleges and universities, how those needs can be met through the program authorized by this part, and what additional steps might be taken to improve the operation and implementation of the construction financing program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cdb4275-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cdb4276-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Board shall be appointed by the Secretary and shall be composed of 11 members as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cdb4277-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066f/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary or the Secretary’s designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb4278-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066f/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members who are presidents of private historically Black colleges or universities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb4279-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066f/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members who are presidents of public historically Black colleges or universities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb427a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066f/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The president of the United Negro College Fund, Inc., or the president’s designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb427b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066f/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The president of the National Association for Equal Opportunity in Higher Education, or the designee of the Association.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb427c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066f/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The executive director of the White House Initiative on historically Black colleges and universities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb427d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066f/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The president of the Thurgood Marshall College Fund, or the designee of the president.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb427e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term of office of each member appointed under paragraphs (1)(B) and (1)(C) shall be 3 years, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cdb427f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066f/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the members first appointed pursuant to paragraphs (1)(B) and (1)(C), 2 shall be appointed for terms of 1 year, and 3 shall be appointed for terms of 2 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb4280-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066f/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members appointed to fill a vacancy occurring before the expiration of a term of a member shall be appointed to serve the remainder of that term; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb4281-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066f/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member may continue to serve after the expiration of a term until a successor is appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cdb4282-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional recommendations from Advisory Board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cdb4283-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the responsibilities of the Advisory Board described in subsection (a), the Advisory Board shall advise the Secretary and the authorizing committees regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cdb4284-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066f/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the fiscal status and strategic financial condition of not less than ten historically Black colleges and universities that have—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cdb4285-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066f/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtained construction financing through the program under this part and seek additional financing or refinancing under such program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cdb4286-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066f/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applied for construction financing through the program under this part but have not received financing under such program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb4287-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066f/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the feasibility of reducing borrowing costs associated with the program under this part, including reducing interest rates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb4288-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than six months after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", the Advisory Board shall prepare and submit a report to the authorizing committees regarding the historically Black colleges and universities described in paragraph (1)(A) that includes administrative and legislative recommendations for addressing the issues related to construction financing facing such historically Black colleges and universities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cdb4289-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s347"},"text":"Pub. L. 89–329, title III, § 347","children":[],"tail":", formerly title VII, § 727, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tVII/s704"},"text":"Pub. L. 102–325, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/746"},"text":"106 Stat. 746","children":[],"tail":"; renumbered title III, § 347, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIII"},"text":"Pub. L. 105–244, title III","children":[],"tail":", §§ 301(a)(3), (4), 306(e), "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1636"},"text":"112 Stat. 1636","children":[],"tail":", 1647; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIII/s314/e"},"text":"Pub. L. 110–315, title III, § 314(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3182"},"text":"122 Stat. 3182","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cdb428a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cdb428b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0cdb428c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1132c–6"},"text":"section 1132c–6 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cdb428d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s347"},"text":"section 347 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1069c"},"text":"section 1069c of this title","children":[],"tail":" prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cdb428e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s314/e/1/A"},"text":"Pub. L. 110–315, § 314(e)(1)(A)","children":[],"tail":", substituted “11 members” for “9 members” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s314/e/1/B"},"text":"Pub. L. 110–315, § 314(e)(1)(B)","children":[],"tail":", substituted “Three members” for “Two members”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s314/e/1/C"},"text":"Pub. L. 110–315, § 314(e)(1)(C)","children":[],"tail":", added subpar. (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s314/e/2"},"text":"Pub. L. 110–315, § 314(e)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s306/e/1/A"},"text":"Pub. L. 105–244, § 306(e)(1)(A)","children":[],"tail":", inserted “, or the president’s designee.” after “Fund, Inc.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s306/e/1/B"},"text":"Pub. L. 105–244, § 306(e)(1)(B)","children":[],"tail":", inserted “, or the designee of the Association” before the period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s306/e/2"},"text":"Pub. L. 105–244, § 306(e)(2)","children":[],"tail":", struck out heading and text of subsec. (c). Text read as follows: “There are authorized to be appropriated $50,000 for fiscal year 1993 and each of the 4 succeeding fiscal years to carry out this section.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cdb428f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cdb4290-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0cdb4291-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Boards","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory boards established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a board established by the President or an officer of the Federal Government, such board is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a board established by Congress, its duration is otherwise provided by law. See sections 1001(2) and 1013 of Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
