{"tag":"section","attrib":{"id":"id0deb2c4a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4414"},"text":null,"children":[{"tag":"num","attrib":{"value":"4414"},"text":"§ 4414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General powers of Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0deb2c4b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4414/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the provisions of this chapter, the Board shall have the power, consistent with the provisions of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0deb2c4c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4414/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to adopt, use, and alter a corporate seal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2c4d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4414/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make agreements and contracts with persons, Indian tribes, and private or governmental entities and to make payments or advance payments under such agreements or contract ","children":[{"tag":"ref","attrib":{"idref":"fn002165"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002165"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “contracts”."}],"tail":" without regard to "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3324"},"text":"section 3324 of title 31","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2c4e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4414/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other provision of law to the contrary notwithstanding, to enter into joint development ventures with public or private commercial or noncommercial entities for development of facilities to meet the plan required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4426"},"text":"section 4426 of this title","children":[],"tail":", if the ventures are related to and further the mission of the Institute;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2c4f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4414/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to sue and be sued in its corporate name and to complain and defend in any court of competent jurisdiction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2c50-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4414/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to represent itself, or to contract for representation, in all judicial, legal, and other proceedings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2c51-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4414/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the approval of the agency concerned, to make use of services, facilities, and property of any board, commission, independent establishment, or executive agency or department of the executive branch in carrying out the provisions of this chapter and to pay for such use (such payments to be credited to the applicable appropriation that incurred the expense);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2c52-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4414/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use the United States mails on the same terms and conditions as the executive departments of the United States Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2c53-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4414/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain the services of experts and consultants in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":" and to accept and utilize the services of voluntary and noncompensated personnel and reimburse them for travel expenses, including per diem, as authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2c54-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4414/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to solicit, accept, and dispose of gifts, bequests, devises of money, securities, and other properties of whatever character, for the benefit of the Institute;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2c55-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4414/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive grants from, and enter into contracts and other arrangements with, Federal, State, or local governments, public and private agencies, organizations, institutions, and individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2c56-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4414/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire, hold, maintain, use, operate, and dispose of such real property, including improvements thereon, personal property, equipment, and other items, as may be necessary to enable the Board to carry out the purpose of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2c57-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4414/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent not already provided by law, to obtain insurance to cover all activities of the Institute, including coverage relating to property and liability, or make other provisions against losses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2c58-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4414/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use any funds or property received by the Institute to carry out the purpose of this chapter, including the authority to designate on an annual basis a portion, not to exceed 10 percent, of the funds appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4451"},"text":"section 4451 of this title","children":[],"tail":" for investment, without regard to any other provision of law regarding investment or disposition of federally appropriated funds, on a short-term basis for the purpose of maximizing yield and liquidity of such funds; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2c59-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4414/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to exercise all other lawful powers necessarily or reasonably related to the establishment of the Institute in order to carry out the provisions of this chapter and the exercise of the powers, purposes, functions, duties, and authorized activities of the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0deb2c5a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4414/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounting for non-Federal funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds received by, or under the control of, the Institute that are not Federal funds shall be accounted for separately from Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0deb2c5b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4414/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest and investments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Interest and earnings on amounts received by the Institute pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4451"},"text":"section 4451 of this title","children":[],"tail":" invested under subsection (a)(12) "},{"tag":"ref","attrib":{"idref":"fn002166"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002166"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" shall be the property of the Institute and shall be expended to carry out this chapter. The Board shall be held to a reasonable and prudent standard of care, given such information and circumstances as existed when the decision is made, in decisions involving investment of funds under subsection (a)(12)."},{"tag":"ref","attrib":{"idref":"fn002166"},"text":"2","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0deb2c5c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/498/tXV/s1507"},"text":"Pub. L. 99–498, title XV, § 1507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1603"},"text":"100 Stat. 1603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/tV/s5406/e"},"text":"Pub. L. 100–297, title V, § 5406(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/418"},"text":"102 Stat. 418","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/644/tV/s501"},"text":"Pub. L. 101–644, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4668"},"text":"104 Stat. 4668","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tXIII/s1331/b"},"text":"Pub. L. 102–325, title XIII, § 1331(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/806"},"text":"106 Stat. 806","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2"},"text":"Pub. L. 103–208, § 2","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2486"},"text":"107 Stat. 2486","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0deb2c5d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0deb2c5e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0deb2c5f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (a)(12), referred to in subsec. (c), was redesignated subsec. (a)(13) of this section, repealed, and a new subsec. (a)(13) added by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/tXIII/s1331/b/1/A"},"text":"Pub. L. 102–325, title XIII, § 1331(b)(1)(A)","children":[],"tail":", (C), "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/806"},"text":"106 Stat. 806","children":[],"tail":", and former subsec. (a)(11) of this section was redesignated subsec. (a)(12)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0deb2c60-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208"},"text":"Pub. L. 103–208","children":[],"tail":" substituted semicolon for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s1331/b/1/B"},"text":"Pub. L. 102–325, § 1331(b)(1)(B)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “to make agreements and contracts with persons, Indian tribes, and private or governmental entities and to make payments or advance payments under such agreements or contracts without regard to "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3324"},"text":"section 3324 of title 31","children":[],"tail":";”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s1331/b/1/A"},"text":"Pub. L. 102–325, § 1331(b)(1)(A)","children":[],"tail":", (B), added par. (3) and redesignated former pars. (3) to (11) as (4) to (12), respectively. Former par. (12) redesignated (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s1331/b/1/C"},"text":"Pub. L. 102–325, § 1331(b)(1)(C)","children":[],"tail":", added par. (13) and struck out former par. (13) which read as follows: “to use any funds or property received by the Institute to carry out the purpose of this chapter; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s1331/b/1/A"},"text":"Pub. L. 102–325, § 1331(b)(1)(A)","children":[],"tail":", redesignated par. (12) as (13). Former par. (13) redesignated (14)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s1331/b/1/A"},"text":"Pub. L. 102–325, § 1331(b)(1)(A)","children":[],"tail":", redesignated par. (13) as (14)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s1331/b/2"},"text":"Pub. L. 102–325, § 1331(b)(2)","children":[],"tail":", substituted “shall be expended” for “may be expended”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/644/s501/b"},"text":"Pub. L. 101–644, § 501(b)","children":[],"tail":", amended par. (11) generally. Prior to amendment, par. (11) read as follows: “to obtain insurance or make other provisions against losses;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/644/s501/a"},"text":"Pub. L. 101–644, § 501(a)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297"},"text":"Pub. L. 100–297","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0deb2c61-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0deb2c62-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208"},"text":"Pub. L. 103–208","children":[],"tail":" effective as if included in the Higher Education Amendments of 1992, "},{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s5/a"},"text":"section 5(a) of Pub. L. 103–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1051"},"text":"section 1051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0deb2c63-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/s2"},"text":"section 2 of Pub. L. 102–325","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0deb2c64-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date and applicability of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297"},"text":"Pub. L. 100–297","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/s6303"},"text":"section 6303 of Pub. L. 100–297","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1071"},"text":"section 1071 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
