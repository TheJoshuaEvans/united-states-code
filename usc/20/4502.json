{"tag":"section","attrib":{"id":"id0ded9d6a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4502"},"text":null,"children":[{"tag":"num","attrib":{"value":"4502"},"text":"§ 4502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foundation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ded9d6b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to commemorate the bicentennial of the Constitution, there is established, as an independent establishment of the executive branch, the James Madison Memorial Fellowship Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ded9d6c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Trustees; membership; term of office","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ded9d6d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Foundation shall be subject to the supervision and direction of a Board of Trustees. The Board shall be composed of thirteen members, as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ded9d6e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4502/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two Members of the Senate, of different political parties, shall be appointed by the President upon the recommendation of the President pro tempore of the Senate, in consultation with the Majority Leader and Minority Leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ded9d6f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4502/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two Members of the House of Representatives, of different political parties, shall be appointed by the President upon the recommendation of the Speaker of the House, in consultation with the Minority Leader of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ded9d70-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4502/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members of the Federal judiciary shall be appointed by the President upon the recommendation of the Chief Justice of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ded9d71-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4502/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Six members, not more than three of whom shall be of the same political party, shall be appointed by the President with the advice and consent of the Senate, of whom one shall be a chief executive officer of a State, two shall be members of the general public, and three shall be members of the academic community, appointed upon the recommendation of the Librarian of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ded9d72-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4502/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Education or his designate shall serve ex officio as a member of the Board, but shall not be eligible to serve as Chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ded9d73-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term of office of each member of the Board shall be six years; except that (A) the members first taking office shall serve as designated by the President, four for terms of two years, five for terms of four years, and four for terms of six years, and (B) any member appointed to fill a vacancy shall serve for the remainder of the term for which his predecessor was appointed, and shall be appointed in the same manner as the original appointment for that vacancy was made. This provision shall not apply to members ex officio.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ded9d74-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member of the Board whose term has expired may continue to serve until the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ded9d75-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4502/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which a successor has taken office; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ded9d76-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4502/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the Congress adjourns sine die to end the session of Congress that commences after the date on which the member’s term expired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ded9d77-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Board shall elect from the members of the Board a Chairman and such other officers as may be necessary to carry out the duties of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ded9d78-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement for expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ded9d79-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4502/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), members of the Board shall serve without pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ded9d7a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4502/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Board and the President, Executive Secretary, and other personnel of the Foundation shall be entitled to reimbursement for travel, subsistence, and other necessary expenses incurred in the performance of their duties at rates applicable to judges of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s456/a"},"text":"section 456(a) of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ded9d7b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/b/tVIII/s803"},"text":"Pub. L. 99–500, § 101(b) [title VIII, § 803]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-39"},"text":"100 Stat. 1783–39","children":[],"tail":", 1783–76, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/b/tVIII/s803"},"text":"Pub. L. 99–591, § 101(b) [title VIII, § 803]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-39"},"text":"100 Stat. 3341–39","children":[],"tail":", 3341–76; "},{"tag":"ref","attrib":{"href":"/us/pl/101/208/s1"},"text":"Pub. L. 101–208, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-07"},"text":"Dec. 7, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1836"},"text":"103 Stat. 1836","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/221/s1/1"},"text":"Pub. L. 102–221, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-11"},"text":"Dec. 11, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1676"},"text":"105 Stat. 1676","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ded9d7c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ded9d7d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0ded9d7e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":" is a corrected version of "},{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0ded9d7f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/221"},"text":"Pub. L. 102–221","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/208"},"text":"Pub. L. 101–208","children":[],"tail":" amended subsec. (d) generally. Prior to amendment, subsec. (d) read as follows: “Members of the Board shall serve without pay, but shall be entitled to reimbursement for travel, subsistence, and other necessary expenses incurred in the performance of their duties.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
