{"tag":"section","attrib":{"id":"id0e542691-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7921"},"text":null,"children":[{"tag":"num","attrib":{"value":"7921"},"text":"§ 7921.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local governance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e542692-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7921/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter shall be construed to allow the Secretary to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e542693-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7921/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise any governance or authority over school administration, including the development and expenditure of school budgets, unless otherwise authorized under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e542694-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7921/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue any regulation without first complying with the rulemaking requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e542695-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7921/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue any nonregulatory guidance without first, to the extent feasible, considering input from stakeholders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e542696-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7921/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority under other law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in subsection (a) shall be construed to affect any authority the Secretary has under any other Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e542697-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8541"},"text":"Pub. L. 89–10, title VIII, § 8541","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII/s8033"},"text":"Pub. L. 114–95, title VIII, § 8033","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2118"},"text":"129 Stat. 2118","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e542698-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e542699-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e54269a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 20