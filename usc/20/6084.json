{"tag":"section","attrib":{"id":"id0dfe3e7b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6084"},"text":null,"children":[{"tag":"num","attrib":{"value":"6084"},"text":"§ 6084.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this part is intended to preempt any provision of law of a State or political subdivision of a State that is more restrictive than a provision of this part.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0dfe3e7c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/227/tX/s1044"},"text":"Pub. L. 103–227, title X, § 1044","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"Mar. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/274"},"text":"108 Stat. 274","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
