{"tag":"section","attrib":{"id":"id0c799aae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s75a"},"text":null,"children":[{"tag":"num","attrib":{"value":"75a"},"text":"§ 75a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this subchapter—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c799aaf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s75a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Board” means the Board of Regents of the Smithsonian Institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c799ab0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s75a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Commission” means the National Portrait Gallery Commission as provided for in this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c799ab1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s75a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Gallery” means the National Portrait Gallery established by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c799ab2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s75a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “gift” includes a gift, bequest, or devise, whether outright or in trust, and any legal instrument by which the gift is effected.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c799ab3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s75a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “portraiture” includes portraits and reproductions thereof made by any means or process, whether invented or developed heretofore or hereafter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c799ab4-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/443/s2"},"text":"Pub. L. 87–443, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-04-27"},"text":"Apr. 27, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/62"},"text":"76 Stat. 62","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/209"},"text":"Pub. L. 94–209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-02-05"},"text":"Feb. 5, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/30"},"text":"90 Stat. 30","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c799ab5-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c799ab6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0c799ab7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/209"},"text":"Pub. L. 94–209","children":[],"tail":" substituted “includes portraits and reproductions thereof made by any means or process, whether invented or developed heretofore or hereafter” for “for purposes of this subchapter shall mean painted or sculptured likenesses”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0c799ab8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id0c799ab9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/443/s1"},"text":"Pub. L. 87–443, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-04-27"},"text":"Apr. 27, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/62"},"text":"76 Stat. 62","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/87/443/s1"},"text":"“That this Act [enacting this subchapter] may be cited as the ‘National Portrait Gallery Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
