{"tag":"section","attrib":{"id":"id0c799ac9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s75e"},"text":null,"children":[{"tag":"num","attrib":{"value":"75e"},"text":"§ 75e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of Board","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of carrying out any function authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s75b"},"text":"section 75b of this title","children":[],"tail":", the Board may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c799aca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s75e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase, accept, borrow, or otherwise acquire portraiture, statuary, and other items for preservation, exhibition, or study. The Board may acquire any such item on the basis of its general historical interest, its artistic merit, or the historical significance of the individual to which it relates, or any combination of any such factors. The Board may acquire period furniture and other items to enhance its displays of portraiture and statuary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c799acb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s75e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserve or restore any item acquired pursuant to paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c799acc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s75e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" display, loan, store, or otherwise hold any such item.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c799acd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s75e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sell, exchange, donate, return, or otherwise dispose of any such item.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c799ace-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/443/s6"},"text":"Pub. L. 87–443, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-04-27"},"text":"Apr. 27, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/63"},"text":"76 Stat. 63","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
