{"tag":"section","attrib":{"id":"id0ca6ec00-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s932"},"text":null,"children":[{"tag":"num","attrib":{"value":"932"},"text":"§ 932.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ca6ec01-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s932/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “dependent” means a minor individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ca6ec02-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s932/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has not completed secondary schooling, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ca6ec03-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s932/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is the child, stepchild, adopted child, ward, or spouse of a sponsor, or who is a resident in the household of a sponsor who stands in loco parentis to such individual and who receives one-half or more of his support from such sponsor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca6ec04-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s932/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “sponsor” means a person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ca6ec05-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s932/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0ca6ec06-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s932/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the Armed Forces serving on active duty, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ca6ec07-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s932/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a full-time civilian officer or employee of the Department of Defense and a citizen or national of the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ca6ec08-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s932/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is authorized to transport dependents to or from an overseas area at Government expense and is provided an allowance for living quarters in that area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca6ec09-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s932/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “overseas area” means any area situated outside the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca6ec0a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s932/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “United States”, when used in a geographical sense, means the several States, the District of Columbia, the Commonwealth of Puerto Rico, and the possessions of the United States (excluding the Trust Territory of the Pacific Islands and Midway Island).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca6ec0b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s932/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “involuntarily separated” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1141"},"text":"section 1141 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca6ec0c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s932/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Director” means the Director of the Department of Defense Education Activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ca6ec0d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXIV/s1414"},"text":"Pub. L. 95–561, title XIV, § 1414","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2372"},"text":"92 Stat. 2372","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tIII/s325/a"},"text":"Pub. L. 101–189, div. A, title III, § 325(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1415"},"text":"103 Stat. 1415","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":