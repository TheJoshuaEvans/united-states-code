{"tag":"section","attrib":{"id":"id0df4c8fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603"},"text":null,"children":[{"tag":"num","attrib":{"value":"5603"},"text":"§ 5603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Morris K. Udall and Stewart L. Udall Foundation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0df4c8fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established as an independent entity of the executive branch of the United States Government, the Morris K. Udall and Stewart L. Udall Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0df4c8fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Trustees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Foundation shall be subject to the supervision and direction of the Board of Trustees. The Board shall be comprised of thirteen trustees, eleven of whom shall be voting members of the Board, as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0df4c8ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two Trustees, shall be appointed by the President, with the advice and consent of the Senate, after considering the recommendation of the Speaker of the House of Representatives, in consultation with the Minority Leader of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c900-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two Trustees, shall be appointed by the President, with the advice and consent of the Senate, after considering the recommendation of the President pro tempore of the Senate, in consultation with the Majority and Minority Leaders of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c901-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Five Trustees, not more than three of whom shall be of the same political party, shall be appointed by the President with the advice and consent of the Senate, who have shown leadership and interest in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0df4c902-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the continued use, enjoyment, education, and exploration of our Nation’s rich and bountiful natural resources, such as presidents of major foundations involved with the environment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df4c903-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the improvement of the health status of Native Americans and Alaska Natives and in strengthening tribal self-governance, such as tribal leaders involved in health and public policy development affecting Native American and Alaska Native communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c904-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior, or the Secretary’s designee, who shall serve as a voting ex officio member of the Board but shall not be eligible to serve as Chairperson.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c905-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Education, or the Secretary’s designee, who shall serve as a voting ex officio member of the Board but shall not be eligible to serve as Chairperson.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c906-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President of the University of Arizona shall serve as a nonvoting, ex officio member and shall not be eligible to serve as chairperson.","children":[{"tag":"ref","attrib":{"idref":"fn002185"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002185"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c907-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chairperson of the President’s Council on Environmental Quality, who shall serve as a nonvoting, ex officio member and shall not be eligible to serve as chairperson.","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0df4c908-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of office","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0df4c909-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002186"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002186"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" "},{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term of office of each member of the Board shall be six years, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0df4c90a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of the Trustees first taking offices—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0df4c90b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as designated by the President, one Trustee appointed pursuant to subsection (b)(2) and two trustees appointed pursuant to subsection (b)(3) shall each serve two years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0df4c90c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as designated by the President, one Trustee appointed pursuant to subsection (b)(1) and two Trustees appointed pursuant to subsection (b)(3) shall each serve four years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0df4c90d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as designated by the President, one Trustee appointed pursuant to subsection (b)(1), one Trustee appointed pursuant to subsection (b)(2), and one Trustee appointed pursuant to subsection (b)(3) shall each serve six years;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df4c90e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Trustee appointed to fill a vacancy shall serve for the remainder of the term for which the Trustee’s predecessor was appointed and shall be appointed in the same manner as the original appointment for that vacancy was made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df4c90f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Trustee may serve after the expiration of the Trustee’s term until a successor has been chosen.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0df4c910-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel and subsistence pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Trustees shall serve without pay, but shall be entitled to reimbursement for travel, subsistence, and other necessary expenses incurred in the performance of their duties as members of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0df4c911-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location of Foundation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall be located in Tucson, Arizona and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0df4c912-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Director","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0df4c913-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be an Executive Director of the Foundation who shall be appointed by the Board. The Executive Director shall be the chief executive officer of the Foundation and shall carry out the functions of the Foundation subject to the supervision and direction of the Board. The Executive Director shall carry out such other functions consistent with the provisions of this chapter as the Board shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c914-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5603/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Executive Director of the Foundation shall be compensated at a rate determined by the Board in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5383"},"text":"section 5383 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0df4c915-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/259/s5"},"text":"Pub. L. 102–259, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-03-19"},"text":"Mar. 19, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/79"},"text":"106 Stat. 79","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/f/tVI/s655"},"text":"Pub. L. 104–208, div. A, title I, § 101(f) [title VI, § 655]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-314"},"text":"110 Stat. 3009–314","children":[],"tail":", 3009–369; "},{"tag":"ref","attrib":{"href":"/us/pl/105/156/s3"},"text":"Pub. L. 105–156, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-02-11"},"text":"Feb. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/8"},"text":"112 Stat. 8","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/90/s5"},"text":"Pub. L. 111–90, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-11-03"},"text":"Nov. 3, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2977"},"text":"123 Stat. 2977","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tIII/s303"},"text":"Pub. L. 116–94, div. P, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3187"},"text":"133 Stat. 3187","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0df4c916-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0df4c917-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0df4c918-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" substituted “Arizona and the District of Columbia.” for “Arizona.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/90/s5/1"},"text":"Pub. L. 111–90, § 5(1)","children":[],"tail":", substituted “and Stewart L. Udall” for “Scholarship and Excellence in National Environmental Policy” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/90/s5/2"},"text":"Pub. L. 111–90, § 5(2)","children":[],"tail":", substituted “and Stewart L. Udall” for “Scholarship and Excellence in National Environmental Policy”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/90/s5/3"},"text":"Pub. L. 111–90, § 5(3)","children":[],"tail":", substituted “a rate determined by the Board in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5383"},"text":"section 5383 of title 5","children":[],"tail":"” for “the rate specified for employees in level IV of the Executive Schedule under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/156/s3/1"},"text":"Pub. L. 105–156, § 3(1)","children":[],"tail":", substituted “thirteen” for “twelve” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/156/s3/2"},"text":"Pub. L. 105–156, § 3(2)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" added subpar. (C)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
