{"tag":"section","attrib":{"id":"id0d2c6fcd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1087b"},"text":"§ 1087b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds for origination of direct student loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d2c6fce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide, on the basis of the need and the eligibility of students at each participating institution, and parents of such students, for such loans, funds for student and parent loans under this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d2c6fcf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly to an institution of higher education that has an agreement with the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087d/a"},"text":"section 1087d(a) of this title","children":[],"tail":" to participate in the direct student loan programs under this part and that also has an agreement with the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087d/b"},"text":"section 1087d(b) of this title","children":[],"tail":" to originate loans under this part; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d2c6fd0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through an alternative originator designated by the Secretary to students (and parents of students) attending institutions of higher education that have an agreement with the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087d/a"},"text":"section 1087d(a) of this title","children":[],"tail":" but that do not have an agreement with the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087d/b"},"text":"section 1087d(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d2c6fd1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No entitlement to participate or originate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No institution of higher education shall have a right to participate in the programs authorized by this part, to originate loans, or to perform any program function under this part. Nothing in this subsection shall be construed so as to limit the entitlement of an eligible student attending a participating institution (or the eligible parent of such student) to borrow under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d2c6fd2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delivery of loan funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Loan funds shall be paid and delivered to an institution by the Secretary prior to the beginning of the payment period established by the Secretary in a manner that is consistent with payment and delivery of Federal Pell Grants under subpart 1 of part A of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d2c6fd3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutions outside the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Loan funds for students (and parents of students) attending institutions outside the United States shall be disbursed through a financial institution located or operating in the United States and designated by the Secretary to serve as the agent of such institutions with respect to the receipt of the disbursements of such loan funds and the transfer of such funds to such institutions. To be eligible to receive funds under this part, an institution outside the United States shall make arrangements with the agent designated by the Secretary under this subsection to receive funds under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d2c6fd4-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s452"},"text":"Pub. L. 89–329, title IV, § 452","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s404"},"text":"Pub. L. 99–498, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1437"},"text":"100 Stat. 1437","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s451"},"text":"Pub. L. 102–325, title IV, § 451","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/569"},"text":"106 Stat. 569","children":[],"tail":"; "},