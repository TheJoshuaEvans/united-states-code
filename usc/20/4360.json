{"tag":"section","attrib":{"id":"id0de8bbb0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4360"},"text":null,"children":[{"tag":"num","attrib":{"value":"4360"},"text":"§ 4360.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National study on the education of the deaf","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de8bbb1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4360/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conduct of study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de8bbb2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4360/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a commission on the education of the deaf (in this section referred to as the “commission”) to conduct a national study on the education of the deaf, to identify education-related barriers to successful postsecondary education experiences and employment for individuals who are deaf, and those education-related factors that contribute to successful postsecondary education experiences and employment for individuals who are deaf.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de8bbb3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4360/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section the term “deaf”, when used with respect to an individual, means an individual with a hearing impairment, including an individual who is hard of hearing, an individual deafened later in life, and an individual who is profoundly deaf.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0deb2bb4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4360/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public input and consultation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0deb2bb5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4360/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting such study, the commission shall obtain input from the public. To obtain such input, the commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0deb2bb6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4360/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish a notice with an opportunity for comment in the Federal Register;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0deb2bb7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4360/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with individuals and organizations representing a wide range of perspectives on deafness-related issues, including organizations representing individuals who are deaf, parents of children who are deaf, educators, and researchers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0deb2bb8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4360/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such other action as the commission deems appropriate, which may include holding public meetings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2bb9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4360/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Structured opportunities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The commission shall provide structured opportunities to receive and respond to the viewpoints of the individuals and organizations described in paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0deb2bba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4360/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The commission shall report to the Secretary and Congress not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", regarding the results of the study. The report shall contain—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0deb2bbb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4360/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations relating to educated-related factors that contribute to successful postsecondary education experiences and employment for individuals who are deaf, including recommendations for legislation, that the commission deems appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2bbc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4360/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed summary of the input received under subsection (b) and the ways in which the report addresses such input.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0deb2bbd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4360/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary for each of the fiscal years 2009 and 2010 to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0deb2bbe-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/371/tII/s211"},"text":"Pub. L. 99–371, title II, § 211","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s924"},"text":"Pub. L. 105–244, title IX, § 924","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1832"},"text":"112 Stat. 1832","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIX/s913"},"text":"Pub. L. 110–315, title IX, § 913","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3455"},"text":"122 Stat. 3455","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0deb2bbf-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0deb2bc0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0deb2bc1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4360, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/371/tII/s211"},"text":"Pub. L. 99–371, title II, § 211","children":[],"tail":", formerly title IV, § 411, "},{"tag":"date","attrib":{"date":"1986-08-04"},"text":"Aug. 4, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/794"},"text":"100 Stat. 794","children":[],"tail":"; renumbered title II, § 211, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/421/tI"},"text":"Pub. L. 102–421, title I","children":[],"tail":", §§ 101(b)(5), (6), 140, 151(a)(4), "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"Oct. 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2151"},"text":"106 Stat. 2151","children":[],"tail":", 2163, 2164; "},{"tag":"ref","attrib":{"href":"/us/pl/103/73/tII/s204/i"},"text":"Pub. L. 103–73, title II, § 204(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-11"},"text":"Aug. 11, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/735"},"text":"107 Stat. 735","children":[],"tail":", authorized appropriations for this chapter, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"Pub. L. 105–244, § 3","children":[],"tail":", title IX, § 923, "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1585"},"text":"112 Stat. 1585","children":[],"tail":", 1832, effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4360a"},"text":"section 4360a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0deb2bc2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s913/a"},"text":"Pub. L. 110–315, § 913(a)","children":[],"tail":", inserted “establish a commission on the education of the deaf (in this section referred to as the ‘commission’) to” after “The Secretary shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s913/b"},"text":"Pub. L. 110–315, § 913(b)","children":[],"tail":", substituted “commission” for “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s913/c/1"},"text":"Pub. L. 110–315, § 913(c)(1)","children":[],"tail":", in introductory provisions, substituted “commission shall report to the Secretary and Congress not later than 18 months after "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":"” for “Secretary shall report to Congress not later than 18 months after "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"October 7, 1998","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s913/c/2"},"text":"Pub. L. 110–315, § 913(c)(2)","children":[],"tail":", substituted “recommendations relating to educated-related factors that contribute to successful postsecondary education experiences and employment for individuals who are deaf, including” for “recommendations, including” and “commission” for “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s913/d"},"text":"Pub. L. 110–315, § 913(d)","children":[],"tail":", substituted “such sums as may be necessary for each of the fiscal years 2009 and 2010” for “$1,000,000 for each of the fiscal years 1999 and 2000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0deb2bc3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0deb2bc4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
