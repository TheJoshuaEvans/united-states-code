{"tag":"section","attrib":{"id":"id0cbc4952-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1011a"},"text":"§ 1011a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of student speech and association rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cbc4953-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of rights","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cbc4954-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is the sense of Congress that no student attending an institution of higher education on a full- or part-time basis should, on the basis of participation in protected speech or protected association, be excluded from participation in, be denied the benefits of, or be subjected to discrimination or official sanction under any education program, activity, or division of the institution directly or indirectly receiving financial assistance under this chapter, whether or not such program, activity, or division is sponsored or officially sanctioned by the institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbc4955-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It is the sense of Congress that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cbc4956-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the diversity of institutions and educational missions is one of the key strengths of American higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cbc4957-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individual institutions of higher education have different missions and each institution should design its academic program in accordance with its educational goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cbc4958-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education should facilitate the free and open exchange of ideas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cbc4959-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011a/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" students should not be intimidated, harassed, discouraged from speaking out, or discriminated against;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cbc495a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011a/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" students should be treated equally and fairly; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cbc495b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011a/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nothing in this paragraph shall be construed to modify, change, or infringe upon any constitutionally protected religious liberty, freedom, expression, or association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cbc495c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cbc495d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to discourage the imposition of an official sanction on a student that has willfully participated in the disruption or attempted disruption of a lecture, class, speech, presentation, or performance made or scheduled to be made under the auspices of the institution of higher education, provided that the imposition of such sanction is done objectively and fairly; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbc495e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent an institution of higher education from taking appropriate and effective action to prevent violations of State liquor laws, to discourage binge drinking and other alcohol abuse, to protect students from sexual harassment including assault and date rape, to prevent hazing, or to regulate unsanitary or unsafe conditions in any student residence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cbc495f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cbc4960-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Official sanction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “official sanction”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cbc4961-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means expulsion, suspension, probation, censure, condemnation, reprimand, or any other disciplinary, coercive, or adverse action taken by an institution of higher education or administrative unit of the institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cbc4962-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes an oral or written warning made by an official of an institution of higher education acting in the official capacity of the official.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbc4963-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protected association","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “protected association” means the joining, assembling, and residing with others that is protected under the first and 14th amendments to the Constitution, or would be protected if the institution of higher education involved were subject to those amendments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbc4964-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protected speech","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “protected speech” means speech that is protected under the first and 14th amendments to the Constitution, or would be protected if the institution of higher education involved were subject to those amendments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cbc4965-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s112"},"text":"Pub. L. 89–329, title I, § 112","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tI/s101/a"},"text":"Pub. L. 105–244, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1591"},"text":"112 Stat. 1591","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tI/s104"},"text":"Pub. L. 110–315, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3090"},"text":"122 Stat. 3090","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cbc4966-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cbc4967-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cbc4968-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1011a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s122"},"text":"Pub. L. 89–329, title I, § 122","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tI/s101"},"text":"Pub. L. 102–325, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/462"},"text":"106 Stat. 462","children":[],"tail":", authorized grants to States, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cbc4969-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s104/1"},"text":"Pub. L. 110–315, § 104(1)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s104/2"},"text":"Pub. L. 110–315, § 104(2)","children":[],"tail":", inserted “, provided that the imposition of such sanction is done objectively and fairly” after “higher education”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
