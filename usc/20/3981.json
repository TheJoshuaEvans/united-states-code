{"tag":"section","attrib":{"id":"id0de18f0f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3981"},"text":null,"children":[{"tag":"num","attrib":{"value":"3981"},"text":"§ 3981.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this part to supplement State and local resources to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de18f10-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3981/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the quality of instruction in the fields of mathematics, science, and engineering in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f11-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3981/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnish additional resources and support for research, student scholarships, and faculty exchange programs in the fields of mathematics, science, and engineering; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f12-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3981/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage partnerships in education between the business community, institutions of higher education, and elementary and secondary schools in the community.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de18f13-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tIII/s302"},"text":"Pub. L. 98–377, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date"