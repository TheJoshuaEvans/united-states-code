 III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-11"},"text":"Aug. 11, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1283"},"text":"98 Stat. 1283","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tVI/s6031/b/2"},"text":"Pub. L. 100–418, title VI, § 6031(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1483"},"text":"102 Stat. 1483","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/418/tVI/s6031/b/2"},"text":"“This part [part A (§§ 301–309) of title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377"},"text":"Pub. L. 98–377","children":[],"tail":" enacting this part] may be cited as the ‘Partnerships in Education for Mathematics, Science, and Engineering Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
