{"tag":"section","attrib":{"id":"id0cd8f90b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1066a"},"text":"§ 1066a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd8f90c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “eligible institution” means a “part B institution” as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1061/2"},"text":"section 1061(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd8f90d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “loan” means a loan made to an eligible institution under the provisions of this part and pursuant to an agreement with the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd8f90e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “qualified bond” means any obligation issued by the designated bonding authority at the direction of the Secretary, the net proceeds of which are loaned to an eligible institution for the purposes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1066b/b"},"text":"section 1066b(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd8f90f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “funding” means any payment under this part from the Secretary to the eligible institution or its assignee in fulfillment of the insurance obligations of the Secretary pursuant to an agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1066b"},"text":"section 1066b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd8f910-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “capital project” means, subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1066c/b"},"text":"section 1066c(b) of this title","children":[],"tail":", the repair, renovation, or, in exceptional circumstances, the construction or acquisition, of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd8f911-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any classroom facility, library, laboratory facility, dormitory (including dining facilities) or other facility customarily used by colleges and universities for instructional or research purposes or for housing students, faculty, and staff;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd8f912-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a facility for the administration of an educational program, or a student center or student union, except that not more than 5 percent of the loan proceeds provided under this part may be used for the facility, center or union if the facility, center or union is owned, leased, managed, or operated by a private business, that, in return for such use, makes a payment to the eligible institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd8f913-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" instructional equipment, technology, research instrumentation, and any capital equipment or fixture related to facilities described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd8f914-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a maintenance, storage, or utility facility that is essential to the operation of a facility, a library, a dormitory, equipment, instrumentation, a fixture, real property or an interest therein, described in this paragraph;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd8f915-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066a/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a facility designed to provide primarily outpatient health care for students or faculty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd8f916-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066a/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical infrastructure essential to support the projects authorized under this paragraph, including roads, sewer and drainage systems, and water, power, lighting, telecommunications, and other utilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd8f917-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066a/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other facility, equipment or fixture which is essential to the maintaining of accreditation of the member institution by an accrediting agency or association recognized by the Secretary under subpart 2 of part H of subchapter IV; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd8f918-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066a/5/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any real property or interest therein underlying facilities described in subparagraph (A) or (G).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd8f919-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “interest” includes accredited value or any other payment constituting interest on an obligation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb420a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “outstanding”, when used with respect to bonds, shall not include bonds the payment of which shall have been provided for by the irrevocable deposit in trust of obligations maturing as to principal and interest in such amounts and at such times as will ensure the availability of sufficient moneys to make payments on such bonds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb420b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “designated bonding authority” means the private, for-profit corporation selected by the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1066d/1"},"text":"section 1066d(1) of this title","children":[],"tail":" for the purpose of issuing taxable capital project construction bonds in furtherance of the purposes of this part."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb420c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Advisory Board” means the Advisory Board established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1066f"},"text":"section 1066f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cdb420d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s342"},"text":"Pub. L. 89–329, title III, § 342","children":[],"tail":", formerly title VII, § 722, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tVII/s704"},"text":"Pub. L. 102–325, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/742"},"text":"106 Stat. 742","children":[],"tail":"; renumbered title III, § 342, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIII"},"text":"Pub. L. 105–244, title III","children":[],"tail":", §§ 301(a)(3), (4), (c)(4), 306(a), "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1636"},"text":"112 Stat. 1636","children":[],"tail":", 1637, 1646; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIII"},"text":"Pub. L. 110–315, title III","children":[],"tail":", §§ 314(a), 320(1), "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3180"},"text":"122 Stat. 3180","children":[],"tail":", 3187.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cdb420e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cdb420f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0cdb4210-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1132c–1"},"text":"section 1132c–1 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cdb4211-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s342"},"text":"section 342 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067"},"text":"section 1067 of this title","children":[],"tail":" prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cdb4212-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s320/1/A"},"text":"Pub. L. 110–315, § 320(1)(A)","children":[],"tail":", inserted a comma after “1066c(b) of this title” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s320/1/B"},"text":"Pub. L. 110–315, § 320(1)(B)","children":[],"tail":", substituted “equipment, technology,” for “equipment technology,,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s314/a/1"},"text":"Pub. L. 110–315, § 314(a)(1)","children":[],"tail":", substituted “by an accrediting agency or association recognized by the Secretary under subpart 2 of part H of subchapter IV” for “by a nationally recognized accrediting agency or association”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s314/a/2"},"text":"Pub. L. 110–315, § 314(a)(2)","children":[],"tail":", inserted “capital project” after “issuing taxable”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s301/c/4/A"},"text":"Pub. L. 105–244, § 301(c)(4)(A)","children":[],"tail":", substituted “section 1066b(b)” for “section 1132c–2(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s301/c/4/B"},"text":"Pub. L. 105–244, § 301(c)(4)(B)","children":[],"tail":", substituted “section 1066b” for “section 1132c–2”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s301/c/4/C"},"text":"Pub. L. 105–244, § 301(c)(4)(C)","children":[],"tail":", substituted “section 1066c(b)” for “section 1132c–3(b)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s306/a/2"},"text":"Pub. L. 105–244, § 306(a)(2)","children":[],"tail":", added subpar. (B). Former subpar. (B) redesignated (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s306/a/1"},"text":"Pub. L. 105–244, § 306(a)(1)","children":[],"tail":", (3), redesignated subpar. (B) as (C) and inserted “technology,” after “instructional equipment”. Former subpar. (C) redesignated (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5)(D) to (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s306/a/4"},"text":"Pub. L. 105–244, § 306(a)(4)","children":[],"tail":", added subpars. (D) to (F). Former subpar. (D) redesignated (H)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s306/a/1"},"text":"Pub. L. 105–244, § 306(a)(1)","children":[],"tail":", redesignated subpar. (C) as (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s306/a/1"},"text":"Pub. L. 105–244, § 306(a)(1)","children":[],"tail":", (5), redesignated subpar. (D) as (H) and substituted “(G)” for “(C)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s301/c/4/D"},"text":"Pub. L. 105–244, § 301(c)(4)(D)","children":[],"tail":", substituted “section 1066d(1)” for “section 1132c–4(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s301/c/4/E"},"text":"Pub. L. 105–244, § 301(c)(4)(E)","children":[],"tail":", substituted “section 1066f” for “section 1132c–6”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cdb4213-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cdb4214-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
