{"tag":"section","attrib":{"id":"id0ce74ff3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070a–13"},"text":"§ 1070a–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Upward bound","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ce74ff4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a program to be known as upward bound which shall be designed to generate skills and motivation necessary for success in education beyond secondary school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce74ff5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any project assisted under this section shall provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce74ff6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic tutoring to enable students to complete secondary or postsecondary courses, which may include instruction in reading, writing, study skills, mathematics, science, and other subjects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce74ff7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advice and assistance in secondary and postsecondary course selection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce74ff8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in preparing for college entrance examinations and completing college admission applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce74ff9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce74ffa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the full range of Federal student financial aid programs and benefits (including Federal Pell Grant awards and loan forgiveness) and resources for locating public and private scholarships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce74ffb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in completing financial aid applications, including the Free Application for Federal Student Aid described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1090/a"},"text":"section 1090(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce74ffc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" guidance on and assistance in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce74ffd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secondary school reentry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce74ffe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternative education programs for secondary school dropouts that lead to the receipt of a regular secondary school diploma;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce74fff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entry into general educational development (GED) programs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce75000-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" postsecondary education; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75001-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education or counseling services designed to improve the financial literacy and economic literacy of students or the students’ parents, including financial planning for postsecondary education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce75002-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional required services for multiple-year grant recipients","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any project assisted under this section which has received funding for two or more years shall include, as part of the core curriculum in the next and succeeding years, instruction in mathematics through precalculus, laboratory science, foreign language, composition, and literature.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce75003-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any project assisted under this section may provide such services as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce75004-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exposure to cultural events, academic programs, and other activities not usually available to disadvantaged youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75005-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information, activities, and instruction designed to acquaint youth participating in the project with the range of career options available to the youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75006-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on-campus residential programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75007-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mentoring programs involving elementary school or secondary school teachers or counselors, faculty members at institutions of higher education, students, or any combination of such persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75008-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work-study positions where youth participating in the project are exposed to careers requiring a postsecondary degree;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75009-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special services, including mathematics and science preparation, to enable veterans to make the transition to postsecondary education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce7500a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs and activities as described in subsection (b), subsection (c), or paragraphs (1) through (6) of this subsection that are specially designed for students who are limited English proficient, students from groups that are traditionally underrepresented in postsecondary education, students with disabilities, students who are homeless children and youths (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11434a"},"text":"section 11434a of title 42","children":[],"tail":"), students who are in foster care or are aging out of the foster care system, or other disconnected students."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce7500b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for approval of applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In approving applications for projects under this section for any fiscal year, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce7500c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require an assurance that not less than two-thirds of the youths participating in the project proposed to be carried out under any application be low-income individuals who are first generation college students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce7500d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require an assurance that the remaining youths participating in the project proposed to be carried out under any application be low-income individuals, first generation college students, or students who have a high risk for academic failure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce7500e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that there be a determination by the institution, with respect to each participant in such project that the participant has a need for academic support in order to pursue successfully a program of education beyond secondary school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce7500f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that such participants be persons who have completed 8 years of elementary education and are at least 13 years of age but not more than 19 years of age, unless the imposition of any such limitation would defeat the purposes of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75010-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require an assurance that no student will be denied participation in a project assisted under this section because the student will enter the project after the 9th grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce75011-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum stipends","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Youths participating in a project proposed to be carried out under any application may be paid stipends not in excess of $60 per month during the summer school recess, for a period not to exceed three months, except that youth participating in a work-study position under subsection (d)(5) may be paid a stipend of $300 per month during the summer school recess, for a period not to exceed three months. Youths participating in a project proposed to be carried out under any application may be paid stipends not in excess of $40 per month during the remaining period of the year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce75012-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce75013-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization and appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated, and there are appropriated to the Secretary, from funds not otherwise appropriated, $57,000,000 for each of the fiscal years 2008 through 2011 to carry out paragraph (2), except that any amounts that remain unexpended for such purpose for each of such fiscal years may be available for technical assistance and administration costs for the Upward Bound program. The authority to award grants under this subsection shall expire at the end of fiscal year 2011.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75014-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts made available by paragraph (1) shall be available to provide assistance to all Upward Bound projects that did not receive assistance in fiscal year 2007 and that have a grant score above 70. Such assistance shall be made available in the form of 4-year grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce75015-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–13/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Absolute priority prohibited in Upward Bound Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon enactment of this subsection and except as otherwise expressly provided by amendment to this section, the Secretary shall not continue, implement, or enforce the absolute priority for the Upward Bound Program published by the Department of Education in the Federal Register on ","children":[{"tag":"date","attrib":{"date":"2006-09-22"},"text":"September 22, 2006","children":[],"tail":" (71 Fed. Reg. 55447 et seq.). This subsection shall not be applied retroactively. In implementing this subsection, the Department shall allow the programs and participants chosen in the grant cycle to which the priority applies to continue their grants and participation without a further recompetition. The entities shall not be required to apply the absolute priority conditions or restrictions to future participants."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ce75016-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s402C"},"text":"Pub. L. 89–329, title IV, § 402C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s402/a/4"},"text":"Pub. L. 102–325, title IV, § 402(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/487"},"text":"106 Stat. 487","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/b/10"},"text":"Pub. L. 103–208, § 2(b)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2459"},"text":"107 Stat. 2459","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s402/c"},"text":"Pub. L. 105–244, title IV, § 402(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1654"},"text":"112 Stat. 1654","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/84/tI/s103"},"text":"Pub. L. 110–84, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/786"},"text":"121 Stat. 786","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s403/c"},"text":"Pub. L. 110–315, title IV, § 403(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3199"},"text":"122 Stat. 3199","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ce75017-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ce75018-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0ce75019-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/c/1"},"text":"Pub. L. 110–315, § 403(c)(1)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which related to permissible services."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/c/2"},"text":"Pub. L. 110–315, § 403(c)(2)","children":[],"tail":", substituted “Additional required services for multiple-year grant recipients” for “Required services” in heading and “project assisted under this section” for “upward bound project assisted under this division” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/c/4"},"text":"Pub. L. 110–315, § 403(c)(4)","children":[],"tail":", added subsec. (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/c/3"},"text":"Pub. L. 110–315, § 403(c)(3)","children":[],"tail":", (5)(A), redesignated subsec. (d) as (e) and substituted “projects under this section” for “upward bound projects under this division” in introductory provisions. Former subsec. (e) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/c/5/B"},"text":"Pub. L. 110–315, § 403(c)(5)(B)","children":[],"tail":", substituted “low-income individuals, first generation college students, or students who have a high risk for academic failure;” for “either low-income individuals or first generation college students;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/c/5/C"},"text":"Pub. L. 110–315, § 403(c)(5)(C)","children":[],"tail":"–(E), added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/c/3"},"text":"Pub. L. 110–315, § 403(c)(3)","children":[],"tail":", (6), redesignated subsec. (e) as (f) and substituted “during the summer school recess, for a period not to exceed three months” for “during June, July, and August” in two places, and “subsection (d)(5)” for “subsection (b)(10)”. Former subsec. (f) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/c/3"},"text":"Pub. L. 110–315, § 403(c)(3)","children":[],"tail":", redesignated subsec. (f) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/c/7"},"text":"Pub. L. 110–315, § 403(c)(7)","children":[],"tail":", added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/84"},"text":"Pub. L. 110–84","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s402/c/1/A"},"text":"Pub. L. 105–244, § 402(c)(1)(A)","children":[],"tail":", substituted “counseling and workshops” for “personal counseling”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s402/c/1/B"},"text":"Pub. L. 105–244, § 402(c)(1)(B)","children":[],"tail":", inserted “or counselors” after “teachers” and struck out “and” after semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(10), (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s402/c/1/D"},"text":"Pub. L. 105–244, § 402(c)(1)(D)","children":[],"tail":", added pars. (10) and (11). Former par. (10) redesignated (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s402/c/1/E"},"text":"Pub. L. 105–244, § 402(c)(1)(E)","children":[],"tail":", substituted “(11)” for “(9)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s402/c/1/C"},"text":"Pub. L. 105–244, § 402(c)(1)(C)","children":[],"tail":", redesignated par. (10) as (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s402/c/2"},"text":"Pub. L. 105–244, § 402(c)(2)","children":[],"tail":", substituted “except that youth participating in a work-study position under subsection (b)(10) may be paid a stipend of $300 per month during June, July, and August. Youths participating in a project proposed to be carried out under any application may be paid stipends not in excess of $40 per month during the remaining period of the year.” for “and not in excess of $40 per month during the remaining period of the year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208"},"text":"Pub. L. 103–208","children":[],"tail":" substituted “foreign” for “and foreign”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0ce7501a-3a70-11f1-a648-bee82ed8a795"},"t