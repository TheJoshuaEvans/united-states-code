{"tag":"section","attrib":{"id":"id0e51b650-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7913"},"text":null,"children":[{"tag":"num","attrib":{"value":"7913"},"text":"§ 7913.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on discrimination","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to require, authorize, or permit, the Secretary, or a State educational agency, local educational agency, or school to grant to a student, or deny or impose upon a student, any financial or educational benefit or burden, in violation of the fifth or 14th amendments to the Constitution or other law relating to discrimination in the provision of federally funded programs or activities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e51b651-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8533"},"text":"Pub. L. 89–10, title VIII, § 8533","children":[],"tail":", formerly title IX, § 9533, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIX/s901"},"text":"Pub. L. 107–110, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1985"},"text":"115 Stat. 1985","children":[],"tail":"; renumbered title VIII, § 8533, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII/s8001/a/6"},"text":"Pub. L. 114–95, title VIII, § 8001(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2088"},"text":"129 Stat. 2088","children":[],"tail":", 2089.)"}],"tail":"\n"}],"tail":null}
