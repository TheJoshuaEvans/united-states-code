{"tag":"section","attrib":{"id":"id0e62582c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9517"},"text":null,"children":[{"tag":"num","attrib":{"value":"9517"},"text":"§ 9517.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioners of the National Education Centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e62582d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9517/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of Commissioners","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e62582e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9517/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), each of the National Education Centers shall be headed by a Commissioner appointed by the Director. In appointing Commissioners, the Director shall seek to promote continuity in leadership of the National Education Centers and shall consider individuals recommended by the Board. The Director may appoint a Commissioner to carry out the functions of a National Education Center without regard to the provisions of title 5 governing appointments in the competitive service, and the provisions of chapter 51 and subchapter III of chapter 53 of such title relating to classification and General Schedule pay rates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e62582f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9517/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay and qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), each Commissioner shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e625830-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9517/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive the rate of basic pay for level IV of the Executive Schedule; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625831-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9517/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be highly qualified in the field of education research or evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e625832-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9517/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), each Commissioner shall report to the Director. A Commissioner shall serve for a period of not more than 6 years, except that a Commissioner—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e625833-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9517/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be reappointed by the Director; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625834-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9517/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may serve after the expiration of that Commissioner’s term, until a successor has been appointed, for a period not to exceed 1 additional year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e625835-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9517/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of Commissioner for Education Statistics","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Center for Education Statistics shall be headed by a Commissioner for Education Statistics who shall be appointed by the President and who shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e625836-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9517/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have substantial knowledge of programs assisted by the National Center for Education Statistics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e625837-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9517/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive the rate of basic pay for level IV of the Executive Schedule; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e625838-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9517/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve for a term of 6 years, with the term to expire every sixth June 21, beginning in 2003.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e625839-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9517/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Commissioner of a National Education Center shall coordinate with each of the other Commissioners of the National Education Centers in carrying out such Commissioner’s duties under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e62583a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9517/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervision and approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Commissioner, except the Commissioner for Education Statistics, shall carry out such Commissioner’s duties under this subchapter under the supervision and subject to the approval of the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e62583b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s117"},"text":"Pub. L. 107–279, title I, § 117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1952"},"text":"116 Stat. 1952","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s2/d/2"},"text":"Pub. L. 112–166, § 2(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1284"},"text":"126 Stat. 1284","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e62583c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e62583d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e62583e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Level IV of the Executive Schedule, referred to in subsecs. (a)(2)(A) and (b)(2), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e62583f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166"},"text":"Pub. L. 112–166","children":[],"tail":" struck out “, by and with the advice and consent of the Senate,” after “President” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e625840-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e625841-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166"},"text":"Pub. L. 112–166","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", and applicable to appointments made on and after that effective date, including any nomination pending in the Senate on that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s6/a"},"text":"section 6(a) of Pub. L. 112–166","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s113"},"text":"section 113 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
