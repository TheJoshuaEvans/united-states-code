{"tag":"section","attrib":{"id":"id0cec0be5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070b–1"},"text":"§ 1070b–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount and duration of grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cec0be6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grant","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cec0be7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (3), from the funds received by it for such purpose under this subpart, an institution which awards a supplemental grant to a student for an academic year under this subpart shall, for each year, pay to that student an amount not to exceed the lesser of (A) the amount determined by the institution, in accordance with the provisions of part F of this subchapter, to be needed by that student to enable the student to pursue a course of study at the institution or in a program of study abroad that is approved for credit by the institution at which the student is enrolled, or (B) $4,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0be8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the amount determined under paragraph (1) with respect to a student for any academic year is less than $100, no payment shall be made to that student for that year. For a student enrolled for less than a full academic year, the minimum payment required shall be reduced proportionately.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0be9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For students participating in study abroad programs, the institution shall consider all reasonable costs associated with such study abroad when determining student eligibility. The amount of grant to be awarded in such cases may exceed the maximum amount of $4,000 by as much as $400 if reasonable study abroad costs exceed the cost of attendance at the home institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cec0bea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period for receipt of grants; continuing eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cec0beb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The period during which a student may receive supplemental grants shall be the period required for the completion of the first undergraduate baccalaureate course of study being pursued by that student.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0bec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A supplemental grant awarded under this subpart shall entitle the student (to whom it is awarded) to payments pursuant to such grant only if the student meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1091"},"text":"section 1091 of this title","children":[],"tail":", except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070b–2/c"},"text":"section 1070b–2(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cec0bed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of grant during academic year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to prohibit an institution from making payments of varying amounts from a supplemental grant to a student during an academic year to cover costs for a period which are not applicable to other periods of such academic year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cec0bee-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s413B"},"text":"Pub. L. 89–329, title IV, § 413B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s401/a"},"text":"Pub. L. 99–498, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1328"},"text":"100 Stat. 1328","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s403/c"},"text":"Pub. L. 102–325, title IV, § 403(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/505"},"text":"106 Stat. 505","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cec0bef-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cec0bf0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cec0bf1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1070b–1, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s413B"},"text":"Pub. L. 89–329, title IV, § 413B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/318/tI/s131/b/1"},"text":"Pub. L. 92–318, title I, § 131(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/252"},"text":"86 Stat. 252","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tIV/s403/c"},"text":"Pub. L. 96–374, title IV, § 403(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1405"},"text":"94 Stat. 1405","children":[],"tail":", related to amount and duration of supplemental educational opportunity grants, prior to the general revision of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cec0bf2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s403/c/1"},"text":"Pub. L. 102–325, § 403(c)(1)","children":[],"tail":", substituted “Except as provided in paragraph (3), from” for “From” in introductory provisions and inserted “or in a program of study abroad that is approved for credit by the institution at which the student is enrolled” after “course of study at the institution” in subpar. (A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s403/c/2"},"text":"Pub. L. 102–325, § 403(c)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
