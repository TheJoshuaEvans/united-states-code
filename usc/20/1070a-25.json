{"tag":"section","attrib":{"id":"id0cec0b62-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070a–25"},"text":"§ 1070a–25.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarship component","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cec0b63-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cec0b64-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to receive a grant under this division, an eligible entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–21/c/1"},"text":"section 1070a–21(c)(1) of this title","children":[],"tail":" shall establish or maintain a financial assistance program that awards scholarships to students in accordance with the requirements of this section. The Secretary shall encourage the eligible entity to ensure that a scholarship provided pursuant to this section is available to an eligible student for use at any institution of higher education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b65-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–21/c/2"},"text":"section 1070a–21(c)(2) of this title","children":[],"tail":" may award scholarships to eligible students in accordance with the requirements of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cec0b66-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cec0b67-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), each eligible entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–21/c/1"},"text":"section 1070a–21(c)(1) of this title","children":[],"tail":" that receives a grant under this division shall use not less than 25 percent and not more than 50 percent of the grant funds for activities described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–24"},"text":"section 1070a–24 of this title","children":[],"tail":" (except for the activity described in subsection (a)(4) of such section), with the remainder of such funds to be used for a scholarship program under this section in accordance with such subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b68-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), the Secretary may allow an eligible entity to use more than 50 percent of grant funds received under this division for such activities, if the eligible entity demonstrates that the eligible entity has another means of providing the students with the financial assistance described in this section and describes such means in the application submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–23"},"text":"section 1070a–23 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cec0b69-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible entity providing scholarships under this section shall provide information on the eligibility requirements for the scholarships to all participating students upon the students’ entry into the programs assisted under this division.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cec0b6a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maximum amount of a scholarship that an eligible student shall be eligible to receive under this section shall be established by the eligible entity. The minimum amount of the scholarship for each fiscal year shall not be less than the minimum Federal Pell Grant award under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a"},"text":"section 1070a of this title","children":[],"tail":" for such award year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cec0b6b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Portability of assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cec0b6c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–21/c/1"},"text":"section 1070a–21(c)(1) of this title","children":[],"tail":" that receives a grant under this division shall hold in reserve, for the students served by such grant as described in section 1070a–22(d)(1)(A) or 1070a–24(d) of this title, an amount that is not less than the minimum scholarship amount described in subsection (d), multiplied by the number of students the eligible entity estimates will meet the requirements of paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b6d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for portability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds held in reserve under paragraph (1) shall be made available to an eligible student when the eligible student has—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cec0b6e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completed a secondary school diploma, its recognized equivalent, or another recognized alternative standard for individuals with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0b6f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrolled in an institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b70-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified educational expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds available to an eligible student under this subsection may be used for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cec0b71-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tuition, fees, books, supplies, and equipment required for the enrollment or attendance of the eligible student at an institution of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0b72-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an eligible student with special needs, expenses for special needs services that are incurred in connection with such enrollment or attendance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b73-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cec0b74-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redistribution","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cec0b75-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/e/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds held in reserve under paragraph (1) that are not used by an eligible student within six years of the student’s scheduled completion of secondary school may be redistributed by the eligible entity to other eligible students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cec0b76-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/e/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of excess to the Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, after meeting the requirements of paragraph (1) and, if applicable, redistributing excess funds in accordance with clause (i) of this subparagraph, an eligible entity has funds held in reserve under paragraph (1) that remain available, the eligible entity shall return such remaining reserved funds to the Secretary for distribution to other grantees under this division in accordance with the funding rules described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–22/a"},"text":"section 1070a–22(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0b77-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonparticipating entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (A), in the case of an eligible entity that does not receive assistance under this subpart for six fiscal years, the eligible entity shall return any funds held in reserve under paragraph (1) that are not awarded or obligated to eligible students to the Secretary for distribution to other grantees under this division.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cec0b78-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Scholarships provided under this section shall not be considered for the purpose of awarding Federal grant assistance under this subchapter, except that in no case shall the total amount of student financial assistance awarded to a student under this subchapter exceed such student’s total cost of attendance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cec0b79-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible students","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A student eligible for assistance under this section is a student who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cec0b7a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is less than 22 years old at time of first scholarship award under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b7b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receives a secondary school diploma or its recognized equivalent on or after ","children":[{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b7c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is enrolled or accepted for enrollment in a program of undergraduate instruction at an institution of higher education that is located within the State’s boundaries, except that, at the State’s option, an eligible entity may offer scholarship program portability for recipients who attend institutions of higher education outside such State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b7d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–25/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who participated in the activities required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–24/a"},"text":"section 1070a–24(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cec0b7e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s404E"},"text":"Pub. L. 89–329, title IV, § 404E","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s403"},"text":"Pub. L. 105–244, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1661"},"text":"112 Stat. 1661","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s404/e"},"text":"Pub. L. 110–315, title IV, § 404(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3213"},"text":"122 Stat. 3213","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cec0b7f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cec0b80-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cec0b81-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1070a–25, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s404E"},"text":"Pub. L. 89–329, title IV, § 404E","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s402/a/4"},"text":"Pub. L. 102–325, title IV, § 402(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/495"},"text":"106 Stat. 495","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/b/20"},"text":"Pub. L. 103–208, § 2(b)(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2459"},"text":"107 Stat. 2459","children":[],"tail":", related to distribution of funds, prior to the general amendment of this division by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cec0b82-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s404/e/3"},"text":"Pub. L. 110–315, § 404(e)(3)","children":[],"tail":", added subsecs. (b) and (c). Former subsecs. (b) and (c) redesignated (d) and (f), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s404/e/4"},"text":"Pub. L. 110–315, § 404(e)(4)","children":[],"tail":", substituted “the minimum Federal Pell Grant award under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a"},"text":"section 1070a of this title","children":[],"tail":" for such award year” for “the lesser of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) 75 percent of the average cost of attendance for an in-State student, in a 4-year program of instruction, at public institutions of higher education in such State, as determined in accordance with regulations prescribed by the Secretary; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the maximum Federal Pell Grant funded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a"},"text":"section 1070a of this title","children":[],"tail":" for such fiscal year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s404/e/2"},"text":"Pub. L. 110–315, § 404(e)(2)","children":[],"tail":", redesignated subsec. (b) as (d). Former subsec. (d) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s404/e/1"},"text":"Pub. L. 110–315, § 404(e)(1)","children":[],"tail":", (5), added subsec. (e) and struck out former subsec. (e). Prior to amendment, text read as follows: “The Secretary shall ensure that each eligible entity places a priority on awarding scholarships to students who will receive a Federal Pell Grant for the academic year for which the scholarship is awarded under this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s404/e/1"},"text":"Pub. L. 110–315, § 404(e)(1)","children":[],"tail":", (2), redesignated subsec. (c) as (f) and struck out former subsec. (f). Text read as follows: “An eligible entity may consider students who have successfully participated in programs funded under division 1 of this subpart to have met the requirements of subsection (d)(4) of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s404/e/2"},"text":"Pub. L. 110–315, § 404(e)(2)","children":[],"tail":", redesignated subsec. (d) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s404/e/6"},"text":"Pub. L. 110–315, § 404(e)(6)","children":[],"tail":", substituted “activities required under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–24/a"},"text":"section 1070a–24(a) of this title","children":[],"tail":"” for “early intervention component required under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–24"},"text":"section 1070a–24 of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cec0b83-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cec0b84-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s404/i"},"text":"Pub. L. 110–315, title IV, § 404(i)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tIV/s401/c"},"text":"Pub. L. 111–39, title IV, § 401(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1940"},"text":"123 Stat. 1940","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/39/tIV/s401/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsection (e) [amending this section] shall apply to grants made under chapter 2 of subpart 2 of part A of title IV of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–21"},"text":"20 U.S.C. 1070a–21","children":[],"tail":" et seq.) on or after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":"], except that a recipient of a grant under such chapter that is made prior to such date may elect to apply the requirements contained in the amendments made by subsection (e) to that grant if the grant recipient informs the Secretary of the election."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A grant recipient may make the election described in paragraph (1) only if the election does not decrease the amount of the scholarship promised to an individual student under the grant.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
