{"tag":"section","attrib":{"id":"id0deb2cb9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4419"},"text":null,"children":[{"tag":"num","attrib":{"value":"4419"},"text":"§ 4419.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit and nonpolitical nature of Institute","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0deb2cba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4419/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute shall have no power to issue any shares of stock or to declare or pay any dividends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0deb2cbb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4419/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit nature","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No part of the income or assets of the Institute shall inure to the benefit of any director, officer, employee, or any other individual except as salary or reasonable compensation for services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0deb2cbc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4419/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonpolitical nature","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute may not contribute to, or otherwise support, any political party or candidate for elective public office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ded9cbd-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/498/tXV/s1512"},"text":"Pub. L. 99–498, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1607"},"text":"100 Stat. 1607","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
