{"tag":"section","attrib":{"id":"id0d41ccb6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1087uu–1"},"text":"§ 1087uu–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native American students","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d41ccb7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the student aid index for Native American students, computations performed pursuant to this part shall exclude—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d41ccb8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any income and assets of $2,000 or less per individual payment received by the student (and spouse) and student’s parents under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/64"},"text":"Public Law 98–64","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s117a"},"text":"25 U.S.C. 117a","children":[],"tail":" et seq.; "},{"tag":"ref","attrib":{"href":"/us/stat/97/365"},"text":"97 Stat. 365","children":[],"tail":") (commonly known as the “Per Capita Act”) or the Indian Tribal Judgment Funds Use or Distribution Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1401"},"text":"25 U.S.C. 1401","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d41ccb9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any income received by the student (and spouse) and student’s parents under the Alaska Native Claims Settlement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.) or the Maine Indian Claims Settlement Act of 1980 ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1721"},"text":"25 U.S.C. 1721","children":[],"tail":" et seq.)."},{"tag":"ref","attrib":{"idref":"fn002093"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002093"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d41ccba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop guidance, in consultation with Tribal Colleges and Universities (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c"},"text":"section 1059c of this title","children":[],"tail":") and the State higher education agency in Alaska and Maine, to implement the determination under subsection (a) without adding additional questions to the FAFSA, including through the use of the authority under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087tt"},"text":"section 1087tt of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d41ccbb-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s479C"},"text":"Pub. L. 89–329, title IV, § 479C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/50/s14/27"},"text":"Pub. L. 100–50, § 14(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-06-03"},"text":"June 3, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/353"},"text":"101 Stat. 353","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s471/a"},"text":"Pub. L. 102–325, title IV, § 471(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/606"},"text":"106 Stat. 606","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tIV/s406/a/5"},"text":"Pub. L. 111–39, title IV, § 406(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1949"},"text":"123 Stat. 1949","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tVII/s702/k"},"text":"Pub. L. 116–260, div. FF, title VII, § 702(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3160"},"text":"134 Stat. 3160","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d41ccbc-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d41ccbd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d41ccbe-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/64"},"text":"Public Law 98–64","children":[],"tail":", referred to in subsec. (a)(1), is "},{"tag":"ref","attrib":{"href":"/us/pl/98/64"},"text":"Pub. L. 98–64","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-02"},"text":"Aug. 2, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/365"},"text":"97 Stat. 365","children":[],"tail":", commonly known as the Per Capita Act, which enacted sections 117a to 117c of Title 25, Indians, and repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s117"},"text":"section 117 of Title 25","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Tribal Judgment Funds Use or Distribution Act, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/134"},"text":"Pub. L. 93–134","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-19"},"text":"Oct. 19, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/466"},"text":"87 Stat. 466","children":[],"tail":", which is classified generally to chapter 16 (§ 1401 et seq.) of Title 25, Indians. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1401/c"},"text":"section 1401(c) of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Alaska Native Claims Settlement Act, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203"},"text":"Pub. L. 92–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"Dec. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/688"},"text":"85 Stat. 688","children":[],"tail":", which is classified generally to chapter 33 (§ 1601 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"section 1601 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Maine Indian Claims Settlement Act of 1980, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/420"},"text":"Pub. L. 96–420","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1785"},"text":"94 Stat. 1785","children":[],"tail":", which was classified generally to subchapter II (§ 1721 et seq.) of chapter 19 of Title 25, Indians, and was omitted from the Code as being of special and not general application."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d41ccbf-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “In determining family contributions for Native American students, computations performed pursuant to this part shall exclude—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) any income and assets of $2,000 or less per individual payment received by the student (and spouse) and student’s parents under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/64"},"text":"Public Law 98–64","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s117a"},"text":"25 U.S.C. 117a","children":[],"tail":" et seq.; "},{"tag":"ref","attrib":{"href":"/us/stat/97/365"},"text":"97 Stat. 365","children":[],"tail":") (commonly known as the ‘Per Capita Act’) or the Indian Tribal Judgment Funds Use or Distribution Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1401"},"text":"25 U.S.C. 1401","children":[],"tail":" et seq.); and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) any income received by the student (and spouse) and student’s parents under the Alaska Native Claims Settlement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.) or the Maine Indian Claims Settlement Act of 1980 ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1721"},"text":"25 U.S.C. 1721","children":[],"tail":" et seq.).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s406/a/5/A"},"text":"Pub. L. 111–39, § 406(a)(5)(A)","children":[],"tail":", substituted “under "},{"tag":"ref","attrib":{"href":"/us/pl/98/64"},"text":"Public Law 98–64","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s117a"},"text":"25 U.S.C. 117a","children":[],"tail":" et seq.; "},{"tag":"ref","attrib":{"href":"/us/stat/97/365"},"text":"97 Stat. 365","children":[],"tail":") (commonly known as the ‘Per Capita Act’) or the Indian Tribal Judgment Funds Use or Distribution Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1401"},"text":"25 U.S.C. 1401","children":[],"tail":" et seq.); and” for “under the Per Capita Act or the Distribution of Judgment Funds Act; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s406/a/5/B"},"text":"Pub. L. 111–39, § 406(a)(5)(B)","children":[],"tail":", substituted “Alaska” for “Alaskan” and inserted “("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.)” after “Native Claims Settlement Act” and “of 1980 ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1721"},"text":"25 U.S.C. 1721","children":[],"tail":" et seq.)” after “Maine Indian Claims Settlement Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":" amended section generally, reenacting provi