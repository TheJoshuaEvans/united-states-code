{"tag":"section","attrib":{"id":"id0d90891a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1225"},"text":null,"children":[{"tag":"num","attrib":{"value":"1225"},"text":"§ 1225.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriations on academic or school-year basis; additional period for obligation of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d90891b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1225/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Academic or differing fiscal year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Appropriations for any fiscal year for grants, loans, contracts, or other payments under any applicable program may, in accordance with regulations of the Secretary, be made available for obligation by the recipient on the basis of an academic or school year differing from such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d90891c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1225/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Succeeding fiscal year","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d90891d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1225/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, unless enacted in specific limitation of the provisions of this subsection, any funds from appropriations to carry out any programs to which this chapter is applicable during any fiscal year, which are not obligated and expended by educational agencies or institutions prior to the beginning of the fiscal year succeeding the fiscal year for which such funds were appropriated shall remain available for obligation and expenditure by such agencies and institutions during such succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d90891e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1225/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any funds under any applicable program which, pursuant to paragraph (1), are available for obligation and expenditure in the year succeeding the fiscal year for which they were appropriated shall be obligated and expended in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d90891f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1225/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal statutory and regulatory provisions relating to such program which are in effect for such succeeding fiscal year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d908920-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1225/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any program plan or application submitted by such educational agencies or institutions for such program for such succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d908921-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1225/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of judicial proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any funds appropriated to carry out any applicable program are not obligated pursuant to a spending plan submitted in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1341/a"},"text":"section 1341(a) of title 31","children":[],"tail":" and become available for obligation after the institution of a judicial proceeding seeking the release of such funds, then such funds shall be available for obligation and expenditure until the end of the fiscal year which begins after the termination of such judicial proceeding."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d908922-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/tIV/s421"},"text":"Pub. L. 90–247, title IV, § 421","children":[],"tail":", formerly § 405, "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/815"},"text":"81 Stat. 815","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/230/tIV/s401/a/5"},"text":"Pub. L. 91–230, title IV, § 401(a)(5)","children":[],"tail":", (7), (8), "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/165"},"text":"84 Stat. 165","children":[],"tail":"; renumbered § 414, "},{"tag":"ref","attrib":{"href":"/us/pl/92/318/tIII/s301/a/1"},"text":"Pub. L. 92–318, title III, § 301(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/326"},"text":"86 Stat. 326","children":[],"tail":"; renumbered § 412, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/380/tV/s506/a/1/D"},"text":"Pub. L. 93–380, title V, § 506(a)(1)(D)","children":[],"tail":", (E), "},{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/562"},"text":"88 Stat. 562","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/273/s3/12"},"text":"Pub. L. 94–273, § 3(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-21"},"text":"Apr. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/376"},"text":"90 Stat. 376","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/112/s5"},"text":"Pub. L. 95–112, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-24"},"text":"Sept. 24, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/912"},"text":"91 Stat. 912","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXII/s1245"},"text":"Pub. L. 95–561, title XII, § 1245","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2354"},"text":"92 Stat. 2354","children":[],"tail":"; renumbered § 421 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tII"},"text":"Pub. L. 103–382, title II","children":[],"tail":", §§ 212(b)(1), 232, "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3913"},"text":"108 Stat. 3913","children":[],"tail":", 3914.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d908923-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d908924-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d908925-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"h