n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/s232/b/2"},"text":"Pub. L. 103–382, § 232(b)(2)","children":[],"tail":", which directed the substitution in the original of “(b)(1) Notwithstanding” for “(b) Notwithstanding”, could not be executed because the original already reads “(b)(1) Notwithstanding”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/s232/b/3"},"text":"Pub. L. 103–382, § 232(b)(3)","children":[],"tail":", substituted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1341/a"},"text":"section 1341(a) of title 31","children":[],"tail":" for reference to section 3679(d)(2) of the Revised Statutes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561"},"text":"Pub. L. 95–561","children":[],"tail":" struck out “ending prior to "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":",” after “applicable during any fiscal year,” in existing provisions, designated existing provisions as thus amended as par. (1), and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/112"},"text":"Pub. L. 95–112","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1978-10-01"},"text":"October 1, 1978","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/273"},"text":"Pub. L. 94–273","children":[],"tail":" substituted “October” for “July”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/380/s506/a/1/E"},"text":"Pub. L. 93–380, § 506(a)(1)(E)","children":[],"tail":", substituted “1978” for “1973” and inserted “by educational agencies or institutions” and “by such agencies and institutions” after “obligated and expended” and “obligation and expenditure”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/380/s506/a/1/E"},"text":"Pub. L. 93–380, § 506(a)(1)(E)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230"},"text":"Pub. L. 91–230","children":[],"tail":" substituted “applicable program” for “Act referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1221"},"text":"section 1221 of this title","children":[],"tail":"”, inserted “loans,” after “grants,” designated existing provisions as thus amended as subsec. (a), and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d908927-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d908928-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561"},"text":"Pub. L. 95–561","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1978-10-01"},"text":"Oct. 1, 1978","children":[],"tail":", but the provisions of subsec. (b)(2) of this section not to take effect with respect to the use of funds under former "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3101"},"text":"section 3101 of this title","children":[],"tail":" until "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":", except at the option of local educational agencies, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/561/s1530"},"text":"section 1530 of Pub. L. 95–561","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1221e–3"},"text":"section 1221e–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d908929-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/380/tV/s506/b"},"text":"Pub. L. 93–380, title V, § 506(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/565"},"text":"88 Stat. 565","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/380/tV/s506/b"},"text":"“The amendments made by subsection (a) of this section [enacting sections 1226a to 1226d of this title, amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1227"},"text":"section 1227 of this title","children":[],"tail":", and repealing sections 1222 and 1224 of this title] shall become effective on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0d90892a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Indochinese Refugee Children Education Assistance Programs; Applicability of Contingent Extension Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/482/tIII/s327"},"text":"Pub. L. 94–482, title III, § 327","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2220"},"text":"90 Stat. 2220","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/482/tIII/s327"},"text":"“The provisions of section 414 [now 422] of the General Education Provisions Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1226a"},"text":"section 1226a of this title","children":[],"tail":"], relating to the contingent extension of applicable programs, shall not apply to the Indochina Refugee Children Assistance Act of 1976 [former "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1211b"},"text":"section 1211b of this title","children":[],"tail":"], or to any program of financial assistance for educational purposes for Indochinese refugee children.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
