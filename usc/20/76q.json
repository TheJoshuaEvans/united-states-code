{"tag":"section","attrib":{"id":"id0c80c6a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q"},"text":null,"children":[{"tag":"num","attrib":{"value":"76q"},"text":"§ 76q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sole national memorial to the late John F. Kennedy within the city of Washington and environs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The John F. Kennedy Center for the Performing Arts, designated by this subchapter, shall be the sole national memorial to the late John Fitzgerald Kennedy within the city of Washington and its environs.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c80c6a4-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/874/s11"},"text":"Pub. L. 85–874, § 11","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/88/260/s1/6"},"text":"Pub. L. 88–260, § 1(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-01-23"},"text":"Jan. 23, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/5"},"text":"78 Stat. 5","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
