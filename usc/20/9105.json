{"tag":"section","attrib":{"id":"id0e58e191-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105"},"text":null,"children":[{"tag":"num","attrib":{"value":"9105"},"text":"§ 9105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e58e192-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may, in accordance with applicable provisions of title 5, appoint and determine the compensation of such employees as the Director determines to be necessary to carry out the duties of the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e58e193-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and compensation of technical and professional employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e58e194-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Director may appoint without regard to the provisions of title 5 governing the appointment in the competitive service and may compensate without regard to the provisions of chapter 51 or subchapter III of chapter 53 of such title (relating to the classification and General Schedule pay rates), such technical and professional employees as the Director determines to be necessary to carry out the duties of the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e58e195-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number and compensation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e58e196-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The number of employees appointed and compensated under paragraph (1) shall not exceed ⅕ of the number of full-time regular or professional employees of the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e58e197-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate of compensation","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e58e198-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), the rate of basic compensation for the employees appointed and compensated under paragraph (1) may not exceed the rate prescribed for level GS–15 of the General Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e58e199-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may appoint not more than 3 employees under paragraph (1) at a rate of basic compensation that exceeds the rate described in clause (i) but does not exceed the rate of basic pay in effect for positions at level IV of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e58e19a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may accept and utilize the voluntary services of individuals and reimburse the individuals for travel expenses, including per diem in lieu of subsistence, in the same amounts and to the same extent as authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":" for persons employed intermittently in Federal Government service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e58e19b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Experts and consultants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may use experts and consultants, including panels of experts, who may be employed as authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e58e19c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/462/tII/s206"},"text":"Pub. L. 94–462, title II, § 206","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/e/tVII/s702"},"text":"Pub. L. 104–208, div. A, title I, § 101(e) [title VII, § 702]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-233"},"text":"110 Stat. 3009–233","children":[],"tail":", 3009–295; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/128/s2"},"text":"Pub. L. 105–128, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-01"},"text":"Dec. 1, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2548"},"text":"111 Stat. 2548","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/340/tI/s103"},"text":"Pub. L. 111–340, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3596"},"text":"124 Stat. 3596","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e58e19d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e58e19e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"t