{"tag":"section","attrib":{"id":"id0d764a18-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1135a"},"text":"§ 1135a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutional eligibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d764a19-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any academic department, program or unit of an institution of higher education that offers a program of postbaccalaureate study leading to a graduate degree, including a master’s or doctoral degree, in an area of national need (as designated under subsection (b)) may apply for a grant under this subpart. No department, program or unit shall be eligible for a grant unless the program of postbaccalaureate study has been in existence for at least 4 years at the time of application for assistance under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d764a1a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of areas of national need","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After consultation with appropriate Federal and nonprofit agencies and organizations, including the National Science Foundation, the Department of Defense, the Department of Homeland Security, the National Academy of Sciences, and the Bureau of Labor Statistics, the Secretary shall designate areas of national need. In making such designations, the Secretary shall take into consideration—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d764a1b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the interest in the area is compelling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d764a1c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which other Federal programs support postbaccalaureate study in the area concerned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d764a1d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of how the program may achieve the most significant impact with available resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb1e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of current (as of the time of the designation) and future professional workforce needs of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d78bb1f-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s712"},"text":"Pub. L. 89–329, title VII, § 712","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVII/s701"},"text":"Pub. L. 105–244, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib