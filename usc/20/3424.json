{"tag":"section","attrib":{"id":"id0dd8197e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3424"},"text":null,"children":[{"tag":"num","attrib":{"value":"3424"},"text":"§ 3424.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Interagency Committee on Education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dd8197f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3424/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and function","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a Federal Interagency Committee on Education (hereafter referred to in this section as the “Committee”). The Committee shall assist the Secretary in providing a mechanism to assure that the procedures and actions of the Department and other Federal departments and agencies are fully coordinated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dd81980-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3424/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of Federal programs, policies and practices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall study and make recommendations for assuring effective coordination of Federal programs, policies, and administrative practices affecting education, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dd81981-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3424/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent administration and development of policies and practices among Federal agencies in the conduct of related programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd81982-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3424/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full and effective communication among Federal agencies to avoid unnecessary duplication of activities and repetitive collection of data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd81983-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3424/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full and effective cooperation with the Secretary on such studies and analyses as are necessary to carry out the purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd81984-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3424/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination of related programs to assure that recipients of Federal assistance are efficiently and responsively served; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd81985-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3424/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full and effective involvement and participation of students and parents in Federal education programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dd81986-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3424/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall be composed of the Secretary, who shall chair the Committee, and senior policy making officials from those Federal agencies, commissions, and boards that the President may find appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dd81987-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3424/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of additional persons to attend meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office of Management and Budget, the Chairman of the Council of Economic Advisers, the Director of the Office of Science and Technology Policy, and the Executive Director of the Domestic Policy Staff may each designate a staff member to attend meetings of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dd81988-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3424/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal vocational education and training programs study; report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall conduct a study concerning the progress, effectiveness, and accomplishments of Federal vocational education and training programs, and the need for improved coordination between all federally funded vocational education and training programs. The Committee shall report the findings of such study to the Secretary and the Congress within two years of ","children":[{"tag":"date","attrib":{"date":"1979-10-17"},"text":"October 17, 1979","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dd81989-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3424/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required meetings; establishment of subcommittees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall meet at least twice each year. The Secretary may establish subcommittees of the Committee to facilitate coordination in important areas of Federal activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dd8198a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3424/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the head of each agency represented on the Committee under subsection (c) shall furnish necessary assistance to the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dd8198b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tII/s217"},"text":"Pub. L. 96–88, title II, § 217","children":[],"tail":", formerly § 214, "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/676"},"text":"93 Stat. 676","children":[],"tail":"; renumbered § 215, "},{"tag":"ref","attrib":{"href":"/us/pl/101/392/tVI/s602/a/2"},"text":"Pub. L. 101–392, title VI, § 602(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-09-25"},"text":"Sept. 25, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/840"},"text":"104 Stat. 840","children":[],"tail":"; renumbered § 217, "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s372/1"},"text":"Pub. L. 103–382, title III, § 372(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3977"},"text":"108 Stat. 3977","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dd8198c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0dd8198d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0dd8198e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Committees","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory committees established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a committee established by the President or an officer of the Federal Government, such committee is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a committee established by the Congress, its duration is otherwise provided for by law. See "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
