{"tag":"section","attrib":{"id":"id0d2c6fbe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1087a"},"text":"§ 1087a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d2c6fbf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are hereby made available, in accordance with the provisions of this part, such sums as may be necessary (1) to make loans to all eligible students (and the eligible parents of such students) in attendance at participating institutions of higher education selected by the Secretary, to enable such students to pursue their courses of study at such institutions during the period beginning ","children":[{"tag":"date","attrib":{"date":"1994-07-01"},"text":"July 1, 1994","children":[],"tail":"; and (2) for purchasing loans under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087i–1"},"text":"section 1087i–1 of this title","children":[],"tail":". Loans made under this part shall be made by participating institutions, or consortia thereof, that have agreements with the Secretary to originate loans, or by alternative originators designated by the Secretary to make loans for students in attendance at participating institutions (and their parents)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d2c6fc0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d2c6fc1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program established under this part shall be referred to as the “William D. Ford Federal Direct Loan Program”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d2c6fc2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this part, loans made to borrowers under this part that, except as otherwise specified in this part, have the same terms, conditions, and benefits as loans made to borrowers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078"},"text":"section 1078 of this title","children":[],"tail":", shall be known as “Federal Direct Stafford/Ford Loans”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d2c6fc3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum aid","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maximum dollar amount of financial assistance provided under this part to a student shall not exceed the cost of attendance for such student.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d2c6fc4-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s451"},"text":"Pub. L. 89–329, title IV, § 451","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s404"},"text":"Pub. L. 99–498, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1437"},"text":"100 Stat. 1437","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s451"},"text":"Pub. L. 102–325, title IV, § 451","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/569"},"text":"106 Stat. 569","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tIV/s4021"},"text":"Pub. L. 103–66, title IV, § 4021","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/341"},"text":"107 Stat. 341","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s358A"},"text":"Pub. L. 103–382, title III, § 358A","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3968"},"text":"108 Stat. 3968","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/227/s7/a"},"text":"Pub. L. 110–227, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-07"},"text":"May 7, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/746"},"text":"122 Stat. 746","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tVII/s702/a/2"},"text":"Pub. L. 116–260, div. FF, title VII, § 702(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tai