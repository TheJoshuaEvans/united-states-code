{"tag":"section","attrib":{"id":"id0e51b62b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7909"},"text":null,"children":[{"tag":"num","attrib":{"value":"7909"},"text":"§ 7909.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on federally sponsored testing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e51b62c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7909/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of Federal law and except as provided in subsection (b), no funds provided under this chapter to the Secretary or to the recipient of any award may be used to develop, incentivize, pilot test, field test, implement, administer, or distribute any federally sponsored national test in reading, mathematics, or any other subject, unless specifically and explicitly authorized by law, including any assessment or testing materials aligned to the Common Core State Standards developed under the Common Core State Standards Initiative or any other academic standards common to a significant number of States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e51b62d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7909/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to international comparative assessments developed under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9543/a/6"},"text":"section 9543(a)(6) of this title","children":[],"tail":" and administered to only a representative sample of pupils in the United States and in foreign nations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e51b62e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8529"},"text":"Pub. L. 89–10, title VIII, § 8529","children":[],"tail":", formerly title IX, § 9529, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIX/s901"},"text":"Pub. L. 107–110, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1984"},"text":"115 Stat. 1984","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/279/tIV/s404/d/9"},"text":"Pub. L. 107–279, title IV, § 404(d)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1986"},"text":"116 Stat. 1986","children":[],"tail":"; renumbered title VIII, § 8529, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII"},"text":"Pub. L. 114–95, title VIII","children":[],"tail":", §§ 8001(a)(6), 8026, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2088"},"text":"129 Stat. 2088","children":[],"tail":", 2089, 2115.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e51b62f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e51b630-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e51b631-3a70-11f1-a648-bee82ed8a795"},"