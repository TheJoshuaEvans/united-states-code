{"tag":"section","attrib":{"id":"id0c93d931-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s130aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"130aa"},"text":"§ 130aa.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c93d932-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s130aa/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “endowment fund” means a fund, or a tax exempt foundation, established and maintained by Howard University for the purpose of generating income for its support, but which shall not include real estate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c93d933-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s130aa/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “endowment fund corpus” means an amount equal to the grants awarded under this subchapter plus an amount equal to such grants provided by Howard University;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c93d934-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s130aa/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “endowment fund income” means an amount equal to the total value of the endowment fund established under this subchapter minus the endowment fund corpus;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c93d935-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s130aa/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c93d936-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s130aa/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “University” means the Howard University established by the Act of ","children":[{"tag":"date","attrib":{"date":"1867-03-02"},"text":"March 2, 1867","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c93d937-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/480/tII/s202"},"text":"Pub. L. 98–480, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-17"},"text":"Oct. 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2245"},"text":"98 Stat. 2245","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c93d938-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c93d939-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0c93d93a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1867-03-02"},"text":"March 2, 1867","children":[],"tail":", referred to in par. (5), is "},{"tag":"ref","attrib":{"href":"/us/act/1867-03-02/ch162"},"text":"act Mar. 2, 1867, ch. 162","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/14/438"},"text":"14 Stat. 438","children":[],"tail":". Section 8 of this Act is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s123"},"text":"section 123 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0c93d93b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0c93d93c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/480/tII/s209"},"text":"Pub. L. 98–480, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-17"},"text":"Oct. 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2247"},"text":"98 Stat. 2247","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/480/tII/s209"},"text":"“This title [see Short Title note below] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1984-10-01"},"text":"October 1, 1984","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id0c93d93d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/480/tII/s201"},"text":"Pub. L. 98–480, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-17"},"text":"Oct. 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2245"},"text":"98 Stat. 2245","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/480/tII/s201"},"text":"“This title [enacting this subchapter, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s123"},"text":"section 123 of this title","children":[],"tail":", and enacting provisions set out as a note above] may be cited as the ‘Howard University Endowment Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
