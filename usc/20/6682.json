{"tag":"section","attrib":{"id":"id0e1fa93e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6682"},"text":null,"children":[{"tag":"num","attrib":{"value":"6682"},"text":"§ 6682.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subpart:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1fa93f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6682/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classified school employee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “classified school employee” means an employee of a State or of any political subdivision of a State, or an employee of a nonprofit entity, who works in any grade from prekindergarten through high school in any of the following occupational specialties:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1fa940-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6682/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paraprofessional, including paraeducator services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1fa941-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6682/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Clerical and administrative services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1fa942-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6682/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1fa943-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6682/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Food and nutrition services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1fa944-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6682/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Custodial and maintenance services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1fa945-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6682/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Security services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1fa946-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6682/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Health and student services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1fa947-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6682/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Technical services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1fa948-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6682/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Skilled trades.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1fa949-3a70-11