{"tag":"section","attrib":{"id":"id0e2b9049-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221g"},"text":null,"children":[{"tag":"num","attrib":{"value":"7221g"},"text":"§ 7221g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records transfer","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"State educational agencies and local educational agencies, as quickly as possible and to the extent practicable, shall ensure that a student’s records and, if applicable, a student’s individualized education program as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1401"},"text":"section 1401 of this title","children":[],"tail":", are transferred to a charter school upon the transfer of the student to the charter school, and to another public school upon the transfer of the student from a charter school to another public school, in accordance with applicable State law."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e2b904a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4308"},"text":"Pub. L. 89–10, title IV, § 4308","children":[],"tail":", formerly title V, § 5208, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1798"},"text":"115 Stat. 1798","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tIII/s305/g/2"},"text":"Pub. L. 108–446, title III, § 305(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2805"},"text":"118 Stat. 2805","children":[],"tail":"; renumbered title IV, § 4308, and amended "},{"tag":"ref","attrib":{"