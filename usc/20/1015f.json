{"tag":"section","attrib":{"id":"id0cc374b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1015f"},"text":"§ 1015f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State commitment to affordable college education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cc374b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of effort required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State shall provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cc374b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for public institutions of higher education in such State for any academic year beginning on or after ","children":[{"tag":"date","attrib":{"date":"2008-07-01"},"text":"July 1, 2008","children":[],"tail":", an amount which is equal to or greater than the average amount provided for non-capital and non-direct research and development expenses or costs by such State to such institutions of higher education during the five most recent preceding academic years for which satisfactory data are available; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc374b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for private institutions of higher education in such State for any academic year beginning on or after ","children":[{"tag":"date","attrib":{"date":"2008-07-01"},"text":"July 1, 2008","children":[],"tail":", an amount which is equal to or greater than the average amount provided for student financial aid for paying costs associated with postsecondary education by such State to such institutions during the five most recent preceding academic years for which satisfactory data are available."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc374b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments for biennial appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall take into consideration any adjustments to the calculations under subsection (a) that may be required to accurately reflect funding levels for postsecondary education in States with biennial appropriation cycles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc374b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall waive the requirements of subsection (a), if the Secretary determines that such a waiver would be equitable due to exceptional or uncontrollable circumstances, such as a natural disaster or a precipitous and unforseen ","children":[{"tag":"ref","attrib":{"idref":"fn002030"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002030"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “unforeseen”."}],"tail":" decline in the financial resources of a State or State educational agency, as appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc374b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violation of maintenance of effort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary shall withhold from any State that violates subsection (a) and does not receive a waiver pursuant to subsection (c) any amount that would otherwise be available to the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1141"},"text":"section 1141 of this title","children":[],"tail":" until such State has made significant efforts to correct such violation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cc374b9-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s137"},"text":"Pub. L. 89–329, title I, § 137","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tI/s116"},"text":"Pub. L. 110–315, title I, § 116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3113"},"text":"122 Stat. 3113","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cc374ba-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cc374bb-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cc374bc-3a70-11f1-a648-bee82ed8a795"},"tex