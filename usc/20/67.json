{"tag":"section","attrib":{"id":"id0c772969-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s67"},"text":null,"children":[{"tag":"num","attrib":{"value":"67"},"text":"§ 67.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of repeal","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Congress may alter, amend, add to, or repeal any of the provisions of sections 41 to 46, 48, 50, 51 to 53, and 54 to 57, of this title; but no contract or individual right made or acquired under such provisions shall be thereby divested or impaired.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c77296a-3a70-11f1-a648-bee82ed8a795"},"text":"(R.S. § 5594.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c77296b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c77296c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0c77296d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5594 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1846-08-10/ch178/s11"},"text":"act Aug. 10, 1846, ch. 178, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/9/106"},"text":"9 Stat. 106","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
