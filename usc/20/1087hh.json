{"tag":"section","attrib":{"id":"id0d3ac808-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087hh"},"text":null,"children":[{"tag":"num","attrib":{"value":"1087hh"},"text":"§ 1087hh.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority of Secretary","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In carrying out the provisions of this part, the Secretary is authorized—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d3ac809-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087hh/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to consent to modification, with respect to rate of interest, time of payment of any installment of principal and interest or any portion thereof, or any other provision of any note evidencing a loan which has been made under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d3ac80a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087hh/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enforce, pay, compromise, waive, or release any right, title, claim, lien, or demand, however acquired, including any equity or any right of redemption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d3ac80b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087hh/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct litigation in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1082/a/2"},"text":"section 1082(a)(2) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d3ac80c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087hh/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enter into a contract or other arrangement with State or nonprofit agencies and, on a competitive basis, with collection agencies for servicing and collection of loans under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d3ac80d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s468"},"text":"Pub. L. 89–329, title IV, § 468","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s405/a"},"text":"Pub. L. 99–498, title IV, § 405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1454"},"text":"100 Stat. 1454","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d3ac80e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d3ac80f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d3ac810-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1087hh, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s468"},"text":"Pub. L. 89–329, title IV, § 468","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tIV/s442/a"},"text":"Pub. L. 96–374, title IV, § 442(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tai