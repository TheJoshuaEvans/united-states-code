{"tag":"section","attrib":{"id":"id0e160c5f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6471"},"text":null,"children":[{"tag":"num","attrib":{"value":"6471"},"text":"§ 6471.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program evaluations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e160c60-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6471/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State agency or local educational agency that conducts a program under subpart 1 or 2 of this part shall evaluate the program, disaggregating data on participation by gender, race, ethnicity, and age while protecting individual student privacy,,","children":[{"tag":"ref","attrib":{"idref":"fn002213"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002213"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" not less than once every 3 years, to determine the program’s impact on the ability of participants—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e160c61-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6471/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain and improve educational achievement and to graduate from high school in the number of years established by the State under either the four-year adjusted cohort graduation rate or the extended-year adjusted cohort graduation rate, if applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e160c62-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6471/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accrue school credits that meet State requirements for grade promotion and high school graduation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e160c63-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6471/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make the transition to a regular program or other education program operated by a local educational agency or school operated or funded by the Bureau of Indian Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e160c64-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6471/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to complete high school (or high school equivalency requirements) and obtain employment after leaving the correctional facility or institution for neglected or delinquent children and youth; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e160c65-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6471/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, to participate in postsecondary education and job training programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e160c66-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6471/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The disaggregation required under subsection (a) shall not be required in a case in which the number of students in a category is insufficient to yield statistically reliable information or the results would reveal personally identifiable information about an individual student.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e160c67-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6471/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation measures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting each evaluation under subsection (a), a State agency or local educational agency shall use multiple and appropriate measures of student progress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e160c68-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6471/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation results","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State agency and local educational agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e160c69-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6471/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit evaluation results to the State educational agency and the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e160c6a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6471/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the results of evaluations under this section to plan and improve subsequent programs for participating children and youth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e160c6b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1431"},"text":"Pub. L. 89–10, title I, § 1431","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1591"},"text":"115 Stat. 1591","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tI/s1401/14"},"text":"Pub. L. 114–95, title I, § 1401(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1905"},"text":"129 Stat. 1905","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e160c6c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e160c6d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e160c6e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6471, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1431"},"text":"Pub. L. 89–10, title I, § 1431","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3600"},"text":"108 Stat. 3600","children":[],"tail":", related to program evaluations, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s1431"},"text":"section 1431 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s2831"},"text":"section 2831 of this title","children":[],"tail":", prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e160c6f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1401/14/A"},"text":"Pub. L. 114–95, § 1401(14)(A)","children":[],"tail":", (B), inserted “while protecting individual student privacy,” after “age” in introductory provisions and substituted “high school” for “secondary school” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1401/14/C"},"text":"Pub. L. 114–95, § 1401(14)(C)","children":[],"tail":", inserted “and to graduate from high school in the number of years established by the State under either the four-year adjusted cohort graduation rate or the extended-year adjusted cohort graduation rate, if applicable” after “educational achievement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1401/14/D"},"text":"Pub. L. 114–95, § 1401(14)(D)","children":[],"tail":", inserted “or school operated or funded by the Bureau of Indian Education” after “local educational agency”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e160c70-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e160c71-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
