{"tag":"section","attrib":{"id":"id0e160c2c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6454"},"text":null,"children":[{"tag":"num","attrib":{"value":"6454"},"text":"§ 6454.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e160c2d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6454/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds provided to local educational agencies under this subpart may be used, as appropriate, for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e160c2e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6454/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs that serve children and youth returning to local schools from correctional facilities, to assist in the transition of such children and youth to the school environment and help them remain in school in order to complete their education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e160c2f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6454/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dropout prevention programs which serve at-risk children and youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e160c30-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6454/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coordination of health and social services for such individuals if there is a likelihood that the provision of such services, including day care, drug and alcohol counseling, and mental health services, will improve the likelihood such individuals will complete their education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e160c31-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6454/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special programs to meet the unique academic needs of participating children and youth, including career and technical education, special education, career counseling, curriculum-based youth entrepreneurship education, and assistance in securing student loans or grants for postsecondary education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e160c32-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6454/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs providing mentoring and peer mediation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e160c33-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6454/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs for at-risk Indian children and youth, including such children and youth in correctional facilities in the area served by the local educational agency that are operated by the Secretary of the Interior or Indian tribes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e160c34-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6454/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay for success initiatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e160c35-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6454/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts and grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local educational agency may use a subgrant received under this subpart to carry out the activities described under paragraphs (1) through (7) of subsection (a) directly or through subgrants, contracts, or cooperative agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e160c36-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1424"},"text":"Pub. L. 89–10, title I, § 1424","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1589"},"text":"115 Stat. 1589","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tI/s1401/11"},"text":"Pub. L. 114–95, title I, § 1401(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1904"},"text":"129 Stat. 1904","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e160c37-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e160c38-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e160c39-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6454, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1424"},"text":"Pub. L. 89–10, title I, § 1424","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3599"},"text":"108 Stat. 3599","children":[],"tail":", related to uses of funds, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e160c3a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1401/11/A"},"text":"Pub. L. 114–95, § 1401(11)(A)","children":[],"tail":", designated existing provisions as subsec. (a) and inserted subsec. heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1401/11/B"},"text":"Pub. L. 114–95, § 1401(11)(B)","children":[],"tail":", struck out “, including pregnant and parenting teens, children and youth who have come in contact with the juvenile justice system, children and youth at least 1 year behind their expected grade level, migrant youth, immigrant youth, students with limited English proficiency, and gang members” after “at-risk children and youth”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1401/11/C/i"},"text":"Pub. L. 114–95, § 1401(11)(C)(i)","children":[],"tail":", substituted “career” for “vocational”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1401/11/C/ii"},"text":"Pub. L. 114–95, § 1401(11)(C)(ii)","children":[],"tail":"–(E), added pars. (6) and (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1401/11/F"},"text":"Pub. L. 114–95, § 1401(11)(F)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e160c3b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e160c3c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
