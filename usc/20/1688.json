{"tag":"section","attrib":{"id":"id0db46401-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1688"},"text":null,"children":[{"tag":"num","attrib":{"value":"1688"},"text":"§ 1688.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Neutrality with respect to abortion","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to require or prohibit any person, or public or private entity, to provide or pay for any benefit or service, including the use of facilities, related to an abortion. Nothing in this section shall be construed to permit a penalty to be imposed on any person or individual because such person or individual is seeking or has received any benefit or service related to a legal abortion.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0db46402-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/318/tIX/s909"},"text":"Pub. L. 92–318, title IX, § 909","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/259/s3/b"},"text":"Pub. L. 100–259, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-03-22"},"text":"Mar. 22, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/29"},"text":"102 Stat. 29","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0db46403-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0db46404-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0db46405-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title IX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/318"},"text":"Pub. L. 92–318","children":[],"tail":" which enacted this chapter and amended sections 203 and 213 of Title 29, Labor, and sections 2000c, 2000c–6, 2000c–9, and 2000h–2 of Title 42, The Public Health and Welfare. For complete classification of title IX to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1681"},"text":"section 1681 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0db46406-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0db46407-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section not to be construed to extend application of Education Amendments of 1972, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/318"},"text":"Pub. L. 92–318","children":[],"tail":", to ultimate beneficiaries of Federal financial assistance excluded from coverage before "},{"tag":"date","attrib":{"date":"1988-03-22"},"text":"Mar. 22, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/259/s7"},"text":"section 7 of Pub. L. 100–259","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1687"},"text":"section 1687 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0db46408-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Abortion Neutrality","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/259/s8"},"text":"Pub. L. 100–259, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-03-22"},"text":"Mar. 22, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/31"},"text":"102 Stat. 31","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/259/s8"},"text":"“No provision of this Act or any amendment made by this Act [see Short Title of 1988 Amendment note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1681"},"text":"section 1681 of this title","children":[],"tail":"] shall be construed to force or require any individual or hospital or any other institution, program, or activity receiving Federal Funds [sic] to perform or pay for an abortion.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
