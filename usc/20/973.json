{"tag":"section","attrib":{"id":"id0cb2d339-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s973"},"text":null,"children":[{"tag":"num","attrib":{"value":"973"},"text":"§ 973.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for indemnity agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cb2d33a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s973/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person, nonprofit agency, institution, or government desiring to make an indemnity agreement for eligible items under this chapter shall make application therefor in accordance with such procedures, in such form, and in such manner as the Council shall, by regulation, prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cb2d33b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s973/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cb2d33c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s973/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe each item to be covered by the agreement (including an estimated value of such item);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cb2d33d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s973/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" show evidence that the items are eligible under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s972/a"},"text":"section 972(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cb2d33e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s973/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth policies, procedures, techniques, and methods with respect to preparation for, and conduct of, exhibition of the items, and any transportation related to such items.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cb2d33f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s973/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon receipt of an application under this section, the Council shall, if such application conforms with the requirements of this chapter, approve the application and make an indemnity agreement with the applicant. Upon such approval, the agreement shall constitute a contract between the Council and the applicant pledging the full faith and credit of the United States to pay any amount for which the Council becomes liable under such agreement. The Council, for such purpose, is hereby authorized to pledge the full faith and credit of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cb2d340-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/158/s4"},"text":"Pub. L. 94–158, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-20"},"text":"Dec. 20, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/845"},"text":"89 Stat. 845","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
