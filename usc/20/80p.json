{"tag":"section","attrib":{"id":"id0c8581cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80p"},"text":null,"children":[{"tag":"num","attrib":{"value":"80p"},"text":"§ 80p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c8581d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal funds for Museum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The faith of the United States is pledged that upon the completion of the acquisition in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s80k"},"text":"section 80k of this title","children":[],"tail":", the United States will provide such funds as may be necessary for the upkeep of the Museum and the administrative expenses and costs of operation thereof, including the protection and care of works of art acquired by the Board, so the Museum shall at all times be properly maintained and works of art contained therein shall be exhibited regularly to the general public free of charge."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c8581d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated for the first fiscal year under this subchapter, the sum of $1,000,000 and such amounts as may be necessary for the succeeding fiscal years in order to carry out the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c8581d2-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/414/s6"},"text":"Pub. L. 95–414, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-05"},"text":"Oct. 5, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/912"},"text":"92 Stat. 912","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c8581d3-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0c8581d4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0c8581d5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective, except for the provisions in subsec. (b) of this section, on the date of transfer of a deed or other instrument under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s80k"},"text":"section 80k of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/414/s7"},"text":"section 7 of Pub. L. 95–414","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s80k"},"text":"section 80k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
