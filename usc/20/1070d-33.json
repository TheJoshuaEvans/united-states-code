{"tag":"section","attrib":{"id":"id0cf3378b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–33"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070d–33"},"text":"§ 1070d–33.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarships authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cf3378c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–33/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized, in accordance with the provisions of this subpart, to make grants to States to enable the States to award scholarships to individuals who have demonstrated outstanding academic achievement and who show promise of continued academic achievement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cf3378d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–33/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of award","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Scholarships under this section shall be awarded for a period of not less than 1 or more than 4 years during the first 4 years of study at any institution of higher education eligible to participate in any programs assisted under this subchapter. The State educational agency administering the program in a State shall have discretion to determine the period of the award (within the limits specified in the preceding sentence), except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cf3378e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–33/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the amount appropriated for this subpart for any fiscal year exceeds the amount appropriated for this subpart for fiscal year 1993, the Secretary shall identify to each State educational agency the number of scholarships available to that State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070d–34/b"},"text":"section 1070d–34(b) of this title","children":[],"tail":" that are attributable to such excess; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf3378f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–33/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State educational agency shall award not less than that number of scholarships for a period of 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cf33790-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–33/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use at any institution permitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A student awarded a scholarship under this subpart may attend any institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cf33791-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–33/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Byrd Scholars","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Individuals awarded scholarships under this subpart shall be known as “Byrd Scholars”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cf33792-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s419C"},"text":"Pub. L. 89–329, title IV, § 419C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s401/a"},"text":"Pub. L. 99–498, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1344"},"text":"100 Stat. 1344","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s406/b"},"text":"Pub. L. 102–325, title IV, § 406(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/508"},"text":"106 Stat. 508","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/b/28"},"text":"Pub. L. 103–208, § 2(b)(28)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2459"},"text":"107 Stat. 2459","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tIV/s401/a/7"},"text":"Pub. L. 111–39, title IV, § 401(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1939"},"text":"123 Stat. 1939","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cf33793-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cf33794-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cf33795-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1070d–33, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s419C"},"text":"Pub. L. 89–329, title IV, § 419C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/558/tVIII/s801/a"},"text":"Pub. L. 98–558, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2900"},"text":"98 Stat. 2900","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXVI/s1627/b"},"text":"Pub. L. 99–145, title XVI, § 1627(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/779"},"text":"99 Stat. 779","children":[],"tail":", authorized the award of scholarships under Robert C. Byrd Honors Scholarship Program, prior to the general revision of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cf33796-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" inserted “and” after semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208"},"text":"Pub. L. 103–208","children":[],"tail":" substituted “for a period of not less than 1 or more than 4 years during the first 4 years of study” for “for a period of not more than 4 years for the first 4 years of study” and inserted at end “The State educational agency administering the program in a State shall have discretion to determine the period of the award (within the limits specified in the preceding sentence), except that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) if the amount appropriated for this subpart for any fiscal year exceeds the amount appropriated for this subpart for fiscal year 1993, the Secretary shall identify to each State educational agency the number of scholarships available to that State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070d–34/b"},"text":"section 1070d–34(b) of this title","children":[],"tail":" that are attributable to such excess;"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the State educational agency shall award not less than that number of scholarships for a period of 4 years.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “Scholarships under this section shall be awarded for a period of one academic year for the first year of study at an institution of higher education.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cf33797-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cf33798-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" effective as if enacted on the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/s3"},"text":"section 3 of Pub. L. 111–39","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cf33799-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208"},"text":"Pub. L. 103–208","children":[],"tail":" effective on and after "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s5/b/2"},"text":"section 5(b)(2) of Pub. L. 103–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1051"},"text":"section 1051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
