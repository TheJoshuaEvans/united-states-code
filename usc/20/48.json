{"tag":"section","attrib":{"id":"id0c74dff6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s48"},"text":null,"children":[{"tag":"num","attrib":{"value":"48"},"text":"§ 48.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Salary and removal of Secretary and assistants","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary and his assistants shall, respectively, receive for their services such sum as may be allowed by the Board of Regents; and shall be removable by the Board of Regents whenever, in their judgment, the interests of the institution require such removal.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c74dff7-3a70-11f1-a648-bee82ed8a795"},"text":"(R.S. § 5584.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c74dff8-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c74dff9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0c74dffa-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5584 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1846-08-10/ch178/s7"},"text":"act Aug. 10, 1846, ch. 178, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/9/105"},"text":"9 Stat. 105","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions which related to semi-annual payments on the first day of January and July have been omitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
