{"tag":"section","attrib":{"id":"id0e542687-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7920"},"text":null,"children":[{"tag":"num","attrib":{"value":"7920"},"text":"§ 7920.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with the Governor","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e542688-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7920/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State educational agency shall consult in a timely and meaningful manner with the Governor, or appropriate officials from the Governor’s office, in the development of State plans under subchapters I and II and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7842"},"text":"section 7842 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e542689-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7920/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The consultation described in subsection (a) shall include meetings of officials from the State educational agency and the Governor’s office and shall occur—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e54268a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7920/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the development of such plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e54268b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7920/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to submission of the plan to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e54268c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7920/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint signature authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Governor shall have 30 days prior to the State educational agency submitting the State plan under subchapter I or II or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7842"},"text":"section 7842 of this title","children":[],"tail":" to the Secretary to sign such plan. If the Governor has not signed the plan within 30 days of delivery by the State educational agency to the Governor, the State educational agency shall submit the plan to the Secretary without such signature."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e54268d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8540"},"text":"Pub. L. 89–10, title VIII, § 8540","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII/s8032"},"text":"Pub. L. 114–95, title VIII, § 8032","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2118"},"text":"129 Stat. 2118","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e54268e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e54268f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e542690-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
