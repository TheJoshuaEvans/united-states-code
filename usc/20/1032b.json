{"tag":"section","attrib":{"id":"id0ccf5b6d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1032b"},"text":"§ 1032b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application requirements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant or enter into a contract or cooperative agreement under this subpart, an eligible consortium shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require. Such application shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ccf5b6e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A description of the project to be carried out with the grant, including how the project will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ccf5b6f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a long-term partnership focused on effective teaching with modern digital tools and content that substantially connects preservice preparation of teacher candidates with high-need schools; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ccf5b70-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transform the way departments, schools, and colleges of education teach classroom technology integration, including the principles of universal design, to teacher candidates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccf5b71-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A demonstration of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ccf5b72-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commitment, including the financial commitment, of each of the members of the consortium for the proposed project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ccf5b73-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the support of the leadership of each organization that is a member of the consortium for the proposed project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccf5b74-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of how each member of the consortium will participate in the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccf5b75-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of how the State educational agency or local educational agency will incorporate the project into the agency’s technology plan, if such a plan already exists.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccf5b76-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of how the project will be continued after Federal funds are no longer available under this subpart for the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccf5b77-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A description of how the project will incorporate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ccf5b78-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State teacher technology standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ccf5b79-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State student technology standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccf5b7a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan for the evaluation of the project, which shall include benchmarks to monitor progress toward specific project objectives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ccf5b7b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tII/s233"},"text":"Pub. L. 89–329, title II, § 233","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tII/s201/3"},"text":"Pub. L. 110–315, title II, § 201(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3157"},"text":"122 Stat. 3157","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ccf5b7c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ccf5b7d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0ccf5b7e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s233"},"text":"section 233 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1043"},"text":"section 1043 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/96/374"},"text":"Pub. L. 96–374","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
