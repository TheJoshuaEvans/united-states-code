{"tag":"section","attrib":{"id":"id0e4f4588-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7883"},"text":null,"children":[{"tag":"num","attrib":{"value":"7883"},"text":"§ 7883.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complaint process for participation of private school children","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e4f4589-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7883/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for complaints","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and implement written procedures for receiving, investigating, and resolving complaints from parents, teachers, or other individuals and organizations concerning violations of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7881"},"text":"section 7881 of this title","children":[],"tail":" by a State educational agency, local educational agency, educational service agency, consortium of those agencies, or entity. The individual or organization shall submit the complaint to the State educational agency for a written resolution by the State educational agency within 45 days."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4f458a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7883/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The resolution may be appealed by an interested party to the Secretary not later than 30 days after the State educational agency resolves the complaint or fails to resolve the complaint within the 45-day time limit. The appeal shall be accompanied by a copy of the State educational agency’s resolution, and, if there is one, a complete statement of the reasons supporting the appeal. The Secretary shall investigate and resolve the appeal not later than 90 days after receipt of the appeal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e4f458b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8503"},"text":"Pub. L. 89–10, title VIII, § 8503","children":[],"tail":", formerly title IX, § 9503, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIX/s901"},"text":"Pub. L. 107–110, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1977"},"text":"115 Stat. 1977","children":[],"tail":"; renumbered title VIII, § 8503, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII"},"text":"Pub. L. 114–95, title VIII","children":[],"tail":", §§ 8001(a)(5), 8017, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2088"},"text":"129 Stat. 2088","children":[],"tail":", 2089, 2111.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e4f458c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e4f458d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e4f458e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8017"},"text":"Pub. L. 114–95, § 8017","children":[],"tail":", added subsecs. (a) and (b) and struck out former subsecs. (a) and (b) which related to procedures for complaints and appeals to Secretary, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e4f458f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e4f4590-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
