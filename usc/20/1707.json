{"tag":"section","attrib":{"id":"id0db4646a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1707"},"text":null,"children":[{"tag":"num","attrib":{"value":"1707"},"text":"§ 1707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Population changes without effect, per se, on school population changes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When a court of competent jurisdiction determines that a school system is desegregated, or that it meets the constitutional requirements, or that it is a unitary system, or that it has no vestiges of a dual system, and thereafter residential shifts in population occur which result in school population changes in any school within such a desegregated school system, such school population changes so occurring shall not, per se, constitute a cause for civil action for a new plan of desegregation or for modification of the court approved plan.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0db4646b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/380/tII/s208"},"text":"Pub. L. 93–380, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/516"},"text":"88 Stat. 516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0db4646c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0db4646d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0db4646e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on and after sixtieth day after ","children":[{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/380/s2/c"},"text":"section 2(c) of Pub. L. 93–380","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1221–1"},"text":"section 1221–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
