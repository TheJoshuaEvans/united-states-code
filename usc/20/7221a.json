{"tag":"section","attrib":{"id":"id0e291eee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221a"},"text":null,"children":[{"tag":"num","attrib":{"value":"7221a"},"text":"§ 7221a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e291eef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may carry out a charter school program that supports charter schools that serve early childhood, elementary school, or secondary school students by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e291ef0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the startup of new charter schools, the replication of high-quality charter schools, and the expansion of high-quality charter schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e291ef1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting charter schools in accessing credit to acquire and renovate facilities for school use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e291ef2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" carrying out national activities to support—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e291ef3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e291ef4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dissemination of best practices of charter schools for all schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e291ef5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221a/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the evaluation of the impact of the charter school program under this part on schools participating in such program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e291ef6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221a/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stronger charter school authorizing practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e291ef7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding allotment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amount made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7221j"},"text":"section 7221j of this title","children":[],"tail":" for a fiscal year, the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e291ef8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reserve 12.5 percent to support charter school facilities assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7221c"},"text":"section 7221c of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e291ef9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reserve 22.5 percent to carry out national activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7221d"},"text":"section 7221d of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e291efa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the remaining amount after the reservations under paragraphs (1) and (2) to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7221b"},"text":"section 7221b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e291efb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior grants and subgrants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The recipient of a grant or subgrant under part B of title V (as such part was in effect on the day before ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"December 10, 2015","children":[],"tail":") shall continue to receive funds in accordance with the terms and conditions of such grant or subgrant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e291efc-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4302"},"text":"Pub. L. 89–10, title IV, § 4302","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4301/1"},"text":"Pub. L. 114–95, title IV, § 4301(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1994"},"text":"129 Stat. 1994","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e291efd-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e291efe-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e291eff-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Part B of title V (as such part was in effect on the day before ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"December 10, 2015","children":[],"tail":"), referred to in subsec. (c), means part B of title V of "},{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":", which was classified generally to part B (§ 7221 et seq.) of subchapter V of this chapter prior to being amended by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV"},"text":"Pub. L. 114–95, title IV","children":[],"tail":", §§ 4001(b)(1)(B), (2), 4301, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1967"},"text":"129 Stat. 1967","children":[],"tail":", 1993, repealed subparts 2 (§ 7223 et seq.) and 3 (§ 7225 et seq.) of part B of subchapter V, redesignated the remainder of part B as this part, struck out the subpart 1 designation and heading, repealed and amended various sections of this part, and added several new sections. For complete classification of "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e291f00-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7221a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4302"},"text":"Pub. L. 89–10, title IV, § 4302","children":[],"tail":", formerly title V, § 5202, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1788"},"text":"115 Stat. 1788","children":[],"tail":"; renumbered title IV, § 4302, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4001/b/2/A"},"text":"Pub. L. 114–95, title IV, § 4001(b)(2)(A)","children":[],"tail":", (B), (D)(iii), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1967"},"text":"129 Stat. 1967","children":[],"tail":", related to authorization of grant program, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"Pub. L. 114–95, § 5","children":[],"tail":", title IV, § 4301(1), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1806"},"text":"129 Stat. 1806","children":[],"tail":", 1993, effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s4302"},"text":"section 4302 of Pub. L. 89–10","children":[],"tail":" was renumbered section 8572, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7972"},"text":"section 7972 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e291f01-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e291f02-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"