{"tag":"section","attrib":{"id":"id0e32bc85-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a"},"text":null,"children":[{"tag":"num","attrib":{"value":"7345a"},"text":"§ 7345a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e32bc86-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to award grants to eligible local educational agencies to enable the local educational agencies to carry out activities authorized under any of the following provisions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e32bc87-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part A of subchapter I.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e32bc88-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part A of subchapter II.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e32bc89-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subchapter III.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e32bc8a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part A or B of subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e32bc8b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e32bc8c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e32bc8d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraphs (3) and (4), the Secretary shall award a grant under subsection (a) to a local educational agency eligible under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7345/b"},"text":"section 7345(b) of this title","children":[],"tail":" for a fiscal year in an amount equal to the initial amount determined under paragraph (2) for the fiscal year minus the total amount received by the agency under the provisions of law described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7345/c"},"text":"section 7345(c) of this title","children":[],"tail":" for the preceding fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e32bc8e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For a local educational agency that is eligible under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7345/b/1/C"},"text":"section 7345(b)(1)(C) of this title","children":[],"tail":" and is a member of an educational service agency, the Secretary may determine the award amount by subtracting from the initial amount determined under paragraph (2), an amount that is equal to that local educational agency’s per-pupil share of the total amount received by the educational service agency under the provisions described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7345/c"},"text":"section 7345(c) of this title","children":[],"tail":", as long as a determination under this subparagraph would not disproportionately affect any State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e32bc8f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of initial amount","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e32bc90-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The initial amount referred to in paragraph (1) is equal to $100 multiplied by the total number of students in excess of 50 students, in average daily attendance at the schools served by the local educational agency, plus $20,000, except that the initial amount may not exceed $60,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e32bc91-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any fiscal year for which the amount made available to carry out this part is $265,000,000 or more, subparagraph (A) shall be applied—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e32bc92-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “$25,000” for “$20,000”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e32bc93-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “$80,000” for “$60,000”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e32bc94-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ratable adjustment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e32bc95-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the amount made available to carry out this section for any fiscal year is not sufficient to pay in full the amounts that local educational agencies are eligible to receive under paragraph (1) for such year, the Secretary shall ratably reduce such amounts for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e32bc96-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If additional funds become available for making payments under paragraph (1) for such fiscal year, payments that were reduced under subparagraph (A) shall be increased on the same basis as such payments were reduced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e32bc97-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hold harmless","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For a local educational agency that is not eligible under this subpart due to amendments made by the Every Student Succeeds Act to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7345/b/1/A/ii"},"text":"section 7345(b)(1)(A)(ii) of this title","children":[],"tail":" but met the eligibility requirements under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7345/b"},"text":"section 7345(b) of this title","children":[],"tail":" as such section was in effect on the day before "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"December 10, 2015","children":[],"tail":", the agency shall receive—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e32bc98-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2017, 75 percent of the amount such agency received for fiscal year 2015;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e32bc99-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2018, 50 percent of the amount such agency received for fiscal year 2015; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e32bc9a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2019, 25 percent of the amount such agency received for fiscal year 2015.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e32bc9b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7345a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall disburse the funds awarded to a local educational agency under this section for a fiscal year not later than July 1 of that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e32bc9c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5212"},"text":"Pub. L. 89–10, title V, § 5212","children":[],"tail":", formerly title VI, § 6212, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVI/s601"},"text":"Pub. L. 107–110, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1892"},"text":"115 Stat. 1892","children":[],"tail":"; renumbered title V, § 5212, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tV"},"text":"Pub. L. 114–95, title V","children":[],"tail":", §§ 5001(a)(3), 5003(2), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2039"},"text":"129 Stat. 2039","children":[],"tail":", 2040, 2042.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e32bc9d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e32bc9e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e32bc9f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendments made by the Every Student Succeeds Act to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7345/b/1/A/ii"},"text":"section 7345(b)(1)(A)(ii) of this title","children":[],"tail":", referred to in subsec. (b)(4), mean the amendments made to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7345/b/1/A/ii"},"text":"section 7345(b)(1)(A)(ii) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tV/s5003/1/B/i"},"text":"Pub. L. 114–95, title V, § 5003(1)(B)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2041"},"text":"129 Stat. 2041","children":[],"tail":". See 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7345"},"text":"section 7345 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7345/b"},"text":"Section 7345(b) of this title","children":[],"tail":" as such section was in effect on the day before "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"December 10, 2015","children":[],"tail":", referred to in subsec. (b)(4), means "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7345/b"},"text":"section 7345(b) of this title","children":[],"tail":" prior to amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tV"},"text":"Pub. L. 114–95, title V","children":[],"tail":", §§ 5001(a)(3), 5003(1)(B), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2039-2041"},"text":"129 Stat. 2039–2041","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e32bca0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5003/2/A"},"text":"Pub. L. 114–95, § 5003(2)(A)","children":[],"tail":", added pars. (1) to (4) and struck out former pars. (1) to (5) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Part A of subchapter I of this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Part A or D of subchapter II of this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) Subchapter III of this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) Part A or B of subchapter IV of this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) Part A of subchapter V of this chapter.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5003/2/B/i"},"text":"Pub. L. 114–95, § 5003(2)(B)(i)","children":[],"tail":", added par. (1) and struck out former par. (1). Prior to amendment, text read as follows: “Except as provided in paragraph (3), the Secretary shall award a grant under subsection (a) of this section to a local educational agency eligible under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7345/b"},"text":"section 7345(b) of this title","children":[],"tail":" for a fiscal year in an amount equal to the initial amount determined under paragraph (2) for the fiscal year minus the total amount received by the agency under the provisions of law described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7345/c"},"text":"section 7345(c) of this title","children":[],"tail":" for the preceding fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5003/2/B/ii"},"text":"Pub. L. 114–95, § 5003(2)(B)(ii)","children":[],"tail":", added par. (2) and struck out former par. (2). Prior to amendment, text read as follows: “The initial amount referred to in paragraph (1) is equal to $100 multiplied by the total number of students in excess of 50 students, in average daily attendance at the schools served by the local educational agency, plus $20,000, except that the initial amount may not exceed $60,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5003/2/B/iii"},"text":"Pub. L. 114–95, § 5003(2)(B)(iii)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5003/2/C"},"text":"Pub. L. 114–95, § 5003(2)(C)","children":[],"tail":", struck out subsec. (d). Text read as follows: “A local educational agency that is eligible to receive a grant under this subpart for a fiscal year is not eligible to receive funds for such fiscal year under subpart 2 of this part.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e32bca1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e32bca2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
