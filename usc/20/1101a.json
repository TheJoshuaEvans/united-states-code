{"tag":"section","attrib":{"id":"id0d6a62a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1101a"},"text":"§ 1101a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions; eligibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d6a62aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6a62ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational and general expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “educational and general expenditures” means the total amount expended by an institution for instruction, research, public service, academic support (including library expenditures), student services, institutional support, scholarships and fellowships, operation and maintenance expenditures for the physical plant, and any mandatory transfers that the institution is required to pay by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible institution” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d6a62ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an institution of higher education—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d6a62ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has an enrollment of needy students as required by subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d6a62af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1103a/b"},"text":"section 1103a(b) of this title","children":[],"tail":", the average educational and general expenditures of which are low, per full-time equivalent undergraduate student, in comparison with the average educational and general expenditures per full-time equivalent undergraduate student of institutions that offer similar instruction;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d6a62b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d6a62b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/2/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legally authorized to provide, and provides within the State, an educational program for which the institution awards a bachelor’s degree; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d6a62b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/2/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a junior or community college;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d6a62b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is accredited by a nationally recognized accrediting agency or association determined by the Secretary to be reliable authority as to the quality of training offered or that is, according to such an agency or association, making reasonable progress toward accreditation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d6a62b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that meets such other requirements as the Secretary may prescribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d6a62b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is located in a State; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6a62b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any branch of any institution of higher education described under subparagraph (A) that by itself satisfies the requirements contained in clauses (i) and (ii) of such subparagraph.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of the determination of whether an institution is an eligible institution under this paragraph, the factor described under subparagraph (A)(i) shall be given twice the weight of the factor described under subparagraph (A)(ii).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Endowment fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “endowment fund” means a fund that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d6a62b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is established by State law, by a Hispanic-serving institution, or by a foundation that is exempt from Federal income taxation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6a62b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is maintained for the purpose of generating income for the support of the institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6a62ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include real estate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full-time equivalent students","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “full-time equivalent students” means the sum of the number of students enrolled full time at an institution, plus the full-time equivalent of the number of students enrolled part time (determined on the basis of the quotient of the sum of the credit hours of all part-time students divided by 12) at such institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hispanic-serving institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Hispanic-serving institution” means an institution of higher education that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d6a62bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an eligible institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6a62be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an enrollment of undergraduate full-time equivalent students that is at least 25 percent Hispanic students at the end of the award year immediately preceding the date of application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Junior or community college","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “junior or community college” means an institution of higher education—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d6a62c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that admits as regular students persons who are beyond the age of compulsory school attendance in the State in which the institution is located and who have the ability to benefit from the training offered by the institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6a62c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that does not provide an educational program for which the institution awards a bachelor’s degree (or an equivalent degree); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6a62c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d6a62c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/6/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides an educational program of not less than 2 years in duration that is acceptable for full credit toward such a degree; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d6a62c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/a/6/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offers a 2-year program in engineering, mathematics, or the physical or biological sciences, designed to prepare a student to work as a technician or at the semiprofessional level in engineering, scientific, or other technological fields requiring the understanding and application of basic engineering, scientific, or mathematical principles of knowledge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6a62c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment of needy students","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subchapter, the term “enrollment of needy students” means an enrollment at an institution with respect to which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6a62c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 50 percent of the degree students so enrolled are receiving need-based assistance under subchapter IV in the second fiscal year preceding the fiscal year for which the determination is made (other than loans for which an interest subsidy is paid pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078"},"text":"section 1078 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substantial percentage of the students so enrolled are receiving Federal Pell Grants in the second fiscal year preceding the fiscal year for which the determination is made, compared to the percentage of students receiving Federal Pell Grants at all such institutions in the second fiscal year preceding the fiscal year for which the determination is made, unless the requirement of this paragraph is waived under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1103a/a"},"text":"section 1103a(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6a62c8-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tV/s502"},"text":"Pub. L. 89–329, title V, § 502","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tV/s501"},"text":"Pub. L. 105–244, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1766"},"text":"112 Stat. 1766","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tX/s1087"},"text":"Pub. L. 108–375, div. A, title X, § 1087","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2066"},"text":"118 Stat. 2066","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/292/s4/a"},"text":"Pub. L. 109–292, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-30"},"text":"Sept. 30, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1341"},"text":"120 Stat. 1341","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tV/s502/b/1"},"text":"Pub. L. 110–315, title V, § 502(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3333"},"text":"122 Stat. 3333","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tV/s501"},"text":"Pub. L. 111–39, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1953"},"text":"123 Stat. 1953","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d6a62c9-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d6a62ca-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d6a62cb-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1101a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tV/s502"},"text":"Pub. L. 89–329, title V, § 502","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tV/s501/a"},"text":"Pub. L. 99–498, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1496"},"text":"100 Stat. 1496","children":[],"tail":", authorized appropriations for this subchapter, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s502"},"text":"section 502 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1102a"},"text":"section 1102a of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s502"},"text":"section 502 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1091a"},"text":"section 1091a of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/482"},"text":"Pub. L. 94–482","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d6a62cc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" substituted “for which the determination is made, compared to” for “for which determination is made, compared to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsecs. (a)(2)(A)(ii), (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1103a"},"text":"section 1103a of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/292/s4/a/1"},"text":"Pub. L. 109–292, § 4(a)(1)","children":[],"tail":", inserted “and” at end of subpar. (A), in subpar. (B), struck out “at the time of application,” before “has an enrollment”, substituted “at the end of the award year immediately preceding the date of application.” for “; and”, and struck out subpar. (C) which read as follows: “provides assurances that not less than 50 percent of the institution’s Hispanic students are low-income individuals, which assurances—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) may employ statistical extrapolation using appropriate data from the Bureau of the Census or other appropriate Federal or State sources; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the Secretary shall consider as meeting the requirements of this subparagraph, unless the Secretary determines, based on a preponderance of the evidence, that the assurances do not meet the requirements.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/292/s4/a/2"},"text":"Pub. L. 109–292, § 4(a)(2)","children":[],"tail":", struck out par. (7) which defined “low-income individual”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(5)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" inserted “, which assurances—” and cls. (i) and (ii) before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d6a62cd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d6a62ce-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" effective as if enacted on the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/s3"},"text":"section 3 of Pub. L. 111–39","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
