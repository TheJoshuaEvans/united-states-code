{"tag":"section","attrib":{"id":"id0dfbcd5c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5966"},"text":null,"children":[{"tag":"num","attrib":{"value":"5966"},"text":"§ 5966.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dfbcd5d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5966/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dfbcd5e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5966/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out the purpose of this subchapter, the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dfbcd5f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5966/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is authorized to use funds reserved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5962/b/2"},"text":"section 5962(b)(2) of this title","children":[],"tail":" to—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0dfbcd60-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5966/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct national leadership activities such as research, program development and evaluation, data collection, public awareness activities, training and technical assistance, dissemination (through appropriate research entities assisted by the Department of Education) of information on successful projects, activities, and strategies developed pursuant to this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dfbcd61-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5966/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide grants to noncommercial telecommunications entities for the production and distribution of national video-based projects that provide young people with models for conflict resolution and responsible decisionmaking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dfbcd62-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5966/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct peer review of applications under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dfbcd63-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5966/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall develop a written safe schools model so that all schools can develop models that enable all students to participate regardless of any language barrier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dfbcd64-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5966/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may carry out the activities described in paragraph (1) directly, through interagency agreements, or through grants, contracts or cooperative agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dfbcd65-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5966/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National model city","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate the District of Columbia as a national model city and shall provide funds made available pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5962/b/2"},"text":"section 5962(b)(2) of this title","children":[],"tail":" in each fiscal year to a local educational agency serving the District of Columbia in an amount sufficient to enable such agency to carry out a comprehensive program to address school and youth violence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dfbcd66-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/227/tVII/s706"},"text":"Pub. L. 103–227, title VII, § 706","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"Mar. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/208"},"text":"108 Stat. 208","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
