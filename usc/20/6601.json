{"tag":"section","attrib":{"id":"id0e187d3c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6601"},"text":null,"children":[{"tag":"num","attrib":{"value":"6601"},"text":"§ 6601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this subchapter is to provide grants to State educational agencies and subgrants to local educational agencies to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e187d3d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6601/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase student achievement consistent with the challenging State academic standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e187d3e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6601/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the quality and effectiveness of teachers, principals, and other school leaders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e187d3f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6601/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the number of teachers, principals, and other school leaders who are effective in improving student academic achievement in schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e187d40-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6601/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide low-income and minority students greater access to effective teac