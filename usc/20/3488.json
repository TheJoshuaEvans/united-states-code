{"tag":"section","attrib":{"id":"id0dda8ad7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3488"},"text":null,"children":[{"tag":"num","attrib":{"value":"3488"},"text":"§ 3488.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to any limitation on appropriations applicable with respect to any function or office transferred to the Secretary or the Department, there are authorized to be appropriated for fiscal year 1980 and each succeeding fiscal year such sums as may be necessary to carry out the provisions of this chapter and to enable the Secretary to administer and manage the Department. Funds appropriated in accordance with this section shall remain available until expended.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0dda8ad8-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIV/s427"},"text":"Pub. L. 96–88, title IV, § 427","children":[],"tail":", formerly § 428, "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/689"},"text":"93 Stat. 689","children":[],"tail":"; renumbered § 427, "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tII/s271/a/2"},"text":"Pub. L. 103–382, title II, § 271(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3929"},"text":"108 Stat. 3929","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dda8ad9-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dda8ada-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,