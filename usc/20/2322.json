{"tag":"section","attrib":{"id":"id0dbdd998-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322"},"text":null,"children":[{"tag":"num","attrib":{"value":"2322"},"text":"§ 2322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Within State allocation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dbdd999-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amount allotted to each State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2321"},"text":"section 2321 of this title","children":[],"tail":" for a fiscal year, the eligible agency shall make available—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dbdd99a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 85 percent for distribution under section 2351 or 2352 of this title, of which not more than 15 percent of the 85 percent may be used in accordance with subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dbdd99b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not more than 10 percent to carry out State leadership activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2344"},"text":"section 2344 of this title","children":[],"tail":", of which—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dbdd99c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to not more than 2 percent of the amount allotted to the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2321"},"text":"section 2321 of this title","children":[],"tail":" for the fiscal year shall be made available to serve individuals in State institutions, such as State correctional institutions, juvenile justice facilities, and educational institutions that serve individuals with disabilities;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbdd99d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $60,000 and not more than $150,000 shall be available for services that prepare individuals for non-traditional fields; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbdd99e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an amount shall be made available for the recruitment of special populations to enroll in career and technical education programs, which shall be not less than the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0dbdd99f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to 0.1 percent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dbdd9a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dbdd9a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an amount equal to not more than 5 percent, or $250,000, whichever is greater, for administration of the State plan, which may be used for the costs of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dbdd9a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing the State plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbdd9a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing local applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbdd9a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring and evaluating program effectiveness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbdd9a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assuring compliance with all applicable Federal laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbdd9a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbdd9a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting and developing State data systems relevant to the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dbdd9a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible agency receiving funds made available under subsection (a)(3) shall match, from non-Federal sources and on a dollar-for-dollar basis, the funds received under subsection (a)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dbdd9a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From amounts made available under subsection (a)(1) to carry out this subsection, an eligible agency may award grants to eligible recipients for career and technical education activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2355"},"text":"section 2355 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dbdd9aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dbdd9ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rural areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbdd9ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" areas with high percentages of CTE concentrators or CTE participants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbdd9ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" areas with high numbers of CTE concentrators or CTE participants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbdd9ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" areas with disparities or gaps in performance as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2323/b/3/C/ii/II"},"text":"section 2323(b)(3)(C)(ii)(II) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dbdd9af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in order to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dbdd9b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster innovation through the identification and promotion of promising and proven career and technical education programs, practices, and strategies, which may include programs, practices, and strategies that prepare individuals for nontraditional fields; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbdd9b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2322/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the development, implementation, and adoption of programs of study or career pathways aligned with State-identified high-skill, high-wage, or in-demand occupations or industries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dbdd9b2-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tI/s112"},"text":"Pub. L. 88–210, title I, § 112","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/b"},"text":"Pub. L. 109–270, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/695"},"text":"120 Stat. 695","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/224/tI/s111"},"text":"Pub. L. 115–224, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-07-31"},"text":"July 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1579"},"text":"132 Stat. 1579","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dbdd9b3-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dbdd9b4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0dbdd9b5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2322, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tI/s112"},"text":"Pub. L. 88–210, title I, § 112","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/332/s1/b"},"text":"Pub. L. 105–332, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3086"},"text":"112 Stat. 3086","children":[],"tail":", related to allocations within States, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/109/270"},"text":"Pub. L. 109–270","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2322, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tI/s112"},"text":"Pub. L. 88–210, title I, § 112","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/524/s1"},"text":"Pub. L. 98–524, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2443"},"text":"98 Stat. 2443","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/159/tVII/s703"},"text":"Pub. L. 99–159, title VII, § 703","children":[],"tail":