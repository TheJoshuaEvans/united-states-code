{"tag":"section","attrib":{"id":"id0c8a3ca0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"80t–1"},"text":"§ 80t–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Museum","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c8a3ca1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Smithsonian Institution a comprehensive women’s history museum, to be named by the Board of Regents in consultation with the council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s80t–2"},"text":"section 80t–2 of this title","children":[],"tail":" (referred to in this subchapter "},{"tag":"ref","attrib":{"idref":"fn002009"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002009"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" as the “Museum”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c8a3ca2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the Museum established under this section shall be to provide for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c8a3ca3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collection and study of, and the establishment of programs relating to, women’s contributions to various fields and throughout different periods of history that have influenced the direction of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8a3ca4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaboration with other Smithsonian Institution museums and facilities, outside museums, and educational institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8a3ca5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the creation of exhibitions and programs that recognize diverse perspectives on women’s history and contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c8a3ca6-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dT/tI/s103"},"text":"Pub. L. 116–260, div. T, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2273"},"text":"134 Stat. 2273","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c8a3ca7-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c8a3ca8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0c8a3ca9-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (a), was in the original “this Act”, and was translated as reading “this title”, meaning title I of div. T of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":", known as the Smithsonian American Women’s History Museum Act, which is classified to this subchapter, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
