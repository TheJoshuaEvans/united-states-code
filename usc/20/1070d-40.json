{"tag":"section","attrib":{"id":"id0cf337d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–40"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070d–40"},"text":"§ 1070d–40.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of needs provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087kk"},"text":"section 1087kk of this title","children":[],"tail":", nothing in this subpart, or any other Act, shall be construed to permit the receipt of a scholarship under this subpart to be counted for any needs test in connection with the awarding of any grant or the making of any loan under this chapter or any other provision of Federal law relating to educational assistance."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0cf337d9-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s419J"},"text":"Pub. L. 89–329, title IV, § 419J","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s401/a"},"text":"Pub. L. 99–498, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1345"},"text":"100 Stat. 1345","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s406/f"},"text":"Pub. L. 102–325, title IV, § 406(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/509"},"text":"106 Stat. 509","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cf337da-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cf337db-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cf337dc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1070d–40, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s419J"},"text":"Pub. L. 89–329, title IV, § 419J","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/558/tVIII/s801/a"},"text":"Pub. L. 98–558, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2902"},"text":"98 Stat. 2902","children":[],"tail":", provided that receipt of scholarship under Robert C. Byrd Honors Scholarship Program not be counted for needs test for education grant or loan, prior to the general revision of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cf337dd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":" substituted “Except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087kk"},"text":"section 1087kk of this title","children":[],"tail":", nothing” for “Nothing”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
