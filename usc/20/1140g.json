{"tag":"section","attrib":{"id":"id0d7d75ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1140g"},"text":"§ 1140g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model comprehensive transition and postsecondary programs for students with intellectual disabilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d7d75eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7d75ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1140i/a"},"text":"section 1140i(a) of this title","children":[],"tail":", the Secretary shall annually award grants, on a competitive basis, to institutions of higher education (or consortia of institutions of higher education), to enable the institutions or consortia to create or expand high quality, inclusive model comprehensive transition and postsecondary programs for students with intellectual disabilities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d75ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program under this section shall be administered by the office in the Department that administers other postsecondary education programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d75ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this section shall be awarded for a period of 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7d75ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution of higher education (or a consortium) desiring a grant under this section shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7d75f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award basis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7d75f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for an equitable geographic distribution of such grants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d75f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide grant funds for model comprehensive transition and postsecondary programs for students with intellectual disabilities that will serve areas that are underserved by programs of this type; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d75f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" give preference to applications submitted under subsection (b) that agree to incorporate into the model comprehensive transition and postsecondary program for students with intellectual disabilities carried out under the grant one or more of the following elements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7d75f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The formation of a partnership with any relevant agency serving students with intellectual disabilities, such as a vocational rehabilitation agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d75f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an institution of higher education that provides institutionally owned or operated housing for students attending the institution, the integration of students with intellectual disabilities into the housing offered to nondisabled students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d75f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The involvement of students attending the institution of higher education who are studying special education, general education, vocational rehabilitation, assistive technology, or related fields in the model program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7d75f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An institution of higher education (or consortium) receiving a grant under this section shall use the grant funds to establish a model comprehensive transition and postsecondary program for students with intellectual disabilities that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7d75f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves students with intellectual disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d75f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides individual supports and services for the academic and social inclusion of students with intellectual disabilities in academic courses, extracurricular activities, and other aspects of the institution of higher education’s regular postsecondary program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d75fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to the students with intellectual disabilities participating in the model program, provides a focus on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7d75fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic enrichment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d75fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" socialization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d75fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" independent living skills, including self-advocacy skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d75fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrated work experiences and career skills that lead to gainful employment;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d75ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrates person-centered planning in the development of the course of study for each student with an intellectual disability participating in the model program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d7600-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participates with the coordinating center established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1140q/b"},"text":"section 1140q(b) of this title","children":[],"tail":" in the evaluation of the model program;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d7601-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partners with one or more local educational agencies to support students with intellectual disabilities participating in the model program who are still eligible for special education and related services under the Individuals with Disabilities Education Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"20 U.S.C. 1400","children":[],"tail":" et seq.], including the use of funds available under part B of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1411"},"text":"20 U.S.C. 1411","children":[],"tail":" et seq.] to support the participation of such students in the model program;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d7602-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans for the sustainability of the model program after the end of the grant period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d7603-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creates and offers a meaningful credential for students with intellectual disabilities upon the completion of the model program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7d7604-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution of higher education (or consortium) that receives a grant under this section shall provide matching funds toward the cost of the model comprehensive transition and postsecondary program for students with intellectual disabilities carried out under the grant. Such matching funds may be provided in cash or in-kind, and shall be in an amount of not less than 25 percent of the amount of such costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7d7605-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than five years after the date of the first grant awarded under this section, the Secretary shall prepare and disseminate a report to the authorizing committees and to the public that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7d7606-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviews the activities of the model comprehensive transition and postsecondary programs for students with intellectual disabilities funded under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d7607-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140g/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides guidance and recommendations on how effective model programs can be replicated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d7d7608-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s767"},"text":"Pub. L. 89–329, title VII, § 767","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVII/s709/2"},"text":"Pub. L. 110–315, title VII, § 709(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3365"},"text":"122 Stat. 3365","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d7d7609-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d7d760a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d7d760b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Individuals with Disabilities Education Act, referred to in subsec. (d)(6), is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230"},"text":"Pub. L. 91–230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/175"},"text":"84 Stat. 175","children":[],"tail":", which is classified generally to chapter 33 (§ 1400 et seq.) of this title. Part B of the Act is classified generally to subchapter II (§ 1411 et seq.) of chapter 33 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
