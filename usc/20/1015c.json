{"tag":"section","attrib":{"id":"id0cc37476-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1015c"},"text":"§ 1015c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Database of student information prohibited","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cc37477-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as described in subsection (b), nothing in this chapter shall be construed to authorize the development, implementation, or maintenance of a Federal database of personally identifiable information on individuals receiving assistance under this chapter, attending institutions receiving assistance under this chapter, or otherwise involved in any studies or other collections of data under this chapter, including a student unit record system, an education bar code system, or any other system that tracks individual students over time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc37478-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of subsection (a) shall not apply to a system (or a successor system) that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cc37479-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary for the operation of programs authorized by subchapter II, IV, or VII; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc3747a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was in use by the Secretary, directly or through a contractor, as of the day before ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc3747b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State databases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall prohibit a State or a consortium of States from developing, implementing, or maintaining State-developed databases that track individuals over time, including student unit record systems that contain information related to enrollment, attendance, graduation and retention rates, student financial assistance, and graduate employment outcomes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cc3747c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s134"},"text":"Pub. L. 89–329, title I, § 134","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tI/s113"},"text":"Pub. L. 110–315, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3110"},"text":"122 Stat. 3110","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cc3747d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cc3747e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cc3747f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1015c, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s134"},"text":"Pub. L. 89–329, title I, § 134","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tI/s101"},"text":"Pub. L. 102–325, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/466"},"text":"106 Stat. 466","children":[],"tail":", defined “public broadcasting entity” for purposes of former part C of this subchapter, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1015c, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s134"},"text":"Pub. L. 89–329, title I, § 134","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/482/tI/s101/g/3"},"text":"Pub. L. 94–482, title I, § 101(g)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2089"},"text":"90 Stat. 2089","children":[],"tail":", related to annual reports by Assistant Secretary and content of these reports, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/96/374"},"text":"Pub. L. 96–374","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
