{"tag":"section","attrib":{"id":"id0c772914-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s53"},"text":null,"children":[{"tag":"num","attrib":{"value":"53"},"text":"§ 53.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All laws for the protection of public property in the city of Washington shall apply to, and be in force for, the protection of the lands, buildings, and other property of the Smithsonian Institution. All moneys recovered by or accruing to, the institution shall be paid into the Treasury of the United States, to the credit of the Smithsonian bequest, and separately accounted for.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c772915-3a70-11f1-a648-bee82ed8a795"},"text":"(R.S. § 5589.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c772916-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c772917-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0c772918-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5589 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1846-08-10/ch178/s5"},"text":"act Aug. 10, 1846, ch. 178, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/9/104"},"text":"9 Stat. 104","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
