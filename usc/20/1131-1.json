{"tag":"section","attrib":{"id":"id0d718f14-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1131–1"},"text":"§ 1131–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutional development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d718f15-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute shall award grants, from amounts available to the Institute for each fiscal year, to historically Black colleges and universities, Hispanic-serving institutions, tribally controlled colleges or universities, and minority institutions, to enable such colleges, universities, and institutions to strengthen international affairs, international business, and foreign language study programs, including the teaching of foreign languages, at such colleges, universities, and institutions, respectively, which may include collaboration with institutions of higher education that receive funding under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d718f16-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No grant may be made by the Institute unless an application is made by the college, university, or institution at such time, in such manner, and accompanied by such information as the Institute may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d718f17-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d718f18-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Hispanic-serving institution” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1101a"},"text":"section 1101a of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718f19-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “minority institution” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067k"},"text":"section 1067k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d718f1a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s622"},"text":"Pub. L. 89–329, title VI, § 622","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVI/s603/b/2"},"text":"Pub. L. 105–244, title VI, § 603(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1784"},"text":"112 Stat. 1784","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVI/s613"},"text":"