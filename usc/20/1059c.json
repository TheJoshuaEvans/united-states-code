{"tag":"section","attrib":{"id":"id0cd1ccc4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1059c"},"text":"§ 1059c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" American Indian tribally controlled colleges and universities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cd1ccc5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide grants and related assistance to Tribal Colleges and Universities to enable such institutions to improve and expand their capacity to serve Indian students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd1ccc6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd1ccc7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian” has the meaning given the term in section 2 of the Tribally Controlled Colleges and Universities Assistance Act of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801"},"text":"25 U.S.C. 1801","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1ccc8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given the term in section 2 of the Tribally Controlled Colleges and Universities Assistance Act of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801"},"text":"25 U.S.C. 1801","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1ccc9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal College or University","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Tribal College or University” means an institution that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd1ccca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualifies for funding under the Tribally Controlled Colleges and Universities Assistance Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801"},"text":"25 U.S.C. 1801","children":[],"tail":" et seq.) or the Navajo Community College Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s640a"},"text":"25 U.S.C. 640a","children":[],"tail":" note); "},{"tag":"ref","attrib":{"idref":"fn002036"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002036"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1cccb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is cited in section 532 of the Equity in Educational Land-Grant Status Act of 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s301"},"text":"7 U.S.C. 301","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cccc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” means an institution of higher education as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"section 1001(a) of this title","children":[],"tail":", except that paragraph (2) of such section shall not apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd1cccd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd1ccce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants awarded under this section shall be used by Tribal Colleges or Universities to assist such institutions to plan, develop, undertake, and carry out activities to improve and expand such institutions’ capacity to serve Indian students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cccf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examples of authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The activities described in paragraph (1) may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd1ccd0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase, rental, or lease of scientific or laboratory equipment for educational purposes, including instructional and research purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1ccd1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction, maintenance, renovation, and improvement in classrooms, libraries, laboratories, and other instructional facilities, including purchase or rental of telecommunications technology equipment or services, and the acquisition of real property adjacent to the campus of the institution on which to construct such facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1ccd2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support of faculty exchanges, faculty development, and faculty fellowships to assist in attaining advanced degrees in the faculty’s field of instruction or in tribal governance or tribal public policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1ccd3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic instruction in disciplines in which Indians are underrepresented and instruction in tribal governance or tribal public policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1ccd4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase of library books, periodicals, and other educational materials, including telecommunications program material;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1ccd5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tutoring, counseling, and student service programs designed to improve academic success;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1ccd6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education or counseling services designed to improve the financial literacy and economic literacy of students or the students’ families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1ccd7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds management, administrative management, and acquisition of equipment for use in strengthening funds management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1ccd8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" joint use of facilities, such as laboratories and libraries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1ccd9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing or improving a development office to strengthen or improve contributions from alumni and the private sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1ccda-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing or enhancing a program of teacher education designed to qualify students to teach in elementary schools or secondary schools, with a particular emphasis on teaching Indian children and youth, that shall include, as part of such program, preparation for teacher certification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1ccdb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing community outreach programs that encourage Indian elementary school and secondary school students to develop the academic skills and the interest to pursue postsecondary education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1ccdc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing or improving facilities for Internet use or other distance education technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1ccdd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c/2/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" other activities proposed in the application submitted pursuant to subsection (d) that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cd1ccde-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c/2/N/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute to carrying out the activities described in subparagraphs (A) through (M); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cd1ccdf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c/2/N/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are approved by the Secretary as part of the review and acceptance of such application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cce0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Endowment fund","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd1cce1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Tribal College or University may use not more than 20 percent of the grant funds provided under this section to establish or increase an endowment fund at the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1cce2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to be eligible to use grant funds in accordance with subparagraph (A), the Tribal College or University shall provide matching funds, in an amount equal to the Federal funds used in accordance with subparagraph (A), for the establishment or increase of the endowment fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1cce3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comparability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of part C regarding the establishment or increase of an endowment fund, that the Secretary determines are not inconsistent with this paragraph, shall apply to funds used under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd1cce4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application, plan, and allocation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd1cce5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutional eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive assistance under this section, a Tribal College or University shall be an eligible institution under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1058/b"},"text":"section 1058(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cce6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd1cce7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Tribal College or University desiring to receive assistance under this section shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1cce8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Streamlined process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish application requirements in such a manner as to simplify and streamline the process for applying for grants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cce9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards and allocations to institutions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd1ccea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction grants","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cd1cceb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount appropriated to carry out this section for any fiscal year, the Secretary may reserve 30 percent for the purpose of awarding one-year grants of not less than $1,000,000 to address construction, maintenance, and renovation needs at eligible institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cd1ccec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing grants under clause (i) for any fiscal year, the Secretary shall give preference to eligible institutions that have not received an award under this section for a previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1cced-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment of remaining funds","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cd1ccee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in clause (ii), the Secretary shall distribute the remaining funds appropriated for any fiscal year to each eligible institution as follows:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0cd1ccef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/d/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 60 percent of the remaining appropriated funds shall be distributed among the eligible Tribal Colleges and Universities on a pro rata basis, based on the respective Indian student counts (as defined in section 2(a) of the Tribally Controlled Colleges and Universities Assistance Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801/a"},"text":"25 U.S.C. 1801(a)","children":[],"tail":") "},{"tag":"ref","attrib":{"idref":"fn002037"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002037"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be followed by a third closing parenthesis."}],"tail":" of the Tribal Colleges and Universities."}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0cd43cf0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/d/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The remaining 40 percent shall be distributed in equal shares to the eligible Tribal Colleges and Universities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cd43cf1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount distributed to a Tribal College or University under clause (i) shall not be less than $500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd43cf2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd43cf3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concurrent funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No Tribal College or University that receives funds under this section shall concurrently receive funds under any other provision of this part, part B, or part A of subchapter V.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43cf4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059c/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059/d"},"text":"Section 1059(d) of this title","children":[],"tail":" shall not apply to institutions that are eligible to receive funds under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cd43cf5-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s316"},"text":"Pub. L. 89–329, title III, § 316","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIII/s302/d/1"},"text":"Pub. L. 102–325, title III, § 302(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/473"},"text":"106 Stat. 473","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/a/7"},"text":"Pub. L. 103–208, § 2(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2457"},"text":"107 Stat. 2457","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIII/s303/e"},"text":"Pub. L. 105–244, title III, § 303(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1639"},"text":"112 Stat. 1639","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/211/s1/a"},"text":"Pub. L. 106–211, § 1(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2000-05-26"},"text":"May 26, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/330"},"text":"114 Stat. 330","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIII/s303"},"text":"Pub. L. 110–315, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3167"},"text":"122 Stat. 3167","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tIII/s301/1"},"text":"Pub. L. 111–39, title III, § 301(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1936"},"text":"123 Stat. 1936","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cd43cf6-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cd43cf7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0cd43cf8-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Tribally Controlled Colleges and Universities Assistance Act of 1978, referred to in subsec. (b)(3)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/471"},"text":"Pub. L. 95–471","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1325"},"text":"92 Stat. 1325","children":[],"tail":", which is classified principally to chapter 20 (§ 1801 et seq.) of Title 25, Indians. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801"},"text":"section 1801 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Navajo Community College Act, referred to in subsec. (b)(3)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/189"},"text":"Pub. L. 92–189","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-15"},"text":"Dec. 15, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/646"},"text":"85 Stat. 646","children":[],"tail":", which was classified to section 640a et seq. of Title 25, Indians, and was omitted from the Code as being of special and not general application."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 532 of the Equity in Educational Land-Grant Status Act of 1994, referred to in subsec. (b)(3)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/s532"},"text":"section 532 of Pub. L. 103–382","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s301"},"text":"section 301 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cd43cf9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s301/1/A"},"text":"Pub. L. 111–39, § 301(1)(A)","children":[],"tail":", substituted “Tribal” for “Indian Tribal”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s301/1/B/i"},"text":"Pub. L. 111–39, § 301(1)(B)(i)","children":[],"tail":", (ii), substituted “the Tribally Controlled Colleges and Universities Assistance Act of 1978” for “the Tribally Controlled College or University Assistance Act of 1978”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s301/1/B/iii"},"text":"Pub. L. 111–39, § 301(1)(B)(iii)","children":[],"tail":", substituted “the Navajo Community College Act” for “the Navajo Community College Assistance Act of 1978”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s303/1"},"text":"Pub. L. 110–315, § 303(1)","children":[],"tail":", added par. (3) and struck out former par. (3). Prior to amendment, text read as follows: “The term ‘Tribal College or University’ has the meaning give the term ‘tribally controlled college or university’ in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801"},"text":"section 1801 of title 25","children":[],"tail":", and includes an institution listed in the Equity in Educational Land Grant Status Act of 1994."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s303/2/A"},"text":"Pub. L. 110–315, § 303(2)(A)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “construction, maintenance, renovation, and improvement in classrooms, libraries, laboratories, and other instructional facilities, including purchase or rental of telecommunications technology equipment or services;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s303/2/B"},"text":"Pub. L. 110–315, § 303(2)(B)","children":[],"tail":", inserted “or in tribal governance or tribal public policy” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s303/2/C"},"text":"Pub. L. 110–315, § 303(2)(C)","children":[],"tail":", inserted “and instruction in tribal governance or tribal public policy” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(G) to (N). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s303/2/D"},"text":"Pub. L. 110–315, § 303(2)(D)","children":[],"tail":"–(H), added subpars. (G) and (M), redesignated former subpars. (G), (H), (I), (J), (K), and (L) as subpars. (H), (I), (J), (K), (L), and (N), respectively, and in subpar. (N)(i) substituted “subparagraphs (A) through (M)” for “subparagraphs (A) through (K)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s303/3"},"text":"Pub. L. 110–315, § 303(3)","children":[],"tail":", added subsec. (d) and struck out former subsec. (d) which related to the application process for assistance under this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/211/s1/a"},"text":"Pub. L. 106–211, § 1(a)","children":[],"tail":", inserted after first sentence “The Secretary shall, to the extent possible, prescribe a simplified and streamlined format for such applications that takes into account the limited number of institutions that are eligible for assistance under this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/211/s1/b/1"},"text":"Pub. L. 106–211, § 1(b)(1)","children":[],"tail":", added par. (3) and struck out heading and text of former par. (3). Text read as follows: “For the purposes of this part, no Tribal College or University that is eligible for and receives funds under this section may concurrently receive other funds under this part or part B of this subchapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text consisted of subsecs. (a) to (e) authorizing grants and related assistance to Hispanic-serving institutions to enable such institutions to improve and expand their capacity to serve Hispanic and other low-income students."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208"},"text":"Pub. L. 103–208","children":[],"tail":" substituted “(2) "},{"tag":"inline","attrib":{},"text":"Examples of authorized activities","children":[],"tail":".—Such programs may include—” for “Such programs may include—”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cd43cfa-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cd43cfb-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" effective as if enacted on the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","child