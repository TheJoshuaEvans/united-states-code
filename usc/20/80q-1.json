{"tag":"section","attrib":{"id":"id0c8581ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"80q–1"},"text":"§ 80q–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Museum of the American Indian","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c8581ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established, within the Smithsonian Institution, a living memorial to Native Americans and their traditions which shall be known as the “National Museum of the American Indian”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c8581ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the National Museum are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c8581f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance the study of Native Americans, including the study of language, literature, history, art, anthropology, and life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8581f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect, preserve, and exhibit Native American objects of artistic, historical, literary, anthropological, and scientific interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8581f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for Native American research and study programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8581f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the means of carrying out paragraphs (1), (2), and (3) in the District of Columbia, the State of New York, and other appropriate locations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c8581f4-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/185/s3"},"text":"Pub. L. 101–185, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1337"},"text":"103 Stat. 1337","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
