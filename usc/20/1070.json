{"tag":"section","attrib":{"id":"id0ce0248e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070"},"text":"§ 1070.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of purpose; program authorization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ce0248f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this part, to assist in making available the benefits of postsecondary education to eligible students (defined in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1091"},"text":"section 1091 of this title","children":[],"tail":") in institutions of higher education by—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce02490-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing Federal Pell Grants to all eligible students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce02491-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing supplemental educational opportunity grants to those students who demonstrate financial need;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce02492-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for payments to the States to assist them in making financial aid available to such students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce02493-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for special programs and projects designed (A) to identify and encourage qualified youths with financial or cultural need with a potential for postsecondary education, (B) to prepare students from low-income families for postsecondary education, and (C) to provide remedial (including remedial language study) and other services to students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce02494-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing assistance to institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce02495-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary required to carry out purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, in accordance with subparts 1 through 9 of this part, carry out programs to achieve the purposes of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ce02496-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s400"},"text":"Pub. L. 89–329, title IV, § 400","children":[],"tail":", formerly § 401, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s401/a"},"text":"Pub. L. 99–498, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1308"},"text":"100 Stat. 1308","children":[],"tail":"; renumbered § 400, "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s402/a/3"},"text":"Pub. L. 102–325, title IV, § 402(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/482"},"text":"106 Stat. 482","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s401/g/1"},"text":"Pub. L. 105–244, title IV, § 401(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1652"},"text":"112 Stat. 1652","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tIV/s401/a/1"},"text":"Pub. L. 111–39, title IV, § 401(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1938"},"text":"123 Stat. 1938","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ce02497-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ce02498-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0ce02499-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 10