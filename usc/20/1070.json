"},{"tag":"date","attrib":{"date":"2007-09-30"},"text":"Sept. 30, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/999"},"text":"121 Stat. 999","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/122"},"text":"Pub. L. 107–122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-15"},"text":"Jan. 15, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2386"},"text":"115 Stat. 2386","children":[],"tail":", known as the Higher Education Relief Opportunities for Students Act of 2001, authorized the Secretary of Education to waive or modify statutory or regulatory provisions applicable to the student financial aid programs under title IV of the Higher Education Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070"},"text":"20 U.S.C. 1070","children":[],"tail":" et seq.) as deemed necessary because of a national emergency, provided sense of Congress as to tuition refunds from institutions of postsecondary education, and provided that the Act ceased to be effective "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0ce0249f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Community Scholarship Mobilization","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVIII/ptC"},"text":"Pub. L. 105–244, title VIII, part C","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1810"},"text":"112 Stat. 1810","children":[],"tail":", known as the Community Scholarship Mobilization Act, which established regional, State and community program centers to foster development of local entities in high poverty areas that promote higher education goals for low-income students with academic support and scholarship assistance for postsecondary education, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIX/s931/2"},"text":"Pub. L. 110–315, title IX, § 931(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3456"},"text":"122 Stat. 3456","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0ce024a0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Community School Partnerships","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/tV"},"text":"Pub. L. 103–382, title V","children":[],"tail":", part B, "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4045"},"text":"108 Stat. 4045","children":[],"tail":", which provided for grants to establish community centers giving academic support and postsecondary scholarships to poor students, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tVIII/s301/a"},"text":"Pub. L. 105–277, div. A, § 101(f) [title VIII, § 301(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–410."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0ce024a1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of Federal Benefit Coordination","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/tXIV/s1405"},"text":"Pub. L. 102–325, title XIV, § 1405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/818"},"text":"106 Stat. 818","children":[],"tail":", directed Secretary of Education to conduct a study to evaluate the coordination of Federal student financial assistance programs under title IV of the Higher Education Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070"},"text":"20 U.S.C. 1070","children":[],"tail":" et seq.) with other programs funded in whole or in part with Federal funds, with Secretary to prepare and submit to appropriate committees of Congress a report on the study not later than 3 years after "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", together with such recommendations as the Secretary deemed appropriate, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/332/s6/b/2"},"text":"Pub. L. 105–332, § 6(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3128"},"text":"112 Stat. 3128","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0ce024a2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Olympic Scholarships","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/tXV/s1543"},"text":"Pub. L. 102–325, title XV, § 1543","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/836"},"text":"106 Stat. 836","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVIII/s836"},"text":"Pub. L. 105–244, title VIII, § 836","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1820"},"text":"112 Stat. 1820","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/1/tIII/s319"},"text":"Pub. L. 106–554, § 1(a)(1) [title III, § 319]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–49; "},{"tag":"ref","attrib":{"href":"/us/pl/107/116/tIII/s305/a"},"text":"Pub. L. 107–116, title III, § 305(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"Jan. 10, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2208"},"text":"115 Stat. 2208","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIX/s934"},"text":"Pub. L. 110–315, title IX, § 934","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3460"},"text":"122 Stat. 3460","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/315/tIX/s934"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scholarships Authorized.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Education is authorized to provide financial assistance to the United States Olympic Education Center or the United States Olympic Training Center to enable such centers to provide financial assistance to athletes who are training at such centers and are pursuing postsecondary education at institutions of higher education (as such term is defined in section 481(a) of the Higher Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1088/a"},"text":"20 U.S.C. 1088(a)","children":[],"tail":"])."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Award determination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of the financial assistance provided to an athlete described in paragraph (1) shall be determined in accordance with criteria, and in amounts, specified in the application of the center under subsection (c). Such assistance shall not exceed the athlete’s cost of attendance as determined under section 472 of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087"},"text":"20 U.S.C. 1087","children":[],"tail":null},{"tag":"i","attrib":{},"text":"ll","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information on distribution of assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each center providing such assistance shall annually report to the Secretary such information as the Secretary may reasonably require on the distribution of such assistance among athletes and institutions of higher education. The Secretary shall compile such reports and submit them to the Committees on Education and the Workforce and Appropriations of the House of Representatives and the Committees on Health, Education, Labor, and Pensions and Appropriations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Education shall ensure that financial assistance provided under this part [part E (§ 1543) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":"] is available to both full-time and part-time students who are athletes at centers described in subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each center desiring financial assistance under this section shall submit an application to the Secretary of Education at such time, in such manner and accompanied by such information as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are authorized to be appropriated $5,000,000 for fiscal year 2009 and such sums as may be necessary for each of the five succeeding fiscal years to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Scholarships awarded under this section shall be known as ‘B.J. Stupak Olympic Scholarships’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/116/tIII/s305/b"},"text":"Pub. L. 107–116, title III, § 305(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"Jan. 10, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2208"},"text":"115 Stat. 2208","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/116/tIII/s305/b"},"text":"“The amendments made by subsection (a) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s1543"},"text":"section 1543 of Pub. L. 102–325","children":[],"tail":", set out above] shall apply with respect to any funds appropriated pursuant to section 1543(d) of the Higher Education Amendments of 1992 ["},{"tag":"ref","attrib":{"href":"/us/pl/102/325/s1543/d"},"text":"section 1543(d) of Pub. L. 102–325","children":[],"tail":", set out above], including funds appropriated pursuant to that section in fiscal years 2000 and 2001, that are available for financial assistance under section 1543 on or after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"Jan. 10, 2002","children":[],"tail":"].”"}],"tail":"\n]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0ce024a3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Persian Gulf Conflict Higher Education Assistance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/26"},"text":"Pub. L. 102–26","children":[],"tail":", §§ 4–6, "},{"tag":"date","attrib":{"date":"1991-04-09"},"text":"Apr. 9, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/125-127"},"text":"105 Stat. 125–127","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/26"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“SEC. 4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" OPERATION DESERT SHIELD/DESERT STORM WAIVER AUTHORITY.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this section to ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the men and women serving on active duty in connection with Operation Desert Shield or Operation Desert Storm who are borrowers of Stafford Loans or Perkins Loans are not placed in a worse position financially in relation to those loans because of such service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administrative requirements placed on all borrowers of student loans made in accordance with title IV of the Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070"},"text":"20 U.S.C. 1070","children":[],"tail":" et seq.] who are engaged in such military service are minimized to the extent possible without impairing the integrity of the student loan programs, in order to ease the burden on such borrowers, and to avoid inadvertent, technical defaults; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the future eligibility of such an individual for Pell Grants is not reduced by the amount of such assistance awarded for a period of instruction that such individual was unable to complete, or for which the individual did not receive academic credit, because he or she was called up for such service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, unless enacted with specific reference to this section, the Secretary of Education shall waive or modify any statutory or regulatory provision applicable to the student financial aid programs under title IV of the Act that the Secretary deems necessary to achieve the purposes stated in subsection (a), including—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the length of, and eligibility requirements for, the military deferments authorized under sections 427(a)(2)(C)(ii), 428(b)(1)(M)(ii), and 464(c)(2)(A)(ii) of the Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1077/a/2/C/ii"},"text":"20 U.S.C. 1077(a)(2)(C)(ii)","children":[],"tail":", 1078(b)(1)(M)(ii), 1087dd(c)(2)(A)(ii)], in order to enable the borrower of a Stafford Loan or a Perkins Loan who is or was serving on active duty in connection with Operation Desert Shield or Operation Desert Storm to obtain a military deferment, under which interest shall accrue and shall, if otherwise payable by the Secretary, be paid by the Secretary of Education, for the duration of such service;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative requirements placed on all borrowers of student loans made in accordance with title IV of the Act who are or were engaged in such military service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of years for which individuals who are engaged in such military service may be eligible for Pell Grants under subpart 1 of part A of title IV of the Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a"},"text":"20 U.S.C. 1070a","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the point at which the borrower of a Stafford Loan who is or was engaged in such military service is required to resume repayment of principal and interest on such loan after the borrower completes a period of deferment under section 427(a)(2)(C)(ii) or 428(b)(1)(M)(ii) of the Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the point at which the borrower of a Stafford Loan who is or was engaged in such military service is required to resume repayment of principal and interest on such loan after the borrower completes a single period of deferment under section 427(a)(2)(C)(i) or 428(b)(1)(M)(i) of the Act subsequent to such service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the modification of the terms ‘annual adjusted family income’ and ‘available income,’ as used in the determination of need for student financial assistance under title IV of the Act for such individual (and the determination of such need for his or her spouse and dependents, if applicable), to mean the sums received in the first calendar year of the award year for which such determination is made, in order to reflect more accurately the financial condition of such individual and his or her family.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 431 [now 437] of the General Education Provisions Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232"},"text":"20 U.S.C. 1232","children":[],"tail":") and "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", United States Code, the Secretary shall, by notice in the Federal Register, publish the waivers or modifications of statutory and regulatory provisions the Secretary deems necessary to achieve the purposes of this section. Such notice shall include the terms and conditions to be applied in lieu of such statutory and regulatory provisions. The Secretary is not required to exercise the waiver or modification authority under this section on a case-by-case basis."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this Act [probably should be “section”]—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Individuals ‘serving on active duty in connection with Operation Desert Shield or Operation Desert Storm’ shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Reserve of an Armed Force called to active duty under section 672(a) [now 12301(a)], 672(g) [now 12301(g)], 673 [now 12302], 673b [now 12304], 674 [now 12306], or 688 of title 10, United States Code, for service in connection with Operation Desert Shield or Operation Desert Storm, regardless of the location at which such active duty service is performed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of waivers of administrative requirements under subsection (b)(2) only, any other member of an Armed Force on active duty in connection with Operation Desert Shield or Operation Desert Storm, who has been assigned to a duty station at a location other than the location at which such member is normally assigned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘active duty’ has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/22"},"text":"section 101(22) of title 10","children":[],"tail":", United States Code [now "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/d/1"},"text":"10 U.S.C. 101(d)(1)","children":[],"tail":"], except that such term does not include active duty for training or attendance at a service school."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“SEC. 5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" TUITION REFUNDS OR CREDITS.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sense of Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is the sense of the Congress that all institutions offering postsecondary education should provide a full refund to any member or Reserve of an Armed Force on active duty service in connection with Operation Desert Shield or Operation Desert Storm for that portion of a period of instruction such individual was unable to complete, or for which such individual did not receive academic credit, because he or she was called up for such service. For purposes of this section, a full refund includes a refund of required tuition and fees, or a credit in a comparable amount against future tuition and fees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Encouragement and Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Education shall encourage institutions to provide such refunds or credits, and shall report to the appropriate committees of Congress on the actions taken in accordance with this subsection as well as information he receives regarding any institutions that are not providing such refunds or credits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“SEC. 6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" TERMINATION OF AUTHORITY.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The provisions of sections 4 and 5 shall cease to be effective on ","children":[{"tag":"date","attrib":{"date":"1997-09-30"},"text":"September 30, 1997","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25/tIII"},"text":"Pub. L. 102–25, title III","children":[],"tail":", part E (§§ 371–376), "},{"tag":"date","attrib":{"date":"1991-04-06"},"text":"Apr. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/93"},"text":"105 Stat. 93","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/25/tIII"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"371"},"text":"“SEC. 371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This part may be cited as the ‘Persian Gulf Conflict Higher Education Assistance Act’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"372"},"text":"“SEC. 372.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" [Superseded by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/26/s4"},"text":"section 4 of Pub. L. 102–26","children":[],"tail":", set out above.]"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"373"},"text":"“SEC. 373.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" [Superseded by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/26/s5"},"text":"section 5 of Pub. L. 102–26","children":[],"tail":", set out above.]"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"374"},"text":"“SEC. 374.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" [Amended ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s294d"},"text":"section 294d of Title 42","children":[],"tail":", The Public Health and Welfare.]"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"375"},"text":"“SEC. 375.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" [Superseded by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/26/s6"},"text":"section 6 of Pub. L. 102–26","children":[],"tail":", set out above.]"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"376"},"text":"“SEC. 376.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" COORDINATION WITH OTHER LAW","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“If the Higher Education Technical Amendments of 1991 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/26"},"text":"Pub. L. 102–26","children":[],"tail":", see Short Title of 1991 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"] is enacted, the provisions of sections 4, 5, and 6 of that Act shall supersede sections 372, 373, and 375.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
