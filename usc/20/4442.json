{"tag":"section","attrib":{"id":"id0ded9d3e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4442"},"text":null,"children":[{"tag":"num","attrib":{"value":"4442"},"text":"§ 4442.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ded9d3f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4442/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants under this subchapter in installments, in advance, or by way of reimbursement and may make necessary adjustments in payments of grants on account of overpayments or underpayments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ded9d40-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4442/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of overpayments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ded9d41-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4442/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary or a court of competent jurisdiction finds that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ded9d42-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4442/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0ded9d43-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4442/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0ded9d44-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4442/b/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made, or has caused to be made by another, a false statement or representation of a material fact knowing it to be false, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0ded9d45-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4442/b/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly failed, or caused another to fail, to disclose a material fact; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ded9d46-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4442/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a result of such action, has received any funds under this subchapter which such person would not have otherwise received, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ded9d47-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4442/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person misappropriates any funds paid by the Secretary under this subchapter,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such person shall be liable to repay the amount of such funds to the United States. Any such finding by the Secretary may be made only after an opportunity for a fair hearing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ded9d48-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4442/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount repaid under this subsection shall be returned to the general fund of the Treasury of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ded9d49-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4442/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ded9d4a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4442/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes a false statement of a material fact knowing it to be false, or knowingly fails to disclose a material fact, for the purpose of obtaining or increasing for such person or for any other person any payment of funds provided under this subchapter, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ded9d4b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4442/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" misappropriates any funds provided under this subchapter,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined not more than $1,000 or imprisoned for not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ded9d4c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/498/tXV/s1522"},"text":"Pub. L. 99–498, title XV, § 1522","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1611"},"text":"100 Stat. 1611","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
