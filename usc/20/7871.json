{"tag":"section","attrib":{"id":"id0e4f4515-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7871"},"text":null,"children":[{"tag":"num","attrib":{"value":"7871"},"text":"§ 7871.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval and disapproval of State plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e4f4516-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7871/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A plan submitted by a State pursuant to section 6611(d), 7113(c), 7173, or 7842 of this title shall be approved by the Secretary unless the Secretary makes a written determination (which shall include the supporting information and rationale supporting such determination), prior to the expiration of the 120-day period beginning on the date on which the Secretary received the plan, that the plan is not in compliance with section 6611(d), 7113(c), or 7173 of this title, or part C, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4f4517-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7871/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval process","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e4f4518-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7871/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not finally disapprove a plan submitted under section 6611(d), 7113(c), 7173, or 7842 of this title, except after giving the State educational agency notice and an opportunity for a hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4f4519-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7871/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary finds that the plan is not in compliance, in whole or in part, with section 6611(d), 7113(c), or 7173 of this title, or part C, as applicable, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4f451a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7871/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immediately notify the State of such determination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4f451b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7871/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a detailed description of the specific provisions of the plan that the Secretary determines fail to meet the requirements, in whole or in part, of such section or part, as applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4f451c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7871/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer the State an opportunity to revise and resubmit its plan within 45 days of such determination, including the chance for the State to present supporting information to clearly demonstrate that the State plan meets the requirements of such section or part, as applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4f451d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7871/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance, upon request of the State, in order to assist the State to meet the requirements of such section or part, as applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4f451e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7871/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a hearing within 30 days of the plan’s resubmission under subparagraph (C), unless a State declines the opportunity for such hearing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4f451f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7871/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request additional information, only as to the noncompliant provisions, needed to make the plan compliant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4f4520-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7871/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Response","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the State educational agency responds to the Secretary’s notification described in paragraph (2)(A) prior to the expiration of the 45-day period beginning on the date on which the State educational agency received the notification, and resubmits the plan as described in paragraph (2)(C), the Secretary shall approve such plan unless the Secretary determines the plan does not meet the requirements of section 6611(d), 7113(c), or 7173 of this title, or part C, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4f4521-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7871/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to respond","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the State educational agency does not respond to the Secretary’s notification described in paragraph (2)(A) prior to the expiration of the 45-day period beginning on the date on which the State educational agency received the notification, such plan shall be deemed to be disapproved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4f4522-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7871/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A plan submitted under section 6611(d), 7113(c), 7173, or 7842 of this title shall not be approved or disapproved based upon the nature of the activities proposed within such plan if such proposed activities meet the applicable program requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4f4523-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7871/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer-review requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other requirements of this part, the Secretary shall ensure that any portion of a consolidated State plan that is related to part A of subchapter I is subject to the peer-review process described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/a/4"},"text":"section 6311(a)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e4f4524-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8451"},"text":"Pub. L. 89–10, title VIII, § 8451","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII/s8014"},"text":"Pub. L. 114–95, title VIII, § 8014","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2107"},"text":"129 Stat. 2107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e4f4525-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e4f4526-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e4f4527-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7871, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIX/s9151"},"text":"Pub. L. 89–10, title IX, § 9151","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3792"},"text":"108 Stat. 3792","children":[],"tail":", established the National Advisory Council on Indian Education, prior to the general amendment of former subchapter IX of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e4f4528-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e4f4529-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
