{"tag":"section","attrib":{"id":"id0e54276a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7947"},"text":null,"children":[{"tag":"num","attrib":{"value":"7947"},"text":"§ 7947.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of responsibility for noneconomic loss","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e54276b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7947/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any civil action against a teacher, based on an act or omission of a teacher acting within the scope of the teacher’s employment or responsibilities to a school or governmental entity, the liability of the teacher for noneconomic loss shall be determined in accordance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e54276c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7947/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of liability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e54276d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7947/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e54276e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7947/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each defendant who is a teacher shall be liable only for the amount of noneconomic loss allocated to that defendant in direct proportion to the percentage of responsibility of that defendant (determined in accordance with paragraph (2)) for the harm to the claimant with respect to which that defendant is liable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e54276f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7947/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate judgment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court shall render a separate judgment against each defendant in an amount determined pursuant to subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e542770-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7947/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Percentage of responsibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of determining the amount of noneconomic loss allocated to a defendant who is a teacher under this section, the trier of fact shall determine the percentage of responsibility of each person responsible for the claimant’s harm, whether or not such person is a party to the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e542771-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7947/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to preempt or supersede any Federal or State law that further limits the application of joint liability in a civil action described in subsection (a), beyond the limitations established in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e542772-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8557"},"text":"Pub. L. 89–10, title VIII, § 8557","children":[],"tail":", formerly title II, § 2367, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tII/s201"},"text":"Pub. L. 107–110, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1670"},"text":"115 Stat. 1670","children":[],"tail":"; renumbered title IX, § 9547, renumbered title VIII, § 8557, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tII/s2001/a/3/A"},"text":"Pub. L. 114–95, title II, § 2001(a)(3)(A)","children":[],"tail":", (B), (D), title VIII, § 8001(a)(7), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1913"},"text":"129 Stat. 1913","children":[],"tail":", 2088, 2089.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e542773-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e542774-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0e542775-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6737"},"text":"section 6737 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
