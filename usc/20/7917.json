{"tag":"section","attrib":{"id":"id0e51b662-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7917"},"text":null,"children":[{"tag":"num","attrib":{"value":"7917"},"text":"§ 7917.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of school disciplinary records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e51b663-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7917/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplication of provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to any disciplinary records with respect to a suspension or expulsion that are transferred from a private, parochial or other nonpublic school, person, institution, or other entity, that provides education below the college level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e51b664-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7917/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disciplinary records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with the Family Educational Rights and Privacy Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232g"},"text":"20 U.S.C. 1232g","children":[],"tail":"), not later than 2 years after "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":", each State receiving Federal funds under this chapter shall provide an assurance to the Secretary that the State has a procedure in place to facilitate the transfer of disciplinary records, with respect to a suspension or expulsion, by local educational agencies to any private or public elementary school or secondary school for any student who is enrolled or seeks, intends, or is instructed to enroll, on a full- or part-time basis, in the school."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e51b665-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8537"},"text":"Pub. L. 89–10, title VIII, § 8537","children":[],"tail":", formerly title IV, § 4155, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIV/s401"},"text":"Pub. L. 107–110, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1765"},"text":"115 Stat. 1765","children":[],"tail":"; renumbered title IX, § 9537, renumbered title VIII, § 8537, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4001/a/3"},"text":"Pub. L. 114–95, title IV, § 4001(a)(3)","children":[],"tail":", title VIII, § 8001(a)(6), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1966"},"text":"129 Stat. 1966","children":[],"tail":", 2088, 2089.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e51b666-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e51b667-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e51b668-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Family Educational Rights and Privacy Act of 1974, referred to in subsec. (b), is ","children"