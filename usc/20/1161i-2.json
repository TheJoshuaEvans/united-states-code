{"tag":"section","attrib":{"id":"id0d84a249-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161i–2"},"text":"§ 1161i–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d84a24a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amounts appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1161i–7"},"text":"section 1161i–7 of this title","children":[],"tail":", the Secretary is authorized to award grants to States in accordance with the provisions of this part to enable such States—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a24b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish a State Task Force described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1161i–3"},"text":"section 1161i–3 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a24c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support activities of the State Task Force described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1161i–4"},"text":"section 1161i–4 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a24d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under this part shall be awarded on a competitive basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a24e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable geographic distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this part, the Secretary shall take into consideration providing an equitable geographic distribution of such grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a24f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under this part shall be awarded for a period of five years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d84a250-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s813"},"text":"Pub. L. 89–329, title VIII, § 813","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12