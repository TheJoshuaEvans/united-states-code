{"tag":"section","attrib":{"id":"id0e246492-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7111"},"text":null,"children":[{"tag":"num","attrib":{"value":"7111"},"text":"§ 7111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this subpart is to improve students’ academic achievement by increasing the capacity of States, local educational agencies, schools, and local communities to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e246493-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7111/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide all students with access to a well-rounded education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e246494-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7111/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve school conditions for student learning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e246495-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7111/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the use of technology in order to improve the academic achievement and digital literacy of all students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e246496-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4101"},"text":"Pub. L. 89–10, title IV, § 4101","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4101"},"text":"Pub. L. 114–95, title IV, § 4101","children":[],"tail":", "},{"tag":"date