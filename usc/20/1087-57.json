{"tag":"section","attrib":{"id":"id0d29ff7f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–57"},"text":null,"children":[{"tag":"num","attrib":{"value":"1087–57"},"text":"§ 1087–57.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funds to conduct community service work-study programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d29ff80-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–57/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community service-learning","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each institution participating under this part may use up to 10 percent of the funds made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1096/a"},"text":"section 1096(a) of this title","children":[],"tail":" and attributable to the amount of the institution’s expenditures under this part to conduct that institution’s program of community service-learning, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d29ff81-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–57/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of mechanisms to assure the academic quality of the student experience,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d29ff82-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–57/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assuring student access to educational resources, expertise, and supervision necessary to achieve community service objectives, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d29ff83-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–57/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaboration with public and private nonprofit agencies, and programs assisted under the National and Community Service Act of 1990 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12501"},"text":"42 U.S.C. 12501","children":[],"tail":" et seq.] in the planning, development, and administration of such programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d29ff84-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–57/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Off-campus community service","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d29ff85-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–57/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to funds made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087–53/b/2/A"},"text":"section 1087–53(b)(2)(A) of this title","children":[],"tail":", the Secretary is authorized to award grants to institutions participating under this part to supplement off-campus community service employment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d29ff86-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–57/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution shall ensure that funds granted to such institution under this subsection are used in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087–53/b/2/A"},"text":"section 1087–53(b)(2)(A) of this title","children":[],"tail":" to recruit and compensate students (including compensation for time spent in training and for travel directly related to such community service)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d29ff87-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–57/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this subsection, the Secretary shall give priority to applications that support postsecondary students assisting with early childhood education activities and activities in preparation for emergencies and natural disasters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d29ff88-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–57/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this subsection such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d29ff89-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s447"},"text":"Pub. L. 89–329, title IV, § 447","children":[],"tail":", as added "},{"tag":