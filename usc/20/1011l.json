{"tag":"section","attrib":{"id":"id0cbeba32-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011l"},"text":null,"children":[{"tag":"num","attrib":{"value":"1011l"},"text":"§ 1011l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diploma mills","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cbeba33-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to the public","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall maintain information and resources on the Department’s website to assist students, families, and employers in understanding what a diploma mill is and how to identify and avoid diploma mills.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cbeba34-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall continue to collaborate with the United States Postal Service, the Federal Trade Commission, the Department of Justice (including the Federal Bureau of Investigation), the Internal Revenue Service, and the Office of Personnel Management to maximize Federal efforts to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cbeba35-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011l/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent, identify, and prosecute diploma mills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbeba36-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011l/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" broadly disseminate to the public information about diploma mills, and resources to identify diploma mills.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cbeba37-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s123"},"text":"Pub. L. 89–329, title I, § 123","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tI/s109"},"text":"Pub. L. 110–315, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3094"},"text":"122 Stat. 3094","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
