48-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6004/b/1"},"text":"Pub. L. 114–95, § 6004(b)(1)","children":[],"tail":", inserted “and address” after “To recognize”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (2) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6004/b/2"},"text":"Pub. L. 114–95, § 6004(b)(2)","children":[],"tail":"–(5), added pars. (2) and (3), redesignated former pars. (2) and (4) as (4) and (5), respectively, substituted “, management, and expansion of effective supplemental educational programs to benefit Alaska Natives.” for “of supplemental educational programs to benefit Alaska Natives.” in par. (4), and struck out former par. (3) which read as follows: “To supplement existing programs and authorities in the area of education to further the purposes of this part.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6004/b/6"},"text":"Pub. L. 114–95, § 6004(b)(6)","children":[],"tail":", added par. (6)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e3c329c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e3c329d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},