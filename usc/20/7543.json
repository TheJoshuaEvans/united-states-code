{"tag":"section","attrib":{"id":"id0e3c3290-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7543"},"text":null,"children":[{"tag":"num","attrib":{"value":"7543"},"text":"§ 7543.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this part are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e3c3291-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7543/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To recognize and address the unique educational needs of Alaska Natives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c3292-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7543/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To recognize the role of Alaska Native languages and cultures in the educational success and long-term well-being of Alaska Native students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c3293-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7543/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To integrate Alaska Native cultures and languages into education, develop Alaska Native students’ positive identity, and support local place-based and culture-based curriculum and programming.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c3294-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7543/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To authorize the development, management, and expansion of effective supplemental educational programs to benefit Alaska Natives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c3295-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7543/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide direction and guidance to appropriate Federal, State and local agencies to focus resources, including resources made available under this part, on meeting the educational needs of Alaska Natives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c3296-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7543/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure the maximum participation by Alaska Native educators and leaders in the planning, development, implementation, management, and evaluation of programs designed to serve Alaska Native students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e3c3297-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVI/s6303"},"text":"Pub. L. 89–10, title VI, § 6303","children":[],"tail":", formerly title VII, § 7303, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVII/s701"},"text":"Pub. L. 107–110, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1943"},"text":"115 Stat. 1943","children":[],"tail":"; renumbered title VI, § 6303, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVI"},"text":"Pub. L. 114–95, title VI","children":[],"tail":", §§ 6001(a), (b)(1), 6004(b), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2046