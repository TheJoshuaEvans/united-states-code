{"tag":"section","attrib":{"id":"id0defe6b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4512"},"text":null,"children":[{"tag":"num","attrib":{"value":"4512"},"text":"§ 4512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" President and Executive Secretary of Foundation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0defe6ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4512/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0defe6bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4512/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board may appoint a President of the Foundation to serve full-time or part-time and for such a term as the Board shall determine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe6bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4512/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall carry out such of the functions and duties of the Foundation as the Board may determine, subject to the supervision and direction of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe6bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4512/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall be compensated at a rate to be determined by the Board without regard to subchapter III of chapter 53 of title 5, not to exceed the rate for level III of the Executive Schedule under section 5314 of that title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe6be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4512/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 5532,","children":[{"tag":"ref","attrib":{"idref":"fn002173"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002173"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" 8344, and 8468 of title 5 shall not apply to a person while such person is serving as President of the Foundation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0defe6bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4512/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0defe6c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4512/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be an Executive Secretary of the Foundation who shall be appointed by the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe6c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4512/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Executive Secretary shall be the chief operating officer of the Foundation and shall carry out the functions of the Foundation subject to the supervision and direction of the Board or the President, as determined by the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe6c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4512/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"c