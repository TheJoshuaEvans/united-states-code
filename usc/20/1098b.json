{"tag":"section","attrib":{"id":"id0d60ed52-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1098b"},"text":"§ 1098b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary for fiscal year 1993 and for each succeeding fiscal year thereafter for administrative expenses necessary for carrying out this subchapter, including expenses for staff personnel, program reviews, and compliance activities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d60ed53-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s493"},"text":"Pub. L. 89–329, title IV, § 493","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s497"},"text":"Pub. L. 102–325, title IV, § 497","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/634"},"text":"106 Stat. 634","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
