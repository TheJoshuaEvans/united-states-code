{"tag":"section","attrib":{"id":"id0ddf4526-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702"},"text":null,"children":[{"tag":"num","attrib":{"value":"3702"},"text":"§ 3702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization of Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ddf4527-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall be composed of fifteen members as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ddf4528-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior (or his designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf4529-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Education (or his designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf452a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Librarian of Congress (or his designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf452b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President of the Association for the Study of Afro-American Life and History.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf452c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The presidents of Wilberforce University and Central State University in Ohio.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf452d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nine members appointed by the President, who are especially qualified to serve on the Commission by reason of their background and experience. No more than two members appointed under this paragraph shall be from any one State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ddf452e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of office","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (c), the members of the Commission specified in paragraphs (1) through (5) of subsection (a) shall serve for the life of the Commission. The members of the Commission appointed under paragraph (6) of such subsection shall serve for terms of four years, except that of the members first appointed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ddf452f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three shall be appointed for terms of one year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf4530-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three shall be appointed for terms of two years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf4531-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three shall be appointed for terms of four years;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as designated by the President at the time of appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ddf4532-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership continuation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any member of the Commission who was appointed to the Commission under paragraphs (1) through (5) ","children":[{"tag":"ref","attrib":{"idref":"fn002154"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002154"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “of subsection (a)”."}],"tail":" as an officer designated under such paragraphs leaves such office, such member may continue as a member of the Commission for not longer than the thirty-day period beginning on the date he leaves that office."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ddf4533-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ddf4534-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vacancy in the Commission shall be filled in the same manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf4535-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any member appointed to fill a vacancy occurring before the expiration of the term for which his predecessor was appointed shall be appointed for the remainder of such term. Members may be reappointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ddf4536-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Six members of the Commission shall constitute a quorum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ddf4537-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall act by affirmative majority vote.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ddf4538-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall elect a chairman and other officers from among its members to serve for terms established by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ddf4539-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall meet at the call of the chairman or a majority of its members, but not less than two times each year. The headquarters of the Commission shall be at Wilberforce, Ohio, and the Commission shall conduct its meetings in such city unless circumstances otherwise require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ddf453a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seal; bylaws; rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may adopt an official seal which shall be judicially noticed and may make such bylaws, rules, and regulations as it considers necessary to carry out its functions under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ddf453b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Commission shall serve without pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ddf453c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may procure, subject to the availability of funds, temporary and intermittent services to the same extent as is authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109/b"},"text":"section 3109(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ddf453d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel details","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon request of the Commission, and subject to the availability of funds, the head of any Federal agency may detail to the Commission on a reimbursable basis any of the personnel of such agency to assist the Commission in carrying out its duties under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ddf453e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3702/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative support services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the General Services Administration shall provide to the Commission on a reimbursable basis such administrative support services as the Commission may request to carry out its duties under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ddf453f-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/430/tII/s203"},"text":"Pub. L. 96–430, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1847"},"text":"94 Stat. 1847","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
