{"tag":"section","attrib":{"id":"id0dc77725-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2397"},"text":null,"children":[{"tag":"num","attrib":{"value":"2397"},"text":"§ 2397.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation of private school personnel and children","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dc77726-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2397/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible agency or eligible recipient that uses funds under this chapter for in-service and preservice career and technical education professional development programs for career and technical education teachers, administrators, and other personnel shall, to the extent practicable, upon written request, permit the participation in such programs of career and technical education secondary school teachers, administrators, and other personnel in nonprofit private schools offering career and technical secondary education programs located in the geographical area served by such eligible agency or eligible recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc77727-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2397/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student participation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc77728-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2397/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as prohibited by State or local law, an eligible recipient may, upon written request, use funds made available under this chapter to provide for the meaningful participation, in career and technical education programs and activities, including programs of study, receiving funding under this chapter, of secondary school students attending nonprofit private schools in areas served by the eligible recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc77729-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2397/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible recipient shall consult, upon written request, in a timely and meaningful manner with representatives of nonprofit private schools in areas served by the eligible recipient described in paragraph (1) regarding the meaningful participation, in career and technical education programs and activities, including programs of study, receiving funding under this chapter, of secondary school students attending nonprofit private schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dc7772a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tII/s217"},"text":"Pub. L. 88–210, title II, § 217","children":[],"tail":", formerly title III, § 317, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/b"},"text":"Pub. L. 109–270, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/744"},"text":"120 Stat. 744","children":[],"tail":"; r