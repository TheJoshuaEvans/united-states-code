{"tag":"section","attrib":{"id":"id0dda8aca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3486"},"text":null,"children":[{"tag":"num","attrib":{"value":"3486"},"text":"§ 3486.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dda8acb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3486/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, as soon as practicable after the close of each fiscal year, make a single, comprehensive report to the President for transmission to the Congress on the activities of the Department during such fiscal year. The report shall include a statement of goals, priorities, and plans for the Department together with an assessment of the progress made toward—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dda8acc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3486/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the attainment of such goals, priorities, and plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dda8acd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3486/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the more effective and efficient management of the Department and the coordination of its functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dda8ace-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3486/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reduction of excessive or burdensome regulation and of unnecessary duplication and fragmentation in Federal education programs,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"accompanied where necessary by recommendations for proposed legislation for the achievement of such objectives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dda8acf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3486/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estimate on non-Federal personnel employed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required by subsection (a) shall also include an estimate of the extent of the non-Federal personnel employed pursuant to contracts entered into by the Department under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3475"},"text":"section 3475 of this title","children":[],"tail":" or under any other authority (including any subcontract thereunder), the number of such contracts and subcontracts pursuant to which non-Federal personnel are employed, and the total cost of those contracts and subcontracts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dda8ad0-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIV/s426"},"text":"Pub. L. 96–88, title IV, § 426","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/688"},"text":"93 Stat. 688","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dda8ad1-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0dda8ad2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0dda8ad3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (a) of this section relating to transmission of report to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and page 80 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
