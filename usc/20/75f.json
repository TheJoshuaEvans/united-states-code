{"tag":"section","attrib":{"id":"id0c799acf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s75f"},"text":null,"children":[{"tag":"num","attrib":{"value":"75f"},"text":"§ 75f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director; appointment and compensation; officers and employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c799ad0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s75f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board may appoint and fix the compensation and duties of a director of the Gallery, and his appointment and salary shall not be subject to the civil-service laws or chapter 51 and subchapter III of chapter 53 of title 5. The Board may employ such other officers and employees as may be necessary for the efficient administration, operation, and maintenance of the Gallery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c799ad1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s75f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board may delegate to the Secretary of the Smithsonian Institution, as well as to the Commission, any of its functions pursuant to subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c799ad2-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/443/s7"},"text":"Pub. L. 87–443, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-04-27"},"text":"Apr. 27, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/63"},"text":"76 Stat. 63","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c799ad3-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c799ad4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0c799ad5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a), “chapter 51 and subchapter III of chapter 53 of title 5” substituted for “the Classification Act of 1949, as amended” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s7/b"},"text":"Pub. L. 89–554, § 7(b)","children":[],"tail":" "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/631"},"text":"80 Stat. 631","children":[],"tail":", the first section of which enacted Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
