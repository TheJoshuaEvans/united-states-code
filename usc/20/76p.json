{"tag":"section","attrib":{"id":"id0c80c69e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76p"},"text":null,"children":[{"tag":"num","attrib":{"value":"76p"},"text":"§ 76p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance and disposition of gifts to the United States contributed in honor or memory of the late President John F. Kennedy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury is authorized to accept on behalf of the United States any gift to the United States which the Secretary finds has been contributed in honor of or in memory of the late President John F. Kennedy and to pay the money to such appropriation or other accounts, including the appropriation accounts established pursuant to appropriations authorized by this subchapter, as in the judgment of the Secretary will best effectuate the intent of the donor.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c80c69f-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/874/s10"},"text":"Pub. L. 85–874, § 10","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/88/260/s1/6"},"text":"Pub. L. 88–260, § 1(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-01-23"},"text":"Jan. 23, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/5"},"text":"78 Stat. 5","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/279/s6"},"text":"Pub. L. 103–279, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-21"},"text":"July 21, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1415"},"text":"108 Stat. 1415","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c80c6a0-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c80c6a1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0c80c6a2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/279"},"text":"Pub. L. 103–279","children":[],"tail":" substituted “which the Secretary finds” for “which he finds” and “the judgment of the Secretary” for “his judgment”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
