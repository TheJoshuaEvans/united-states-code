{"tag":"section","attrib":{"id":"id0e54273f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7945"},"text":null,"children":[{"tag":"num","attrib":{"value":"7945"},"text":"§ 7945.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption and election of State nonapplicability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e542740-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7945/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subpart preempts the laws of any State to the extent that such laws are inconsistent with this subpart, except that this subpart shall not preempt any State law that provides additional protection from liability relating to teachers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e542741-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7945/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of State regarding nonapplicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subpart shall not apply to any civil action in a State court against a teacher with respect to claims arising within that State if such State enacts a statute in accordance with State requirements for enacting legislation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e542742-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7945/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" citing the authority of this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e542743-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7945/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" declaring the election of such State that this subpart shall not apply, as of a date certain, to such civil action in the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e542744-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7945/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" containing no other provisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e542745-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8555"},"text":"Pub. L. 89–10, title VIII, § 8555","children":[],"tail":", formerly title II, § 2365, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tII/s201"},"text":"Pub. L. 107–110, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1668"},"text":"115 Stat. 1668","children":[],"tail":"; renumbered title IX, § 9545, renumbered title VIII, § 8555, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tII/s2001/a/3/A"},"text":"Pub. L. 114–95, title II, § 2001(a)(3)(A)","children":[],"tail":", (B), (D), title VIII, § 8001(a)(7), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1913"},"text":"129 Stat. 1913","children":[],"tail":", 2088, 2089.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e542746-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e542747-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0e542748-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6735"},"text":"section 6735 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
