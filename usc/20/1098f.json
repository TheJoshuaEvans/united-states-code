{"tag":"section","attrib":{"id":"id0d63368a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1098f"},"text":"§ 1098f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deferral of loan repayment following active duty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d63368b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deferral of loan repayment following active duty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any deferral of repayment of a loan made under this subchapter pursuant to section 1078(b)(1)(M)(iii), 1087e(f)(2)(C), or 1087dd(c)(2)(A)(iii) of this title, a borrower of a loan under this subchapter who is a member of the National Guard or other reserve component of the Armed Forces of the United States, or a member of such Armed Forces in a retired status, is called or ordered to active duty, and is enrolled, or was enrolled within six months prior to the activation, in a program of instruction at an eligible institution, shall be eligible for a deferment during the 13 months following the conclusion of such service, except that a deferment under this subsection shall expire upon the borrower’s return to enrolled student status.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d63368c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Active duty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1088/d"},"text":"section 1088(d) of this title","children":[],"tail":", in this section, the term “active duty” has the meaning given such term in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/d/1"},"text":"section 101(d)(1) of title 10","children":[],"tail":", except that such term—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d63368d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include active duty for training or attendance at a service school; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d63368e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes, in the case of members of the National Guard, active State duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d63368f-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s493D"},"text":"Pub. L. 89–329, title IV, § 493D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/84/tII/s204"},"text":"Pub. L. 110–84, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/795"},"text":"121 Stat. 795","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d633690-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d633691-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d633692-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2007-10-01"},"text":"Oct. 1, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/84/s1/c"},"text":"section 1(c) of Pub. L. 110–84","children":[],"tail":", set out as an Effective Date of 2007 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a"},"text":"section 1070a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
