{"tag":"section","attrib":{"id":"id0d6f1e68-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1128"},"text":null,"children":[{"tag":"num","attrib":{"value":"1128"},"text":"§ 1128.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable distribution of certain funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d6f1e69-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1128/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make excellence the criterion for selection of grants awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1122"},"text":"section 1122 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6f1e6a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1128/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable and consistent with the criterion of excellence, the Secretary shall award grants under this part (other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1122"},"text":"section 1122 of this title","children":[],"tail":") in such a manner as will achieve an equitable distribution of funds throughout the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6f1e6b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1128/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for undergraduate education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall also award grants under this part in such manner as to ensure that an appropriate portion of the funds appropriated for this part (as determined by the Secretary) are used to support undergraduate education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6f1e6c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s608"},"text":"Pub. L. 89–329, title VI, § 608","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVI/s601"},"text":"Pub. L. 105–244, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1782"},"text":"112 Stat. 1782","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d6f1e6d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d6f1e6e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d6f1e6f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1128, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s610A"},"text":"Pub. L. 89–329, title VI, § 610A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tVI/s601"},"text":"Pub. L. 102–325, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/728"},"text":"106 Stat. 728","children":[],"tail":", authorized appropriations for this part, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1128, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s608"},"text":"Pub. L. 89–329, title VI, § 608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1265"},"text":"79 Stat. 1265","children":[],"tail":", provided the process of judicial review in event of State dissatisfaction in equipment grant program, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/96/374"},"text":"Pub. L. 96–374","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s608"},"text":"section 608 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1125b"},"text":"section 1125b of this title","children":[],"tail":", prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
