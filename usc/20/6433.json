{"tag":"section","attrib":{"id":"id0e13c287-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6433"},"text":null,"children":[{"tag":"num","attrib":{"value":"6433"},"text":"§ 6433.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State reallocation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If a State educational agency determines that a State agency does not need the full amount of the subgrant for which such State agency is eligible under this subpart for any fiscal year, the State educational agency may reallocate the amount that will not be needed to other eligible State agencies that need additional funds to carry out the purpose of this part, in such amounts as the State educational agency shall determine.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e13c288-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1413"},"text":"Pub. L. 89–10, title I, § 1413","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1582"},"text":"115 Stat. 1582","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e13c289-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e13c28a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e13c28b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"