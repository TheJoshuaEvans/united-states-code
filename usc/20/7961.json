{"tag":"section","attrib":{"id":"id0e542782-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7961"},"text":null,"children":[{"tag":"num","attrib":{"value":"7961"},"text":"§ 7961.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gun-free requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e542783-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7961/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subpart may be cited as the “Gun-Free Schools Act”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e542784-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7961/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e542785-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7961/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State receiving Federal funds under any subchapter of this chapter shall have in effect a State law requiring local educational agencies to expel from school for a period of not less than 1 year a student who is determined to have brought a firearm to a school, or to have possessed a firearm at a school, under the jurisdiction of local educational agencies in that State, except that such State law shall allow the chief administering officer of a local educational agency to modify such expulsion requirement for a student on a case-by-case basis if such modification is in writing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e542786-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7961/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subpart shall be construed to prevent a State from allowing a local educational agency that has expelled a student from such a student’s regular school setting from providing educational services to such student in an alternative setting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e542787-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7961/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this section, the term “firearm” has the same meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s921/a"},"text":"section 921(a) of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e542788-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7961/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall be construed in a manner consistent with the Individuals with Disabilities Education Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"20 U.S.C. 1400","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e542789-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7961/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each local educational agency requesting assistance from the State educational agency that is to be provided from funds made available to the State under any subchapter of this chapter shall provide to the State, in the application requesting such assistance—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e54278a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7961/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that such local educational agency is in compliance with the State law required by subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e54278b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7961/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the circumstances surrounding any expulsions imposed under the State law required by subsection (b), including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e54278c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7961/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the school concerned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e54278d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7961/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of students expelled from such school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e54278e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7961/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of firearms concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e54278f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7961/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State shall report the information described in subsection (d) to the Secretary on an annual basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e542790-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7961/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of subsection (d), the term “school” means any setting that is under the control and supervision of the local educational agency for the purpose of student activities approved and authorized by the local educational agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e542791-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7961/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall apply to a firearm that is lawfully stored inside a locked vehicle on school property, or if it is for activities approved and authorized by the local educational agency and the local educational agency adopts appropriate safeguards to ensure student safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e542792-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7961/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy regarding criminal justice system referral","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e542793-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7961/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds shall be made available under any subchapter of this chapter to any local educational agency unless such agency has a policy requiring referral to the criminal justice or juvenile delinquency system of any student who brings a firearm or weapon to a school served by such agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e542794-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7961/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this subsection, the term “school” has the same meaning given to such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s921/a"},"text":"section 921(a) of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e542795-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8561"},"text":"Pub. L. 89–10, title VIII, § 8561","children":[],"tail":", formerly title IV, § 4141, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIV/s401"},"text":"Pub. L. 107–110, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1762"},"text":"115 Stat. 1762","children":[],"tail":"; renumbered title IX, § 9551, renumbered title VIII, § 8561, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4001/a/2/A"},"text":"Pub. L. 114–95, title IV, § 4001(a)(2)(A)","children":[],"tail":", (B), (D), title VIII, § 8001(a)(8), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1966"},"text":"129 Stat. 1966","children":[],"tail":", 2088, 2089.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e542796-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e542797-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e542798-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Individuals with Disabilities Education Act, referred to in subsec. (c), is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230"},"text":"Pub. L. 91–230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/175"},"text":"84 Stat. 175","children":[],"tail":", which is classified generally to chapter 33 (§ 1400 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0e542799-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7151"},"text":"section 7151 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
