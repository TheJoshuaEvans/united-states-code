{"tag":"section","attrib":{"id":"id0e1aee5e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631"},"text":null,"children":[{"tag":"num","attrib":{"value":"6631"},"text":"§ 6631.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes; definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e1aee5f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this subpart are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1aee60-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist States, local educational agencies, and nonprofit organizations to develop, implement, improve, or expand comprehensive performance-based compensation systems or human capital management systems for teachers, principals, or other school leaders (especially for teachers, principals, or other school leaders in high-need schools) who raise student academic achievement and close the achievement gap between high- and low-performing students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aee61-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to study and review performance-based compensation systems or human capital management systems for teachers, principals, or other school leaders to evaluate the effectiveness, fairness, quality, consistency, and reliability of the systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1aee62-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subpart:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1aee63-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1aee64-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local educational agency, including a charter school that is a local educational agency, or a consortium of local educational agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aee65-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State educational agency or other State agency designated by the chief executive of a State to participate under this subpart;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aee66-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Indian Education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aee67-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a partnership consisting of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e1aee68-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more agencies described in subparagraph (A), (B), or (C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e1aee69-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 nonprofit or for-profit entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aee6a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-need school","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “high-need school” means a public elementary school or secondary school that is located in an area in which the percentage of students from families with incomes below the poverty line is 30 percent or more.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aee6b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Human capital management system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “human capital management system” means a system—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1aee6c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by which a local educational agency makes and implements human capital decisions, such as decisions on preparation, recruitment, hiring, placement, retention, dismissal, compensation, professional development, tenure, and promotion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aee6d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that includes a performance-based compensation system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aee6e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance-based compensation system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “performance-based compensation system” means a system of compensation for teachers, principals, or other school leaders—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1aee6f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that differentiates levels of compensation based in part on measurable increases in student academic achievement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aee70-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e1aee71-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" differentiated levels of compensation, which may include bonus pay, on the basis of the employment responsibilities and success of effective teachers, principals, or other school leaders in hard-to-staff schools or high-need subject areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e1aee72-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recognition of the skills and knowledge of teachers, principals, or other school leaders as demonstrated through—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e1aee73-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631/b/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" successful fulfillment of additional responsibilities or job functions, such as teacher leadership roles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e1aee74-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6631/b/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence of professional achievement and mastery of content knowledge and superior teaching and leadership skills.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e1aee75-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2211"},"text":"Pub. L. 89–10, title II, § 2211","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tII/s2002"},"text":"Pub. L. 114–95, title II, § 2002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1931"},"text":"129 Stat. 1931","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e1aee76-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e1aee77-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e1aee78-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6631, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2131"},"text":"Pub. L. 89–10, title II, § 2131","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tII/s201"},"text":"Pub. L. 107–110, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1633"},"text":"115 Stat. 1633","children":[],"tail":", defined terms in subpart 3 of part A of former subchapter II of this chapter, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"Pub. L. 114–95, § 5","children":[],"tail":", title II, § 2002, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1806"},"text":"129 Stat. 1806","children":[],"tail":", 1913, effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s2211"},"text":"section 2211 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6651"},"text":"section 6651 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e1aee79-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e1aee7a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
