{"tag":"section","attrib":{"id":"id0dd35da2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3404"},"text":null,"children":[{"tag":"num","attrib":{"value":"3404"},"text":"§ 3404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter, unless otherwise provided or indicated by the context—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dd35da3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3404/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Department” means the Department of Education or any component thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd35da4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3404/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd35da5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3404/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Deputy Secretary” means the Deputy Secretary of Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd35da6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3404/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “function” includes any duty, obligation, power, authority, responsibility, right, privilege, activity, or program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd35da7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3404/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” includes the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, American Samoa, the Northern Mariana Islands, and the Trust Territory of the Pacific Islands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd35da8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3404/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “private” and “private educational” refer to independent, nonpublic, and private institutions of elementary, secondary, and postsecondary education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd35da9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3404/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “office” includes any office, institute, council, unit, organizational entity, or component thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dd35daa-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tI/s104"},"text":"Pub. L. 96–88, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/671"},"text":"93 Stat. 671","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tI/s112/a/3/A"},"text":"Pub. L. 101–509, title V, § 529 [title I, § 112(a)(3)(A)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1454.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dd35dab-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dd35dac-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0dd35dad-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":" substituted “Deputy Secretary” for “Under Secretary” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0dd35dae-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0dd35daf-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment; Continued Service by Incumbents","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tI/s112/e"},"text":"Pub. L. 101–509, title V, § 529 [title I, § 112(e)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1455, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/509/tV/s529/tI/s112/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section [amending this section, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3412"},"text":"section 3412 of this title","children":[],"tail":", sections 5313 and 5314 of Title 5, Government Organization and Employees, "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s472a"},"text":"section 472a of Title 25","children":[],"tail":", Indians, "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3533"},"text":"section 3533 of Title 42","children":[],"tail":", The Public Health and Welfare, and "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1452"},"text":"section 1452 of Title 43","children":[],"tail":", Public Lands and enacting provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3501"},"text":"section 3501 of Title 42","children":[],"tail":"] shall take effect on the first day of the first pay period that begins on or after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The incumbent in the position of Under Secretary of Health and Human Services on the day immediately preceding the date this section takes effect may serve as Deputy Secretary of Health and Human Services at the pleasure of the President after such day.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The incumbent in the position of Under Secretary of the Interior on the day immediately preceding the date this section takes effect may serve as Deputy Secretary of the Interior at the pleasure of the President after such day.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The incumbent in the position of Under Secretary of Education on the day immediately preceding the date this section takes effect may serve as Deputy Secretary of Education at the pleasure of the President after such day.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The incumbent in the position of Under Secretary of Housing and Urban Development on the day immediately preceding the date this section takes effect may serve as Deputy Secretary of Housing and Urban Development at the pleasure of the President after such day.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0dd35db0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of References","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tI/s112/c"},"text":"Pub. L. 101–509, title V, § 529 [title I, § 112(c)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1454, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/509/tV/s529/tI/s112/c"},"text":"“Any reference in any statute, reorganization plan, regulation, executive order, or any document issued pursuant thereto in force on the date this section takes effect [see Effective Date of 1990 Amendment; Continued Service by Incumbents note above] to the Under Secretary of Health and Human Services, the Under Secretary of the Interior, the Under Secretary of Education, or the Under Secretary of Housing and Urban Development shall be deemed to be a reference to the Deputy Secretary of Health and Human Services, the Deputy Secretary of the Interior, the Deputy Secretary of Education, or the Deputy Secretary of Housing and Urban Development, respectively.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id0dd35db1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0dd35db2-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
