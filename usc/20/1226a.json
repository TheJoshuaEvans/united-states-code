{"tag":"section","attrib":{"id":"id0d90892e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1226a"},"text":"§ 1226a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contingent extension of programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d90892f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automatic extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authorization of appropriations for, or duration of, an applicable program shall be automatically extended for one additional fiscal year unless Congress, in the regular session that ends prior to the beginning of the terminal fiscal year of such authorization or duration, has passed legislation that becomes law and extends or repeals the authorization or duration of such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d908930-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount authorized to be appropriated for the period of automatic extension under subsection (a) of an applicable program shall be the amount authorized to be appropriated for such program for the terminal fiscal year of the applicable program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d908931-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acts and determinations necessary for program continuation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary is required, in the terminal fiscal year of an applicable program, to carry out certain acts or make certain determinations that are necessary for the continuation of such program, such acts or determinations shall be required to be carried out or made during the period of automatic extension under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d908932-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to commissions, councils, and committees required by law to terminate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to the authorization of appropriations for a commission, council, or committee which is required by an applicable statute to terminate on a date certain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d908933-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/tIV/s422"},"text":"Pub. L. 90–247, title IV, § 422","children":[],"tail":", formerly § 414, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/380/tV/s506/a/2/B"},"text":"Pub. L. 93–380, title V, § 506(a)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/563"},"text":"88 Stat. 563","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tXIII/s1301"},"text":"Pub. L. 96–374, title XIII, § 1301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1496"},"text":"94 Stat. 1496","children":[],"tail":"; renumbered § 422 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tII"},"text":"Pub. L. 103–382, title II","children":[],"tail":", §§ 212(b)(1), 233, "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3913"},"text":"108 Stat. 3913","children":[],"tail":", 3915.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d908934-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d908935-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d908936-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/s422"},"text":"section 422 of Pub. L. 90–247","children":[],"tail":" was renumbered section 431, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1231a"},"text":"section 1231a of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/s422"},"text":"section 422 of Pub. L. 90–247","children":[],"tail":" was renumbered section 438, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232a"},"text":"section 1232a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d908937-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/s233"},"text":"Pub. L. 103–382, § 233","children":[],"tail":", amended section generally, revising and restating former subsecs. (a) and (b) as subsecs. (a) to (c) and adding subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/374"},"text":"Pub. L. 96–374","children":[],"tail":" inserted provisions for the automatic extension of an authorization or duration of two additional fiscal years for any applicable program authorized to be included in the Appropriation Act for the fiscal year preceding the fiscal year for which appropriations are available for obligation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d908938-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d908939-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/374"},"text":"Pub. L. 96–374","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/s1393/a"},"text":"section 1393(a) of Pub. L. 96–374","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0d90893a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Additional Extensions Not Permitted","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/105/s2/c"},"text":"Pub. L. 114–105, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2220"},"text":"129 Stat. 2220","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/105/s2/c"},"text":"“Section 422 of the General Education Provisions Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1226a"},"text":"20 U.S.C. 1226a","children":[],"tail":") shall not apply to further extend the duration of the authority under paragraph (1) of section 461(b) of the Higher Education Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087aa/b"},"text":"20 U.S.C. 1087aa(b)","children":[],"tail":"), as amended by subsection (a)(1) of this section, beyond "},{"tag":"date","attrib":{"date":"2017-09-30"},"text":"September 30, 2017","children":[],"tail":", on the basis of the extension under such subsection.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0d90893b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Indochinese Refugee Children Education Assistance Programs; Applicability of Contingent Extension Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Applicability of contingent extension provisions to any program of financial assistance for educational purposes for Indochinese refugee children, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/482/s327"},"text":"section 327 of Pub. L. 94–482","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1225"},"text":"section 1225 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0d90893c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitation on Extension of Programs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/328/s2/d"},"text":"Pub. L. 94–328, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/727"},"text":"90 Stat. 727","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/328/s2/d"},"text":"“The amendments made by this section [amending sections 1070a, 1074, 1078 and 1078a of this title] shall not be deemed to authorize the automatic extension of the programs so amended, under section 414 [now 422] of the General Education Provisions Act [this section], beyond the date specified in such amendments.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
