{"tag":"section","attrib":{"id":"id0ddcd42e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3508"},"text":null,"children":[{"tag":"num","attrib":{"value":"3508"},"text":"§ 3508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Health and Human Services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ddcd42f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redesignation of Department of Health, Education, and Welfare","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department of Health, Education, and Welfare is hereby redesignated the Department of Health and Human Services, and the Secretary of Health, Education, and Welfare or any other official of the Department of Health, Education, and Welfare is hereby redesignated the Secretary or official, as appropriate, of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ddcd430-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reference to Department, Secretary, etc., of Health, Education, and Welfare deemed reference to Department, Secretary, etc., of Health and Human Services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference to the Department of Health, Education, and Welfare, the Secretary of Health, Education, and Welfare, or any other official of the Department of Health, Education, and Welfare in any law, rule, regulation, certificate, directive, instruction, or other official paper in force on ","children":[{"tag":"date","attrib":{"date":"1980-05-04"},"text":"May 4, 1980","children":[],"tail":", shall be deemed to refer and apply to the Department of Health and Human Services or the Secretary of Health and Human Services, respectively, except to the extent such reference is to a function or office transferred to the Secretary or the Department under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ddcd431-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509"},"text":"Pub. L. 96–88, title V, § 509","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s6/b"},"text":"Pub. L. 107–217, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1304"},"text":"116 Stat. 1304","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/178/s2/b/2"},"text":"Pub. L. 108–178, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-15"},"text":"Dec. 15, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2640"},"text":"117 Stat. 2640","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ddcd432-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ddcd433-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0ddcd434-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b), “","children":[{"tag":"date","attrib":{"date":"1980-05-04"},"text":"May 4, 1980","children":[],"tail":"” substituted for “the effective date of this chapter” pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/s601"},"text":"section 601 of Pub. L. 96–88","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3401"},"text":"section 3401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0ddcd435-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/178"},"text":"Pub. L. 108–178","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s6/b"},"text":"Pub. L. 107–217, § 6(b)","children":[],"tail":". See 2002 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s6/b"},"text":"Pub. L. 107–217, § 6(b)","children":[],"tail":", which had repealed subsec. (b) of this section, was itself repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/108/178"},"text":"Pub. L. 108–178","children":[],"tail":" insofar as it related to subsec. (b) of this section, and "},{"tag":"ref","attrib":{"href":"/us/pl/108/178"},"text":"Pub. L. 108–178","children":[],"tail":" further provided that subsec. (b) of this section was revived to read as if "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s6/b"},"text":"Pub. L. 107–217, § 6(b)","children":[],"tail":", had not been enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0ddcd436-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0ddcd437-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/178"},"text":"Pub. L. 108–178","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/178/s5"},"text":"section 5 of Pub. L. 108–178","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5334"},"text":"section 5334 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
