{"tag":"section","attrib":{"id":"id0d895d9a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161s"},"text":"§ 1161s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program to promote training and job placement of realtime writers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d895d9b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d895d9c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amounts appropriated to carry out this section, the Secretary shall award grants, on a competitive basis, to eligible entities under paragraph (2) to promote training and placement of individuals, including individuals who have completed a court reporting training program, as realtime writers in order to meet the requirements for closed captioning of video programming set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s613"},"text":"section 613 of title 47","children":[],"tail":" and the rules prescribed thereunder."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895d9d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, an eligible entity is a court reporting program that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895d9e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a curriculum capable of training realtime writers qualified to provide captioning services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895d9f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is accredited by an accrediting agency or association recognized by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895da0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is participating in student aid programs under subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895da1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority in grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether to make grants under this section, the Secretary shall give a priority to eligible entities that, as determined by the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895da2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possess the most substantial capability to increase their capacity to train realtime writers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895da3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate the most promising collaboration with educational institutions, businesses, labor organizations, or other community groups having the potential to train or provide job placement assistance to realtime writers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895da4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" propose the most promising and innovative approaches for initiating or expanding training or job placement assistance efforts with respect to realtime writers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895da5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this section shall be for a period of up to five years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895da6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a grant provided under this subsection to an eligible entity may not exceed $1,500,000 for the period of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895da7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d895da8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To receive a grant under subsection (a), an eligible entity shall submit an application to the Secretary at such time and in such manner as the Secretary may require. The application shall contain the information set forth under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895da9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Information in the application of an eligible entity for a grant under subsection (a) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895daa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the training and assistance to be funded using the grant amount, including how such training and assistance will increase the number of realtime writers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895dab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of performance measures to be utilized to evaluate the progress of individuals receiving such training and assistance in matters relating to enrollment, completion of training, and job placement and retention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895dac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the manner in which the eligible entity will ensure that recipients of scholarships, if any, funded by the grant will be employed and retained as realtime writers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895dad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the manner in which the eligible entity intends to continue providing the training and assistance to be funded by the grant after the end of the grant period, including any partnerships or arrangements established for that purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895dae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of how the eligible entity will work with local boards (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"section 3102 of title 29","children":[],"tail":") to ensure that training and assistance to be funded with the grant will further local workforce goals, including the creation of educational opportunities for individuals who are from economically disadvantaged backgrounds or are displaced workers."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895daf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Additional information, if any, on the eligibility of the eligible entity for priority in the making of grants under subsection (a)(3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895db0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895db1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d895db2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity receiving a grant under subsection (a) shall use the grant amount for purposes relating to the recruitment, training and assistance, and job placement of individuals, including individuals who have completed a court reporting training program, as realtime writers, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895db3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruitment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895db4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraph (2), the provision of scholarships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895db5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distance learning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895db6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" further developing and implementing both English and Spanish curricula to more effectively train individuals in realtime writing skills, and education in the knowledge necessary for the delivery of high quality closed captioning services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895db7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mentoring students to ensure successful completion of the realtime training and providing assistance in job placement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895db8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging individuals with disabilities to pursue a career in realtime writing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895db9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employment and payment of personnel for the purposes described in this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895dba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarships","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895dbb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a scholarship under paragraph (1)(B) shall be based on the amount of need of the scholarship recipient for financial assistance, as determined in accordance with part F of subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895dbc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient of a scholarship under paragraph (1)(B) shall enter into an agreement with the school in which the recipient is enrolled to provide realtime writing services for the purposes described in subsection (a)(1) for a period of time appropriate (as determined by the Secretary) for the amount of the scholarship received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895dbd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coursework and employment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish requirements for coursework and employment for recipients of scholarships under paragraph (1)(B), including requirements for repayment of scholarship amounts in the event of failure to meet such requirements for coursework and employment. The Secretary may waive, in whole or in part, the requirements for repayment of scholarship amounts on the basis of economic conditions which may affect the ability of scholarship recipients to find work as realtime writers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895dbe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The recipient of a grant under this section may not use more than five percent of the grant amount to pay administrative costs associated with activities funded by the grant. The Secretary shall use not more than five percent of the amount available for grants under this section in any fiscal year for administrative costs of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895dbf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grant amounts under this section shall supplement and not supplant other Federal or non-Federal funds of the grant recipient for purposes of promoting the training and placement of individuals as realtime writers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895dc0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d895dc1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible entity receiving a grant under subsection (a) shall submit to the Secretary, at the end of the grant period, a report on the activities of such entity with respect to the use of grant amounts during the grant period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895dc2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report of an eligible entity under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895dc3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment by the entity of the effectiveness of activities carried out using such funds in increasing the number of realtime writers, using the performance measures submitted by the eligible entity in the application for the grant under subsection (b)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895dc4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the best practices identified by the eligible entity for increasing the number of individuals who are trained, employed, and retained in employment as realtime writers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895dc5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall summarize the reports submitted under paragraph (2) and make such summary available on the Department’s website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895dc6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161s/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d895dc7-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s872"},"text":"Pub. L. 89–329, title VIII, § 872","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3426"},"text":"122 Stat. 3426","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tV/s512/n/7"},"text":"Pub. L. 113–128, title V, § 512(n)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1711"},"text":"128 Stat. 1711","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d895dc8-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d895dc9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note