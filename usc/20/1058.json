{"tag":"section","attrib":{"id":"id0cd1cc80-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058"},"text":null,"children":[{"tag":"num","attrib":{"value":"1058"},"text":"§ 1058.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions; eligibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cd1cc81-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational and general expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this part, the term “educational and general expenditures” means the total amount expended by an institution of higher education for instruction, research, public service, academic support (including library expenditures), student services, institutional support, scholarships and fellowships, operation and maintenance expenditures for the physical plant, and any mandatory transfers which the institution is required to pay by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd1cc82-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this part, the term “eligible institution” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd1cc83-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an institution of higher education—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd1cc84-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which has an enrollment of needy students as required by subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1cc85-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1068a/b"},"text":"section 1068a(b) of this title","children":[],"tail":", the average educational and general expenditures of which are low, per full-time equivalent undergraduate student, in comparison with the average educational and general expenditures per full-time equivalent undergraduate student of institutions that offer similar instruction;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1cc86-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cd1cc87-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legally authorized to provide, and provides within the State, an educational program for which such institution awards a bachelor’s degree;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cd1cc88-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a junior or community college; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cd1cc89-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the College of the Marshall Islands, the College of Micronesia/Federated States of Micronesia, and Palau Community College;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1cc8a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is accredited by a nationally recognized accrediting agency or association determined by the Secretary to be reliable authority as to the quality of training offered or which is, according to such an agency or association, making reasonable progress toward accreditation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1cc8b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which meets such other requirements as the Secretary may prescribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1cc8c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located in a State; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cc8d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any branch of any institution of higher education described under paragraph (1) which by itself satisfies the requirements contained in subparagraphs (A) and (B) of such paragraph.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of the determination of whether an institution is an eligible institution under this paragraph,","children":[{"tag":"ref","attrib":{"idref":"fn002035"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002035"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection,”."}],"tail":" the factor described under paragraph (1)(A) shall be given twice the weight of the factor described under paragraph (1)(B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd1cc8e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Endowment fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this part, the term “endowment fund” means a fund that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd1cc8f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is established by State law, by an institution of higher education, or by a foundation that is exempt from Federal income taxation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cc90-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is maintained for the purpose of generating income for the support of the institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cc91-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include real estate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd1cc92-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment of needy students","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059e/b"},"text":"section 1059e(b) of this title","children":[],"tail":", for the purpose of this part, the term “enrollment of needy students” means an enrollment at an institution of higher education or a junior or community college which includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd1cc93-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 50 percent of the degree students so enrolled who are receiving need-based assistance under subchapter IV of this chapter in the second fiscal year preceding the fiscal year for which the determination is being made (other than loans for which an interest subsidy is paid pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078"},"text":"section 1078 of this title","children":[],"tail":"), or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cc94-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substantial percentage of students receiving Pell Grants in the second fiscal year preceding the fiscal year for which determination is being made, in comparison with the percentage of students receiving Pell Grants at all such institutions in the second fiscal year preceding the fiscal year for which the determination is made, unless the requirement of this paragraph is waived under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1068a/a"},"text":"section 1068a(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd1cc95-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full-time equivalent students","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this part, the term “full-time equivalent students” means the sum of the number of students enrolled full time at an institution, plus the full-time equivalent of the number of students enrolled part time (determined on the basis of the quotient of the sum of the credit hours of all part-time students divided by 12) at such institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd1cc96-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Junior or community college","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this part, the term “junior or community college” means an institution of higher education—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd1cc97-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that admits as regular students persons who are beyond the age of compulsory school attendance in the State in which the institution is located and who have the ability to benefit from the training offered by the institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cc98-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that does not provide an educational program for which it awards a bachelor’s degree (or an equivalent degree); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cc99-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd1cc9a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides an educational program of not less than 2 years that is acceptable for full credit toward such a degree, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1cc9b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offers a 2-year program in engineering, mathematics, or the physical or biological sciences, designed to prepare a student to work as a technician or at the semiprofessional level in engineering, scientific, or other technological fields requiring the understanding and application of basic engineering, scientific, or mathematical principles of knowledge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd1cc9c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-income individual","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this part, the term “low-income individual” means an individual from a family whose taxable income for the preceding year did not exceed 150 percent of an amount equal to the poverty level determined by using criteria of poverty established by the Bureau of the Census.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd1cc9d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1058/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historically black college or university","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, no historically black college or university which is eligible for and receives funds under part B of this subchapter is eligible for or may receive funds under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cd1cc9e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s312"},"text":"Pub. L. 89–329, title III, § 312","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIII/s301/a"},"text":"Pub. L. 99–498, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1292"},"text":"100 Stat. 1292","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/50/s2/a/2"},"text":"Pub. L. 100–50, § 2(a)(2)","children":[],"tail":"–(6), "},{"tag":"date","attrib":{"date":"1987-06-03"},"text":"June 3, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/335"},"text":"101 Stat. 335","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/369/s10/a"},"text":"Pub. L. 100–369, § 10(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-07-18"},"text":"July 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/837"},"text":"102 Stat. 837","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIII/s302/a"},"text":"Pub. L. 102–325, title III, § 302(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/472"},"text":"106 Stat. 472","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/a/5"},"text":"Pub. L. 103–208, § 2(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2457"},"text":"107 Stat. 2457","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s353"},"text":"Pub. L. 103–382, title III, § 353","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3966"},"text":"108 Stat. 3966","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIII"},"text":"Pub. L. 105–244, title III","children":[],"tail":", §§ 301(c)(2), 303(b), "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1636"},"text":"112 Stat. 1636","children":[],"tail":", 1639; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIII"},"text":"Pub. L. 110–315, title III","children":[],"tail":", §§ 302, 305(b), "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3167"},"text":"122 Stat. 3167","children":[],"tail":", 3173.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cd1cc9f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cd1cca0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cd1cca1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1058, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s312"},"text":"Pub. L. 89–329, title III, § 312","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tIII/s301"},"text":"Pub. L. 96–374, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1391"},"text":"94 Stat. 1391","children":[],"tail":", defined terms used in this subchapter, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cd1cca2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s302/1"},"text":"Pub. L. 110–315, § 302(1)","children":[],"tail":", substituted “subsection (d)” for “subsection (c) of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s305/b"},"text":"Pub. L. 110–315, § 305(b)","children":[],"tail":", substituted “Except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059e/b"},"text":"section 1059e(b) of this title","children":[],"tail":", for the purpose” for “For the purpose” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s302/2"},"text":"Pub. L. 110–315, § 302(2)","children":[],"tail":", substituted “paragraph” for “subdivision”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s302/3"},"text":"Pub. L. 110–315, § 302(3)","children":[],"tail":", (4), added subsec. (g) and redesignated former subsec. (g) as (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s301/c/2/A"},"text":"Pub. L. 105–244, § 301(c)(2)(A)","children":[],"tail":", substituted “section 1068a(b)” for “section 1067(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s303/b/2"},"text":"Pub. L. 105–244, § 303(b)(2)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s301/c/2/B"},"text":"Pub. L. 105–244, § 301(c)(2)(B)","children":[],"tail":", substituted “section 1068a(a)” for “section 1067(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s303/b/1"},"text":"Pub. L. 105–244, § 303(b)(1)","children":[],"tail":", redesignated subsecs. (c) to (f) as (d) to (g), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/s353/1"},"text":"Pub. L. 103–382, § 353(1)","children":[],"tail":", amended subpar. (C) generally. Prior to amendment, subpar. (C) read as follows: “(C)(i) which is legally authorized to provide, and provides within the State, an educational program for which it awards a bachelor’s degree, or (ii) which is a junior or community college;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/s353/2"},"text":"Pub. L. 103–382, § 353(2)","children":[],"tail":", (3), added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208"},"text":"Pub. L. 103–208","children":[],"tail":" inserted “the” after “such institutions in”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s302/a/1"},"text":"Pub. L. 102–325, § 302(a)(1)","children":[],"tail":", (2), inserted “and” at end of subpar. (D), struck out subpar. (E), redesignated subpar. (F) as (E) and inserted “and” at end, and substituted period for semicolon at end of par. (2). Prior to amendment, subpar. (E) of par. (1) read as follows: “except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067/b"},"text":"section 1067(b) of this title","children":[],"tail":" which has, during the 5 academic years preceding the academic year for which it seeks assistance under this part—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) met the requirement of either subparagraph (C)(i) or (C)(ii), or of both such subparagraphs (simultaneously or consecutively); and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) met the requirement of subparagraph (D); and”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s302/a/3"},"text":"Pub. L. 102–325, § 302(a)(3)","children":[],"tail":", struck out pars. (3) to (5) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) any institution of higher education which has an enrollment of which at least 20 percent are Mexican American, Puerto Rican, Cuban, or other Hispanic students, or combination thereof, and which also satisfies the requirements of subparagraphs (A), (B), (C), and (D) of paragraph (1);","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) any institution of higher education which has an enrollment of at least 60 percent American Indian, or in the case of Alaska natives, an enrollment of at least 5 percent, and which also satisfies the requirements of subparagraphs (A), (B), (C), and (D) of paragraph (1); and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) any institution of higher education which has an enrollment of which at least 5 percent are Native Hawaiian, Asian American, American Samoan, Micronesian, Guamian (Chamorro), and Northern Marianian, or any combination thereof, and which also satisfies the requirements of subparagraphs (A), (B), (C), and (D) of paragraph (1).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s302/b"},"text":"Pub. L. 102–325, § 302(b)","children":[],"tail":", substituted “second fiscal year preceding the fiscal year for which the determination is made, unless the requirement” for “second preceding fiscal year, unless the requirement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/369"},"text":"Pub. L. 100–369","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (b)(1)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/50/s2/a/2/A"},"text":"Pub. L. 100–50, § 2(a)(2)(A)","children":[],"tail":", inserted “which” before “is” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/50/s2/a/2/B"},"text":"Pub. L. 100–50, § 2(a)(2)(B)","children":[],"tail":", inserted “which” before “has”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/50/s2/a/2/C"},"text":"Pub. L. 100–50, § 2(a)(2)(C)","children":[],"tail":", inserted “which” before “meets”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/50/s2/a/3"},"text":"Pub. L. 100–50, § 2(a)(3)","children":[],"tail":", (4), substituted “subparagraphs (A), (B), (C), and (D)” for “subparagraphs (A) and (B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/50/s2/a/5"},"text":"Pub. L. 100–50, § 2(a)(5)","children":[],"tail":", inserted “in the second fiscal year preceding the fiscal year for which the determination is being made” after “chapter 34 of title 42”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/50/s2/a/6"},"text":"Pub. L. 100–50, § 2(a)(6)","children":[],"tail":", substituted “fiscal year preceding the fiscal year for which determination is being made” for “preceding fiscal year” and “second preceding fiscal year” for “such fiscal year”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cd1cca3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"tex