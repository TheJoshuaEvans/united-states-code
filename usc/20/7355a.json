{"tag":"section","attrib":{"id":"id0e3505f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7355a"},"text":null,"children":[{"tag":"num","attrib":{"value":"7355a"},"text":"§ 7355a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement, not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds made available under subpart 1 or subpart 2 of this part shall be used to supplement, and not supplant, any other Federal, State, or local education funds.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e3505f7-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5232"},"text":"Pub. L. 89–10, title V, § 5232","children":[],"tail":", formerly title VI, § 6232, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVI/s601"},"text":"Pub. L. 107–110, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1897"},"text":"115 Stat. 1897","children":[],"tail":"; renumbered title V, § 5232, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tV/s5001/a/5"},"text":"Pub. L. 114–95, title V, § 5001(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2039"},"text":"129 Stat. 2039","children":[],"tail":", 2040.)"}],"tail":"\n"}],"tail":null}
