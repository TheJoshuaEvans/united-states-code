{"tag":"section","attrib":{"id":"id0d9c6f50-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1404"},"text":null,"children":[{"tag":"num","attrib":{"value":"1404"},"text":"§ 1404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of equipment; construction or alteration of facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d9c6f51-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that a program authorized under this chapter will be improved by permitting program funds to be used to acquire appropriate equipment, or to construct new facilities or alter existing facilities, the Secretary is authorized to allow the use of those funds for those purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9c6f52-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with certain regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any construction of new facilities or alteration of existing facilities under subsection (a) shall comply with the requirements of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9c6f53-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1404/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appendix A of part 36 of title 28, Code of Federal Regulations (commonly known as the “Americans with Disabilities Accessibility Guidelines for Buildings and 