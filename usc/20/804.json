{"tag":"section","attrib":{"id":"id0c9fc012-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s804"},"text":null,"children":[{"tag":"num","attrib":{"value":"804"},"text":"§ 804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on grants to any one State","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not more than 10 per centum of the total amount appropriated for the purposes of this chapter may be used for making grants to any one State.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c9fc013-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/560/tVII/s805"},"text":"Pub. L. 88–560, title VII, § 805","children":[],"tail":", formerly § 804, "},{"tag":"date","attrib":{"date":"1964-09-02"},"text":"Sept. 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/803"},"text":"78 Stat. 803","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/19/s21/d"},"text":"Pub. L. 90–19, § 21(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-05-25"},"text":"May 25, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/26"},"text":"81 Stat. 26","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/152/tIII/s307"},"text":"Pub. L. 91–152, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-24"},"text":"Dec. 24, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/394"},"text":"83 Stat. 394","children":[],"tail":"; renumbered § 805, "},{"tag":"ref","attrib":{"href":"/us/pl/93/383/tIV/s402/c/1"},"text":"Pub. L. 93–383, title IV, § 402(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/692"},"text":"88 Stat. 692","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c9fc014-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c9fc015-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0c9fc016-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1969—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/152"},"text":"Pub. L. 91–152","children":[],"tail":" substituted provisions that not more than 10 per centum of the total amount appropriated be used for making grants to any one State for provisions that authorized the Secretary to provide technical assistance, etc., to State and local bodies. The former provisions of the section are now set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s805"},"text":"section 805 of this title","children":[],"tail":" with minor amendments."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/19"},"text":"Pub. L. 90–19","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
