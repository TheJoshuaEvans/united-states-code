{"tag":"section","attrib":{"id":"id0c80c6a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"76q–1"},"text":"§ 76q–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" John F. Kennedy Center Plaza","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c80c6a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c80c6a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Air rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “air rights” means real property interests conveyed by deed, lease, or permit for the use of space between streets and alleys within the boundaries of the Project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c80c6a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Center” means the John F. Kennedy Center for the Performing Arts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c80c6a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Green spaces","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “green spaces” means areas within the boundaries of the Project or affected by the Project that are covered by grass, trees, or other vegetation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c80c6aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plaza","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Plaza” means improvements to the area surrounding the John F. Kennedy Center building carried out under the Project and comprised of transportation elements (including roadways, sidewalks, and bicycle lanes) and non-transportation elements (including landscaping, green space, open public space, water, sewer, and utility connections).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c80c6ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Project” means the Plaza project, as described in the TEA–21 report, providing for construction of a Plaza adjacent to the Center and for improved bicycle, pedestrian, and vehicular access to and around the Center. The term includes planning, design, engineering, and construction of the Plaza, buildings to be constructed on the Plaza, and related transportation improvements and may include any other elements of the Project identified in the TEA–21 report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c80c6ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c80c6ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" TEA–21 report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “TEA–21 report” means the report of the Secretary submitted to Congress under section 1214 of the Transportation Equity Act for the 21st Century (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s76j"},"text":"20 U.S.C. 76j","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/stat/112/204"},"text":"112 Stat. 204","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c80c6ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of the Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c80c6af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall be responsible for the Project and may undertake such activities as may be necessary to construct the Project, other than buildings to be constructed on the Plaza, substantially as described in the TEA–21 report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c80c6b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning, design, engineering, and construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall be responsible for the planning, design, engineering, and construction of the Project, other than buildings to be constructed on the Plaza.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c80c6b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements with the Board and other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall enter into memoranda of agreement with the Board and any appropriate Federal or other governmental agency to facilitate the planning, design, engineering, and construction of the Project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c80c6b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with the Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with the Board to maximize efficiencies in planning and executing the Project, including the construction of any buildings on the Plaza.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c80c6b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the approval of the Board, the Secretary may enter into contracts on behalf of the Center related to the planning, design, engineering, and construction of the Project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c80c6b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project Team","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c80c6b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To further construction of the Project, the Secretary shall establish a Project Team.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c80c6b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Project Team shall be composed of the following members:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0c80c6b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/b/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary (or the Secretary’s designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c80c6b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/b/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of General Services (or the Administrator’s designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c80c6b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/b/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman of the Board (or the Chairman’s designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c80c6ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/b/6/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other individuals as the Project Team considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c80c6bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Project Team shall have a Project Director who shall be appointed by the Secretary, in consultation with the Administrator of General Services and the Chairman of the Board. The Project Director shall report directly to the Project Team.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c80c6bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of the Board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c80c6bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board, in consultation with the Project Team, may undertake such activities as may be necessary to construct buildings on the Plaza for the Project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c80c6be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt of transfers of air rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may receive from the District of Columbia such transfers of air rights as may be necessary for the planning, design, engineering, and construction of the Project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c80c6bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of buildings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board, in consultation with the Project Team, may construct, with non-appropriated funds, buildings on the Plaza for the Project and shall be responsible for the planning, design, engineering, and construction of the buildings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c80c6c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acknowledgment of contributions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c80c6c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may acknowledge private contributions used in the construction of buildings on the Plaza for the Project in the interior of the buildings, but may not acknowledge private contributions on the exterior of the buildings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c80c6c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of other requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any acknowledgment of private contributions under this paragraph shall be consistent with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s76j/b"},"text":"section 76j(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c80c6c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval by Project Team","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s76k/e"},"text":"section 76k(e) of this title","children":[],"tail":", any decision by the Board that will significantly affect, as determined by the Project Team in consultation with the Board, the scope, cost, schedule, or engineering feasibility of any element of the Project, other than buildings to be constructed on the Plaza, shall be subject to the approval of the Project Team."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c80c6c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of the District of Columbia","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c80c6c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of highway system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any State or local law, the Mayor of the District of Columbia, in consultation with the National Capital Planning Commission and the Secretary, shall have exclusive authority to amend or modify the permanent system of highways of the District of Columbia as may be necessary to meet the requirements and needs of the Project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c80c6c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conveyances","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c80c6c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any State or local law, the Mayor of the District of Columbia shall have exclusive authority to convey or dispose of any interests in real estate (including air rights or air space as that term is defined by District of Columbia law) owned or controlled by the District of Columbia, as may be necessary to meet the requirements and needs of the Project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c80c6c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conveyance to the Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days following the date of receipt of notification from the Secretary of the requirements and needs of the Project, the Mayor of the District of Columbia shall convey or dispose of to the Board without compensation interests in real estate described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c80c6c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements with the Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Mayor of the District of Columbia shall have the authority to enter into memoranda of agreement with the Board and any Federal or other governmental agency to facilitate the planning, design, engineering, and construction of the Project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c80c6ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ownership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c80c6cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Roadways and sidewalks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon completion of the Project, responsibility for maintenance and oversight of roadways and sidewalks modified or improved for the Project shall remain with the owner of the affected roadways and sidewalks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c80c6cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of green spaces","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (3), upon completion of the Project, responsibility for maintenance and oversight of any green spaces modified or improved for the Project shall remain with the owner of the affected green spaces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c80c6cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Buildings and green spaces on the Plaza","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon completion of the Project, the Board shall own, operate, and maintain the buildings and green spaces established on the Plaza for the Project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c80c6ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National highway boundaries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c80c6cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Realignment of boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may realign national highways related to proposed changes to the Northern and Southern Interchanges and the E Street Approach recommended in the TEA–21 report in order to facilitate the flow of traffic in the vicinity of the Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c80c6d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to Center from I–66","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may improve direct access and egress between Interstate Route 66 and the Center, including its garages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c80c6d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76q–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Until completion of the Project, the Comptroller General shall review the management and oversight of construction of the Project by the Board and report periodically on the results of the review to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Environment and Public Works of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c80c6d2-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/874/s12"},"text":"Pub. L. 85–874, § 12","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/224/s2/2"},"text":"Pub. L. 107–224, § 2(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-18"},"text":"Sept. 18, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1340"},"text":"116 Stat. 1340","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/410/s3"},"text":"Pub. L. 108–410, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2303"},"text":"118 Stat. 2303","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c80c6d3-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c80c6d4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0c80c6d5-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1214 of the Transportation Equity Act for the 21st Century, referred to in subsec. (a)(7), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s1214"},"text":"section 1214 of Pub. L. 105–178","children":[],"tail":", which enacted provisions set out as notes under sections 50 and 76j of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410eeee–16"},"text":"section 410eeee–16 of Title 16","children":[],"tail":", Conservation, and "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s202"},"text":"section 202 of Title 23","children":[],"tail":", Highways, and enacted provisions listed in a table of National Wildlife Refuges set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s668dd"},"text":"section 668dd of Title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0c80c6d6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/874/s12"},"text":"section 12 of Pub. L. 85–874","children":[],"tail":" was renumbered section 13 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s76r"},"text":"section 76r of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0c80c6d7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/410/s3/a"},"text":"Pub. L. 108–410, § 3(a)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/410/s3/b/1"},"text":"Pub. L. 108–410, § 3(b)(1)","children":[],"tail":", (2), inserted “, in consultation with the Project Team,” after “The Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/410/s3/b/3"},"text":"Pub. L. 108–410, § 3(b)(3)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/410/s3/c"},"text":"Pub. L. 108–410, § 3(c)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
