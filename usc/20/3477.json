{"tag":"section","attrib":{"id":"id0dda8a88-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3477"},"text":null,"children":[{"tag":"num","attrib":{"value":"3477"},"text":"§ 3477.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition and maintenance of property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dda8a89-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3477/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized properties; establishment of necessary facilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dda8a8a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3477/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to acquire (by purchase, lease, condemnation, or otherwise), construct, improve, repair, operate, and maintain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dda8a8b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3477/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" schools and related facilities (but only to the extent that operation of schools and related facilities by the Department is authorized by this chapter);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dda8a8c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3477/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dda8a8d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3477/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and testing sites and facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dda8a8e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3477/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quarters and related accommodations for employees and dependents of employees of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dda8a8f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3477/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal property (including patents), or any interest therein,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as may be necessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dda8a90-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3477/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide by contract or otherwise for the establishment of eating facilities and other necessary facilities for the health and welfare of employees of the Department at its installations, and purchase and maintain equipment therefor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dda8a91-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3477/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Day care center facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority available to the Secretary of Health, Education, and Welfare under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2564"},"text":"section 2564 of this title","children":[],"tail":", shall also be available to the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dda8a92-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3477/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special purpose facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority granted by subsection (a) of this section shall be available only with respect to facilities of a special purpose nature that cannot readily be reassigned from similar Federal activities and are not otherwise available for assignment to the Department by the Administrator of General Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dda8a93-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIV/s417"},"text":"Pub. L. 96–88, title IV, § 417","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/685"},"text":"93 Stat. 685","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
