{"tag":"section","attrib":{"id":"id0e13c2c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6435"},"text":null,"children":[{"tag":"num","attrib":{"value":"6435"},"text":"§ 6435.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e13c2c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6435/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e13c2c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6435/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State agency shall use funds received under this subpart only for programs and projects that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e13c2c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6435/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with the State plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6434/a"},"text":"section 6434(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e13c2c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6435/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concentrate on providing participants with the knowledge and skills needed to make a successful transition to secondary school completion, career and technical education, further education, or employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e13c2c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6435/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs and projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such programs and projects—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e13c2c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6435/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e13c2ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6435/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition of equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e13c2cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6435/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay-for-success initiatives; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e13c2cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6435/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing targeted services for youth who have come in contact with both the child welfare system and juvenile justice system;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e13c2cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6435/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be designed to support educational services that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e13c2ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6435/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except for institution-wide projects under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6436"},"text":"section 6436 of this title","children":[],"tail":", are provided to children and youth identified by the State agency as failing, or most at-risk of failing, to meet the challenging State academic standards;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e13c2cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6435/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respond to the educational needs of such children and youth, including by supplementing and improving the quality of the educational services provided to such children and youth by the State agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e13c2d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6435/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" afford such children and youth an opportunity to meet challenging State academic standards; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e13c2d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6435/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be carried out in a manner consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6321"},"text":"section 6321 of this title","children":[],"tail":" and part F (as applied to programs and projects under this part)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e13c2d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6435/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement, not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A program under this subpart that supplements the number of hours of instruction students receive from State and local sources shall be considered to comply with the supplement, not supplant requirement of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6321"},"text":"section 6321 of this title","children":[],"tail":" (as applied to this part) without regard to the subject areas in which instruction is given during those hours."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e13c2d3-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1415"},"text":"Pub. L. 89–10, title I, § 1415","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1585"},"text":"115 Stat. 1585","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tI/s1401/4"},"text":"Pub. L. 114–95, title I, § 1401(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1902"},"text":"129 Stat. 1902","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e13c2d4-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e13c2d5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e13c2d6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6435, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1415"},"text":"Pub. L. 89–10, title I, § 1415","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3596"},"text":"108 Stat. 3596","children":[],"tail":", related to use of funds, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e13c2d7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1401/4/A/i"},"text":"Pub. L. 114–95, § 1401(4)(A)(i)","children":[],"tail":", substituted “career and technical education” for “vocational or technical training”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1401/4/A/ii/I"},"text":"Pub. L. 114–95, § 1401(4)(A)(ii)(I)","children":[],"tail":", added subpar. (A) and struck out former subpar (A) which read as follows: “may include the acquisition of equipment;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1401/4/A/ii/II/aa"},"text":"Pub. L. 114–95, § 1401(4)(A)(ii)(II)(aa)","children":[],"tail":", substituted “the challenging State academic standards” for “the State’s challenging academic content standards and student academic achievement standards”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1401/4/A/ii/II/bb"},"text":"Pub. L. 114–95, § 1401(4)(A)(ii)(II)(bb)","children":[],"tail":", substituted “respond to the educational needs of such children and youth, including by supplementing and improving the quality” for “supplement and improve the quality”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1401/4/A/ii/II/cc"},"text":"Pub. L. 114–95, § 1401(4)(A)(ii)(II)(cc)","children":[],"tail":", substituted “challenging State academic standards” for “challenging State academic achievement standards” and inserted “and” after semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1401/4/A/ii/III"},"text":"Pub. L. 114–95, § 1401(4)(A)(ii)(III)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6321"},"text":"section 6321 of this title","children":[],"tail":" and substituted “part F” for “part I” and period for “; and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1401/4/A/ii/IV"},"text":"Pub. L. 114–95, § 1401(4)(A)(ii)(IV)","children":[],"tail":", struck out subpar. (D) which read as follows: “may include the costs of meeting the evaluation requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7941"},"text":"section 7941 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1401/4/B"},"text":"Pub. L. 114–95, § 1401(4)(B)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6321"},"text":"section 6321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e13c2d8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e13c2d9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
