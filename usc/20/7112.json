{"tag":"section","attrib":{"id":"id0e24649c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112"},"text":null,"children":[{"tag":"num","attrib":{"value":"7112"},"text":"§ 7112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subpart:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e24649d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Blended learning","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “blended learning” means a formal education program that leverages both technology-based and face-to-face instructional approaches—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e24649e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that include an element of online or digital learning, combined with supervised learning time, and student-led learning, in which the elements are connected to provide an integrated learning experience; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e24649f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which students are provided some control over time, path, or pace.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2464a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled substance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “controlled substance” means a drug or other substance identified under Schedule I, II, III, IV, or V in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s812/c"},"text":"section 812(c) of title 21","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2464a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Digital learning","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “digital learning” means any instructional practice that effectively uses technology to strengthen a student’s learning experience and encompasses a wide spectrum of tools and practices, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2464a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interactive learning resources, digital learning content (which may include openly licensed content), software, or simulations, that engage students in academic content;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2464a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to online databases and other primary source documents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2464a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of data and information to personalize learning and provide targeted supplementary instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2464a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" online and computer-based assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2464a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" learning environments that allow for rich collaboration and communication, which may include student collaboration with content experts and peers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2464a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hybrid or blended learning, which occurs under direct instructor supervision at a school or other location away from home and, at least in part, through online delivery of instruction with some element of student control over time, place, path, or pace; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2464a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to online course opportunities for students in rural or remote areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2464a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “drug” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2464aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" controlled substances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2464ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the illegal use of alcohol or tobacco, including smokeless tobacco products and electronic cigarettes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2464ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the harmful, abusive, or addictive use of substances, including inhalants and anabolic steroids.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2464ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug and violence prevention","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “drug and violence prevention” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2464ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to drugs, prevention, early intervention, rehabilitation referral, recovery support services, or education related to the illegal use of drugs, such as raising awareness about the consequences of drug use that are evidence-based (to the extent a State, in consultation with local educational agencies in the State, determines that such evidence is reasonably available); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2464af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to violence, the promotion of school safety, such that students and school personnel are free from violent and disruptive acts, including sexual harassment and abuse, and victimization associated with prejudice and intolerance, on school premises, going to and from school, and at school-sponsored activities, through the creation and maintenance of a school environment that is free of weapons and fosters individual responsibility and respect for the rights of others.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2464b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" School-based mental health services provider","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “school-based mental health services provider” includes a State-licensed or State-certified school counselor, school psychologist, school social worker, or other State licensed or certified mental health professional qualified under State law to provide mental health services to children and adolescents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2464b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the 50 States, the District of Columbia, and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2464b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7112/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stem-focused specialty school","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “STEM-focused specialty school” means a school, or dedicated program within a school, that engages students in rigorous, relevant, and integrated learning experiences focused on science, technology, engineering, and mathematics, including computer science, which include authentic schoolwide research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e2464b3-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4102"},"text":"Pub. L. 89–10, title IV, § 4102","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4101"},"text":"Pub. L. 114–95, title IV, § 4101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1969"},"text":"129 Stat. 1969","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e2464b4-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e2464b5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e2464b6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7112, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4112"},"text":"Pub. L. 89–10, title IV, § 4112","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIV/s401"},"text":"Pub. L. 107–110, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1736"},"text":"115 Stat. 1736","children":[],"tail":", related to reservation of State funds for safe and drug-free schools, prior to the general amendment of this subpart by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 7112, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4112"},"text":"Pub. L. 89–10, title IV, § 4112","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3675"},"text":"108 Stat. 3675","children":[],"tail":", related to State applications, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s4102"},"text":"section 4102 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3062"},"text":"section 3062 of this title","children":[],"tail":", prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e2464b7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e2464b8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
