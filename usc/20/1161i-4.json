{"tag":"section","attrib":{"id":"id0d84a255-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161i–4"},"text":"§ 1161i–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State Task Force activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d84a256-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State Task Force shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a257-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordinate and communicate regularly with the State Advisory Council on Early Care and Education (hereafter in this part referred to as “State Advisory Council”) or a similar State entity charged with creating a comprehensive system of early care and education in the State, for the purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a258-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrating recommendations for early childhood professional development and career activities into the plans of the State Advisory Council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a259-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting in the implementation of professional development and career activities that are consistent with the plans described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a25a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct a review of opportunities for and barriers to high-quality professional development, training, and higher education degree programs, in early childhood development and learning, including a periodic statewide survey concerning the demographics of individuals working in early childhood education programs in the State, which survey shall include information disaggregated by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a25b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" race, gender, and ethnicity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a25c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a25d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" type of early childhood education program setting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a25e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specialized knowledge of child development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a25f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" years of experience in an early childhood education program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a260-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" attainment of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d84a261-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic credit for coursework;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a262-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an academic degree;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a263-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/2/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a credential;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a264-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/2/F/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" licensure; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a265-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/2/F/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certification in early childhood education; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a266-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specialized knowledge in the education of children with limited English proficiency and students with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a267-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop a plan for a comprehensive statewide professional development and career system for individuals working in early childhood education programs or for early childhood education providers, which plan may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a268-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods of providing outreach to early childhood education program staff, directors, and administrators, including methods for how outreach is provided to non-English speaking providers, in order to enable the providers to be aware of opportunities and resources under the statewide plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a269-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing a unified data collection and dissemination system for early childhood education training, professional development, and higher education programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a26a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the participation of early childhood educators in high-quality training and professional development by assisting in paying the costs of enrollment in and completion of such training and professional development courses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a26b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" increasing the participation of early childhood educators in undergraduate and graduate education programs leading to degrees in early childhood education by providing assistance to pay the costs of enrollment in and completion of such programs, which assistance—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d84a26c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall only be provided to an individual who—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d84a26d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/3/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual pursuing an undergraduate or graduate degree, enters into an agreement under which the individual agrees to work, for a reasonable number of years after receiving such a degree, in an early childhood education program that is located in a low-income area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d84a26e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/3/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a family income equal to or less than the annually adjusted national median family income as determined by the Bureau of the Census; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a26f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be provided in an amount that does not exceed $17,500;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a270-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting professional development activities and a career lattice for a variety of early childhood professional roles with varying professional qualifications and responsibilities for early childhood education personnel, including strategies to enhance the compensation of such personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a271-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting articulation agreements between two- and four-year public and private institutions of higher education and mechanisms to transform other training, professional development, and experience into academic credit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a272-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing mentoring and coaching programs to support new educators in and directors of early childhood education programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a273-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing career development advising with respect to the field of early childhood education, including informing an individual regarding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d84a274-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/3/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entry into and continuing education requirements for professional roles in the field;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a275-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/3/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available financial assistance for postsecondary education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a276-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/3/H/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional development and career advancement in the field;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a277-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing the capacity and quality of faculty and coursework in postsecondary programs that lead to an associate, baccalaureate, or graduate degree in early childhood education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a278-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consideration of the availability of on-line graduate level professional development offered by institutions of higher education with experience and demonstrated expertise in establishing programs in child development, in order to improve the skills and expertise of individuals working in early childhood education programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a279-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/a/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing or enhancing a system of quality assurance with respect to the early childhood education professional development and career system, including standards or qualifications for individuals and entities who offer training and professional development in early childhood education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a27a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State Task Force shall hold public hearings and provide an opportunity for public comment on the activities described in the statewide plan described in subsection (a)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a27b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State Task Force shall meet periodically to review implementation of the statewide plan and to recommend any changes to the statewide plan the State Task Force determines necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d84a27c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s815"},"text":"Pub. L. 89–329, title VIII, § 815","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3398"},"text":"122 Stat. 3398","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
