{"tag":"section","attrib":{"id":"id0d6f1df6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124"},"text":null,"children":[{"tag":"num","attrib":{"value":"1124"},"text":"§ 1124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Undergraduate international studies and foreign language programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d6f1df7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentives for creation of new programs and strengthening of existing programs in undergraduate international studies and foreign language programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6f1df8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make grants to institutions of higher education, consortia of such institutions, or partnerships between nonprofit educational organizations and institutions of higher education, to assist such institutions, consortia or partnerships in planning, developing, and carrying out programs to improve undergraduate instruction in international studies and foreign languages. Such grants shall be awarded to institutions, consortia or partnerships seeking to create new programs or to strengthen existing programs in foreign languages, area studies, and other international fields.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1df9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants made under this section may be used for the Federal share of the cost of projects and activities which are an integral part of such a program, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d6f1dfa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning for the development and expansion of undergraduate programs in international studies and foreign languages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1dfb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" teaching, research, curriculum development, faculty training in the United States or abroad, and other related activities, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d6f1dfc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expansion of library and teaching resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d6f1dfd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pre-service teacher training and in-service teacher professional development;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1dfe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expansion of opportunities for learning foreign languages, including less commonly taught languages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1dff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs under which foreign teachers and scholars may visit institutions as visiting faculty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1e00-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs designed to develop or enhance linkages between 2- and 4-year institutions of higher education, or baccalaureate and post-baccalaureate programs or institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1e01-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the development of undergraduate educational programs—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d6f1e02-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in locations abroad where such opportunities are not otherwise available or that serve students for whom such opportunities are not otherwise available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d6f1e03-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that provide courses that are closely related to on-campus foreign language and international curricula;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1e04-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integration of new and continuing education abroad opportunities for undergraduate students into curricula of specific degree programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1e05-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of model programs to enrich or enhance the effectiveness of educational programs abroad, including predeparture and postreturn programs, and the integration of educational programs abroad into the curriculum of the home institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1e06-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the provision of grants for educational programs abroad that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d6f1e07-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2/I/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are closely linked to the program’s overall goals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d6f1e08-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2/I/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the purpose of promoting foreign language fluency and knowledge of world regions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1e09-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of programs designed to integrate professional and technical education with foreign languages, area studies, and other international fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1e0a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of linkages overseas with institutions of higher education and organizations that contribute to the educational programs assisted under this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1e0b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of summer institutes in foreign area, foreign language, and other international fields to provide faculty and curriculum development, including the integration of professional and technical education with foreign area and other international studies, and to provide foreign area and other international knowledge or skills to government personnel or private sector professionals in international activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1e0c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the development of partnerships between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d6f1e0d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2/M/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d6f1e0e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2/M/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the private sector, government, or elementary and secondary education institutions,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in order to enhance international knowledge and skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1e0f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/2/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of innovative technology to increase access to international education programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e10-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The non-Federal share of the cost of the programs assisted under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d6f1e11-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be provided in cash from the private sector corporations or foundations in an amount equal to one-third of the total cost of the programs assisted under this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1e12-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be provided as an in-cash or in-kind contribution from institutional and noninstitutional funds, including State and private sector corporation or foundation contributions, equal to one-half of the total cost of the programs assisted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e13-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may waive or reduce the required non-Federal share for institutions that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d6f1e14-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are eligible to receive assistance under part A or B of subchapter III or under subchapter V; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1e15-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have submitted a grant application under this section that demonstrates a need for a waiver or reduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e16-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Secretary shall give priority to applications from institutions of higher education, consortia or partnerships that require entering students to have successfully completed at least 2 years of secondary school foreign language instruction or that require each graduating student to earn 2 years of postsecondary credit in a foreign language (or have demonstrated equivalent competence in the foreign language) or, in the case of a 2-year degree granting institution, offer 2 years of postsecondary credit in a foreign language.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e17-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under this subsection shall reflect the purposes of this part and be made on such conditions as the Secretary determines to be necessary to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e18-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application for assistance under this subsection shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d6f1e19-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence that the applicant has conducted extensive planning prior to submitting the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1e1a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the faculty and administrators of all relevant departments and programs served by the applicant are involved in ongoing collaboration with regard to achieving the stated objectives of the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1e1b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that students at the applicant institutions, as appropriate, will have equal access to, and derive benefits from, the program assisted under this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1e1c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that each applicant, consortium, or partnership will use the Federal assistance provided under this subsection to supplement and not supplant non-Federal funds the institution expends for programs to improve undergraduate instruction in international studies and foreign languages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1e1d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the applicant will provide information to students regarding federally funded scholarship programs in related areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1e1e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/7/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of how the activities funded by the grant will reflect diverse perspectives and a wide range of views and generate debate on world regions and international affairs, where applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1e1f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/7/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the applicant will encourage service in areas of national need, as identified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e20-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish requirements for program evaluations and require grant recipients to submit annual reports that evaluate the progress and performance of students participating in programs assisted under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6f1e21-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs of national significance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may also award grants to public and private nonprofit agencies and organizations, including professional and scholarly associations, whenever the Secretary determines such grants will make an especially significant contribution to improving undergraduate international studies and foreign language programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6f1e22-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding support","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6f1e23-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use not more than 20 percent of the total amount appropriated for this part for carrying out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e24-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1124/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the total amount of grant funds awarded to a grantee under this section, the grantee may use not more than ten percent of such funds for the activity described in subsection (a)(2)(I).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6f1e25-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s604"},"text":"Pub. L. 89–329, title VI, § 604","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVI/s601"},"text":"Pub. L. 105–244, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1778"},"text":"112 Stat. 1778","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVI"},"text":"Pub. L. 110–315, title VI","children":[],"tail":", §§ 604, 610(a), "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3336"},"text":"122 Stat. 3336","children":[],"tail":", 3338; "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tVI/s601/a/1"},"text":"Pub. L. 111–39, title VI, § 601(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1953"},"text":"123 Stat. 1953","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"ty