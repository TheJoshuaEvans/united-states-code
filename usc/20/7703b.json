{"tag":"section","attrib":{"id":"id0e435e59-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b"},"text":null,"children":[{"tag":"num","attrib":{"value":"7703b"},"text":"§ 7703b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to local educational agencies that benefit dependents of members of the Armed Forces and Department of Defense civilian employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e435e5a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to schools with significant numbers of military dependent students","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e435e5b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense shall provide financial assistance to an eligible local educational agency described in paragraph (2) if, without such assistance, the local educational agency will be unable (as determined by the Secretary of Defense in consultation with the Secretary of Education) to provide the students in the schools of the local educational agency with a level of education that is equivalent to the minimum level of education available in the schools of the other local educational agencies in the same State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e45ce5c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible local educational agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local educational agency is eligible for assistance under this subsection for a fiscal year if at least 20 percent (as rounded to the nearest whole percent) of the students in average daily attendance in the schools of the local educational agency during the preceding school year were military dependent students counted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7703/a/1"},"text":"section 7703(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e45ce5d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to schools with enrollment changes due to base closures, force structure changes, or force relocations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e45ce5e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To assist communities in making adjustments resulting from changes in the size or location of the Armed Forces, the Secretary of Defense shall provide financial assistance to an eligible local educational agency described in paragraph (2) if, during the period between the end of the school year preceding the fiscal year for which the assistance is authorized and the beginning of the school year immediately preceding that school year, the local educational agency had (as determined by the Secretary of Defense in consultation with the Secretary of Education) an overall increase or reduction of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e45ce5f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than five percent in the average daily attendance of military dependent students in the schools of the local educational agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e45ce60-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 250 military dependent students in average daily attendance in the schools of the local educational agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e45ce61-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible local educational agencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A local educational agency is eligible for assistance under this subsection for a fiscal year if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e45ce62-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the local educational agency is eligible for assistance under subsection (a) for the same fiscal year, or would have been eligible for such assistance if not for the reduction in military dependent students in schools of the local educational agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e45ce63-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the overall increase or reduction in military dependent students in schools of the local educational agency is the result of one or more of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e45ce64-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The global rebasing plan of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e45ce65-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The official creation or activation of one or more new military units.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e45ce66-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The realignment of forces as a result of the base closure process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e45ce67-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A change in the number of housing units on a military installation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e45ce68-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation of amount of assistance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e45ce69-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pro rata distribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the assistance provided under this subsection to a local educational agency that is eligible for such assistance for a fiscal year shall be equal to the product obtained by multiplying—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e45ce6a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the per-student rate determined under subparagraph (B) for that fiscal year; by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e45ce6b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the net of the overall increases and reductions in the number of military dependent students in schools of the local educational agency, as determined under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e45ce6c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Per-student rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A)(i), the per-student rate for a fiscal year shall be equal to the dollar amount obtained by dividing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e45ce6d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of funds made available for that fiscal year to provide assistance under this subsection; by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e45ce6e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the overall increases and reductions in the number of military dependent students in schools of all eligible local educational agencies for that fiscal year under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e45ce6f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local educational agency may not receive more than $1,000,000 in assistance under this subsection for any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e45ce70-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance may not be provided under this subsection after ","children":[{"tag":"date","attrib":{"date":"2014-09-30"},"text":"September 30, 2014","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e45ce71-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2006-06-30"},"text":"June 30, 2006","children":[],"tail":", and June 30 of each fiscal year thereafter for which funds are made available to carry out this section, the Secretary of Defense shall notify each local educational agency that is eligible for assistance under this section for that fiscal year of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e45ce72-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligibility of the local educational agency for the assistance, including whether the agency is eligible for assistance under either subsection (a) or (b) or both subsections; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e45ce73-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the assistance for which the local educational agency is eligible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e45ce74-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disbursement of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense shall disburse assistance made available under this section for a fiscal year not later than 30 days after the date on which notification to the eligible local educational agencies is provided pursuant to subsection (c) for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e45ce75-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e45ce76-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “base closure process” means the 2005 base closure and realignment process authorized by Defense Base Closure and Realignment Act of 1990 (part A of title XXIX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Public Law 101–510","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2687"},"text":"10 U.S.C. 2687","children":[],"tail":" note) or any base closure and realignment process conducted after "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"January 6, 2006","children":[],"tail":", under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2687"},"text":"section 2687 of title 10","children":[],"tail":" or any other similar law enacted after "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"January 6, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e45ce77-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “local educational agency” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7713/9"},"text":"section 7713(9) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e45ce78-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “military dependent students” refers to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e45ce79-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elementary and secondary school students who are dependents of members of the Armed Forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e45ce7a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elementary and secondary school students who are dependents of civilian employees of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e45ce7b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703b/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means each of the 50 States and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e45ce7c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s572"},"text":"Pub. L. 109–163, div. A, title V, § 572","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3271"},"text":"119 Stat. 3271","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tV/s533"},"text":"Pub. L. 111–84, div. A, title V, § 533","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2292"},"text":"123 Stat. 2292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tV/s561/b/1"},"text":"Pub. L. 112–239, div. A, title V, § 561(b)(1)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1743"},"text":"126 Stat. 1743","children":[],"tail":", 1744; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/ccc"},"text":"Pub. L. 114–95, title IX, § 9215(ccc)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2185"},"text":"129 Stat. 2185","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e45ce7d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e45ce7e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e45ce7f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Defense Base Closure and Realignment Act of 1990, referred to in subsec. (e)(1), is part A of title XXIX of div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1808"},"text":"104 Stat. 1808","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2687"},"text":"section 2687 of Title 10","children":[],"tail":", Armed Forces. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0e45ce80-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s572"},"text":"section 572 of Pub. L. 109–163","children":[],"tail":". Subsec. (g) of "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s572"},"text":"section 572 of Pub. L. 109–163","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/s386"},"text":"section 386 of Pub. L. 102–484","children":[],"tail":", formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7703"},"text":"section 7703 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 2006, and not as part of the Elementary and Secondary Education Act of 1965 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e45ce81-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9215/ccc/1"},"text":"Pub. L. 114–95, § 9215(ccc)(1)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7703/a/1"},"text":"section 7703(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9215/ccc/2"},"text":"Pub. L. 114–95, § 9215(ccc)(2)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7713/9"},"text":"section 7713(9) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s561/b/1"},"text":"Pub. L. 112–239, § 561(b)(1)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2014-09-30"},"text":"September 30, 2014","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2012-09-30"},"text":"September 30, 2012","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s561/c"},"text":"Pub. L. 112–239, § 561(c)","children":[],"tail":", redesignated subsec. (f) as (e) and struck out former subsec. (e) which read as follows: “Of the amount authorized to be appropriated pursuant to section 301(5) for operation and maintenance for Defense-wide activities—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) $30,000,000 shall be available only for the purpose of providing assistance to local educational agencies under subsection (a) of this section; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) $10,000,000 shall be available only for the purpose of pro