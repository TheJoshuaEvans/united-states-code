iations Act for any fiscal year to carry out this chapter "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" may, subject to the appropriation, become available for obligations on July 1 of that fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ded9d57-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4451/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subchapter II","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated for the purpose of carrying out the provisions of subchapter II of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ded9d58-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4451/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 1987, $1,000,000, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ded9d59-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4451/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each succeeding fiscal year, such sums as may be necessary to carry out such provisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ded9d5a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/498/tXV/s1531"},"text":"Pub. L. 99–498, title XV, § 1531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1612"},"text":"100 Stat. 1612","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/tV/s5406/c"},"text":"Pub. L. 100–297, title V, § 5406(c)"