{"tag":"section","attrib":{"id":"id0e1aeeb3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6633"},"text":null,"children":[{"tag":"num","attrib":{"value":"6633"},"text":"§ 6633.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e1aeeb4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6633/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities summary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible entity receiving a grant under this subpart shall provide to the Secretary a summary of the activities assisted under the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1aeeb5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6633/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide to Congress an annual report on the implementation of the program carried out under this subpart, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1aeeb6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6633/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information on eligible entities that received grant funds under this subpart, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1aeeb7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6633/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information provided by eligible entities to the Secretary in the applications submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6632/c"},"text":"section 6632(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aeeb8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6633/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the summaries received under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aeeb9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6633/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant award amounts; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aeeba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6633/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" student academic achievement and, as applicable, growth data from the schools participating in the programs supported under the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1aeebb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6633/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and technical assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1aeebc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6633/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the total amount reserved for this subpart for a fiscal year, the Secretary may reserve for such fiscal year not more than 1 percent for the cost of the evaluation under paragraph (2) and for technical assistance in carrying out this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aeebd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6633/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts reserved under paragraph (1), the Secretary, acting through the Director of the Institute of Education Sciences, shall carry out an independent evaluation to measure the effectiveness of the program assisted under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aeebe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6633/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The evaluation under paragraph (2) shall measure—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1aeebf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6633/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of the program in improving student academic achievement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aeec0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6633/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the satisfaction of the participating teachers, principals, or other school leaders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aeec1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6633/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the program assisted the eligible entities in recruiting and retaining high-quality teachers, principals, or other school leaders, especially in high-need subject areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e1aeec2-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2213"},"text":"Pub. L. 89–10, title II, § 2213","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tII/s2002"},"text":"Pub. L. 114–95, title II, § 2002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1935"},"text":"129 Stat. 1935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e1aeec3-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e1aeec4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e1aeec5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 6633 and 6634 were repealed by ","children":[{"tag":"ref