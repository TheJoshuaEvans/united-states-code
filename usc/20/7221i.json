{"tag":"section","attrib":{"id":"id0e2b9052-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i"},"text":null,"children":[{"tag":"num","attrib":{"value":"7221i"},"text":"§ 7221i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2b9053-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized public chartering agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “authorized public chartering agency” means a State educational agency, local educational agency, or other public entity that has the authority pursuant to State law and approved by the Secretary to authorize or approve a charter school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b9054-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charter school","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “charter school” means a public school that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2b9055-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with a specific State statute authorizing the granting of charters to schools, is exempt from significant State or local rules that inhibit the flexible operation and management of public schools, but not from any rules relating to the other requirements of this paragraph;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b9056-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is created by a developer as a public school, or is adapted by a developer from an existing public school, and is operated under public supervision and direction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b9057-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operates in pursuit of a specific set of educational objectives determined by the school’s developer and agreed to by the authorized public chartering agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b9058-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides a program of elementary or secondary education, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b9059-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is nonsectarian in its programs, admissions policies, employment practices, and all other operations, and is not affiliated with a sectarian school or religious institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b905a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not charge tuition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b905b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with the Age Discrimination Act of 1975 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6101"},"text":"42 U.S.C. 6101","children":[],"tail":" et seq.], title VI of the Civil Rights Act of 1964 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000d"},"text":"42 U.S.C. 2000d","children":[],"tail":" et seq.], title IX of the Education Amendments of 1972 ["},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1681"},"text":"20 U.S.C. 1681","children":[],"tail":" et seq.], section 504 of the Rehabilitation Act of 1973 ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"29 U.S.C. 794","children":[],"tail":"], the Americans with Disabilities Act of 1990 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"42 U.S.C. 12101","children":[],"tail":" et seq.), "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232g"},"text":"section 1232g of this title","children":[],"tail":" (commonly referred to as the “Family Educational Rights and Privacy Act of 1974”), and part B of the Individuals with Disabilities Education Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1411"},"text":"20 U.S.C. 1411","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b905c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is a school to which parents choose to send their children, and that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e2b905d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/2/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" admits students on the basis of a lottery, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7221b/c/3/A"},"text":"section 7221b(c)(3)(A) of this title","children":[],"tail":", if more students apply for admission than can be accommodated; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2b905e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/2/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a school that has an affiliated charter school (such as a school that is part of the same network of schools), automatically enrolls students who are enrolled in the immediate prior grade level of the affiliated charter school and, for any additional student openings or student openings created through regular attrition in student enrollment in the affiliated charter school and the enrolling school, admits students on the basis of a lottery as described in clause (i);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b905f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees to comply with the same Federal and State audit requirements as do other elementary schools and secondary schools in the State, unless such State audit requirements are waived by the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b9060-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets all applicable Federal, State, and local health and safety requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b9061-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operates in accordance with State law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b9062-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a written performance contract with the authorized public chartering agency in the State that includes a description of how student performance will be measured in charter schools pursuant to State assessments that are required of other schools and pursuant to any other assessments mutually agreeable to the authorized public chartering agency and the charter school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b9063-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may serve students in early childhood education programs or postsecondary students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b9064-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charter management organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “charter management organization” means a nonprofit organization that operates or manages a network of charter schools linked by centralized support, operations, and oversight.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b9065-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charter school support organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “charter school support organization” means a nonprofit, nongovernmental entity that is not an authorized public chartering agency and provides, on a statewide basis—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2b9066-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance to developers during the planning, program design, and initial implementation of a charter school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b9067-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance to operating charter schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b9068-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Developer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “developer” means an individual or group of individuals (including a public or private nonprofit organization), which may include teachers, administrators and other school staff, parents, or other members of the local community in which a charter school project will be carried out.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b9069-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible applicant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible applicant” means a developer that has—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2b906a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applied to an authorized public chartering authority to operate a charter school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b906b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided adequate and timely notice to that authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b906c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expand","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “expand”, when used with respect to a high-quality charter school, means to significantly increase enrollment or add one or more grades to the high-quality charter school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b906d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-quality charter school","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “high-quality charter school” means a charter school that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2b906e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shows evidence of strong academic results, which may include strong student academic growth, as determined by a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b906f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has no significant issues in the areas of student safety, financial and operational management, or statutory or regulatory compliance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b9070-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has demonstrated success in significantly increasing student academic achievement, including graduation rates where applicable, for all students served by the charter school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b9071-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has demonstrated success in increasing student academic achievement, including graduation rates where applicable, for each of the subgroups of students, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/c/2"},"text":"section 6311(c)(2) of this title","children":[],"tail":", except that such demonstration is not required in a case in which the number of students in a group is insufficient to yield statistically reliable information or the results would reveal personally identifiable information about an individual student."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b9072-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221i/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replicate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “replicate”, when used with respect to a high-quality charter school, means to open a new charter school, or a new campus of a high-quality charter school, based on the educational model of an existing high-quality charter school, under an existing charter or an additional charter, if permitted or required by State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e2b9073-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4310"},"text":"Pub. L. 89–10, title IV, § 4310","children":[],"tail":", formerly title V, § 5210, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1798"},"text":"115 Stat. 1798","children":[],"tail":"; renumbered title IV, § 4310, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV"},"text":"Pub. L. 114–95, title IV","children":[],"tail":", §§ 4001(b)(2)(A), (B), (D)(iii), 4301(4), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1967"},"text":"129 Stat. 1967","children":[],"tail":", 2012.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e2b9074-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e2b9075-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e2b9076-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Age Discrimination Act of 1975, referred to in par. (2)(G), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/135"},"text":"Pub. L. 94–135","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-28"},"text":"Nov. 28, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/728"},"text":"89 Stat. 728","children":[],"tail":", which is classified generally to chapter 76 (§ 6101 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6101"},"text":"section 6101 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Civil Rights Act of 1964, referred to in par. (2)(G), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352"},"text":"Pub. L. 88–352","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/241"},"text":"78 Stat. 241","children":[],"tail":". Title VI of the Act is classified generally to subchapter V (§ 2000d et seq.) of chapter 21 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000a"},"text":"section 2000a of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Education Amendments of 1972, referred to in par. (2)(G), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/318"},"text":"Pub. L. 92–318","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/235"},"text":"86 Stat. 235","children":[],"tail":". Title IX of the Act, known as the Patsy Takemoto Mink Equal Opportunity in Education Act, is classified principally to chapter 38 (§ 1681 et seq.) of this title. For complete classification of title IX to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1681"},"text":"section 1681 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Americans with Disabilities Act of 1990, referred to in par. (2)(G), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336"},"text":"Pub. L. 101–336","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/327"},"text":"104 Stat. 327","children":[],"tail":", which is classified principally to chapter 126 (§ 12101 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"section 12101 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Individuals with Disabilities Education Act, referred to in par. (2)(G), is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230"},"text":"Pub. L. 91–230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/175"},"text":"84 Stat. 175","children":[],"tail":". Part B of the Act is classified generally to subchapter II (§ 1411 et seq.) of chapter 33 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e2b9077-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s4301/4/A"},"text":"Pub. L. 114–95, § 4301(4)(A)","children":[],"tail":", substituted “part” for “subpart” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s4301/4/C"},"text":"Pub. L. 114–95, § 4301(4)(C)","children":[],"tail":", redesignated par. (4) as (1). Former par. (1) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s4301/4/B"},"text":"Pub. L. 114–95, § 4301(4)(B)","children":[],"tail":", redesignated par. (1) as (2). Former par. (2) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s4301/4/D/i"},"text":"Pub. L. 114–95, § 4301(4)(D)(i)","children":[],"tail":", substituted “, the Americans with Disabilities Act of 1990 ("},{"tag":"ref","