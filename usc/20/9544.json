{"tag":"section","attrib":{"id":"id0e6258d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9544"},"text":null,"children":[{"tag":"num","attrib":{"value":"9544"},"text":"§ 9544.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance of duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e6258d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9544/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants, contracts, and cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the duties under this part, the Statistics Commissioner,","children":[{"tag":"ref","attrib":{"idref":"fn002245"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002245"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" may award grants, enter into contracts and cooperative agreements, and provide technical assistance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6258da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9544/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gathering information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e6258db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9544/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sampling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Statistics Commissioner may use the statistical method known as sampling (including random sampling) to carry out this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6258dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9544/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Statistics Commissioner may, as appropriate, use information collected—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e6258dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9544/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from States, local educational agencies, public and private schools, preschools, institutions of higher education, vocational and adult education programs, libraries, administrators, teachers, students, the general public, and other individuals, organizations, agencies, and institutions (including information collected by States and local educational agencies for their own use); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6258de-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9544/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by other offices within the Institute and by other Federal departments, agencies, and instrumentalities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6258df-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9544/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Statistics Commissioner may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e6258e0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9544/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into interagency agreements for the collection of statistics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6258e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9544/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrange with any agency, organization, or institution for the collection of statistics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6258e2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9544/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assign employees of the Statistics Center to any such agency, organization, or institution to assist in such collection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6258e3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9544/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance and coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to maximize the effectiveness of Department efforts to serve the educational needs of children and youth, the Statistics Commissioner shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e6258e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9544/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to the Department offices that gather data for statistical purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6258e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9544/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with other Department offices in the collection of data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6258e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9544/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the grants, contracts, and cooperative agreements under this section may be awarded, on a competitive basis, for a period of not more than 5 years, and may be renewed at the discretion of the Statistics Commissioner for an additional period of not more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e6258e7-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s154"},"text":"Pub. L. 107–279, title I, § 154","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1960"},"text":"116 Stat. 1960","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
