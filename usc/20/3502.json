{"tag":"section","attrib":{"id":"id0ddcd3fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3502"},"text":null,"children":[{"tag":"num","attrib":{"value":"3502"},"text":"§ 3502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ddcd3ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-separation or non-reduction in grade or compensation of full-time personnel and part-time personnel holding permanent positions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this chapter, the transfer pursuant to this subchapter of full-time personnel (except special Government employees) and part-time personnel holding permanent positions shall not cause any such employee to be separated or reduced in grade or compensation for one year after the date of transfer to the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ddcd400-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Positions compensated in accordance with Executive Schedule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who, on the day preceding ","children":[{"tag":"date","attrib":{"date":"1980-05-04"},"text":"May 4, 1980","children":[],"tail":", held a position compensated in accordance with the Executive Schedule prescribed in chapter 53 of title 5 and who, without a break in service, is appointed in the Department to a position having duties comparable to the duties performed immediately preceding such appointment shall continue to be compensated in such new position at not less than the rate provided for such previous position, for the duration of the service of such person in such new position."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ddcd401-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s502"},"text":"Pub. L. 96–88, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/690"},"text":"93 Stat. 690","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ddcd402-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ddcd403-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0ddcd404-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b), “","children":[{"tag":"date","attrib":{"date":"1980-05-04"},"text":"May 4, 1980","children":[],"tail":"” substituted for “the effective date of this chapter” pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/s601"},"text":"section 601 of Pub. L. 96–88","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3401"},"text":"section 3401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0ddcd405-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0ddcd406-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Abolished Positions Deemed Transferred","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s508"},"text":"Pub. L. 96–88, title V, § 508","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(4), "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/694"},"text":"93 Stat. 694","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/stat/93/694"},"text":"“Positions abolished as a consequence of the amendments made by this subsection [amending sections 1102, 2390, and 3012 of this title] shall, for purposes of section 502(a) [subsec. (a) of this section], be deemed to be permanent positions transferred pursuant to title V of this Act [this subchapter].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
