{"tag":"section","attrib":{"id":"id0e32bc1e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305a"},"text":null,"children":[{"tag":"num","attrib":{"value":"7305a"},"text":"§ 7305a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this part is to allow States and local educational agencies the flexibility to target Federal funds to the programs and activities that most effectively address the unique needs of States and localities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e32bc1f-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5102"},"text":"Pub. L. 89–10, title V, § 5102","children":[],"tail":", formerly title VI, § 6122, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVI/s601"},"text":"Pub. L. 107–110, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1876"},"text":"115 Stat. 1876","children":[],"tail":"; renumbered title V, § 5102, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tV"},"text":"Pub. L. 114–95, title V","children":[],"tail":", §§ 5001(a)(1), 5002(4), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2039"},"text":"129 Stat. 2039","children":[],"tail":", 2040.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e32bc20-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e32bc21-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":