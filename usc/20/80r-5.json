{"tag":"section","attrib":{"id":"id0c8a3c1f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"80r–5"},"text":"§ 80r–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational and liaison programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c8a3c20-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c8a3c21-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Museum may carry out educational and liaison programs in support of the goals of the Museum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8a3c22-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific activities described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Director shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c8a3c23-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–5/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" carry out educational programs relating to African American life, art, history, and culture, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0c8a3c24-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–5/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs using digital, electronic, and interactive technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c8a3c25-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–5/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs carried out in collaboration with elementary schools, secondary schools, and postsecondary schools; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8a3c26-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–5/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Director of the Institute of Museum and Library Services concerning the grant and scholarship programs carried out under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c8a3c27-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant and scholarship programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c8a3c28-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In consultation with the Council and the Director of the Museum, the Director of the Institute of Museum and Library Services shall establish—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c8a3c29-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–5/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a grant program with the purpose of improving operations, care of collections, and development of professional management at African American museums;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8a3c2a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–5/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a grant program with the purpose of providing internship and fellowship opportunities at African American museums;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8a3c2b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–5/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a scholarship program with the purpose of assisting individuals who are pursuing careers or carrying out studies in the arts, humanities, and sciences in the study of African American life, art, history, and culture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8a3c2c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–5/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with other museums, historical societies, and educational institutions, a grant program with the purpose of promoting the understanding of modern-day practices of slavery throughout the world; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8a3c2d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–5/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a grant program under which an African-American museum (including a nonprofit education organization the primary mission of which is to promote the study of African-American diaspora) may use the funds provided under the grant to increase an endowment fund established by the museum (or organization) as of ","children":[{"tag":"date","attrib":{"date":"2003-05-01"},"text":"May 1, 2003","children":[],"tail":", for the purposes of—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0c8a3c2e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–5/b/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing educational programming; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c8a3c2f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–5/b/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining and operating traveling educational exhibits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8a3c30-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Director of the Institute of Museum and Library Services to carry out this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c8a3c31-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–5/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000,000 for fiscal year 2004; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8a3c32-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–5/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c8a3c33-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/184/s7"},"text":"Pub. L. 108–184, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2679"},"text":"117 Stat. 2679","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
