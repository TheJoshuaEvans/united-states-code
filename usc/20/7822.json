{"tag":"section","attrib":{"id":"id0e4cfb3c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7822"},"text":null,"children":[{"tag":"num","attrib":{"value":"7822"},"text":"§ 7822.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single local educational agency States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A State educational agency that also serves as a local educational agency shall, in its applications or plans under this chapter, describe how the agency will eliminate duplication in conducting administrative functions.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e4cfb3d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8202"},"text":"Pub. L. 89–10, title VIII, § 8202","children":[],"tail":", formerly title IX, § 9202, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIX/s901"},"text":"Pub. L. 107–110, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1967"},"text":"115 Stat. 1967","children":[],"tail":"; renumbered title VIII, § 8202, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII/s8001/a/2"},"text":"Pub. L. 114–95, title VIII, § 8001(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2088"},"text":"129 Stat. 2088","children":[],"tail":", 2089.)"}],"tail":"\n"}],"tail":null}
