{"tag":"section","attrib":{"id":"id0d84a298-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161j"},"text":"§ 1161j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving science, technology, engineering, and mathematics education with a focus on Alaska Native and Native Hawaiian students","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d84a299-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a29a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop or expand programs for the development of professionals in the fields of science, technology, engineering, and mathematics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a29b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to focus resources on meeting the educational and cultural needs of Alaska Natives and Native Hawaiians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a29c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a29d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alaska Native","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Alaska Native” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7546"},"text":"section 7546 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a29e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible partnership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible partnership” means a partnership that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a29f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more colleges, schools, or departments of engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a2a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more colleges of science or mathematics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a2a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more institutions of higher education that offer two-year degrees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a2a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" one or more private entities that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d84a2a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct career awareness activities showcasing local technology professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a2a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage students to pursue education in science, technology, engineering, and mathematics from elementary school through postsecondary education, and careers in those fields, with the assistance of local technology professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a2a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop internships, apprenticeships, and mentoring programs in partnership with relevant industries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a2a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/b/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist with placement of interns and apprentices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a2a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"section 1001(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a2a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native Hawaiian","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Native Hawaiian” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7517"},"text":"section 7517 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a2a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amounts appropriated to carry out this section under subsection (i), the Secretary is authorized to award a grant to an eligible partnership to enable the eligible partnership to expand programs for the development of science, technology, engineering, or mathematics professionals, from elementary school through postsecondary education, including existing programs for Alaska Native and Native Hawaiian students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a2aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grant funds under this section shall be used for one or more of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a2ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development or implementation of cultural, social, or educational transition programs to assist students to transition into college life and academics in order to increase such students’ retention rates in the fields of science, technology, engineering, or mathematics, with a focus on Alaska Native or Native Hawaiian students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a2ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development or implementation of academic support or supplemental educational programs to increase the graduation rates of students in the fields of science, technology, engineering, or mathematics, with a focus on Alaska Native and Native Hawaiian students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a2ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development or implementation of internship programs, carried out in coordination with educational institutions and private entities, to prepare students for careers in the fields of science, technology, engineering, or mathematics, with a focus on programs that serve Alaska Native or Native Hawaiian students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a2ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other activities as are consistent with the purpose of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a2af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible partnership that desires a grant under this section shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a2b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Secretary shall give priority to an eligible partnership that, on the day before ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", provides one or more programs in which 30 percent or more of the program participants are Alaska Native or Native Hawaiian."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a2b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this section shall be awarded for a period of five years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a2b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible partnership that receives a grant under this section shall conduct an evaluation to determine the effectiveness of the programs funded under the grant and shall provide a report regarding the evaluation to the Secretary not later than six months after the end of the grant period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a2b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161j/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d84a2b4-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s819"},"text":"Pub. L. 89–329, title VIII, § 819","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3402"},"text":"122 Stat. 3402","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tVIII/s801/4"},"text":"Pub. L. 111–39, title VIII, § 801(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1955"},"text":"123 Stat. 1955","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215"},"text":"Pub. L. 114–95, title IX, § 9215","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"oo","children":[],"tail":")(11), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2180"},"text":"129 Stat. 2180","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d84a2b5-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d84a2b6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d84a2b7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attri