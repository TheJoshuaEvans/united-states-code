{"tag":"section","attrib":{"id":"id0d908996-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1228b"},"text":"§ 1228b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The National Assessment Governing Board, the Advisory Council on Education Statistics, the National Education Goals Panel, and any other board established to analyze, address, or approve education content or student performance standards and assessments shall coordinate and interact with one another in order to ensure that each such entity does not duplicate activities to assist the States in reforming their educational systems.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d908997-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/tIV/s428"},"text":"Pub. L. 90–247, title IV, § 428","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tII/s237"},"text":"Pub. L. 103–382, title II, § 237","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3917"},"text":"108 Stat. 3917","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101/d/tVII/s703/c"},"text":"Pub. L. 104–134, title I, § 101(d) [title VII, § 703(c)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321-211"},"text":"110 Stat. 1321–211","children":[],"tail":", 1321–255; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d908998-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d908999-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d90899a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/s428"},"text":"section 428 of Pub. L. 90–247","children":[],"tail":" was renumbered section 435, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1231e"},"text":"section 1231e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d90899b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134"},"text":"Pub. L. 104–134","children":[],"tail":" struck out “the National Education Standards and Improvement Council,” before “and any other board”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
