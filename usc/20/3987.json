{"tag":"section","attrib":{"id":"id0de18f5d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3987"},"text":null,"children":[{"tag":"num","attrib":{"value":"3987"},"text":"§ 3987.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de18f5e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3987/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria; consistency of applications with State plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de18f5f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3987/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish criteria for approval of applications under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f60-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3987/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No application may be approved by the Secretary unless the State educational agency or the State agency for higher education, as the case may be, determines that the application is consistent with State plans for elementary and secondary education or State plans for higher education, as the case may be, in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de18f61-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3987/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for equitable distribution of grants among States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall adopt approval procedures designed to assure that there is equitable distribution of grants among the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de18f62-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tIII/s308"},"text":"Pub. L. 98–377, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-11"},"text":"Aug. 11, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1286"},"text":"98 Stat. 1286","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/159/tII/s231"},"text":"Pub. L. 99–159, title II, § 231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-22"},"text":"Nov. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/900"},"text":"99 Stat. 900","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tVI/s6031/b/2"},"text":"Pub. L. 100–418, title VI, § 6031(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1483"},"text":"102 Stat. 1483","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de18f63-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de18f64-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0de18f65-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" substituted “part” for “subchapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/159"},"text":"Pub. L. 99–159","children":[],"tail":" substituted “Secretary” for “Foundation” in pars. (1) and (2) of subsec. (a) and in subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
