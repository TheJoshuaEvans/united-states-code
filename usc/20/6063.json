{"tag":"section","attrib":{"id":"id0dfbce21-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6063"},"text":null,"children":[{"tag":"num","attrib":{"value":"6063"},"text":"§ 6063.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study of Goals 2000 and students with disabilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dfbce22-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6063/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dfbce23-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6063/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1994-03-31"},"text":"March 31, 1994","children":[],"tail":", the Secretary shall make appropriate arrangements with the National Academy of Sciences or the National Academy of Education to conduct a comprehensive study of the inclusion of children with disabilities in school reform activities assisted under the Goals 2000: Educate America Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t20/s5801"},"text":"20 U.S.C. 5801","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dfbce24-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6063/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Children with disabilities” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “children with disabilities” has the same meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1401"},"text":"section 1401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dfbce25-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6063/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study conducted under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dfbce26-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6063/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the National Education Goals and objectives, curriculum reforms, standards, and other programs and activities intended to achieve those goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dfbce27-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6063/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of the adequacy of assessments and measures used to gauge progress towards meeting National Education Goals and any national and State standards, and an examination of other methods or accommodations necessary or desirable to collect data on the educational progress of children with disabilities, and the costs of such methods and accommodations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dfbce28-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6063/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an examination of what incentives or assistance might be provided to States to develop improvement plans that adequately address the needs of children with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dfbce29-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6063/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relation of the Goals 2000: Educate America Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5801"},"text":"20 U.S.C. 5801","children":[],"tail":" et seq.] to other Federal laws governing or affecting the education of children with disabilities; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dfbce2a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6063/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other issues as the National Academy of Sciences or the National Academy of Education considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dfbce2b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6063/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study panel membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any panel constituted in furtherance of the study to be conducted under subsection (a) shall include consumer representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dfbce2c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6063/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall request the National Academy of Sciences or the National Academy of Education to submit an interim report of its findings and recommendations to the President and Congress not later than 12 months, and a final report not later than 24 months, from the date of the completion of procurement relating to the study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dfbce2d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6063/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From funds appropriated to the Secretary for research related to individuals with disabilities the Secretary shall make available $600,000 for fiscal year 1994, and such sums as may be necessary for fiscal year 1995, to carry out this section. Amounts made available under this subsection shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dfbce2e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/227/tX/s1015"},"text":"Pub. L. 103–227, title X, § 1015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"Mar. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/266"},"text":"108 Stat. 266","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dfbce2f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dfbce30-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0dfbce31-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Goals 2000: Educate America Act, referred to in subsecs. (a)(1) and (b)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/227"},"text":"Pub. L. 103–227","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"Mar. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/125"},"text":"108 Stat. 125","children":[],"tail":" (except titles V and IX), which is classified principally to this chapter (except subchapters V (§ 5931 et seq.) and IX (§ 6001 et seq.)). For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s5801"},"text":"section 5801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
