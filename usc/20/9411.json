{"tag":"section","attrib":{"id":"id0e600e39-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9411"},"text":null,"children":[{"tag":"num","attrib":{"value":"9411"},"text":"§ 9411.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local allocations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e600e3a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9411/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Lead State Agency shall allocate to Local Councils in the State not less than 93 percent of the funds provided to the State under this chapter for a fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e600e3b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9411/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Lead State Agency shall allocate funds provided under this chapter on the basis of the population of the locality served by the Local Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e600e3c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/1/tVIII/s812"},"text":"Pub. L. 106–554, § 1(a)(1) [title VIII, § 812]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–88.)"}],"tail":"\n"}],"tail":null}
