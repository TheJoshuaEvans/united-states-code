{"tag":"section","attrib":{"id":"id0e24645c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7014"},"text":null,"children":[{"tag":"num","attrib":{"value":"7014"},"text":"§ 7014.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In developing regulations under this subchapter, the Secretary shall consult with State educational agencies and local educational agencies, organizations representing English learners, and organizations representing teachers and other personnel involved in the education of English learners.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e24645d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIII/s3203"},"text":"Pub. L. 89–10, title III, § 3203","children":[],"tail":", formerly § 3304, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIII/s301"},"text":"Pub. L. 107–110, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1734"},"text":"115 Stat. 1734","children":[],"tail":"; renumbered § 3203 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIII"},"text":"Pub. L. 114–95, title III","children":[],"tail":", §§ 3001(5)(C), 3004(c), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1953"},"text":"129 Stat. 1953","children":[],"tail":", 1965.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e24645e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e24645f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib