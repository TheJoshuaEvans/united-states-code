{"tag":"section","attrib":{"id":"id0d60ed5c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1098e"},"text":"§ 1098e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income-based repayment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d60ed5d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d60ed5e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excepted PLUS loan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “excepted PLUS loan” means a loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078–2"},"text":"section 1078–2 of this title","children":[],"tail":", or a Federal Direct PLUS Loan, that is made, insured, or guaranteed on behalf of a dependent student."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d60ed5f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excepted consolidation loan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d60ed60-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “excepted consolidation loan” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d60ed61-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consolidation loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078–3"},"text":"section 1078–3 of this title","children":[],"tail":", or a Federal Direct Consolidation Loan, if the proceeds of such loan were used to discharge the liability on an excepted PLUS loan; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d60ed62-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consolidation loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078–3"},"text":"section 1078–3 of this title","children":[],"tail":", or a Federal Direct Consolidation Loan, if the proceeds of such loan were used to discharge the liability on a consolidation loan under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078–3"},"text":"section 1078–3 of this title","children":[],"tail":", or a Federal Direct Consolidation Loan described in clause (i)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d60ed63-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “excepted consolidation loan” does not include a Federal Direct Consolidation Loan described in subparagraph (A) that, on any date during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2028-06-30"},"text":"June 30, 2028","children":[],"tail":", was being repaid—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0d60ed64-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to the Income Contingent Repayment (ICR) plan in accordance with section 685.209(b) of title 34, Code of Federal Regulations (as in effect on ","children":[{"tag":"date","attrib":{"date":"2023-06-30"},"text":"June 30, 2023","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d60ed65-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to another income driven repayment plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d60ed66-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable amount” means 15 percent of the result obtained by calculating, on at least an annual basis, the amount by which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d60ed67-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the borrower’s, and the borrower’s spouse’s (if applicable), adjusted gross income; exceeds","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d60ed68-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 150 percent of the poverty line applicable to the borrower’s family size as determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9902/2"},"text":"section 9902(2) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d60ed69-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income-based repayment program authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this chapter, the Secretary shall carry out a program under which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d60ed6a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a borrower of any loan made, insured, or guaranteed under part B or D (other than an excepted PLUS loan or excepted consolidation loan), may elect to have the borrower’s aggregate monthly payment for all such loans not exceed the applicable amount divided by 12;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d60ed6b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the holder of such a loan shall apply the borrower’s monthly payment under this subsection first toward interest due on the loan, next toward any fees due on the loan, and then toward the principal of the loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d60ed6c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any interest due and not paid under paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d60ed6d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, on subsidized loans, be paid by the Secretary for a period of not more than 3 years after the date of the borrower’s election under paragraph (1), except that such period shall not include any period during which the borrower is in deferment due to an economic hardship described in section 1085(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d60ed6e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be capitalized—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d60ed6f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a subsidized loan, subject to subparagraph (A), at the time the borrower—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d60ed70-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ends the election to make income-based repayment under this subsection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d60ed71-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" begins making payments of not less than the amount specified in paragraph (6)(A); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d60ed72-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an unsubsidized loan, at the time the borrower—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d60ed73-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ends the election to make income-based repayment under this subsection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d60ed74-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" begins making payments of not less than the amount specified in paragraph (6)(A);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d60ed75-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any principal due and not paid under paragraph (2) shall be deferred;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d60ed76-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of time the borrower makes monthly payments under paragraph (1) may exceed 10 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d60ed77-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the monthly payment amount calculated under this section for all loans made to the borrower under part B or D (other than an excepted PLUS loan or excepted consolidation loan) exceeds the monthly amount calculated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078/b/9/A/i"},"text":"section 1078(b)(9)(A)(i) of this title","children":[],"tail":" or 1087e(d)(1)(A) of this title, based on a 10-year repayment period, when the borrower first made the election described in this subsection (referred to in this paragraph as the “standard monthly repayment amount”), or if the borrower no longer wishes to continue the election under this subsection, then—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d60ed78-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum monthly payment required to be paid for all loans made to the borrower under part B or D (other than an excepted PLUS loan or excepted consolidation loan) shall be the standard monthly repayment amount; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d60ed79-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of time the borrower is permitted to repay such loans may exceed 10 years;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d60ed7a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary shall repay or cancel any outstanding balance of principal and interest due on all loans made under part B or D (other than a loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078–2"},"text":"section 1078–2 of this title","children":[],"tail":" or a Federal Direct PLUS Loan) to a borrower who—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d60ed7b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at any time, elected to participate in income-based repayment under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d60ed7c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for a period of time prescribed by the Secretary, not to exceed 25 years, meets 1 or more of the following requirements—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d60ed7d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has made reduced monthly payments under paragraph (1) or paragraph (6);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d60ed7e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has made monthly payments of not less than the monthly amount calculated under section 1078(b)(9)(A)(i) or 1087e(d)(1)(A) of this title, based on a 10-year repayment period, when the borrower first made the election described in this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d60ed7f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/7/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has made payments of not less than the payments required under a standard repayment plan under section 1078(b)(9)(A)(i) or 1087e(d)(1)(A) of this title with a repayment period of 10 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d60ed80-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/7/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has made payments under an income-contingent repayment plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087e/d/1/D"},"text":"section 1087e(d)(1)(D) of this title","children":[],"tail":" (as such section was in effect on the day before the date of the repeal of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087e/e"},"text":"section 1087e(e) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d60ed81-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/7/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been in deferment due to an economic hardship described in section 1085(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of this title;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d60ed82-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a borrower who is repaying a loan made under part B or D pursuant to income-based repayment may elect, at any time, to terminate repayment pursuant to income-based repayment and repay such loan under the standard repayment plan or the Repayment Assistance Program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087e/q"},"text":"section 1087e(q) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d60ed83-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the special allowance payment to a lender calculated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087–1/b/2/I"},"text":"section 1087–1(b)(2)(I) of this title","children":[],"tail":", when calculated for a loan in repayment under this section, shall be calculated on the principal balance of the loan and on any accrued interest unpaid by the borrower in accordance with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d60ed84-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility determinations; automatic recertification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d60ed85-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish procedures for annually determining, in accordance with paragraph (2), the borrower’s eligibility for income-based repayment, including the verification of a borrower’s annual income and the annual amount due on the total amount of loans made, insured, or guaranteed under part B or D (other than an excepted PLUS loan or excepted consolidation loan), and such other procedures as are necessary to effectively implement income-based repayment under this section. The Secretary shall consider, but is not limited to, the procedures established in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087e/e/1"},"text":"section 1087e(e)(1) of this title","children":[],"tail":" (as in effect on the day before the date of repeal of subsection (e) of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087e"},"text":"section 1087e of this title","children":[],"tail":") or in connection with income sensitive repayment schedules under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078/b/9/A/iii"},"text":"section 1078(b)(9)(A)(iii) of this title","children":[],"tail":" or 1078–3(b)(1)(E) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d60ed86-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automatic recertification","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d60ed87-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish and implement, with respect to any borrower enrolled in an income-based repayment program under this section or under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087e/q"},"text":"section 1087e(q) of this title","children":[],"tail":", procedures to—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0d60ed88-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use return information disclosed under section 6103(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(13) of title 26, pursuant to approval provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1098h"},"text":"section 1098h of this title","children":[],"tail":", to determine the repayment obligation of the borrower without further action by the borrower;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d60ed89-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow the borrower (or the spouse of the borrower), at any time, to opt out of disclosure under such section 6103(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(13) and instead provide such information as the Secretary may require to determine the repayment obligation of the borrower (or withdraw from the repayment plan under this section or under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087e/q"},"text":"section 1087e(q) of this title","children":[],"tail":", as the case may be); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d60ed8a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the borrower with an opportunity to update the return information so disclosed before the determination of the repayment obligation of the borrower.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d60ed8b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subparagraph (A) shall apply to each borrower of a loan eligible to be repaid under this section or under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087e/q"},"text":"section 1087e(q) of this title","children":[],"tail":", who, on or after the date on which the Secretary establishes procedures under such subparagraph (A)—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0d60ed8c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selects, or is required to repay such loan pursuant to, an income-based repayment plan under this section or under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087e/q"},"text":"section 1087e(q) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d60ed8d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recertifies income or family size under such plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d60ed8e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for married borrowers filing separately","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a married borrower who files a separate Federal income tax return, the Secretary shall calculate the amount of the borrower’s income-based repayment under this section solely on the basis of the borrower’s student loan debt and adjusted gross income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d60ed8f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special terms for new borrowers on and after ","children":[{"tag":"date","attrib":{"date":"2014-07-01"},"text":"July 1, 2014","children":[],"tail":" and before "},{"tag":"date","attrib":{"date":"2026-07-01"},"text":"July 1, 2026","children":[],"tail":null}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any loan made to a new borrower on or after ","children":[{"tag":"date","attrib":{"date":"2014-07-01"},"text":"July 1, 2014","children":[],"tail":" and before "},{"tag":"date","attrib":{"date":"2026-07-01"},"text":"July 1, 2026","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d60ed90-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a)(3)(B) shall be applied by substituting “10 percent” for “15 percent”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d60ed91-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098e/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (b)(7)(B) shall be applied by substituting “20 years” for “25 years”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d60ed92-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s493C"},"text":"Pub. L. 89–329, title IV, § 493C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/84/tII/s203/a"},"text":"Pub. L. 110–84, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/792"},"text":"121 Stat. 792","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/153/s2"},"text":"Pub. L. 110–153, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-21"},"text":"Dec. 21, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1824"},"text":"121 Stat. 1824","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s494F"},"text":"Pub. L. 110–315, title IV, § 494F","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3324"},"text":"122 Stat. 3324","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/152/tII/s2213"},"text":"Pub. L. 111–152, title II, § 2213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-30"},"text":"Mar. 30, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1081"},"text":"124 Stat. 1081","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/91/s4/b"},"text":"Pub. L. 116–91, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-19"},"text":"Dec. 19, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1193"},"text":"133 Stat. 1193","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVIII/s82001/f/1"},"text":"Pub. L. 119–21, title VIII, § 82001(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/345"},"text":"139 Stat. 345","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d60ed93-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d60ed94-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d60ed95-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087e/e"},"text":"section 1087e(e) of this title","children":[],"tail":", referred to in subsec. (b)(7)(B)(iv), is "},{"tag":"date","attrib":{"date":"2028-07-01"},"text":"July 1, 2028","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/s82001/c/3"},"text":"section 82001(c)(3) of Pub. L. 119–21","children":[],"tail":", set out as an Effective Date of 2025 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078"},"text":"section 1078 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d60ed96-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s82001/f/1/A"},"text":"Pub. L. 119–21, § 82001(f)(1)(A)","children":[],"tail":", amended par. (2) generally. Prior to amendment, text read as follows: “The term ‘excepted consolidation loan’ means a consolidation loan under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078–3"},"text":"section 1078–3 of this title","children":[],"tail":", or a Federal Direct Consolidation Loan, if the proceeds of such loan were used to the discharge the liability on an excepted PLUS loan.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s82001/f/1/B"},"text":"Pub. L. 119–21, § 82001(f)(1)(B)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) defined “partial financial hardship” with respect to a borrower."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s82001/f/1/C/i"},"text":"Pub. L. 119–21, § 82001(f)(1)(C)(i)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “a borrower of any loan made, insured, or guaranteed under part B or D (other than an excepted PLUS loan or excepted consolidation loan) who has a partial financial hardship (whether or not the borrower’s loan has been submitted to a guaranty agency for default aversion or had been in default) may elect, during any period the borrower has the partial financial hardship, to have the borrower’s aggregate monthly payment for all such loans not exceed the result described in subsection (a)(3)(B) divided by 12;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s82001/f/1/C/ii"},"text":"Pub. L. 119–21, § 82001(f)(1)(C)(ii)","children":[],"tail":", added par. (6) and struck out former par. (6) which related to a borrower who no longer has a partial financial hardship or no longer wishes to continue the election under the income-based repayment program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7)(B)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s82001/f/1/C/iii"},"text":"Pub. L. 119–21, § 82001(f)(1)(C)(iii)","children":[],"tail":", inserted “(as such section was in effect on the day before the date of the repeal of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087e/e"},"text":"section 1087e(e) of this title","children":[],"tail":"” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087e/d/1/D"},"text":"section 1087e(d)(1)(D) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s82001/f/1/C/iv"},"text":"Pub. L. 119–21, § 82001(f)(1)(C)(iv)","children":[],"tail":", inserted “or the Repayment Assistance Program under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087e/q"},"text":"section 1087e(q) of this title","children":[],"tail":"” after “standard repayment plan”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s82001/f/1/D"},"text":"Pub. L. 119–21, § 82001(f)(1)(D)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, subsec. (c) related to eligibility determinations for income-based repayment."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s82001/f/1/E/ii"},"text":"Pub. L. 119–21, § 82001(f)(1)(E)(ii)","children":[],"tail":", inserted “and before "},{"tag":"date","attrib":{"date":"2026-07-01"},"text":"July 1, 2026","children":[],"tail":"” after “after "},{"tag":"date","attrib":{"date":"2014-07-01"},"text":"July 1, 2014","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s82001/f/1/E/i"},"text":"Pub. L. 119–21, § 82001(f)(1)(E)(i)","children":[],"tail":", inserted “and before "},{"tag":"date","attrib":{"date":"2026-07-01"},"text":"July 1, 2026","children":[],"tail":"” after “after "},{"tag":"date","attrib":{"date":"2014-07-01"},"text":"July 1, 2014","children":[],"tail":"” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/91/s4/b/1"},"text":"Pub. L. 116–91, § 4(b)(1)","children":[],"tail":", designated first sentence of existing provisions as par. (1) and inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/91/s4/b/2"},"text":"Pub. L. 116–91, § 4(b)(2)","children":[],"tail":", (3), designated second sentence of existing provisions as par. (2) and inserted heading, substituted “The Secretary shall—” for “The Secretary shall”, inserted subpar. (A) designation before “consider,”, substituted “; and” for period at end of subpar. (A), and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152"},"text":"Pub. L. 111–152","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" substituted “or had been in default” for “or is already in default”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/153"},"text":"Pub. L. 110–153","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d633687-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d633688-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVIII/s82001/f/2"},"text":"Pub. L. 119–21, title VIII, § 82001(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/347"},"text":"139 Stat. 347","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVIII/s82001/f/2"},"text":"“The amendments made by this subsection [amending this section] shall take effect on the date of enactment of this title [","children":[{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":"], and shall apply with respect to any borrower who is in repayment before, on, or after the date of enactment of this title.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d633689-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/84/s203/c/1"},"text":"section 203(c)(1) of Pub. L. 110–84","children":[],"tail":", set out in an Effective Date of 2007 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078–3"},"text":"section 1078–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
