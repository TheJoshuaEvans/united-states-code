{"tag":"section","attrib":{"id":"id0de18f80-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3993"},"text":null,"children":[{"tag":"num","attrib":{"value":"3993"},"text":"§ 3993.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment to State application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de18f81-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3993/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State shall be eligible to receive a grant under this part if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de18f82-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3993/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State submits to the Secretary as part of its application under section 209 ","children":[{"tag":"ref","attrib":{"idref":"fn002159"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002159"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" such information and assurances as the Secretary may require at such time as the Secretary shall establish; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f83-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3993/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary approves such application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de18f84-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3993/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require each application to include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de18f85-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3993/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the State’s procedures relating to the use of funds from grants received under this part, including the approval process for local applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f86-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3993/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that not more than 1 percent of the amount received shall be used for administrative expenses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f87-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3993/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the State will, to the extent possible, assist local school districts in economically depressed areas to obtain matching funds from business concerns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de18f88-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tIII/s323"},"text":"Pub. L. 98–377, title III, § 323","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tVI/s6031/a/2"},"text":"Pub. L. 100–418, title VI, § 6031(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1480"},"text":"102 Stat. 1480","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de18f89-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de18f8a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0de18f8b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 209, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/s209"},"text":"section 209 of Pub. L. 98–377","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"1984-08-11"},"text":"Aug. 11, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1279"},"text":"98 Stat. 1279","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3969"},"text":"section 3969 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/tII/s2303"},"text":"Pub. L. 100–297, title II, § 2303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/324"},"text":"102 Stat. 324","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
