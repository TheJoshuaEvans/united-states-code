{"tag":"section","attrib":{"id":"id0e51b635-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7910"},"text":null,"children":[{"tag":"num","attrib":{"value":"7910"},"text":"§ 7910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on national testing or certification for teachers, principals, or other school leaders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e51b636-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7910/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory national testing or certification of teachers, principals, or other school leaders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter or any other provision of law, no funds available to the Department or otherwise available under this chapter may be used for any purpose relating to a mandatory nationwide test or certification of teachers, principals, other school leaders, or education paraprofessionals, including any planning, development, implementation, or administration of, or incentive regarding, such test or certification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e51b637-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7910/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on withholding funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is prohibited from withholding funds from any State educational agency or local educational agency if the State educational agency or local educational agency fails to adopt a specific method of teacher or paraprofessional certification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e51b638-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8530"},"text":"Pub. L. 89–10, title VIII, § 8530","children":[],"tail":", formerly title IX, § 9530, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIX/s901"},"text":"Pub. L. 107–110, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1984"},"text":"115 Stat. 1984","children":[],"tail":"; renumbered title VIII, § 8530, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII"},"text":"Pub. L. 114–95, title VIII","children":[],"tail":", §§ 8001(a)(6), 8027, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2088"},"text":"129 Stat. 2088","children":[],"tail":", 2089, 2116.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e51b639-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e51b63a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e51b63b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7910, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIX/s9210"},"text":"Pub. L. 89–10, title IX, § 9210","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3804"},"text":"108 Stat. 3804","children":[],"tail":", related to Native Hawaiian community-based education learning centers, prior to the general amendment of former subchapter IX of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e51b63c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8027/1"},"text":"Pub. L. 114–95, § 8027(1)","children":[],"tail":", inserted “, principals, or other school leaders” after “teachers” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8027/3"},"text":"Pub. L. 114–95, § 8027(3)","children":[],"tail":", inserted “, principals, other school leaders,” after “teachers” and “, or incentive regarding,” after “administration of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8027/2"},"text":"Pub. L. 114–95, § 8027(2)","children":[],"tail":", which directed amendment of subsection heading by inserting “, principals, or other school leaders” after “teachers”, was executed by making the insertion in the heading of subsec. (a) to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e51b63d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effective