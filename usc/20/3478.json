{"tag":"section","attrib":{"id":"id0dda8a94-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3478"},"text":null,"children":[{"tag":"num","attrib":{"value":"3478"},"text":"§ 3478.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilities at remote locations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dda8a95-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3478/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized services, supplies and facilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to provide, construct, or maintain for employees and their dependents stationed at remote locations as necessary and when not otherwise available at such remote locations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dda8a96-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3478/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency medical services and supplies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dda8a97-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3478/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food and other subsistence supplies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dda8a98-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3478/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dining facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dda8a99-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3478/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" audiovisual equipment, accessories, and supplies for recreation and training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dda8a9a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3478/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimbursement for food, clothing, medicine, and other supplies furnished by such employees in emergencies for the temporary relief of distressed persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dda8a9b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3478/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" living and working quarters and facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dda8a9c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3478/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation for dependents of employees of the Department to the nearest appropriate educational facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dda8a9d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3478/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The furnishing of medical treatment under paragraph (1) of subsection (a) and the furnishing of services and supplies under paragraphs (2), (3), and (4) of subsection (a) shall be at prices reflecting reasonable value as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dda8a9e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3478/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation credits and refunds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Proceeds from reimbursements under this section may be credited to the appropriation of funds that bear or will bear all or part of the cost of such work or services or used to refund excess sums when necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dda8a9f-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIV/s418"},"text":"Pub. L. 96–88, title IV, § 418","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/686"},"text":"93 Stat. 686","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
