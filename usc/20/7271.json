{"tag":"section","attrib":{"id":"id0e2e01ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7271"},"text":null,"children":[{"tag":"num","attrib":{"value":"7271"},"text":"§ 7271.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this subpart are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2e01cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7271/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significantly improve the academic and developmental outcomes of children living in the most distressed communities of the United States, including ensuring school readiness, high school graduation, and access to a community-based continuum of high-quality services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e01d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7271/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide support for the planning, implementation, and operation of full-service community schools that improve the coordination and integration, accessibility, and effectiveness of services for children and families, particularly for children attending high-poverty schools, including high-poverty rural schools.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e2e01d1-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4621"},"text":"Pub. L. 89–10, title IV, § 4621","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4601"},"text":"Pub. L. 114–95, title IV, § 4601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],