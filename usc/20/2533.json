{"tag":"section","attrib":{"id":"id0dc9c0d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2533"},"text":null,"children":[{"tag":"num","attrib":{"value":"2533"},"text":"§ 2533.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration by unit in Department of Education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dc9c0d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2533/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Education shall establish or designate an administrative unit within the Department of Education for purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc9c0d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2533/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out provisions of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc9c0da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2533/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing information regarding guidance and counseling as a profession, guidance and counseling activities of the Federal Government, and, to the extent practicable, activities of State and local programs of guidance and counseling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc9c0db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2533/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advising the Secretary of Education on coordinating guidance and counseling activities included in all programs which he is authorized to carry out, and, to the extent he deems practicable, how such activities may be coordinated with other programs of the Federal Government and State and local guidance and counseling programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc9c0dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2533/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of amount for implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Education may reserve an amount not to exceed 5 per centum of the sums appropriated under this subchapter to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dc9c0dd-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/482/tIII/s343"},"text":"Pub. L. 94–482, title III, § 343","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2225"},"text":"90 Stat. 2225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/43/s1/b/8"},"text":"Pub. L. 95–43, § 1(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-06-15"},"text":"June 15, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/219"},"text":"91 Stat. 219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIII/s301/a/1"},"text":"Pub. L. 96–88, title III, § 301(a)(1)","children":[],"tail":", (b)(2), title V, § 507, "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/677"},"text":"93 Stat. 677","children":[],"tail":", 678, 692.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dc9c0de-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dc9c0df-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0dc9c0e0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1977—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/43"},"text":"Pub. L. 95–43","children":[],"tail":" substituted “this subchapter” for “this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0dc9c0e1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0dc9c0e2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 30 days after ","children":[{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", except either as specifically otherwise provided or, if not so specifically otherwise provided, effective "},{"tag":"date","attrib":{"date":"1976-07-01"},"text":"July 1, 1976","children":[],"tail":", where section provides for authorization of appropriations, see "},{"tag":"ref","attrib":{"href":"/us/pl/94/482/s532"},"text":"section 532 of Pub. L. 94–482","children":[],"tail":", set out as an Effective Date of 1976 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id0dc9c0e3-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Education” and “Department of Education” substituted in text for “Commissioner” and “Education Division”, respectively, pursuant to sections 301(a)(1), (b)(2) and 507 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88"},"text":"Pub. L. 96–88","children":[],"tail":", which are classified to sections 3441(a)(1), (b)(2) and 3507 of this title and which transferred functions of Commissioner of Education to Secretary of Education and transferred Education Division to Department of Education."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For authority of Secretary of Education to consolidate, alter, or discontinue the administrative unit for guidance and counseling programs, or to reallocate any functions vested by statute in the administrative unit, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s413"},"text":"section 413 of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3473"},"text":"section 3473 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
