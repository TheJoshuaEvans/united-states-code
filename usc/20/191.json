22"},"text":"101 Stat. 1329–322","children":[],"tail":", 1329–327."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/a/tI"},"text":"Pub. L. 99–500, § 101(a) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783"},"text":"100 Stat. 1783","children":[],"tail":", 1783–5, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/a/tI"},"text":"Pub. L. 99–591, § 101(a) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341"},"text":"100 Stat. 3341","children":[],"tail":", 3341–5."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id0c962360-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id0c962361-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of all officers, agencies and employees of Department of Agriculture transferred, with certain exceptions, to Secretary of Agriculture by Reorg. Plan No. 2 of 1953, § 1, eff. ","children":[{"tag":"date","attrib":{"date":"1953-06-04"},"text":"June 4, 1953","children":[],"tail":", 18 F.R. 3219, "},{"tag":"ref","attrib":{"href":"/us/stat/67/633"},"text":"67 Stat. 633","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id0c962362-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Authority of President under this section to transfer to jurisdiction of Secretary of Agriculture for purposes of this chapter any land belonging to United States within or adjacent to District of Columbia located along Anacostia River north of Benning Bridge delegated to Administrator of General Services, see section 1(18) of Ex. Ord. No. 11609, ","children":[{"tag":"date","attrib":{"date":"1971-07-22"},"text":"July 22, 1971","children":[],"tail":", 36 F.R. 13747, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
