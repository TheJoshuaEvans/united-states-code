{"tag":"section","attrib":{"id":"id0c96235b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s191"},"text":null,"children":[{"tag":"num","attrib":{"value":"191"},"text":"§ 191.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; site; acquisition of land","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture is authorized and directed to establish and maintain a national arboretum for purposes of research and education concerning tree and plant life. For the purposes of this chapter, (1) the President is authorized to transfer to the jurisdiction of the Secretary of Agriculture by Executive order any land which now belongs to the United States within or adjacent to the District of Columbia located along the Anacostia River north of Benning Bridge, and (2) the Secretary of Agriculture is authorized in his discretion to acquire, within the limits of the appropriation authorized by this chapter by private purchase, condemnation proceedings, or gift, land so located or other land within or adjacent to the District of Columbia: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the purchase price of any part of said land shall not exceed the full value assessment of such property last made before purchase thereof plus 25 per centum of such assessed value."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c96235c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-04/ch505/s1"},"text":"Mar. 4, 1927, ch. 505, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1422"},"text":"44 Stat. 1422","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c96235d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0c96235e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0c96235f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Facilities To House Bonsai Collections","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/111/tI"},"text":"Pub. L. 103–111, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-10-21"},"text":"Oct. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1051"},"text":"107 Stat. 1051","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/111/tI"},"text":"“That hereafter, facilities to house bonsai collections at the National Arboretum may be constructed with funds accepted under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/129"},"text":"Public Law 94–129","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s195"},"text":"20 U.S.C. 195","children":[],"tail":") and the limitation on construction contained in the Act of "},{"tag":"date","attrib":{"date":"1912-08-24"},"text":"August 24, 1912","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s68"},"text":"40 U.S.C. 68","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s8106"},"text":"40 U.S.C. 8106","children":[],"tail":"] shall not apply to the construction of such facilities”."}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriations acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/341/tI"},"text":"Pub. L. 102–341, title I","children":[],"tail":", "},