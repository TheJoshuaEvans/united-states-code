{"tag":"section","attrib":{"id":"id0ded9d80-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4503"},"text":null,"children":[{"tag":"num","attrib":{"value":"4503"},"text":"§ 4503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship recipients","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ded9d81-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Foundation is authorized to award fellowships to outstanding students and teachers who will pursue graduate study leading to the degree of Master of Arts in teaching or other appropriate masters degree for teachers, with a major in social studies or American history. Each recipient must take at least twelve semester hours, or its equivalent in topics directly related to the Constitution of the United States, as determined by the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ded9d82-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ded9d83-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" James Madison fellowships shall be awarded to individuals who are, or who desire to become, social studies and American history teachers in accordance with paragraphs (2) and (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ded9d84-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Junior fellowships shall be awarded to graduate students who are about to complete or have recently completed their undergraduate course of study, and plan to begin graduate work on a relatively full-time basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ded9d85-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4503/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Senior fellowships shall be awarded to experienced teachers who wish to undertake work for a graduate degree on a part-time basis during summers or in evening programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ded9d86-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/b/tVIII/s804"},"text":"Pub. L. 99–500, § 101(b) [title VIII, § 804]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-39"},"text":"100 Stat. 1783–39","children":[],"tail":", 1783–77, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/b/tVIII/s804"},"text":"Pub. L. 99–591, § 101(b) [title VIII, § 804]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-39"},"text":"100 Stat. 3341–39","children":[],"tail":", 3341–77.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ded9d87-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ded9d88-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0ded9d89-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":" is a corrected version of "},{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
