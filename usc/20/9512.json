{"tag":"section","attrib":{"id":"id0e600ead-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9512"},"text":null,"children":[{"tag":"num","attrib":{"value":"9512"},"text":"§ 9512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"From funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9584"},"text":"section 9584 of this title","children":[],"tail":", the Institute, directly or through grants, contracts, or cooperative agreements, shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e600eae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9512/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct and support scientifically valid research activities, including basic research and applied research, statistics activities, scientifically valid education evaluation, development, and wide dissemination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600eaf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9512/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" widely disseminate the findings and results of scientifically valid research in education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600eb0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9512/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the use, development, and application of knowledge gained from scientifically valid research activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600eb1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9512/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen the national capacity to conduct, develop, and widely disseminate scientifically valid research in education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600eb2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9512/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the coordination, development, and dissemination of scientifically valid research in education within the Department and the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600eb3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9512/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the use and application of research and development to improve practice in the classroom.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e600eb4-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s112"},"text":"Pub. L. 107–279, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1945"},"text":"116 Stat. 1945","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
