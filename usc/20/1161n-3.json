{"tag":"section","attrib":{"id":"id0d895d0d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161n–3"},"text":"§ 1161n–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration and innovation projects; training and resource centers; and research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d895d0e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amounts appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1161n–4"},"text":"section 1161n–4 of this title","children":[],"tail":", the Secretary is authorized, in accordance with the provisions of this section, to make grants and enter into contracts—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d895d0f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the amounts available in each fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1161n–1/a/3"},"text":"section 1161n–1(a)(3) of this title","children":[],"tail":", for the conduct of demonstration projects designed to demonstrate or determine the effectiveness of innovative methods of cooperative education;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895d10-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" from the amounts available in each fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1161n–1/a/4"},"text":"section 1161n–1(a)(4) of this title","children":[],"tail":", for the conduct of training and resource centers designed to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895d11-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–3/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" train personnel in the field of cooperative education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895d12-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–3/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve materials used in cooperative education programs if such improvement is conducted in conjunction with other activities described in this paragraph;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895d13-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–3/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to institutions of higher education to increase the potential of the institution to continue to conduct a cooperative education program without Federal assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895d14-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–3/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage model cooperative education programs that furnish education and training in occupations in which there is a national need;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895d15-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–3/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support partnerships under which an institution carrying out a comprehensive cooperative education program joins with one or more institutions of higher education in order to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d895d16-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–3/a/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the institution that is not the institution carrying out the cooperative education program to develop and expand an existing program of cooperative education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d895d17-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–3/a/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and improve or expand comprehensive cooperative education programs; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895d18-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–3/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage model cooperative education programs in the fields of science and mathematics for women and minorities who are underrepresented in such fields; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895d19-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–3/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the amounts available in each fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1161n–1/a/5"},"text":"section 1161n–1(a)(5) of this title","children":[],"tail":", for the conduct of research relating to cooperative education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895d1a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provision","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d895d1b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out this section, the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895d1c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–3/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make grants to or contracts with institutions of higher education or consortia of such institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895d1d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–3/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make grants to or contracts with other public or private nonprofit agencies or organizations, whenever such grants or contracts will contribute to the objectives of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895d1e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895d1f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–3/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts with institutions of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use not more than three percent of the amount appropriated to carry out this section in each fiscal year to enter into contracts described in paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895d20-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–3/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts with other agencies or organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use not more than three percent of the amount appropriated to carry out this section in each fiscal year to enter into contracts described in paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895d21-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A recipient of a grant or contract under this section may use the funds provided only to supplement funds made available from non-Federal sources to carry out the activities supported by such grant or contract, and in no case to supplant such funds from non-Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d895d22-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s834"},"text":"Pub. L. 89–329, title VIII, § 834","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3419"},"text":"122 Stat. 3419","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
