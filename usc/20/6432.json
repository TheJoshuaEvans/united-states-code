{"tag":"section","attrib":{"id":"id0e13c26b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6432"},"text":null,"children":[{"tag":"num","attrib":{"value":"6432"},"text":"§ 6432.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e13c26c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6432/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subgrants to State agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e13c26d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6432/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State agency described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6431"},"text":"section 6431 of this title","children":[],"tail":" (other than an agency in the Commonwealth of Puerto Rico) is eligible to receive a subgrant under this subpart, for each fiscal year, in an amount equal to the product of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e13c26e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6432/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number of neglected or delinquent children and youth described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6431"},"text":"section 6431 of this title","children":[],"tail":" who—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0e13c26f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6432/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are enrolled for at least 15 hours per week in education programs in adult correctional institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e13c270-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6432/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" are enrolled for at least 20 hours per week—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e13c271-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6432/a/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in education programs in institutions for neglected or delinquent children and youth; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e13c272-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6432/a/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in community day programs for neglected or delinquent children and youth; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e13c273-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6432/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 40 percent of the average per-pupil expenditure in the State, except that the amount determined under this subparagraph shall not be less than 32 percent, nor more than 48 percent, of the average per-pupil expenditure in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e13c274-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6432/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The number of neglected or delinquent children and youth determined under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e13c275-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6432/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be determined by the State agency by a deadline set by the Secretary, except that no State agency shall be required to determine the number of such children and youth on a specific date set by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e13c276-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6432/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be adjusted, as the Secretary determines is appropriate, to reflect the relative length of such agency’s annual programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e13c277-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6432/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subgrants to State agencies in Puerto Rico","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e13c278-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6432/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each fiscal year, the amount of the subgrant which a State agency in the Commonwealth of Puerto Rico shall be eligible to receive under this subpart shall be the amount determined by multiplying the number of children counted under subsection (a)(1)(A) for the Commonwealth of Puerto Rico by the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e13c279-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6432/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage which the average per-pupil expenditure in the Commonwealth of Puerto Rico is of the lowest average per-pupil expenditure of any of the 50 States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e13c27a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6432/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 32 percent of the average per-pupil expenditure in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e13c27b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6432/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum percentage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The percentage in paragraph (1)(A) shall not be less than 85 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e13c27c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6432/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the application of paragraph (2) would result in any of the 50 States or the District of Columbia receiving less under this subpart than it received under this subpart for the preceding fiscal year, then the percentage described in paragraph (1)(A) that is used for the Commonwealth of Puerto Rico for the fiscal year for which the determination is made shall be the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e13c27d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6432/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage in paragraph (1)(A) for such fiscal year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e13c27e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6432/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage used for the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e13c27f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6432/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ratable reductions in case of insufficient appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the amount appropriated for any fiscal year for subgrants under subsections (a) and (b) is insufficient to pay the full amount for which all State agencies are eligible under such subsections, the Secretary shall ratably reduce each such amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e13c280-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1412"},"text":"Pub. L. 89–10, title I, § 1412","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1581"},"text":"115 Stat. 1581","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tI/s1401/2"},"text":"Pub. L. 114–95, title I, § 1401(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1900"},"text":"129 Stat. 1900","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e13c281-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e13c282-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e13c283-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6432, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1412"},"text":"Pub. L. 89–10, title I, § 1412","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3592"},"text":"108 Stat. 3592","children":[],"tail":", related to allocation of funds, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e13c284-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" added par. (2) and struck out former par. (2) which related to minimum percentage for fiscal year 2002, fiscal year 2003, fiscal year 2004, and fiscal year 2005 and succeeding fiscal years."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e13c285-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e13c286-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
