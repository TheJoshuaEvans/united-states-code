{"tag":"section","attrib":{"id":"id0cbeb9aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1011d"},"text":"§ 1011d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student representation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall, in appointing individuals to any commission, committee, board, panel, or other body in connection with the administration of this chapter, include individuals who are, at the time of appointment, attending an institution of higher education.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0cbeb9ab-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s115"},"text":"Pub. L. 89–329, title I, § 115","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tI/s101/a"},"text":"Pub. L. 105–244, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1593"},"text":"112 Stat. 1593","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cbeb9ac-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cbeb9ad-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cbeb9ae-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib"