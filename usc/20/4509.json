{"tag":"section","attrib":{"id":"id0ded9dae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4509"},"text":null,"children":[{"tag":"num","attrib":{"value":"4509"},"text":"§ 4509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship conditions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ded9daf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4509/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A student awarded a Madison Fellowship shall continue to receive payments only during such periods as the Foundation finds that the student is maintaining satisfactory progress in an approved program of study or research. Recipients of junior fellowships shall devote essentially full time to their program of study.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ded9db0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4509/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Foundation is authorized to require reports from any fellowship recipient containing such information, in such form, and to be filed at such times as the Foundation determines to be necessary. Such reports shall be accompanied by a certificate from an appropriate official at the institution of higher education, approved by the Foundation, stating that such student is making satisfactory progress in a program of study or research, with such exceptions as the Foundation may establish.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ded9db1-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/b/tVIII/s810"},"text":"Pub. L. 99–500, § 101(b) [title VIII, § 810]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-39"},"text":"100 Stat. 1783–39","children":[],"tail":", 1783–79, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/b/tVIII/s810"},"text":"Pub. L. 99–591, § 101(b) [title VIII, § 810]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-39"},"text":"100 Stat. 3341–39","children":[],"tail":", 3341–79.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ded9db2-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ded9db3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0ded9db4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":" is a corrected version of "},{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
