{"tag":"section","attrib":{"id":"id0c83107b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80f"},"text":null,"children":[{"tag":"num","attrib":{"value":"80f"},"text":"§ 80f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Woodrow Wilson International Center for Scholars; Board of Trustees of the Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c83107c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established in the Smithsonian Institution a Woodrow Wilson International Center for Scholars and a Board of Trustees of the Center (hereinafter referred to as the “Center” and the “Board”), whose duties it shall be to maintain and administer the Center and site thereof and to execute such other functions as are vested in the Board by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c83107d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition of Board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board of Trustees shall be composed of 17 members as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c83107e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c83107f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Health and Human Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c831080-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c831081-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80f/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the National Endowment for the Humanities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c831082-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80f/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Smithsonian Institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c831083-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80f/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Librarian of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c831084-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80f/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Archivist of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c831085-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80f/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member appointed by the President from time to time from within the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c831086-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80f/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 9 members appointed by the President from private life.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c831087-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of alternate members by members of Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Board of Trustees specified in paragraphs (1) through (8) of subsection (b) may designate another official to serve on the Board of Trustees in his stead.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c831088-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of office; vacancies; reappointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Board of Trustees appointed under paragraph (10) of subsection (b) shall serve for a term of six years from the expiration of his predecessor’s term; except that (1) any trustee appointed to fill a vacancy occurring prior to the expiration of the term for which his predecessor was appointed shall be appointed for the remainder of such term, and (2) the terms of office of the trustees first taking office shall begin on ","children":[{"tag":"date","attrib":{"date":"1968-10-24"},"text":"October 24, 1968","children":[],"tail":", and shall expire as designated at the time of appointment, two at the end of two years, three at the end of four years, and three at the end of six years. No trustee of the Board chosen from private life shall be eligible to serve in excess of two consecutive terms, except that a trustee whose term has expired may serve until his successor has qualified."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c831089-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman and Vice Chairman of Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall designate a Chairman and a Vice Chairman from among the members of the Board chosen from private life.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c83108a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/637/s3"},"text":"Pub. L. 90–637, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-24"},"text":"Oct. 24, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1357"},"text":"82 Stat. 1357","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/426/tII/s206"},"text":"Pub. L. 95–426, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-07"},"text":"Oct. 7, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/975"},"text":"92 Stat. 975","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/268"},"text":"Pub. L. 101–268","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-04-09"},"text":"Apr. 9, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/132"},"text":"104 Stat. 132","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XIII, § 1335(i), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-788"},"text":"112 Stat. 2681–788","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c83108b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c83108c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0c83108d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1335/i/1/A"},"text":"Pub. L. 105–277, § 1335(i)(1)(A)","children":[],"tail":", substituted “17” for “19” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1335/i/1/B"},"text":"Pub. L. 105–277, § 1335(i)(1)(B)","children":[],"tail":"–(D), redesignated pars. (8) to (10) as (7) to (9), respectively, in par. (9) substituted “9” for “10”, and struck out former par. (7) which read as follows: “the Director of the United States Information Agency;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1335/i/2"},"text":"Pub. L. 105–277, § 1335(i)(2)","children":[],"tail":", substituted “(8)” for “(9)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/268/s1"},"text":"Pub. L. 101–268, § 1","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “The Board of Trustees shall be composed of sixteen members as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the Secretary of State;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the Director of the United States Information Agency;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) the Secretary of Health and Human Services;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) the Chairman of the National Endowment for the Humanities;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) the Secretary of the Smithsonian Institution;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) the Librarian of Congress;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(7) the Archivist of the United States;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(8) one appointed by the President from time to time from within the Federal Government; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(9) eight appointed by the President from private life.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/268/s2/1"},"text":"Pub. L. 101–268, § 2(1)","children":[],"tail":", substituted “(9)” for “(8)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/268/s2/2"},"text":"Pub. L. 101–268, § 2(2)","children":[],"tail":", substituted “(10)” for “(9)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/426/s206/a/1"},"text":"Pub. L. 95–426, § 206(a)(1)","children":[],"tail":", substituted “sixteen” for “fifteen”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/426/s206/a/2"},"text":"Pub. L. 95–426, § 206(a)(2)","children":[],"tail":", (3), designated pars. (2) to (8) as (3) to (9), respectively, and added a new par. (2) “the Director of the International Communication Agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/426/s206/b/1"},"text":"Pub. L. 95–426, § 206(b)(1)","children":[],"tail":", substituted “(8)” for “(7)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/426/s206/b/2"},"text":"Pub. L. 95–426, § 206(b)(2)","children":[],"tail":", substituted “(9)” for “(8)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0c85818e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0c85818f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1301"},"text":"section 1301 of Pub. L. 105–277","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6531"},"text":"section 6531 of Title 22","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
