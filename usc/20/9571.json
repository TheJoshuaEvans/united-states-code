{"tag":"section","attrib":{"id":"id0e64c8e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9571"},"text":null,"children":[{"tag":"num","attrib":{"value":"9571"},"text":"§ 9571.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency data sources and formats","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Director, shall ensure that the Department and the Institute use common sources of data in standardized formats.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e64c8e2-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s181"},"text":"Pub. L. 107–279, title I, § 181","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1971"},"text":"116 Stat. 1971","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
