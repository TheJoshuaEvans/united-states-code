{"tag":"section","attrib":{"id":"id0d6336ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"1098dd"},"text":"§ 1098dd.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of professional judgment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A financial aid administrator shall be considered to be making a necessary adjustment in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087tt/a"},"text":"section 1087tt(a) of this title","children":[],"tail":" if the administrator makes adjustments with respect to the calculation of the expected student or parent contribution (or both) of an affected individual, and adequately documents the need for the adjustment."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d633700-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/76/s4"},"text":"Pub. L. 108–76, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-08-18"},"text":"Aug. 18, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/906"},"text":"117 Stat. 906","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d633701-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d633702-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d633703-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out in a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070"},"text":"section 1070 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Higher Education Relief Opportunities for Students Act of 2003, and not as part of title IV of the Higher Education Act of 1965 which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
