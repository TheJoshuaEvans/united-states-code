{"tag":"section","attrib":{"id":"id0dc7774e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2411"},"text":null,"children":[{"tag":"num","attrib":{"value":"2411"},"text":"§ 2411.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dc7774f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2411/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds made available to eligible agencies under this chapter may be used to provide additional funds under an applicable program if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc77750-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2411/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such program otherwise meets the requirements of this chapter and the requirements of the applicable program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc77751-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2411/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such program serves the same individuals that are served under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc77752-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2411/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such program provides services in a coordinated manner with services provided under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc77753-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2411/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such funds are used to supplement, and not supplant, funds provided from non-Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc77754-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2411/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section, the term “applicable program” means any program under any of the following provisions of law:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc77755-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2411/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapters 2 and 3 of subtitle B of title I of the Workforce Innovation and Opportunity Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3161"},"text":"29 U.S.C. 3161","children":[],"tail":" et seq., 3171 et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc77756-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2411/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Wagner-Peyser Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s49"},"text":"29 U.S.C. 49","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc77757-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2411/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds as matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, the term “additional funds” does not include funds used as matching funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dc77758-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tII/s221"},"text":"Pub. L. 88–210, title II, § 221","children":[],"tail":", formerly title III, § 321, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/b"},"text":"Pub. L. 109–270, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/745"},"text":"120 Stat. 745","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tV/s512/e/7"},"text":"Pub. L. 113–128, title V, § 512(e)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1707"},"text":"128 Stat. 1707","children":[],"tail":"; renumbered title II, § 221, "},{"tag":"ref","attrib":{"href":"/us/pl/115/224/tII/s201/a/5"},"text":"Pub. L. 115–224, title II, § 201(a)(5)","children":[],"tail":", (7), "},{"tag":"date","attrib":{"date":"2018-07-31"},"text":"July 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1621"},"text":"132 Stat. 1621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dc77759-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dc7775a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","child