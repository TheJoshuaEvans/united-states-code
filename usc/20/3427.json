{"tag":"section","attrib":{"id":"id0dd819ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3427"},"text":null,"children":[{"tag":"num","attrib":{"value":"3427"},"text":"§ 3427.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordinator for the outlying areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dd819af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3427/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate an office of the Department to coordinate the activities of the Department as they relate to the outlying areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dd819b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3427/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":", the head of the office designated under subsection (a) shall appoint a coordinator for the outlying areas, who shall be a person with substantial experience in the operation of Federal programs in the outlying areas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dd819b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3427/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The coordinator for the outlying areas shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dd819b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3427/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the principal advisor to the Department on Federal matters affecting the outlying areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd819b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3427/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate, on a periodic basis, the needs of education programs in the outlying areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd819b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3427/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist with the coordination of programs that serve the outlying areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd819b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3427/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide guidance to programs within the Department that serve the outlying areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dd819b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3427/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outlying areas defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “outlying areas” includes Guam, the Virgin Islands, American Samoa, and the Commonwealth of the Northern Marianas Islands, but does not include the freely associated states of the Republic of the Marshall Islands, the Federated States of Micronesia, and the Republic of Palau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dd819b7-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tII/s220"},"text":"Pub. L. 96–88, title II, § 220","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1072/a"},"text":"Pub. L. 107–110, title X, § 1072(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2088"},"text":"115 Stat. 2088","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dd819b8-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0dd819b9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0dd819ba-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
