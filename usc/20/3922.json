{"tag":"section","attrib":{"id":"id0de18ef6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3922"},"text":null,"children":[{"tag":"num","attrib":{"value":"3922"},"text":"§ 3922.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation of teachers from private schools","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Foundation shall, after consultation with appropriate private school representatives, make provision for the benefit of teachers in private elementary and secondary schools in the programs authorized by this subchapter, in order to assure equitable participation of such teachers.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0de18ef7-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tI/s112"},"text":"Pub. L. 98–377, title I, § 112","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/159/tII/s201"},"text":"Pub. L. 99–159, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-22"},"text":"Nov. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/897"},"text":"99 Stat. 897","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de18ef8-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de18ef9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0de18efa-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 3922 to 3954 were omitted in the gener