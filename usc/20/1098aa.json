{"tag":"section","attrib":{"id":"id0d6336d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"1098aa"},"text":"§ 1098aa.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title; findings; reference","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d6336d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098aa/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This part may be cited as the “Higher Education Relief Opportunities for Students Act of 2003”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6336d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098aa/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6336d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098aa/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is no more important cause than that of our nation’s defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6336d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098aa/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States will protect the freedom and secure the safety of its citizens.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6336d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098aa/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States military is the finest in the world and its personnel are determined to lead the world in pursuit of peace.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6336d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098aa/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hundreds of thousands of Army, Air Force, Marine Corps, Navy, and Coast Guard reservists and members of the National Guard have been called to active duty or active service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6336d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098aa/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The men and women of the United States military put their lives on hold, leave their families, jobs, and postsecondary education in order to serve their country and do so with distinction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6336d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098aa/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is no more important cause for this Congress than to support the members of the United States military and provide assistance with their transition into and out of active duty and active service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6336da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098aa/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"References in this part to “the Act” are references to the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"20 U.S.C. 1001","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6336db-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/76/s1"},"text":"Pub. L. 108–76, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-08-18"},"text":"Aug. 18, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/904"},"text":"117 Stat. 904","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d6336dc-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d6336dd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d6336de-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Higher Education Act of 1965, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329"},"text":"Pub. L. 89–329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1219"},"text":"79 Stat. 1219","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d6336df-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out in a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070"},"text":"section 1070 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Higher Education Relief Opportunities for Students Act of 2003, and not as part of title IV of the Higher Education Act of 1965 which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d6336e0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0d6336e1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Sense of Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/93/s1"},"text":"Pub. L. 110–93, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-30"},"text":"Sept. 30, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/999"},"text":"121 Stat. 999","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/93/s1"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“It is the sense of Congress that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Higher Education Relief Opportunities for Students Act of 2003 [this part] addresses the unique situations that active duty military personnel and other affected individuals may face in connection with their enrollment in postsecondary institutions and their Federal student loans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions authorized by such Act should be made permanent, thereby allowing the Secretary of Education to continue providing assistance to active duty service members and other affected individuals and their families.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
