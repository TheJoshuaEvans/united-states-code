{"tag":"section","attrib":{"id":"id0ded9cef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4424"},"text":null,"children":[{"tag":"num","attrib":{"value":"4424"},"text":"§ 4424.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with other Acts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ded9cf0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4424/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Institute shall comply with the provisions of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ded9cf1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4424/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/341"},"text":"Public Law 95–341","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1996"},"text":"42 U.S.C. 1996","children":[],"tail":" [, 1996a]), popularly known as the American Indian Religious Freedom Act,"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ded9cf2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4424/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Archeological Resources Protection Act of 1979 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s470aa"},"text":"16 U.S.C. 470aa","children":[],"tail":" et seq.), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ded9cf3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4424/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" division A of subtitle III of title 54.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ded9cf4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4424/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All Federal criminal laws relating to larceny, embezzlement, or conversion of the funds or the property of the United States shall apply to the funds and property of the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ded9cf5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4424/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other Federal assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ded9cf6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4424/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds received by the institute ","children":[{"tag":"ref","attrib":{"idref":"fn002167"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002167"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" pursuant to this chapter "},{"tag":"ref","attrib":{"idref":"fn002168"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002168"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" shall not be regarded as Federal money for purposes of meeting any matching requirements for any Federal grant, contract or cooperative agreement."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ded9cf7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4424/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Institute shall not be subject to any provision of law requiring that non-Federal funds or other moneys be used in part to fund any grant, contract, cooperative agreement, or project as a condition to the application for, or receipt of, Federal assistance. This subsection shall not be construed to effect ","children":[{"tag":"ref","attrib":{"idref":"fn002169"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002169"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “affect”."}],"tail":" in a negative fashion the review, prioritization, or acceptance of any application or proposal for such a program, solicited or unsolicited."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ded9cf8-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/498/tXV/s1517"},"text":"Pub. L. 99–498, title XV, § 1517","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1609"},"text":"100 Stat. 1609","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/644/tV/s504"},"text":"Pub. L. 101–644, title V, § 504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4669"},"text":"104 Stat. 4669","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tXIII/s1331/i"},"text":"Pub. L. 102–325, title XIII, § 1331(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/808"},"text":"106 Stat. 808","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s5/e/2"},"text":"Pub. L. 113–287, § 5(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3268"},"text":"128 Stat. 3268","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ded9cf9-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ded9cfa-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0ded9cfb-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/341"},"text":"Public Law 95–341","children":[],"tail":", popularly known as the American Indian Religious Freedom Act, referred to in subsec. (a)(1), is "},{"tag":"ref","attrib":{"href":"/us/pl/95/341"},"text":"Pub. L. 95–341","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-11"},"text":"Aug. 11, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/469"},"text":"92 Stat. 469","children":[],"tail":", which is classified to sections 1996 and 1996a of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1996"},"text":"section 1996 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"tex