{"tag":"section","attrib":{"id":"id0daf82c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1473"},"text":null,"children":[{"tag":"num","attrib":{"value":"1473"},"text":"§ 1473.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance for parent training and information centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0daf82c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1473/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daf82c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1473/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, directly or through awards to eligible entities, provide technical assistance for developing, assisting, and coordinating parent training and information programs carried out by parent training and information centers receiving assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1471"},"text":"section 1471 of this title","children":[],"tail":" and community parent resource centers receiving assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1472"},"text":"section 1472 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf82c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1473/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “eligible entity” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1461/b"},"text":"section 1461(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daf82ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1473/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide technical assistance to a parent training and information center or a community parent resource center under this section in areas such as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daf82cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1473/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective coordination of parent training efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf82cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1473/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dissemination of scientifically based research and information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf82cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1473/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotion of the use of technology, including assistive technology devices and assistive technology services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf82ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1473/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reaching underserved populations, including parents of low-income and limited English proficient children with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf82cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1473/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" including children with disabilities in general education programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf82d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1473/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" facilitation of transitions from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daf82d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1473/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early intervention services to preschool;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf82d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1473/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preschool to elementary school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf82d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1473/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elementary school to secondary school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf82d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1473/b/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secondary school to postsecondary environments; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf82d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1473/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotion of alternative methods of dispute resolution, including mediation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daf82d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1473/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration with the resource centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible entity receiving an award under subsection (a) shall develop collaborative agreements with the geographically appropriate regional resource center and, as appropriate, the regional educational laboratory supported under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9564"},"text":"section 9564 of this title","children":[],"tail":", to further parent and professional collaboration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0daf82d7-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s673"},"text":"Pub. L. 91–230, title VI, § 673","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date",