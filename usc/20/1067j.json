{"tag":"section","attrib":{"id":"id0cddb351-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067j"},"text":null,"children":[{"tag":"num","attrib":{"value":"1067j"},"text":"§ 1067j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cddb352-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint, without regard to the provisions of title 5 governing appointments in the competitive service, not less than 2 technical employees with appropriate scientific and educational background to administer the programs under this part who may be paid without regard to the provisions of chapter 51 and subchapter III of chapter 53 of such title relating to classification and General Schedule pay rates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cddb353-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for grant review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish procedures for reviewing and evaluating grants and contracts made or entered into under such programs. Procedures for reviewing grant applications, based on the peer review system, or contracts for financial assistance under this subchapter may not be subject to any review outside of officials responsible for the administration of the Minority Science and Engineering Improvement Programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cddb354-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s364"},"text":"Pub. L. 89–329, title III, § 364","children":[],"tail":", formerly title X, § 1044, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tX/s1002"},"text":"Pub. L. 99–498, title X, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1564"},"text":"100 Stat. 1564","children":[],"tail":"; renumbered title III, § 364, "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIII/s301/a/5"},"text":"Pub. L. 105–244, title III, § 301(a)(5)","children":[],"tail":", (7), "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1636"},"text":"112 Stat. 1636","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cddb355-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cddb356-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0cddb357-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1135d–3"},"text":"section 1135d–3 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
