{"tag":"section","attrib":{"id":"id0dfbcd73-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5982"},"text":null,"children":[{"tag":"num","attrib":{"value":"5982"},"text":"§ 5982.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dfbcd74-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5982/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to encourage improved instruction for minorities and Native Americans in American government and civics through a national program of accredited summer teacher training and staff development seminars or institutes followed by academic year inservice training programs conducted on college and university campuses or other appropriate sites, for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dfbcd75-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5982/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" social studies and other teachers responsible for American history, government, and civics classes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dfbcd76-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5982/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other educators who work with minority and Native American youth; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dfbcd77-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5982/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through such improved instruction to improve minority and Native American student knowledge and understanding of the American system of government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dfbcd78-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/227/tVIII/s802"},"text":"Pub. L. 103–227, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"Mar. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/209"},"text":"108 Stat. 209","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
