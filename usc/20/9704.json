{"tag":"section","attrib":{"id":"id0e6bf51d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9704"},"text":null,"children":[{"tag":"num","attrib":{"value":"9704"},"text":"§ 9704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of the Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e6bf51e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e6bf51f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall hold such hearings, sit and act at such times and places, take such testimony, and receive such evidence as the Commission deems appropriate to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6bf520-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In hearings held under this subsection, the Commission shall consider inviting witnesses from, among other groups—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e6bf521-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9704/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal Government officials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6bf522-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9704/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local government officials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6bf523-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9704/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consumer and community groups;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6bf524-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9704/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit financial literacy and education groups (such as those involved in personal finance and economic education); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6bf525-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9704/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial services industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6bf526-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information from Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may secure directly from any Federal department or agency such information as the Commission considers necessary to carry out this chapter. Upon request of the Chairperson, the head of such department or agency shall furnish such information to the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6bf527-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic studies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may conduct periodic studies regarding the state of financial literacy and education in the United States, as the Commission determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6bf528-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multilingual","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may take any action to develop and promote financial literacy and education materials in languages other than English, as the Commission deems appropriate, including for the website established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9703/b"},"text":"section 9703(b) of this title","children":[],"tail":", at the toll-free number established under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9703/c"},"text":"section 9703(c) of this title","children":[],"tail":", and in the materials developed and disseminated under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9703/d"},"text":"section 9703(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e6bf529-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/159/tV/s515"},"text":"Pub. L. 108–159, title V, § 515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-04"},"text":"Dec. 4, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2007"},"text":"117 Stat. 2007","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e6bf52a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e6bf52b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e6bf52c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section subject to joint regulations establishing effective dates as prescribed by Federal Reserve Board and Federal Trade Commission, except as otherwise provided, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/159/s3"},"text":"section 3 of Pub. L. 108–159","children":[],"tail":", set out as an Effective Date of 2003 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681"},"text":"section 1681 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id0e6bf52d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/159/s2"},"text":"section 2 of Pub. L. 108–159","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681"},"text":"section 1681 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
