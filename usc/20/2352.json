{"tag":"section","attrib":{"id":"id0dc50637-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2352"},"text":null,"children":[{"tag":"num","attrib":{"value":"2352"},"text":"§ 2352.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of funds for postsecondary education programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dc50638-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2352/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc50639-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2352/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsections (b) and (c) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2353"},"text":"section 2353 of this title","children":[],"tail":", each eligible agency shall distribute the portion of the funds made available under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s2322/a/1"},"text":"section 2322(a)(1) of this title","children":[],"tail":" to carry out this section for any fiscal year to eligible institutions or consortia of eligible institutions within the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc5063a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2352/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formula","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible institution or consortium of eligible institutions shall be allocated an amount that bears the same relationship to the portion of funds made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2322/a/1"},"text":"section 2322(a)(1) of this title","children":[],"tail":" to carry out this section for any fiscal year as the sum of the number of individuals who are Federal Pell Grant recipients and recipients of assistance from the Bureau of Indian Affairs enrolled in programs meeting the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s2355"},"text":"section 2355 of this title","children":[],"tail":" offered by such institution or consortium in the preceding fiscal year bears to the sum of the number of such recipients enrolled in such programs within the State for such year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc5063b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2352/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consortium requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dc5063c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2352/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order for a consortium of eligible institutions described in paragraph (2) to receive assistance pursuant to such paragraph, such consortium shall operate joint projects that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0dc5063d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2352/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide services to all postsecondary institutions participating in the consortium; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dc5063e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2352/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are of sufficient size, scope, and quality to be effective.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc5063f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2352/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds to consortium","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds allocated to a consortium formed to meet the requirements of this section shall be used only for purposes and programs that are mutually beneficial to all members of the consortium and shall be used only for programs authorized under this subchapter. Such funds may not be reallocated to individual members of the consortium for purposes or programs benefitting only 1 member of the consortium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc50640-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2352/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The eligible agency may waive the application of paragraph (3)(A)(i) in any case in which the eligible institution is located in a rural, sparsely populated area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc50641-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2352/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver for more equitable distribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may waive the application of subsection (a) if an eligible agency submits to the Secretary an application for such a waiver that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc50642-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2352/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates that the formula described in subsection (a) does not result in a distribution of funds to the eligible institutions or consortia within the State that have the highest numbers of economically disadvantaged individuals and that an alternative formula will result in such a distribution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc50643-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2352/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a proposal for such an alternative formula.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc50644-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2352/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum grant amount","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc50645-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2352/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No institution or consortium shall receive an allocation under this section in an amount that is less than $50,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc50646-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2352/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redistribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts that are not distributed by reason of paragraph (1) shall be redistributed to eligible institutions or consortia in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dc50647-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tI/s132"},"text":"Pub. L. 88–210, title I, § 132","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/b"},"text":"Pub. L. 109–270, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/730"},"text":"120 Stat. 730","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dc50648-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dc50649-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0dc5064a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2352, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tI/s132"},"text":"Pub. L. 88–210, title I, § 132","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/332/s1/b"},"text":"Pub. L. 105–332, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3112"},"text":"112 Stat. 3112","children":[],"tail":", related to distribution of funds for postsecondary vocational and technical education programs, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/109/270"},"text":"Pub. L. 109–270","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2352, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tIII/s302"},"text":"Pub. L. 88–210, title III, § 302","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/524/s1"},"text":"Pub. L. 98–524, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2458"},"text":"98 Stat. 2458","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/392/tIII/s301"},"text":"Pub. L. 101–392, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-09-25"},"text":"Sept. 25, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/786"},"text":"104 Stat. 786","children":[],"tail":", related to use of funds, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/332"},"text":"Pub. L. 105–332","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
