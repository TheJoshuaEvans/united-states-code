{"tag":"section","attrib":{"id":"id0db6add6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1757"},"text":null,"children":[{"tag":"num","attrib":{"value":"1757"},"text":"§ 1757.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of forced busing during school year","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0db6add7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1757/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db6add8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1757/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the forced transportation of elementary and secondary school students in implementation of the constitutional requirement for the desegregation of such schools is controversial and difficult under the best planning and administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db6add9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1757/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the forced transportation of elementary and secondary school students after the commencement of an academic school year is educationally unsound and administratively inefficient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db6adda-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1757/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student transportation orders incidental to student transfers pursuant to school desegregation plans effective beginning with academic school year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provisions of law, no order of a court, department, or agency of the United States, requiring the transportation of any student incident to the transfer of that student from one elementary or secondary school to another such school in a local educational agency pursuant to a plan requiring such transportation for the racial desegregation of any school in that agency, shall be effective until the beginning of an academic school year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db6addb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1757/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Academic school year” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this section, the term “academic school year” means, pursuant to regulations promulgated by the Secretary, the customary beginning of classes for the school year at an elementary or secondary school of a local educational agency for a school year that occurs not more often than once in any twelve-month period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db6addc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1757/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Orders subject to provisions of section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section apply to any order which was not implemented at the beginning of the 1974–1975 academic year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0db6addd-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/380/tII/s258"},"text":"Pub. L. 93–380, title II, § 258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/520"},"text":"88 Stat. 520","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIII/s301/a/1"},"text":"Pub. L. 96–88, title III, § 301(a)(1)","children":[],"tail":", title V, § 507, "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/677"},"text":"93 Stat. 677","children":[],"tail":", 692.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0db6adde-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0db6addf-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0db6ade0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on and after sixtieth day after ","children":[{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/380/s2/c"},"text":"section 2(c) of Pub. L. 93–380","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1221–1"},"text":"section 1221–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id0db6ade1-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary”, meaning the Secretary of Education, substituted for “Commissioner” in subsec. (c) pursuant to sections 301(a)(1) and 507 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88"},"text":"Pub. L. 96–88","children":[],"tail":", which are classified to sections 3441(a)(1) and 3507 of this title and which transferred functions of Commissioner of Education to Secretary of Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
