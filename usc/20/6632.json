{"tag":"section","attrib":{"id":"id0e1aee7b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632"},"text":null,"children":[{"tag":"num","attrib":{"value":"6632"},"text":"§ 6632.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Teacher and school leader incentive fund grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e1aee7c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amounts reserved by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6621/1"},"text":"section 6621(1) of this title","children":[],"tail":", the Secretary shall award grants, on a competitive basis, to eligible entities to enable the eligible entities to develop, implement, improve, or expand performance-based compensation systems or human capital management systems, in schools served by the eligible entity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1aee7d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1aee7e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under this subpart shall be for a period of not more than 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aee7f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may renew a grant awarded under this subpart for a period of not more than 2 years if the grantee demonstrates to the Secretary that the grantee is effectively using funds. Such renewal may include allowing the grantee to scale up or replicate the successful program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aee80-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local educational agency may receive (whether individually or as part of a consortium or partnership) a grant under this subpart, as amended by the Every Student Succeeds Act,","children":[{"tag":"ref","attrib":{"idref":"fn002215"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002215"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" only twice."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1aee81-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity desiring a grant under this subpart shall submit an application to the Secretary at such time and in such manner as the Secretary may reasonably require. The application shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1aee82-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the performance-based compensation system or human capital management system that the eligible entity proposes to develop, implement, improve, or expand through the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aee83-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the most significant gaps or insufficiencies in student access to effective teachers, principals, or other school leaders in high-need schools, including gaps or inequities in how effective teachers, principals, or other school leaders are distributed across the local educational agency, as identified using factors such as data on school resources, staffing patterns, school environment, educator support systems, and other school-level factors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aee84-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description and evidence of the support and commitment from teachers, principals, or other school leaders, which may include charter school leaders, in the school (including organizations representing teachers, principals, or other school leaders), the community, and the local educational agency to the activities proposed under the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aee85-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the eligible entity will develop and implement a fair, rigorous, valid, reliable, and objective process to evaluate teacher, principal, or other school leader performance under the system that is based in part on measures of student academic achievement, including the baseline performance against which evaluations of improved performance will be made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aee86-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the local educational agencies or schools to be served under the grant, including such student academic achievement, demographic, and socioeconomic information as the Secretary may request;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aee87-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the effectiveness of teachers, principals, or other school leaders in the local educational agency and the schools to be served under the grant and the extent to which the system will increase the effectiveness of teachers, principals, or other school leaders in such schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aee88-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the eligible entity will use grant funds under this subpart in each year of the grant, including a timeline for implementation of such activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aee89-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the eligible entity will continue the activities assisted under the grant after the grant period ends;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aee8a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the State, local, or other public or private funds that will be used to supplement the grant, including funds under part A, and sustain the activities assisted under the grant after the end of the grant period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aee8b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1aee8c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/c/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rationale for the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aee8d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/c/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the proposed activities are evidence-based; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aee8e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/c/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, the prior experience of the eligible entity in developing and implementing such activities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aee8f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how activities funded under this subpart will be evaluated, monitored, and publically reported.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1aee90-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award basis","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1aee91-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding a grant under this subpart, the Secretary shall give priority to an eligible entity that concentrates the activities proposed to be assisted under the grant on teachers, principals, or other school leaders serving in high-need schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aee92-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, the Secretary shall ensure an equitable geographic distribution of grants under this subpart, including the distribution of such grants between rural and urban areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1aee93-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1aee94-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity that receives a grant under this subpart shall use the grant funds to develop, implement, improve, or expand, in collaboration with teachers, principals, other school leaders, and members of the public, a performance-based compensation system or human capital management system consistent with this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aee95-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grant funds under this subpart may be used for one or more of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1aee96-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Developing or improving an evaluation and support system, including as part of a human capital management system as applicable, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e1aee97-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflects clear and fair measures of teacher, principal, or other school leader performance, based in part on demonstrated improvement in student academic achievement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e1aee98-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides teachers, principals, or other school leaders with ongoing, differentiated, targeted, and personalized support and feedback for improvement, including professional development opportunities designed to increase effectiveness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aee99-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conducting outreach within a local educational agency or a State to gain input on how to construct an evaluation and support system described in subparagraph (A) and to develop support for the evaluation and support system, including by training appropriate personnel in how to observe and evaluate teachers, principals, or other school leaders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aee9a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Providing principals or other school leaders with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e1aee9b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" balanced autonomy to make budgeting, scheduling, and other school-level decisions in a manner that meets the needs of the school without compromising the intent or essential components of the policies of the local educational agency or State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e1aee9c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authority to make staffing decisions that meet the needs of the school, such as building an instructional leadership team that includes teacher leaders or offering opportunities for teams or pairs of effective teachers or candidates to teach or start teaching in high-need schools together.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aee9d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Implementing, as part of a comprehensive performance-based compensation system, a differentiated salary structure, which may include bonuses and stipends, to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e1aee9e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" teachers who—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e1aee9f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e/2/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" teach in—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id0e1aeea0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e/2/D/i/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high-need schools; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id0e1aeea1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e/2/D/i/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high-need subjects;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e1aeea2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e/2/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" raise student academic achievement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e1aeea3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e/2/D/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take on additional leadership responsibilities; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e1aeea4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" principals or other school leaders who serve in high-need schools and raise student academic achievement in the schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aeea5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Improving the local educational agency’s system and process for the recruitment, selection, placement, and retention of effective teachers, principals, or other school leaders in high-need schools, such as by improving local educational agency policies and procedures to ensure that high-need schools are competitive and timely in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e1aeea6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attracting, hiring, and retaining effective educators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e1aeea7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offering bonuses or higher salaries to effective educators; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e1aeea8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing or strengthening school leader residency programs and teacher residency programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aeea9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Instituting career advancement opportunities characterized by increased responsibility and pay that reward and recognize effective teachers, principals, or other school leaders in high-need schools and enable them to expand their leadership and results, such as through teacher-led professional development, mentoring, coaching, hybrid roles, administrative duties, and career ladders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1aeeaa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible entity that receives a grant under this subpart shall provide, from non-Federal sources, an amount equal to 50 percent of the amount of the grant (which may be provided in cash or in kind) to carry out the activities supported by the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1aeeab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6632/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement, not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grant funds provided under this subpart shall be used to supplement, not supplant, other Federal or State funds available to carry out activities described in this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e1aeeac-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2212"},"text":"Pub. L. 89–10, title II, § 2212","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tII/s2002"},"text":"Pub. L. 114–95, title II, § 2002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1932"},"text":"129 Stat. 1932","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e1aeead-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e1aeeae-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e1aeeaf-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subpart, as amended by the Every Student Succeeds Act, referred to in subsec. (b)(3), probably means this subpart as enacted by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/tII/s2002"},"text":"Pub. L. 114–95, title II, § 2002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1931"},"text":"129 Stat. 1931","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e1aeeb0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6632, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2132"},"text":"Pub. L. 89–10, title II, § 2132","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tII/s201"},"text":"Pub. L. 107–110, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1633"},"text":"115 Stat. 1633","children":[],"tail":", related to subgrants to eligible partnerships, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"Pub. L. 114–95, § 5","children":[],"tail":", title II, § 2002, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1806"},"text":"129 Stat. 1806","children":[],"tail":", 1913, effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e1aeeb1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e1aeeb2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
