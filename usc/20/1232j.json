{"tag":"section","attrib":{"id":"id0d97b4ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232j"},"text":null,"children":[{"tag":"num","attrib":{"value":"1232j"},"text":"§ 1232j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on federally sponsored testing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d97b4ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of Federal law and except as provided in subsection (b), no funds provided to the Department of Education or to an applicable program, may be used to pilot test, field test, implement, administer or distribute in any way any federally sponsored national test in reading, mathematics, or any other subject that is not specifically and explicitly provided for in authorizing legislation enacted into law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b4ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to the Third International Mathematics and Science Study or other international comparative assessments developed under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9543/a/6"},"text":"section 9543(a)(6) of this title","children":[],"tail":" and administered to only a representative sample of pupils in the United States and in foreign nations."}],"tail":"\n"}]