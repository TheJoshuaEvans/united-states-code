{"tag":"section","attrib":{"id":"id0dc506a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355"},"text":null,"children":[{"tag":"num","attrib":{"value":"2355"},"text":"§ 2355.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local uses of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dc506a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible recipient that receives funds under this part shall use such funds to develop, coordinate, implement, or improve career and technical education programs to meet the needs identified in the comprehensive needs assessment described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2354/c"},"text":"section 2354(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc506a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds made available to eligible recipients under this part shall be used to support career and technical education programs that are of sufficient size, scope, and quality to be effective and that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc506a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide career exploration and career development activities through an organized, systematic framework designed to aid students, including in the middle grades, before enrolling and while participating in a career and technical education program, in making informed plans and decisions about future education and career opportunities and programs of study, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dc506a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" introductory courses or activities focused on career exploration and career awareness, including non-traditional fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" readily available career and labor market information, including information on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0dc506a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occupational supply and demand;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dc506aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dc506ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other information on careers aligned to State, local, or Tribal (as applicable) economic priorities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dc506ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employment sectors;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs and activities related to the development of student graduation and career plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" career guidance and academic counselors that provide information on postsecondary education and career options;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activity that advances knowledge of career opportunities and assists students in making informed decisions about future education and employment goals, including non-traditional fields; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing students with strong experience in, and comprehensive understanding of, all aspects of an industry;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc506b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide professional development for teachers, faculty, school leaders, administrators, specialized instructional support personnel, career guidance and academic counselors, or paraprofessionals, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dc506b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional development on supporting individualized academic and career and technical education instructional approaches, including the integration of academic and career and technical education standards and curricula;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional development on ensuring labor market information is used to inform the programs, guidance, and advisement offered to students, including information provided under section 49","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–2(e)(2)(C) of title 29;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing teachers, faculty, school leaders, administrators, specialized instructional support personnel, career guidance and academic counselors, or paraprofessionals, as appropriate, with opportunities to advance knowledge, skills, and understanding of all aspects of an industry, including the latest workplace equipment, technologies, standards, and credentials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting school leaders and administrators in managing career and technical education programs in the schools, institutions, or local educational agencies of such school leaders or administrators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the implementation of strategies to improve student achievement and close gaps in student participation and performance in career and technical education programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing teachers, faculty, specialized instructional support personnel, career guidance and academic counselors, principals, school leaders, or paraprofessionals, as appropriate, with opportunities to advance knowledge, skills, and understanding in pedagogical practices, including, to the extent the eligible recipient determines that such evidence is reasonably available, evidence-based pedagogical practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training teachers, faculty, school leaders, administrators, specialized instructional support personnel, career guidance and academic counselors, or paraprofessionals, as appropriate, to provide appropriate accommodations for individuals with disabilities, and students with disabilities who are provided accommodations under the Rehabilitation Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"29 U.S.C. 701","children":[],"tail":" et seq.) or the Individuals with Disabilities Education Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"20 U.S.C. 1400","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training teachers, faculty, specialized instructional support personnel, career guidance and academic counselors, and paraprofessionals in frameworks to effectively teach students, including a particular focus on students with disabilities and English learners, which may include universal design for learning, multi-tier systems of supports, and positive behavioral interventions and support; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training for the effective use of community spaces that provide access to tools, technology, and knowledge for learners and entrepreneurs, such as makerspaces or libraries;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc506bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide within career and technical education the skills necessary to pursue careers in high-skill, high-wage, or in-demand industry sectors or occupations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc506bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support integration of academic skills into career and technical education programs and programs of study to support—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dc506bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" CTE participants at the secondary school level in meeting the challenging State academic standards adopted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/1"},"text":"section 6311(b)(1) of this title","children":[],"tail":" by the State in which the eligible recipient is located; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" CTE participants at the postsecondary level in achieving academic skills;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc506bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" plan and carry out elements that support the implementation of career and technical education programs and programs of study and that result in increasing student achievement of the local levels of performance established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2323"},"text":"section 2323 of this title","children":[],"tail":", which may include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dc506c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a curriculum aligned with the requirements for a program of study;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sustainable relationships among education, business and industry, and other community stakeholders, including industry or sector partnerships in the local area, where applicable, that are designed to facilitate the process of continuously updating and aligning programs of study with skills that are in demand in the State, regional, or local economy, and in collaboration with business outreach staff in one-stop centers, as defined in section 3 of the Workforce Innovation and Opportunity Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"29 U.S.C. 3102","children":[],"tail":"), and other appropriate organizations, including community-based and youth-serving organizations;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where appropriate, expanding opportunities for CTE concentrators to participate in accelerated learning programs (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7114/b/3/A/i/IV"},"text":"section 7114(b)(3)(A)(i)(IV) of this title","children":[],"tail":"), including dual or concurrent enrollment programs, early college high schools, and the development or implementation of articulation agreements as part of a career and technical education program of study;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate equipment, technology, and instructional materials (including support for library resources) aligned with business and industry needs, including machinery, testing equipment, tools, implements, hardware and software, and other new and emerging instructional materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a continuum of work-based learning opportunities, including simulated work environments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industry-recognized certification examinations or other assessments leading toward a recognized postsecondary credential;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts to recruit and retain career and technical education program teachers, faculty, school leaders, administrators, specialized instructional support personnel, career guidance and academic counselors, and paraprofessionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/5/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where applicable, coordination with other education and workforce development programs and initiatives, including career pathways and sector partnerships developed under the Workforce Innovation and Opportunity Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"29 U.S.C. 3101","children":[],"tail":" et seq.) and other Federal laws and initiatives that provide students with transition-related services, including the Individuals with Disabilities Education Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"20 U.S.C. 1400","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/5/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanding opportunities for students to participate in distance career and technical education and blended-learning programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/5/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanding opportunities for students to participate in competency-based education programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/5/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving career guidance and academic counseling programs that assist students in making informed academic and career and technical education decisions, including academic and financial aid counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/5/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the integration of employability skills into career and technical education programs and programs of study, including through family and consumer science programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/5/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting programs and activities that increase access, student engagement, and success in science, technology, engineering, and mathematics fields (including computer science and architecture) for students who are members of groups underrepresented in such subject fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/5/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing career and technical education, in a school or other educational setting, for adults or out-of-school youth to complete secondary school education or upgrade technical skills;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/5/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting career and technical student organizations, including student preparation for and participation in technical skills competitions aligned with career and technical education program standards and curricula;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/5/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making all forms of instructional content widely available, which may include use of open educational resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/5/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the integration of arts and design skills, when appropriate, into career and technical education programs and programs of study;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/5/R"},"text":null,"children":[{"tag":"num","attrib":{"value":"R"},"text":"(R)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partnering with a qualified intermediary to improve training, the development of public-private partnerships, systems development, capacity-building, and scalability of the delivery of high-quality career and technical education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/5/S"},"text":null,"children":[{"tag":"num","attrib":{"value":"S"},"text":"(S)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support to reduce or eliminate out-of-pocket expenses for special populations participating in career and technical education, including those participating in dual or concurrent enrollment programs or early college high school programs, and supporting the costs associated with fees, transportation, child care, or mobility challenges for those special populations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc506d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/5/T"},"text":null,"children":[{"tag":"num","attrib":{"value":"T"},"text":"(T)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities to improve career and technical education programs; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc506d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement evaluations of the activities carried out with funds under this part, including evaluations necessary to complete the comprehensive needs assessment required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2354/c"},"text":"section 2354(c) of this title","children":[],"tail":" and the local report required under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s2323/b/4/B"},"text":"section 2323(b)(4)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc506d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pooling funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible recipient may pool a portion of funds received under this chapter with a portion of funds received under this chapter available to one or more eligible recipients to support implementation of programs of study through the activities described in subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc506d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2355/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible recipient receiving funds under this part shall not use more than 5 percent of such funds for costs associated with the administration of activities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dc506d7-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tI/s135"},"text":"Pub. L. 88–210, title I, § 135","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/b"},"text":"Pub. L. 109–270, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref"