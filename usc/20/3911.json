{"tag":"section","attrib":{"id":"id0ddf45b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3911"},"text":null,"children":[{"tag":"num","attrib":{"value":"3911"},"text":"§ 3911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ddf45b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3911/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Congress declares that the science and engineering education responsibilities of the National Science Foundation are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ddf45b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3911/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the quality of instruction in the fields of mathematics, science, and engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf45b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3911/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support research, fellowships, teacher-faculty-business exchange programs in mathematics, science, and engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf45b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3911/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the quality and availability of instrumentation for mathematics, science, and engineering instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf45b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3911/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage partnerships in education between local and State education agencies, business and industry, colleges and universities, and cultural and professional institutions and societies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf45b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3911/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the quality of education at all levels in the fields of mathematics, science, and engineering.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ddf45b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3911/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In exercising its responsibilities to strengthen scientific and engineering research potential and science and engineering education programs at all levels, the Foundation shall avoid undue concentration of support for research and education activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ddf45b9-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tI/s101"},"text":"Pub. L. 98–377, title I, § 101","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/159/tII/s201"},"text":"Pub. L. 99–159, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-22"},"text":"Nov. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/893"},"text":"99 Stat. 893","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ddf45ba-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ddf45bb-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0ddf45bc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3911, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tI/s101"},"text":"Pub. L. 98–377, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-11"},"text":"Aug. 11, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1268"},"text":"98 Stat. 1268","children":[],"tail":", related to grants for teacher institutes, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/99/159/s201"},"text":"section 201 of Pub. L. 99–159","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3913"},"text":"section 3913 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0ddf45bd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0ddf45be-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Undergraduate Science Improvement","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/570/tI/s112"},"text":"Pub. L. 100–570, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2870"},"text":"102 Stat. 2870","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/570/tI/s112"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Congress finds that the support of undergraduate science and engineering education is a critical component in a comprehensive national policy intended to ensure the Nation’s future supply of scientists and engineers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In accordance with the provisions of this Act [see Tables for classification], the Foundation shall support undergraduate science and engineering activities in instrumentation and laboratory improvement, undergraduate faculty enhancement, undergraduate research opportunities, undergraduate curriculum development, and efforts to encourage the participation of women, minorities, and the disabled in such fields.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out the provisions of this section, the Foundation shall take into account the special needs of two-year and four-year colleges and universities.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
