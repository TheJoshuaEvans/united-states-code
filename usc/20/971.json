{"tag":"section","attrib":{"id":"id0cb2d31c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s971"},"text":null,"children":[{"tag":"num","attrib":{"value":"971"},"text":"§ 971.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements to indemnify against loss or damage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cb2d31d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s971/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of Federal Council on the Arts and Humanities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Council on the Arts and Humanities (hereinafter in this chapter referred to as the “Council”), established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s958"},"text":"section 958 of this title","children":[],"tail":", is authorized to make agreements to indemnify against loss or damage such items as may be eligible for such indemnity agreements under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s972"},"text":"section 972 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cb2d31e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s971/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with the provisions of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cb2d31f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s971/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on such terms and conditions as the Council shall prescribe, by regulation, in order to achieve the purposes of this chapter and, consistent with such purposes, to protect the financial interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cb2d320-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s971/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council as “agency”","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cb2d321-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s971/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this chapter, the Council shall be an “agency” within the meaning of the appropriate definitions of such term in title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cb2d322-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s971/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this chapter, the Secretary of the Smithsonian Institution, the Director of the National Gallery of Art, the member designated by the Chairman of the Senate Commission of Art and Antiquities and the member designated by the Speaker of the House of Representatives shall not serve as members of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cb2d323-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/158/s2"},"text":"Pub. L. 94–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-20"},"text":"Dec. 20, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/844"},"text":"89 Stat. 844","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/194/tIII/s301"},"text":"Pub. L. 99–194, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-20"},"text":"Dec. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1345"},"text":"99 Stat. 1345","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cb2d324-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cb2d325-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cb2d326-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/194"},"text":"Pub. L. 99–194","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cb2d327-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0cb2d328-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/158/s9"},"text":"Pub. L. 94–158, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-20"},"text":"Dec. 20, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/846"},"text":"89 Stat. 846","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/158/s9"},"text":"“This Act [see Short Title note below] shall become effective 30 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1975-12-20"},"text":"Dec. 20, 1975","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id0cb2d329-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/158/s1"},"text":"Pub. L. 94–158, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-20"},"text":"Dec. 20, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/844"},"text":"89 Stat. 844","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/158/s1"},"text":"“This Act [enacting this chapter and provisions set out as a note under this section] may be cited as the ‘Arts and Artifacts Indemnity Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
