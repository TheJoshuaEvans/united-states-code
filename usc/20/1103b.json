{"tag":"section","attrib":{"id":"id0d6a6357-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1103b"},"text":"§ 1103b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application review process","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d6a6358-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review panel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All applications submitted under this subchapter by Hispanic-serving institutions shall be read by a panel of readers composed of individuals who are selected by the Secretary and who include individuals representing Hispanic-serving institutions. The Secretary shall ensure that no individual assigned under this section to review any application has any conflict of interest with regard to the application that might impair the impartiality with which the individual conducts the review under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6a6359-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Instruction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All readers selected by the Secretary shall receive thorough instruction from the Secretary regarding the evaluation process for applications submitted under this subchapter that are consistent with the provisions of this subchapter, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6a635a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an enumeration of the factors to be used to determine the quality of applications submitted under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a635b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an enumeration of the factors to be used to determine whether a grant should be awarded for a project under this subchapter, the amount of any such grant, and the duration of any such grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6a635c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations of panel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this subchapter, the Secretary shall take into consideration the recommendations of the panel made under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6a635d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than June 30 of each year, the Secretary shall notify each Hispanic-serving institution making an application under this subchapter of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6a635e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scores given the institution by the panel pursuant to this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a635f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recommendations of the panel with respect to such application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a6360-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons for the decision of the Secretary in awarding or refusing to award a grant under this subchapter, and any modifications, if any, in the recommendations of the panel made by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6a6361-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tV/s523"},"text":"Pub. L. 89–329, title V, § 523","children":[],"tail":", formerly § 513, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tV/s501"},"text":"Pub. L. 105–244, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1772"},"text":"112 Stat. 1772","children":[],"tail":"; renumbered § 523, "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tV/s502/a/2"},"text":"Pub. L. 110–315, title V, § 502(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3331"},"text":"122 Stat. 3331","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d6a6362-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d6a6363-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d6a6364-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1103b, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tV/s513"},"text":"Pub. L. 89–329, title V, § 513","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tV/s501/a"},"text":"Pub. L. 102–325, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/674"},"text":"106 Stat. 674","children":[],"tail":", related to use of funds, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1103b, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tV/s513"},"text":"Pub. L. 89–329, title V, § 513","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tV/s501/a"},"text":"Pub. L. 99–498, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1497"},"text":"100 Stat. 1497","children":[],"tail":", related to review of applications for grants, prior to the general amendment of this subchapter by "},{"tag":"ref","at