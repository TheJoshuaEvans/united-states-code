{"tag":"section","attrib":{"id":"id0c9fc022-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s807"},"text":null,"children":[{"tag":"num","attrib":{"value":"807"},"text":"§ 807.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions; authorization of appropriations for administrative and other expenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c9fc023-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s807/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in this chapter the term “State” means any State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, Guam, American Samoa, the Trust Territory of the Pacific Islands, and the Virgin Islands; and the term “Secretary” means the Secretary of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c9fc024-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s807/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated such sums as may be necessary for administrative and other expenses in carrying out this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c9fc025-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/560/tVIII/s808"},"text":"Pub. L. 88–560, title VIII, § 808","children":[],"tail":", formerly § 807, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/152/tIII/s307"},"text":"Pub. L. 91–152, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-24"},"text":"Dec. 24, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/394"},"text":"83 Stat. 394","children":[],"tail":"; renumbered § 808, "},{"tag":"ref","attrib"