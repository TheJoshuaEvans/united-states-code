{"tag":"section","attrib":{"id":"id0ccd124a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032"},"text":null,"children":[{"tag":"num","attrib":{"value":"1032"},"text":"§ 1032.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ccd124b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to award grants to, or enter into contracts or cooperative agreements with, eligible consortia to pay the Federal share of the costs of projects to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ccd124c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assist in the graduation of teacher candidates who are prepared to use modern information, communication, and learning tools to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ccd124d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve student learning, assessment, and learning management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ccd124e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" help students develop learning skills to succeed in higher education and to enter the workforce;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccd124f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen and develop partnerships among the stakeholders in teacher preparation to transform teacher education and ensure technology-rich teaching and learning environments throughout a teacher candidate’s preservice education, including clinical experiences; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccd1250-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the effectiveness of departments, schools, and colleges of education at institutions of higher education in preparing teacher candidates for successful implementation of technology-rich teaching and learning environments, including environments consistent with the principles of universal design for learning, that enable kindergarten through grade 12 students to develop learning skills to succeed in higher education and to enter the workforce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ccd1251-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount and duration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant, contract, or cooperative agreement under this subpart—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ccd1252-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be for not more than $2,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccd1253-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be for a three-year period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccd1254-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be renewed for one additional year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ccd1255-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of any project funded under this subpart shall not exceed 75 percent. The non-Federal share of the cost of such project may be provided in cash or in kind, fairly evaluated, including services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ccd1256-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible consortium","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subpart, the term “eligible consortium” means a consortium of members that includes the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ccd1257-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not less than one institution of higher education that awards baccalaureate or masters degrees and prepares teachers for initial entry into teaching.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccd1258-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not less than one State educational agency or local educational agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccd1259-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A department, school, or college of education at an institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccd125a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A department, school, or college of arts and sciences at an institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccd125b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1032/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not less than one entity with the capacity to contribute to the technology-related reform of teacher preparation programs, which may be a professional association, foundation, museum, library, for-profit business, public or private nonprofit organization, community-based organization, or other entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ccd125c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tII/s231"},"text":"Pub. L. 89–329, title II, § 231","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tII/s201/3"},"text":"Pub. L. 110–315, title II, § 201(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3154"},"text":"122 Stat. 3154","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tII/s201/3"},"text":"Pub. L. 111–39, title II, § 201(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1936"},"text":"123 Stat. 1936","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ccd125d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ccd125e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0ccd125f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1032, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tII/s222"},"text":"Pub. L. 89–329, title II, § 222","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tII/s201"},"text":"Pub. L. 96–374, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-1