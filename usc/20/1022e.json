{"tag":"section","attrib":{"id":"id0ccd1206-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1022e"},"text":"§ 1022e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Teacher development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ccd1207-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual goals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each institution of higher education that conducts a traditional teacher preparation program (including programs that offer any ongoing professional development programs) or alternative routes to State certification or licensure program, and that enrolls students receiving Federal assistance under this chapter, shall set annual quantifiable goals for increasing the number of prospective teachers trained in teacher shortage areas designated by the Secretary or by the State educational agency, including mathematics, science, special education, and instruction of limited English proficient students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ccd1208-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assurances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each institution described in subsection (a) shall provide assurances to the Secretary that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ccd1209-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training provided to prospective teachers responds to the identified needs of the local educational agencies or States where the institution’s graduates are likely to teach, based on past hiring and recruitment trends;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccd120a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training provided to prospective teachers is closely linked with the needs of schools and the instructional decisions new teachers face in the classroom;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccd120b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prospective special education teachers receive course work in core academic subjects and receive training in providing instruction in core academic subjects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccd120c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" general education teachers receive training in providing instruction to diverse populations, including children with disabilities, limited English proficient students, and children from low-income families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccd120d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022e/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prospective teachers receive training on how to effectively teach in urban and rural schools, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ccd120e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1022e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to require an institution to create a new teacher preparation area of concentration or degree program or adopt a specific curriculum in complying with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ccd120f-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tII/s206"},"text":"Pub. L. 89–329, title II, § 206","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tII/s201/2"},"text":"Pub. L. 110–315, title II, § 201(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3152"},"text":"122 Stat. 3152","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ccd1210-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ccd1211-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0ccd1212-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s206"},"text":"section 206 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1026"},"text":"section 1026 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s206"},"text":"section 206 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1026"},"text":"section 1026 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/96/374"},"text":"Pub. L. 96–374","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
