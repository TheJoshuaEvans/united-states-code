{"tag":"section","attrib":{"id":"id0e48196f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7708"},"text":null,"children":[{"tag":"num","attrib":{"value":"7708"},"text":"§ 7708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e481970-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount appropriated for any fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7714/e"},"text":"section 7714(e) of this title","children":[],"tail":", the Secretary may continue to provide assistance for school facilities that were supported by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-23/s10"},"text":"section 10 of the Act of September 23, 1950","children":[],"tail":" (Public Law 815, 81st Congress) (as such Act was in effect on the day preceding "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"October 20, 1994","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e481971-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e481972-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7708/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"tex