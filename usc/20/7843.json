{"tag":"section","attrib":{"id":"id0e4cfb86-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7843"},"text":null,"children":[{"tag":"num","attrib":{"value":"7843"},"text":"§ 7843.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidated reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e4cfb87-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7843/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to simplify reporting requirements and reduce reporting burdens, the Secretary shall establish procedures and criteria under which a State educational agency, in consultation with the Governor of the State, may submit a consolidated State annual report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4cfb88-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7843/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report shall contain information about the programs included in the report, including the performance of the State under those programs, and other matters as the Secretary determines are necessary, such as monitoring activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4cfb89-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7843/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replacement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report shall replace separate individual annual reports for the programs included in the consolidated State annual report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e4cfb8a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8303"},"text":"Pub. L. 89–10, title VIII, § 8303","children":[],"tail":", formerly title IX, § 9303, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIX/s901"},"text":"Pub. L. 107–110, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1969"},"text":"115 Stat. 1969","children":[],"tail":"; renumbered title VIII, § 8303, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII/s8001/a/3"},"text":"Pub. L. 114–95, title VIII, § 8001(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2088"},"text":"129 Stat. 2088","children":[],"tail":", 2089.)"}],"tail":"\n"}],"tail":null}
