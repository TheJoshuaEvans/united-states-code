{"tag":"section","attrib":{"id":"id0d895dce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161t"},"text":"§ 1161t.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model programs for Centers of Excellence for Veteran Student Success","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d895dcf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the purpose of this section to encourage model programs to support veteran student success in postsecondary education by coordinating services to address the academic, financial, physical, and social needs of veteran students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895dd0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d895dd1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations under subsection (f), the Secretary shall award grants to institutions of higher education to develop model programs to support veteran student success in postsecondary education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895dd2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under this section shall be awarded for a period of three years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895dd3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d895dd4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An institution of higher education receiving a grant under this section shall use such grant to carry out a model program that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895dd5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a Center of Excellence for Veteran Student Success on the campus of the institution to provide a single point of contact to coordinate comprehensive support services for veteran students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895dd6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a veteran student support team, including representatives from the offices of the institution responsible for admissions, registration, financial aid, veterans benefits, academic advising, student health, personal or mental health counseling, career advising, disabilities services, and any other office of the institution that provides support to veteran students on campus;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895dd7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing a coordinator whose primary responsibility is to coordinate the model program carried out under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895dd8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring the rates of veteran student enrollment, persistence, and completion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895dd9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing a plan to sustain the Center of Excellence for Veteran Student Success after the grant period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895dda-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An institution of higher education receiving a grant under this section may use such grant to carry out any of the following activities with respect to veteran students:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895ddb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Outreach and recruitment of such students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895ddc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Supportive instructional services for such students, which may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d895ddd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal, academic, and career counseling, as an ongoing part of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d895dde-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tutoring and academic skill-building instruction assistance, as needed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d895ddf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance with special admissions and transfer of credit from previous postsecondary education or experience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895de0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistance in obtaining student financial aid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895de1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Housing support for veteran students living in institutional facilities and commuting veteran students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895de2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cultural events, academic programs, orientation programs, and other activities designed to ease the transition to campus life for veteran students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895de3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Support for veteran student organizations and veteran student support groups on campus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895de4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordination of academic advising and admissions counseling with military bases and national guard units in the area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895de5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other support services the institution determines to be necessary to ensure the success of veterans in achieving educational and career goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895de6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application; selection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d895de7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be considered for a grant under this section, an institution of higher education shall submit to the Secretary an application at such time, in such manner, and accompanied by such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895de8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this section, the Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895de9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of veteran students enrolled at an institution of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895dea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the need for model programs to address the needs of veteran students at a wide range of institutions of higher education, including the need to provide—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d895deb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an equitable distribution of such grants to institutions of higher education of various types and sizes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d895dec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an equitable geographic distribution of such grants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d895ded-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an equitable distribution of such grants among rural and urban areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895dee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and accountability plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop an evaluation and accountability plan for model programs funded under this section to objectively measure the impact of such programs, including a measure of whether postsecondary education enrollment, persistence, and completion for veterans increases as a result of such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895def-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161t/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d895df0-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s873"},"text":"Pub. L. 89–329, title VIII, § 873","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3428"},"text":"122 Stat. 3428","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
