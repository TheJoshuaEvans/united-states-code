{"tag":"section","attrib":{"id":"id0e51b613-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7908"},"text":null,"children":[{"tag":"num","attrib":{"value":"7908"},"text":"§ 7908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Armed Forces recruiter access to students and student recruiting information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e51b614-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e51b615-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7908/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to student recruiting information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232g/a/5/B"},"text":"section 1232g(a)(5)(B) of this title","children":[],"tail":", each local educational agency receiving assistance under this chapter shall provide, upon a request made by a military recruiter or an institution of higher education, access to the name, address, and telephone listing of each secondary school student served by the local educational agency, unless the parent of such student has submitted the prior consent request under paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e51b616-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7908/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e51b617-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7908/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opt-out process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A parent of a secondary school student may submit a written request, to the local educational agency, that the student’s name, address, and telephone listing not be released for purposes of paragraph (1) without prior written consent of the parent. Upon receiving such request, the local educational agency may not release the student’s name, address, and telephone listing for such purposes without the prior written consent of the parent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e51b618-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7908/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of opt-out process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each local educational agency shall notify the parents of the students served by the agency of the option to make a request described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e51b619-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7908/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Same access to students","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each local educational agency receiving assistance under this chapter shall provide military recruiters the same access to secondary school students as is provided to institutions of higher education or to prospective employers of those students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e51b61a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7908/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction prohibiting opt-in processes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to allow a local educational agency to withhold access to a student’s name, address, and telephone listing from a military recruiter or institution of higher education by implementing an opt-in process or any other process other than the written consent request process under paragraph (2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e51b61b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7908/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parental consent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, whenever a student has attained 18 years of age, the permission or consent required of and the rights accorded to the parents of the student shall only be required of and accorded to the student.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e51b61c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of Defense, shall, not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"December 10, 2015","children":[],"tail":", notify school leaders, school administrators, and other educators about the requirements of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e51b61d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7908/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of this section do not apply to a private secondary school that maintains a religious objection to service in the Armed Forces if the objection is verifiable through the corporate or other organizational documents or materials of that school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e51b61e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8528"},"text":"Pub. L. 89–10, title VIII, § 8528","children":[],"tail":", formerly title IX, § 9528, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIX/s901"},"text":"Pub. L. 107–110, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1983"},"text":"115 Stat. 1983","children":[],"tail":"; renumbered title VIII, § 8528, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII"},"text":"Pub. L. 114–95, title VIII","children":[],"tail":", §§ 8001(a)(6), 8025, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2088"},"text":"129 Stat. 2088","children":[],"tail":", 2089, 2114.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e51b61f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e51b620-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e51b621-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7908, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIX/s9208"},"text":"Pub. L. 89–10, title IX, § 9208","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3802"},"text":"108 Stat. 3802","children":[],"tail":", related to Native Hawaiian special education programs, prior to the general amendment of former subchapter IX of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e51b622-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8025"},"text":"Pub. L. 114–95, § 8025","children":[],"tail":", added subsecs. (a) to (c) and struck out former subsecs. (a) to (d) which related to policy regarding access to student recruiting information, notification of requirements of this section, exception for a private secondary school that maintains a religious objection to service in the Armed Forces, and special rule regarding Connecticut State law, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e51b623-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e51b624-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
