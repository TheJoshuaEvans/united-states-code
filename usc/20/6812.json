{"tag":"section","attrib":{"id":"id0e1fa995-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6812"},"text":null,"children":[{"tag":"num","attrib":{"value":"6812"},"text":"§ 6812.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this part are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1fa996-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6812/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to help ensure that English learners, including immigrant children and youth, attain English proficiency and develop high levels of academic achievement in English;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1fa997-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6812/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist all English learners, including immigrant children and youth, to achieve at high levels in academic subjects so that all English learners can meet the same challenging State academic standards that all children are expected to meet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1fa998-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6812/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist teachers (including preschool teachers), principals and other school leaders, State educational agencies, local educational agencies, and schools in establishing, implementing, and sustaining effective language instruction educational programs designed to assist in teaching English learners, including immigrant children and youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1fa999-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6812/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist teachers (including preschool teachers), principals and other school leaders, State educational agencies, and local educational agencies to develop and enhance their capacity to provide effective instructional programs designed to prepare English learners, including immigrant children and youth, to enter all-English instructional settings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1fa99a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6812/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote parental, family, and community participation in language instruction educational programs for the parents, families, and communities of English learners.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e1fa99b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIII/s3102"},"text":"Pub. L. 89–10, title III, § 3102","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIII/s301"},"text":"Pub. L. 107–110, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1690"},"text":"115 Stat. 1690","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIII/s3003/a"},"text":"Pub. L. 114–95, title III, § 3003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1954"},"text":"129 Stat. 1954","children":[],"