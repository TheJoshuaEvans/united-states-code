{"tag":"section","attrib":{"id":"id0e304b79-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7281"},"text":null,"children":[{"tag":"num","attrib":{"value":"7281"},"text":"§ 7281.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National activities for school safety","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e304b7a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7281/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e304b7b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7281/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the funds reserved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7251/b/1"},"text":"section 7251(b)(1) of this title","children":[],"tail":", the Secretary—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e304b7c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7281/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall use a portion of such funds for the Project School Emergency Response to Violence program (in this section referred to as “Project SERV”), in order to provide education-related services to eligible entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304b7d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7281/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use a portion of such funds to carry out other activities to improve students’ safety and well-being, during and after the school day, under this section directly or through grants, contracts, or cooperative agreements with public or private entities or individuals, or other Federal agencies, such as providing technical assistance to States and local educational agencies carrying out activities under this section or conducting a national evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304b7e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7281/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts reserved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7251/b/1"},"text":"section 7251(b)(1) of this title","children":[],"tail":" for Project SERV are authorized to remain available until expended for Project SERV."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e304b7f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7281/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project SERV","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e304b80-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7281/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under subsection (a) for extended services grants under Project SERV may be used by an eligible entity to initiate or strengthen violence prevention activities as part of the activities designed to restore the learning environment that was disrupted by the violent or traumatic crisis in response to which the grant was awarded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304b81-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7281/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application process","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e304b82-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7281/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity desiring to use a portion of extended services grant funds under Project SERV to initiate or strengthen a violence prevention activity shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e304b83-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7281/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit, in an application that meets all requirements of the Secretary for Project SERV, the information described in subparagraph (B); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e304b84-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7281/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an eligible entity that has already received an extended services grant under Project SERV, submit an addition to the original application that includes the information described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304b85-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7281/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application, or addition to an application, for an extended services grant pursuant to subparagraph (A) shall include the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e304b86-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7281/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A demonstration of the need for funds due to a continued disruption or a substantial risk of disruption to the learning environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e304b87-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7281/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An explanation of the proposed activities that are designed to restore and preserve the learning environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e304b88-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7281/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A budget and budget narrative for the proposed activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304b89-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7281/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any award of funds under Project SERV for violence prevention activities under this section shall be subject to the discretion of the Secretary and the availability of funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304b8a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7281/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds provided to an eligible entity for violence prevention activities may be used for construction, renovation, or repair of a facility or for the permanent infrastructure of the eligible entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e304b8b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7281/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible entity” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e304b8c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7281/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local educational agency, as defined in subparagraph (A), (B), or (C) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801/30"},"text":"section 7801(30) of this title","children":[],"tail":", or institution of higher education in which the learning environment has been disrupted due to a violent or traumatic crisis; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304b8d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7281/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Indian Education in a case where the learning environment of a school operated or funded by the Bureau, including a school meeting the definition of a local educational agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801/30/C"},"text":"section 7801(30)(C) of this title","children":[],"tail":", has been disrupted due to a violent or traumatic crisis."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e304b8e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4631"},"text":"Pub. L. 89–10, title IV, § 4631","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4601"},"text":"Pub. L. 114–95, title IV, § 4601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2032"},"text":"129 Stat. 2032","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e304b8f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e304b90-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e304b91-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 7281 to 7281b and 7283 to 7283g were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"Pub. L. 114–95, § 5","children":[],"tail":", title IV, § 4001(b)(1)(C), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1806"},"text":"129 Stat. 1806","children":[],"tail":", 1967, effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7281, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5601"},"text":"Pub. L. 89–10, title V, § 5601","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1866"},"text":"115 Stat. 1866","children":[],"tail":", authorized Secretary to provide additional assistance to meet special circumstances."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7281a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5602"},"text":"Pub. L. 89–10, title V, § 5602","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1866"},"text":"115 Stat. 1866","children":[],"tail":", related to eligibility."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7281b, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5603"},"text":"Pub. L. 89–10, title V, § 5603","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1867"},"text":"115 Stat. 1867","children":[],"tail":", related to maximum amount."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7283, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5611"},"text":"Pub. L. 89–10, title V, § 5611","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1867"},"text":"115 Stat. 1867","children":[],"tail":", provided that subpart 21 of subpart D of former subchapter V of this chapter could be cited as the “Women’s Educational Equity Act of 2001” and related to findings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7283a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5612"},"text":"Pub. L. 89–10, title V, § 5612","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1868"},"text":"115 Stat. 1868","children":[],"tail":", related to statement of purpose."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7283b, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5613"},"text":"Pub. L. 89–10, title V, § 5613","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1868"},"text":"115 Stat. 1868","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/279/tIV/s404/d/7"},"text":"Pub. L. 107–279, title IV, § 404(d)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1986"},"text":"116 Stat. 1986","children":[],"tail":", authorized program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7283c, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5614"},"text":"Pub. L. 89–10, title V, § 5614","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1871"},"text":"115 Stat. 1871","children":[],"tail":", related to applications."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7283d, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5615"},"text":"Pub. L. 89–10, title V, § 5615","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1871"},"text":"115 Stat. 1871","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/279/tIV/s404/d/5/D"},"text":"Pub. L. 107–279, title IV, § 404(d)(5)(D)","children":[],"tail":", (8), "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1986"},"text":"116 Stat. 1986","children":[],"tail":", related to criteria and priorities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7283e, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5616"},"text":"Pub. L. 89–10, title V, § 5616","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1872"},"text":"115 Stat. 1872","children":[],"tail":", related to report requirement."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7283f, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5617"},"text":"Pub. L. 89–10, title V, § 5617","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1872"},"text":"115 Stat. 1872","children":[],"tail":", related to administration."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7283g, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5618"},"text":"Pub. L. 89–10, title V, § 5618","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1873"},"text":"115 Stat. 1873","children":[],"tail":", related to amounts to be used to carry out certain activities."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e304b92-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e304b93-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
