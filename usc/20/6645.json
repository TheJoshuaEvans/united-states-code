{"tag":"section","attrib":{"id":"id0e1d384a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6645"},"text":null,"children":[{"tag":"num","attrib":{"value":"6645"},"text":"§ 6645.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National evaluation and information dissemination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e1d384b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6645/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From funds reserved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6642/b/1"},"text":"section 6642(b)(1) of this title","children":[],"tail":", the Director of the Institute of Education Sciences shall conduct a national evaluation of the grant and subgrant programs assisted under this subpart. Such evaluation shall include high-quality research that applies rigorous and systematic procedures to obtain valid knowledge relevant to the implementation and effect of the programs and shall directly coordinate with individual State evaluations of the programs’ implementation and impact."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1d384c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6645/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program improvement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1d384d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6645/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the findings of the evaluation conducted under this section to State educational agencies and subgrant recipients for use in program improvement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d384e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6645/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such findings publicly available, including on the websites of the Department and the Institute of Education Sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d384f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6645/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit such findings to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Education and the Workforce of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d3850-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6645/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make publicly available, in a manner consistent with paragraph (2), best practices for implementing evidence-based activities under this subpart, including evidence-based activities, defined for the purpose of this paragraph as activities meeting the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801/21/A/i"},"text":"section 7801(21)(A)(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e1d3851-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2225"},"text":"Pub. L. 89–10, title II, § 2225","children":[],"