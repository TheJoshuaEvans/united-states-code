{"tag":"section","attrib":{"id":"id0df25872-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5205"},"text":null,"children":[{"tag":"num","attrib":{"value":"5205"},"text":"§ 5205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of income on endowment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0df25873-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5205/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":", (b) Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101"},"text":"Pub. L. 104–134, title I, § 101[(a)]","children":[],"tail":" [title IV, § 407], "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321"},"text":"110 Stat. 1321","children":[],"tail":", 1321–45; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0df25874-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5205/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural exchange program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any fiscal year, as may be determined by Eisenhower Exchange Fellowships, Incorporated, a portion of the amounts made available to Eisenhower Exchange Fellowships, Incorporated, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5203/a"},"text":"section 5203(a) of this title","children":[],"tail":" shall be used to provide fellowships for agricultural exchange programs for farmers from the United States and foreign countries."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0df25875-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5205/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation by United States minority populations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to ensure that the United States fellows participating in programs of the Eisenhower Exchange Fellowships, Incorporated, are representative of the cultural, ethnic, and racial diversity of the American people, of the amounts made available to Eisenhower Exchange Fellowships, Incorporated, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5203/a"},"text":"section 5203(a) of this title","children":[],"tail":" which are obligated and expended for United States fellowship programs, not less than 10 percent shall be available only for participation by individuals who are representative of United States minority populations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0df25876-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/454/s6"},"text":"Pub. L. 101–454, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-24"},"text":"Oct. 24, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1065"},"text":"104 Stat. 1065","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101"},"text":"Pub. L. 104–134, title I, § 101[(a)]","children":[],"tail":" [title IV, § 407], "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321"},"text":"110 Stat. 1321","children":[],"tail":", 1321–45; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0df25877-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0df25878-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0df25879-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134"},"text":"Pub. L. 104–134","children":[],"tail":" struck out heading and text of subsec. (a). Text read as follows: “For any fiscal year, not less than 50 percent of the amounts made available to Eisenhower Exchange Fellowships, Incorporated, pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s5203/a"},"text":"section 5203(a) of this title","children":[],"tail":" shall be available only to assist United States fellows in traveling to and studying in emerging European democracies.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134"},"text":"Pub. L. 104–134","children":[],"tail":" struck out heading and text of subsec. (b). Text read as follows: “For any fiscal year, not more than 50 percent of the amounts made available to Eisenhower Exchange Fellowships, Incorporated, pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s5203/a"},"text":"section 5203(a) of this title","children":[],"tail":" shall be available to assist foreign fellows in traveling to and studying in the United States.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
