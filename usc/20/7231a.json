{"tag":"section","attrib":{"id":"id0e2b90a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7231a"},"text":null,"children":[{"tag":"num","attrib":{"value":"7231a"},"text":"§ 7231a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of this part, the term “magnet school” means a public elementary school, public secondary school, public elementary education center, or public secondary education center that offers a special curriculum capable of attracting substantial numbers of students of different racial backgrounds.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e2b90a2-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4402"},"text":"Pub. L. 89–10, title IV, § 4402","children":[],"tail":", formerly title V, § 5302, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1807"},"text":"115 Stat. 1807","children":[],"tail":"; renumbered title IV, § 4402, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4001/b/3/A"},"text":"Pub. L. 114–95, title IV, § 4001(b)(3)(A)","children":[],"tail":", (B), (D)(i), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1967"},"text":"129 Stat. 1967","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e2b90a3-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e2b90a4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"c