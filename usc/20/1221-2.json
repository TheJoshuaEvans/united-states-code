{"tag":"section","attrib":{"id":"id0d8e3ebb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1221–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1221–2"},"text":"§ 1221–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National policy with respect to museums as educational institutions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress, recognizing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8e3ebc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1221–2/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that museums serve as sources for schools in providing education for children,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8e3ebd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1221–2/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that museums provide educational services of various kinds for educational agencies and institutions and institutions of higher education, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8e3ebe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1221–2/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the expense of the educational services provided by museums is seldom borne by the educational agencies and institutions taking advantage of the museums’ resources,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"declares that it is the sense of the Congress that museums be considered educational institutions and that the cost of their educational services be more frequently borne by educational agencies and institutions benefiting from those services.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d8e3ebf-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/380/tVIII/s803"},"text":"Pub. L. 93–380, title VIII, § 803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/597"},"text":"88 Stat. 597","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d8e3ec0-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d8e3ec1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d8e3ec2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of Education Amendments of 1974, and not as part of General Education Provisions Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d8e3ec3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d8e3ec4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on and after sixtieth day after ","children":[{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/380/s2/c"},"text":"section 2(c) of Pub. L. 93–380","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1221–1"},"text":"section 1221–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
