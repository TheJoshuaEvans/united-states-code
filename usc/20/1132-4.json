{"tag":"section","attrib":{"id":"id0d740097-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"1132–4"},"text":"§ 1132–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation, outreach, and information","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may use not more than one percent of the funds made available under this subchapter to carry out program evaluation, national outreach, and information dissemination activities relating to the programs authorized under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d740098-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s635"},"text":"Pub. L. 89–329, title VI, § 635","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVI/s622"},"text":"Pub. L. 110–315, title VI, § 622","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3343"},"text":"122 Stat. 3343","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
