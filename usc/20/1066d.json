-23"},"text":"July 23, 1992","children":[],"tail":",” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (2) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s314/d/2"},"text":"Pub. L. 110–315, § 314(d)(2)","children":[],"tail":", (3), added pars. (2) and (3) and redesignated former pars. (2) to (7) as (4) to (9), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s314/d/4"},"text":"Pub. L. 110–315, § 314(d)(4)","children":[],"tail":"–(6), added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s301/c/6"},"text":"Pub. L. 105–244, § 301(c)(6)","children":[],"tail":", substituted “section 1066b” for “section 1132c–2”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s306/c"},"text":"Pub. L. 105–244, § 306(c)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Pars. (2) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208"},"text":"Pub. L. 103–208","children":[],"tail":" added par. (2) and redesignated former pars. (2) to (5) as (3) to (6), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cdb4269-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cdb426a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pu