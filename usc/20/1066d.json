{"tag":"section","attrib":{"id":"id0cdb424e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1066d"},"text":"§ 1066d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In the performance of, and with respect to, the functions vested in the Secretary by this part, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cdb424f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall, within 120 days of ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", publish in the Federal Register a notice and request for proposals for any private for-profit organization or entity wishing to serve as the designated bonding authority under this part, which notice shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cdb4250-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the time and manner for submission of proposals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb4251-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify any information, qualifications, criteria, or standards the Secretary determines to be necessary to evaluate the financial capacity and administrative capability of any applicant to carry out the responsibilities of the designated bonding authority under this part;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb4252-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cdb4253-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the selection process for the designated bonding authority is conducted on a competitive basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb4254-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the evaluation and selection process is transparent;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb4255-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cdb4256-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the performance of the designated bonding authority after the third year of the insurance agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb4257-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" following the review described in subparagraph (A), implement a revised competitive selection process, if determined necessary by the Secretary in consultation with the Advisory Board established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1066f"},"text":"section 1066f of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb4258-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall require that the first loans for capital projects authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1066b"},"text":"section 1066b of this title","children":[],"tail":" be made no later than "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"March 31, 1994","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb4259-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may sue and be sued in any court of record of a State having general jurisdiction or in any district court of the United States, and such district courts shall have jurisdiction of civil actions arising under this part without regard to the amount in controversy, and any action instituted under this part without regard to the amount in controversy, and any action instituted under this section by or against the Secretary shall survive notwithstanding any change in the person occupying the office of the Secretary or any vacancy in such office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb425a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cdb425b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may foreclose on any property and bid for and purchase at any foreclosure, or any other sale, any property in connection with which the Secretary has been assigned a loan pursuant to this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb425c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the event of such an acquisition, notwithstanding any other provisions of law relating to the acquisition, handling, or disposal of real property by the United States, complete, administer, remodel and convert, dispose of, lease, and otherwise deal with, such property, except that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cdb425d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066d/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such action shall not preclude any other action by the Secretary to recover any deficiency in the amount of a loan assigned to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cdb425e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066d/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any such acquisition of real property shall not deprive any State or political subdivision thereof of its civil or criminal jurisdiction in and over such property or impair the civil rights under the State or local laws of the inhabitants on such property;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb425f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may sell, exchange, or lease real or personal property and securities or obligations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb4260-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include in any contract such other covenants, conditions, or provisions necessary to ensure that the purposes of this part will be achieved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb4261-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, directly or by grant or contract, provide technical assistance to eligible institutions to prepare the institutions to qualify, apply for, and maintain a capital improvement loan, including a loan under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb4262-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1066d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", shall submit to the authorizing committees a report on the progress of the Department in implementing the recommendations made by the Government Accountability Office in October 2006 for improving the Historically Black College and Universities Capital Financing Program."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cdb4263-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s345"},"text":"Pub. L. 89–329, title III, § 345","children":[],"tail":", formerly title VII, § 725, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tVII/s704"},"text":"Pub. L. 102–325, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/745"},"text":"106 Stat. 745","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/j/16"},"text":"Pub. L. 103–208, § 2(j)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2481"},"text":"107 Stat. 2481","children":[],"tail":"; renumbered title III, § 345, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIII"},"text":"Pub. L. 105–244, title III","children":[],"tail":", §§ 301(a)(3), (4), (c)(6), 306(c), "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1636"},"text":"112 Stat. 1636","children":[],"tail":", 1637, 1647; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIII/s314/d"},"text":"Pub. L. 110–315, title III, § 314(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3181"},"text":"122 Stat. 3181","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cdb4264-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"ed