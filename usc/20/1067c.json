8) of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb42ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special projects (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067k/9"},"text":"section 1067k(9) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cdb42cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized uses for each type of grant","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cdb42d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The authorized uses of funds made available as institutional grants include (but are not limited to)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cdb42d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" faculty development programs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb42d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of curriculum materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb42d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The authorized uses of funds made available as cooperative grants include (but are not limited to)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cdb42d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting institutions in sharing facilities and personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb42d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminating information about established programs in science and engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb42d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067c/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting cooperative efforts to strengthen the institutions’ science and engineering programs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb42d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067c/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out a combination of any of the activities in subparagraphs (A) through (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb42d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The authorized uses of funds made available as design projects include (but are not limited to)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cdb42d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067c/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing planning, management, and evaluation systems; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb42da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067c/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing plans for initiating scientific research and for improving institutions’ capabilities for such activities.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Funds used for design project grants may not be used to pay more than 50 percent of the salaries during any academic year of faculty members involved in the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb42db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The authorized uses of funds made available as special projects include (but are not limited to)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cdb42dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067c/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced science seminars;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb42dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067c/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" science faculty workshops and conferences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb42de-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067c/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" faculty training to develop specific science research or education skills;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb42df-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067c/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research in science education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb42e0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067c/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs for visiting scientists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb42e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067c/b/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparation of films or audio-visual materials in science;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cdb42e2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067c/b/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of learning experiences in science beyond those n