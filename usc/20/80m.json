{"tag":"section","attrib":{"id":"id0c8581bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80m"},"text":null,"children":[{"tag":"num","attrib":{"value":"80m"},"text":"§ 80m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c8581be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition, retention, and disposition of property; research and education programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of carrying out sections 80k and 80","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title, the Board may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c8581bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80m/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase, accept, borrow, or otherwise acquire additional works of art or any other real or personal property for the Museum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8581c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80m/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserve, maintain, restore, display, loan, transfer, store, or otherwise hold any property of whatsoever nature acquired pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s80k"},"text":"section 80k of this title","children":[],"tail":" or paragraph (1) of this subsection;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8581c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80m/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct programs of research and education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8581c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80m/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to any limitations otherwise expressly provided by law, and, in the case of any gift, subject to any applicable restrictions under the terms of such gift, sell, exchange, or otherwise dispose of any property of whatsoever nature acquired pursuant to the provisions of this subchapter: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the proceeds from the sale of any property acquired pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s80k"},"text":"section 80k of this title","children":[],"tail":" shall be designated for the benefit of the Museum."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c8581c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations of Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the purposes of this subchapter, the Board shall consider the recommendations of the Commission established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s80n"},"text":"section 80n of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c8581c4-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/414/s3"},"text":"Pub. L. 95–414, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-05"},"text":"Oct. 5, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/911"},"text":"92 Stat. 911","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
