{"tag":"section","attrib":{"id":"id0d7d75d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1140c"},"text":"§ 1140c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each institution of higher education desiring to receive a grant, contract, or cooperative agreement under this subpart shall submit an application to the Secretary at such time, in such manner, and accompanied by such information as the Secretary may require. Each application shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7d75d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the activities authorized under this subpart that the institution proposes to carry out, and how such institution plans to conduct such activities in order to further the purpose of this subpart;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d75d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the institution consulted with a broad range of people within the institution to develop activities for which assistance is sought;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d75d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the institution will coordinate and collaborate with the office that provides services to students with disabilities within the institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d75d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the extent to which the institution will work to replicate the research-based and best practices of institutions of higher education with demonstrated effectiveness in serving students with disabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d7d75d5-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s763"},"text":"Pub. L. 89–329, title VII, § 763","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVII/s709/2"},"text":"Pub. L. 110–315, title VII, § 709(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3364"},"text":"122 Stat. 3364","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d7d75d6-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d7d75d7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d7d75d8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1140c, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s764"},"text":"Pub. L. 89–329, title VII, § 764","children":[],"tail":", as added "},{"tag":"ref","attrib":{"hre