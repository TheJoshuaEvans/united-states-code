{"tag":"section","attrib":{"id":"id0e58e18c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9104"},"text":null,"children":[{"tag":"num","attrib":{"value":"9104"},"text":"§ 9104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deputy Directors","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Office of Library Services shall be headed by a Deputy Director, who shall be appointed by the Director from among individuals who have a graduate degree in library science and expertise in library and information services. The Office of Museum Services shall be headed by a Deputy Director, who shall be appointed by the Director from among individuals who have expertise in museum services.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e58e18d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/462/tII/s205"},"text":"Pub. L. 94–462, title II, § 205","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/e/tVII/s702"},"text":"Pub. L. 104–208, div. A, title I, § 101(e) [title VII, § 702]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-233"},"text":"110 Stat. 3009–233","children":[],"tail":", 3009–295.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e58e18e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e58e18f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e58e190-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"headin