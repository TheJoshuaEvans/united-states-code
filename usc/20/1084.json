{"tag":"section","attrib":{"id":"id0d195ce1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1084"},"text":null,"children":[{"tag":"num","attrib":{"value":"1084"},"text":"§ 1084.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation by Federal credit unions in Federal, State, and private student loan insurance programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, Federal credit unions shall, pursuant to regulations of the National Credit Union Administration, have power to make insured loans to student members in accordance with the provisions of this part relating to federally insured loans, or in accordance with the provisions of any State or nonprofit private student loan insurance program which meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078/a/1/B"},"text":"section 1078(a)(1)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d195ce2-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s434"},"text":"Pub. L. 89–329, title IV, § 434","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s402/a"},"text":"Pub. L. 99–498, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1408"},"text":"100 Stat. 1408","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d195ce3-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d195ce4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":