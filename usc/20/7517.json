{"tag":"section","attrib":{"id":"id0e3c325e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517"},"text":null,"children":[{"tag":"num","attrib":{"value":"7517"},"text":"§ 7517.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e3c325f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “community consultation” means a public gathering—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e3c3260-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to discuss Native Hawaiian education concerns; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c3261-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" about which the public has been given not less than 30 days notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c3262-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native Hawaiian","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Native Hawaiian” means any individual who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e3c3263-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a citizen of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c3264-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a descendant of the aboriginal people who, prior to 1778, occupied and exercised sovereignty in the area that now comprises the State of Hawaii, as evidenced by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e3c3265-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" genealogical records;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3c3266-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Kupuna (elders) or Kamaaina (long-term community residents) verification; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3c3267-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certified birth records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c3268-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native Hawaiian community-based organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Native Hawaiian community-based organization” means any organization that is composed primarily of Native Hawaiians from a specific community and that assists in the social, cultural, and educational development of Native Hawaiians in that community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c3269-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native Hawaiian educational organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Native Hawaiian educational organization” means a private nonprofit organization that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e3c326a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves the interests of Native Hawaiians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c326b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has Native Hawaiians in substantive and policymaking positions within the organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c326c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporates Native Hawaiian perspective, values, language, culture, and traditions into the core function of the organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c326d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has demonstrated expertise in the education of Native Hawaiian youth; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c326e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has demonstrated expertise in research and program development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c326f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native Hawaiian language","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Native Hawaiian language” means the single Native American language indigenous to the original inhabitants of the State of Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c3270-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native Hawaiian organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Native Hawaiian organization” means a private nonprofit organization that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e3c3271-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves the interests of Native Hawaiians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c3272-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has Native Hawaiians in substantive and policymaking positions within the organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c3273-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is recognized by the Governor of Hawaii for the purpose of planning, conducting, or administering programs (or portions of programs) for the benefit of Native Hawaiians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c3274-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7517/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Hawaiian Affairs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Office of Hawaiian Affairs” means the Office of Hawaiian Affairs established by the Constitution of the State of Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e3c3275-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVI/s6207"},"text":"Pub. L. 89–10, title VI, § 6207","children":[],"tail":", formerly title VII, § 7207, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVII/s701"},"text":"Pub. L. 107–110, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1941"},"text":"115 Stat. 1941","children":[],"tail":"; renumbered title VI, § 6207, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVI"},"text":"Pub. L. 114–95, title VI","children":[],"tail":", §§ 6001(a), (b)(1), 6003(d), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2046"},"text":"129 Stat. 2046","children":[],"tail":", 2067.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e3c3276-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e3c3277-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e3c3278-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6003/d"},"text":"Pub. L. 114–95, § 6003(d)","children":[],"tail":", added par. (1) and redesignated former pars. (1) to (6) as (2) to (7), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e3c3279-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e3c327a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
