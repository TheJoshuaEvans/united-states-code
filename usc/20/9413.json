{"tag":"section","attrib":{"id":"id0e600e44-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9413"},"text":null,"children":[{"tag":"num","attrib":{"value":"9413"},"text":"§ 9413.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e600e45-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9413/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local Council","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e600e46-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9413/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive funds under this chapter, a local government entity, Indian tribe, Regional Corporation, or Native Hawaiian entity, as appropriate, shall establish or designate a Local Council, which shall be composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e600e47-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9413/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of local agencies directly affected by early learning programs assisted under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600e48-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9413/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600e49-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9413/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other individuals concerned with early learning issues in the locality, such as representative entities providing elementary education, child care resource and referral services, early learning opportunities, child care, and health services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600e4a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9413/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other key community leaders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e4b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9413/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designating existing entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a local government entity, Indian tribe, Regional Corporation, or Native Hawaiian entity has, before ","children":[{"tag":"date","attrib":{"date":"2000-12-21"},"text":"December 21, 2000","children":[],"tail":", a Local Council or a regional entity that is comparable to the Local Council described in paragraph (1), the entity, tribe, or corporation may designate the council or entity as a Local Council under this chapter, and shall be considered to have established a Local Council in compliance with this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e4c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9413/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Local Council shall be responsible for preparing and submitting the application described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9412"},"text":"section 9412 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e600e4d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9413/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e600e4e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9413/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 3 percent of the funds received by a Local Council under this chapter shall be used to pay for the administrative costs of the Local Council in carrying out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e4f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9413/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal agent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Local Council may designate any entity, with a demonstrated capacity for administering grants, that is affected by, or concerned with, early learning issues, including the State, to serve as fiscal agent for the administration of grant funds received by the Local Council under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e600e50-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/1/tVIII/s814"},"text":"Pub. L. 106–554, § 1(a)(1) [title VIII, § 814]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–88.)"}],"tail":"\n"}],"tail":null}
