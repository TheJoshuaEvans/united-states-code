{"tag":"section","attrib":{"id":"id0e600dcc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9403"},"text":null,"children":[{"tag":"num","attrib":{"value":"9403"},"text":"§ 9403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e600dcd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation not required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person, including a parent, shall be required to participate in any program of early childhood education, early learning, parent education, or developmental screening pursuant to the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e600dce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of parents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to affect the rights of parents otherwise established in Federal, State, or local law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e600dcf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9403/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Particular methods or settings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No entity that receives funds under this chapter shall be required to provide services under this chapter through a particular instructional method or in a particular instructional setting to comply with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e600dd0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9403/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonduplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds provided under this chapter shall be used to carry out an activity funded under another provision of law providing for Federal child care or early learning programs, unless an expansion of such activity is identified in the local needs assessment and performance goals under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e600dd1-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/1/tVIII/s804"},"text":"Pub. L. 106–554, § 1(a)(1) [title VIII, § 804]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–82.)"}],"tail":"\n"}],"tail":null}
