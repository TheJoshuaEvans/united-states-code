{"tag":"section","attrib":{"id":"id0d59c185-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1093a"},"text":"§ 1093a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Articulation agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d59c186-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “articulation agreement” means an agreement between or among institutions of higher education that specifies the acceptability of courses in transfer toward meeting specific degree or program requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d59c187-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program to encourage articulation agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d59c188-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program established","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a program for States, in cooperation with public institutions of higher education, to develop, enhance, and implement comprehensive articulation agreements between or among such institutions in a State, and (to the extent practicable) across State lines, by 2010. Such articulation agreements shall be made widely and publicly available on the websites of States and such institutions. In developing, enhancing, and implementing articulation agreements, States and public institutions of higher education may employ strategies, where applicable, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d59c189-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" common course numbering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c18a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a general education core curriculum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c18b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management systems regarding course equivalency, transfer of credit, and articulation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c18c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093a/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other strategies identified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c18d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance provided","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide technical assistance to States and public institutions of higher education for the purposes of developing and implementing articulation agreements in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c18e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1093a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to authorize the Secretary to require particular policies, procedures, or practices by institutions of higher education with respect to articulation agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d59c18f-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s486A"},"text":"Pub. L. 89–329, title IV, § 486A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s492"},"text":"Pub. L. 110–315, title IV, § 492","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3307"},"text":"122 Stat. 3307","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
