{"tag":"section","attrib":{"id":"id0ccf5bbb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034"},"text":null,"children":[{"tag":"num","attrib":{"value":"1034"},"text":"§ 1034.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Teach to reach grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ccf5bbc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ccf5bbd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to award grants, on a competitive basis, to eligible partnerships to improve the preparation of general education teacher candidates to ensure that such teacher candidates possess the knowledge and skills necessary to effectively instruct students with disabilities in general education classrooms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccf5bbe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this section shall be awarded for a period of not more than five years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccf5bbf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible partnership that receives a grant under this section shall provide not less than 25 percent of the cost of the activities carried out with such grant from non-Federal sources, which may be provided in cash or in kind.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ccf5bc0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible partnership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible partnership” means a partnership that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ccf5bc1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ccf5bc2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" one or more departments or programs at an institution of higher education—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0ccf5bc3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that prepare elementary or secondary general education teachers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ccf5bc4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that have a program of study that leads to an undergraduate degree, a master’s degree, or completion of a postbaccalaureate program required for teacher certification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ccf5bc5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the graduates of which meet the applicable State certification and licensure requirements, including any requirements for certification obtained through alternative routes to certification, or, with regard to special education teachers, the qualifications described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1412/a/14/C"},"text":"section 1412(a)(14)(C) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ccf5bc6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a department or program of special education at an institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ccf5bc7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a department or program at an institution of higher education that provides degrees in core academic subjects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ccf5bc8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a high-need local educational agency; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccf5bc9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include a department or program of mathematics, earth or physical science, foreign language, or another department at the institution that has a role in preparing teachers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ccf5bca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible partnership that receives a grant under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ccf5bcb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall use the grant funds to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ccf5bcc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop or strengthen an undergraduate, postbaccalaureate, or master’s teacher preparation program by integrating special education strategies into the general education curriculum and academic content;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ccf5bcd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide teacher candidates participating in the program under subparagraph (A) with skills related to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0ccf5bce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" response to intervention, positive behavioral interventions and supports, differentiated instruction, and data driven instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ccf5bcf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" universal design for learning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ccf5bd0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining and utilizing accommodations for instruction and assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ccf5bd1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborating with special educators, related services providers, and parents, including participation in individualized education program development and implementation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ccf5bd2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/c/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriately utilizing technology and assistive technology for students with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ccf5bd3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide extensive clinical experience for participants described in subparagraph (B) with mentoring and induction support throughout the program that continues during the first two years of full-time teaching; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccf5bd4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use grant funds to develop and administer alternate assessments of students with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ccf5bd5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible partnership seeking a grant under this section shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require. Such application shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ccf5bd6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a self-assessment by the eligible partnership of the existing teacher preparation program at the institution of higher education and needs related to preparing general education teacher candidates to instruct students with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccf5bd7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the existing personnel needs for general education teachers who instruct students with disabilities, performed by the local educational agency in which most graduates of the teacher preparation program are likely to teach after completion of the program under subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ccf5bd8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall convene a peer review committee to review applications for grants under this section and to make recommendations to the Secretary regarding the selection of grantees. Members of the peer review committee shall be recognized experts in the fields of special education, teacher preparation, and general education and shall not be in a position to benefit financially from any grants awarded under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ccf5bd9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ccf5bda-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By the partnership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ccf5bdb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible partnership receiving a grant under this section shall conduct an evaluation at the end of the grant period to determine—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0ccf5bdc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/f/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of the general education teachers who completed a program under subsection (c)(1) with respect to instruction of students with disabilities in general education classrooms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ccf5bdd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/f/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the systemic impact of the activities carried out by such grant on how each institution of higher education that is a member of the partnership prepares teachers for instruction in elementary schools and secondary schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ccf5bde-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to the Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible partnership performing an evaluation under subparagraph (A) shall report the findings of such evaluation to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccf5bdf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1034/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by the Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the last day of the grant period under this section, the Secretary shall make available to Congress and the public the findings of the evaluations submitted under paragraph (1), and information on best practices related to effective instruction of students with disabilities in general education classrooms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ccf5be0-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tII/s251"},"text":"Pub. L. 89–329, title II, § 251","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tII/s201/3"},"text":"Pub. L. 110–315, title II, § 201(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3159"},"text":"122 Stat. 3159","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9214/c/9"},"text":"Pub. L. 114–95, title IX, § 9214(c)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2163"},"text":"129 Stat. 2163","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ccf5be1-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ccf5be2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0ccf5be3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1034, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tII/s224"},"text":"Pub. L. 89–329, title II, § 224","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tII/s201"},"text":"Pub. L. 102–325, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/470"},"text":"106 Stat. 470","children":[],"tail":", required Secretary to consult with appropriate library and information science professional bodies in determining critical needs and priorities under former sections 1032 and 1033 of this title, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/e/tVII/s708/b"},"text":"Pub. L. 104–208, div. A, title I, § 101(e) [title VII, § 708(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[]