{"tag":"section","attrib":{"id":"id0e39e887-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7473"},"text":null,"children":[{"tag":"num","attrib":{"value":"7473"},"text":"§ 7473.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference for Indian applicants","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In making grants and entering into contracts or cooperative agreements under subpart 2 or subpart 3 of this part, the Secretary shall give a preference to Indian tribes, organizations, and institutions of higher education under any program with respect to which Indian tribes, organizations, and institutions are eligible to apply for grants, contracts, or cooperative agreements.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e39e888-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVI/s6143"},"text":"Pub. L. 89–10, title VI, § 6143","children":[],"tail":", formerly title VII, § 7143, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVII/s701"},"text":"Pub. L. 107–110, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1931"},"text":"115 Stat. 1931","children":[],"tail":"; renumbered title VI, § 6143, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVI/s6001/a"},"text":"Pub. L. 114–95, title VI, § 6001(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2046"},"text":"129 Stat. 2046","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e39e889-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e39e88a-3a70-11f1-a64