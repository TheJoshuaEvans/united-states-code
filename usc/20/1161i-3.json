{"tag":"section","attrib":{"id":"id0d84a251-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161i–3"},"text":"§ 1161i–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State Task Force establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d84a252-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State Task Force established","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governor of a State receiving a grant under this part shall establish, or designate an existing entity to serve as, the State Early Childhood Education Professional Development and Career Task Force (hereafter in this part referred to as the “State Task Force”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a253-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State Task Force shall include a representative of a State agency, an institution of higher education (including an associate or a baccalaureate degree granting institution of higher education), an early childhood education program, a nonprofit early childhood organization, a statewide early childhood workforce scholarship or supplemental initiative, the State Head Start collaboration director, and any other entity or individual the Governor determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d84a254-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s814"},"text":"Pub. L. 89–329, title VIII, § 814","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3398"},"text":"122 Stat. 3398","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
