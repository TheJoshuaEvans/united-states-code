{"tag":"section","attrib":{"id":"id0e542727-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7943"},"text":null,"children":[{"tag":"num","attrib":{"value":"7943"},"text":"§ 7943.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subpart:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e542728-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7943/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “economic loss” means any pecuniary loss resulting from harm (including the loss of earnings or other benefits related to employment, medical expense loss, replacement services loss, loss due to death, burial costs, and loss of business or employment opportunities) to the extent recovery for such loss is allowed under applicable State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e542729-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7943/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Harm","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “harm” includes physical, nonphysical, economic, and noneconomic losses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e54272a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7943/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noneconomic loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “noneconomic loss” means loss for physical or emotional pain, suffering, inconvenience, physical impairment, mental anguish, disfigurement, loss of enjoyment of life, loss of society or companionship, loss of consortium (other than loss of domestic service), hedonic damages, injury to reputation, or any other nonpecuniary loss of any kind or nature.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e54272b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7943/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" School","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “school” means a public or private kindergarten, a public or private elementary school or secondary school, or a home school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e54272c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7943/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the United States Virgin Islands, Guam, American Samoa, the Commonwealth of the Northern Mariana Islands, any other territory or possession of the United States, or any political subdivision of any such State, territory, or possession.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e54272d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7943/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Teacher","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “teacher” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e54272e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7943/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a teacher, instructor, principal, or administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e54272f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7943/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another educational professional who works in a school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e542730-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7943/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a professional or nonprofessional employee who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e542731-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7943/6/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" works in a school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e542732-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7943/6/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e542733-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7943/6/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the employee’s job, maintains discipline or ensures safety; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e542734-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7943/6/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an emergency, is called on to maintain discipline or ensure safety; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e542735-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7943/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual member of a school board (as distinct from the board).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e542736-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8553"},"text":"Pub. L. 89–10, title VIII, § 8553","children":[],"tail":", formerly title II, § 2363, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tII/s201"},"text":"Pub. L. 107–110, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1667"},"text":"115 Stat. 1667","children":[],"tail":"; renumbered title IX, § 9543, renumbered title VIII, § 8553, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tII/s2001/a/3/A"},"text":"Pub. L. 114–95, title II, § 2001(a)(3)(A)","children":[],"tail":", (B), (D), title VIII, § 8001(a)(7), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1913"},"text":"129 Stat. 1913","children":[],"tail":", 2088, 2089.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e542737-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e542738-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0e542739-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6733"},"text":"section 6733 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
