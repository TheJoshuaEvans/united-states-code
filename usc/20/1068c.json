{"tag":"section","attrib":{"id":"id0ce02440-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1068c"},"text":"§ 1068c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative arrangements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ce02441-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make grants to encourage cooperative arrangements—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce02442-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with funds available to carry out part A, between institutions eligible for assistance under part A and between such institutions and institutions not receiving assistance under this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce02443-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with funds available to carry out part B, between institutions eligible for assistance under part B and institutions not receiving assistance under this subchapter;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for the activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1057/b"},"text":"section 1057(b) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1062"},"text":"section 1062 of this title","children":[],"tail":", as the case may be, so that the resources of the cooperating institutions might be combined and shared to achieve the purposes of such parts and avoid costly duplicative efforts and to enhance the development of part A and part B eligible institutions."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce02444-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall give priority to grants for the purposes described under subsection (a) whenever the Secretary determines that the cooperative arrangement is geographically and economically sound or will benefit the applicant institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce02445-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants to institutions having a cooperative arrangement may be made under this section for a period as determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059"},"text":"section 1059 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1062"},"text":"section 1062 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ce02446-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s394"},"text":"Pub. L. 89–329, title III, § 394","children":[],"tail":", formerly § 354, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIII/s301/a"},"text":"Pub. L. 99–498, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1305"},"text":"100 Stat. 1305","children":[],"tail":"; renumbered § 394, "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIII/s301/a/2"},"text":"Pub. L. 105–244, title III, § 301(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1636"},"text":"112 Stat. 1636","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ce02447-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ce02448-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0ce02449-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1069"},"text":"section 1069 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
