{"tag":"section","attrib":{"id":"id0c93d8d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s107f"},"text":null,"children":[{"tag":"num","attrib":{"value":"107f"},"text":"§ 107f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated such sums as may be necessary for carrying out the provisions of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c93d8d4-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-20/ch638/s10"},"text":"June 20, 1936, ch. 638, § 10","children":[],"tail":", formerly § 7, "},{"tag":"ref","attrib":{"href":"/us/stat/49/1560"},"text":"49 Stat. 1560","children":[],"tail":"; renumbered § 8, "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-03/ch655/s4/g"},"text":"Aug. 3, 1954, ch. 655, § 4(g)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/664"},"text":"68 Stat. 664","children":[],"tail":"; renumbered § 10, "},{"tag":"ref","attrib":{"href":"/us/pl/93/516/tII/s206"},"text":"Pub. L. 93–516, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-07"},"text":"Dec. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1626"},"text":"88 Stat. 1626","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/651/tII/s206"},"text":"Pub. L. 93–651, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-11-21"},"text":"Nov. 21, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/2-11"},"text":"89 Stat. 2–11","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c93d8d5-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"