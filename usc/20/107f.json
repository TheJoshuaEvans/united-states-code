":", "},{"tag":"date","attrib":{"date":"1974-11-21"},"text":"Nov. 21, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1626"},"text":"88 Stat. 1626","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
