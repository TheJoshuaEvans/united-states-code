{"tag":"section","attrib":{"id":"id0e0ee073-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6338"},"text":null,"children":[{"tag":"num","attrib":{"value":"6338"},"text":"§ 6338.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special allocation procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e0ee074-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6338/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations for neglected children","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0ee075-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6338/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State educational agency determines that a local educational agency in the State is unable or unwilling to provide for the special educational needs of children who are living in institutions for neglected children as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333/c/1/B"},"text":"section 6333(c)(1)(B) of this title","children":[],"tail":", the State educational agency shall, if such agency assumes responsibility for the special educational needs of such children, receive the portion of such local educational agency’s allocation under sections 6333, 6334, 6335, and 6337 of this title that is attributable to such children."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0ee076-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6338/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the State educational agency does not assume such responsibility, any other State or local public agency that does assume such responsibility shall receive that portion of the local educational agency’s allocation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0ee077-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6338/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations among local educational agencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State educational agency may allocate the amounts of grants under sections 6333, 6334, 6335, and 6337 of this title among the affected local educational agencies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0ee078-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6338/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if two or more local educational agencies serve, in whole or in part, the same geographical area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0ee079-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6338/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a local educational agency provides free public education for children who reside in the school district of another local educational agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0ee07a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6338/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reflect the merger, creation, or change of boundaries of one or more local educational agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0ee07b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6338/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State educational agency determines that the amount of a grant a local educational agency would receive under sections 6333, 6334, 6335, and 6337 of this title is more than such local educational agency will use, the State educational agency shall make the excess amount available to other local educational agencies in the State that need additional funds in accordance with criteria established by the State educational agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e0ee07c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1126"},"text":"Pub. L. 89–10, title I, § 1126","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1534"},"text":"115 Stat. 1534","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e0ee07d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e0ee07e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e0ee07f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6338, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1127"},"text":"Pub. L. 89–10, title I, § 1127","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3577"},"text":"108 Stat. 3577","children":[],"tail":", related to carryover and waiver, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s1126"},"text":"section 1126 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6337"},"text":"section 6337 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
