{"tag":"section","attrib":{"id":"id0d6a630e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1102b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1102b"},"text":"§ 1102b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Grants awarded under this part shall be used for one or more of the following activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6a630f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1102b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Purchase, rental, or lease of scientific or laboratory equipment for educational purposes, including instructional and research purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a6310-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1102b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Construction, maintenance, renovation, and improvement of classrooms, libraries, laboratories, and other instructional facilities, including purchase or rental of telecommunications technology equipment or services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a6311-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1102b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Purchase of library books, periodicals, technical and other scientific journals, microfilm, microfiche, and other educational materials, including telecommunications program materials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a6312-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1102b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Support for low-income postbaccalaureate students including outreach, academic support services, mentoring, scholarships, fellowships, and other financial assistance to permit the enrollment of such students in postbaccalaureate certificate and postbaccalaureate degree granting programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a6313-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1102b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Support of faculty exchanges, faculty development, faculty research, curriculum development, and academic instruction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a6314-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1102b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Creating or improving facilities for Internet or other distance education technologies, including purchase or rental of telecommunications technology equipment or services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a6315-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1102b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Collaboration with other institutions of higher education to expand postbaccalaureate certificate and postbaccalaureate degree offerings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a6316-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1102b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Other activities proposed in the application submitted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1102c"},"text":"section 1102c of this title","children":[],"tail":" that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d6a6317-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1102b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute to carrying out the purposes of this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6a6318-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1102b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are approved by the Secretary as part of the review and acceptance of such application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6a6319-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tV/s513"},"text":"Pub. L. 89–329, title V, § 513","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tV/s502/a/3"},"text":"Pub. L. 110–315, title V, § 502(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3332"},"text":"122 Stat. 3332","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d6a631a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d6a631b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic