{"tag":"section","attrib":{"id":"id0defe7a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4709"},"text":null,"children":[{"tag":"num","attrib":{"value":"4709"},"text":"§ 4709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0defe7a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment by Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be an Executive Secretary of the Foundation who shall be appointed by the Board. The Executive Secretary shall be the chief executive officer of the Foundation and shall carry out the functions of the Foundation subject to the supervision and direction of the Board. The Executive Secretary shall carry out such other functions consistent with the provisions of this chapter as the Board shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0defe7a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Executive Secretary of the Foundation shall serve as a noncareer appointee of the Senior Executive Service and shall be compensated at a rate determined by the Board in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5383"},"text":"section 5383 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0defe7aa-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tXIV/s1410"},"text":"Pub. L. 99–661, div. A, title XIV, § 1410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4011"},"text":"100 Stat. 4011","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tX/s1089/3"},"text":"Pub. L. 102–190, div. A, title X, § 1089(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1485"},"text":"105 Stat. 1485","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0defe7ab-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0defe7ac-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0defe7ad-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" substituted “serve as a noncareer appointee of the Senior Executive Service and shall be compensated at a rate determined by the Board in accordance with section 5383” for “be compensated at the rate specified for employees in grade GS–18 of the General Schedule under section 5332”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
