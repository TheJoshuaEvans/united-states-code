{"tag":"section","attrib":{"id":"id0e1d38e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673"},"text":null,"children":[{"tag":"num","attrib":{"value":"6673"},"text":"§ 6673.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" School leader recruitment and support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e1d38e2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the funds reserved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6671/2"},"text":"section 6671(2) of this title","children":[],"tail":" for a fiscal year, the Secretary shall award grants, on a competitive basis, to eligible entities to enable such entities to improve the recruitment, preparation, placement, support, and retention of effective principals or other school leaders in high-need schools, which may include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1d38e3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing or implementing leadership training programs designed to prepare and support principals or other school leaders in high-need schools, including through new or alternative pathways or school leader residency programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing or implementing programs or activities for recruiting, selecting, and developing aspiring or current principals or other school leaders to serve in high-need schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing or implementing programs for recruiting, developing, and placing school leaders to improve schools implementing comprehensive support and improvement activities and targeted support and improvement activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/d"},"text":"section 6311(d) of this title","children":[],"tail":", including through cohort-based activities that build effective instructional and school leadership teams and develop a school culture, design, instructional program, and professional development program focused on improving student learning;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing continuous professional development for principals or other school leaders in high-need schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and disseminating information on best practices and strategies for effective school leadership in high-need schools, such as training and supporting principals to identify, develop, and maintain school leadership teams using various leadership models; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other evidence-based programs or activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6611/c/4"},"text":"section 6611(c)(4) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6613/b/3"},"text":"section 6613(b)(3) of this title","children":[],"tail":" focused on principals or other school leaders in high-need schools."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1d38e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program periods and diversity of projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1d38ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded by the Secretary to an eligible entity under this section shall be for a period of not more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may renew a grant awarded under this section for 1 additional 2-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diversity of projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Secretary shall ensure that, to the extent practicable, grants are distributed among eligible entities that will serve geographically diverse areas, including urban, suburban, and rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not award more than 1 grant under this section to an eligible entity during a grant competition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1d38ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1d38ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity that receives a grant under this section shall provide, from non-Federal sources, not less than 25 percent of the funds for the total cost for each year of activities carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptable contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity that receives a grant under this section may meet the requirement of paragraph (1) by providing contributions in cash or in kind, fairly evaluated, including plant, equipment, and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive or modify the requirement of paragraph (1) in cases of demonstrated financial hardship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1d38f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity that desires a grant under this section shall submit to the Secretary an application at such time, and in such manner, as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1d38f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this section, the Secretary shall give priority to an eligible entity—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1d38f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with a record of preparing or developing principals who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1d38f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have improved school-level student outcomes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1d38f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have become principals in high-need schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1d38f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain principals in high-need schools for multiple years; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who will implement evidence-based activities, defined for the purpose of this paragraph as activities meeting the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801/21/A/i"},"text":"section 7801(21)(A)(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1d38f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1d38fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1d38fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local educational agency, including an educational service agency, that serves a high-need school or a consortium of such agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1d38fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State educational agency or a consortium of such agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1d38fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State educational agency in partnership with 1 or more local educational agencies, or educational service agencies, that serve a high-need school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1d38fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Indian Education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1d38ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/f/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity described in subparagraph (A), (B), (C), or (D) in partnership with 1 or more nonprofit organizations or institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d3900-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-need school","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “high-need school” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1d3901-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an elementary school in which not less than 50 percent of the enrolled students are from families with incomes below the poverty line; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1d3902-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6673/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a secondary school in which not less than 40 percent of the enrolled students are from families with incomes below the poverty line.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e1d3903-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2243"},"text":"Pub. L. 89–10, title II, § 2243","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tII/s2002"},"text":"Pub. L. 114–95, title II, § 2002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1949"},"text":"129 Stat. 1949","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e1d3904-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e1d3905-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e1d3906-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6673, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2303"},"text":"Pub. L. 89–10, title II, § 2303","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tII/s201"},"text":"Pub. L. 107–110, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1649"},"text":"115 Stat. 1649","children":[],"tail":", related to recruitment and selection of Troops-to-Teachers Program participants, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tV/s541/d/1"},"text":"Pub. L. 112–239, div. A, title V, § 541(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1735"},"text":"126 Stat. 1735","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 6673, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2303"},"text":"Pub. L. 89–10, title II, § 2303","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3634"},"text":"108 Stat. 3634","children":[],"tail":", related to grants for the implementation of professional development programs, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e1d3907-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e1d3908-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
