{"tag":"section","attrib":{"id":"id0daf82db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474"},"text":null,"children":[{"tag":"num","attrib":{"value":"1474"},"text":"§ 1474.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology development, demonstration, and utilization; media services; and instructional materials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0daf82dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daf82dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, on a competitive basis, shall award grants to, and enter into contracts and cooperative agreements with, eligible entities to support activities described in subsections (b) and (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf82de-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “eligible entity” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1461/b"},"text":"section 1461(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daf82df-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology development, demonstration, and use","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daf82e0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall support activities to promote the development, demonstration, and use of technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf82e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following activities may be carried out under this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daf82e2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conducting research on and promoting the demonstration and use of innovative, emerging, and universally designed technologies for children with disabilities, by improving the transfer of technology from research and development to practice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f2e3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supporting research, development, and dissemination of technology with universal design features, so that the technology is accessible to the broadest range of individuals with disabilities without further modification or adaptation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f2e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Demonstrating the use of systems to provide parents and teachers with information and training concerning early diagnosis of, intervention for, and effective teaching strategies for, young children with reading disabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f2e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supporting the use of Internet-based communications for students with cognitive disabilities in order to maximize their academic and functional skills.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db1f2e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational media services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db1f2e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall support—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db1f2e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational media activities that are designed to be of educational value in the classroom setting to children with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f2e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing video description, open captioning, or closed captioning, that is appropriate for use in the classroom setting, of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0db1f2ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" television programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0db1f2eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" videos;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0db1f2ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other materials, including programs and materials associated with new and emerging technologies, such as CDs, DVDs, video streaming, and other forms of multimedia; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0db1f2ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" news (but only until ","children":[{"tag":"date","attrib":{"date":"2006-09-30"},"text":"September 30, 2006","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f2ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distributing materials described in subparagraphs (A) and (B) through such mechanisms as a loan service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f2ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing free educational materials, including textbooks, in accessible media for visually impaired and print disabled students in elementary schools and secondary schools, postsecondary schools, and graduate schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db1f2f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The video description, open captioning, or closed captioning described in paragraph (1)(B) shall be provided only when the description or captioning has not been previously provided by the producer or distributor, or has not been fully funded by other sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db1f2f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db1f2f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any eligible entity that wishes to receive a grant, or enter into a contract or cooperative agreement, under subsection (b) or (c) shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db1f2f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of an application for an award to carry out activities described in subsection (c)(1)(D), such eligible entity shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db1f2f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a national, nonprofit entity with a proven track record of meeting the needs of students with print disabilities through services described in subsection (c)(1)(D);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f2f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the capacity to produce, maintain, and distribute in a timely fashion, up-to-date textbooks in digital audio formats to qualified students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f2f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a demonstrated ability to significantly leverage Federal funds through other public and private contributions, as well as through the expansive use of volunteers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db1f2f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Instructional Materials Access Center","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db1f2f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish and support, through the American Printing House for the Blind, a center to be known as the “National Instructional Materials Access Center” not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2004-12-03"},"text":"December 3, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db1f2f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of the National Instructional Materials Access Center are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db1f2fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To receive and maintain a catalog of print instructional materials prepared in the National Instructional Materials Accessibility Standard, as established by the Secretary, made available to such center by the textbook publishing industry, State educational agencies, and local educational agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f2fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide access to print instructional materials, including textbooks, in accessible media, free of charge, to blind or other persons with print disabilities in elementary schools and secondary schools, in accordance with such terms and procedures as the National Instructional Materials Access Center may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f2fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To develop, adopt and publish procedures to protect against copyright infringement, with respect to the print instructional materials provided under sections 1412(a)(23) and 1413(a)(6) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db1f2fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db1f2fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Blind or other persons with print disabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “blind or other persons with print disabilities” means children served under this chapter and who may qualify in accordance with the Act entitled “An Act to provide books for the adult blind”, approved ","children":[{"tag":"date","attrib":{"date":"1931-03-03"},"text":"March 3, 1931","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t2/s135a"},"text":"2 U.S.C. 135a","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/46/1487"},"text":"46 Stat. 1487","children":[],"tail":") to receive books and other publications produced in specialized formats."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f2ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Instructional Materials Accessibility Standard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Instructional Materials Accessibility Standard” means the standard established by the Secretary to be used in the preparation of electronic files suitable and used solely for efficient conversion into specialized formats.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f300-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Print instructional materials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “print instructional materials” means printed textbooks and related printed core materials that are written and published primarily for use in elementary school and secondary school instruction and are required by a State educational agency or local educational agency for use by students in the classroom.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f301-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specialized formats","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “specialized formats” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t17/s121/d/3"},"text":"section 121(d)(3) of title 17","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db1f302-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall apply to print instructional materials published after the date on which the final rule establishing the National Instructional Materials Accessibility Standard was published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db1f303-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of the Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to establish a private right of action against the Secretary for failure to provide instructional materials directly, or for failure by the National Instructional Materials Access Center to perform the duties of such center, or to otherwise authorize a private right of action related to the performance by such center, including through the application of the rights of children and parents established under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db1f304-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1474/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (a) through (d) shall not apply to this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0db1f305-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s674"},"text":"Pub. L. 91–230, title VI, § 674","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2792"},"text":"118 Stat. 2792","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0db1f306-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0db1f307-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0db1f308-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (e)(3)(A), (5), was in the original “this Act” and was translated as reading “this title”, meaning title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230"},"text":"Pub. L. 91–230","children":[],"tail":", which enacted this chapter, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“An Act to provide books for the adult blind”, approved ","children":[{"tag":"date","attrib":{"date":"1931-03-03"},"text":"March 3, 1931","children":[],"tail":", referred to in subsec. (e)(3)(A), is "},{"tag":"ref","attrib":{"href":"/us/act/1931-03-03/ch400"},"text":"act Mar. 3, 1931, ch. 400","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/1487"},"text":"46 Stat. 1487","children":[],"tail":", which is classified generally to sections 135a and 135b of Title 2, The Congress. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t17/s121/d"},"text":"Section 121(d) of title 17","children":[],"tail":", referred to in subsec. (e)(3)(D), was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/261/s2/a/1/D"},"text":"Pub. L. 115–261, § 2(a)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-09"},"text":"Oct. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3667"},"text":"132 Stat. 3667","children":[],"tail":", and no longer defines the term “specialized formats”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0db1f309-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1474, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s674"},"text":"Pub. L. 91–230, title VI, § 674","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/17/tI/s101"},"text":"Pub. L. 105–17, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-04"},"text":"June 4, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/143"},"text":"111 Stat. 143","children":[],"tail":", related to studies and evaluations, prior to the general amendment of subchapters I to IV of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/108/446"},"text":"Pub. L. 108–446","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1474, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s674"},"text":"Pub. L. 91–230, title VI, § 674","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/457/tI/s101/a"},"text":"Pub. L. 99–457, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-08"},"text":"Oct. 8, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"hr