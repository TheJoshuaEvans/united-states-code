{"tag":"section","attrib":{"id":"id0cd1cc56-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057"},"text":null,"children":[{"tag":"num","attrib":{"value":"1057"},"text":"§ 1057.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cd1cc57-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a program, in accordance with this part, to improve the academic quality, institutional management, and fiscal stability of eligible institutions, in order to increase their self-sufficiency and strengthen their capacity to make a substantial contribution to the higher education resources of the Nation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd1cc58-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants awarded; special consideration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd1cc59-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" From the sums available for this part under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1068h/a/1"},"text":"section 1068h(a)(1) of this title","children":[],"tail":", the Secretary may award grants to any eligible institution with an application approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1068"},"text":"section 1068 of this title","children":[],"tail":" in order to assist such an institution to plan, develop, or implement activities that promise to strengthen the institution."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cc5a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Special consideration shall be given to any eligible institution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd1cc5b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which has endowment funds (other than any endowment fund built under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1065"},"text":"section 1065 of this title","children":[],"tail":" as in effect on "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"September 30, 1986","children":[],"tail":", and under part B) the market value of which, per full-time equivalent student, is less than the average current market value of the endowment funds, per full-time equivalent student (other than any endowment fund built under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1065"},"text":"section 1065 of this title","children":[],"tail":" as in effect on "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"September 30, 1986","children":[],"tail":", and under part B) at similar institutions; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1cc5c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which has expenditures per full-time equivalent student for library materials which is less than the average of the expenditures for library materials per full-time equivalent student by other similarly situated institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cc5d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Special consideration shall be given to applications which propose, pursuant to the institution’s plan, to engage in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd1cc5e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" faculty development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1cc5f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds and administrative management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1cc60-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development and improvement of academic programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1cc61-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition of equipment for use in strengthening funds management and academic programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1cc62-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" joint use of facilities such as libraries and laboratories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1cc63-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" student services, including services that will assist in the education of special populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd1cc64-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under this section shall be used for 1 or more of the following activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd1cc65-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Purchase, rental, or lease of scientific or laboratory equipment for educational purposes, including instructional and research purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cc66-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Construction, maintenance, renovation, and improvement in classrooms, libraries, laboratories, and other instructional facilities, including the integration of computer technology into institutional facilities to create smart buildings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cc67-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Support of faculty exchanges, faculty development, and faculty fellowships to assist in attaining advanced degrees in the field of instruction of the faculty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cc68-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development and improvement of academic programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cc69-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Purchase of library books, periodicals, and other educational materials, including telecommunications program material.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cc6a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tutoring, counseling, and student service programs designed to improve academic success, including innovative, customized, instruction courses designed to help retain students and move the students rapidly into core courses and through program completion, which may include remedial education and English language instruction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cc6b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Education or counseling services designed to improve the financial literacy and economic literacy of students or the students’ families.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cc6c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds management, administrative management, and acquisition of equipment for use in strengthening funds management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cc6d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Joint use of facilities, such as laboratories and libraries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cc6e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing or improving a development office to strengthen or improve contributions from alumni and the private sector.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cc6f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing or improving an endowment fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cc70-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Creating or improving facilities for Internet or other distance education technologies, including purchase or rental of telecommunications technology equipment or services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cc71-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/c/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Other activities proposed in the application submitted pursuant to subsection (b) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1068"},"text":"section 1068 of this title","children":[],"tail":" that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd1cc72-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/c/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute to carrying out the purposes of the program assisted under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd1cc73-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/c/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are approved by the Secretary as part of the review and acceptance of such application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd1cc74-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Endowment fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd1cc75-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible institution may use not more than 20 percent of the grant funds provided under this part to establish or increase an endowment fund at such institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cc76-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to be eligible to use grant funds in accordance with paragraph (1), the eligible institution shall provide matching funds from non-Federal sources, in an amount equal to or greater than the Federal funds used in accordance with paragraph (1), for the establishment or increase of the endowment fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd1cc77-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1057/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comparability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of part C, regarding the establishment or increase of an endowment fund, that the Secretary determines are not inconsistent with this subsection, shall apply to funds used under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cd1cc78-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s311"},"text":"Pub. L. 89–329, title III, § 311","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIII/s301/a"},"text":"Pub. L. 99–498, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1291"},"text":"100 Stat. 1291","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/50/s2/a/1"},"text":"Pub. L. 100–50, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-06-03"},"text":"June 3, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/335"},"text":"101 Stat. 335","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIII"},"text":"Pub. L. 105–244, title III","children":[],"tail":", §§ 301(c)(1), 303(a), "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1636"},"text":"112 Stat. 1636","children":[],"tail":", 1638; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIII/s301"},"text":"Pub. L. 110–315, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3166"},"text":"122 Stat. 3166","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cd1cc79-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cd1cc7a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cd1cc7b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1057, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s311"},"text":"Pub. L. 89–329, title III, § 311","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tIII/s301"},"text":"Pub. L. 96–374, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1391"},"text":"94 Stat. 1391","children":[],"tail":", enumerated purposes and established grant authority for program to strengthen eligible institutions, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cd1cc7c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s301/1/A"},"text":"Pub. L. 110–315, § 301(1)(A)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1068"},"text":"section 1068 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s301/1/B"},"text":"Pub. L. 110–315, § 301(1)(B)","children":[],"tail":", inserted “, including services that will assist in the education of special populations” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s301/2/A"},"text":"Pub. L. 110–315, § 301(2)(A)","children":[],"tail":", inserted “, including innovative, customized, instruction courses designed to help retain students and move the students rapidly into core courses and through program completion, which may include remedial education and English language instruction” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(7) to (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s301/2/B"},"text":"Pub. L. 110–315, § 301(2)(B)","children":[],"tail":"–(E), added par. (7), redesignated former pars. (7) to (12) as pars. (8) to (13), respectively, in par. (12), substituted “distance education technologies” for “distance learning academic instruction capabilities” and, in introductory provisions of par. (13), substituted “subsection (b) and "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1068"},"text":"section 1068 of this title","children":[],"tail":"” for “subsection (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s301/c/1"},"text":"Pub. L. 105–244, § 301(c)(1)","children":[],"tail":", substituted “section 1068h(a)(1)” for “section 1069f(a)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s303/a"},"text":"Pub. L. 105–244, § 303(a)","children":[],"tail":", added subsecs. (c) and (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/50"},"text":"Pub. L. 100–50","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1069f/a/1"},"text":"section 1069f(a)(1) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1069d/a/1"},"text":"section 1069d(a)(1) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cd1cc7d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cd1cc7e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cd1cc7f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/50"},"text":"Pub. L. 100–50","children":[],"tail":" effective as if enacted as part of the Higher Education Amendments of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/50/s27"},"text":"section 27 of Pub. L. 100–50","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
