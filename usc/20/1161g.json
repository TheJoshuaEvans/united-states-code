{"tag":"section","attrib":{"id":"id0d84a1e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161g"},"text":"§ 1161g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patsy T. Mink fellowship program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d84a1e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose; designation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a1e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the purpose of this section to provide, through eligible institutions, a program of fellowship awards to assist highly qualified minorities and women to acquire the doctoral degree, or highest possible degree available, in academic areas in which such individuals are underrepresented for the purpose of enabling such individuals to enter the higher education professoriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a1e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient of a fellowship award from an eligible institution receiving a grant under this section shall be known as a “Patsy T. Mink Graduate Fellow”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a1ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “eligible institution” means an institution of higher education, or a consortium of such institutions, that offers a program of postbaccalaureate study leading to a graduate degree.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a1eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a1ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants by Secretary","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a1ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amounts appropriated under subsection (f), the Secretary shall award grants to eligible institutions to enable such institutions to make fellowship awards to individuals in accordance with the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a1ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Secretary shall consider the eligible institution’s prior experience in producing doctoral degree, or highest possible degree available, holders who are minorities and women, and shall give priority consideration in making grants under this section to those eligible institutions with a demonstrated record of producing minorities and women who have earned such degrees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a1ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a1f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible institution that desires a grant under this section shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a1f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications made on behalf","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following entities may submit an application on behalf of an eligible institution:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d84a1f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A graduate school or department of such institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a1f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A graduate school or department of such institution in collaboration with an undergraduate college or school of such institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a1f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An organizational unit within such institution that offers a program of postbaccalaureate study leading to a graduate degree, including an interdisciplinary or an interdepartmental program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a1f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing a grant application and carrying out the grant activities authorized under this section, an eligible institution may partner with a nonprofit organization with a demonstrated record of helping minorities and women earn postbaccalaureate degrees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a1f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a1f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" take into account—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d84a1f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and distribution of minority and female faculty nationally;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a1f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current and projected need for highly trained individuals in all areas of the higher education professoriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a1fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the present and projected need for highly trained individuals in academic career fields in which minorities and women are underrepresented in the higher education professoriate; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a1fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the need to prepare a large number of minorities and women generally in academic career fields of high national priority, especially in areas in which such individuals are traditionally underrepresented in college and university faculty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a1fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution and amounts of grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a1fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Secretary shall, to the maximum extent feasible, ensure an equitable geographic distribution of awards and an equitable distribution among public and private eligible institutions that apply for grants under this section and that demonstrate an ability to achieve the purpose of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a1fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the Secretary shall use not less than 30 percent of the amount appropriated pursuant to subsection (f) to award grants to eligible institutions that are eligible for assistance under subchapter III or subchapter V, or to consortia of eligible institutions that include at least one eligible institution that is eligible for assistance under subchapter III or subchapter V.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a1ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Secretary shall allocate appropriate funds to those eligible institutions whose applications indicate an ability to significantly increase the numbers of minorities and women entering the higher education professoriate and that commit institutional resources to the attainment of the purpose of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a200-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of fellowship awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible institution that receives a grant under this section shall make not less than ten fellowship awards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a201-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insufficient funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the amount appropriated is not sufficient to permit all grantees under this section to provide the minimum number of fellowships required by subparagraph (D), the Secretary may, after awarding as many grants to support the minimum number of fellowships as such amount appropriated permits, award grants that do not require the grantee to award the minimum number of fellowships required by such subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a202-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutional allowance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a203-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d84a204-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of allowances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Secretary shall pay to each eligible institution awarded a grant, for each individual awarded a fellowship by such institution under this section, an institutional allowance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a205-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (C), for academic year 2009–2010 and succeeding academic years, an institutional allowance under this paragraph shall be in an amount equal to the amount of institutional allowance made to an institution of higher education under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1135d"},"text":"section 1135d of this title","children":[],"tail":" for such academic year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a206-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Institutional allowances may be expended at the discretion of the eligible institution and may be used to provide, except as prohibited under subparagraph (D), academic support and career transition services for individuals awarded fellowships by such institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a207-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The institutional allowance paid under subparagraph (A) shall be reduced by the amount the eligible institution charges and collects from a fellowship recipient for tuition and other expenses as part of the recipient’s instructional program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a208-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/c/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use for overhead prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under this section may not be used for general operational overhead of the academic department or institution receiving funds under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a209-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship recipients","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a20a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible institution that receives a grant under this section shall use the grant funds to make fellowship awards to minorities and women who are enrolled at such institution in a doctoral degree program, or program for the highest possible degree available, and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a20b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" intend to pursue a career in instruction at—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d84a20c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education (as the term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a20d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education (as the term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002/a/1"},"text":"section 1002(a)(1) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a20e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/d/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proprietary institution of higher education (as the term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002/b"},"text":"section 1002(b) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a20f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" sign an agreement with the Secretary agreeing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d84a210-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to begin employment at an institution described in subparagraph (A) not later than three years after receiving the doctoral degree or highest possible degree available, which three-year period may be extended by the Secretary for extraordinary circumstances; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a211-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be employed by such institution for one year for each year of fellowship assistance received under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a212-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment for failure to comply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event that any recipient of a fellowship under this section fails or refuses to comply with the agreement signed pursuant to paragraph (1)(B), the sum of the amounts of any fellowship received by such recipient shall, upon a determination of such a failure or refusal to comply, be treated as a Federal Direct Unsubsidized Stafford Loan under part D of subchapter IV, and shall be subject to repayment, together with interest thereon accruing from the date of the grant award, in accordance with terms and conditions specified by the Secretary in regulations under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a213-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver and modification","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a214-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations setting forth criteria to be considered in granting a waiver for the service requirement under paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a215-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The criteria under subparagraph (A) shall include whether compliance with the service requirement by the fellowship recipient would be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d84a216-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inequitable and represent an extraordinary hardship; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a217-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deemed impossible because the individual is permanently and totally disabled at the time of the waiver request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a218-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of fellowship awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fellowship awards under this section shall consist of a stipend in an amount equal to the level of support provided to fellows under the National Science Foundation Graduate Research Fellowship Program, except that such stipend shall be adjusted as necessary so as not to exceed the fellow’s tuition and fees or demonstrated need (as determined by the institution of higher education where the graduate student is enrolled), whichever is greater.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a219-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Academic progress required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual student shall not be eligible to receive a fellowship award—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a21a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except during periods in which such student is enrolled, and such student is maintaining satisfactory academic progress in, and devoting essentially full time to, study or research in the pursuit of the degree for which the fellowship support was awarded; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a21b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the student is engaged in gainful employment, other than part-time employment in teaching, research, or similar activity determined by the eligible institution to be consistent with and supportive of the student’s progress toward the appropriate degree.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a21c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed to require an eligible institution that receives a grant under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a21d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to grant a preference to or to differentially treat any applicant for a faculty position as a result of the institution’s participation in the program under this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a21e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to hire a Patsy T. Mink Fellow who completes this program and seeks employment at such institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a21f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161g/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d84a220-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s807"},"text":"Pub. L. 89–329, title VIII, § 807","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3392"},"text":"122 Stat. 3392","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
