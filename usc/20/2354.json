{"tag":"section","attrib":{"id":"id0dc50660-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354"},"text":null,"children":[{"tag":"num","attrib":{"value":"2354"},"text":"§ 2354.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local application for career and technical education programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dc50661-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local application required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any eligible recipient desiring financial assistance under this part shall, in accordance with requirements established by the eligible agency (in consultation with such other educational training entities as the eligible agency determines to be appropriate) submit a local application to the eligible agency. Such local application shall cover the same period of time as the period of time applicable to the State plan submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2342"},"text":"section 2342 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc50662-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The eligible agency shall determine the requirements for local applications, except that each local application shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc50663-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the results of the comprehensive needs assessment conducted under subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc50664-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information on the career and technical education course offerings and activities that the eligible recipient will provide with funds under this part, which shall include not less than 1 program of study approved by a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2344/b/2"},"text":"section 2344(b)(2) of this title","children":[],"tail":", including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dc50665-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the results of the comprehensive needs assessment described in subsection (c) informed the selection of the specific career and technical education programs and activities selected to be funded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc50666-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any new programs of study the eligible recipient will develop and submit to the State for approval; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc50667-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how students, including students who are members of special populations, will learn about their school’s career and technical education course offerings and whether each course is part of a career and technical education program of study;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc50668-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of how the eligible recipient, in collaboration with local workforce development boards and other local workforce agencies, one-stop delivery systems described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3151/e/2"},"text":"section 3151(e)(2) of title 29","children":[],"tail":", and other partners, will provide—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dc50669-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" career exploration and career development coursework, activities, or services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc5066a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" career information on employment opportunities that incorporate the most up-to-date information on high-skill, high-wage, or in-demand industry sectors or occupations, as determined by the comprehensive needs assessment described in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc5066b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organized system of career guidance and academic counseling to students before enrolling and while participating in a career and technical education program;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc5066c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the eligible recipient will improve the academic and technical skills of students participating in career and technical education programs by strengthening the academic and career and technical education components of such programs through the integration of coherent and rigorous content aligned with challenging academic standards and relevant career and technical education programs to ensure learning in the subjects that constitute a well-rounded education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc5066d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of how the eligible recipient will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dc5066e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide activities to prepare special populations for high-skill, high-wage, or in-demand industry sectors or occupations that will lead to self-sufficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc5066f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare CTE participants for non-traditional fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc50670-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide equal access for special populations to career and technical education courses, programs, and programs of study; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc50671-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that members of special populations will not be discriminated against on the basis of their status as members of special populations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc50672-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the work-based learning opportunities that the eligible recipient will provide to students participating in career and technical education programs and how the recipient will work with representatives from employers to develop or expand work-based learning opportunities for career and technical education students, as applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc50673-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the eligible recipient will provide students participating in career and technical education programs with the opportunity to gain postsecondary credit while still attending high school, such as through dual or concurrent enrollment programs or early college high school, as practicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc50674-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the eligible recipient will coordinate with the eligible agency and institutions of higher education to support the recruitment, preparation, retention, and training, including professional development, of teachers, faculty, administrators, and specialized instructional support personnel and paraprofessionals who meet applicable State certification and licensure requirements (including any requirements met through alternative routes to certification), including individuals from groups underrepresented in the teaching profession; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc50675-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the eligible recipient will address disparities or gaps in performance as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2323/b/3/C/ii/II"},"text":"section 2323(b)(3)(C)(ii)(II) of this title","children":[],"tail":" in each of the plan years, and if no meaningful progress has been achieved prior to the third program year, a description of the additional actions such recipient will take to eliminate those disparities or gaps."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc50676-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive needs assessment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc50677-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive financial assistance under this part, an eligible recipient shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dc50678-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a comprehensive local needs assessment related to career and technical education and include the results of the needs assessment in the local application submitted under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc50679-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than once every 2 years, update such comprehensive local needs assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc5067a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The comprehensive local needs assessment described in paragraph (1) shall include each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dc5067b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An evaluation of the performance of the students served by the eligible recipient with respect to State determined and local levels of performance established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2323"},"text":"section 2323 of this title","children":[],"tail":", including an evaluation of performance for special populations and each subgroup described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/h/1/C/ii"},"text":"section 6311(h)(1)(C)(ii) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc5067c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A description of how career and technical education programs offered by the eligible recipient are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0dc5067d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sufficient in size, scope, and quality to meet the needs of all students served by the eligible recipient; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dc5067e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0dc5067f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/c/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aligned to State, regional, Tribal, or local in-demand industry sectors or occupations identified by the State workforce development board described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3111"},"text":"section 3111 of title 29","children":[],"tail":" (referred to in this section as the “State board”) or local workforce development board, including career pathways, where appropriate; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0dc50680-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/c/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designed to meet local education or economic needs not identified by State boards or local workforce development boards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc50681-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An evaluation of progress toward the implementation of career and technical education programs and programs of study.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc50682-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of how the eligible recipient will improve recruitment, retention, and training of career and technical education teachers, faculty, specialized instructional support personnel, paraprofessionals, and career guidance and academic counselors, including individuals in groups underrepresented in such professions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc50683-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A description of progress toward implementation of equal access to high-quality career and technical education courses and programs of study for all students, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0dc50684-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/c/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strategies to overcome barriers that result in lower rates of access to, or performance gaps in, the courses and programs for special populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dc50685-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/c/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing programs that are designed to enable special populations to meet the local levels of performance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dc50686-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/c/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing activities to prepare special populations for high-skill, high-wage, or in-demand industry sectors or occupations in competitive, integrated settings that will lead to self-sufficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc50687-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the comprehensive needs assessment under subsection (c), and developing the local application described in subsection (b), an eligible recipient shall involve a diverse body of stakeholders, including, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc50688-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of career and technical education programs in a local educational agency or educational service agency, including teachers, career guidance and academic counselors, principals and other school leaders, administrators, and specialized instructional support personnel and paraprofessionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc50689-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of career and technical education programs at postsecondary educational institutions, including faculty and administrators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc5068a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of the State board or local workforce development boards and a range of local or regional businesses or industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc5068b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parents and students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc5068c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of special populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc5068d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of regional or local agencies serving out-of-school youth, homeless children and youth, and at-risk youth (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6472"},"text":"section 6472 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc5068e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of Indian Tribes and Tribal organizations in the State, where applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc5068f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other stakeholders that the eligible agency may require the eligible recipient to consult.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc50690-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible recipient receiving financial assistance under this part shall consult with stakeholders described in subsection (d) on an ongoing basis, as determined by the eligible agency. This may include consultation in order to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc50691-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide input on annual updates to the comprehensive needs assessment required under subsection (c)(1)(B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc50692-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure programs of study are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dc50693-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responsive to community employment needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc50694-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aligned with employment priorities in the State, regional, tribal, or local economy identified by employers and the entities described in subsection (d), which may include in-demand industry sectors or occupations identified by the local workforce development board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc50695-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informed by labor market information, including information provided under section 49","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–2(e)(2)(C) of title 29;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc50696-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designed to meet current, intermediate, or long-term labor market projections; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc50697-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow employer input, including input from industry or sector partnerships in the local area, where applicable, into the development and implementation of programs of study to ensure such programs of study align with skills required by local employment opportunities, including activities such as the identification of relevant standards, curriculum, industry-recognized credentials, and current technology and equipment;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc50698-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and encourage opportunities for work-based learning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc50699-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2354/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure funding under this part is used in a coordinated manner with other local resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dc5069a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tI/s134"},"text":"Pub. L. 88–210, title I, § 134","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/b"},"text":"Pub. L. 109–270, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/732"},"text":"120 Stat. 732","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tV/s512/e/5"},"text":"Pub. L. 113–128, title V, § 512(e)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1707"},"text":"128 Stat. 1707","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/n/8"},"text":"Pub. L. 114–95, title IX, § 9215(n)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2170"},"text":"129 Stat. 2170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/224/tI/s133"},"text":"Pub. L. 115–224, title I, § 133","children":[],"tail":", "},{"tag":"date","at