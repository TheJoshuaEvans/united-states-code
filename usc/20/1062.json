{"tag":"section","attrib":{"id":"id0cd687c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062"},"text":null,"children":[{"tag":"num","attrib":{"value":"1062"},"text":"§ 1062.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cd687c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authorization; uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From amounts available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1068h/a/2"},"text":"section 1068h(a)(2) of this title","children":[],"tail":" for any fiscal year, the Secretary shall make grants (under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1063"},"text":"section 1063 of this title","children":[],"tail":") to institutions which have applications approved by the Secretary (under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1063a"},"text":"section 1063a of this title","children":[],"tail":") for any of the following uses:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd687c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Purchase, rental, or lease of scientific or laboratory equipment for educational purposes, including instructional and research purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd687c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Construction, maintenance, renovation, and improvement in classroom, library, laboratory, and other instructional facilities, including purchase or rental of telecommunications technology equipment or services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd687c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Support of faculty exchanges, and faculty development and faculty fellowships to assist in attaining advanced degrees in their field of instruction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd687c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Academic instruction in disciplines in which Black Americans are underrepresented.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd687ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Purchase of library books, periodicals, microfilm, and other educational materials, including telecommunications program materials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd687cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tutoring, counseling, and student service programs designed to improve academic success.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd687cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds and administrative management, and acquisition of equipment for use in strengthening funds management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd687cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Joint use of facilities, such as laboratories and libraries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd687ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing or improving a development office to strengthen or improve contributions from alumni and the private sector.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd687cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing or enhancing a program of teacher education designed to qualify students to teach in a public elementary or secondary school in the State that shall include, as part of such program, preparation for teacher certification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd687d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing community outreach programs which will encourage elementary and secondary students to develop the academic skills and the interest to pursue postsecondary education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd687d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Acquisition of real property in connection with the construction, renovation, or addition to or improvement of campus facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd687d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Education or financial information designed to improve the financial literacy and economic literacy of students or the students’ families, especially with regard to student indebtedness and student assistance programs under subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd687d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Services necessary for the implementation of projects or activities that are described in the grant application and that are approved, in advance, by the Secretary, except that not more than two percent of the grant amount may be used for this purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd687d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Other activities proposed in the application submitted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1063a"},"text":"section 1063a of this title","children":[],"tail":" that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd687d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/a/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute to carrying out the purposes of this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd687d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/a/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are approved by the Secretary as part of the review and acceptance of such application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd687d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Endowment fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd687d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution may use not more than 20 percent of the grant funds provided under this part to establish or increase an endowment fund at the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd687d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to be eligible to use grant funds in accordance with paragraph (1), the eligible institution shall provide matching funds from non-Federal sources, in an amount equal to or greater than the Federal funds used in accordance with paragraph (1), for the establishment or increase of the endowment fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd687da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comparability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of part C regarding the establishment or increase of an endowment fund, that the Secretary determines are not inconsistent with this subsection, shall apply to funds used under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd687db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd687dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No grant may be made under this chapter for any educational program, activity, or service related to sectarian instruction or religious worship, or provided by a school or department of divinity. For the purpose of this subsection, the term “school or department of divinity” means an institution whose program is specifically for the education of students to prepare them to become ministers of religion or to enter upon some other religious vocation, or to prepare them to teach theological subjects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd687dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1062/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 50 percent of the allotment of any institution may be available for the purpose of constructing or maintaining a classroom, library, laboratory, or other instructional facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cd687de-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s323"},"text":"Pub. L. 89–329, title III, § 323","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIII/s301/a"},"text":"Pub. L. 99–498, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1295"},"text":"100 Stat. 1295","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/50/s2/a/7"},"text":"Pub. L. 100–50, § 2(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-06-03"},"text":"June 3, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/335"},"text":"101 Stat. 335","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/369/s10/b"},"text":"Pub. L. 100–369, § 10(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-07-18"},"text":"July 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/838"},"text":"102 Stat. 838","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIII/s303/a"},"text":"Pub. L. 102–325, title III, § 303(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"ta