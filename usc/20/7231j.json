{"tag":"section","attrib":{"id":"id0e2e0110-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7231j"},"text":null,"children":[{"tag":"num","attrib":{"value":"7231j"},"text":"§ 7231j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; reservation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e2e0111-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7231j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this part the following amounts:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2e0112-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7231j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $94,000,000 for fiscal year 2017.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e0113-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7231j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $96,820,000 for fiscal year 2018.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e0114-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7231j/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $102,387,150 for fiscal year 2019.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e0115-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7231j/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $108,530,379 for fiscal year 2020.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2e0116-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7231j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation for technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may reserve not more than 1 percent of the funds appropriated under subsection (a) for any fiscal year to provide technical assistance and share best practices with respect to magnet school programs assisted under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2e0117-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7231j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds for grants to agencies not previously assisted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any fiscal year for which the amount appropriated pursuant to subsection (a) exceeds $75,000,000, the Secretary shall give priority in using such amounts in excess of $75,000,000 to awarding grants to local educational agencies or consortia of such agencies that did not receive a grant under this part in the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e2e0118-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4409"},"text":"Pub. L. 89–10, title IV, § 4409","children":[],"tail":", formerly title V, § 5311, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":",