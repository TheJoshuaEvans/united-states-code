{"tag":"section","attrib":{"id":"id0d871336-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161l–3"},"text":"§ 1161l–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education Disaster and Emergency Relief Loan Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d871337-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of Homeland Security, is authorized to establish an Education Disaster and Emergency Relief Loan Program for institutions of higher education impacted by a major disaster or emergency declared by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d871338-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, subject to the availability of appropriations, provide loans under this section to institutions of higher education after the declaration of a major disaster or emergency by the President. Loan funds provided under this section may be used for construction, replacement, renovation, and operations costs resulting from a major disaster or emergency declared by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d871339-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be considered for a loan under this section, an institution of higher education shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d87133a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit a financial statement and other appropriate data, documentation, or evidence requested by the Secretary that indicates that the institution incurred losses resulting from the impact of a major disaster or emergency declared by the President, and the monetary amount of such losses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d87133b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate that the institution had appropriate insurance policies prior to the major disaster or emergency and filed claims, as appropriate, related to the major disaster or emergency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d87133c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate that the institution attempted to minimize the cost of any losses by pursuing collateral source compensation from the Federal Emergency Management Agency prior to seeking a loan under this section, except that an institution of higher education shall not be required to receive collateral source compensation from the Federal Emergency Management Agency prior to being eligible for a loan under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d87133d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may audit a financial statement submitted under subsection (c) and an institution of higher education shall provide any information that the Secretary determines necessary to conduct such an audit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d87133e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction in loan amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To determine the amount of a loan to make available to an institution of higher education under this section, the Secretary shall calculate the monetary amount of losses incurred by such institution as a result of a major disaster or emergency declared by the President, and shall reduce such amount by the amount of collateral source compensation the institution has already received from insurance, the Federal Emergency Management Agency, and the Small Business Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d87133f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of loan program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Prior to disbursing any loans under this section, the Secretary shall prescribe regulations that establish the Education Disaster and Emergency Relief Loan Program, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d871340-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terms for the loan program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d871341-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for an application for a loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d871342-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" minimum requirements for the loan program and for receiving a loan, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d871343-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" online forms to be used in submitting a request for a loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d871344-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information to be included in such forms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d871345-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures to assist in filing and pursuing a loan; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d871346-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other terms and conditions the Secretary may prescribe after taking into consideration the structure of other existing capital financing loan programs under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d871347-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d871348-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution affected by a Gulf hurricane disaster","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “institution affected by a Gulf hurricane disaster” means an institution of higher education that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d871349-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located in an area affected by a Gulf hurricane disaster; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d87134a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is able to demonstrate that the institution—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d87134b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/g/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incurred physical damage resulting from the impact of a Gulf hurricane disaster; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d87134c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/g/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was not able to fully reopen in existing facilities or to fully reopen to the pre-hurricane levels for 30 days or more on or after ","children":[{"tag":"date","attrib":{"date":"2005-08-29"},"text":"August 29, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d87134d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area affected by a Gulf hurricane disaster; Gulf hurricane disaster","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “area affected by a Gulf hurricane disaster” and “Gulf hurricane disaster” have the meanings given such terms in section 209 of the Higher Education Hurricane Relief Act of 2005 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/148"},"text":"Public Law 109–148","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2808"},"text":"119 Stat. 2808","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d87134e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “emergency” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122/1"},"text":"section 5122(1) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d87134f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutions of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d871350-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major disaster","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “major disaster” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122/2"},"text":"section 5122(2) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d871351-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Loans provided to institutions of higher education pursuant to this section shall be available only with respect to major disasters or emergencies declared by the President that occur after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", except that loans may be provided pursuant to this section to an institution affected by a Gulf hurricane disaster with respect to such disaster."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d871352-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–3/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d871353-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s824"},"text":"Pub. L. 89–329, title VIII, § 824","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3410"},"text":"122 Stat. 3410","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tVIII/s801/7"},"text":"Pub. L. 111–39, title VIII, § 801(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1956"},"text":"123 Stat. 1956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d871354-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d871355-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d871356-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 209 of the Higher Education Hurricane Relief Act of 2005, referred to in subsec. (g)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/148/dB/tIV/s209"},"text":"section 209 of title IV of div. B of Pub. L. 109–148","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2808"},"text":"119 Stat. 2808","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d871357-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (f)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s801/7/A"},"text":"Pub. L. 111–39, § 801(7)(A)","children":[],"tail":", inserted “a” after “submitting”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s801/7/B"},"text":"Pub. L. 111–39, § 801(7)(B)","children":[],"tail":", substituted “pursuing” for “pursing”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d871358-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d871359-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" effective as if enacted on the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/s3"},"text":"section 3 of Pub. L. 111–39","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
