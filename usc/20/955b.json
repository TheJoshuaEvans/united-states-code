{"tag":"section","attrib":{"id":"id0caba706-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s955b"},"text":null,"children":[{"tag":"num","attrib":{"value":"955b"},"text":"§ 955b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Medal of Arts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0caba707-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s955b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established a National Medal of Arts, which shall be a medal of such design as is deemed appropriate by the President, on the basis of recommendations submitted by the National Council on the Arts, and which shall be awarded as provided in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0caba708-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s955b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award of Medal; conditions; recipients; presentation ceremonies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0caba709-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s955b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall from time to time award the National Medal of Arts, on the basis of recommendations from the National Council on the Arts, to individuals or groups who in the President’s judgment are deserving of special recognition by reason of their outstanding contributions to the excellence, growth, support, and availability of the arts in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0caba70a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s955b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than twelve of such medals may be awarded in any calendar year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0caba70b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s955b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An individual may be awarded the National Medal of Arts only if at the time such award is made such individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0caba70c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s955b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a citizen or other national of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0caba70d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s955b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an alien lawfully admitted to the United States for permanent residence who (i) has filed an application or petition for naturalization in the manner prescribed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1445"},"text":"section 1445 of title 8","children":[],"tail":" and (ii) is not permanently ineligible to become a citizen of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cae180e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s955b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A group may be awarded the National Medal of Arts only if such group is organized or incorporated in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cae180f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s955b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The presentation of the National Medal of Arts shall be made by the President with such ceremonies as the President may deem proper, including attendance by appropriate Members of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cae1810-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s955b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available to the National Endowment for the Arts shall be used to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cae1811-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/306/s13"},"text":"Pub. L. 98–306, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-05-31"},"text":"May 31, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/225"},"text":"98 Stat. 225","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cae1812-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cae1813-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0cae1814-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Foundation on the Arts and the Humanities Act Amendments of 1983, and not as part of the National Foundation on the Arts and the Humanities Act of 1965 which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
