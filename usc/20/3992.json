{"tag":"section","attrib":{"id":"id0de18f79-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3992"},"text":null,"children":[{"tag":"num","attrib":{"value":"3992"},"text":"§ 3992.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de18f7a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3992/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants to States to pay the Federal share of the cost of the programs described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3994"},"text":"section 3994 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de18f7b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3992/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for purposes of carrying out this part ","children":[{"tag":"ref","attrib":{"idref":"fn002158"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002158"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" $20,000,000 for fiscal year 1988."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de18f7c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tIII/s322"},"text":"Pub. L. 98–377, title III, § 322","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tVI/s6031/a/2"},"text":"Pub. L. 100–418, title VI, § 6031(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1480"},"text":"102 Stat. 1480","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de18f7d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de18f7e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0de18f7f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in subsec. (b), was in the original “this chapter” and was translated as reading “this part” to reflect the probable intent of Congress because title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377"},"text":"Pub. L. 98–377","children":[],"tail":", which comprises this subchapter, does not contain chapters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
