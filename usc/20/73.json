{"tag":"section","attrib":{"id":"id0c799a93-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s73"},"text":null,"children":[{"tag":"num","attrib":{"value":"73"},"text":"§ 73.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of gift from A. W. Mellon","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon completion of the National Gallery of Art, the board shall accept for the Smithsonian Institution as a gift from the donor a collection of works of art which shall be housed and exhibited in the National Gallery of Art.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c799a94-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-03-24/ch50/s3"},"text":"Mar. 24, 1937, ch. 50, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/52"},"text":"50 Stat. 52","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
