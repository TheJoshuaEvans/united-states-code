{"tag":"section","attrib":{"id":"id0e1aeec9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641"},"text":null,"children":[{"tag":"num","attrib":{"value":"6641"},"text":"§ 6641.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes; definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e1aeeca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this subpart are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1aeecb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve student academic achievement in reading and writing by providing Federal support to States to develop, revise, or update comprehensive literacy instruction plans that, when implemented, ensure high-quality instruction and effective strategies in reading and writing from early education through grade 12; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aeecc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for States to provide targeted subgrants to early childhood education programs and local educational agencies and their public or private partners to implement evidence-based programs that ensure high-quality comprehensive literacy instruction for students most in need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1aeecd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subpart:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1aeece-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive literacy instruction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “comprehensive literacy instruction” means instruction that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1aeecf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes developmentally appropriate, contextually explicit, and systematic instruction, and frequent practice, in reading and writing across content areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aeed0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes age-appropriate, explicit, systematic, and intentional instruction in phonological awareness, phonic decoding, vocabulary, language structure, reading fluency, and reading comprehension;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aeed1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes age-appropriate, explicit instruction in writing, including opportunities for children to write with clear purposes, with critical reasoning appropriate to the topic and purpose, and with specific instruction and feedback from instructional staff;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aeed2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes available and uses diverse, high-quality print materials that reflect the reading and development levels, and interests, of children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aeed3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses differentiated instructional approaches, including individual and small group instruction and discussion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aeed4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides opportunities for children to use language with peers and adults in order to develop language skills, including developing vocabulary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aeed5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes frequent practice of reading and writing strategies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aeed6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses age-appropriate, valid, and reliable screening assessments, diagnostic assessments, formative assessment processes, and summative assessments to identify a child’s learning needs, to inform instruction, and to monitor the child’s progress and the effects of instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aeed7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses strategies to enhance children’s motivation to read and write and children’s engagement in self-directed learning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aeed8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporates the principles of universal design for learning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aeed9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depends on teachers’ collaboration in planning, instruction, and assessing a child’s progress and on continuous professional learning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aeeda-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" links literacy instruction to the challenging State academic standards, including the ability to navigate, understand, and write about, complex print and digital subject matter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aeedb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means an entity that consists of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1aeedc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" one or more local educational agencies that serve a high percentage of high-need schools and—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e1aeedd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the highest number or proportion of children who are counted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333/c"},"text":"section 6333(c) of this title","children":[],"tail":", in comparison to other local educational agencies in the State;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e1aeede-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are among the local educational agencies in the State with the highest number or percentages of children reading or writing below grade level, based on the most currently available State academic assessment data under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/2"},"text":"section 6311(b)(2) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e1aeedf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve a significant number or percentage of schools that are implementing comprehensive support and improvement activities and targeted support and improvement activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/d"},"text":"section 6311(d) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aeee0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more early childhood education programs serving low-income or otherwise disadvantaged children, which may include home-based literacy programs for preschool-aged children, that have a demonstrated record of providing comprehensive literacy instruction for the age group such program proposes to serve; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aeee1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a local educational agency, described in subparagraph (A), or consortium of such local educational agencies, or an early childhood education program, which may include home-based literacy programs for preschool-aged children, acting in partnership with 1 or more public or private nonprofit organizations or agencies (which may include early childhood education programs) that have a demonstrated record of effectiveness in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e1aeee2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving literacy achievement of children, consistent with the purposes of participation under this subpart, from birth through grade 12; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e1aeee3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing professional development in comprehensive literacy instruction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aeee4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-need school","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1aeee5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “high-need school” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e1aeee6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an elementary school or middle school in which not less than 50 percent of the enrolled students are children from low-income families; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e1aeee7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a high school in which not less than 40 percent of the enrolled students are children from low-income families, which may be calculated using comparable data from the schools that feed into the high school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aeee8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-income family","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the term “low-income family” means a family—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e1aeee9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the children are eligible for a free or reduced-price lunch under the Richard B. Russell National School Lunch Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"42 U.S.C. 1751","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e1aeeea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receiving assistance under the program of block grants to States for temporary assistance for needy families established under part A of title IV of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s601"},"text":"42 U.S.C. 601","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e1aeeeb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6641/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the children are eligible to receive medical assistance under the Medicaid program under title XIX of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e1aeeec-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2221"},"text":"Pub. L. 89–10, title II, § 2221","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tII/s2002"},"text":"Pub. L. 114–95, title II, § 2002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1936"},"text":"129 Stat. 1936","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e1aeeed-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e1aeeee-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e1aeeef-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Richard B. Russell National School Lunch Act, referred to in subsec. (b)(3)(B)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281"},"text":"act June 4, 1946, ch. 281","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/230"},"text":"60 Stat. 230","children":[],"tail":", which is classified generally to chapter 13 (§ 1751 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"section 1751 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (b)(3)(B)(ii), (iii), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Part A of title IV of the Act is classified generally to part A (§ 601 et seq.) of subchapter IV of chapter 7 of Title 42, The Public Health and Welfare. Title XIX of the Act is classified generally to subchapter XIX (§ 1396 et seq.) of chapter 7 of Title 42. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e1aeef0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6641, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2141"},"text":"Pub. L. 89–10, title II, § 2141","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tII/s201"},"text":"Pub. L. 107–110, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1634"},"text":"115 Stat. 1634","children":[],"tail":", related to technical assistance and accountability, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"Pub. L. 114–95, § 5","children":[],"tail":", title II, § 2002, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1806"},"text":"129 Stat. 1806","children":[],"tail":", 1913, effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 6641, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2201"},"text":"Pub. L. 89–10, title II, § 2201","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3621"},"text":"108 Stat. 3621","children":[],"tail":", authorized program for State and local professional development activities, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e1aeef1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e1aeef2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
