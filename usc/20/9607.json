{"tag":"section","attrib":{"id":"id0e6739b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9607"},"text":null,"children":[{"tag":"num","attrib":{"value":"9607"},"text":"§ 9607.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program for statewide, longitudinal data systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e6739ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9607/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to award grants, on a competitive basis, to State educational agencies to enable such agencies to design, develop, and implement statewide, longitudinal data systems to efficiently and accurately manage, analyze, disaggregate, and use individual student data, consistent with the Elementary and Secondary Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"20 U.S.C. 6301","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6739bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9607/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State educational agency desiring a grant under this section shall submit an application to the Secretary at such time, in such manner, and accompanied by such information as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6739bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9607/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awarding of grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this section, the Secretary shall use a peer review process that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e6739bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9607/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures technical quality (including validity and reliability), promotes linkages across States, and protects student privacy consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9573"},"text":"section 9573 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6739be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9607/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" promotes the generation and accurate and timely use of data that is needed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e6739bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9607/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for States and local educational agencies to comply with the Elementary and Secondary Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"20 U.S.C. 6301","children":[],"tail":" et seq.) and other reporting requirements and close achievement gaps; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9607/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate research to improve student academic achievement and close achievement gaps; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6739c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9607/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gives priority to applications that meet the voluntary standards and guidelines described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9543/a/5"},"text":"section 9543(a)(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6739c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9607/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under this section shall be used to supplement, and not supplant, other State or local funds used for developing State data systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6739c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9607/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2002-11-05"},"text":"November 5, 2002","children":[],"tail":", and again 3 years after such date, the Secretary, in consultation with the National Academies Committee on National Statistics, shall make publicly available a report on the implementation and effectiveness of Federal, State, and local efforts related to the goals of this section, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e6739c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9607/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and analyzing State practices regarding the development and use of statewide, longitudinal data systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6739c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9607/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating the ability of such systems to manage individual student data consistent with the Elementary and Secondary Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"20 U.S.C. 6301","children":[],"tail":" et seq.), promote linkages across States, and protect student privacy consistent with "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9573"},"text":"section 9573 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6739c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9607/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying best practices and areas for improvement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e6739c7-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tII/s208"},"text":"Pub. L. 107–279, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1981"},"text":"116 Stat. 1981","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e6739c8-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e6739c9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e6739ca-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Elementary and Secondary Education Act of 1965, referred to in subsecs. (a), (c)(2)(A), and (e)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-04-11"},"text":"Apr. 11, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/27"},"text":"79 Stat. 27","children":[],"tail":", which is classified generally to chapter 70 (§ 6301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
