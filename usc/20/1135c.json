{"tag":"section","attrib":{"id":"id0d78bb39-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1135c"},"text":"§ 1135c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards to graduate students","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d78bb3a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commitments to graduate students","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d78bb3b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An academic department, program or unit of an institution of higher education shall make commitments to graduate students who are eligible students under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1091"},"text":"section 1091 of this title","children":[],"tail":" (including students pursuing a doctoral degree after having completed a master’s degree program at an institution of higher education) at any point in their graduate study to provide stipends for the length of time necessary for a student to complete the course of graduate study, but in no case longer than 5 years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb3c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No such commitments shall be made to students under this subpart unless the academic department, program or unit has determined adequate funds are available to fulfill the commitment from funds received or anticipated under this subpart, or from institutional funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d78bb3d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of stipends","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make payments to institutions of higher education for the purpose of paying stipends to individuals who are awarded fellowships under this subpart. The stipends the Secretary establishes shall reflect the purpose of the program under this subpart to encourage highly talented students to undertake graduate study as described in this subpart. In the case of an individual who receives such individual’s first stipend under this subpart in academic year 2009–2010 or any succeeding academic year, such stipend shall be set at a level of support equal to that provided by the National Science Foundation Graduate Research Fellowship Program for such academic year, except such amount shall be adjusted as necessary so as not to exceed the fellow’s demonstrated level of need as determined under part F of subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d78bb3e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of institutional payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution of higher education that makes institutional payments for tuition and fees on behalf of individuals supported by fellowships under this subpart in amounts that exceed the institutional payments made by the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1135d/a"},"text":"section 1135d(a) of this title","children":[],"tail":" may count such excess toward the amounts the institution is required to provide pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1135b/b/2"},"text":"section 1135b(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d78bb3f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Academic progress required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the provisions of subsection (a), no student shall receive an award—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d78bb40-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except during periods in which such student is maintaining satisfactory progress in, and devoting essentially full time to, study or research in the field in which such fellowship was awarded; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb41-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the student is engaging in gainful employment other than part-time employment involved in teaching, research, or similar activities determined by the institution to be in support of the student’s progress towards a degree.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d78bb42-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s714"},"text":"Pub. L. 89–329, title VII, § 714","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVII/s701"},"text":"Pub. L. 105–244, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1792"},"text":"112 Stat. 1792","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVII/s703/b"},"text":"Pub. L. 110–315, title VII, § 703(b)","children":[],"tail":", (e)(4), "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3346"},"text":"122 Stat. 3346","children":[],"tail":", 3347.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d78bb43-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d78bb44-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d78bb45-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1134p"},"text":"section 1134p of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":