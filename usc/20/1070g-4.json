{"tag":"section","attrib":{"id":"id0cf5818b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070g–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070g–4"},"text":"§ 1070g–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program report","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than two years after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", and every two years thereafter, the Secretary shall prepare and submit to the authorizing committees a report on TEACH grants with respect to the schools and students served by recipients of such grants. Such report shall take into consideration information related to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cf5818c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070g–4/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of TEACH grant recipients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf5818d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070g–4/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degrees obtained by such recipients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf5818e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070g–4/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location, including the school, local educational agency, and State, where the recipients completed the service agreed to under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070g–2/b"},"text":"section 1070g–2(b) of this title","children":[],"tail":" and the subject taught;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf5818f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070g–4/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duration of such service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf58190-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070g–4/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other data necessary to conduct such evaluation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cf58191-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s420P"},"text":"Pub. L. 89–329, title IV, § 420P","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s412/a/2"},"text":"Pub. L. 110–315, title IV, § 412(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3227"},"text":"122 Stat. 3227","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
