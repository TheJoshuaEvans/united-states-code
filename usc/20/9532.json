{"tag":"section","attrib":{"id":"id0e62585f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9532"},"text":null,"children":[{"tag":"num","attrib":{"value":"9532"},"text":"§ 9532.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioner for Education Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Research Center shall be headed by a Commissioner for Education Research (in this part referred to as the “Research Commissioner”) who shall have substantial knowledge of the activities of the Research Center, including a high level of expertise in the fields of research and research management.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e625860-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s132"},"text":"Pub. L. 107–279, title I, § 132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1954"},"text":"116 Stat. 1954","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
