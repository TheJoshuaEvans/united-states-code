{"tag":"section","attrib":{"id":"id0e3505c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7351b"},"text":null,"children":[{"tag":"num","attrib":{"value":"7351b"},"text":"§ 7351b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e3505c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7351b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State educational agency or specially qualified agency desiring to receive a grant under this subpart shall submit an application to the Secretary at such time and in such manner as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e3505c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7351b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application submitted under subsection (a) shall include information on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e3505c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7351b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" program objectives and outcomes for activities under this subpart, including how the State educational agency or specially qualified agency will use funds to help all students meet the challenging State academic standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3505ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7351b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the State educational agency will competitively award grants to eligible local educational agencies, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7351/b/3/A"},"text":"section 7351(b)(3)(A) of this title","children":[],"tail":", the application under the section shall include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e3505cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7351b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methods and criteria the State educational agency will use to review applications and award funds to local educational agencies on a competitive basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3505cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7351b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the State educational agency will notify eligible local educational agencies of the grant competition; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3505cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7351b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the State educational agency will provide technical assistance to eligible local educational agencies to help such agencies implement the activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7351a"},"text":"section 7351a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e3505