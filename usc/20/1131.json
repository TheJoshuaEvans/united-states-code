{"tag":"section","attrib":{"id":"id0d718efe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131"},"text":null,"children":[{"tag":"num","attrib":{"value":"1131"},"text":"§ 1131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minority foreign service professional development program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d718eff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to award a grant, on a competitive basis, to an eligible recipient to enable such recipient to establish an Institute for International Public Policy (hereafter in this part referred to as the “Institute”). The Institute shall conduct a program to enhance the international competitiveness of the United States by increasing the participation of underrepresented populations in the international service, including private international voluntary organizations and the foreign service of the United States. Such program shall include a program for such students to study abroad in their junior year, fellowships for graduate study, internships, intensive academic programs such as summer institutes, or intensive language training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d718f00-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Eligible recipient” defined","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d718f01-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this part, the term “eligible recipient” means a consortium consisting of 1 or more of the following entities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d718f02-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An institution eligible for assistance under part B of subchapter III of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718f03-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A tribally controlled college or university or Alaska Native or Native Hawaiian-serving institution eligible for assistance under part A or B of subchapter III, or an institution eligible for assistance under subchapter V.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718f04-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An institution of higher education that serves substantial numbers of underrepresented minority students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718f05-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An institution of higher education with programs in training foreign service professionals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718f06-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Host institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible recipient receiving a grant under this section shall designate an institution of higher education as the host institution for the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d718f07-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d718f08-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible recipient desiring a grant under this section shall submit an application at such time, in such manner, and accompanied by such information as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718f09-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each application submitted under paragraph (1) shall include a description of how the activities funded by the grant will reflect diverse perspectives and a wide range of views and generate debate on world regions and international affairs, where applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d718f0a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants made pursuant to this section shall be awarded for a period not to exceed 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d718f0b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Match required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The eligible recipient of a grant under this section shall contribute to the conduct of the program supported by the grant an amount from non-Federal sources equal to at least one-half the amount of the grant, which contribution may be in cash or in kind.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d718f0c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s621"},"text":"Pub. L. 89–329, title VI, § 621","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tVI/s601"},"text":"Pub. L. 102–325, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/734"},"text":"106 Stat. 734","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVI/s603/a"},"text":"Pub. L. 105–244, title VI, § 603(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1783"},"text":"112 Stat. 1783","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVI/s612"},"text":"Pub. L. 110–315, title VI, § 612","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3339"},"text":"122 Stat. 3339","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d718f0d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d718f0e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d718f0f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1131, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s621"},"text":"Pub. L. 89–329, title VI, § 621","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tVI/s601/a"},"text":"Pub. L. 96–374, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1469"},"text":"94 Stat. 1469","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tIII/s303/b"},"text":"Pub. L. 97–241, title III, § 303(b)","children":[],"tail":", "},{"tag":"date","attr