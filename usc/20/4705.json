{"tag":"section","attrib":{"id":"id0defe783-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4705"},"text":null,"children":[{"tag":"num","attrib":{"value":"4705"},"text":"§ 4705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stipends","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each person awarded a scholarship or fellowship under this chapter shall receive a stipend which shall not exceed the cost to such person for tuition, fees, books, room and board, or such lesser amount as may be prescribed by the Board. Each person awarded a research internship under this chapter shall receive a stipend as may be prescribed by the Board, which shall not exceed the maximum stipend amount awarded for a scholarship or fellowship.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0defe784-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tXIV/s1406"},"text":"Pub. L. 99–661, div. A, title XIV, § 1406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4010"},"text":"100 Stat. 4010","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXIII/s6304"},"text":"Pub. L. 117–81, div. F, title LXIII, § 6304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2394"},"text":"135 Stat. 2394","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0defe785-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0defe786-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0defe787-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" inserted at end “Each person awarded a research internship under this chapter shall receive a stipend as may be prescribed by the Board, which shall not exceed the maximum stipend amount awarded for a scholarship or fellowship.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
