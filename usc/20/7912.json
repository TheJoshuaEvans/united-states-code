{"tag":"section","attrib":{"id":"id0e51b649-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7912"},"text":null,"children":[{"tag":"num","attrib":{"value":"7912"},"text":"§ 7912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unsafe school choice option","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e51b64a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unsafe school choice policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State receiving funds under this chapter shall establish and implement a statewide policy requiring that a student attending a persistently dangerous public elementary school or secondary school, as determined by the State in consultation with a representative sample of local educational agencies, or who becomes a victim of a violent criminal offense, as determined by State law, while in or on the grounds of a public elementary school or secondary school that the student attends, be allowed to attend a safe public elementary school or secondary school within the local educational agency, including a public charter school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e51b64b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of receiving funds under this chapter, a State shall certify in writing to the Secretary that the State is in compliance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","a