{"tag":"section","attrib":{"id":"id0e5b2c0c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9122"},"text":null,"children":[{"tag":"num","attrib":{"value":"9122"},"text":"§ 9122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e5b2c0d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9122/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Library","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “library” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e5b2c0e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9122/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public library;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e5b2c0f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9122/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public elementary school or secondary school library;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e5b2c10-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9122/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tribal library;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e5b2c11-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9122/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an academic library;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e5b2c12-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9122/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a research library, which for the purposes of this subchapter means a library that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e5b2c13-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9122/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes publicly available library services and materials suitable for scholarly research and not otherwise available to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e5b2c14-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9122/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not an integral part of an institution of higher education; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e5b2c15-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9122/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private library or other special library, but only if the State in which such private or special library is located determines that the library should be considered a library for purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5b2c16-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9122/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Library consortium","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “library consortium” means any local, statewide, regional, interstate, or international cooperative association of library entities which provides for the systematic and effective coordination of the resources of school, public, academic, and special libraries and information centers, for improved services for the clientele of such library entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5b2c17-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9122/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State”, unless otherwise specified, includes each of the 50 States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the United States Virgin Islands, Guam, American Samoa, the Commonwealth of the Northern Mariana Islands, the Republic of the Marshall Islands, the Federated States of Micronesia, and the Republic of Palau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5b2c18-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9122/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State library administrative agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State library administrative agency” means the official agency of a State charged by the law of the State with the extension and development of public library services throughout the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5b2c19-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9122/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State plan” means the document which gives assurances that the officially designated State library administrative agency has the fiscal and legal authority and capability to administer all aspects of this subchapter, provides assurances for establishing the State’s policies, priorities, criteria, and procedures necessary to the implementation of all programs under this subchapter, submits copies for approval as required by regulations promulgated by the Director, identifies a State’s library needs, and sets forth the activities to be taken toward meeting the identified needs supported with the assistance of Federal funds made available under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e5b2c1a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/462/tII/s213"},"text":"Pub. L. 94–462, title II, § 213","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/e/tVII/s702"},"text":"Pub. L. 104–208, div. A, title I, § 101(e) [title VII, § 702]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-233"},"text":"110 Stat. 3009–233","children":[],"tail":", 3009–296; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/128/s3"},"text":"Pub. L. 105–128, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-01"},"text":"Dec. 1, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2548"},"text":"111 Stat. 2548","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/81/tII/s202"},"text":"Pub. L. 108–81, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-25"},"text":"Sept. 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/997"},"text":"117 Stat. 997","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/410/s8"},"text":"Pub. L. 115–410, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5416"},"text":"132 Stat. 5416","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e5b2c1b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e5b2c1c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e5b2c1d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (1)(C) to (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/410"},"text":"Pub. L. 115–410","children":[],"tail":" added subpar. (C) and redesignated former subpars. (C) to (E) as (D) to (F), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Pars. (1) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/81"},"text":"Pub. L. 108–81","children":[],"tail":" redesignated pars. (2) to (6) as (1) to (5), respectively, and struck out heading and text of former par. (1). Text read as follows: “The term ‘Indian tribe’ means any tribe, band, nation, or other organized group or community, including any Alaska native village, regional corporation, or village corporation, as defined in or established pursuant to the Alaska Native Claims Settlement Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.), which is recognized by the Secretary of the Interior as eligible for the special programs and services provided by the United States to Indians because of their status as Indians.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Par. (2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/128"},"text":"Pub. L. 105–128","children":[],"tail":" inserted “or other special library” after “a private library” and “or special” after “such private”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
