{"tag":"section","attrib":{"id":"id0ce0242b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1068b"},"text":"§ 1068b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application review process","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ce0242c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review panel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce0242d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All applications submitted under this subchapter by institutions of higher education shall be read by a panel of readers composed of individuals selected by the Secretary. The Secretary shall assure that no individual assigned under this section to review any application has any conflict of interest with regard to the application which might impair the impartiality with which the individual conducts the review under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce0242e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall take care to assure that representatives of historically and predominantly Black colleges, Hispanic institutions, Tribal Colleges and Universities, and institutions with substantial numbers of Hispanics, Native Americans, Asian Americans, and Native American Pacific Islanders (including Native Hawaiians) are included as readers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce0242f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" All readers selected by the Secretary shall receive thorough instruction from the Secretary regarding the evaluation process for applications submitted under this subchapter and consistent with the provisions of this subchapter, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce02430-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068b/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explanations and examples of the types of activities referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1057/b"},"text":"section 1057(b) of this title","children":[],"tail":" that should receive special consideration for grants awarded under part A and of the types of activities referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1062"},"text":"section 1062 of this title","children":[],"tail":" that should receive special consideration for grants awarded under part B;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce02431-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068b/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an enumeration of the factors to be used to determine the quality of applications submitted under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce02432-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068b/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an enumeration of the factors to be used to determine whether a grant should be awarded for a project under this subchapter, the amount of any such grant, and the duration of any such grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce02433-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations of panel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this subchapter, the Secretary shall take into consideration the recommendations of the panel made under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce02434-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than June 30 of each year, the Secretary shall notify each institution of higher education making an application under this subchapter of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce02435-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scores given the applicant by the panel pursuant to this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce02436-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recommendations of the panel with respect to such application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce02437-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons for the decision of the Secretary in awarding or refusing to award a grant under this subchapter, and any modifications, if any, in the recommendations of the panel made by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce02438-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall not apply to applications submitted under part D.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ce02439-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s393"},"text":"Pub. L. 89–329, title III, § 393","children":[],"tail":", formerly § 353, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIII/s301/a"},"text":"Pub. L. 99–498, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1305"},"text":"100 Stat. 1305","children":[],"tail":"; renumbered § 393 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIII"},"text":"Pub. L. 105–244, title III","children":[],"tail":", §§ 301(a)(2), 308(e), "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1636"},"text":"112 Stat. 1636","children":[],"tail":", 1649.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ce0243a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ce0243b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0ce0243c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1068"},"text":"section 1068 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0ce0243d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s308/e/1"},"text":"Pub. L. 105–244, § 308(e)(1)","children":[],"tail":", substituted “Tribal Colleges and Universities” for “Native American colleges and universities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s308/e/2"},"text":"Pub. L. 105–244, § 308(e)(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0ce0243e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0ce0243f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
