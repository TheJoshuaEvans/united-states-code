{"tag":"section","attrib":{"id":"id0d871363-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161l–5"},"text":"§ 1161l–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this part shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d871364-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–5/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a private right of action to any person to enforce any provision of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d871365-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–5/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to create a cause of action against any institution of higher education or any employee of the institution for any civil liability; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d871366-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–5/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to affect ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232g"},"text":"section 1232g of this title","children":[],"tail":" (commonly known as the “Family Educational Rights and Privacy Act of 1974”) or the regulations issued under section 264 of the Health Insurance Portability and Accountability Act of 1996 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–2"},"text":"42 U.S.C. 1320d–2","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d871367