{"tag":"section","attrib":{"id":"id0de67196-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4305"},"text":null,"children":[{"tag":"num","attrib":{"value":"4305"},"text":"§ 4305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement with Gallaudet University","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de67197-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and Gallaudet University shall establish, and periodically update, an agreement governing the operation and national mission activities, including construction and provision of equipment, of the elementary and secondary education programs at the University. The Secretary or the University shall determine the necessity for the periodic update described in the preceding sentence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de67198-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions of agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The agreement shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de67199-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4305/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that Federal funds appropriated for the benefit of the Kendall Demonstration Elementary School and the Model Secondary School for the Deaf will be used only for the purposes for which appropriated and in accordance with the applicable provisions of this chapter and such agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de6719a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4305/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that the University will make an annual report, to be part of the report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4354"},"text":"section 4354 of this title","children":[],"tail":", to the Secretary on the operations and national mission activities of the elementary and secondary education programs, including such other information as the Secretary may consider necessary;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de6719b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4305/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that in the design and construction of any facilities, maximum attention will be given to innovative auditory and visual devices and installations appropriate for the educational functions of such facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de6719c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4305/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that any laborer or mechanic employed by any contractor or subcontractor in the performance of work on any construction aided by Federal funds appropriated for the benefit of the Kendall Demonstration Elementary School or the Model Secondary School for the Deaf will be paid wages at rates not less than those prevailing on similar construction in the locality as determined by the Secretary of Labor in accordance with subchapter IV of chapter 31 of title 40, commonly referred to as the Davis-Bacon Act; except that the Secretary of Labor shall have, with respect to the labor standards specified in this paragraph, the authority and functions set forth in Reorganization Plan Numbered 14 of 1950 (5 U.S.C. App.) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3145"},"text":"section 3145 of title 40","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de6719d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4305/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include such other conditions as the Secretary or the University considers necessary to carry out the purposes of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de6719e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/371/tI/s105"},"text":"Pub. L. 99–371, title I, § 105","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/421/tI/s113"},"text":"Pub. L. 102–421, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"Oct. 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2154"},"text":"106 Stat. 2154","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/73/tII/s203/e"},"text":"Pub. L. 103–73, title II, § 203(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-11"},"text":"Aug. 11, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/734"},"text":"107 Stat. 734","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s913"},"text":"Pub. L. 105–244, title IX, § 913","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1830"},"text":"112 Stat. 1830","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIX/s902"},"text":"Pub. L. 110–315, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3451"},"text":"122 Stat. 3451","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de6719f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de671a0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0de671a1-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Reorganization Plan Numbered 14 of 1950, referred to in subsec. (b)(4), is set out in the Appendix to Title 5, Government Organization and Employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0de671a2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" substituted “subchapter IV of chapter 31 of title 40, commonly referred to as the Davis-Bacon Act” for “the Act of "},{"tag":"date","attrib":{"date":"1931-03-03"},"text":"March 3, 1931","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s276a"},"text":"40 U.S.C. 276a","children":[],"tail":"—276a–5) commonly referred to as the Davis-Bacon Act” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s3145"},"text":"section 3145 of title 40","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/act/1934-06-13/s2"},"text":"section 2 of the Act of June 13, 1934","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s276c"},"text":"40 U.S.C. 276c","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" substituted “and periodically update, an” for “within 1 year after "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"October 16, 1992","children":[],"tail":", a new” and “The Secretary or the University shall determine the necessity for the periodic update described in the preceding sentence.” for “The Secretary and the University shall periodically update the agreement as determined to be necessary by the Secretary or the University.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/73/s203/e/1"},"text":"Pub. L. 103–73, § 203(e)(1)","children":[],"tail":", substituted “will” for “shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/73/s203/e/2"},"text":"Pub. L. 103–73, § 203(e)(2)","children":[],"tail":", substituted “Elementary School or the Model” for “Elementary School and the Model” and “except that the Secretary” for “and the Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0de671a3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0de671a4-3a70-11f1-a648-bee82ed8a795"},"text":