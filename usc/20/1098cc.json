{"tag":"section","attrib":{"id":"id0d6336f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"1098cc"},"text":"§ 1098cc.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tuition refunds or credits for members of armed forces","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d6336f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098cc/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6336f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098cc/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all institutions offering postsecondary education should provide a full refund to students who are affected individuals for that portion of a period of instruction such student was unable to complete, or for which such individual did not receive academic credit, because he or she was called up for active duty or active service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6336f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098cc/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if affected individuals withdraw from a course of study as a result of such active duty or active service, such institutions should make every effort to minimize deferral of enrollment or reapplication requirements and should provide the greatest flexibility possible with administrative deadlines related to those applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6336fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098cc/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of full refund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, a full refund includes a refund of required tuition and fees, or a credit in a comparable amount against future tuition and fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6336fb-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/76/s3"},"text":"Pub. L. 108–76, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-08-18"},"text":"Aug. 18, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/906"},"text":"117 Stat. 906","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d6336fc-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d6336fd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d6336fe-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out in a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070"},"text":"section 1070 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Higher Education Relief Opportunities for Students Act of 2003, and not as part of title IV of the Higher Education Act of 1965 which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
