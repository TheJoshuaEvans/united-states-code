{"tag":"section","attrib":{"id":"id0e35063a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422"},"text":null,"children":[{"tag":"num","attrib":{"value":"7422"},"text":"§ 7422.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to local educational agencies and tribes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e35063b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make grants, from allocations made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7423"},"text":"section 7423 of this title","children":[],"tail":", and in accordance with this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7423"},"text":"section 7423 of this title","children":[],"tail":", to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e35063c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local educational agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e35063d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian tribes, as provided under subsection (c)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e35063e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian organizations, as provided under subsection (c)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e35063f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consortia of 2 or more local educational agencies, Indian tribes, Indian organizations, or Indian community-based organizations, if each local educational agency participating in such a consortium, if applicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e350640-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides an assurance that the eligible Indian children served by such local educational agency will receive the services of the programs funded under this subpart; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e350641-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to all the requirements, assurances, and obligations applicable to local educational agencies under this subpart; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e350642-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian community-based organizations, as provided under subsection (d)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e350643-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local educational agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e350644-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), a local educational agency shall be eligible for a grant under this subpart for any fiscal year if the number of Indian children eligible under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7427"},"text":"section 7427 of this title","children":[],"tail":" who were enrolled in the schools of the agency, and to whom the agency provided free public education, during the preceding fiscal year—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e350645-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was at least 10; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e350646-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constituted not less than 25 percent of the total number of individuals enrolled in the schools of such agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e350647-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A local educational agency may enter into a cooperative agreement with an Indian tribe under this subpart if such Indian tribe—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e350648-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represents not less than 25 percent of the eligible Indian children who are served by such local educational agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e350649-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requests that the local educational agency enter into a cooperative agreement under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e35064a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirement of paragraph (1) shall not apply in Alaska, California, or Oklahoma, or with respect to any local educational agency located on, or in proximity to, a reservation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e35064b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribes and Indian organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e35064c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a local educational agency that is otherwise eligible for a grant under this subpart does not establish a committee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7424/c/4"},"text":"section 7424(c)(4) of this title","children":[],"tail":" for such grant, an Indian tribe, an Indian organization, or a consortium of such entities, that represents more than one-half of the eligible Indian children who are served by such local educational agency may apply for such grant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e35064d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e35064e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall treat each Indian tribe, Indian organization, or consortium of such entities applying for a grant pursuant to paragraph (1) as if such tribe, Indian organization, or consortium were a local educational agency for purposes of this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e35064f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (A), such Indian tribe, Indian organization, or consortium shall not be subject to the requirements of subsections (b)(7) or (c)(4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7424"},"text":"section 7424 of this title","children":[],"tail":" or section 7428(c) or 7429 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e350650-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assurance to serve all Indian children","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Indian tribe, Indian organization, or consortium of such entities that is eligible to apply for a grant under paragraph (1) shall include, in the application required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7424"},"text":"section 7424 of this title","children":[],"tail":", an assurance that the entity will use the grant funds to provide services to all Indian students served by the local educational agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e350651-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian community-based organization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e350652-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If no local educational agency pursuant to subsection (b), and no Indian tribe, Indian organization, or consortium pursuant to subsection (c), applies for a grant under this subpart in a particular community, an Indian community-based organization serving the community of the local educational agency may apply for such grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e350653-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall apply the special rule in subsection (c)(2) to an Indian community-based organization applying for a grant under paragraph (1) in the same manner as such rule applies to an Indian tribe, Indian organization, or consortium described in that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e350654-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of Indian community-based organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “Indian community-based organization” means any organization that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e350655-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is composed primarily of Indian parents, family members, and community members, tribal government education officials, and tribal members, from a specific community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e350656-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assists in the social, cultural, and educational development of Indians in such community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e350657-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the unique cultural, language, and academic needs of Indian students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e350658-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7422/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates organizational and administrative capacity to manage the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e350659-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVI/s6112"},"text":"Pub. L. 89–10, title VI, § 6112","children":[],"tail":", formerly title VII, § 7112, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVII/s701"},"text":"Pub. L. 107–110, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1908"},"text":"115 Stat. 1908","children":[],"tail":"; renumbered title VI, § 6112, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVI"},"text":"Pub. L. 114–95, title VI","children":[],"tail":", §§ 6001(a), (b)(1), (2), 6002(d), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2046"},"text":"129 Stat. 2046","children":[],"tail":", 2048.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e35065a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e35065b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e35065c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7422, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVII/s7112"},"text":"Pub. L. 89–10, title VII, § 7112","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3719"},"text":"108 Stat. 3719","children":[],"tail":", related to program development and implementation grants, prior to the general amendment of former subchapter VII of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/19/s6112"},"text":"section 6112 of Pub. L. 89–19","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7301a"},"text":"section 7301a of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e35065d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/d/1"},"text":"Pub. L. 114–95, § 6002(d)(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a). Prior to amendment, text read as follows: “The Secretary may make grants, from allocations made under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7423"},"text":"section 7423 of this title","children":[],"tail":", to local educational agencies and Indian tribes, in accordance with this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7423"},"text":"section 7423 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/d/2/A"},"text":"Pub. L. 114–95, § 6002(d)(2)(A)","children":[],"tail":", substituted “Subject to paragraph (2), a local educational agency shall” for “A local educational agency shall” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6001/b/2"},"text":"Pub. L. 114–95, § 6001(b)(2)","children":[],"tail":", made technical amendment to reference in original act which appears in introductory provisions as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7427"},"text":"section 7427 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/d/2/B"},"text":"Pub. L. 114–95, § 6002(d)(2)(B)","children":[],"tail":", (C), added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/d/3"},"text":"Pub. L. 114–95, § 6002(d)(3)","children":[],"tail":", added subsecs. (c) and (d) and struck out former subsec. (c) which allowed certain Indian tribes to apply for grants."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e35065e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e35065f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
