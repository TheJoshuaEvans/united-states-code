{"tag":"section","attrib":{"id":"id0e00aff3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303"},"text":null,"children":[{"tag":"num","attrib":{"value":"6303"},"text":"§ 6303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" School improvement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e00aff4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State reservations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out subsection (b) and the State educational agency’s statewide system of technical assistance and support for local educational agencies, each State shall reserve the greater of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e00aff5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 7 percent of the amount the State receives under subpart 2 of part A; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e00aff6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum of the amount the State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e00aff7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reserved for fiscal year 2016 under this subsection, as in effect on the day before ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"December 10, 2015","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00aff8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received for fiscal year 2016 under subsection (g), as in effect on the day before ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"December 10, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e00aff9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amount reserved under subsection (a) for any fiscal year, the State educational agency—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e00affa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e00affb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall allocate not less than 95 percent of that amount to make grants to local educational agencies on a formula or competitive basis, to serve schools implementing comprehensive support and improvement activities or targeted support and improvement activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/d"},"text":"section 6311(d) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00affc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, with the approval of the local educational agency, directly provide for these activities or arrange for their provision through other entities such as school support teams, educational service agencies, or nonprofit or for-profit external providers with expertise in using evidence-based strategies to improve student achievement, instruction, and schools; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e00affd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall use the funds not allocated to local educational agencies under paragraph (1) to carry out this section, which shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e00affe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establishing the method, consistent with paragraph (1)(A), the State will use to allocate funds to local educational agencies under such paragraph, including ensuring—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e00afff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the local educational agencies receiving an allotment under such paragraph represent the geographic diversity of the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e00b000-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that allotments are of sufficient size to enable a local educational agency to effectively implement selected strategies;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00b001-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring and evaluating the use of funds by local educational agencies receiving an allotment under such paragraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00b002-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, reducing barriers and providing operational flexibility for schools in the implementation of comprehensive support and improvement activities or targeted support and improvement activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/d"},"text":"section 6311(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e00b003-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State educational agency shall award each subgrant under subsection (b) for a period of not more than 4 years, which may include a planning year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e00b004-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as prohibiting a State from allocating subgrants under this section to a statewide school district, consortium of local educational agencies, or an educational service agency that serves schools implementing comprehensive support and improvement activities or targeted support and improvement activities, if such entities are legally constituted or recognized as local educational agencies in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e00b005-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To receive an allotment under subsection (b)(1), a local educational agency shall submit an application to the State educational agency at such time, in such form, and including such information as the State educational agency may require. Each application shall include, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e00b006-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of how the local educational agency will carry out its responsibilities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/d"},"text":"section 6311(d) of this title","children":[],"tail":" for schools receiving funds under this section, including how the local educational agency will—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e00b007-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop comprehensive support and improvement plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/d/1"},"text":"section 6311(d)(1) of this title","children":[],"tail":" for schools receiving funds under this section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00b008-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support schools developing or implementing targeted support and improvement plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/d/2"},"text":"section 6311(d)(2) of this title","children":[],"tail":", if funds received under this section are used for such purpose;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00b009-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor schools receiving funds under this section, including how the local educational agency will carry out its responsibilities under clauses (iv) and (v) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/d/2/B"},"text":"section 6311(d)(2)(B) of this title","children":[],"tail":" if funds received under this section are used to support schools implementing targeted support and improvement plans;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00b00a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use a rigorous review process to recruit, screen, select, and evaluate any external partners with whom the local educational agency will partner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00b00b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" align other Federal, State, and local resources to carry out the activities supported with funds received under subsection (b)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00b00c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/e/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, modify practices and policies to provide operational flexibility that enables full and effective implementation of the plans described in paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/d"},"text":"section 6311(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e00b00d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that each school the local educational agency proposes to serve will receive all of the State and local funds it would have received in the absence of funds received under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e00b00e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State educational agency, in allocating funds to local educational agencies under this section, shall give priority to local educational agencies that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e00b00f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve high numbers, or a high percentage of, elementary schools and secondary schools implementing plans under paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/d"},"text":"section 6311(d) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e00b010-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate the greatest need for such funds, as determined by the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e00b011-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate the strongest commitment to using funds under this section to enable the lowest-performing schools to improve student achievement and student outcomes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e00b012-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unused funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, after consultation with local educational agencies in the State, the State educational agency determines that the amount of funds reserved to carry out subsection (b) is greater than the amount needed to provide the assistance described in that subsection, the State educational agency shall allocate the excess amount to local educational agencies in accordance with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e00b013-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relative allocations the State educational agency made to those agencies for that fiscal year under subpart 2 of part A; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e00b014-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6338/c"},"text":"section 6338(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e00b015-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section, the amount of funds reserved by the State educational agency under subsection (a) for fiscal year 2018 and each subsequent fiscal year shall not decrease the amount of funds each local educational agency receives under subpart 2 of part A below the amount received by such local educational agency under such subpart for the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e00b016-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State shall include in the report described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/h/1"},"text":"section 6311(h)(1) of this title","children":[],"tail":" a list of all the local educational agencies and schools that received funds under this section, including the amount of funds each school received and the types of strategies implemented in each school with such funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e00b017-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1003"},"text":"Pub. L. 89–10, title I, § 1003","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1442"},"text":"115 Stat. 1442","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tI/s1003"},"text":"Pub. L. 114–95, title I, § 1003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1815"},"text":"129 Stat. 1815","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e00b018-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e00b019-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e00b01a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6303, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1003"},"text":"Pub. L. 89–10, title I, § 1003","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3522"},"text":"108 Stat. 3522","children":[],"tail":", related to reservation and allocation for school improvement, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s1003"},"text":"section 1003 of Pub. L. 89–10","children":[],"tail":" was renumbered section 9003 and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3383"},"text":"section 3383 of this title","children":[],"tail":", prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e00b01b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" amended section generally. Prior to amendment, section consisted of subsecs. (a) to (g) relating to State reservations of amounts, uses of amounts, priority in allocating funds, allocation of unused funds, special rule limiting decrease of amounts received under subpart 2 of part A, reporting of list of recipient schools and percentage of students from families with incomes below poverty line, and grants program for assistance for local school improvement."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e00b01c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e00b01d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
