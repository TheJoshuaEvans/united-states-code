{"tag":"section","attrib":{"id":"id0e3c3257-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7516"},"text":null,"children":[{"tag":"num","attrib":{"value":"7516"},"text":"§ 7516.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e3c3258-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7516/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No grant may be made under this part, and no contract may be entered into under this part, unless the entity seeking the grant or contract submits an application to the Secretary at such time, in such manner, and containing such information as the Secretary may determine to be necessary to carry out the provisions of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e3c3259-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7516/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each applicant for a grant or contract under this part shall submit the application for comment to the local educational agency serving students who will participate in the program to be carried out under the grant or contract, and include those comments, if any, with the application to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e3c325a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVI/s6206"},"text":"Pub. L. 89–10, title VI, 