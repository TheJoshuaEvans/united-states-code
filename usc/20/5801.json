{"tag":"section","attrib":{"id":"id0df712b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5801"},"text":null,"children":[{"tag":"num","attrib":{"value":"5801"},"text":"§ 5801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this chapter is to provide a framework for meeting the National Education Goals established by subchapter I of this chapter by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0df712b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5801/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting coherent, nationwide, systemic education reform;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df712b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5801/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the quality of learning and teaching in the classroom and in the workplace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df712ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5801/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defining appropriate and coherent Federal, State, and local roles and responsibilities for education reform and lifelong learning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df712bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5801/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establishing valid and reliable mechanisms for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0df712bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5801/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building a broad national consensus on American education reform;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df712bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5801/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting in the development and certification of high-quality, internationally competitive content and student performance standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df712be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5801/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting in the development and certification of high-quality assessment measures that reflect the internationally competitive content and student performance standards;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df712bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5801/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting new initiatives at the Federal, State, local, and school levels to provide equal educational opportunity for all students to meet high academic and occupational skill standards and to succeed in the world of employment and civic participation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df712c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5801/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing a framework for the reauthorization of all Federal education programs by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0df712c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5801/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating a vision of excellence and equity that will guide all Federal education and related programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df712c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5801/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for the establishment of high-quality, internationally competitive content and student performance standards and strategies that all students will be expected to achieve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df712c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5801/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging and enabling all State educational agencies and local educational agencies to develop comprehensive improvement plans that will provide a coherent framework for the implementation of reauthorized Federal education and related programs in an integrated fashion that effectively educates all children to prepare them to participate fully as workers, parents, and citizens;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df712c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5801/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing resources to help individual schools, including those serving students with high needs, develop and implement comprehensive improvement plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df712c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5801/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting the use of technology to enable all students to achieve the National Education Goals;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df712c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5801/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stimulating the development and adoption of a voluntary national system of skill standards and certification to serve as a cornerstone of the national strategy to enhance workforce skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df712c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5801/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting every elementary and secondary school that receives funds under this chapter to actively involve parents and families in supporting the academic work of their children at home and in providing parents with skills to advocate for their children at school.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0df712c8-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/227/s2"},"text":"Pub. L. 103–227, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"Mar. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/128"},"text":"108 Stat. 128","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101/d/tVII/s703/a/2"},"text":"Pub. L. 104–134, title I, § 101(d) [title VII, § 703(a)(2)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321-211"},"text":"110 Stat. 1321–211","children":[],"tail":", 1321–252; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0df712c9-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0df712ca-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0df712cb-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/227"},"text":"Pub. L. 103–227","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"Mar. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/125"},"text":"108 Stat. 125","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0df712cc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Par. (4)(B) to (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/s101/d/tVII/s703/a/2/A"},"text":"Pub. L. 104–134, § 101(d) [title VII, § 703(a)(2)(A)]","children":[],"tail":", inserted “and” at end of subpar. (B), redesignated subpar. (D) as (C), and struck out former subpar. (C) which read as follows: “assisting in the development and certification of opportunity-to-learn standards; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6)(C) to (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/s101/d/tVII/s703/a/2/B"},"text":"Pub. L. 104–134, § 101(d) [title VII, § 703(a)(2)(B)]","children":[],"tail":", redesignated subpars. (D) to (F) as (C) to (E), respectively, and struck out former subpar. (C) which read as follows: “providing for the establishment of high-quality, internationally competitive opportunity-to-learn standards that all States, local educational agencies, and schools should achieve;”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0df712cd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0df712ce-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/25/s1"},"text":"Pub. L. 106–25, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-04-29"},"text":"Apr. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/41"},"text":"113 Stat. 41","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/25/s1"},"text":"“This Act [enacting sections 5891a and 5891b of this title, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1415"},"text":"section 1415 of this title","children":[],"tail":", and enacting provisions set out as notes under sections 1415 and 5891a of this title] may be cited as the ‘Education Flexibility Partnership Act of 1999’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id0df712cf-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/227/s1/a"},"text":"Pub. L. 103–227, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"Mar. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/125"},"text":"108 Stat. 125","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/227/s1/a"},"text":"“This Act (other than titles V and IX) [enacting this chapter (other than subchapters V and IX) and sections 3351 and 3425 of this title, amending sections 1107, 1221e–1, 1232h, 2421, 3381 to 3384, 3386, and 5093 of this title, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of Title 5","children":[],"tail":", Government Organization and Employees, sections 1632, 1633, and 1635 of Title 29, Labor, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11903a"},"text":"section 11903a of Title 42","children":[],"tail":", The Public Health and Welfare, and enacting provisions set out as notes under sections 5093 and 6301 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11901"},"text":"section 11901 of Title 42","children":[],"tail":"] may be cited as the ‘Goals 2000: Educate America Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
