{"tag":"section","attrib":{"id":"id0e673915-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9575"},"text":null,"children":[{"tag":"num","attrib":{"value":"9575"},"text":"§ 9575.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance management","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Director shall ensure that all activities conducted or supported by the Institute or a National Education Center make customer service a priority. The Director shall ensure a high level of customer satisfaction through the following methods:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e673916-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9575/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing and improving feedback mechanisms in order to anticipate customer needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e673917-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9575/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Disseminating information in a timely fashion and in formats that are easily accessible and usable by researchers, practitioners, and the general public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e673918-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9575/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Utilizing the most modern technology and other methods available, including arrangements to use data collected electronically by States and local educational agencies, to ensure the efficient collection and timely distribution of information, including data and reports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e673919-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9575/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing and measuring performance against a set of indicators for the quality of data collected, analyzed, and reported.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e67391a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9575/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Continuously improving management strategies and practices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e67391b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9575/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Making information available to the public in an expeditious fashion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e67391c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s185"},"text":"Pub. L. 107–279, title I, § 185","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1972"},"text":"116 Stat. 1972","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
