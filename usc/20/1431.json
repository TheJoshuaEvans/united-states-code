{"tag":"section","attrib":{"id":"id0da85742-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1431"},"text":null,"children":[{"tag":"num","attrib":{"value":"1431"},"text":"§ 1431.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0da85743-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1431/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that there is an urgent and substantial need—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0da85744-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1431/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance the development of infants and toddlers with disabilities, to minimize their potential for developmental delay, and to recognize the significant brain development that occurs during a child’s first 3 years of life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da85745-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1431/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the educational costs to our society, including our Nation’s schools, by minimizing the need for special education and related services after infants and toddlers with disabilities reach school age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da85746-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1431/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maximize the potential for individuals with disabilities to live independently in society;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da85747-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1431/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance the capacity of families to meet the special needs of their infants and toddlers with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da85748-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1431/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance the capacity of State and local agencies and service providers to identify, evaluate, and meet the needs of all children, particularly minority, low-income, inner city, and rural children, and infants and toddlers in foster care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da85749-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1431/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the policy of the United States to provide financial assistance to States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0da8574a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1431/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and implement a statewide, comprehensive, coordinated, multidisciplinary, interagency system that provides early intervention services for infants and toddlers with disabilities and their families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da8574b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1431/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the coordination of payment for early intervention services from Federal, State, local, and private sources (including public and private insurance coverage);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da8574c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1431/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance State capacity to provide quality early intervention services and expand and improve existing early intervention services being provided to infants and toddlers with disabilities and their families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da8574d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1431/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage States to expand opportunities for children under 3 years of age who would be at risk of having substantial developmental delay if they did not receive early intervention services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0da8574e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s631"},"text":"Pub. L. 91–230, title VI, § 631","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2744"},"text":"118 Stat. 2744","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0da8574f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0da85750-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0da85751-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1431, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s631"},"text":"Pub. L. 91–230, title VI, § 631","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/17/tI/s101"},"text":"Pub. L. 105–17, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-04"},"text":"June 4, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/106"},"text":"111 Stat. 106","children":[],"tail":", set out findings and policy, prior to the general amendment of subchapters I to IV of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/108/446"},"text":"Pub. L. 108–446","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1431, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s631"},"text":"Pub. L. 91–230, title VI, § 631","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/184"},"text":"84 Stat. 184","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/199"},"text":"Pub. L. 98–199","children":[],"tail":", §§ 3(b), 11, "},{"tag":"date","attrib":{"date":"1983-12-02"},"text":"Dec. 2, 1983","children":[],"tail":", "},{"tag":