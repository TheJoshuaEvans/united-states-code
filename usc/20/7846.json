{"tag":"section","attrib":{"id":"id0e4cfbb2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7846"},"text":null,"children":[{"tag":"num","attrib":{"value":"7846"},"text":"§ 7846.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other general assurances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e4cfbb3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7846/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assurances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any applicant, other than a State educational agency that submits a plan or application under this chapter, shall have on file with the State educational agency a single set of assurances, applicable to each program for which a plan or application is submitted, that provides that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e4cfbb4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7846/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each such program will be administered in accordance with all applicable statutes, regulations, program plans, and applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4cfbb5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7846/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4cfbb6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7846/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the control of funds provided under each such program and title to property acquired with program funds will be in a public agency or in a ","children":[{"tag":"ref","attrib":{"idref":"fn002232"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002232"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “an”."}],"tail":" eligible private agency, institution, organization, or Indian tribe, if the law authorizing the program provides for assistance to those entities; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4cfbb7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7846/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public agency, eligible private agency, institution, or organization, or Indian tribe will administer the funds and property to the extent required by the authorizing statutes;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4cfbb8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7846/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the applicant will adopt and use proper methods of administering each such program, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4cfbb9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7846/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enforcement of any obligations imposed by law on agencies, institutions, organizations, and other recipients responsible for carrying out each program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4cfbba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7846/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the correction of deficiencies in program operations that are identified through audits, monitoring, or evaluation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4cfbbb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7846/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant will cooperate in carrying out any evaluation of each such program conducted by or for the State educational agency, the Secretary, or other Federal officials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4cfbbc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7846/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant will use such fiscal control and fund accounting procedures as will ensure proper disbursement of, and accounting for, Federal funds paid to the applicant under each such program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4cfbbd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7846/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the applicant will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4cfbbe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7846/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit such reports to the State educational agency (which shall make the reports available to the Governor) and the Secretary as the State educational agency and Secretary may require to enable the State educational agency and the Secretary to perform their duties under each such program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4cfbbf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7846/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain such records, provide such information, and afford such access to the records as the State educational agency (after consultation with the Governor) or the Secretary may reasonably require to carry out the State educational agency’s or the Secretary’s duties; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4cfbc0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7846/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the application was submitted, the applicant afforded a reasonable opportunity for public comment on the application and considered such comment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4cfbc1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7846/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GEPA provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 442 of the General Education Provisions Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232e"},"text":"20 U.S.C. 1232e","children":[],"tail":"] shall not apply to programs under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e4cfbc2-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8306"},"text":"Pub. L. 89–10, title VIII, § 8306","children":[],"tail":", formerly title IX, § 9306, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIX/s901"},"text":"Pub. L. 107–110, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1971"},"text":"115 Stat. 1971","children":[],"tail":"; renumbered title VIII, § 8306, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII"},"text":"Pub. L. 114–95, title VIII","children":[],"tail":", §§ 8001(a)(3), (b)(2), 8012, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2088"},"text":"129 Stat. 2088","children":[],"tail":", 2089, 2102.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e4cfbc3-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e4cfbc4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e4cfbc5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7851, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIX/s9131"},"text":"Pub. L. 89–10, title IX, § 9131","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3790"},"text":"108 Stat. 3790","children":[],"tail":", which related to improvement of educational opportunities for adult Indians, was omitted in the general amendment of former subchapter IX of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e4cfbc6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8012/1"},"text":"Pub. L. 114–95, § 8012(1)","children":[],"tail":", struck out “whether separately or pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7845"},"text":"section 7845 of this title","children":[],"tail":",” before “shall have on file” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8001/b/2"},"text":"Pub. L. 114–95, § 8001(b)(2)","children":[],"tail":", made technical amendment to reference in original act which appears in introductory provisions as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7845"},"text":"section 7845 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8012/2"},"text":"Pub. L. 114–95, § 8012(2)","children":[],"tail":", substituted “eligible” for “nonprofit” in subpars. (A) and (B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e4cfbc7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e4cfbc8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":