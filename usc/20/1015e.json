{"tag":"section","attrib":{"id":"id0cc37490-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1015e"},"text":"§ 1015e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State higher education information system pilot program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cc37491-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this section to carry out a pilot program to assist not more than five States to develop State-level postsecondary student data systems to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cc37492-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the capacity of States and institutions of higher education to generate more comprehensive and comparable data, in order to develop better-informed educational policy at the State level and to evaluate the effectiveness of institutional performance while protecting the confidentiality of students’ personally identifiable information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc37493-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify how to best minimize the data-reporting burden placed on institutions of higher education, particularly smaller institutions, and to maximize and improve the information institutions receive from the data systems, in order to assist institutions in improving educational practice and postsecondary outcomes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc37494-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible entity” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cc37495-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State higher education system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc37496-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium of State higher education systems, or a consortium of individual institutions of higher education, that is broadly representative of institutions in different sectors and geographic locations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc37497-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cc37498-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall award grants, on a competitive basis, to not more than five eligible entities to enable the eligible entities to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cc37499-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design, test, and implement systems of postsecondary student data that provide the maximum benefits to States, institutions of higher education, and State policymakers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc3749a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine the costs and burdens involved in implementing a State-level postsecondary student data system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc3749b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under this section shall be for a period of not more than three years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc3749c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity desiring a grant under this section shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may reasonably require, including a description of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cc3749d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the eligible entity will ensure that student privacy is protected and that individually identifiable information about students, the students’ achievements, and the students’ families remains confidential in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232g"},"text":"section 1232g of this title","children":[],"tail":" (commonly known as the “Family Educational Rights and Privacy Act of 1974”); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc3749e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the activities funded by the grant will be supported after the three-year grant period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc3749f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant awarded under this section shall be used to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cc374a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design, develop, and implement the components of a comprehensive postsecondary student data system with the capacity to transmit student information within a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc374a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the capacity of institutions of higher education to analyze and use student data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc374a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" select and define common data elements, data quality, and other elements that will enable the data system to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cc374a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve the needs of institutions of higher education for institutional research and improvement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc374a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide students and the students’ families with useful information for decision-making about postsecondary education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc374a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide State policymakers with improved information to monitor and guide efforts to improve student outcomes and success in higher education;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc374a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimate costs and burdens at the institutional level for the reporting system for different types of institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc374a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" test the feasibility of protocols and standards for maintaining data privacy and data access.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc374a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation; reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than six months after the end of the projects funded by grants awarded under this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cc374a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a comprehensive evaluation of the pilot program authorized by this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc374aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report the Secretary’s findings, as well as recommendations regarding the implementation of State-level postsecondary student data systems, to the authorizing committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc374ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015e/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cc374ac-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s136"},"text":"Pub. L. 89–329, title I, § 136","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tI/s115"},"text":"Pub. L. 110–315, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3111"},"text":"122 Stat. 3111","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tI/s101/b/4"},"text":"Pub. L. 111–39, title I, § 101(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1935"},"text":"123 Stat. 1935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cc374ad-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cc374ae-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cc374af-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" substituted “(commonly known as the ‘Family Educational Rights and Privacy Act of 1974’)” for “(Family Educational Rights and Privacy Act of 1974)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cc374b0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cc374b1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" effective as if enacted on the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/s3"},"text":"section 3 of Pub. L. 111–39","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
