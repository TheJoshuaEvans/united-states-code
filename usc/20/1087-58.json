{"tag":"section","attrib":{"id":"id0d29ff93-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58"},"text":null,"children":[{"tag":"num","attrib":{"value":"1087–58"},"text":"§ 1087–58.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Work colleges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d29ff94-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to recognize, encourage, and promote the use of comprehensive work-learning-service programs as a valuable educational approach when it is an integral part of the institution’s educational program and a part of a financial plan which decreases reliance on grants and loans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d29ff95-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source and use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d29ff96-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the sums appropriated under subsection (f) of this section, funds allocated to the institution under this part and part E of this subchapter may be transferred for use under this section to provide flexibility in strengthening the self-help-through-work element in financial aid packaging.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d29ff97-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the sums appropriated pursuant to subsection (f) of this section, and from the funds available under paragraph (1), eligible institutions may, following approval of an application under subsection (c) of this section by the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d29ff98-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the educational costs of qualified students through self-help payments or credits provided under the work-learning-service program of the institution within the limits of part F of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d29ff99-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the work-learning-service experience as a tool of postsecondary education, financial self-help and community service-learning opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d29ff9a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out activities described in section 1087–53 or 1087–56 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d29ff9b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be used for the administration, development and assessment of comprehensive work-learning-service programs, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d29ff9c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-based work-learning-service alternatives that expand opportunities for community service and career-related work; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d29ff9d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternatives that develop sound citizenship, encourage student persistence, and make optimum use of assistance under this part in education and student development;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d29ff9e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate and carry out joint projects and activities to promote work service learning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d29ff9f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out a comprehensive, longitudinal study of student academic progress and academic and career outcomes, relative to student self-sufficiency in financing their higher education, repayment of student loans, continued community service, kind and quality of service performed, and career choice and community service selected after graduation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d29ffa0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible institution may submit an application for funds authorized by subsection (f) of this section to use funds under subsection (b)(1) of this section at such time and in such manner as the Secretary, by regulation, may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d29ffa1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Match required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available to work-colleges pursuant to this section shall be matched on a dollar-for-dollar basis from non-Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d29ffa2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d2c6fa3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “work college” means an eligible institution that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d2c6fa4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been a public or private nonprofit, four-year, degree-granting institution with a commitment to community service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d2c6fa5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has operated a comprehensive work-learning-service program for at least two years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d2c6fa6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires students, including at least one-half of all students who are enrolled on a full-time basis, to participate in a comprehensive work-learning-service program for at least five hours each week, or at least 80 hours during each period of enrollment, except summer school, unless the student is engaged in an institutionally organized or approved study abroad or externship program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d2c6fa7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides students participating in the comprehensive work-learning-service program with the opportunity to contribute to their education and to the welfare of the community as a whole; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d2c6fa8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “comprehensive student work-learning-service program” means a student work-learning-service program that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d2c6fa9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an integral and stated part of the institution’s educational philosophy and program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d2c6faa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires participation of all resident students for enrollment and graduation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d2c6fab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes learning objectives, evaluation, and a record of work performance as part of the student’s college record;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d2c6fac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides programmatic leadership by college personnel at levels comparable to traditional academic programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d2c6fad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognizes the educational role of work-learning-service supervisors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d2c6fae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes consequences for nonperformance or failure in the work-learning-service program similar to the consequences for failure in the regular academic program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d2c6faf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–58/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d2c6fb0-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s448"},"text":"Pub. L. 89–329, title IV, § 448","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s447"},"text":"Pub. L. 102–325, title IV, § 447","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/567"},"text":"106 Stat. 567","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s445"},"text":"Pub. L. 105–244, title IV, § 445","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1714"},"text":"112 Stat. 1714","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s447"},"text":"Pub. L. 110–315, title IV, § 447","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3260"},"text":"122 Stat. 3260","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d2c6fb1-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d2c6fb2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d2c6fb3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2756b"},"text":"section 2756b of Title 42","children":[],"tail":", The Public Health and Welfare, prior to transfer to this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d2c6fb4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s448"},"text":"section 448 of Pub. L. 89–329","children":[],"tail":", title IV, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tIV/s437"},"text":"Pub. L. 96–374, title IV, § 437","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1436"},"text":"94 Stat. 1436","children":[],"tail":", which related to work study programs for community service-learning, was omitted in the general revision of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s403/a"},"text":"Pub. L. 99–498, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1429"},"text":"100 Stat. 1429","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087–57"},"text":"section 1087–57 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d2c6fb5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsecs. (a), (b)(2)(A), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s447/1"},"text":"Pub. L. 110–315, § 447(1)","children":[],"tail":", substituted “work-learning-service” for “work-learning” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s447/2"},"text":"Pub. L. 110–315, § 447(2)","children":[],"tail":", added subsec. (e) and struck out former subsec. (e) which defined “work-college” and “comprehensive student work-learning program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s447/3"},"text":"Pub. L. 110–315, § 447(3)","children":[],"tail":", substituted “such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years” for “$5,000,000 for fiscal year 1999 and such sums as may be necessary for each of the 4 succeeding fiscal years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(2)(E), (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s445/1"},"text":"Pub. L. 105–244, § 445(1)","children":[],"tail":", added subpars. (E) and (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s445/2"},"text":"Pub. L. 105–244, § 445(2)","children":[],"tail":", substituted “1999” for “1993”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d2c6fb6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d2c6fb7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d2c6fb8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/s2"},"text":"section 2 of Pub. L. 102–325","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
