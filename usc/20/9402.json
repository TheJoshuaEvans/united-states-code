{"tag":"section","attrib":{"id":"id0e600db6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9402"},"text":null,"children":[{"tag":"num","attrib":{"value":"9402"},"text":"§ 9402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e600db7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9402/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Caregiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “caregiver” means an individual, including a relative, neighbor, or family friend, who regularly or frequently provides care, with or without compensation, for a child for whom the individual is not the parent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600db8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9402/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child care provider","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “child care provider” means a provider of non-residential child care services (including center-based, family-based, and in-home child care services) for compensation who or that is legally operating under State law, and complies with applicable State and local requirements for the provision of child care services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600db9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9402/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early learning","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “early learning”, used with respect to a program or activity, means learning designed to facilitate the development of cognitive, language, motor, and social-emotional skills for, and to promote learning readiness in, young children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600dba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9402/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early learning program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “early learning program” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e600dbb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9402/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a program of services or activities that helps parents, caregivers, and child care providers incorporate early learning into the daily lives of young children; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600dbc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9402/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a program that directly provides early learning to young children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600dbd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9402/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600dbe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9402/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Local Council” means a Local Council established or designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9413/a"},"text":"section 9413(a) of this title","children":[],"tail":" that serves one or more localities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600dbf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9402/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Locality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “locality” means a city, county, borough, township, or area served by another general purpose unit of local government, an Indian tribe, a Regional Corporation, or a Native Hawaiian entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600dc0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9402/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “parent” means a biological parent, an adoptive parent, a stepparent, a foster parent, or a legal guardian of, or a person standing in loco parentis to, a child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600dc1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9402/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Poverty line","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “poverty line” means the poverty line (as defined by the Office of Management and Budget, and revised annually in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9902/2"},"text":"section 9902(2) of title 42","children":[],"tail":") applicable to a family of the size involved."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600dc2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9402/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Regional Corporation” means an entity listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s619/4/B"},"text":"section 619(4)(B) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600dc3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9402/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600dc4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9402/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States of the United States, the District of Columbia, and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600dc5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9402/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “training” means instruction in early learning that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e600dc6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9402/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required for certification under State and local laws, regulations, and policies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600dc7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9402/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required to receive a nationally or State recognized credential or its equivalent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600dc8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9402/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is received in a postsecondary education program focused on early learning or early childhood development in which the individual is enrolled; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600dc9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9402/13/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is provided, certified, or sponsored by an organization that is recognized for its expertise in promoting early learning or early childhood development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600dca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9402/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Young child","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “young child” means any child from birth to the age of mandatory school attendance in the State where the child resides.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e600dcb-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/1/tVIII/s803"},"text":"Pub. L. 106–554, § 1(a)(1) [title VIII, § 803]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–81.)"}],"tail":"\n"}],"tail":null}
