{"tag":"section","attrib":{"id":"id0e6258ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9546"},"text":null,"children":[{"tag":"num","attrib":{"value":"9546"},"text":"§ 9546.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e6258ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9546/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General requests","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e6258ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9546/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Statistics Center may furnish transcripts or copies of tables and other statistical records and make special statistical compilations and surveys for State and local officials, public and private organizations, and individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6258f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9546/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compilations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Statistics Center shall provide State educational agencies, local educational agencies, and institutions of higher education with opportunities to suggest the establishment of particular compilations of statistics, surveys, and analyses that will assist those educational agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6258f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9546/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional requests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Statistics Center shall furnish such special statistical compilations and surveys as the relevant congressional committees may request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e64c7f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9546/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint statistical projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Statistics Center may engage in joint statistical projects related to the mission of the Center, or other statistical purposes authorized by law, with nonprofit organizations or agencies, and the cost of such projects shall be shared equitably as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e64c7f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9546/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e64c7f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9546/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Statistical compilations and surveys under this section, other than those carried out pursuant to subsections (b) and (c), may be made subject to the payment of the actual or estimated cost of such work.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c7f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9546/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds received","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All funds received in payment for work or services described in this subsection may be used to pay directly the costs of such work or services, to repay appropriations that initially bore all or part of such costs, or to refund excess sums when necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e64c7f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9546/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e64c7f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9546/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Statistics Center shall, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9573"},"text":"section 9573 of this title","children":[],"tail":", cooperate with other Federal agencies having a need for educational data in providing access to educational data received by the Statistics Center."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c7f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9546/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interested parties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Statistics Center shall, in accordance with such terms and conditions as the Center may prescribe, provide all interested parties, including public and private agencies, parents, and other individuals, direct access, in the most appropriate form (including, where possible, electronically), to data collected by the Statistics Center for the purposes of research and acquiring statistical information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e64c7f9-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s156"},"text":"Pub. L. 107–279, title I, § 156","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1961"},"text":"116 Stat. 1961","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
