{"tag":"section","attrib":{"id":"id0d681913-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1099c–1"},"text":"§ 1099c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program review and data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d681914-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to strengthen the administrative capability and financial responsibility provisions of this subchapter, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d681915-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide for the conduct of program reviews on a systematic basis designed to include all institutions of higher education participating in programs authorized by this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d681916-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall give priority for program review to institutions of higher education that are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d681917-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions with a cohort default rate for loans under part B of this subchapter in excess of 25 percent or which places such institutions in the highest 25 percent of such institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d681918-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions with a default rate in dollar volume for loans under part B of this subchapter which places the institutions in the highest 25 percent of such institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d681919-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions with a significant fluctuation in Federal Stafford Loan volume, Federal Direct Stafford/Ford Loan volume, or Federal Pell Grant award volume, or any combination thereof, in the year for which the determination is made, compared to the year prior to such year, that are not accounted for by changes in the Federal Stafford Loan program, the Federal Direct Stafford/Ford Loan program, or the Pell Grant program, or any combination thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d68191a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions reported to have deficiencies or financial aid problems by the State licensing or authorizing agency, or by the appropriate accrediting agency or association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d68191b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions with high annual dropout rates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d68191c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other institutions that the Secretary determines may pose a significant risk of failure to comply with the administrative capability or financial responsibility provisions of this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d68191d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall establish and operate a central data base of information on institutional accreditation, eligibility, and certification that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d68191e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all relevant information available to the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d68191f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all relevant information made available by the Secretary of Veterans Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d681920-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all relevant information from accrediting agencies or associations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d681921-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all relevant information available from a guaranty agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d681922-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all relevant information available from States under subpart 1 of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d681923-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special administrative rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraphs (1) and (2) of subsection (a) and any other relevant provisions of this subchapter, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d681924-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish guidelines designed to ensure uniformity of practice in the conduct of program reviews of institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d681925-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available to each institution participating in programs authorized under this subchapter complete copies of all review guidelines and procedures used in program reviews;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d681926-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit the institution to correct or cure an administrative, accounting, or recordkeeping error if the error is not part of a pattern of error and there is no evidence of fraud or misconduct related to the error;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d681927-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" base any civil penalty assessed against an institution of higher education resulting from a program review or audit on the gravity of the violation, failure, or misrepresentation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d681928-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform the appropriate State and accrediting agency or association whenever the Secretary takes action against an institution of higher education under this section, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1099c"},"text":"section 1099c of this title","children":[],"tail":", or "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1082"},"text":"section 1082 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d681929-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to an institution of higher education an adequate opportunity to review and respond to any program review report and relevant materials related to the report before any final program review report is issued;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d68192a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" review and take into consideration an institution of higher education’s response in any final program review report or audit determination, and include in the report or determination—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d68192b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written statement addressing the institution of higher education’s response;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d68192c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written statement of the basis for such report or determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d68192d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the institution’s response; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d68192e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain and preserve at all times the confidentiality of any program review report until the requirements of paragraphs (6) and (7) are met, and until a final program review is issued, other than to the extent required to comply with paragraph (5), except that the Secretary shall promptly disclose any and all program review reports to the institution of higher education under review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d68192f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and carry out a plan for the data collection responsibilities described in paragraph (3) of subsection (a). The Secretary shall make the information obtained under such paragraph (3) readily available to all institutions of higher education, guaranty agencies, States, and other organizations participating in the programs authorized by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d681930-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide training to personnel of the Department, including criminal investigative training, designed to improve the quality of financial and compliance audits and program reviews conducted under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d681931-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3403/b"},"text":"section 3403(b) of this title","children":[],"tail":" shall not apply to Secretarial determinations made regarding the appropriate length of instruction for programs measured in clock hours."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d681932-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s498A"},"text":"Pub. L. 89–329, title IV, § 498A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s499"},"text":"Pub. L. 102–325, title IV, § 499","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/652"},"text":"106 Stat. 652","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/i/15"},"text":"Pub. L. 103–208, § 2(i)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2480"},"text":"107 Stat. 2480","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s494"},"text":"Pub. L. 105–244, title IV, § 494","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1763"},"text":"112 Stat. 1763","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s497"},"text":"Pub. L. 110–315, title IV, § 497","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3328"},"text":"122 Stat. 3328","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d681933-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d681934-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d681935-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(6) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" added pars. (6) to (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s494/1/A/i"},"text":"Pub. L. 105–244, § 494(1)(A)(i)","children":[],"tail":", substituted “shall” for “may” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s494/1/A/ii"},"text":"Pub. L. 105–244, § 494(1)(A)(ii)","children":[],"tail":", amended subpar. (C) generally. Prior to amendment, subpar. (C) read as follows: “institutions with a significant fluctuation in Federal Stafford Loan volume or Federal Pell Grant awards, or both, in the year for which the determination is made compared to the year prior to such year;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s494/1/A/iii"},"text":"Pub. L. 105–244, § 494(1)(A)(iii)","children":[],"tail":", amended subpar. (D) generally. Prior to amendment, subpar. (D) read as follows: “institutions reported to have deficiencies or financial aid problems by the appropriate State postsecondary review entity designated under subpart 1 of this part or by the appropriate accrediting agency or association;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s494/1/A/iv"},"text":"Pub. L. 105–244, § 494(1)(A)(iv)","children":[],"tail":", inserted “and” after the semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(F), (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s494/1/A/v"},"text":"Pub. L. 105–244, § 494(1)(A)(v)","children":[],"tail":", added subpar. (F) and struck out former subpars. (F) and (G) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(F) any institution which is required to be reviewed by a State postsecondary review entity pursuant to subpart 1 of this part under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1099a–3/b"},"text":"section 1099a–3(b) of this title","children":[],"tail":"; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(G) such other institutions as the Secretary deems necessary; and”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s494/1/B"},"text":"Pub. L. 105–244, § 494(1)(B)","children":[],"tail":", inserted “relevant” after “all”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s494/2"},"text":"Pub. L. 105–244, § 494(2)","children":[],"tail":", amended heading and text of subsec. (b). Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) In carrying out paragraphs (1) and (2) of subsection (a) of this section, the Secretary shall establish guidelines designed to ensure uniformity of practice in the conduct of program reviews of institutions of higher education.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The Secretary shall review the regulations of the Department and the application of such regulations to ensure the uniformity of interpretation and application of the regulations.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208"},"text":"Pub. L. 103–208","children":[],"tail":" struck out comma after “title”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d681936-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d681937-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d681938-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208"},"text":"Pub. L. 103–208","children":[],"tail":" effective as if included in the Higher Education Amendments of 1992, "},{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s5/a"},"text":"section 5(a) of Pub. L. 103–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1051"},"text":"section 1051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
