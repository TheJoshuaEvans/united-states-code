{"tag":"section","attrib":{"id":"id0d823154-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161d"},"text":"§ 1161d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capacity for nursing students and faculty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d823155-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amounts appropriated under subsection (f), the Secretary shall award grants to institutions of higher education that offer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d823156-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an accredited registered nursing program at the baccalaureate or associate degree level to enable such program to expand the faculty and facilities of such program to accommodate additional students in such program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d823157-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an accredited graduate-level nursing program to accommodate advanced practice degrees for registered nurses or to accommodate students enrolled in such program to become teachers of nursing students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d823158-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of number of students and application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each institution of higher education that offers a program described in subsection (a) that desires to receive a grant under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d823159-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine, for the four academic years preceding the academic year for which the determination is made, the average number of matriculated nursing program students, in each of the institution’s accredited associate, baccalaureate, or advanced nursing degree programs at such institution for such academic years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d82315a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit an application to the Secretary at such time, in such manner, and accompanied by such information as the Secretary may require, including the average number in each of the institution’s accredited nursing programs determined under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d82315b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to the partnerships described in subsection (c)(2)(B), provide assurances that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d82315c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the individuals enrolled in the program will—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d82315d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be registered nurses in pursuit of a master’s or doctoral degree in nursing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d82315e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a contractual obligation with the hospital or health facility that is in partnership with the institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d82315f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the hospital or health facility of employment will be the clinical site for the accredited school of nursing program, if the program requires a clinical site;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d823160-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" individuals enrolled in the program will—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d823161-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain their employment on at least a part-time basis with the hospital or health facility that allowed them to participate in the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d823162-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive an income from the hospital or health facility, as at least a part-time employee, and release times or flexible schedules, to accommodate their program requirements, as necessary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d823163-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon completion of the program, recipients of scholarships described in subsection (c)(2)(B)(ii)(III) will be required to teach for two years in an accredited school of nursing for each year of support the individual received under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d823164-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant amount; award basis","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d823165-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each academic year after academic year 2009–2010, the Secretary is authorized to provide to each institution of higher education awarded a grant under this section an amount that is equal to $3,000 multiplied by the number by which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d823166-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of matriculated nursing program students at such institution for such academic year, exceeds","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d823167-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average number determined with respect to such institution under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d823168-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of grants among different degree programs","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d823169-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (D), from the funds available to award grants under this section for each fiscal year, the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d82316a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use 20 percent of such funds to award grants under this section to institutions of higher education for the purpose of accommodating advanced practice degrees or students in accredited graduate-level nursing programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d82316b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use 40 percent of such funds to award grants under this section to institutions of higher education for the purpose of expanding accredited registered nurse programs at the baccalaureate degree level; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d82316c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use 40 percent of such funds to award grants under this section to institutions of higher education for the purpose of expanding accredited registered nurse programs at the associate degree level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d82316d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Optional uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under this section may be used to support partnerships with hospitals or health facilities to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d82316e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" improve the alignment between nursing education and the emerging challenges of health care delivery by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d82316f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase of distance learning technologies and expanding methods of delivery of instruction to include alternatives to onsite learning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d823170-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collection, analysis, and dissemination of data on educational outcomes and best practices identified through the activities described in this section; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d823171-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that students can earn a salary while obtaining an advanced degree in nursing with the goal of becoming nurse faculty by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d823172-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding release time for qualified nurses enrolled in the graduate nursing program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d823173-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for faculty salaries; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d823174-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing scholarships to qualified nurses in pursuit of an advanced degree with the goal of becoming faculty members in an accredited nursing program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d823175-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations in making awards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this section, the Secretary shall consider the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d823176-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Providing an equitable geographic distribution of such grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d823177-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Urban and rural areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Distributing such grants to urban and rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d823178-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Range and type of institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Ensuring that the activities to be assisted are developed for a range of types and sizes of institutions of higher education, including institutions providing alternative methods of delivery of instruction in addition to on-site learning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d823179-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of excess funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, for a fiscal year, funds described in clause (i), (ii), or (iii) of subparagraph (A) remain available after the Secretary awards grants under this section to all applicants for the particular category of accredited nursing programs described in such clause, the Secretary shall use equal amounts of the remaining funds to award grants under this section to applicants that applied under the other categories of nursing programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d82317a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount appropriated to carry out this section, the Secretary may award not more than ten percent of such amount for the optional purposes under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d82317b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d82317c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “health facility” means an Indian health service center, a Native Hawaiian health center, a hospital, a federally qualified health center, a rural health clinic, a nursing home, a home health agency, a hospice program, a public health clinic, a State or local department of public health, a skilled nursing facility, or an ambulatory surgical center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d82317d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public Health Service Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “accredited” and “school of nursing” have the meanings given those terms in section 801 of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s296"},"text":"42 U.S.C. 296","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d82317e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d82317f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided under this section may not be used for the construction of new facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d823180-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraph (1) shall be construed to prohibit funds provided under this section from being used for the repair or renovation of facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d823181-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d823182-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s804"},"text":"Pub. L. 89–329, title VIII, § 804","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3385"},"text":"122 Stat. 3385","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tVIII/s801/2"},"text":"Pub. L. 111–39, title VIII, § 801(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1955"},"text":"123 Stat. 1955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d823183-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d823184-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d823185-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subs