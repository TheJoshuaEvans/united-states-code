{"tag":"section","attrib":{"id":"id0d6f1e40-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126"},"text":null,"children":[{"tag":"num","attrib":{"value":"1126"},"text":"§ 1126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technological innovation and cooperation for foreign information access","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d6f1e41-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6f1e42-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make grants to institutions of higher education, public or nonprofit private libraries, or partnerships between such institutions and other such institutions, libraries, or nonprofit educational organizations, to develop innovative techniques or programs using electronic technologies to collect, organize, preserve, and widely disseminate information from foreign sources on world regions and countries other than the United States that address our Nation’s teaching and research needs in international education and foreign languages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e43-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant recipients","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may award grants under this section to carry out the activities authorized under this section to the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d6f1e44-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1e45-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A public or nonprofit private library.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1e46-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A partnership of an institution of higher education and one or more of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d6f1e47-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Another institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d6f1e48-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A library.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d6f1e49-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/a/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nonprofit educational organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6f1e4a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants under this section may be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6f1e4b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire, facilitate access to, or preserve foreign information resources in print or electronic forms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e4c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop new means of immediate, full-text document delivery for information and scholarship from abroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e4d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop new means of or standards for shared electronic access to international data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e4e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support collaborative projects of indexing, cataloging, and other means of bibliographic access for scholars to important research materials published or distributed outside the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e4f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop methods for the wide dissemination of resources written in non-Roman language alphabets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e50-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist teachers of less commonly taught languages in acquiring, via electronic and other means, materials suitable for classroom use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e51-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote collaborative technology based projects in foreign languages, area studies, and international studies among grant recipients under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e52-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to establish linkages to facilitate carrying out the activities described in this subsection between—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d6f1e53-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institutions of higher education, libraries, and partnerships receiving grants under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6f1e54-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education, nonprofit educational organizations, and libraries overseas; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e55-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out other activities that the Secretary determines are consistent with the purpose of the grants awarded under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6f1e56-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each institution of higher education, library, or partnership desiring a grant under this section shall submit an application to the Secretary at such time, in such manner, and accompanied by such information and assurances as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6f1e57-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1126/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Match required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the total cost of carrying out a program supported by a grant under this section shall not be more than 66⅔ percent. The non-Federal share of such cost may be provided either in-kind or in cash, and may include contributions from private sector corporations or foundations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6f1e58-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s606"},"text":"Pub. L. 89–329, title VI, § 606","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVI/s601"},"text":"Pub. L. 105–244, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1781"},"text":"112 Stat. 1781","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVI/s606"},"text":"Pub. L. 110–315, title VI, § 606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3337"},"text":"122 Stat. 3337","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d6f1e59-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d6f1e5a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d6f1e5b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1126, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s609"},"text":"Pub. L. 89–329, title VI, § 609","children":[],"tail":", formerly § 606, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tVI/s601/a"},"text":"Pub. L. 96–374, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1467"},"text":"94 Stat. 1467","children":[],"tail":"; renumbered § 609, "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tVI/s605/1"},"text":"Pub. L. 99–498, title VI, § 605(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1517"},"text":"100 Stat. 1517","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tVI/s601"},"text":"Pub. L. 102–325, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/727"},"text":"106 Stat. 727","children":[],"tail":", related to equitable distribution of grants, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1126, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s606"},"text":"Pub. L. 89–329, title VI, § 606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1265"},"text":"79 Stat. 1265","children":[],"tail":", related to reservation and payment of equipment grants to institutions of higher education, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/96/374"},"text":"Pub. L. 96–374","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s606"},"text":"section 606 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1125"},"text":"section 1125 of this title","children":[],"tail":", prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d6f1e5c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s606/1/D"},"text":"Pub. L. 110–315, § 606(1)(D)","children":[],"tail":", (E), designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s606/1/A"},"text":"Pub. L. 110–315, § 606(1)(A)","children":[],"tail":"–(C), substituted “or partnerships between such institutions and other such institutions, libraries, or nonprofit educational organizations” for “or consortia of such institutions or libraries” and “electronic technologies” for “new electronic technologies” and inserted “from foreign sources” after “disseminate information”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s606/2/A"},"text":"Pub. L. 110–315, § 606(2)(A)","children":[],"tail":", substituted “to acquire, facilitate access to,” for “to facilitate access to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s606/2/B"},"text":"Pub. L. 110–315, § 606(2)(B)","children":[],"tail":", inserted “or standards for” after “develop new means of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8), (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s606/2/C"},"text":"Pub. L. 110–315, § 606(2)(C)","children":[],"tail":"–(E), added pars. (8) and (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s606/3"},"text":"Pub. L. 110–315, § 606(3)","children":[],"tail":", substituted “institution of higher education, library, or partnership” for “institution or consortium”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
