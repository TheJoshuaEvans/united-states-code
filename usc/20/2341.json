{"tag":"section","attrib":{"id":"id0dc04c3f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2341"},"text":null,"children":[{"tag":"num","attrib":{"value":"2341"},"text":"§ 2341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dc04c40-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2341/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible agency responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The responsibilities of an eligible agency under this subchapter shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc04c41-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2341/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination of the development, submission, and implementation of the State plan, and the evaluation of the program, services, and activities assisted under this subchapter, including preparation for non-traditional fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc04c42-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2341/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consultation with the Governor and appropriate agencies, groups, and individuals including teachers, faculty, specialized instructional support personnel, paraprofessionals, school leaders, authorized public chartering agencies and charter school leaders (consistent with State law), employers, representatives of business (including small businesses), labor organizations, eligible recipients, local program administrators, State and local officials, Indian Tribes or Tribal organizations present in the State, parents, students, and community organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc04c43-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2341/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convening and meeting as an eligible agency (consistent with State law and procedure for the conduct of such meetings) at such time as the eligible agency determines necessary to carry out the eligible agency’s responsibilities under this subchapter, but not less than 4 times annually; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc04c44-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2341/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the adoption of such procedures as the eligible agency considers necessary to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dc04c45-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2341/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement State level coordination with the activities undertaken by the State boards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3111"},"text":"section 3111 of title 29","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc04c46-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2341/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available to the one-stop delivery system under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3151"},"text":"section 3151 of title 29","children":[],"tail":" within the State a listing of all school dropout, postsecondary education, and adult programs assisted under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc04c47-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2341/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except with respect to the responsibilities set forth in subsection (a), the eligible agency may delegate any of the other responsibilities of the eligible agency that involve the administration, operation, or supervision of activities assisted under this subchapter, in whole or in part, to 1 or more appropriate State agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dc04c48-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tI/s121"},"text":"Pub. L. 88–210, title I, § 121","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/b"},"text":"Pub. L. 109–270, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/715"},"text":"120 Stat. 715","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tV/s512/e/2"},"text":"Pub. L. 113–128, title V, § 512(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1706"},"text":"128 Stat. 1706","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/224/tI/s121"},"text":"Pub. L. 115–224, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-07-31"},"te