{"tag":"section","attrib":{"id":"id0d8e3f04-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1221j"},"text":null,"children":[{"tag":"num","attrib":{"value":"1221j"},"text":"§ 1221j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Television program assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d8e3f05-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1221j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Granting and contracting authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Education is authorized to make grants to and contracts with public and private agencies for the production, development, or distribution (or any combination thereof) of programs designed for television systems, whether broadcast or nonbroadcast.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8e3f06-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1221j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration and studies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Education shall be responsible for the administration of this section and shall also conduct surveys, research, and evaluation studies which may assist in decisions to support pilot programs for full scale production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d8e3f07-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXV/s1527"},"text":"Pub. L. 95–561, title XV, § 1527","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2379"},"text":"92 Stat. 2379","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIII/s301"},"text":"Pub. L. 96–88, title III, § 301","children":[],"tail":", title V, § 507, "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/677"},"text":"93 Stat. 677","children":[],"tail":", 692.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d8e3f08-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d8e3f09-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d8e3f0a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of Education Amendments of 1978, and not as part of General Education Provisions Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d8e3f0b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d8e3f0c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1978-10-01"},"text":"Oct. 1, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/561/s1530"},"text":"section 1530 of Pub. L. 95–561","children":[],"tail":", set out as an Effective Date of 1974 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1221e–3"},"text":"section 1221e–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id0d8e3f0d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Education” substituted for “Secretary” in subsec. (a) and “Assistant Secretary for Education” in subsec. (b), pursuant to sections 301 and 507 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88"},"text":"Pub. L. 96–88","children":[],"tail":", which are classified to sections 3441 and 3507 of this title and which transferred functions (relating to education) of Secretary of Health, Education, and Welfare, and functions of Assistant Secretary for Education, to Secretary of Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
