{"tag":"section","attrib":{"id":"id0dd8195b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423c"},"text":null,"children":[{"tag":"num","attrib":{"value":"3423c"},"text":"§ 3423c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Indian Education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dd8195c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Indian Education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be an Office of Indian Education (referred to in this section as “the Office”) in the Department of Education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dd8195d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dd8195e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall be under the direction of the Director, who shall be appointed by the Secretary and who shall report directly to the Assistant Secretary for Elementary and Secondary Education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd8195f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dd81960-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for administering part A of title VI of the Elementary and Secondary Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7401"},"text":"20 U.S.C. 7401","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dd81961-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be involved in, and be primarily responsible for, the development of all policies affecting Indian children and adults under programs administered by the Office of Elementary and Secondary Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dd81962-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423c/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the development of policy and practice for all programs in the Department relating to Indian persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dd81963-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423c/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Assistant Secretary of the Office of Educational Research and Improvement in identifying research priorities related to the education of Indian persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dd81964-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian preference in employment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dd81965-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall give a preference to Indian persons in all personnel actions in the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd81966-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such preference shall be implemented in the same fashion as the preference given to any veteran under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s45"},"text":"section 45 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dd81967-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tII/s215"},"text":"Pub. L. 96–88, title II, § 215","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s372/2"},"text":"Pub. L. 103–382, title III, § 372(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3977"},"text":"108 Stat. 3977","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/v"},"text":"Pub. L. 114–95, title IX, § 9215(v)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2171"},"text":"129 Stat. 2171","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dd81968-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dd81969-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0dd8196a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Elementary and Secondary Education Act of 1965, referred to in subsec. (b)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-04-11"},"text":"Apr. 11, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/27"},"text":"79 Stat. 27","children":[],"tail":". Part A of title VI of the Act is classified generally to part A (§ 7401 et seq.) of subchapter VI of chapter 70 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0dd8196b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s215"},"text":"section 215 of Pub. L. 96–88","children":[],"tail":" was renumbered section 217 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3424"},"text":"section 3424 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2641"},"text":"section 2641 of Title 25","children":[],"tail":", Indians, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/s367"},"text":"Pub. L. 103–382, § 367","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0dd8196c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" substituted “be responsible for administering part A of title VI of the Elementary and Secondary Education Act of 1965” for “be responsible for administering this title”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0dd8196d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0dd8196e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0dd8196f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Office of Educational Research and Improvement","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Office of Educational Research and Improvement was established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3419"},"text":"section 3419 of this title","children":[],"tail":". Section 3419 was repealed and a new section 3419 establishing the Institute of Educational Sciences was enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/107/279/tIV/s402/2"},"text":"Pub. L. 107–279, title IV, § 402(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1985"},"text":"116 Stat. 1985","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
