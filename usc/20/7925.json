{"tag":"section","attrib":{"id":"id0e5426b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7925"},"text":null,"children":[{"tag":"num","attrib":{"value":"7925"},"text":"§ 7925.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress on protecting student privacy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e5426b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7925/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e5426b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7925/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Students’ personally identifiable information is important to protect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5426b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7925/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Students’ information should not be shared with individuals other than school officials in charge of educating those students without clear notice to parents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5426b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7925/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With the use of more technology, and more research about student learning, the responsibility to protect students’ personally identifiable information is more important than ever.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5426b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7925/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Regulations allowing more access to students’ personal information could allow that information to be shared or sold by individuals who do not have the best interest of the students in mind.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5426b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7925/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary has the responsibility to ensure every entity that receives funding under this chapter holds any personally identifiable information in strict confidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e5426b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7925/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that the Secretary should review all regulations addressing issues of student privacy, including those under this chapter, and ensure that students’ personally identifiable information is protected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e5426b8-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8545"},"text":"Pub. L. 89–10, title VIII, § 8545","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII/s8037"},"text":"Pub. L. 114–95, title VIII, § 8037","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2119"},"text":"129 Stat. 2119","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e5426b9-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e5426ba-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e5426bb-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
