{"tag":"section","attrib":{"id":"id0e26d646-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173"},"text":null,"children":[{"tag":"num","attrib":{"value":"7173"},"text":"§ 7173.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e26d647-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to receive an allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7172"},"text":"section 7172 of this title","children":[],"tail":" for any fiscal year, a State shall submit to the Secretary, at such time as the Secretary may require, an application that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e26d648-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designates the State educational agency as the agency responsible for the administration and supervision of programs assisted under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d649-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes how the State educational agency will use funds received under this part, including funds reserved for State-level activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d64a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contains an assurance that the State educational agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e26d64b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" will make awards under this part to eligible entities that serve—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e26d64c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" students who primarily attend—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e26d64d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" schools implementing comprehensive support and improvement activities or targeted support and improvement activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/d"},"text":"section 6311(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e26d64e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other schools determined by the local educational agency to be in need of intervention and support; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e26d64f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the families of such students; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d650-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will further give priority to eligible entities that propose in the application to serve students described in subclauses (I) and (II) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7174/i/1/A/i"},"text":"section 7174(i)(1)(A)(i) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d651-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the procedures and criteria the State educational agency will use for reviewing applications and awarding funds to eligible entities on a competitive basis, which shall include procedures and criteria that take into consideration the likelihood that a proposed community learning center will help participating students meet the challenging State academic standards and any local academic standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d652-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describes how the State educational agency will ensure that awards made under this part are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e26d653-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of sufficient size and scope to support high-quality, effective programs that are consistent with the purpose of this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d654-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in amounts that are consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7174/h"},"text":"section 7174(h) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d655-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the steps the State educational agency will take to ensure that programs implement effective strategies, including providing ongoing technical assistance and training, evaluation, dissemination of promising practices, and coordination of professional development for staff in specific content areas and youth development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d656-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes how programs under this part will be coordinated with programs under this chapter, and other programs as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d657-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contains an assurance that the State educational agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e26d658-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will make awards for programs for a period of not less than 3 years and not more than 5 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d659-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will require each eligible entity seeking such an award to submit a plan describing how the activities to be funded through the award will continue after funding under this part ends;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d65a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains an assurance that funds appropriated to carry out this part will be used to supplement, and not supplant, other Federal, State, and local public funds expended to provide programs and activities authorized under this part and other similar programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d65b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains an assurance that the State educational agency will require eligible entities to describe in their applications under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7174/b"},"text":"section 7174(b) of this title","children":[],"tail":" how the transportation needs of participating students will be addressed;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d65c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describes how the State will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e26d65d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescreen external organizations that could provide assistance in carrying out the activities under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d65e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and make available to eligible entities a list of external organizations that successfully completed the prescreening process;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d65f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e26d660-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the application was developed in consultation and coordination with appropriate State officials, including the chief State school officer, and other State agencies administering before and after school (or summer recess) programs and activities, the heads of the State health and mental health agencies or their designees, statewide after-school networks (where applicable) and representatives of teachers, local educational agencies, and community-based organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d661-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any other representatives of teachers, parents, students, or the business community that the State has selected to assist in the development of the application, if applicable;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d662-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the results of the State’s needs and resources assessment for before and after school (or summer recess) programs and activities, which shall be based on the results of on-going State evaluation activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d663-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describes how the State educational agency will evaluate the effectiveness of programs and activities carried out under this part, which shall include, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e26d664-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the performance indicators and performance measures that will be used to evaluate programs and activities with emphasis on alignment with the regular academic program of the school and the academic needs of participating students, including performance indicators and measures that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e26d665-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/14/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are able to track student success and improvement over time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e26d666-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/14/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include State assessment results and other indicators of student success and improvement, such as improved attendance during the school day, better classroom grades, regular (or consistent) program attendance, and on-time advancement to the next grade level; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e26d667-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/14/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for high school students, may include indicators such as career competencies, successful completion of internships or apprenticeships, or work-based learning opportunities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d668-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how data collected for the purposes of subparagraph (A) will be collected; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d669-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/14/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public dissemination of the evaluations of programs and activities carried out under this part; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d66a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for timely public notice of intent to file an application and an assurance that the application will be available for public review after submission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e26d66b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deemed approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application submitted by a State educational agency pursuant to subsection (a) shall be deemed to be approved by the Secretary unless the Secretary makes a written determination, prior to the expiration of the 120-day period beginning on the date on which the Secretary received the application, that the application is not in compliance with this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e26d66c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not finally disapprove the application, except after giving the State educational agency notice and an opportunity for a hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e26d66d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary finds that the application is not in compliance, in whole or in part, with this part, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e26d66e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give the State educational agency notice and an opportunity for a hearing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d66f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" notify the State educational agency of the finding of noncompliance and, in such notification—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e26d670-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cite the specific provisions in the application that are not in compliance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d671-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request additional information, only as to the noncompliant provisions, needed to make the application compliant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e26d672-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Response","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the State educational agency responds to the Secretary’s notification described in subsection (d)(2) during the 45-day period beginning on the date on which the agency received the notification, and resubmits the application with the requested information described in subsection (d)(2)(B), the Secretary shall approve or disapprove such application prior to the later of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e26d673-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expiration of the 45-day period beginning on the date on which the application is resubmitted; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d674-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expiration of the 120-day period described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e26d675-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to respond","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the State educational agency does not respond to the Secretary’s notification described in subsection (d)(2) during the 45-day period beginning on the date on which the agency received the notification, such application shall be deemed to be disapproved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e26d676-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7173/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not give a priority or a preference for States or eligible entities that seek to use funds made available under this part to extend the regular school day.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e26d677-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4203"},"text":"Pub. L. 89–10, title IV, § 4203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIV/s401"},"text":"Pub. L. 107–110, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1767"},"text":"115 Stat. 1767","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4201/a"},"text":"Pub. L. 114–95, title IV, § 4201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1986"},"text":"129 Stat. 1986","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e26d678-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e26d679-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e26d67a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" amended section generally. Prior to amendment, section related to State application, consisting of subsecs. (a) to (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e26d67b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e26d67c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"r