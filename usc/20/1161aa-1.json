{"tag":"section","attrib":{"id":"id0d8bce15-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161aa–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161aa–1"},"text":"§ 1161aa–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postbaccalaureate programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to any amounts appropriated under part B of subchapter V, there are authorized to be appropriated, and there are appropriated, out of any funds in the Treasury not otherwise appropriated, $11,500,000 for fiscal year 2009 and for each of the five succeeding fiscal years to carry out part B of subchapter V.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d8bce16-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s898"},"text":"Pub. L. 89–329, title VIII, § 898","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3446"},"text":"122 Stat. 3446","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
