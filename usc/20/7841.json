{"tag":"section","attrib":{"id":"id0e4cfb71-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7841"},"text":null,"children":[{"tag":"num","attrib":{"value":"7841"},"text":"§ 7841.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this part are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e4cfb72-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7841/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve teaching and learning by encouraging greater cross-program coordination, planning, and service delivery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4cfb73-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7841/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide greater flexibility to State and local authorities through consolidated plans, applications, and reporting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4cfb74-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7841/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance the integration of programs under this chapter with State and local programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e4cfb75-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8301"},"text":"Pub. L. 89–10, title VIII, § 8301","children":[],"tail":", formerly title IX, § 9301, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIX/s901"},"text":"Pub. L. 107–110, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1968"},"text":"115 Stat. 1968","children":[],"tail":"; renumbered title VIII, § 8301, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII/s8001/a/3"},"text":"Pub. L. 114–95, title VIII, § 8001(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2088"},"text":"129 Stat. 2088","children":[],"tail":", 2089.)"}],"tail":"\n"}],"tail":null}
