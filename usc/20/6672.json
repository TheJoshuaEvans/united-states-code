{"tag":"section","attrib":{"id":"id0e1d38c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672"},"text":null,"children":[{"tag":"num","attrib":{"value":"6672"},"text":"§ 6672.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supporting effective educator development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e1d38c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the funds reserved by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6671/1"},"text":"section 6671(1) of this title","children":[],"tail":" for a fiscal year, the Secretary shall award grants, on a competitive basis, to eligible entities for the purposes of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1d38c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing teachers, principals, or other school leaders from nontraditional preparation and certification routes or pathways to serve in traditionally underserved local educational agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing evidence-based professional development activities that address literacy, numeracy, remedial, or other needs of local educational agencies and the students the agencies serve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing teachers, principals, or other school leaders with professional development activities that enhance or enable the provision of postsecondary coursework through dual or concurrent enrollment programs and early college high school settings across a local educational agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making freely available services and learning opportunities to local educational agencies, through partnerships and cooperative agreements or by making the services or opportunities publicly accessible through electronic means; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing teachers, principals, or other school leaders with evidence-based professional enhancement activities, which may include activities that lead to an advanced credential.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1d38c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program periods and diversity of projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1d38ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded by the Secretary to an eligible entity under this section shall be for a period of not more than 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may renew a grant awarded under this section for 1 additional 2-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diversity of projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Secretary shall ensure that, to the extent practicable, grants are distributed among eligible entities that will serve geographically diverse areas, including urban, suburban, and rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not award more than 1 grant under this section to an eligible entity during a grant competition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1d38ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1d38cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity that receives a grant under this section shall provide, from non-Federal sources, not less than 25 percent of the funds for the total cost for each year of activities carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptable contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity that receives a grant under this section may meet the requirement of paragraph (1) by providing contributions in cash or in kind, fairly evaluated, including plant, equipment, and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive or modify the requirement of paragraph (1) in cases of demonstrated financial hardship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1d38d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to receive a grant under this section, an eligible entity shall submit an application to the Secretary at such time and in such manner as the Secretary may reasonably require. Such application shall include, at a minimum, a certification that the services provided by an eligible entity under the grant to a local educational agency or to a school served by the local educational agency will not result in direct fees for participating students or parents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1d38d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Secretary shall give priority to an eligible entity that will implement evidence-based activities, defined for the purpose of this subsection as activities meeting the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801/21/A/i"},"text":"section 7801(21)(A)(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1d38d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible entity” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1d38d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education that provides course materials or resources that are evidence-based in increasing academic achievement, graduation rates, or rates of postsecondary education matriculation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national nonprofit entity with a demonstrated record of raising student academic achievement, graduation rates, and rates of higher education attendance, matriculation, or completion, or of effectiveness in providing preparation and professional development activities and programs for teachers, principals, or other school leaders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Indian Education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a partnership consisting of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1d38d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more entities described in paragraph (1) or (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1d38da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6672/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a for-profit entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e1d38db-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2242"},"text":"Pub. L. 89–10, title II, § 2242","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tII/s2002"},"text":"Pub. L. 114–95, title II, § 2002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1948"},"text":"129 Stat. 1948","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e1d38dc-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e1d38dd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e1d38de-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6672, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2302"},"text":"Pub. L. 89–10, title II, § 2302","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tII/s201"},"text":"Pub. L. 107–110, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1648"},"text":"115 Stat. 1648","children":[],"tail":", authorized funding and administration of the Troops-to-Teachers Program, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tV/s541/d/1"},"text":"Pub. L. 112–239, div. A, title V, § 541(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1735"},"text":"126 Stat. 1735","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 6672, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2302"},"text":"Pub. L. 89–10, title II, § 2302","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3633"},"text":"108 Stat. 3633","children":[],"tail":", authorized professional development demonstration program, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e1d38df-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e1d38e0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
