7q/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000,000 for such fiscal year shall be available to eligible institutions described in subsection (a)(4) and shall be made available as grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059d"},"text":"section 1059d of this title","children":[],"tail":", treating such $15,000,000 as part of the amount appropriated for such fiscal year in a regular or supplemental appropriation Act to carry out such section and using such $15,000,000 for purposes described in subsection (c) of such section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cddb39d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for such fiscal year shall be available to eligible institutions described in subsection (a)(6) for activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1057/c"},"text":"section 1057(c) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cddb39e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" $5,000,000 for such fiscal year shall be available to eligible institutions described in subsection (a)(7)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0cddb39f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/D/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to plan, develop, undertake, and carry out activities to improve and expand such institutions’ capacity to serve Native Americans, which may include—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id0cddb3a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/D/iv/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase, rental, or lease of scientific or laboratory equipment for educational purposes, including instructional and research purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id0cddb3a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/D/iv/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" renovation and improvement in classroom, library, laboratory, and other instructional facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id0cddb3a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/D/iv/I/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support of faculty exchanges, faculty development, and faculty fellowships to assist faculty in attaining advanced degrees in the faculty’s field of instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id0cddb3a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/D/iv/I/dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"dd"},"text":"(dd)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" curriculum development and academic instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id0cddb3a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/D/iv/I/ee"},"text":null,"children":[{"tag":"num","attrib":{"value":"ee"},"text":"(ee)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase of library books, periodicals, microfilm, and other educational materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id0cddb3a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/D/iv/I/ff"},"text":null,"children":[{"tag":"num","attrib":{"value":"ff"},"text":"(ff)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds and administrative management, and acquisition of equipment for use in strengthening funds management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id0cddb3a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/D/iv/I/gg"},"text":null,"children":[{"tag":"num","attrib":{"value":"gg"},"text":"(gg)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the joint use of facilities such as laboratories and libraries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id0cddb3a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/D/iv/I/hh"},"text":null,"children":[{"tag":"num","attrib":{"value":"hh"},"text":"(hh)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic tutoring and counseling programs and student support services; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0cddb3a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/D/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which the Secretary, to the extent possible and consistent with a competitive process under which such grants are awarded, allocates funds under this clause to ensure maximum and equitable distribution among all such eligible institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cddb3a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cddb3aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asian American","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Asian American” has the meaning given the term “Asian” in the Office of Management and Budget’s Standards for Maintaining, Collecting, and Presenting Federal Data on Race and Ethnicity as published on ","children":[{"tag":"date","attrib":{"date":"1997-10-30"},"text":"October 30, 1997","children":[],"tail":" (62 Fed. Reg. 58789)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cddb3ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asian American and Native American Pacific Islander-serving institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Asian American and Native American Pacific Islander-serving institution” means an institution of higher education that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cddb3ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an eligible institution under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1058/b"},"text":"section 1058(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb3ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time of application, has an enrollment of undergraduate students that is at least 10 percent Asian American and Native American Pacific Islander students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cddb3ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment of needy students","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “enrollment of needy students” means the enrollment at an institution of higher education with respect to which not less than 50 percent of the undergraduate students enrolled in an academic program leading to a degree—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cddb3af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the second fiscal year preceding the fiscal year for which the determination is made, were Federal Pell Grant recipients for such year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb3b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" come from families that receive benefits under a means-tested Federal benefit program (as defined in paragraph (5));","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb3b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" attended a public or nonprofit private secondary school—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cddb3b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is in the school district of a local educational agency that was eligible for assistance under part A of title I of the Elementary and Secondary Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311"},"text":"20 U.S.C. 6311","children":[],"tail":" et seq.] for any year during which the student attended such secondary school; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cddb3b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which for the purpose of this paragraph and for that year was determined by the Secretary (pursuant to regulations and after consultation with the State educational agency of the State in which the school is located) to be a school in which the enrollment of children counted under a measure of poverty described in section 1113(a)(5) of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6313/a/5"},"text":"20 U.S.C. 6313(a)(5)","children":[],"tail":"] exceeds 30 percent of the total enrollment of such school; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb3b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are first-generation college students (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–11/h"},"text":"section 1070a–11(h) of this title","children":[],"tail":"), and a majority of such first-generation college students are low-income individuals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cddb3b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-income individual","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “low-income individual” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–11/h"},"text":"section 1070a–11(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cddb3b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Means-tested Federal benefit program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “means-tested Federal benefit program” means a program of the Federal Government, other than a program under subchapter IV, in which eligibility for the programs’ benefits or the amount of such benefits are determined on the basis of income or resources of the individual or family seeking the benefit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cddb3b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native American","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Native American” means an individual who is of a tribe, people, or culture that is indigenous to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cddb3b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native American Pacific Islander","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Native American Pacific Islander” means any descendant of the aboriginal people of any island in the Pacific Ocean that is a territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cddb3b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native American-serving nontribal institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Native American-serving nontribal institution” means an institution of higher education that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cddb3ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at the time of application—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cddb3bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/8/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an enrollment of undergraduate students that is not less than 10 percent Native American students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cddb3bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/8/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a Tribal College or University (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c"},"text":"section 1059c of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb3bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits to the Secretary such enrollment data as may be necessary to demonstrate that the institution is described in subparagraph (A), along with such other information and data as the Secretary may by regulation require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cddb3be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Predominantly Black institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Predominantly Black institution” means an institution of higher education that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cddb3bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an enrollment of needy students as defined by paragraph (3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb3c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an average educational and general expenditure which is low, per full-time equivalent undergraduate student in comparison with the average educational and general expenditure per full-time equivalent undergraduate student of institutions of higher education that offer similar instruction, except that the Secretary may apply the waiver requirements described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1068a/b"},"text":"section 1068a(b) of this title","children":[],"tail":" to this subparagraph in the same manner as the Secretary applies the waiver requirements to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1058/b/1/B"},"text":"section 1058(b)(1)(B) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb3c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has an enrollment of undergraduate students—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cddb3c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/9/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is at least 40 percent Black American students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cddb3c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/9/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is at least 1,000 undergraduate students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cddb3c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/9/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of which not less than 50 percent of the undergraduate students enrolled at the institution are low-income individuals or first-generation college students (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–11/h"},"text":"section 1070a–11(h) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cddb3c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/9/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of which not less than 50 percent of the undergraduate students are enrolled in an educational program leading to a bachelor’s or associate’s degree that the institution is licensed to award by the State in which the institution is located;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb3c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is legally authorized to provide, and provides within the State, an educational program for which the institution of higher education awards a bachelor’s degree, or in the case of a junior or community college, an associate’s degree;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb3c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/9/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is accredited by a nationally recognized accrediting agency or association determined by the Secretary to be a reliable authority as to the quality of training offered, or is, according to such an agency or association, making reasonable progress toward accreditation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb3c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/9/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is not receiving assistance under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cddb3c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/9/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" part B;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cddb3ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/9/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" part A of subchapter V; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cddb3cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/c/9/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annual authorization of appropriations under the Act of ","children":[{"tag":"date","attrib":{"date":"1867-03-02"},"text":"March 2, 1867","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/14/438"},"text":"14 Stat. 438","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s123"},"text":"20 U.S.C. 123","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cddb3cc-3a70-11f1-a648-bee82ed8a795"},