t20/s1067q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New investment of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cddb385-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cddb386-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be available to the Secretary to carry out this section, from funds in the Treasury not otherwise appropriated, $255,000,000 for fiscal year 2020 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb387-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under subparagraph (A) for a fiscal year shall remain available for the next succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cddb388-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation and allotment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cddb389-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts made available under paragraph (1) for each fiscal year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cddb38a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 shall be available for allocation under subparagraph (B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cddb38b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 shall be available for allocation under subparagraph (C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cddb38c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $55,000,000 shall be available for allocation under subparagraph (D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb38d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" HSI STEM and articulation programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount made available for allocation under this subparagraph by subparagraph (A)(i) for any fiscal year shall be available for Hispanic-serving Institutions ","children":[{"tag":"ref","attrib":{"idref":"fn002045"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002045"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" for activities described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1101b"},"text":"section 1101b of this title","children":[],"tail":", with a priority given to applications that propose—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0cddb38e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the number of Hispanic and other low income students attaining degrees in the fields of science, technology, engineering, or mathematics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cddb38f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop model transfer and articulation agreements between 2-year Hispanic-serving institutions and 4-year institutions in such fields.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb390-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation and allotment HBCUs and PBIs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amount made available for allocation under this subparagraph by subparagraph (A)(ii) for any fiscal year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cddb391-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 85 percent shall be available to eligible institutions described in subsection (a)(1) and shall be made available as grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1062"},"text":"section 1062 of this title","children":[],"tail":" and allotted among such institutions under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1063"},"text":"section 1063 of this title","children":[],"tail":", treating such amount, plus the amount appropriated for such fiscal year in a regular or supplemental appropriation Act to carry out part B of this subchapter, as the amount appropriated to carry out part B of this subchapter for purposes of allotments under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1063"},"text":"section 1063 of this title","children":[],"tail":", for use by such institutions with a priority for—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id0cddb392-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities described in paragraphs (1), (2), (4), (5), and (10) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1062/a"},"text":"section 1062(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0cddb393-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067q/b/2/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities, consistent with the institution’s comprehensive plan and designed to increase the institution’s capacity to prepare students fo