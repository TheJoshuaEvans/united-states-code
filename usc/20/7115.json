{"tag":"section","attrib":{"id":"id0e246500-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7115"},"text":null,"children":[{"tag":"num","attrib":{"value":"7115"},"text":"§ 7115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations to local educational agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e246501-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations to local educational agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e246502-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7115/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the funds reserved by a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7114/a/1"},"text":"section 7114(a)(1) of this title","children":[],"tail":", the State shall allocate to each local educational agency in the State that has an application approved by the State educational agency under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7116"},"text":"section 7116 of this title","children":[],"tail":" an amount that bears the same relationship to the total amount of such reservation as the amount the local educational agency received under subpart 2 of part A of subchapter I for the preceding fiscal year bears to the total amount received by all local educational agencies in the State under such subpart for the preceding fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e246503-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7115/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum local educational agency allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No allocation to a local educational agency under this subsection may be made in an amount that is less than $10,000, subject to subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e246504-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7115/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consortia","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Local educational agencies in a State may form a consortium with other surrounding local educational agencies and combine the funds each such agency in the consortium receives under this section to jointly carry out the local activities described in this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e246505-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ratable reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the amount reserved by the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7114/a/1"},"text":"section 7114(a)(1) of this title","children":[],"tail":" is insufficient to make allocations to local educational agencies in an amount equal to the minimum allocation described in subsection (a)(2), such allocations shall be ratably reduced."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e246506-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7115/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount received under subsection (a)(2), a local educational agency may reserve not more than 2 percent for the direct administrative costs of carrying out the local educational agency’s responsibilities under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e246507-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4105"},"text":"Pub. L. 89–10, title IV, § 4105","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4101"},"text":"Pub. L. 114–95, title IV, § 4101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1974"},"text":"129 Stat. 1974","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e246508-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e246509-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e24650a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7115, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4115"},"text":"Pub. L. 89–10, title IV, § 4115","children":[],"tail":", as added "},{"tag":"ref",