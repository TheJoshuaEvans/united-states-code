{"tag":"section","attrib":{"id":"id0cd1ccbd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1059b"},"text":"§ 1059b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals for financial management and academic program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cd1ccbe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any application for a grant under this part shall describe measurable goals for the institution’s financial management and academic programs, and include a plan of how the applicant intends to achieve those goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd1ccbf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any continuation application shall demonstrate the progress made toward achievement of the goals described pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cd1ccc0-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s315"},"text":"Pub. L. 89–329, title III, § 315","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIII/s302/d/1"},"text":"Pub. L. 102–325, title III, § 302(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/472"},"text":"106 Stat. 472","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cd1ccc1-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cd1ccc2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0cd1ccc3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/s2"},"text":"section 2 of Pub. L. 102–325","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
