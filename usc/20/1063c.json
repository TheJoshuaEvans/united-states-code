{"tag":"section","attrib":{"id":"id0cd8f866-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1063c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1063c"},"text":"§ 1063c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting and audit requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cd8f867-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1063c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each recipient of a grant under this part shall keep such records as the Secretary shall prescribe, including records which fully disclose—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd8f868-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1063c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and disposition by such recipient of the proceeds of such assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd8f869-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1063c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of the project or undertaking in connection with which such assistance is given or used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd8f86a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1063c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of that portion of the cost of the project or undertaking supplied by other sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd8f86b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1063c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other records as will facilitate an effective audit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd8f86c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1063c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of unexpended funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds paid to an institution and not expended or used for the purposes for which the funds were paid during the five-year period following the date of the initial grant award, may be carried over and expended during the succeeding five-year period, if such funds were obligated for a purpose for which the funds were paid during the five-year period following the date of the initial grant award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cd8f86d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s327"},"text":"Pub. L. 89–329, title III, § 327","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIII/s301/a"},"text":"Pub. L. 99–498, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1298"},"text":"100 Stat. 1298","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/50/s2/a/11"},"text":"Pub. L. 100–50, § 2(a)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-06-03"},"text":"June 3, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/335"},"text":"101 Stat. 335","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIII/s312"},"text":"Pub. L. 110–315, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3180"},"text":"122 Stat. 3180","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cd8f86e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cd8f86f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cd8f870-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, text read as follows: “Any funds paid to an institution and not expended or used for the purposes for which the funds were paid within 10 years following the date of the initial grant awarded to an institution under part B of this subchapter shall be repaid to the Treasury of the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/50"},"text":"Pub. L. 100–50","children":[],"tail":" substituted “part” for “chapter” in introductory text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cd8f871-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cd8f872-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/50"},"text":"Pub. L. 100–50","children":[],"tail":" effective as if enacted as part of the Higher Education Amendments of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/50/s27"},"text":"section 27 of Pub. L. 100–50","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
