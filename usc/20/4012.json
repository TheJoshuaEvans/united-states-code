{"tag":"section","attrib":{"id":"id0de18fee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4012"},"text":null,"children":[{"tag":"num","attrib":{"value":"4012"},"text":"§ 4012.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asbestos hazard abatement program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de18fef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4012/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abatement program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established a program within the Environmental Protection Agency to be known as the Asbestos Hazards Abatement Program (hereinafter in this subchapter referred to as “Program”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de18ff0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4012/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of the Administrator in implementing and effectuating the Program shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de18ff1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4012/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the compilation of medical, scientific, and technical information including, but not limited to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de18ff2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4012/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the health and safety hazards associated with asbestos materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de18ff3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4012/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the means of identifying, sampling, and testing materials suspected of emitting asbestos fibers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de18ff4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4012/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the means of abating the threat posed by asbestos and asbestos containing materials;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18ff5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4012/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distribution of the information described in paragraph (1) (in any appropriate form such as pamphlets, reports, or instructions) to State and local educational agencies and to other institutions, including parent and employee organizations, for the purpose of carrying out activities described in this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18ff6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4012/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than November 15 of each year for which this subchapter is authorized, the development and distribution of applications, or notifications to all local educational agencies of the availability of application forms including information for obtaining such forms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18ff7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4012/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the review of applications for financial assistance, and the approval or disapproval of such applications, in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4014"},"text":"section 4014 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de18ff8-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tV/s503"},"text":"Pub. L. 98–377, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-11"},"text":"Aug. 11, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1288"},"text":"98 Stat. 1288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/637"},"text":"Pub. L. 101–637","children":[],"tail":", §§ 4, 14(a)(3), (b)(3), (4), "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4590"},"text":"104 Stat. 4590","children":[],"tail":", 4594, 4595.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de18ff9-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de18ffa-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0de18ffb-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/a/3"},"text":"Pub. L. 101–637, § 14(a)(3)","children":[],"tail":", made technical amendment to section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/b/3"},"text":"Pub. L. 101–637, § 14(b)(3)","children":[],"tail":", inserted heading and struck out par. (1) designation before “There is hereby established”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/b/4"},"text":"Pub. L. 101–637, § 14(b)(4)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s4/1"},"text":"Pub. L. 101–637, § 4(1)","children":[],"tail":", (2), substituted “educational agencies” for “agencies” and “institutions, including parent and employee organizations,” for “institutions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s4/3"},"text":"Pub. L. 101–637, § 4(3)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows: “the development within forty-five days of "},{"tag":"date","attrib":{"date":"1984-08-11"},"text":"August 11, 1984","children":[],"tail":", of an interim or final application form, which shall be distributed promptly to local educational agencies; and”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
