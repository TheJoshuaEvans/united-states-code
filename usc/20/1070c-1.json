{"tag":"section","attrib":{"id":"id0cee7c70-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070c–1"},"text":"§ 1070c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment among States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cee7c71-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070c–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment based on number of eligible students in attendance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cee7c72-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070c–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" From the sums appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070c/b/1"},"text":"section 1070c(b)(1) of this title","children":[],"tail":" and not reserved under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070c/b/2"},"text":"section 1070c(b)(2) of this title","children":[],"tail":" for any fiscal year, the Secretary shall allot to each State an amount which bears the same ratio to such sums as the number of students who are deemed eligible in such State for participation in the grant program authorized by this subpart bears to the total number of such students in all the States, except that no State shall receive less than the State received for fiscal year 1979."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cee7c73-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070c–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this subsection, the number of students who are deemed eligible in a State for participation in the grant program authorized by this subpart, and the number of such students in all the States, shall be determined for the most recent year for which satisfactory data are available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cee7c74-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070c–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of any State’s allotment under subsection (a) for any fiscal year which the Secretary determines will not be required for such fiscal year for the leveraging educational assistance partnership program of that State shall be available for reallotment from time to time, on such dates during such year as the Secretary may fix, to other States in proportion to the original allotments to such States under such part for such year, but with such proportionate amount for any of such States being reduced to the extent it exceeds the sum the Secretary estimates such State needs and will be able to use for such year for carrying out the State plan. The total of such reductions shall be similarly reallotted among the States whose proportionate amounts were not so reduced. Any amount reallotted to a State under this part during a year from funds appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070c/b/1"},"text":"section 1070c(b)(1) of this title","children":[],"tail":" shall be deemed part of its allotment under subsection (a) for such year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cee7c75-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070c–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments subject to continuing compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make payments for continuing incentive grants only to States which continue to meet the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070c–2/b"},"text":"section 1070c–2(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cee7c76-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s415B"},"text":"Pub. L. 89–329, title IV, § 415B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s401/a"},"text":"Pub. L. 99–498, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1333"},"text":"100 Stat. 1333","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s407/a/2/A"},"text":"Pub. L. 105–244, title IV, § 407(a)(2)(A)","children":[],"tail":", (c)(2), "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1666"},"text":"112 Stat. 1666","children":[],"tail":", 1667.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cee7c77-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cee7c78-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cee7c79-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Prov