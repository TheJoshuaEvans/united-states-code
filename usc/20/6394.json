{"tag":"section","attrib":{"id":"id0e1151bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394"},"text":null,"children":[{"tag":"num","attrib":{"value":"6394"},"text":"§ 6394.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State applications; services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e1151c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any State desiring to receive a grant under this part for any fiscal year shall submit an application to the Secretary at such time and in such manner as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1151c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each such application shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1151c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of how, in planning, implementing, and evaluating programs and projects assisted under this part, the State and its local operating agencies will ensure that the unique educational needs of migratory children, including preschool migratory children and migratory children who have dropped out of school, are identified and addressed through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1151c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the full range of services that are available for migratory children from appropriate local, State, and Federal educational programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1151c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" joint planning among local, State, and Federal educational programs serving migratory children, including language instruction educational programs under part A of subchapter III;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1151c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integration of services available under this part with services provided by those other programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1151c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measurable program objectives and outcomes;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1151c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the steps the State is taking to provide all migratory students with the opportunity to meet the same challenging State academic standards that all children are expected to meet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1151c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the State will use funds received under this part to promote interstate and intrastate coordination of services for migratory children, including how the State will provide for educational continuity through the timely transfer of pertinent school records, including information on health, when children move from one school to another, whether or not such move occurs during the regular school year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1151c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the State’s priorities for the use of funds received under this part, and how such priorities relate to the State’s assessment of needs for services in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1151ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the State will determine the amount of any subgrants the State will award to local operating agencies, taking into account the numbers and needs of migratory children, the requirements of subsection (d), and the availability of funds from other Federal, State, and local programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1151cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the State will encourage programs and projects assisted under this part to offer family literacy services if the program or project serves a substantial number of migratory children whose parents do not have a high school diploma or its recognized equivalent or who have low levels of literacy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1151cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assurances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each such application shall also include assurances that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1151cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" funds received under this part will be used only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1151ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for programs and projects, including the acquisition of equipment, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6396"},"text":"section 6396 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1151cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate such programs and projects with similar programs and projects within the State and in other States, as well as with other Federal programs that can benefit migratory children and their families;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1151d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such programs and projects will be carried out in a manner consistent with the objectives of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6314"},"text":"section 6314 of this title","children":[],"tail":", subsections (b) and (d) of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6315"},"text":"section 6315 of this title","children":[],"tail":", subsections (b) and (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6321"},"text":"section 6321 of this title","children":[],"tail":", and part F;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1151d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the planning and operation of programs and projects at both the State and local agency operating level, there is consultation with parents of migratory children, including parent advisory councils, for programs not less than 1 school year in duration, and that all such programs and projects are carried out—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1151d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner that provides for the same parental involvement as is required for programs and projects under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6318"},"text":"section 6318 of this title","children":[],"tail":", unless extraordinary circumstances make such provision impractical; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1151d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a format and language understandable to the parents;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1151d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in planning and carrying out such programs and projects, there has been, and will be, adequate provision for addressing the unmet education needs of preschool migratory children and migratory children who have dropped out of school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1151d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of such programs and projects will be determined, where feasible, using the same approaches and standards that will be used to assess the performance of students, schools, and local educational agencies under part A;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1151d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such programs and projects will provide for outreach activities for migratory children and their families to inform such children and families of other education, health, nutrition, and social services to help connect them to such services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1151d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent feasible, such programs and projects will provide for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1151d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advocacy and other outreach activities for migratory children and their families, including helping such children and families gain access to other education, health, nutrition, and social services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1151d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional development programs, including mentoring, for teachers and other program personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1151da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/c/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family literacy programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1151db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/c/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integration of information technology into educational and related programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1151dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/c/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs to facilitate the transition of secondary school students to postsecondary education or employment; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1151dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State will assist the Secretary in determining the number of migratory children under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6393/a/1"},"text":"section 6393(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1151de-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority for services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing services with funds received under this part, each recipient of such funds shall give priority to migratory children who have made a qualifying move within the previous 1-year period and who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1151df-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are failing, or most at risk of failing, to meet the challenging State academic standards; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1151e0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have dropped out of school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1151e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1151e2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a child who ceases to be a migratory child during a school term shall be eligible for services until the end of such term;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1151e3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a child who is no longer a migratory child may continue to receive services for 1 additional school year, but only if comparable services are not available through other programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1151e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6394/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" students who were eligible for services in secondary school may continue to be served through credit accrual programs until graduation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e1151e5-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1304"},"text":"Pub. L. 89–10, title I, § 1304","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1574"},"text":"115 Stat. 1574","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tI/s1301/c"},"text":"Pub. L. 114–95, title I, § 1301(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1896"},"text":"129 Stat. 1896","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e1151e6-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e1151e7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e1151e8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6394, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1304"},"text":"Pub. L. 89–10, title I, § 1304","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3587"},"text":"108 Stat. 3587","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tXVI/s1605"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title XVI, § 1605]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–334, related to State applications and services, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e1151e9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/c/1/A/i"},"text":"Pub. L. 114–95, § 1301(c)(1)(A)(i)","children":[],"tail":", in introductory provisions substituted “unique educational needs” for “special educational needs” and inserted “and migratory children who have dropped out of school” after “preschool migratory children”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/c/1/A/ii"},"text":"Pub. L. 114–95, § 1301(c)(1)(A)(ii)","children":[],"tail":", substituted “migratory children” for “migrant children” and “part A of subchapter III” for “part A or B of subchapter III”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/c/1/A/iii"},"text":"Pub. L. 114–95, § 1301(c)(1)(A)(iii)","children":[],"tail":", added subpar. (D) and struck out former subpar. (D) which read as follows: “measurable program goals and outcomes;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/c/1/B"},"text":"Pub. L. 114–95, § 1301(c)(1)(B)","children":[],"tail":", substituted “challenging State academic standards” for “challenging State academic content standards and challenging State student academic achievement standards”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/c/1/C"},"text":"Pub. L. 114–95, § 1301(c)(1)(C)","children":[],"tail":", struck out “, consistent with procedures the Secretary may require,” after “including how”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/c/1/D"},"text":"Pub. L. 114–95, § 1301(c)(1)(D)","children":[],"tail":", inserted “and” after semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/c/1/E"},"text":"Pub. L. 114–95, § 1301(c)(1)(E)","children":[],"tail":"–(G), redesignated par. (7) as (6), substituted “migratory children whose parents do not have a high school diploma” for “migratory children who have parents who do not have a high school diploma”, and struck out former par. (6) which read as follows: “such budgetary and other information as the Secretary may require; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/c/2/A"},"text":"Pub. L. 114–95, § 1301(c)(2)(A)","children":[],"tail":", struck out “, satisfactory to the Secretary,” after “assurances” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/c/2/B"},"text":"Pub. L. 114–95, § 1301(c)(2)(B)","children":[],"tail":", made technical amendment