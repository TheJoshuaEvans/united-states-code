{"tag":"section","attrib":{"id":"id0e64c8af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b"},"text":null,"children":[{"tag":"num","attrib":{"value":"9567b"},"text":"§ 9567b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e64c8b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Special Education Research Center shall carry out research activities under this part consistent with the mission described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9567/b"},"text":"section 9567(b) of this title","children":[],"tail":", such as activities that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e64c8b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" improve services provided under the Individuals with Disabilities Education Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"20 U.S.C. 1400","children":[],"tail":" et seq.] in order to improve—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e64c8b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic achievement, functional outcomes, and educational results for children with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e64c8b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developmental outcomes for infants or toddlers with disabilities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify scientifically based educational practices that support learning and improve academic achievement, functional outcomes, and educational results for all students with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine the special needs of preschool aged children, infants, and toddlers with disabilities, including factors that may result in developmental delays;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify scientifically based related services and interventions that promote participation and progress in the general education curriculum and general education settings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the alignment, compatibility, and development of valid and reliable assessments, including alternate assessments, as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b"},"text":"section 6311(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine State content standards and alternate assessments for students with significant cognitive impairment in terms of academic achievement, individualized instructional need, appropriate education settings, and improved post-school results;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine the educational, developmental, and transitional needs of children with high incidence and low incidence disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine the extent to which overidentification and underidentification of children with disabilities occurs, and the causes thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve reading and literacy skills of children with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine and improve secondary and postsecondary education and transitional outcomes and results for children with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine methods of early intervention for children with disabilities, including children with multiple or complex developmental delays;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine and incorporate universal design concepts in the development of standards, assessments, curricula, and instructional methods to improve educational and transitional results for children with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the preparation of personnel, including early intervention personnel, who provide educational and related services to children with disabilities to increase the academic achievement and functional performance of students with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine the excess costs of educating a child with a disability and expenses associated with high cost special education and related services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" help parents improve educational results for their children, particularly related to transition issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/a/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address the unique needs of children with significant cognitive disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/a/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine the special needs of limited English proficient children with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e64c8c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Special Education Research Commissioner shall ensure that activities assisted under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e64c8c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conform to high standards of quality, integrity, accuracy, validity, and reliability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are carried out in accordance with the standards for the conduct and evaluation of all research and development established by the National Center for Education Research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are objective, secular, neutral, and nonideological, and are free of partisan political influence, and racial, cultural, gender, regional, or disability bias.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e64c8c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Special Education Research Commissioner shall propose to the Director a research plan, developed in collaboration with the Assistant Secretary for Special Education and Rehabilitative Services, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e64c8c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with the priorities and mission of the Institute and the mission of the Special Education Research Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is carried out, updated, and modified, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with the purposes of the Individuals with Disabilities Education Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"20 U.S.C. 1400","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains an appropriate balance across all age ranges and types of children with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for research that is objective and uses measurable indicators to assess its progress and results; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is coordinated with the comprehensive plan developed under section 681 of the Individuals with Disabilities Education Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1481"},"text":"20 U.S.C. 1481","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e64c8cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants, contracts, and cooperative agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e64c8d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the duties under this section, the Director may award grants to, or enter into contracts or cooperative agreements with, eligible applicants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible applicants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Activities carried out under this subsection through contracts, grants, or cooperative agreements shall be carried out only by recipients with the ability and capacity to conduct scientifically valid research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible applicant that wishes to receive a grant, or enter into a contract or cooperative agreement, under this section shall submit an application to the Director at such time, in such manner, and containing such information as the Director may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e64c8d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Special Education Research Center shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e64c8d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" synthesize and disseminate, through the National Center for Education Evaluation and Regional Assistance, the findings and results of special education research conducted or supported by the Special Education Research Center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Director in the preparation of a biennial report, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9519"},"text":"section 9519 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e64c8d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this part such sums as may be necessary for each of fiscal years 2005 through 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e64c8d7-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s177"},"text":"Pub. L. 107–279, title I, § 177","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tII/s201/a/2"},"text":"Pub. L. 108–446, title II, § 201(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2800"},"text":"118 Stat. 2800","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e64c8d8-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e64c8d9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e64c8da-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Individuals with Disabilities Education Act, referred to in subsecs. (a)(1) and (c)(3), is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230"},"text":"Pub. L. 91–230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/175"},"text":"84 Stat. 175","children":[],"tail":", which is classified generally to chapter 33 (§ 1400 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e64c8db-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e64c8dc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/446/tIII/s302/c"},"text":"Pub. L. 108–446, title III, § 302(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2803"},"text":"118 Stat. 2803","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/446/tIII/s302/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National center for special education research","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sections 175, 176, and 177 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9567"},"text":"20 U.S.C. 9567","children":[],"tail":", 9567a, 9567b] (other than section 177(c) ["},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9567b/c"},"text":"20 U.S.C. 9567b(c)","children":[],"tail":"]) of the Education Sciences Reform Act of 2002, as enacted by section 201(a)(2) of this Act, shall take effect on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 177(c) of the Education Sciences Reform Act of 2002, as enacted by section 201(a)(2) of this Act, shall take effect on ","children":[{"tag":"date","attrib":{"date":"2005-10-01"},"text":"October 1, 2005","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
