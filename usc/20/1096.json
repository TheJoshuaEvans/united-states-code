3"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1453"},"text":"94 Stat. 1453","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tV/s537/a/2"},"text":"Pub. L. 97–35, title V, § 537(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/456"},"text":"95 Stat. 456","children":[],"tail":", related to administrative expenses, prior to the general revision of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d5e7cb3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" substituted “has referred under section 1087cc(a)(4)(B)” for “has agreed to assign under section 1087cc(a)(6)(B)” and “1091(g)” for “1091(h)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" substituted “administering” for “offsetting the administrative costs of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/k/6"},"text":"Pub. L. 103–208, § 2(k)(6)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/s446/c"},"text":"Pub. L. 102–325, § 446(c)","children":[],"tail":". See 1992 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/h/44"},"text":"Pub. L. 103–208, § 2(h)(44)","children":[],"tail":", substituted “1091(h) of this title” for “1091(c) of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s493/a/3"},"text":"Pub. L. 102–325, § 493(a)(3)","children":[],"tail":", substituted “subpart 3” for “subpart 2” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s493/a/1"},"text":"Pub. L. 102–325, § 493(a)(1)","children":[],"tail":", (2), struck out “(other than "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087–57"},"text":"section 1087–57 of this title","children":[],"tail":")” after “or part C” in second sentence and struck out fourth sentence which read as follows: “The payment for a fiscal year for the purpose of subsection (b) with respect to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087–57"},"text":"section 1087–57 of this title","children":[],"tail":" shall be payable from each allotment under part C in accordance with regulations of the Secretary, and shall be 10 percent of the institution’s expenditures during such fiscal year under such section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s446/c"},"text":"Pub. L. 102–325, § 446(c)","children":[],"tail":", which directed amendment identical to amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/s493/a/1"},"text":"Pub. L. 102–325, § 493(a)(1)","children":[],"tail":", (2), above, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/k/6"},"text":"Pub. L. 103–208, § 2(k)(6)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s493/b"},"text":"Pub. L. 102–325, § 493(b)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/50"},"text":"Pub. L. 100–50","children":[],"tail":" made technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087–57"},"text":"section 1087–57 of this title","children":[],"tail":" to correct reference to corresponding section of original Act, requiring no change in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/603"},"text":"Pub. L. 99–603","children":[],"tail":" inserted provision directing the Secretary to pay the costs incurred by institutions of higher education in implementing and operating the immigration status verification system under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1091/c"},"text":"section 1091(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d5e7cb4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d5e7cb5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" effective as if enacted on the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/s3"},"text":"section 3 of Pub. L. 111–39","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"ta