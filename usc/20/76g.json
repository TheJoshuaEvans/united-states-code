{"tag":"section","attrib":{"id":"id0c7be3e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76g"},"text":null,"children":[{"tag":"num","attrib":{"value":"76g"},"text":"§ 76g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated annually such sums as may be necessary to maintain and administer the Gallery, including the salaries of the Director and of other necessary officers and employees, and for special public exhibitions at Washington and elsewhere.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c7be3e7-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-05-17/ch238/s8"},"text":"May 17, 1938, ch. 238, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/401"},"text":"52 Stat. 401","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
