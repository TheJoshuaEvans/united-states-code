{"tag":"section","attrib":{"id":"id0de18fb4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3997"},"text":null,"children":[{"tag":"num","attrib":{"value":"3997"},"text":"§ 3997.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de18fb5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3997/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State shall establish criteria for approval of applications under this section. Such criteria shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de18fb6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3997/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consideration of the local district’s need for, and inability to locally provide for, the activities, equipment, library and instructional materials requested;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18fb7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3997/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and nature of elementary and secondary students who will benefit from the planned program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18fb8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3997/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expressed level of financial and in-kind commitment from other parties to the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de18fb9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3997/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State shall adopt approval procedures designed to ensure that grants are equitably distributed among—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de18fba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3997/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rural, urban, and suburban areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18fbb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3997/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small, medium, and large local educational agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de18fbc-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tIII/s327"},"text":"Pub. L. 98–377, title III, § 327","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tVI/s6031/a/2"},"text":"Pub. L. 100–418, title VI, § 6031(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1482"},"text":"102 Stat. 1482","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
