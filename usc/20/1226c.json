 L. 103–437, § 7(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4587"},"text":"108 Stat. 4587","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1076/h"},"text":"Pub. L. 107–110, title X, § 1076(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2091"},"text":"115 Stat. 2091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/mm/1"},"text":"Pub. L. 114–95, title IX, § 9215(mm)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2176"},"text":"129 Stat. 2176","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d908968-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d908969-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d90896a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/s425"},"text":"section 425 of Pub. L. 90–247","children":[],"tail":" was renumbered section 432, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1231b–2"},"text":"section 1231b–2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/s425"},"text":"section 425 of Pub. L. 90–247","children":[],"tail":" was renumbered section 434, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1231d"},"text":"section 1231d of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/s425"},"text":"section 425 of Pub. L. 90–247","children":[],"tail":" was renumbered section 423, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1226a–1"},"text":"section 1226a–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d90896b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7981"},"text":"section 7981 of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7941"},"text":"section 7941 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":" substituted “7941” for “8941”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":", which directed that "},{"tag":"ref","attrib":{"href":"/us/pl/90/247/s417/a"},"text":"section 417(a) of Pub. L. 90–247","children":[],"tail":" be amended by substituting “Labor and Human Resources” for “Human Resources”, could not be executed because this section, which was "},{"tag":"ref","attrib":{"href":"/us/pl/90/247/s417"},"text":"section 417 of Pub. L. 90–247","children":[],"tail":", was renumbered section 425 and amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/s235"},"text":"Pub. L. 103–382, § 235","children":[],"tail":", amended section generally, substituting single undesignated par. relating to biennial evaluation reports for former subsecs. (a) and (b) relating to annual evaluation reports and including requirement for information on contracts and grants for evaluations of programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/511"},"text":"Pub. L. 98–511","children":[],"tail":" substituted “December 31” for “November 1”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/374"},"text":"Pub. L. 96–374","children":[],"tail":" inserted “, including tabulations of available data to indicate the effectiveness of the programs and projects by the sex, race, and age of its beneficiaries” after “detailed data and appendices”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/46"},"text":"Pub. L. 96–46","children":[],"tail":" substituted “(a) Not later than” for “(a)(1) Not later than” and struck out par. (2) which provided that, in the case of programs and projects assisted under title I of the Elementary and Secondary Education Act of 1965, the report include a survey of how many children counted under section 103(c) of such Act do or do not participate in such programs and projects and how many disadvantaged children do or do not participate in such programs and projects."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561"},"text":"Pub. L. 95–561","children":[],"tail":" inserted “(including compliance with provisions of law requiring the maintenance of non-Federal expenditures for the purposes of such applicable programs)” after “effectiveness of applicable programs” and substituted “Committee on Human Resources” for “Committee on Labor and Public Welfare” in provisions preceding subpar. (A)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d90896c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id0d90896d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Education and Labor of House of Representatives changed to Committee on Education and the Workforce of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Labor and Human Resources of Senate changed to Committee on Health, Education, Labor, and Pensions of Senate by Senate Resolution No. 20, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-19"},"text":"Jan. 19, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d90896e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","chil