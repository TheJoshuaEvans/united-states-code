{"tag":"section","attrib":{"id":"id0e6e668b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9901"},"text":null,"children":[{"tag":"num","attrib":{"value":"9901"},"text":"§ 9901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this chapter is to replicate and implement programs at institutions of higher education that provide integrated courses of study in science, technology, engineering, or mathematics, and teacher education, that lead to a baccalaureate degree in science, technology, engineering, or mathematics with concurrent teacher certification.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e6e668c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/tV/s551"},"text":"Pub. L. 111–358, title V, § 551","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4021"},"text":"124 Stat. 4021","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
