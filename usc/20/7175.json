{"tag":"section","attrib":{"id":"id0e26d6bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175"},"text":null,"children":[{"tag":"num","attrib":{"value":"7175"},"text":"§ 7175.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e26d6bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each eligible entity that receives an award under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7174"},"text":"section 7174 of this title","children":[],"tail":" may use the award funds to carry out a broad array of activities that advance student academic achievement and support student success, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e26d6be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" academic enrichment learning programs, mentoring programs, remedial education activities, and tutoring services, that are aligned with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e26d6bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the challenging State academic standards and any local academic standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d6c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local curricula that are designed to improve student academic achievement;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d6c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" well-rounded education activities, including such activities that enable students to be eligible for credit recovery or attainment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d6c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" literacy education programs, including financial literacy programs and environmental literacy programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d6c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs that support a healthy and active lifestyle, including nutritional education and regular, structured physical activity programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d6c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services for individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d6c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs that provide after-school activities for students who are English learners that emphasize language skills and academic achievement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d6c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cultural programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d6c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" telecommunications and technology education programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d6c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanded library service hours;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d6c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parenting skills programs that promote parental involvement and family literacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d6ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs that provide assistance to students who have been truant, suspended, or expelled to allow the students to improve their academic achievement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e291ebb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drug and violence prevention programs and counseling programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e291ebc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs that build skills in science, technology, engineering, and mathematics (referred to in this paragraph as “STEM”), including computer science, and that foster innovation in learning by supporting nontraditional STEM education teaching methods; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e291ebd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs that partner with in-demand fields of the local workforce or build career competencies and career readiness and ensure that local workforce and career readiness skills are aligned with the Carl D. Perkins Career and Technical Education Act of 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2301"},"text":"20 U.S.C. 2301","children":[],"tail":" et seq.) and the Workforce Innovation and Opportunity Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"29 U.S.C. 3101","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e291ebe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Measures of effectiveness","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e291ebf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For a program or activity developed pursuant to this part to meet the measures of effectiveness, monitored by the State educational agency as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7173/a/14"},"text":"section 7173(a)(14) of this title","children":[],"tail":", such program or activity shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e291ec0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be based upon an assessment of objective data regarding the need for before and after school (or summer recess) programs and activities in the schools and communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e291ec1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be based upon an established set of performance measures aimed at ensuring the availability of high-quality academic enrichment opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e291ec2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if appropriate, be based upon evidence-based research that the program or activity will help students meet the challenging State academic standards and any local academic standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e291ec3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that measures of student success align with the regular academic program of the school and the academic needs of participating students and include performance indicators and measures described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7173/a/14/A"},"text":"section 7173(a)(14)(A) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e291ec4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect the data necessary for the measures of student success described in subparagraph (D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e291ec5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic evaluation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e291ec6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program or activity shall undergo a periodic evaluation in conjunction with the State educational agency’s overall evaluation plan as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7173/a/14"},"text":"section 7173(a)(14) of this title","children":[],"tail":", to assess the program’s progress toward achieving the goal of providing high-quality opportunities for academic enrichment and overall student success."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e291ec7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of results","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The results of evaluations under subparagraph (A) shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e291ec8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used to refine, improve, and strengthen the program or activity, and to refine the performance measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e291ec9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made available to the public upon request, with public notice of such availability provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e291eca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7175/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used by the State to determine whether a subgrant is eligible to be renewed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7174/j"},"text":"section 7174(j) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e291ecb-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4205"},"text":"Pub. L. 89–10, title IV, § 4205","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIV/s401"},"text":"Pub. L. 107–110, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1772"},"text":"115 Stat. 1772","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4201/a"},"text":"Pub. L. 114–95, title IV, § 4201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1992"},"text":"129 Stat. 1992","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e291ecc-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e291ecd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e291ece-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Carl D. Perkins Career and Technical Education Act of 2006, referred to in subsec. (a)(14), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210"},"text":"Pub. L. 88–210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-12-18"},"text":"Dec. 18, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/403"},"text":"77 Stat. 403","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/b"},"text":"Pub. L. 109–270, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/683"},"text":"120 Stat. 683","children":[],"tail":", which is classified generally to chapter 44 (§ 2301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s2301"},"text":"section 2301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Workforce Innovation and Opportunity Act, referred to in (a)(14), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1425"},"text":"128 Stat. 1425","children":[],"tail":", which enacted chapter 32 (§ 3101 et seq.) of Title 29, Labor, repealed chapter 30 (§ 2801 et seq.) of Title 29 and chapter 73 (§ 9201 et seq.) of this title, and made amendments to numerous other sections and notes in the Code. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e291ecf-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" amended section generally. Prior to amendment, section related to local activities."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e291ed0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e291ed1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
