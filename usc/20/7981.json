{"tag":"section","attrib":{"id":"id0e5670ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981"},"text":null,"children":[{"tag":"num","attrib":{"value":"7981"},"text":"§ 7981.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e5670cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002239"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002239"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsections”."}],"tail":" (b) and (e), the Secretary, in consultation with the Director of the Institute of Education Sciences, may reserve not more than 0.5 percent of the amount appropriated for each program authorized under this chapter to carry out activities under this section. If the Secretary elects to make a reservation under this subsection, the reserved amounts—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e5670d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall first be used by the Secretary, acting through the Director of the Institute of Education Sciences, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e5670d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct comprehensive, high-quality evaluations of the programs that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e5670d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with the evaluation plan under subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e5670d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" primarily include impact evaluations that use experimental or quasi-experimental designs, where practicable and appropriate, and other rigorous methodologies that permit the strongest possible causal inferences;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e5670d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct studies of the effectiveness of the programs and the administrative impact of the programs on schools and local educational agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e5670d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" widely disseminate evaluation findings under this section related to programs authorized under this chapter—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e5670d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a timely fashion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e5670d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in forms that are understandable, easily accessible, usable, and adaptable for use in the improvement of educational practice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e5670d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/a/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through electronic transfer and other means, such as posting, as available, to the websites of State educational agencies, local educational agencies, the Institute of Education Sciences, or the Department, or in another relevant place; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e5670d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/a/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner that promotes the utilization of such findings; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5670da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may be used by the Secretary, acting through the Director of the Institute of Education Sciences—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e5670db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to evaluate the aggregate short- and long-term effects and cost efficiencies across—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e5670dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal programs assisted or authorized under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e5670dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related Federal early childhood education programs, preschool programs, elementary school programs, and secondary school programs, under any other Federal law;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e5670de-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the usefulness of the evaluations conducted under this section by improving the quality, timeliness, efficiency, and use of information relating to performance to promote continuous improvement of programs assisted or authorized under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e5670df-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist recipients of grants under such programs in collecting and analyzing data and other activities related to conducting high-quality evaluations under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e5670e0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subchapter I","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Institute of Education Sciences, shall use funds authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6302/e"},"text":"section 6302(e) of this title","children":[],"tail":" to carry out evaluation activities under this section related to subchapter I, and shall not reserve any other money from such subchapter for evaluation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e5670e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6302/e"},"text":"section 6302(e) of this title","children":[],"tail":", the Secretary, in consultation with the Director of the Institute of Education Sciences—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e5670e2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may consolidate the funds reserved under subsections (a) and (b) for purposes of carrying out the activities under subsection (a)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5670e3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be required to evaluate under subsection (a)(1) each program authorized under this chapter each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e5670e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Institute of Education Sciences, shall, on a biennial basis, develop, submit to Congress, and make publicly available an evaluation plan, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e5670e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the specific activities that will be carried out under subsection (a) for the 2-year period applicable to the plan, and the timelines of such activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5670e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains the results of the activities carried out under subsection (a) for the most recent 2-year period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5670e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes how programs authorized under this chapter will be regularly evaluated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e5670e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7981/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation activities authorized elsewhere","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, under any other provision of this chapter, funds are authorized to be reserved or used for evaluation activities with respect to a program, the Secretary may not reserve additional funds under this section for the evaluation of that program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e5670e9-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8601"},"text":"Pub. L. 89–10, title VIII, § 8601","children":[],"tail":", formerly title IX, § 9601, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIX/s901"},"text":"Pub. L. 107–110, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1985"},"text":"115 Stat. 1985","children":[],"tail":"; renumbered title VIII, § 8601, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII"},"text":"Pub. L. 114–95, title VIII","children":[],"tail":", §§ 8001(a)(10), 8042, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2088"},"text":"129 Stat. 2088","children":[],"tail":", 2089, 2122.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e5670ea-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e5670eb-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0e5670ec-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7941"},"text":"section 7941 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e5670ed-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8042"},"text":"Pub. L. 114–95, § 8042","children":[],"tail":", amended section generally. Prior to amendment, section consisted of subsecs. (a) to (c) relating to reservation of funds for evaluations, exclusion of subchapters I and III, and evaluation activities authorized elsewhere, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e5670ee-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e5670ef-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
