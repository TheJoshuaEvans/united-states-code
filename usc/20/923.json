{"tag":"section","attrib":{"id":"id0ca6eb79-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923"},"text":null,"children":[{"tag":"num","attrib":{"value":"923"},"text":"§ 923.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Space-available enrollment of students; tuition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ca6eb7a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment of ineligible child in system school","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b) and in accordance with regulations issued under subsection (c), the Director may authorize the enrollment in a school of the defense dependents’ education system of a child not otherwise eligible to enroll in such a school if and to the extent that there is space available for such child in the school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ca6eb7b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount of tuition; use of payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ca6eb7c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided under subsection (c), any child permitted to enroll in a school of the defense dependents’ education system under this section shall be required to pay tuition at a rate determined by the Secretary of Defense, which shall not be less than the rate necessary to defray the average cost of the enrollment of children in the system under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca6eb7d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts received under paragraph (1) shall be available to the defense dependents’ education system to assist in defraying the cost of enrollment of children in the system under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ca6eb7e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations respecting enrollment requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ca6eb7f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may by regulation identify classes of children who shall be eligible to enroll in schools of the defense dependents’ education system under this section if and to the extent that there is space available, establish priorities among such classes, waive the tuition requirement of subsection (b)(1) with respect to any such class, and issue such other regulations as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca6eb80-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ca6eb81-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall include in the regulations prescribed under this subsection a requirement that children in the class of children described in subparagraph (B) shall be subject to the same tuition requirements, or waiver of tuition requirements, as children in the class of children described in subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ca6eb82-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The class of children described in this subparagraph are children of members of reserve components of the Armed Forces who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0ca6eb83-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are on active duty under an order to active duty under section 12301 or 12302 of title 10;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ca6eb84-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were ordered to active duty from a location in the United States (other than in Alaska or Hawaii); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ca6eb85-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are serving on active duty outside the United States or in Alaska or Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ca6eb86-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The class of children described in this subparagraph are children of members of reserve components of the Armed Forces who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0ca6eb87-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are on active duty under an order to active duty under section 12301 or 12302 of title 10;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ca6eb88-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were ordered to active duty from a location outside the United States (or in Alaska or Hawaii); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ca6eb89-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are serving on active duty outside the United States or in Alaska or Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ca6eb8a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment of certain children in overseas schools","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ca6eb8b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense may authorize the enrollment in schools of the defense dependents’ education system of children in the following classes:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ca6eb8c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Children of officers and employees of the United States (other than civilian officers and employees who are sponsors under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s932/2"},"text":"section 932(2) of this title","children":[],"tail":") stationed in overseas areas."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ca6eb8d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Children of employees of contractors employed in carrying out work for the United States in overseas areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ca6eb8e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Children of other citizens or nationals of the United States or of foreign nationals, if the Secretary determines that enrollment of such children is in the national interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ca6eb8f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Children of employees of the American Red Cross who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0ca6eb90-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/d/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are performing, on a full-time basis, services for the Armed Forces, including emergency services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ca6eb91-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/d/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reside in an overseas area supported by a school of the defense dependents’ education system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca6eb92-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subsection (c), the Secretary may not waive the tuition requirements of subsection (b)(1) with respect to children referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ca6eb93-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXIV/s1404"},"text":"Pub. L. 95–561, title XIV, § 1404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2366"},"text":"92 Stat. 2366","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXII/s1205"},"text":"Pub. L. 99–145, title XII, § 1205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/721"},"text":"99 Stat. 721","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tIII/s325/b"},"text":"Pub. L. 101–189, div. A, title III, § 325(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1415"},"text":"103 Stat. 1415","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tV/s563"},"text":"Pub. L. 108–136, div. A, title V, § 563","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1483"},"text":"117 Stat. 1483","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tV/s582/a"},"text":"Pub. L. 119–60, div. A, title V, § 582(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/888"},"text":"139 Stat. 888","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ca6eb94-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ca6eb95-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0ca6eb96-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s563/b"},"text":"Pub. L. 108–136, § 563(b)","children":[],"tail":", substituted “Space-available enrollment of students; tuition” for “Tuition-paying students” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s563/a"},"text":"Pub. L. 108–136, § 563(a)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" substituted “(other than civilian officers and employees who are sponsors under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s932/2"},"text":"section 932(2) of this title","children":[],"tail":")” for “(including employees of nonappropriated fund activities of the Department of Defense)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0ca6eb97-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0ca6eb98-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tIII/s325/c"},"text":"Pub. L. 101–189, div. A, title III, § 325(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1415"},"text":"103 Stat. 1415","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/189/dA/tIII/s325/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s932"},"text":"section 932 of this title","children":[],"tail":"] shall apply with respect to periods of enrollment in schools of the defense dependents’ education system beginning after "},{"tag":"date","attrib":{"date":"1989-09-30"},"text":"September 30, 1989","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
