{"tag":"section","attrib":{"id":"id0ce02462-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1068f"},"text":"§ 1068f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being an officer, director, agent, or employee of, or connected in any capacity with, any recipient of Federal financial assistance or grant pursuant to this subchapter embezzles, willfully misapplies, steals, or obtains by fraud any of the funds which are the subject of such grant or assistance, shall be fined not more than $10,000 or imprisoned for not more than 2 years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0ce02463-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s397"},"text":"Pub. L. 89–329, title III, § 397","children":[],"tail":", formerly § 358, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIII/s301/a"},"text":"Pub. L. 99–498, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1307"},"text":"100 Stat. 1307","children":[],"tail":"; renumbered § 397, "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIII/s301/a/2"},"text":"Pub. L. 105–244, title III, § 301(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1636"},"text":"112 Stat. 1636","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ce02464-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ce02465-3a70-11f1-a648-bee82ed8a795"},"text":nu