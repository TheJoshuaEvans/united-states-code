{"tag":"section","attrib":{"id":"id0d97b515-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1234c"},"text":"§ 1234c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies for existing violations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d97b516-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whenever the Secretary has reason to believe that any recipient of funds under any applicable program is failing to comply substantially with any requirement of law applicable to such funds, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d97b517-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withhold further payments under that program, as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1234d"},"text":"section 1234d of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d97b518-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue a complaint to compel compliance through a cease and desist order of the Office, as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1234e"},"text":"section 1234e of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d97b519-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into a compliance agreement with a recipient to bring it into compliance, as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1234f"},"text":"section 1234f of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d97b51a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take any other action authorized by law with respect to the recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b51b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any action, or failure to take action, by the Secretary under this section shall not preclude the Secretary from seeking a recovery of funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1234a"},"text":"section 1234a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d97b51c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/tIV/s454"},"text":"Pub. L. 90–247, title IV, § 454","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXII/s1232"},"text":"Pub. L. 95–561, title XII, § 1232","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2349"},"text":"92 Stat. 2349","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/tIII/s3501/a"},"text":"Pub. L. 100–297, title III, § 3501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/354"},"text":"102 Stat. 354","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d97b51d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d97b51e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d97b51f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297"},"text":"Pub. L. 100–297","children":[],"tail":" amended section generally, substituting provisions relating to remedies for existing violations for provisions relating to cease and desist orders. See "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1234e"},"text":"section 1234e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d97b520-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d97b521-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297"},"text":"Pub. L. 100–297","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", but not applicable to recipients receiving written notice to return funds prior to that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/s3501/b"},"text":"section 3501(b) of Pub. L. 100–297","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1234"},"text":"section 1234 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
