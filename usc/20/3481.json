{"tag":"section","attrib":{"id":"id0dda8aaf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3481"},"text":null,"children":[{"tag":"num","attrib":{"value":"3481"},"text":"§ 3481.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gifts and bequests","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to accept, hold, administer, and utilize gifts, bequests and devises of property, both real and personal, and to accept donations of services, for the purpose of aiding or facilitating the work of the Department. Gifts, bequests, and devises of money and proceeds from sales of other property received as gifts, bequests, or devises shall be deposited in the Treasury and shall be available for disbursement upon the order of the Secretary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0dda8ab0-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIV/s421"},"text":"Pub. L. 96–88, title IV, § 421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/687"},"text":"93 Stat. 687","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tII/s271/d/2"},"text":"Pub. L. 103–382, title II, § 271(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3930"},"text":"108 Stat. 3930","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dda8ab1-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dda8ab2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0dda8ab3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":" inserted “and to accept donations of services,” after “personal,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
