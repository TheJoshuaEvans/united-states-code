{"tag":"section","attrib":{"id":"id0d3f8305-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087rr"},"text":null,"children":[{"tag":"num","attrib":{"value":"1087rr"},"text":"§ 1087rr.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations; updated tables","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d3f8306-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087rr/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to prescribe regulations restricted","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary shall not have the authority to prescribe regulations to carry out this part except—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d3f8307-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087rr/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prescribe updated tables in accordance with subsections (b) through (g); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d3f8308-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087rr/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the definition of cost of attendance under section 1087","children":[{"tag":"i","attrib":{},"text":"ll","children":[],"tail":" of this title, excluding section 1087"},{"tag":"i","attrib":{},"text":"ll","children":[],"tail":"(a)(1) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d3f8309-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087rr/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income protection allowance adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For award year 2023–2024 and each subsequent award year, the Secretary shall publish in the Federal Register revised income protection allowances for the purposes of subsections (c)(3) and (g)(2)(C) of section 1087","children":[{"tag":"i","attrib":{},"text":"oo","children":[],"tail":" of this title, subclauses (I) and (II) of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087pp/b/1/A/iii"},"text":"section 1087pp(b)(1)(A)(iii) of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087qq/b/3"},"text":"section 1087qq(b)(3) of this title","children":[],"tail":", by increasing the income protection allowances in each of such provisions, by a percentage equal to the percentage increase in the Consumer Price Index, as defined in subsection (f), between April 2020 and the April in the year prior to the beginning of the award year and rounding the result to the nearest $10."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d3f830a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087rr/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjusted net worth of a farm or business","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d3f830b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087rr/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Table","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The table of the net worth of a farm or business for purposes of making determinations of assets as defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087vv/f"},"text":"section 1087vv(f) of this title","children":[],"tail":" is the following:"},{"tag":"html:table","attrib":{"width":"50%","id":"id0d3f830c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"Farm/Business Net Worth Adjustment","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"If the net worth of a farm or business is—","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Then the adjusted net worth is—","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Less than $1","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$0","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" $1 to $140,000","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40% of net worth of farm/business","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" $140,001 to $415,000","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$56,000 + 50% of net worth over $140,000","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" $415,001 to $695,000","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$193,500 + 60% of net worth over $415,000","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" $695,001 or more","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$361,500 + 100% of net worth over $695,000.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d3f830d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087rr/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revised tables","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For award year 2023–2024 and each subsequent award year, the Secretary shall publish in the Federal Register a revised table of the adjusted net worth of a farm or business for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087vv/f"},"text":"section 1087vv(f) of this title","children":[],"tail":". Such revised table shall be developed—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d3f830e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087rr/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by increasing each dollar amount that refers to net worth of a farm or business by a percentage equal to the percentage increase in the Consumer Price Index between April 2020 and the April in the year prior to the beginning of such award year, and rounding the result to the nearest $5,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d3f830f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087rr/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by adjusting the dollar amounts in the column referring to the adjusted net worth to reflect the changes made pursuant to subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d3f8310-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087rr/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asset protection allowance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For award year 2023–2024 and each subsequent award year, the Secretary shall publish in the Federal Register a revised table of allowances for the purpose of sections 1087","children":[{"tag":"i","attrib":{},"text":"oo","children":[],"tail":"(d)(2), 1087pp(c)(2), and 1087qq(c)(2) of this title. Such revised table shall be developed by determining the present value cost, rounded to the nearest $100, of an annuity that would provide, for each age cohort of 40 and above, a supplemental income at age 65 (adjusted for inflation) equal to the difference between the moderate family income (as most recently determined by the Bureau of Labor Statistics), and the current average social security retirement benefits. For each age cohort below 40, the allowance shall be computed by decreasing the allowance for age 40, as updated, by one-fifteenth for each year of age below age 40 and rounding the result to the nearest $100. In making such determinations—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d3f8311-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087rr/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tables of allowances specified in sections 1087","children":[{"tag":"i","attrib":{},"text":"oo","children":[],"tail":"(d)(2), 1087pp(c)(2), and 1087qq(c)(2) of this title shall be considered to be for award year 2021–2022 for the purposes of calculating inflation;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d3f8312-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087rr/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inflation shall be presumed to be 6 percent per year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d3f8313-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087rr/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of return of an annuity shall be presumed to be 8 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d3f8314-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087rr/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sales commission on an annuity shall be presumed to be 6 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d3f8315-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087rr/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment schedules and rates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For award year 2023–2024 and each subsequent award year, the Secretary shall publish in the Federal Register a revised table of assessments from adjusted available income for the purpose of sections 1087","children":[{"tag":"i","attrib":{},"text":"oo","children":[],"tail":"(e) and 1087qq(d) of this title. Such revised table shall be developed—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d3f8316-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087rr/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by increasing each dollar amount that refers to adjusted available income by a percentage equal to the percentage increase in the Consumer Price Index between April 2020 and the April in the year prior to the beginning of such academic year, rounded to the nearest $100; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d3f8317-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087rr/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by adjusting the other dollar amounts to reflect the changes made pursuant to paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d3f8318-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087rr/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer price index defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “Consumer Price Index” means the Consumer Price Index for All Urban Consumers published by the Department of Labor. Each annual update of tables to reflect changes in the Consumer Price Index shall be corrected for misestimation of actual changes in such Index in previous years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d3f8319-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087rr/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment expense allowance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For award year 2023–2024 and each succeeding award year, the Secretary shall publish in the Federal Register a revised table of employment expense allowances for the purpose of sections 1087","children":[{"tag":"i","attrib":{},"text":"oo","children":[],"tail":"(c)(4), 1087pp(b)(3), and 1087qq(b)(4) of this title. Such revised table shall be developed by increasing the dollar amount specified in sections 1087"},{"tag":"i","attrib":{},"text":"oo","children":[],"tail":"(c)(4), 1087pp(b)(3), and 1087qq(b)(4) of this title by a percentage equal to the percentage increase in the Consumer Price Index, as defined in subsection (f), between April 2020 and the April in the year prior to the beginning of the award year and rounding the result to the nearest $10."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d3f831a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087rr/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification for award year 2023–2024","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For award year 2023–2024, the Secretary shall determine adjusted amounts and prescribe revised tables with respect to the income protection, employment expense, and asset protection allowances and the assessment schedules under sections 1087","children":[{"tag":"i","attrib":{},"text":"oo","children":[],"tail":", 1087pp, and 1087qq of this title, pursuant to this section. The amounts and tables specified in sections 1087"},{"tag":"i","attrib":{},"text":"oo","children":[],"tail":", 1087pp, and 1087qq of this title with respect to such allowances and schedules shall only be used by the Secretary as a baseline for adjustments and table revisions prescribed in accordance with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d3f831b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s478"},"text":"Pub. L. 89–329, title IV, § 478","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s406/a"},"text":"Pub. L. 99–498, title IV, § 406(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1470"},"text":"100 Stat. 1470","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/50/s14/20"},"text":"Pub. L. 100–50, § 14(20)","children":[],"tail":"–(22), "},{"tag":"date","attrib":{"date":"1987-06-03"},"text":"June 3, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/351"},"text":"101 Stat. 351","children":[],"tail":", 352; "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s471/a"},"text":"Pub. L. 102–325, title IV, § 471(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/602"},"text":"106 Stat. 602","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/g/8"},"text":"Pub. L. 103–208, § 2(g)(8)","children":[],"tail":", (9), "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2472"},"text":"107 Stat. 2472","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s476"},"text":"Pub. L. 105–244, title IV, § 476","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1730"},"text":"112 Stat. 1730","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/tVIII/s8017/d"},"text":"Pub. L. 109–171, title VIII, § 8017(d)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/173"},"text":"120 Stat. 173","children":[],"tail":", 174; "},{"tag":"ref","attrib":{"href":"/us/pl/110/84/tVI/s601/d"},"text":"Pub. L. 110–84, title VI, § 601(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/803"},"text":"121 Stat. 803","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tVII/s702/g"},"text":"Pub. L. 116–260, div. FF, title VII, § 702(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3150"},"text":"134 Stat. 3150","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d3f831c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d3f831d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d3f831e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" amended section generally. Prior to amendment, section related to authority to update certain tables, including a revised table of State and other tax allowances, and authority to propose modifications in need analysis methodology."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/84/s601/d/1"},"text":"Pub. L. 110–84, § 601(d)(1)","children":[],"tail":", added par. (1) and struck out former par. (1). Prior to amendment, par. (1) required the Secretary to publish in the Federal Register, for each academic year after academic year 1993–1994, a revised table of income protection allowances for the purpose of sections 1087"},{"tag":"i","attrib":{},"text":"oo","children":[],"tail":"(c)(4) and 1087qq(b)(4) of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/84/s601/d/2"},"text":"Pub. L. 110–84, § 601(d)(2)","children":[],"tail":", substituted “shall be developed for each academic year after academic year 2012–2013, by increasing each of the dollar amounts contained in such section for academic year 2012–2013 by a percentage equal to the estimated percentage increase in the Consumer Price Index (as determined by the Secretary) between December 2011 and the December next preceding the beginning of such academic year, and rounding the result to the nearest $10.” for “shall be developed by increasing each of the dollar amounts contained in such section by a percentage equal to the estimated percentage increase in the Consumer Price Index (as determined by the Secretary) between December 2006 and the December next preceding the beginning of such academic year, and rounding the result to the nearest $10.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s8017/d/1"},"text":"Pub. L. 109–171, § 8017(d)(1)","children":[],"tail":", inserted at end “For the 2007–2008 academic year, the Secretary shall revise the tables in accordance with this paragraph, except that the Secretary shall increase the amounts contained in the table in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087qq/b/4"},"text":"section 1087qq(b)(4) of this title","children":[],"tail":" by a percentage equal to the greater of the estimated percentage increase in the Consumer Price Index (as determined under the preceding sentence) or 5 percent.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s8017/d/2"},"text":"Pub. L. 109–171, § 8017(d)(2)","children":[],"tail":", substituted “2007–2008” for “2000–2001” and “2006” for “1999”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s8017/e"},"text":"Pub. L. 109–171, § 8017(e)","children":[],"tail":", struck out “1087pp(b)(4)(B),” after “1087pp(b)(4)(A),” and substituted “food away from home, apparel, transportation, and household furnishings and operations” for “meals away from home, apparel and upkeep, transportation, and housekeeping services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":