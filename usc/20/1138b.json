{"tag":"section","attrib":{"id":"id0d7b2c64-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1138b"},"text":"§ 1138b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may appoint, for terms not to exceed 3 years, without regard to the provisions of title 5 governing appointments in the competitive service, not more than 7 technical employees to administer this part who may be paid without regard to the provisions of chapter 51 and subchapter III of chapter 53 of such title relating to classification and General Schedule pay rates.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d7b2c65-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s743"},"text":"Pub. L. 89–329, title VII, § 743","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVII/s701"},"text":"Pub. L. 105–244, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1797"},"text":"112 Stat. 1797","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVII/s707/h/2"},"text":"Pub. L. 110–315, title VII, § 707(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3360"},"text":"122 Stat. 3360","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d7b2c66-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d7b2c67-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"