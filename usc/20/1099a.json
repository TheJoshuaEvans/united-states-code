{"tag":"section","attrib":{"id":"id0d633722-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1099a"},"text":"§ 1099a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State responsibilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d633723-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the integrity program authorized by this part, each State, through one State agency or several State agencies selected by the State, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d633724-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnish the Secretary, upon request, information with respect to the process for licensing or other authorization for institutions of higher education to operate within the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d633725-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the Secretary promptly whenever the State revokes a license or other authority to operate an institution of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d633726-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" notify the Secretary promptly whenever the State has credible evidence that an institution of higher education within the State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d633727-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has committed fraud in the administration of the student assistance programs authorized by this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d633728-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has substantially violated a provision of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d633729-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutional responsibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each institution of higher education shall provide evidence to the Secretary that the institution has authority to operate within a State at the time the institution is certified under subpart 3 of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d63372a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s495"},"text":"Pub. L. 89–329, title IV, § 495","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s491/2"},"text":"Pub. L. 105–244, title IV, § 491(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1758"},"text":"112 Stat. 1758","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d63372b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d63372c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d63372d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 1099a to 1099a–3 were omitted in the general amendment of this subpart by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1099a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s494"},"text":"Pub. L. 89–329, title IV, § 494","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s499"},"text":"Pub. L. 102–325, title IV, § 499","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/635"},"text":"106 Stat. 635","children":[],"tail":", authorized State postsecondary review program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1099a–1, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s494A"},"text":"Pub. L. 89–329, title IV, § 494A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s499"},"text":"Pub. L. 102–325, title IV, § 499","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/635"},"text":"106 Stat. 635","children":[],"tail":", related to State postsecondary review entity agreements."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1099a–2, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s494B"},"text":"Pub. L. 89–329, title IV, § 494B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s499"},"text":"Pub. L. 102–325, title IV, § 499","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/637"},"text":"106 Stat. 637","children":[],"tail":", related to Federal reimbursement of State postsecondary review costs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1099a–3, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s494C"},"text":"Pub. L. 89–329, title IV, § 494C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s499"},"text":"Pub. L. 102–325, title IV, § 499","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/637"},"text":"106 Stat. 637","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/i/1"},"text":"Pub. L. 103–208, § 2(i)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2478"},"text":"107 Stat. 2478","children":[],"tail":", related to functions of State review entities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
