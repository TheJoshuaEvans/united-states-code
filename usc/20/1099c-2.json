{"tag":"section","attrib":{"id":"id0d681939-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1099c–2"},"text":"§ 1099c–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d68193a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall review each regulation issued under this subchapter that is in effect at the time of the review and applies to the operations or activities of any participant in the programs assisted under this subchapter. The review shall include a determination of whether the regulation is duplicative, or is no longer necessary. The review may involve one or more of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d68193b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assurance of the uniformity of interpretation and application of such regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d68193c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The establishment of a process for ensuring that eligibility and compliance issues, such as institutional audit, program review, and recertification, are considered simultaneously.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d68193d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A determination of the extent to which unnecessary costs are imposed on institutions of higher education as a consequence of the applicability to the facilities and equipment of such institutions of regulations prescribed for purposes of regulating industrial and commercial enterprises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d68193e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory and statutory relief for small volume institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall review and evaluate ways in which regulations under and provisions of this chapter affecting institution of higher education (other than institutions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002/a/1/C"},"text":"section 1002(a)(1)(C) of this title","children":[],"tail":"), that have received in each of the two most recent award years prior to "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"October 7, 1998","children":[],"tail":", less than $200,000 in funds through this subchapter, may be improved, streamlined, or eliminated."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d68193f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1099c–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subsections (a) and (b), the Secretary shall consult with relevant representatives of institutions participating in the programs authorized by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d681940-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s498B"},"text":"Pub. L. 89–329, title IV, § 498B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s495"},"text":"Pub. L. 105–244, title IV, § 495","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1764"},"text":"112 Stat. 1764","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s498"},"text":"Pub. L. 110–315, title IV, § 498","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3328"},"text":"122 Stat. 3328","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d681941-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d681942-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d681943-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" struck out subsec. (d) which required the Secretary to submit reports to Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d681944-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d681945-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
