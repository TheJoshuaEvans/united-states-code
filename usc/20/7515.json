{"tag":"section","attrib":{"id":"id0e3c321f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515"},"text":null,"children":[{"tag":"num","attrib":{"value":"7515"},"text":"§ 7515.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e3c3220-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e3c3221-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants and contracts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to make direct grants to, or enter into contracts with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e3c3222-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Native Hawaiian educational organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c3223-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Native Hawaiian community-based organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c3224-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public and private nonprofit organizations, agencies, and institutions with experience in developing or operating Native Hawaiian programs or programs of instruction in the Native Hawaiian language;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c3225-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charter schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c3226-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consortia of the organizations, agencies, and institutions described in subparagraphs (A) through (C),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to carry out programs that meet the purposes of this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c3227-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants or contracts to carry out activities described in paragraph (3), the Secretary shall give priority to entities proposing projects that are designed to address—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e3c3228-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning reading and literacy among students in kindergarten through third grade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c3229-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the needs of at-risk children and youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c322a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" needs in fields or disciplines in which Native Hawaiians are underemployed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c322b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of the Hawaiian language in instruction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c322c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities provided through programs carried out under this part may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e3c322d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and maintenance of a statewide Native Hawaiian early education and care system to provide a continuum of services for Native Hawaiian children from the prenatal period of the children through age 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c322e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the operation of family-based education centers that provide such services as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e3c322f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs for Native Hawaiian parents and their infants from the prenatal period of the infants through age 3;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3c3230-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preschool programs for Native Hawaiians; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3c3231-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on, and development and assessment of, family-based, early childhood, and preschool programs for Native Hawaiians;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c3232-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities that enhance beginning reading and literacy in either the Hawaiian or the English language among Native Hawaiian students in kindergarten through grade 3 and assistance in addressing the distinct features of combined English and Hawaiian literacy for Hawaiian speakers in grades 5 and 6;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c3233-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" activities to meet the special needs of Native Hawaiian students with disabilities, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e3c3234-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of such students and their needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3c3235-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of support services to the families of such students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3c3236-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities consistent with the requirements of the Individuals with Disabilities Education Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"20 U.S.C. 1400","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c3237-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" activities that address the special needs of Native Hawaiian students who are gifted and talented, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e3c3238-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational, psychological, and developmental activities designed to assist in the educational progress of those students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3c3239-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities that involve the parents of those students in a manner designed to assist in the educational progress of such students;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c323a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of academic and vocational curricula to address the needs of Native Hawaiian children and adults, including curriculum materials in the Hawaiian language and mathematics and science curricula that incorporate Native Hawaiian tradition and culture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c323b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" professional development activities for educators, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e3c323c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of programs to prepare prospective teachers to address the unique needs of Native Hawaiian students within the context of Native Hawaiian culture, language, and traditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3c323d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in-service programs to improve the ability of teachers who teach in schools with high concentrations of Native Hawaiian students to meet the unique needs of such students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3c323e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/G/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recruitment and preparation of Native Hawaiians, and other individuals who live in communities with a high concentration of Native Hawaiians, to become teachers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c323f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the operation of community-based learning centers that address the needs of Native Hawaiian students, parents, families, and communities through the coordination of public and private programs and services, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e3c3240-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early childhood education programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3c3241-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before, after, and summer school programs, expanded learning time, or weekend academies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3c3242-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/H/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" career and technical education programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3c3243-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/H/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs that recognize and support the unique cultural and educational needs of Native Hawaiian children, and incorporate appropriately qualified Native Hawaiian elders and seniors;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c3244-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" activities, including program co-location, to enable Native Hawaiians to enter and complete programs of postsecondary education, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e3c3245-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/I/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family literacy services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3c3246-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/I/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" counseling, guidance, and support services for students;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c3247-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and data collection activities to determine the educational status and needs of Native Hawaiian children and adults;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c3248-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other research and evaluation activities related to programs carried out under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c3249-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/a/3/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities, consistent with the purposes of this part, to meet the educational needs of Native Hawaiian children and adults.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e3c324a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 5 percent of funds provided to a recipient of a grant or contract under subsection (a) for any fiscal year may be used for administrative purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e3c324b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e3c324c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7514"},"text":"section 7514 of this title","children":[],"tail":" $32,397,000 for each of fiscal years 2017 through 2020."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c324d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds appropriated under this subsection, the Secretary shall reserve $500,000 for each of fiscal years 2017 through 2020 to make a direct grant to the Education Council to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7514"},"text":"section 7514 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c324e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7515/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated under this subsection shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e3c324f-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVI/s6205"},"text":"Pub. L. 89–10, title VI, § 6205","children":[],"tail":", formerly title VII, § 7205, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVII/s701"},"text":"Pub. L. 107–110, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1939"},"text":"115 Stat. 1939","children":[],"tail":"; renumbered title VI, § 6205, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVI"},"text":"Pub. L. 114–95, title VI","children":[],"tail":", §§ 6001(a), (b)(1), (10), 6003(c), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2046"},"text":"129 Stat. 2046","children":[],"tail":", 2047, 2066.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e3c3250-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e3c3251-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e3c3252-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Individuals with Disabilities Education Act, referred to in subsec. (a)(3)(D)(iii), is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230"},"text":"Pub. L. 91–230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/175"},"text":"84 Stat. 175","children":[],"tail":", which is classified generally to chapter 33 (§ 1400 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e3c3253-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7515, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVII/s7205"},"text":"Pub. L. 89–10, title VII, § 7205","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3738"},"text":"108 Stat. 3738","children":[],"tail":", related to elementary school foreign language incentive program, prior to the general amendment of former subchapter VII of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e3c3254-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1)(D), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6003/c/1/A"},"text":"Pub. L. 114–95, § 6003(c)(1)(A)","children":[],"tail":", added subpar. (D) and redesignated former subpar. (D) as (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6003/c/1/B/i"},"text":"Pub. L. 114–95, § 6003(c)(1)(B)(i)","children":[],"tail":", substituted “grade 3” for “third grade” and “grades 5 and 6” for “fifth and sixth grade”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(D)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6003/c/1/B/ii"},"text":"Pub. L. 114–95, § 6003(c)(1)(B)(ii)","children":[],"tail":", substituted “of such students” for “of those students”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(E)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6003/c/1/B/iii"},"text":"Pub. L. 114–95, § 6003(c)(1)(B)(iii)","children":[],"tail":", substituted “educational progress of such students” for “students’ educational progress”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(G)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6003/c/1/B/iv"},"text":"Pub. L. 114–95, § 6003(c)(1)(B)(iv)","children":[],"tail":", substituted “high concentrations of Native Hawaiian students to meet the unique needs of such students; and” for “concentrations of Native Hawaiian students to meet those students’ unique needs; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6003/c/1/B/v/I"},"text":"Pub. L. 114–95, § 6003(c)(1)(B)(v)(I)","children":[],"tail":", substituted “students, parents, families,” for “families” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(H)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6003/c/1/B/v/II"},"text":"Pub. L. 114–95, § 6003(c)(1)(B)(v)(II)","children":[],"tail":", substituted “early childhood education programs” for “preschool programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(H)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6003/c/1/B/v/III"},"text":"Pub. L. 114–95, § 6003(c)(1)(B)(v)(III)","children":[],"tail":", added cl. (ii) and struck out former cl. (ii) which read as follows: “after-school programs;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(H)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6003/c/1/B/v/IV"},"text":"Pub. L. 114–95, § 6003(c)(1)(B)(v)(IV)","children":[],"tail":", substituted “career and technical education programs” for “vocational and adult education programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6003/c/1/B/vi"},"text":"Pub. L. 114–95, § 6003(c)(1)(B)(vi)","children":[],"tail":", added cls. (i) and (ii) and struck out former cls. (i) to (v) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) provision of full or partial scholarships for undergraduate or graduate study that are awarded to students based on their academic promise and financial need, with a priority, at the graduate level, given to students entering professions in which Native Hawaiians are underrepresented;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) family literacy services;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) counseling and support services for students receiving scholarship assistance;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iv) counseling and guidance for Native Hawaiian secondary students who have the potential to receive scholarships; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(v) faculty development activities designed to promote the matriculation of Native Hawaiian students;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6003/c/1/C"},"text":"Pub. L. 114–95, § 6003(c)(1)(C)","children":[],"tail":", struck out par. (4). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) ","children":[{"tag":"inline","attrib":{},"text":"Institutions outside hawaii","children":[],"tail":".—The Secretary shall not establish a policy under this section that prevents a Native Hawaiian student enrolled at a 2- or 4-year degree granting institution of higher education outside of the State of Hawaii from receiving a scholarship pursuant to paragraph (3)(I)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) ","children":[{"tag":"inline","attrib":{},"text":"Scholarship conditions","children":[],"tail":".—The Secretary shall establish conditions for receipt of a scholarship awarded under paragraph (3)(I). The conditions shall require that an individual seeking such a scholarship enter into a contract to provide professional services, either during the scholarship period or upon completion of a program of postsecondary education, to the Native Hawaiian community.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6003/c/2/A"},"text":"Pub. L. 114–95, § 6003(c)(2)(A)","children":[],"tail":", substituted “$32,397,000 for each of fiscal years 2017 through 2020” for “such sums as may be necessary for fiscal year 2002 and each of the 5 succeeding fiscal years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6001/b/10/A"},"text":"Pub. L. 114–95, § 6001(b)(10)(A)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7514"},"text":"section 7514 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6003/c/2/B"},"text":"Pub. L. 114–95, § 6003(c)(2)(B)","children":[],"tail":", substituted “for each of fiscal years 2017 through 2020” for “for fiscal year 2002 and each of the 5 succeeding fiscal years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6001/b/10/B"},"text":"Pub. L. 114–95, § 6001(b)(10)(B)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7514"},"text":"section 7514 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e3c3255-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e3c3256-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
