{"tag":"section","attrib":{"id":"id0ccf5c33-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1041"},"text":null,"children":[{"tag":"num","attrib":{"value":"1041"},"text":"§ 1041.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ccf5c34-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1041/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal control prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to permit, allow, encourage, or authorize any Federal control over any aspect of any private, religious, or home school, whether or not a home school is treated as a private school or home school under State law. This section shall not be construed to prohibit private, religious, or home schools from participation in programs or services under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ccf5c35-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1041/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No change in State control encouraged or required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to encourage or require any change in a State’s treatment of any private, religious, or home school, whether or not a home school is treated as a private school or home school under State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ccf5c36-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1041/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National system of teacher certification or licensure prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to permit, allow, encourage, or authorize the Secretary to establish or support any national system of teacher certification or licensure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ccf5c37-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1041/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to alter or otherwise affect the rights, remedies, and procedures afforded to the employees of local educational agencies under Federal, State, or local laws (including applicable regulations or court orders) or under the terms of collective bargaining agreements, memoranda of understanding, or other agreements between such employees and their employers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ccf5c38-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tII/s261"},"text":"Pub. L. 89–329, title II, § 261","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tII/s201/3"},"text":"Pub. L. 110–315, title II, § 201(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3166"},"text":"122 Stat. 3166","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ccf5c39-3