{"tag":"section","attrib":{"id":"id0c8a3bc2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r"},"text":null,"children":[{"tag":"num","attrib":{"value":"80r"},"text":"§ 80r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c8a3bc3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" since its founding, the United States has grown into a symbol of democracy and freedom around the world, and the legacy of African Americans is rooted in the very fabric of the democracy and freedom of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8a3bc4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" there exists no national museum within the Smithsonian Institution that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c8a3bc5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is devoted to the documentation of African American life, art, history, and culture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8a3bc6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" encompasses, on a national level—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0c8a3bc7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of slavery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c8a3bc8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the era of Reconstruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c8a3bc9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Harlem renaissance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c8a3bca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the civil rights movement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c8a3bcb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other periods associated with African American life, art, history, and culture; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8a3bcc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a National Museum of African American History and Culture would be dedicated to the collection, preservation, research, and exhibition of African American historical and cultural material reflecting the breadth and depth of the experiences of individuals of African descent living in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c8a3bcd-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/184/s2"},"text":"Pub. L. 108–184, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2676"},"text":"117 Stat. 2676","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c8a3bce-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0c8a3bcf-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id0c8a3bd0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/184/s1"},"text":"Pub. L. 108–184, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2676"},"text":"117 Stat. 2676","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/184/s1"},"text":"“This Act [enacting this subchapter] may be cited as the ‘National Museum of African American History and Culture Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
