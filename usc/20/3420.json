{"tag":"section","attrib":{"id":"id0dd81920-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3420"},"text":null,"children":[{"tag":"num","attrib":{"value":"3420"},"text":"§ 3420.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of English Language Acquisition, Language Enhancement, and Academic Achievement for Limited English Proficient Students","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be in the Department an Office of English Language Acquisition, Language Enhancement, and Academic Achievement for Limited English Proficient Students, to be administered by a Director of English Language Acquisition, Language Enhancement, and Academic Achievement for Limited English Proficient Students, who shall be appointed by the Secretary. The Director shall coordinate the administration of bilingual education programs by the Department and shall consult with the Secretary concerning policy decisions affecting bilingual education and minority languages affairs. The Director shall report directly to the Secretary, and shall perform such additional functions as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0dd81921-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tII/s209"},"text":"Pub. L. 96–88, title II, § 209","children":[],"tail":", formerly § 210, "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/675"},"text":"93 Stat. 675","children":[],"tail":"; renumbered § 209, "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tII/s271/a/2"},"text":"Pub. L. 103–382, title II, § 271(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3929"},"text":"108 Stat. 3929","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1072/b"},"text":"Pub. L. 107–110, title X, § 1072(b)","children":[],"tail":", (c)(2)(A), (d), "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2089"},"text":"115 Stat. 2089","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dd81922-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dd81923-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0dd81924-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s209"},"text":"section 209 of Pub. L. 96–88","children":[],"tail":" was renumbered section 208 and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3419"},"text":"section 3419 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/279"},"text":"Pub. L. 107–279","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0dd81925-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110/s1072/d"},"text":"Pub. L. 107–110, § 1072(d)","children":[],"tail":", substituted “Director of English Language Acquisition, Language Enhancement, and Academic Achievement for Limited English Proficient Students” for “Directo