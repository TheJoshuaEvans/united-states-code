{"tag":"section","attrib":{"id":"id0c7e558c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76m"},"text":null,"children":[{"tag":"num","attrib":{"value":"76m"},"text":"§ 76m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Photovoltaic system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c7e558d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may study, plan, design, engineer, and construct a photovoltaic system for the main roof of the John F. Kennedy Center for the Performing Arts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c7e558e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days before beginning construction of the photovoltaic system pursuant to subsection (a), the Board shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Environment and Public Works of the Senate a report on the feasibility and design of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c7e558f-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/874/s7"},"text":"Pub. L. 85–874, § 7","children":[],"tail":", as added, "},{"tag":"ref","attrib":{"href":"/us/pl/110/338/s3"},"text":"Pub. L. 110–338, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3731"},"text":"122 Stat. 3731","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c7e5590-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c7e5591-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0c7e5592-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 76m, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/874/s7"},"text":"Pub. L. 85–874, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1700"},"text":"72 Stat. 1700","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/297"},"text":"Pub. L. 86–297","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-21"},"text":"Sept. 21, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/573"},"text":"73 Stat. 573","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/100/s4"},"text":"Pub. L. 88–100, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-08-19"},"text":"Aug. 19, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/128"},"text":"77 Stat. 128","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/260/s1/2"},"text":"Pub. L. 88–260, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-01-23"},"text":"Jan. 23, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/4"},