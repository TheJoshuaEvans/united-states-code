{"tag":"section","attrib":{"id":"id0e673998-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605"},"text":null,"children":[{"tag":"num","attrib":{"value":"9605"},"text":"§ 9605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional advisory committees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e673999-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning in 2004, the Secretary shall establish a regional advisory committee for each region described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9564/b"},"text":"section 9564(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e67399a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e67399b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The membership of each regional advisory committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e67399c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not exceed 25 members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e67399d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain a balanced representation of States in the region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e67399e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include not more than one representative of each State educational agency geographically located in the region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e67399f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The membership of each regional advisory committee may include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e6739a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Representatives of local educational agencies, including rural and urban local educational agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Representatives of institutions of higher education, including individuals representing university-based education research and university-based research on subjects other than education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Parents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Practicing educators, including classroom teachers, principals, administrators, school board members, and other local school officials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Representatives of business.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Researchers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6739a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In choosing individuals for membership on a regional advisory committee, the Secretary shall consult with, and solicit recommendations from, the chief executive officers of States, chief State school officers, and education stakeholders within the applicable region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6739a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e6739a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Total number","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total number of members on each committee who are selected under subparagraphs (A), (C), and (D) of paragraph (2), collectively, shall exceed the total number of members who are selected under paragraph (1)(C) and subparagraphs (B), (E), and (F) of paragraph (2), collectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissolution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each regional advisory committee shall be dissolved by the Secretary after submission of such committee’s report described in subsection (c)(2) to the Secretary, but each such committee may be reconvened at the discretion of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6739aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each regional advisory committee shall advise the Secretary on the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e6739ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An educational needs assessment of its region (using the results of the assessment conducted under subsection (d)), in order to assist in making decisions regarding the regional educational priorities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6739ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 6 months after the committee is first convened, a report based on the assessment conducted under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6739ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional assessments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each regional advisory committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e6739ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the educational needs within the region to be served;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6739af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in conducting the assessment under paragraph (1), seek input from chief executive officers of States, chief State school officers, educators, and parents (including through a process of open hearings to solicit the views and needs of schools (including public charter schools), teachers, administrators, members of the regional educational laboratory governing board, parents, local educational agencies, librarians, businesses, State educational agencies, and other customers (such as adult education programs) within the region) regarding the need for the activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9564"},"text":"section 9564 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9602"},"text":"section 9602 of this title","children":[],"tail":" and how those needs would be most effectively addressed; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6739b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9605/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit the assessment to the Secretary and to the Director of the Institute of Education Sciences, at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e6739b1-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tII/s206"},"text":"Pub. L. 107–279, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1979"},"text":"116 Stat. 1979","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tII/s203"},"text":"Pub. L. 108–446, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2803"},"text":"118 Stat. 2803","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e6739b2-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e6739b3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e6739b4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/446"},"text":"Pub. L. 108–446","children":[],"tail":" substituted “Institute” for “Academy”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e6739b5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0e6739b6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Committees","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory committees established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a committee established by the President or an officer of the Federal Government, such committee is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a committee established by the Congress, its duration is otherwise provided for by law. See "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
