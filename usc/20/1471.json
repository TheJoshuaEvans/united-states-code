{"tag":"section","attrib":{"id":"id0daf827b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471"},"text":null,"children":[{"tag":"num","attrib":{"value":"1471"},"text":"§ 1471.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parent training and information centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0daf827c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daf827d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants to, and enter into contracts and cooperative agreements with, parent organizations to support parent training and information centers to carry out activities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf827e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of parent organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “parent organization” means a private nonprofit organization (other than an institution of higher education) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daf827f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has a board of directors—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0daf8280-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the majority of whom are parents of children with disabilities ages birth through 26;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0daf8281-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that includes—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0daf8282-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/a/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals working in the fields of special education, related services, and early intervention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0daf8283-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/a/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0daf8284-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the parent and professional members of which are broadly representative of the population to be served, including low-income parents and parents of limited English proficient children; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8285-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has as its mission serving families of children with disabilities who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0daf8286-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are ages birth through 26; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0daf8287-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the full range of disabilities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1401/3"},"text":"section 1401(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daf8288-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each parent training and information center that receives assistance under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daf8289-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide training and information that meets the needs of parents of children with disabilities living in the area served by the center, particularly underserved parents and parents of children who may be inappropriately identified, to enable their children with disabilities to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daf828a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet developmental and functional goals, and challenging academic achievement goals that have been established for all children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf828b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be prepared to lead productive independent adult lives, to the maximum extent possible;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf828c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve the parents of infants, toddlers, and children with the full range of disabilities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1401/3"},"text":"section 1401(3) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf828d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the training and information provided meets the needs of low-income parents and parents of limited English proficient children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf828e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assist parents to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daf828f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" better understand the nature of their children’s disabilities and their educational, developmental, and transitional needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8290-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communicate effectively and work collaboratively with personnel responsible for providing special education, early intervention services, transition services, and related services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8291-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in decisionmaking processes and the development of individualized education programs under subchapter II and individualized family service plans under subchapter III;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8292-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" obtain appropriate information about the range, type, and quality of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0daf8293-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" options, programs, services, technologies, practices and interventions based on scientifically based research, to the extent practicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0daf8294-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resources available to assist children with disabilities and their families in school and at home;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8295-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" understand the provisions of this chapter for the education of, and the provision of early intervention services to, children with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8296-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in activities at the school level that benefit their children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8297-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in school reform activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf8298-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in States where the State elects to contract with the parent training and information center, contract with State educational agencies to provide, consistent with subparagraphs (B) and (D) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1415/e/2"},"text":"section 1415(e)(2) of this title","children":[],"tail":", individuals who meet with parents to explain the mediation process to the parents;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf8299-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist parents in resolving disputes in the most expeditious and effective way possible, including encouraging the use, and explaining the benefits, of alternative methods of dispute resolution, such as the mediation process described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1415/e"},"text":"section 1415(e) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf829a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist parents and students with disabilities to understand their rights and responsibilities under this chapter, including those under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1415/m"},"text":"section 1415(m) of this title","children":[],"tail":" upon the student’s reaching the age of majority (as appropriate under State law);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf829b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist parents to understand the availability of, and how to effectively use, procedural safeguards under this chapter, including the resolution session described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1415/e"},"text":"section 1415(e) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf829c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist parents in understanding, preparing for, and participating in, the process described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1415/f/1/B"},"text":"section 1415(f)(1)(B) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf829d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish cooperative partnerships with community parent resource centers funded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1472"},"text":"section 1472 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf829e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" network with appropriate clearinghouses, including organizations conducting national dissemination activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1463"},"text":"section 1463 of this title","children":[],"tail":" and the Institute of Education Sciences, and with other national, State, and local organizations and agencies, such as protection and advocacy agencies, that serve parents and families of children with the full range of disabilities described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1401/3"},"text":"section 1401(3) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf829f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" annually report to the Secretary on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daf82a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and demographics of parents to whom the center provided information and training in the most recently concluded fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf82a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of strategies used to reach and serve parents, including underserved parents of children with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf82a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/b/12/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of parents served who have resolved disputes through alternative methods of dispute resolution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daf82a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Optional activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A parent training and information center that receives assistance under this section may provide information to teachers and other professionals to assist the teachers and professionals in improving results for children with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daf82a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application for assistance under this section shall identify with specificity the special efforts that the parent organization will undertake—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daf82a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that the needs for training and information of underserved parents of children with disabilities in the area to be served are effectively met; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf82a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to work with community based organizations, including community based organizations that work with low-income parents and parents of limited English proficient children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daf82a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daf82a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daf82a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make not less than 1 award to a parent organization in each State for a parent training and information center that is designated as the statewide parent training and information center; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf82aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a large State, make awards to multiple parent training and information centers, but only if the centers demonstrate that coordinated services and supports will occur among the multiple centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf82ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall select among applications submitted by parent organizations in a State in a manner that ensures the most effective assistance to parents, including parents in urban and rural areas, in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daf82ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daf82ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The board of directors of each parent organization that receives an award under this section shall meet not less than once in each calendar quarter to review the activities for which the award was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf82ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1471/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation award","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When a parent organization requests a continuation award under this section, the board of directors shall submit to the Secretary a written review of the parent training and information program conducted by the parent organization during the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0daf82af-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s671"},"text":"Pub. L. 91–230, title VI, § 671","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2788"},"text":"118 Stat. 2788","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0daf82b0-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0daf82b1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0daf82b2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1471, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s671"},"text":"Pub. L. 91–230, title VI, § 671","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/17/tI/s101"},"text":"Pub. L. 105–17, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-04"},"text":"June 4, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/135"},"text":"111 Stat. 135","children":[],"tail":", related to congressional findings and purposes for subpart 1 of part B