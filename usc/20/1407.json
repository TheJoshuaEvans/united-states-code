{"tag":"section","attrib":{"id":"id0d9c6f74-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1407"},"text":null,"children":[{"tag":"num","attrib":{"value":"1407"},"text":"§ 1407.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d9c6f75-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1407/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State that receives funds under this chapter shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9c6f76-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1407/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that any State rules, regulations, and policies relating to this chapter conform to the purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9c6f77-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1407/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify in writing to local educational agencies located in the State and the Secretary any such rule, regulation, or policy as a State-imposed requirement that is not required by this chapter and Federal regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9c6f78-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1407/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the number of rules, regulations, and policies to which the local educational agencies and schools located in the State are subject under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9c6f79-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1407/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support and facilitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"State rules, regulations, and policies under this chapter shall support and facilitate local educational agency and school-level system improvement designed to enable children with disabilities to meet the challenging State student academic achievement standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9c6f7a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s608"},"text":"Pub. L. 91–230, title VI, § 608","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2661"},"text":"118 Stat. 2661","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9c6f7b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9c6f7c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d9c6f7d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},