{"tag":"section","attrib":{"id":"id0d5e7c8a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1094b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1094b"},"text":"§ 1094b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment of identification numbers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall assign to each participant in subchapter IV programs, including institutions, lenders, and guaranty agencies, a single Department of Education identification number to be used to identify its participation in each of the subchapter IV programs.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d5e7c8b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s487B"},"text":"Pub. L. 89–329, title IV, § 487B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s491"},"text":"Pub. L. 102–325, title IV, § 491","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/630"},"text":"106 Stat. 630","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
