{"tag":"section","attrib":{"id":"id0e6bf52e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9705"},"text":null,"children":[{"tag":"num","attrib":{"value":"9705"},"text":"§ 9705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission personnel matters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e6bf52f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Commission shall serve without compensation in addition to that received for their service as an officer or employee of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6bf530-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Commission shall be allowed travel expenses, including per diem in lieu of subsistence, at rates authorized for employees of agencies under subchapter I of chapter 57 of title 5, while away from their homes or regular places of business in the performance of services for the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6bf531-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9705/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e6bf532-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9705/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office of Financial Education of the Department of the Treasury shall provide assistance to the Commission, upon request of the Commission, without reimbursement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6bf533-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9705/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail of Government employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any Federal Government employee may be detailed to the Commission without reimbursement, and such detail shall be without interruption or loss of civil service status or privilege.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e6bf534-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/159/tV/s516"},"text":"Pub. L. 108–159, title V, § 516","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-04"},"text":"Dec. 4, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2008"},"text":"117 Stat. 2008","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e6bf535-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e6bf536-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e6bf537-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section subject to joint regulations establishing effective dates as prescribed by Federal Reserve Board and Federal Trade Commission, except as otherwise provided, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/159/s3"},"text":"section 3 of Pub. L. 108–159","children":[],"tail":", set out as an Effective Date of 2003 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681"},"text":"section 1681 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
