{"tag":"section","attrib":{"id":"id0de18f2a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3984"},"text":null,"children":[{"tag":"num","attrib":{"value":"3984"},"text":"§ 3984.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de18f2b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3984/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Higher education partnership in education programs and activities; eligible applicants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de18f2c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3984/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An applicant may use payments received under this part in any fiscal year for higher education programs and activities described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f2d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3984/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Grants under this subsection may be used for partnership in education programs—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de18f2e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3984/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the improvement of instruction in mathematics, science, computer science, and engineering education at the postsecondary level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de18f2f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3984/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for awarding scholarships to students at institutions of higher education in the fields of mathematics, science, computer science, and engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de18f30-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3984/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the operation of faculty exchange programs by the institutions of higher education and business concerns within the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de18f31-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3984/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for research in the fields of mathematics, science, computer science, and engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de18f32-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3984/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the acquisition, rehabilitation, and renovation of equipment and instrumentation for use in instruction in the fields of mathematics, science, computer science, and engineering; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de18f33-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3984/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote public understanding of science, mathematics, and computer science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f34-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3984/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Education partnerships under this subsection may include institutions of higher education, business concerns, nonprofit private organizations, local educational agencies, professional mathematic and scientific associations, museums, libraries, educational television stations, and if the State so desires, appropriate State agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de18f35-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3984/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elementary and secondary partnership in education programs and activities; eligible applicants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de18f36-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3984/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An applicant may use payments received under this part in any fiscal year for programs and activities described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f37-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3984/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A local educational agency may carry out an elementary and secondary school partnership in education program under which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de18f38-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3984/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elementary and secondary school teachers in the schools of local educational agencies who teach mathematics, science, or computer science are made available to local business concerns and business concerns with establishments located in the community to serve in such concerns or establishments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de18f39-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3984/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel of local business concerns and business concerns with establishments located in the community serve as consultants, lecturers, teaching assistants, or teachers of mathematics, science, or computer science in the elementary and secondary schools within the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de18f3a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3984/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and retraining is furnished to elementary and secondary school teachers of mathematics, science, and computer science under a cooperative arrangement between the State or local educational agency and appropriate business concerns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de18f3b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3984/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secondary school students observe, participate, and work in local business concerns and business concerns with establishments located in the community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de18f3c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3984/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" computer clubs and extracurricular activities involving modern technologies are established in elementary and secondary schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f3d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3984/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Partnerships under this subsection may include local educational agencies, business concerns, nonprofit private organizations, institutions of higher education, professional mathematic and scientific associations, museums, libraries, educational television stations, and, if the State so desires, appropriate State agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de18f3e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tIII/s305"},"text":"Pub. L. 98–377, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-11"},"text":"Aug. 11, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1284"},"text":"98 Stat. 1284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tVI/s6031/b/2"},"text":"Pub. L. 100–418, title VI, § 6031(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1483"},"text":"102 Stat. 1483","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de18f3f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de18f40-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0de18f41-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsecs. (a)(1), (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" substituted “part” for “subchapter” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
