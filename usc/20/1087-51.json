{"tag":"section","attrib":{"id":"id0d27b4b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–51"},"text":null,"children":[{"tag":"num","attrib":{"value":"1087–51"},"text":"§ 1087–51.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose; appropriations authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d27b4b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–51/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this part is to stimulate and promote the part-time employment of students who are enrolled as undergraduate, graduate, or professional students and who are in need of earnings from employment to pursue courses of study at eligible institutions, and to encourage students receiving Federal student financial assistance to participate in community service activities that will benefit the Nation and engender in the students a sense of social responsibility and commitment to the community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d27b4b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–51/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this part, such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d27b4b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–51/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Community services” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, the term “community services” means services which are identified by an institution of higher education, through formal or informal consultation with local nonprofit, governmental, and community-based organizations, as designed to improve the quality of life for community residents, particularly low-income individuals, or to solve particular problems related to their needs, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d27b4b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–51/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such fields as health care, child care (including child care services provided on campus that are open and accessible to the community), literacy training, education (including tutorial services), welfare, social services, transportation, housing and neighborhood improvement, public safety, emergency preparedness and response, crime prevention and control, recreation, rural development, and community improvement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d27b4b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–51/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work in a project, as defined in section 12511(20) ","children":[{"tag":"ref","attrib":{"idref":"fn002079"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002079"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 42;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d27b4b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–51/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support services to students with disabilities, including students with disabilities who are enrolled at the institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d27b4b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–51/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" activities in which a student serves as a mentor for such purposes as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d27b4b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–51/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tutoring;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d27b4ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–51/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting educational and recreational activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d27b4bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–51/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" counseling, including career counseling.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d27b4bc-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s441"},"text":"Pub. L. 89–329, title IV, § 441","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s403/a"},"text":"Pub. L. 99–498, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1429"},"text":"100 Stat. 1429","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s441/b"},"text":"Pub. L. 102–325, title IV, § 441(b)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/563"},"text":"106 Stat. 563","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s111/b/3"},"text":"Pub. L. 103–82, title I, § 111(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/860"},"text":"107 Stat. 860","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s441"},"text":"Pub. L. 105–244, title IV, § 441","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1711"},"text":"112 Stat. 1711","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s441"},"text":"Pub. L. 110–315, title IV, § 441","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3258"},"text":"122 Stat. 3258","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d27b4bd-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d27b4be-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d27b4bf-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12511/20"},"text":"Section 12511(20) of title 42","children":[],"tail":", referred to in subsec. (c)(2), was redesignated section 12511(35) by "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1102/b/1"},"text":"Pub. L. 111–13, title I, § 1102(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1467"},"text":"123 Stat. 1467","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d27b4c0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2751"},"text":"section 2751 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to transfer to this section. See note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was originally enacted as section 121 (and later renumbered section 141) of the Economic Opportunity Act of 1964, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452"},"text":"Pub. L. 88–452","children":[],"tail":", at which time it was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2751"},"text":"section 2751 of Title 42","children":[],"tail":", The Public Health and Welfare. It was renumbered as section 441 of title IV of the Higher Education Act of 1965, "},{"tag":"ref","attrib":{"href":"/us/pl/89/329"},"text":"Pub. L. 89–329","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/90/575/s131/a"},"text":"Pub. L. 90–575, § 131(a)","children":[],"tail":", (b)(1), and later editorially transferred to this section to merge with the rest of the Act, which is classified to this chapter. For complete credit information on acts affecting this section prior to "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":", see Prior Provisions note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d27b4c1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s441"},"text":"section 441 of Pub. L. 89–329","children":[],"tail":", title IV, formerly "},{"tag":"ref","attrib":{"href":"/us/pl/88/452/tI/s141"},"text":"Pub. L. 88–452, title I, § 141","children":[],"tail":", formerly § 121, "},{"tag":"date","attrib":{"date":"1964-08-20"},"text":"Aug. 20, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/513"},"text":"78 Stat. 513","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s441/2"},"text":"Pub. L. 89–329, title IV, § 441(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1249"},"text":"79 Stat. 1249","children":[],"tail":"; renumbered § 141, "},{"tag":"ref","attrib":{"href":"/us/pl/90/222/tI/s111/a"},"text":"Pub. L. 90–222, title I, § 111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-23"},"text":"Dec. 23, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/726"},"text":"81 Stat. 726","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s441"},"text":"Pub. L. 89–329, title IV, § 441","children":[],"tail":", and amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/575/tI"},"text":"Pub. L. 90–575, title I","children":[],"tail":", §§ 131(a), (b)(1), 132, 133(a), "},{"tag":"date","attrib":{"date":"1968-10-16"},"text":"Oct. 16, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1028"},"text":"82 Stat. 1028","children":[],"tail":", 1029; "},{"tag":"ref","attrib":{"href":"/us/pl/91/95/s5"},"text":"Pub. L. 91–95, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-10-22"},"text":"Oct. 22, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/143"},"text":"83 Stat. 143","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/318/tI"},"text":"Pub. L. 92–318, title I","children":[],"tail":", §§ 135, 135A(a), "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/270"},"text":"86 Stat. 270","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/482/tI/s128/a"},"text":"Pub. L. 94–482, title I, § 128(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2143"},"text":"90 Stat. 2143","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tIV/s431"},"text":"Pub. L. 96–374, title IV, § 431","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1433"},"text":"94 Stat. 1433","children":[],"tail":", stated purpose of this part and authorized appropriations for fiscal years 1981 to 1985, prior to the general revision of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s441"},"text":"section 441 of Pub. L. 89–329","children":[],"tail":", title IV, "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1249"},"text":"79 Stat. 1249","children":[],"tail":", which amended this section and former sections 2752 to 2756 and 2761 of Title 42, The Public Health and Welfare, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/90/575/tI/s131/a"},"text":"Pub. L. 90–575, title I, § 131(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-16"},"text":"Oct. 16, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1028"},"text":"82 Stat. 1028","children":[],"tail":". Because the repeal happened in order to accommodate the new section 441 resulting from the renumbering of former "},{"tag":"ref","attrib":{"href":"/us/pl/88/452/s141"},"text":"section 141 of Pub. L. 88–452","children":[],"tail":", the amendments made by prior section 441 were not treated as being struck out."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d27b4c2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s441/1"},"text":"Pub. L. 110–315, § 441(1)","children":[],"tail":", substituted “such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years” for “$1,000,000,000 for fiscal year 1999 and such sums as may be necessary for each of the 4 succeeding fiscal years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s441/2"},"text":"Pub. L. 110–315, § 441(2)","children":[],"tail":", inserted “emergency preparedness and response,” after “public safety,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s441/a"},"text":"Pub. L. 105–244, § 441(a)","children":[],"tail":", substituted “$1,000,000,000 for fiscal year 1999” for “$800,000,000 for fiscal year 1993”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s441/b/1"},"text":"Pub. L. 105–244, § 441(b)(1)","children":[],"tail":", inserted “(including child care services provided on campus that are open and accessible to the community)” after “child care”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s441/b/2"},"text":"Pub. L. 105–244, § 441(b)(2)","children":[],"tail":", inserted “, including students with disabilities who are enrolled at the institution” before the semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":" substituted “a project, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12511/20"},"text":"section 12511(20) of title 42","children":[],"tail":"” for “service opportunities or youth corps as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12511"},"text":"section 12511 of title 42","children":[],"tail":", and service in the agencies, institutions and activities designated in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12544/a"},"text":"section 12544(a) of title 42","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s441/b"},"text":"Pub. L. 102–325, § 441(b)","children":[],"tail":", inserted before period at end “, and to encourage students receiving Federal student financial assistance to participate in community service activities that will benefit the Nation and engender in the students a sense of social responsibility and commitment to the community”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s441/c"},"text":"Pub. L. 102–325, § 441(c)","children":[],"tail":", amended subsec. (b) generally, substituting present provisions for former provisions which authorized appropriations for fiscal years 1987 to 1991."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s441/d"},"text":"Pub. L. 102–325, § 441(d)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d27b4c3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d27b4c4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d27b4c5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s123"},"text":"section 123 of Pub. L. 103–82","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1701"},"text":"section 1701 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d27b4c6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/s2"},"text":"section 2 of Pub. L. 102–325","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0d27b4c7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Part C of Title I of the Economic Opportunity Act of 1964","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/575/tI/s131/c"},"text":"Pub. L. 90–575, title I, § 131(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-16"},"text":"Oct. 16, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1028"},"text":"82 Stat. 1028","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/575/tI/s131/c"},"text":"“Any reference to any provision of part C of title I of the Economic Opportunity Act of 1964 in any law of the United States shall be deemed to be a reference to the corresponding provision of part C of title IV of the Higher Education Act of 1965 [this part] as amended by this section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
