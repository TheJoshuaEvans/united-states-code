{"tag":"section","attrib":{"id":"id0c831017-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s77d"},"text":null,"children":[{"tag":"num","attrib":{"value":"77d"},"text":"§ 77d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer or loan of aeronautical or space flight equipment to museum","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The heads of executive departments and independent agencies of the Government are authorized to transfer or loan to said national air and space museum without charge therefor, aircraft, spacecraft, aircraft and spacecraft parts, instruments, engines, or other aeronautical and space flight equipment or records for exhibition, historical, or educational purposes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c831018-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-12/ch955/s5/a"},"text":"Aug. 12, 1946, ch. 955, § 5(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/998"},"text":"60 Stat. 998","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/509"},"text":"Pub. L. 89–509","children":[],"tail":", pt. I, § 8, "},{"tag":"date","attrib":{"date":"1966-07-19"},"text":"July 19, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/311"},"text":"80 Stat. 311","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c831019-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c83101a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0c83101b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consists of subsec. (a) of section 5 of act ","children":[{"tag":"date","attrib":{"date":"1946-08-12"},"text":"Aug. 12, 1946","children":[],"tail":". Subsec. (b) of said section is set out as a note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0c83101c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/509"},"text":"Pub. L. 89–509","children":[],"tail":" inserted “and independent agencies” after “departments”, “and space” after “national air”, “spacecraft,” after “aircraft,”, “and spacecraft” after “aircraft” in phrase “aircraft parts”, and “and space flight” after “aeronautical”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0c83101d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0c83101e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Acceptance of Statue of General Mitchell","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-12/ch955/s5/b"},"text":"Act Aug. 12, 1946, ch. 955, § 5(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/998"},"text":"60 Stat. 998","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/89/509"},"text":"Pub. L. 89–509","children":[],"tail":", pt. I, § 9, "},{"tag":"date","attrib":{"date":"1966-07-19"},"text":"July 19, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/311"},"text":"80 Stat. 311","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/509"},"text":"“The Secretary of the Smithsonian Institution, with the advice of the Commission of Fine Arts, is authorized (1) to accept as a gift to the Smithsonian Institution from George H. Stephenson, of Philadelphia, Pennsylvania, a statue of Brigadier General William L. Mitchell of such character as may be deemed appropriate, and (2) without expense to the United States, to cause such statue to be erected at a suitable location on the grounds of the national air and space museum.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
