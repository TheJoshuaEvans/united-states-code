{"tag":"section","attrib":{"id":"id0d84a1b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161f"},"text":"§ 1161f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Teach For America","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d84a1b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a1b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grantee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “grantee” means Teach For America, Inc.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a1ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9214/c/12/A"},"text":"Pub. L. 114–95, title IX, § 9214(c)(12)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2164"},"text":"129 Stat. 2164","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a1bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-need local educational agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “high-need local educational agency” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1021"},"text":"section 1021 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a1bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amounts appropriated under subsection (f), the Secretary is authorized to award a five-year grant to Teach For America, Inc., the national teacher corps of outstanding recent college graduates who commit to teach for two years in underserved communities in the United States, to implement and expand its program of recruiting, selecting, training, and supporting new teachers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a1bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the grant program under subsection (b), the Secretary shall enter into an agreement with the grantee under which the grantee agrees to use the grant funds provided under this section to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a1be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide teachers who meet the applicable State certification and licensure requirements, including any requirements for certification obtained through alternative routes to certification, or, with regard to special education teachers, the qualifications described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1412/a/14/C"},"text":"section 1412(a)(14)(C) of this title","children":[],"tail":", to high-need local educational agencies in urban and rural communities;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a1bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay the costs of recruiting, selecting, training, and supporting new teachers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a1c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve a substantial number and percentage of underserved students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a1c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a1c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grant funds provided under this section shall be used by the grantee to carry out each of the following activities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a1c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recruiting and selecting teachers through a highly selective national process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a1c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing preservice training to such teachers through a rigorous summer institute that includes hands-on teaching experience and significant exposure to education coursework and theory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a1c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Placing such teachers in schools and positions designated by high-need local educational agencies as high-need placements serving underserved students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a1c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing ongoing professional development activities for such teachers’ first two years in the classroom, including regular classroom observations and feedback, and ongoing training and support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a1c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The grantee shall use all grant funds received under this section to support activities related directly to the recruitment, selection, training, and support of teachers as described in subsection (b), except that funds may be used for non-programmatic costs in accordance with subsection (f)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a1c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports and evaluations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a1c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The grantee shall provide to the Secretary an annual report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a1ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data on the number and quality of the teachers provided to local educational agencies through a grant under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a1cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an externally conducted analysis of the satisfaction of local educational agencies and principals with the teachers so provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a1cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comprehensive data on the background of the teachers chosen, the training such teachers received, the placement sites of such teachers, the professional development of such teachers, and the retention of such teachers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a1cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a1ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From funds appropriated under subsection (f), the Secretary shall provide for a study that examines the achievement levels of the students taught by the teachers assisted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a1cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student achievement gains compared","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The study shall compare, within the same schools, the achievement gains made by students taught by teachers who are assisted under this section with the achievement gains made by students taught by teachers who are not assisted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a1d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for such a study not less than once every three years, and each such study shall include multiple placement sites and multiple schools within placement sites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a1d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each such study shall meet the peer review standards of the education research community. Further, the peer review standards shall ensure that reviewers are practicing researchers and have expertise in assessment systems, accountability, psychometric measurement and statistics, and instruction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a1d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounting, financial reporting, and internal control systems","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a1d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The grantee shall contract with an independent auditor to conduct a comprehensive review of the grantee’s accounting, financial reporting, and internal control systems. Such review shall assess whether that grantee’s accounting, financial reporting, and internal control systems are designed to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d84a1d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information that is complete, accurate, and reliable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a1d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonably detect and prevent material misstatements, as well as fraud, waste, and abuse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a1d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/e/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information to demonstrate the grantee’s compliance with related Federal programs, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a1d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the grantee receives funds to carry out this section for the first fiscal year in which funds become available to carry out this section after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", the independent auditor shall complete the review required by this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a1d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after the grantee receives funds to carry out this section for the first fiscal year in which funds become available to carry out this section after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", the independent auditor shall submit a report to the authorizing committees and the Secretary of the findings of the review required under this paragraph, including any recommendations of the independent auditor, as appropriate, with respect to the grantee’s accounting, financial reporting, and internal control systems."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a1d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a1da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount authorized to be appropriated to carry out this section shall not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a1db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a1dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000,000 for fiscal year 2010; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a1dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as may be necessary for each of the four succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a1de-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161f/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The grantee shall not use more than 5 percent of Federal funds made available under this section for non-programmatic costs to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d84a1df-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s806"},"text":"Pub. L. 89–329, title VIII, § 806","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3390"},"text":"122 Stat. 3390","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9214/c/12"},"text":"Pub. L. 114–95, title IX, § 9214(c)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2164"},"text":"129 Stat. 2164","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d84a1e0-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d84a1e1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d84a1e2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9214/c/12/A"},"text":"Pub. L. 114–95, § 9214(c)(12)(A)","children":[],"tail":", struck out par. (2). Text read as follows: “The term ‘highly qualified’ has the meaning given the term in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1401"},"text":"section 1401 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9214/c/12/B"},"text":"Pub. L. 114–95, § 9214(c)(12)(B)","children":[],"tail":", substituted “teachers who meet the applicable State certification and licensure requirements, including any requirements for certification obtained through alternative routes to certification, or, with regard to special education teachers, the qualifications described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1412/a/14/C"},"text":"section 1412(a)(14)(C) of this title","children":[],"tail":",” for “highly qualified teachers”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d84a1e3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d84a1e4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"se