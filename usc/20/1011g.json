{"tag":"section","attrib":{"id":"id0cbeb9df-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1011g"},"text":"§ 1011g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of peer review process","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All applications submitted under the provisions of this chapter which require peer review shall be read by a panel of readers composed of individuals selected by the Secretary, which shall include outside readers who are not employees of the Federal Government. The Secretary shall ensure that no individual assigned under this section to review any application has any conflict of interest with regard to that application which might impair the impartiality with which that individual conducts the review under this section.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0cbeb9e0-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s118"},"text":"Pub. L. 89–329, title I, § 118","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tI/s101/a"},"text":"Pub. L. 105–244, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1595"},"text":"112 Stat. 1595","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cbeb9e1-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cbeb9e2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cbeb9e3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1145d–1"},"text":"section 1145d–1 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 1011g, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s128"},"text":"Pub. L. 89–329, title I, § 128","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tI/s101"},"text":"Pub. L. 102–325, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/464"},"text":"106 Stat. 464","children":[],"tail":", related to reports and evaluation of programs, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
