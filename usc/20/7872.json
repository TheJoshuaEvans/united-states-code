{"tag":"section","attrib":{"id":"id0e4f452a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7872"},"text":null,"children":[{"tag":"num","attrib":{"value":"7872"},"text":"§ 7872.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval and disapproval of local educational agency applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e4f452b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7872/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application submitted by a local educational agency pursuant to section 6612(b), 7116, 7174(b) or 7845 of this title, shall be approved by the State educational agency unless the State educational agency makes a written determination (which shall include the supporting information and rationale for such determination), prior to the expiration of the 120-day period beginning on the date on which the State educational agency received the application, that the application is not in compliance with section 6612(b), 7116, or 7174(b) of this title, or part C, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4f452c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7872/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval process","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e4f452d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7872/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State educational agency shall not finally disapprove an application submitted under section 6612(b), 7116, 7174(b) or 7845 of this title except after giving the local educational agency notice and opportunity for a hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4f452e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7872/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the State educational agency finds that the application submitted under section 6612(b), 7116, 7174(b) or 7845 of this title is not in compliance, in whole or in part, with section 6612(b), 7116, or 7174(b) of this title, or part C, respectively, the State educational agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4f452f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7872/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immediately notify the local educational agency of such determination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4f4530-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7872/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a detailed description of the specific provisions of the application that the State determines fail to meet the requirements, in whole or in part, of such section or part, as applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4f4531-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7872/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer the local educational agency an opportunity to revise and resubmit its application within 45 days of such determination, including the chance for the local educational agency to present supporting information to clearly demonstrate that the application meets the requirements of such section or part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4f4532-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7872/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance, upon request of the local educational agency, in order to assist the local educational agency to meet the requirements of such section or part, as applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4f4533-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7872/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a hearing within 30 days of the application’s resubmission under subparagraph (C), unless a local educational agency declines the opportunity for such a hearing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4f4534-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7872/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request additional information, only as to the noncompliant provisions, needed to make the application compliant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4f4535-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7872/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Response","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the local educational agency responds to the State educational agency’s notification described in paragraph (2)(A) prior to the expiration of the 45-day period beginning on the date on which the local educational agency received the notification, and resubmits the application as described in paragraph (2)(C), the State educational agency shall approve such application unless the State educational agency determines the application does not meet the requirements of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4f4536-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7872/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to respond","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the local educational agency does not respond to the State educational agency’s notification described in paragraph (2)(A) prior to the expiration of the 45-day period beginning on the date on which the local educational agency received the notification, such application shall be deemed to be disapproved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e4f4537-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8452"},"text":"Pub. L. 89–10, title VIII, § 8452","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII/s8014"},"text":"Pub. L. 114–95, title VIII, § 8014","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2108"},"text":"129 Stat. 2108","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e4f4538-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e4f4539-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e4f453a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 7872 to 7874 were omitted in the general amendment of former subchapter IX of this chapter by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7872, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIX/s9152"},"text":"Pub. L. 89–10, title IX, § 9152","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3793"},"text":"108 Stat. 3793","children":[],"tail":", related to peer review of applications."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7873, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIX/s9153"},"text":"Pub. L. 89–10, title IX, § 9153","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3793"},"text":"108 Stat. 3793","children":[],"tail":", related to preference for Indian applicants for grants."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7874, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIX/s9154"},"text":"Pub. L. 89–10, title IX, § 9154","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3793"},"text":"108 Stat. 3793","children":[],"tail":", related to minimum grant criteria."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e4f453b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e4f453c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
