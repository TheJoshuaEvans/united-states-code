f":"/us/stat/79/1266"},"text":"79 Stat. 1266","children":[],"tail":", related to stipends for persons attending faculty development program institutes, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/96/374"},"text":"Pub. L. 96–374","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d740087-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/s621"},"text":"Pub. L. 110–315, § 621","children":[],"tail":". See 2008 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s621/2"},"text":"Pub. L. 110–315, § 621(2)","children":[],"tail":", (3), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":", redesignated par. (5) as (2) and substituted “comprehensive foreign language and area or international studies center” for “comprehensive language and area center”. Former par. (2) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s621/2"},"text":"Pub. L. 110–315, § 621(2)","children":[],"tail":", (4), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":", redesignated par. (9) as (3) and substituted semicolon for period at end. Former par. (3) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s621/2"},"text":"Pub. L. 110–315, § 621(2)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":", redesignated par. (3) as (4). Former par. (4) redesignated (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s621/5"},"text":"Pub. L. 110–315, § 621(5)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s621/2"},"text":"Pub. L. 110–315, § 621(2)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":", redesignated par. (5) as (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s621/2"},"text":"Pub. L. 110–315, § 621(2)","children":[],"tail":", (6), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":", redesignated par. (8) as (6) and struck out “and” after semicolon. Former par. (6) redesignated (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s621/1"},"text":"Pub. L. 110–315, § 621(1)","children":[],"tail":", (2), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":", redesignated par. (2) as (7) and struck out former par. (7) which read as follows: “the term ‘critical languages’ means each of the languages contained in the list of critical languages designated by the Secretary pursuant to section 212(d) of the Education for Economic Security Act (50 Fed. Reg. 149, 31413), except that, in the implementation of this definition, the Secretary may set priorities according to the purposes of this subchapter;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s621/2"},"text":"Pub. L. 110–315, § 621(2)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":", redesignated par. (4) as (8). Former par. (8) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s621/7"},"text":"Pub. L. 110–315, § 621(7)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":", added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s621/2"},"text":"Pub. L. 110–315, § 621(2)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":", redesignated par. (9) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s621/2"},"text":"Pub. L. 110–315, § 621(2)","children":[],"tail":", (8), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":", redesignated par. (6) as (10) and substituted “undergraduate foreign language and area or international studies center” for “undergraduate language and area center” and a period for the semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s102/b/8"},"text":"Pub. L. 105–244, § 102(b)(8)","children":[],"tail":", substituted “section 1001” for “section 1141(a)” in two places and “of section 1001” for “of 1141(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s604/a"},"text":"Pub. L. 105–244, § 604(a)","children":[],"tail":", added par. (9)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d740088-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d740089-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" effective as if enacted on the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/s3"},"text":"section 3 of Pub. L. 111–39","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d74008a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"t