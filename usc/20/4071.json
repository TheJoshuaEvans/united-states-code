{"tag":"section","attrib":{"id":"id0de400e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4071"},"text":null,"children":[{"tag":"num","attrib":{"value":"4071"},"text":"§ 4071.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of equal access prohibited","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de400e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4071/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction of limited open forum on basis of religious, political, philosophical, or other speech content prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any public secondary school which receives Federal financial assistance and which has a limited open forum to deny equal access or a fair opportunity to, or discriminate against, any students who wish to conduct a meeting within that limited open forum on the basis of the religious, political, philosophical, or other content of the speech at such meetings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de400e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4071/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Limited open forum” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A public secondary school has a limited open forum whenever such school grants an offering to or opportunity for one or more noncurriculum related student groups to meet on school premises during noninstructional time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de400ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4071/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fair opportunity criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Schools shall be deemed to offer a fair opportunity to students who wish to conduct a meeting within its limited open forum if such school uniformly provides that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de400eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4071/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the meeting is voluntary and student-initiated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de400ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4071/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is no sponsorship of the meeting by the school, the government, or its agents or employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de400ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4071/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees or agents of the school or government are present at religious meetings only in a nonparticipatory capacity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de400ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4071/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the meeting does not materially and substantially interfere with the orderly conduct of educational activities within the school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de400ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4071/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonschool persons may not direct, conduct, control, or regularly attend activities of student groups.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de400f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4071/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of subchapter with respect to certain rights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter shall be construed to authorize the United States or any State or political subdivision thereof—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de400f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4071/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to influence the form or content of any prayer or other religious activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de400f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4071/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require any person to participate in prayer or other religious activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de400f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4071/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expend public funds beyond the incidental cost of providing the space for student-initiated meetings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de400f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4071/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to compel any school agent or employee to attend a school meeting if the content of the speech at the meeting is contrary to the beliefs of the agent or employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de400f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4071/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to sanction meetings that are otherwise unlawful;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de400f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4071/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit the rights of groups of students which are not of a specified numerical size; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de400f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4071/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to abridge the constitutional rights of any person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de400f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4071/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal financial assistance to schools unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the availability of any other remedy under the Constitution or the laws of the United States, nothing in this subchapter shall be construed to authorize the United States to deny or withhold Federal financial assistance to any school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de400f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4071/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of schools with respect to order, discipline, well-being, and attendance concerns","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to limit the authority of the school, its agents or employees, to maintain order and discipline on school premises, to protect the well-being of students and faculty, and to assure that attendance of students at meetings is voluntary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de400fa-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tVIII/s802"},"text":"Pub. L. 98–377, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-11"},"text":"Aug. 11, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1302"},"text":"98 Stat. 1302","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de400fb-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0de400fc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id0de400fd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tVIII/s801"},"text":"Pub. L. 98–377, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-11"},"text":"Aug. 11, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1302"},"text":"98 Stat. 1302","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/377/tVIII/s801"},"text":"“This title [enacting this subchapter] may be cited as ‘The Equal Access Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
