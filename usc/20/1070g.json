{"tag":"section","attrib":{"id":"id0cf33836-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070g"},"text":"§ 1070g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this subpart:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cf33837-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible institution” means an institution of higher education, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"section 1002 of this title","children":[],"tail":", that the Secretary determines—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cf33838-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides high quality teacher preparation and professional development services, including extensive clinical experience as a part of pre-service preparation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cf33839-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is financially responsible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cf3383a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides pedagogical course work, or assistance in the provision of such coursework, including the monitoring of student performance, and formal instruction related to the theory and practices of teaching; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cf5812b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides supervision and support services to teachers, or assistance in the provision of such services, including mentoring focused on developing effective teaching skills and strategies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf5812c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post-baccalaureate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “post-baccalaureate” means a program of instruction for individuals who have completed a baccalaureate degree, that does not lead to a graduate degree, and that consists of courses required by a State in order for a teacher candidate to receive a professional certification or licensing credential that is required for employment as a teacher in an elementary school or secondary school in that State, except that such term shall not include any program of instruction offered by an eligible institution that offers a baccalaureate degree in education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf5812d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Teacher candidate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “teacher candidate” means a student or teacher described in subparagraph (A) or (B) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070g–2/a/2"},"text":"section 1070g–2(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cf5812e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s420L"},"text":"Pub. L. 89–329, title IV, § 420L","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/84/tI/s104"},"text":"Pub. L. 110–84, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/786"},"text":"121 Stat. 786","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/153/s3/1"},"text":"Pub. L. 110–153, § 3(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-21"},"text":"Dec. 21, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1824"},"text":"121 Stat. 1824","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cf5812f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cf58130-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cf58131-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Par. (1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/153"},"text":"Pub. L. 110–153","children":[],"tail":" substituted “responsible” for “sound”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cf58132-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0cf58133-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subpart effective ","children":[{"tag":"date","attrib":{"date":"2007-10-01"},"text":"Oct. 1, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/84/s1/c"},"text":"section 1(c) of Pub. L. 110–84","children":[],"tail":", set out as an Effective Date of 2007 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a"},"text":"section 1070a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
