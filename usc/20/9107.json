{"tag":"section","attrib":{"id":"id0e58e1d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9107"},"text":null,"children":[{"tag":"num","attrib":{"value":"9107"},"text":"§ 9107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards and medals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director, with the advice of the Museum and Library Services Board, may annually award national awards and medals for library and museum services to outstanding libraries and museums that have made significant contributions in service to their communities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e58e1d9-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/462/tII/s209"},"text":"Pub. L. 94–462, title II, § 209","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/81/tI/s105"},"text":"Pub. L. 108–81, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-25"},"text":"Sept. 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/996"},"text":"117 Stat. 996","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/340/tI/s105"},"text":"Pub. L. 111–340, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3598"},"text":"124 Stat. 3598","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e58e1da-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e58e1db-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e58e1dc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/340"},"text":"Pub. L. 111–340","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows: “The Director, with the advice of the Museum and Library Services Board, may annually award National Awards for Library Service and National Awards for Museum Service to outstanding libraries and outstanding museums, respectively, that have made significant contributions in service to their communities.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
