{"tag":"section","attrib":{"id":"id0db6ae67-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2006"},"text":null,"children":[{"tag":"num","attrib":{"value":"2006"},"text":"§ 2006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of scholars","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0db6ae68-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nationwide competition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation is authorized, either directly or by contract, to provide for the conduct of a nationwide competition for the purpose of selecting Truman scholars.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db6ae69-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall adopt selection procedures which shall assure that at least one Truman scholar shall be selected each year from each State in which there is at least one resident applicant who meets the minimum criteria established by the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0db6ae6a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/642/s7"},"text":"Pub. L. 93–642, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2278"},"text":"88 Stat. 2278","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
