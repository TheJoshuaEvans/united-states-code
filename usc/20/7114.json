{"tag":"section","attrib":{"id":"id0e2464d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114"},"text":null,"children":[{"tag":"num","attrib":{"value":"7114"},"text":"§ 7114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State use of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e2464d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State that receives an allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7113"},"text":"section 7113 of this title","children":[],"tail":" for a fiscal year shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2464d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reserve not less than 95 percent of the allotment to make allocations to local educational agencies under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7115"},"text":"section 7115 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2464d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reserve not more than 1 percent of the allotment for the administrative costs of carrying out its responsibilities under this subpart, including public reporting on how funds made available under this subpart are being expended by local educational agencies, including the degree to which the local educational agencies have made progress toward meeting the objectives and outcomes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7116/e/1/E"},"text":"section 7116(e)(1)(E) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2464d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the amount made available to the State and not reserved under paragraphs (1) and (2) for activities described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2464d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State that receives an allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7113"},"text":"section 7113 of this title","children":[],"tail":" shall use the funds available under subsection (a)(3) for activities and programs designed to meet the purposes of this subpart, which may include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2464d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing monitoring of, and training, technical assistance, and capacity building to, local educational agencies that receive an allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7115"},"text":"section 7115 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2464da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and eliminating State barriers to the coordination and integration of programs, initiatives, and funding streams that meet the purposes of this subpart, so that local educational agencies can better coordinate with other agencies, schools, and community-based services and programs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2464db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" supporting local educational agencies in providing programs and activities that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2464dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" offer well-rounded educational experiences to all students, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7117"},"text":"section 7117 of this title","children":[],"tail":", including female students, minority students, English learners, children with disabilities, and low-income students who are often underrepresented in critical and enriching subjects, which may include—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0e2464dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" increasing student access to and improving student engagement and achievement in—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e2464de-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high-quality courses in science, technology, engineering, and mathematics, including computer science;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e2464df-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities and programs in music and the arts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e2464e0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign languages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e2464e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" accelerated learning programs that provide—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id0e2464e2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/A/i/IV/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" postsecondary level courses accepted for credit at institutions of higher education, including dual or concurrent enrollment programs, and early college high schools; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id0e2464e3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/A/i/IV/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" postsecondary level instruction and examinations that are accepted for credit at institutions of higher education, including Advanced Placement and International Baccalaureate programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e2464e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/A/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" American history, civics, economics, geography, social studies, or government education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e2464e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/A/i/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e2464e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/A/i/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other courses, activities, and programs or other experiences that contribute to a well-rounded education; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2464e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimbursing low-income students to cover part or all of the costs of accelerated learning examination fees, as described in clause (i)(IV);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2464e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" foster safe, healthy, supportive, and drug-free environments that support student academic achievement, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7118"},"text":"section 7118 of this title","children":[],"tail":", which may include—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0e2464e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating with any local educational agencies or consortia of such agencies implementing a youth PROMISE plan to reduce exclusionary discipline, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7118/5/F"},"text":"section 7118(5)(F) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2464ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" supporting local educational agencies to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e2464eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement mental health awareness training programs that are evidence-based (to the extent the State determines that such evidence is reasonably available) to provide education to school personnel regarding resources available in the community for students with mental illnesses and other relevant resources relating to mental health or the safe de-escalation of crisis situations involving a student with a mental illness; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e2464ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand access to or coordinate resources for school-based counseling and mental health programs, such as through school-based mental health services partnership programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2464ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing local educational agencies with resources that are evidence-based (to the extent the State determines that such evidence is reasonably available) addressing ways to integrate health and safety practices into school or athletic programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2464ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminating best practices and evaluating program outcomes relating to any local educational agency activities to promote student safety and violence prevention through effective communication as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7118/5/C/iv"},"text":"section 7118(5)(C)(iv) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2464ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" increase access to personalized, rigorous learning experiences supported by technology by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e2464f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing technical assistance to local educational agencies to improve the ability of local educational agencies to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e2464f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and address technology readiness needs, including the types of technology infrastructure and access available to the students served by the local educational agency, including computer devices, access to school libraries, Internet connectivity, operating systems, software, related network infrastructure, and data security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e2464f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use technology, consistent with the principles of universal design for learning, to support the learning needs of all students, including children with disabilities and English learners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e2464f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" build capacity for principals, other school leaders, and local educational agency administrators to support teachers in using data and technology to improve instruction and personalize learning;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2464f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting schools in rural and remote areas to expand access to high-quality digital learning opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2464f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing or using strategies that are innovative or evidence-based (to the extent the State determines that such evidence is reasonably available) for the delivery of specialized or rigorous academic courses and curricula through the use of technology, including digital learning technologies and assistive technology, which may include increased access to online dual or concurrent enrollment opportunities, career and technical courses, and programs leading to a recognized postsecondary credential (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"section 3102 of title 29","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2464f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminating promising practices related to technology instruction, data security, and the acquisition and implementation of technology tools and applications, including through making such promising practices publicly available on the website of the State educational agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2464f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing teachers, paraprofessionals, school librarians and media personnel, specialized instructional support personnel, and administrators with the knowledge and skills to use technology effectively, including effective integration of technology, to improve instruction and student achievement, which may include coordination with teacher, principal, and other school leader preparation programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2464f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/b/3/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making instructional content widely available through open educational resources, which may include providing tools and processes to support local educational agencies in making such resources widely available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2464f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7114/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives a grant under this subpart for fiscal year 2017 may use the amount made available to the State and not reserved under paragraphs (1) and (2) of subsection (a) for such fiscal year to cover part or all of the fees for accelerated learning examinations taken by low-income students during the 2016-2017 school year, in accordance with subsection (b)(3)(A)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e2464fa-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4104"},"text":"Pub. L. 89–10, title IV, § 4104","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4101"},"text":"Pub. L. 114–95, title IV, § 4101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1971"},"text":"129 Stat. 1971","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e2464fb-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e2464fc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e2464fd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7114, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4114"},"text":"Pub. L. 89–10, title IV, § 4114","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIV/s401"},"text":"Pub. L. 107–110, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1742"},"text":"115 Stat. 1742","children":[],"tail":", related to local educational agency programs, prior to the general amendment of this subpart by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 7114, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4114"},"text":"Pub. L. 89–10, title IV, § 4114","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3679"},"text":"108 Stat. 3679","children":[],"tail":", related to governor’s programs, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s4104"},"text":"section 4104 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3064"},"text":"section 3064 of this title","children":[],"tail":", prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e2464fe-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e2464ff-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
