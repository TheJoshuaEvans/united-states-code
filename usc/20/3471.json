{"tag":"section","attrib":{"id":"id0dda8a52-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3471"},"text":null,"children":[{"tag":"num","attrib":{"value":"3471"},"text":"§ 3471.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dda8a53-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3471/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Force and effect of actions by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out any function transferred by this chapter, the Secretary, or any officer or employee of the Department, may exercise any authority available by law (including appropriation Acts) with respect to such function to the official or agency from which such function is transferred, and the actions of the Secretary in exercising such authority shall have the same force and effect as when exercised by such official or agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dda8a54-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3471/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dda8a55-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3471/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The director of any office continued in the Department the director of which was required, prior to ","children":[{"tag":"date","attrib":{"date":"1980-05-04"},"text":"May 4, 1980","children":[],"tail":", to report to the Commissioner of Education or the Assistant Secretary for Education of the Department of Health, Education, and Welfare, shall report to the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dda8a56-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3471/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary is authorized to delegate reporting requirements vested in the Secretary by paragraph (1) to any officer or employee of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dda8a57-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIV/s411"},"text":"Pub. L. 96–88, title IV, § 411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/683"},"text":"93 Stat. 683","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dda8a58-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dda8a59-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0dda8a5a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b)(1), “","children":[{"tag":"date","attrib":{"date":"1980-05-04"},"text":"May 4, 1980","children":[],"tail":"” substituted for “the effective date of this chapter” pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/s601"},"text":"section 601 of Pub. L. 96–88","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3401"},"text":"section 3401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
