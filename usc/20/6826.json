{"tag":"section","attrib":{"id":"id0e21f346-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6826"},"text":null,"children":[{"tag":"num","attrib":{"value":"6826"},"text":"§ 6826.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e21f347-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6826/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible entity desiring a subgrant from the State educational agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6824"},"text":"section 6824 of this title","children":[],"tail":" shall submit a plan to the State educational agency at such time, in such manner, and containing such information as the State educational agency may require."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e21f348-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6826/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each plan submitted under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e21f349-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6826/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the effective programs and activities, including language instruction educational programs, proposed to be developed, implemented, and administered under the subgrant that will help English learners increase their English language proficiency and meet the challenging State academic standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f34a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6826/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describe how the eligible entity will ensure that elementary schools and secondary schools receiving funds under this subpart assist English learners in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e21f34b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6826/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieving English proficiency based on the State’s English language proficiency assessment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/2/G"},"text":"section 6311(b)(2)(G) of this title","children":[],"tail":", consistent with the State’s long-term goals, as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/c/4/A/ii"},"text":"section 6311(c)(4)(A)(ii) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e21f34c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6826/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meeting the challenging State academic standards;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f34d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6826/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe how the eligible entity will promote parent, family, and community engagement in the education of English learners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f34e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6826/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contain assurances that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e21f34f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6826/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each local educational agency that is included in the eligible entity is complying with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6312/e"},"text":"section 6312(e) of this title","children":[],"tail":" prior to, and throughout, each school year as of the date of application;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e21f350-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6826/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible entity is not in violation of any State law, including State constitutional law, regarding the education of English learners, consistent with sections 6846 and 6847 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e21f351-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6826/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible entity consulted with teachers, researchers, school administrators, parents and family members, community members, public or private entities, and institutions of higher education, in developing and implementing such plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e21f352-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6826/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible entity will, if applicable, coordinate activities and share relevant data under the plan with local Head Start and Early Head Start agencies, including migrant and seasonal Head Start agencies, and other early childhood education providers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e21f353-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6826/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Teacher English fluency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible entity receiving a subgrant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6824"},"text":"section 6824 of this title","children":[],"tail":" shall include in its plan a certification that all teachers in any language instruction educational program for English learners that is, or will be, funded under this part are fluent in English and any other language used for instruction, including having written and oral communications skills."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e21f354-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIII/s3116"},"text":"Pub. L. 89–10, title III, § 3116","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIII/s301"},"text":"Pub. L. 107–110, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1700"},"text":"115 Stat. 1700","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/u