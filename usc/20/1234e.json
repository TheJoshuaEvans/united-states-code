{"tag":"section","attrib":{"id":"id0d97b534-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1234e"},"text":"§ 1234e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cease and desist orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d97b535-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance and contents of complaint","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1234c"},"text":"section 1234c of this title","children":[],"tail":", the Secretary may issue to a recipient under an applicable program a complaint which—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d97b536-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the factual and legal basis for the Secretary’s belief that the recipient is failing to comply substantially with a requirement of law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d97b537-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains a notice of a hearing to be held before the Office on a date at least 30 days after the service of the complaint.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b538-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appearance contesting order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The recipient upon which a complaint has been served shall have the right to appear before the Office on the date specified and to show cause why an order should not be entered by the Office requiring the recipient to cease and desist from the violation of law charged in the complaint.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b539-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report; issuance of cease and desist order","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The testimony in any hearing held under this section shall be reduced to writing and filed with the Office. If upon that hearing the Office is of the opinion that the recipient is in violation of any requirement of law as charged in the complaint, the Office shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d97b53a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a report in writing stating its findings of fact; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d97b53b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue to the recipient an order requiring the recipient to cease and desist from the practice, policy, or procedure which resulted in the violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b53c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report and order as final agency action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report and order of the Office under this section shall become the final agency action when the recipient receives the report and order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b53d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of final order","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may enforce a final order of the Office under this section which becomes final agency action by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d97b53e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234e/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withholding from the recipient any portion of the amount payable to it, including the amount payable for administrative costs, under the applicable program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d97b53f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234e/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certifying the facts to the Attorney General who shall cause an appropriate proceeding to be brought for the enforcement of the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d97b540-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/tIV/s456"},"text":"Pub. L. 90–247, title IV, § 456","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXII/s1232"},"text":"Pub. L. 95–561, title XII, § 1232","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2351"},"text":"92 Stat. 2351","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/tIII/s3501/a"},"text":"Pub. L. 100–297, title III, § 3501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/355"},"text":"102 Stat. 355","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d97b541-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d97b542-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d97b543-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297"},"text":"Pub. L. 100–297","children":[],"tail":" amended section generally, substituting provisions relating to cease and desist orders for provisions relating to use of recovered funds. See "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1234h"},"text":"section 1234h of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d97b544-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d97b545-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297"},"text":"Pub. L. 100–297","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", but not applicable to recipients receiving written notice to return funds prior to that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/s3501/b"},"text":"section 3501(b) of Pub. L. 100–297","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1234"},"text":"section 1234 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
