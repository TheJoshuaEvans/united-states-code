{"tag":"section","attrib":{"id":"id0de8bb7b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359"},"text":null,"children":[{"tag":"num","attrib":{"value":"4359"},"text":"§ 4359.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight and effect of agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de8bb7c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to diminish the oversight activities of the Committee on Education and Labor of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate with respect to any agreement entered into between the Secretary of Education and Gallaudet University, and the institution of higher education with which the Secretary has an agreement under part B of subchapter I.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de8bb7d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The agreements described in subsection (a) of this section shall continue in effect, to the extent that such agreements are not inconsistent with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de8bb7e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/371/tII/s208"},"text":"Pub. L. 99–371, title II, § 208",