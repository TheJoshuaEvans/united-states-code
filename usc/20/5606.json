{"tag":"section","attrib":{"id":"id0df7124a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5606"},"text":null,"children":[{"tag":"num","attrib":{"value":"5606"},"text":"§ 5606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Morris K. Udall and Stewart L. Udall Trust Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0df7124b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5606/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Trust Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a trust fund to be known as the “Morris K. Udall and Stewart L. Udall Trust Fund” to be administered by a Foundation. The Trust Fund shall consist of amounts appropriated to it pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5609/a"},"text":"section 5609(a) of this title","children":[],"tail":" and amounts credited to it under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0df7124c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5606/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of Trust Fund assets","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0df7124d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5606/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002188"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002188"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" "},{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It shall be the duty of the Secretary of the Treasury to invest, at the direction of the Foundation Board, in full the amounts appropriated to the Trust Fund. Such investments shall be in public debt securities with maturities suitable to the needs of the Trust Fund. Investments in public debt securities shall bear interest “at rates determined by the Secretary of the Treasury taking into consideration the current average market yield on outstanding marketable obligations of the United States” of comparable maturity. Beginning on ","children":[{"tag":"date","attrib":{"date":"2023-10-01"},"text":"October 1, 2023","children":[],"tail":", and thereafter, interest earned from investments made with any new appropriations to the Trust Fund shall only be available subject to appropriations and is authorized to be appropriated to carry out the provisions of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0df7124e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/259/s8"},"text":"Pub. L. 102–259, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-03-19"},"text":"Mar. 19, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/82"},"text":"106 Stat. 82","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/156/s9"},"text":"Pub. L. 105–156, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-02-11"},"text":"Feb. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/12"},"text":"112 Stat. 12","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/90/s7"},"text":"Pub. L. 111–90, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-11-03"},"text":"Nov. 3, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2978"},"text":"123 Stat. 2978","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/47/dG/tII/s202"},"text":"Pub. L. 118–47, div. G, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-23"},"text":"Mar. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/858"},"text":"138 Stat. 858","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0df7124f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0df71250-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0df71251-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/47"},"text":"Pub. L. 118–47","children":[],"tail":" inserted at end “Beginning on "},{"tag":"date","attrib":{"date":"2023-10-01"},"text":"October 1, 2023","children":[],"tail":", and thereafter, interest earned from investments made with any new appropriations to the Trust Fund shall only be available subject to appropriations and is authorized to be appropriated to carry out the provisions of this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/90"},"text":"Pub. L. 111–90","children":[],"tail":" substituted “and Stewart L. Udall” for “Scholarship and Excellence in National Environmental Policy” in section catchline and in subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/156/s9/a"},"text":"Pub. L. 105–156, § 9(a)","children":[],"tail":", substituted “The Trust Fund” for “The fund” and “5609(a)” for “5609”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/156/s9/b"},"text":"Pub. L. 105–156, § 9(b)","children":[],"tail":", substituted “Trust Fund” for “Fund” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
