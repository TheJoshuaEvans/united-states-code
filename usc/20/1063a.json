{"tag":"section","attrib":{"id":"id0cd6880a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1063a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1063a"},"text":"§ 1063a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cd6880b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1063a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No part B institution shall be entitled to its allotment of Federal funds for any grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1063"},"text":"section 1063 of this title","children":[],"tail":" for any period unless that institution meets the requirements of subparagraphs (C), (D), and (E) "},{"tag":"ref","attrib":{"idref":"fn002040"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002040"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1058/b/1"},"text":"section 1058(b)(1) of this title","children":[],"tail":" and submits an application to the Secretary at such time, in such manner, and containing or accompanied by such information, as the Secretary may reasonably require. Each such application shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd6880c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1063a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that the payments under this chapter will be used for the purposes set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1062"},"text":"section 1062 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd6880d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1063a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide for making an annual report to the Secretary and provide for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd6880e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1063a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting, except as provided in subparagraph (B), a financial and compliance audit of an eligible institution, with regard to any funds obtained by it under this subchapter at least once every 2 years and covering the period since the most recent audit, conducted by a qualified, independent organization or person in accordance with standards established by the Comptroller General for the audit of governmental organizations, programs, and functions, and as prescribed in regulations of the Secretary, the results of which shall be submitted to the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd6880f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1063a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with regard to an eligible institution which is audited under chapter 75 of title 31 deeming such audit to satisfy the requirements of subparagraph (A) for the period covered by such audit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd68810-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1063a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall approve any application which meets the requirements of subsection (a) and shall not disapprove any application submitted under this part, or any modification thereof, without first affording such institution reasonable notice and opportunity for a hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd68811-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1063a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals for financial management and academic programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any application for a grant under this part shall describe measurable goals for the institution’s financial management and academic programs and include a plan of how the applicant intends to achieve those goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cd68812-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s325"},"text":"Pub. L. 89–329, title III, § 325","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIII/s301/a"},"text":"Pub. L. 99–498, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1296"},"text":"100 Stat. 1296","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/50/s2/a/8"},"text":"Pub. L. 100–50, § 2(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-06-03"},"text":"June 3, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/335"