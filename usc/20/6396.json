{"tag":"section","attrib":{"id":"id0e1151f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6396"},"text":null,"children":[{"tag":"num","attrib":{"value":"6396"},"text":"§ 6396.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive needs assessment and service-delivery plan; authorized activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e1151f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6396/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1151f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6396/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State that receives assistance under this part shall ensure that the State and its local operating agencies identify and address the unique educational needs of migratory children in accordance with a comprehensive State plan that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1151f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6396/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is integrated with other programs under this chapter or other Acts, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1151f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6396/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may be submitted as a part of a consolidated application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7842"},"text":"section 7842 of this title","children":[],"tail":", if—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0e1151f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6396/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unique needs of migratory children are specifically addressed in the comprehensive State plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e1151fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6396/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the comprehensive State plan is developed in collaboration with parents of migratory children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e1151fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6396/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the comprehensive State plan is not used to supplant State efforts regarding, or administrative funding for, this part;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1151fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6396/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides that migratory children will have an opportunity to meet the same challenging State academic standards that all children are expected to meet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1151fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6396/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifies measurable program goals and outcomes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1151fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6396/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encompasses the full range of services that are available for migratory children from appropriate local, State, and Federal educational programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1151ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6396/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the product of joint planning among such local, State, and Federal programs, including programs under part A, early childhood programs, and language instruction educational programs under part A of subchapter III; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e115200-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6396/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for the integration of services available under this part with services provided by such other programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e115201-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6396/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of the plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each such comprehensive State plan shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e115202-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6396/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain in effect for the duration of the State’s participation under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e115203-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6396/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be periodically reviewed and revised by the State, as necessary, to reflect changes in the State’s strategies and programs under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e115204-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6396/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e115205-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6396/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flexibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In implementing the comprehensive plan described in subsection (a), each State educational agency, where applicable through its local educational agencies, retains the flexibility to determine the activities to be provided with funds made available under this part, except that such funds first shall be used to meet the identified needs of migratory children that result from their migratory lifestyle, and to permit these children to participate effectively in school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e115206-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6396/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unaddressed needs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided under this part shall be used to address the needs of migratory children that are not addressed by services available from other Federal or non-Federal programs, except that migratory children who are eligible to receive services under part A may receive those services through funds provided under that part, or through funds under this part that remain after the agency addresses the needs described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e13c207-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6396/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this part shall be construed to prohibit a local educational agency from serving migratory children simultaneously with students with similar educational needs in the same educational settings, where appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e13c208-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6396/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6314"},"text":"section 6314 of this title","children":[],"tail":", a school that receives funds under this part shall continue to address the identified needs described in paragraph (1), and shall meet the unique educational needs of migratory children before using funds under this part for schoolwide programs under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6314"},"text":"section 6314 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e13c209-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1306"},"text":"Pub. L. 89–10, title I, § 1306","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1576"},"text":"115 Stat. 1576","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tI/s1301/e"},"text":"Pub. L. 114–95, title I, § 1301(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1897"},"text":"129 Stat. 1897","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e13c20a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e13c20b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e13c20c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6396, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1306"},"text":"Pub. L. 89–10, title I, § 1306","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3589"},"text":"108 Stat. 3589","children":[],"tail":", related to comprehensive needs assessments and service-delivery plans, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e13c20d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/e/1/A"},"text":"Pub. L. 114–95, § 1301(e)(1)(A)","children":[],"tail":", substituted “unique” for “special” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/e/1/B/i"},"text":"Pub. L. 114–95, § 1301(e)(1)(B)(i)","children":[],"tail":", made technical amendment to reference in original act which appears in introductory provisions as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7842"},"text":"section 7842 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/e/1/B/ii"},"text":"Pub. L. 114–95, § 1301(e)(1)(B)(ii)","children":[],"tail":", substituted “unique” for “special”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/e/1/C"},"text":"Pub. L. 114–95, § 1301(e)(1)(C)","children":[],"tail":", substituted “challenging State academic standards” for “challenging State academic content standards and challenging State student academic achievement standards”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/e/1/D"},"text":"Pub. L. 114–95, § 1301(e)(1)(D)","children":[],"tail":", substituted “part A of subchapter III” for “part A or B of subchapter III”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/e/2/A"},"text":"Pub. L. 114–95, § 1301(e)(2)(A)","children":[],"tail":", substituted “retains the flexibility to” for “shall have the flexibility to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/e/2/B"},"text":"Pub. L. 114–95, § 1301(e)(2)(B)","children":[],"tail":", substituted “unique educational needs” for “special educational needs”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e13c20e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e13c20f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
