{"tag":"section","attrib":{"id":"id0dda8a17-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3447"},"text":null,"children":[{"tag":"num","attrib":{"value":"3447"},"text":"§ 3447.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of transfers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The transfer of a function or office from an officer or agency to the Secretary or to the Department includes any aspects of such function or office vested in a subordinate of such officer or in a component of such agency.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0dda8a18-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIII/s306"},"text":"Pub. L. 96–88, title III, § 306","children":[],"tail":", formerly § 307, "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/681"},"text":"93 Stat. 681","children":[],"tail":"; renumbered § 306, "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tII/s271/a/2"},"text":"Pub. L. 103–382, title II, § 271(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3929"},"text":"108 Stat. 3929","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dda8a19-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dda8a1a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0dda8a1b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","a