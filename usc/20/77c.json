{"tag":"section","attrib":{"id":"id0c831010-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s77c"},"text":null,"children":[{"tag":"num","attrib":{"value":"77c"},"text":"§ 77c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Museum board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c831011-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s77c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seal; regulations; vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The board is authorized to adopt an official seal which shall be judicially noticed and to make such bylaws, rules, and regulations as it deems necessary for the administration of its functions. The board may function notwithstanding vacancies and six members of the board shall constitute a quorum for the transaction of business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c831012-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s77c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Smithsonian Institution shall include in its annual report of its operations to Congress a statement of the operations of said national air and space museum, including all public and private moneys received and disbursed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c831013-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-12/ch955/s4"},"text":"Aug. 12, 1946, ch. 955, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/998"},"text":"60 Stat. 998","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/509"},"text":"Pub. L. 89–509","children":[],"tail":", pt. I, §§ 6, 7, "},{"tag":"date","attrib":{"date":"1966-07-19"},"text":"July 19, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/310"},"text":"80 Stat. 310","children":[],"tail":", 311.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c831014-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c831015-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0c831016-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1966—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/509/s6"},"text":"Pub. L. 89–509, § 6","children":[],"tail":", raised from three to six the number of board members required to constitute a quorum."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/509/s7"},"text":"Pub. L. 89–509, § 7","children":[],"tail":", substituted “national air and space museum” for “national air museum”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
