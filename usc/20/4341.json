{"tag":"section","attrib":{"id":"id0de671d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4341"},"text":null,"children":[{"tag":"num","attrib":{"value":"4341"},"text":"§ 4341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cultural experiences grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de671d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4341/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to, on a competitive basis, make grants to, and enter into contracts and cooperative agreements with, eligible entities to support the activities described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de671d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4341/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall support activities providing cultural experiences, through appropriate nonprofit organizations with a demonstrated proficiency in providing such activities, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de671d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4341/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrich the lives of deaf and hard-of-hearing children and adults;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de671d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4341/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase public awareness and understanding of deafness and of the artistic and intellectual achievements of deaf and hard-of-hearing persons; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de671d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4341/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the integration of hearing, deaf, and hard-of-hearing persons through shared cultural, educational, and social experiences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de671da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4341/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity that desires to receive a grant, or enter into a contract or cooperative agreement, under this section shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de671db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4341/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de671dc-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/371/tI/s121"},"text":"Pub. L. 99–371, title I, § 121","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIX/s904/a"},"text":"Pub. L. 110–315, title IX, § 904(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3452"},"text":"122 Stat. 3452","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de671dd-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de671de-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0de671df-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4341, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/371/tIII/s301"},"text":"Pub. L. 99–371, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-04"},"text":"Aug. 4, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/786"},"text":"100 Stat. 786","children":[],"tail":", established Commission on Education of the Deaf, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/421/tI"},"text":"Pub. L. 102–421, title I","children":[],"tail":", §§ 101(a)(2), 161, "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"Oct. 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2151"},"text":"106 Stat. 2151","childre