{"tag":"section","attrib":{"id":"id0e6739b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9606"},"text":null,"children":[{"tag":"num","attrib":{"value":"9606"},"text":"§ 9606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish priorities for the regional educational laboratories (established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9564"},"text":"section 9564 of this title","children":[],"tail":") and comprehensive centers (established under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9602"},"text":"section 9602 of this title","children":[],"tail":") to address, taking onto account the regional assessments conducted under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9605"},"text":"section 9605 of this title","children":[],"tail":" and other relevant regional surveys of educational needs, to the extent the Secretary deems appropriate."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e6739b8-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tII/s207"},"text":"Pub. L. 107–279, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1981"},"text":"116 Stat. 1981","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
