{"tag":"section","attrib":{"id":"id0df4c8c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5601"},"text":null,"children":[{"tag":"num","attrib":{"value":"5601"},"text":"§ 5601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0df4c8ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5601/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for three decades, Congressman Morris K. Udall has served his country with distinction and honor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c8cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5601/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congressman Morris K. Udall has had a lasting impact on this Nation’s environment, public lands, and natural resources, and has instilled in this Nation’s youth a love of the air, land, and water;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c8cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5601/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congressman Morris K. Udall has been a champion of the rights of Native Americans and Alaska Natives and has used his leadership in the Congress to strengthen tribal self-governance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c8cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5601/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is a fitting tribute to the leadership, courage, and vision Congressman Morris K. Udall exemplifies to establish in his name programs to encourage the continued use, enjoyment, education, and exploration of our Nation’s rich and bountiful natural resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c8ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5601/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Foundation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0df4c8cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5601/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" since 1995, has operated exceptional scholarship, internship, and fellowship programs for areas of study related to the environment and Native American tribal policy and health care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df4c8d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5601/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" since 1999, has provided valuable environmental conflict resolution services and leadership through the National Center (previously known as the United States Institute for Environmental Conflict Resolution); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df4c8d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5601/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is committed to continue making a substantial contribution toward public policy in the future by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0df4c8d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5601/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" playing a significant role in developing the next generation of environmental and Native American leaders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0df4c8d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5601/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" working with current leaders to improve decisionmaking on—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0df4c8d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5601/5/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" challenging environmental, energy, and related economic problems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0df4c8d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5601/5/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal governance and economic issues;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c8d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5601/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Stewart L. Udall, as a member of Congress, Secretary of the Interior, environmental lawyer, and author, has provided distinguished national leadership in environmental and Native American policy for more than 50 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c8d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5601/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as Secretary of the Interior from 1961 to 1969, Stewart L. Udall oversaw the creation of 4 national parks, 6 national monuments, 8 national seashores and lakeshores, 9 recreation areas, 20 historic sites, and 56 wildlife refuges; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c8d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5601/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is fitting that the leadership and vision of Stewart L. Udall in the areas of environmental and Native American policy be jointly honored with that of Morris K. Udall through the foundation bearing the Udall name.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0df4c8d9-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/259/s3"},"text":"Pub. L. 102–259, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-03-19"},"text":"Mar. 19, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/78"},"text":"106 Stat. 78","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/90/s3"},"text":"Pub. L. 111–90, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-11-03"},"text":"Nov. 3, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2976"},"text":"123 Stat. 2976","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tIII/s302/b"},"text":"Pub. L. 116–94, div. P, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3187"},"text":"133 Stat. 3187","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0df4c8da-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0df4c8db-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0df4c8dc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Par. (5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" substituted “the National Center (previously known as the United States Institute for Environmental Conflict Resolution)” for “the United States Institute for Environmental Conflict Resolution”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Pars. (5) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/90"},"text":"Pub. L. 111–90","children":[],"tail":" added pars. (5) to (8)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0df4c8dd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0df4c8de-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/47/dG/tII/s201"},"text":"Pub. L. 118–47, div. G, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-23"},"text":"Mar. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/858"},"text":"138 Stat. 858","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/47/dG/tII/s201"},"text":"“This title [amending sections 5606 and 5609 of this title] may be cited as the ‘Udall Foundation Reauthorization Act of 2024’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0df4c8df-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/90/s1"},"text":"Pub. L. 111–90, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-11-03"},"text":"Nov. 3, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2976"},"text":"123 Stat. 2976","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/90/s1"},"text":"“This Act [amending this section, sections 5602, 5603, 5605 to 5607, 5607b, and 5608 of this title, and provisions set out as note under this section] may be cited as the ‘Morris K. Udall Scholarship and Excellence in National Environmental Policy Amendments Act of 2009’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0df4c8e0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/160/s1"},"text":"Pub. L. 108–160, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2013"},"text":"117 Stat. 2013","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/160/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5609"},"text":"section 5609 of this title","children":[],"tail":"] may be cited as the ‘Environmental Policy and Conflict Resolution Advancement Act of 2003’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0df4c8e1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/156/s1"},"text":"Pub. L. 105–156, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-02-11"},"text":"Feb. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/8"},"text":"112 Stat. 8","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/156/s1"},"text":"“This Act [enacting sections 5607a and 5607b of this title and amending sections 5602 to 5607, 5608, and 5609 of this title] may be cited as the ‘Environmental Policy and Conflict Resolution Act of 1998’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id0df4c8e2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/259/s1"},"text":"Pub. L. 102–259, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-03-19"},"text":"Mar. 19, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/78"},"text":"106 Stat. 78","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/90/s2"},"text":"Pub. L. 111–90, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-11-03"},"text":"Nov. 3, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2976"},"text":"123 Stat. 2976","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/90/s2"},"text":"“This Act [enacting this chapter] may be cited as the ‘Morris K. Udall and Stewart L. Udall Foundation Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0df4c8e3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tIII/s301"},"text":"Pub. L. 116–94, div. P, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3186"},"text":"133 Stat. 3186","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/94/dP/tIII/s301"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds the following:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Since 1999, the Morris K. Udall and Stewart L. Udall Foundation (referred to in this Act [probably means “this title”, title III of div. P of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":", which amended this section and sections 5602 to 5605 and 5607a to 5609 of this title and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s5605"},"text":"section 5605 of this title","children":[],"tail":"] as the ‘Foundation’) has operated the Parks in Focus program to provide opportunities for the youth of the United States to learn about and experience the Nation’s parks and wilderness, and other outdoor areas."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Since 2001, the Foundation has conducted research and provided education and training to Native American and Alaska Native professionals and leaders on Native American and Alaska Native health care issues and tribal public policy through the Native Nations Institute for Leadership, Management, and Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Foundation is committed to continuing to make a substantial contribution toward public policy in the future by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" playing a significant role in developing the next generation of environmental, public health, public lands, natural resource, and Native American leaders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" working with current leaders to improve collaboration and decision-making on challenging environmental, energy, public health, and related economic problems and tribal governance and economic development issues.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0df4c8e4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Previous Legislation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/259/s2"},"text":"Pub. L. 102–259, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-03-19"},"text":"Mar. 19, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/78"},"text":"106 Stat. 78","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/259/s2"},"text":"“The Morris K. Udall Scholarship and Excellence in National Environmental Policy Act, S. 1176, One Hundred Second Congress, is hereby repealed.”","children":[],"tail":"\n [For details concerning purported pocket veto of S. 1176, One Hundred Second Congress, see Weekly Compilation of Presidential Documents, vol. 28 (1992), no. 12, p. 507, Mar. 19, Presidential Statement, and Cong. Rec., vol. 138, pt. 3, p. 4078, "},{"tag":"date","attrib":{"date":"1992-03-03"},"text":"Mar. 3, 1992","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
