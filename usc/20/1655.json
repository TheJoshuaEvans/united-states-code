{"tag":"section","attrib":{"id":"id0db1f3a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1655"},"text":null,"children":[{"tag":"num","attrib":{"value":"1655"},"text":"§ 1655.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform rules of evidence of racial discrimination","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The rules of evidence required to prove that State or local authorities are practicing racial discrimination in assigning students to public schools shall be uniform throughout the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0db1f3a8-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/318/tVIII/s805"},"text":"Pub. L. 92–318, title VIII, § 805","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/372"},"text":"86 Stat. 372","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
