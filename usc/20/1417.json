{"tag":"section","attrib":{"id":"id0da856c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1417"},"text":null,"children":[{"tag":"num","attrib":{"value":"1417"},"text":"§ 1417.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0da856c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1417/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0da856c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1417/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" cooperate with, and (directly or by grant or contract) furnish technical assistance necessary to, a State in matters relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0da856c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1417/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the education of children with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da856c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1417/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da856c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1417/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide short-term training programs and institutes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da856ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1417/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against Federal mandates, direction, or control","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to authorize an officer or employee of the Federal Government to mandate, direct, or control a State, local educational agency, or school’s specific instructional content, academic achievement standards and assessments, curriculum, or program of instruction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da856cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1417/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall take appropriate action, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232g"},"text":"section 1232g of this title","children":[],"tail":", to ensure the protection of the confidentiality of any personally identifiable data, information, and records collected or maintained by the Secretary and by State educational agencies and local educational agencies pursuant to this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da856cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1417/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to hire qualified personnel necessary to carry out the Secretary’s duties under subsection (a), under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1418"},"text":"section 1418 of this title","children":[],"tail":", and under part D of subchapter IV, without regard to the provisions of title 5 relating to appointments in the competitive service and without regard to chapter 51 and subchapter III of chapter 53 of such title relating to classification and general schedule pay rates, except that no more than 20 such personnel shall be employed at any time."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da856cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1417/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model forms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than the date that the Secretary publishes final regulations under this chapter, to implement amendments made by the Individuals with Disabilities Education Improvement Act of 2004, the Secretary shall publish and disseminate widely to States, local educational agencies, and parent and community training and information centers—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0da856ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1417/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a model IEP form;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da856cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1417/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a model individualized family service plan (IFSP) form;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da856d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1417/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a model form of the notice of procedural safeguards described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1415/d"},"text":"section 1415(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da856d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1417/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a model form of the prior written notice described in subsections (b)(3) and (c)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1415"},"text":"section 1415 of this title","children":[],"tail":" that is consistent with the requirements of this subchapter and is sufficient to meet such requirements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0da856d2-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s617"},"text":"Pub. L. 91–230, title VI, § 617","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2737"},"text":"118 Stat. 2737","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0da856d3-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0da856d4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0da856d5-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The provisions of title 5 relating to appointments in the competitive service, referred to in subsec. (d), are classified generally to section 3301 et seq. of Title 5, Government Organization and Employees.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Individuals with Disabilities Education Improvement Act of 2004, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/446"},"text":"Pub. L. 108–446","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2647"},"text":"118 Stat. 2647","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2004 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0da856d6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1417, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s617"},"text":"Pub. L. 91–230, title VI, § 617","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/17/tI/s101"},"text":"Pub. L. 105–17, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-04"},"text":"June 4, 1997","child