{"tag":"section","attrib":{"id":"id0e2e012c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7242"},"text":null,"children":[{"tag":"num","attrib":{"value":"7242"},"text":"§ 7242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized.","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e2e012d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7242/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statewide family engagement centers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7246"},"text":"section 7246 of this title","children":[],"tail":" and not reserved under subsection (d), the Secretary is authorized to award grants for each fiscal year to statewide organizations (or consortia of such organizations), to establish statewide family engagement centers that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2e012e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7242/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out parent education, and family engagement in education, programs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e012f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7242/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide comprehensive training and technical assistance to State educational agencies, local educational agencies, schools identified by State educational agencies and local educational agencies, organizations that support family-school partnerships, and other organizations that carry out such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2e0130-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7242/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum award","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Secretary shall, to the extent practicable, ensure that a grant is awarded for a statewide family engagement center in an amount not less than $500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2e0131-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7242/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds for grant renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each organization or consortium receiving assistance under this part shall demonstrate that, for each fiscal year after the first fiscal year for which the organization or consortium is receiving such assistance, a portion of the services provided by the organization or consortium is supported through non-Federal contributions, which may be in cash or in-kind.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2e0132-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7242/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall reserve not more than 2 percent of the funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7246"},"text":"section 7246 of this title","children":[],"tail":" to carry out this part to provide technical assistance, by competitive grant or contract, for the establishment, development, and coordination of statewide family engagement centers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e2e0133-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4502"},"text":"Pub. L. 89–10, title IV, § 4502","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4501"},"text":"Pub. L. 114–95, title IV, § 4501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2016"},"text":"129 Stat. 2016","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e2e0134-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e2e0135-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e2e0136-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s4502"},"text":"section 4502 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3142"},"text":"section 3142 of this title","children":[],"tail":", prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e2e0137-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e2e0138-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
