{"tag":"section","attrib":{"id":"id0deb2bea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4401"},"text":null,"children":[{"tag":"num","attrib":{"value":"4401"},"text":"§ 4401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0deb2beb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4401/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian art and culture and Native Hawaiian art and culture have contributed greatly to the artistic and cultural richness of the Nation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2bec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4401/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian art and culture and Native Hawaiian art and culture occupy a unique position in American history as being our only native art form and cultural heritage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2bed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4401/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enhancement and preservation of this Nation’s native art and culture has a fundamental positive influence on the American people;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2bee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4401/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" although the encouragement and support of Indian and Native Hawaiian arts and crafts are primarily a matter for private, local, and Indian and Native Hawaiian initiative, it is also an appropriate matter of concern to the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2bef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4401/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is appropriate and necessary for the Federal Government to support research and scholarship in Indian art and culture and Native Hawaiian art and culture and to complement programs for the advancement of such art and culture by tribal, private, and public agencies and organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2bf0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4401/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" current Federal initiatives in the area of Indian art and culture and Native Hawaiian art and culture are fragmented and inadequate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2bf1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4401/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in order to coordinate the Federal Government’s effort to preserve, support, revitalize, and disseminate Indian art and culture and Native Hawaiian art and culture, it is desirable to establish—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0deb2bf2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4401/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national Institute of American Indian and Alaska Native Culture and Arts Development, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0deb2bf3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4401/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a program for Native Hawaiian culture and arts development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0deb2bf4-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/498/tXV/s1502"},"text":"Pub. L. 99–498, title XV, § 1502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1600"},"text":"100 Stat. 1600","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0deb2bf5-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0deb2bf6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0deb2bf7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/239/tVII/s721"},"text":"Pub. L. 103–239, title VII, § 721","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-05-04"},"text":"May 4, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/606"},"text":"108 Stat. 606","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/239/tVII/s721"},"text":"“This title [probably should be “subtitle” meaning subtitle C [§§ 721, 722] of title VII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/239"},"text":"Pub. L. 103–239","children":[],"tail":", amending "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4441"},"text":"section 4441 of this title","children":[],"tail":"] may be cited as the ‘Alaska Native Culture and Arts Development Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id0deb2bf8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/498/tXV/s1501"},"text":"Pub. L. 99–498, title XV, § 1501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1600"},"text":"100 Stat. 1600","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/498/tXV/s1501"},"text":"“This title [enacting this chapter] may be cited as the ‘American Indian, Alaska Native, and Native Hawaiian Culture and Art Development Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
