{"tag":"section","attrib":{"id":"id0e160c54-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6456"},"text":null,"children":[{"tag":"num","attrib":{"value":"6456"},"text":"§ 6456.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The State educational agency may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e160c55-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6456/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce or terminate funding for projects under this subpart if a local educational agency does not show progress in the number of children and youth attaining a regular high school diploma or its recognized equivalent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e160c56-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6456/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require correctional facilities or institutions for neglected or delinquent children and youth to demonstrate, after receiving assistance under this subpart for 3 years, that there has been an increase in the number of children and youth returning to school, attaining a regular high school diploma or its recognized equivalent, or attaining employment after such children and youth are released.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e160c57-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1426"},"text":"Pub. L. 89–10, title I, § 1426","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1590"},"text":"115 Stat. 1590","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tI/s1401/13"},"text":"Pub. L. 114–95, title I, § 1401(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1905"},"text":"129 Stat. 1905","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e160c58-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e160c59-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e160c5a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6456, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1426"},"text":"Pub. L. 89–10, title I, § 1426","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3600"},"text":"108 Stat. 3600","children":[],"tail":", related to accountability, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e160c5b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1401/13/A"},"text":"Pub. L. 114–95, § 1401(13)(A)","children":[],"tail":", substituted “the number of children and youth attaining a regular high school diploma or its recognized equivalent” for “reducing dropout rates for male students and for female students over a 3-year period”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1401/13/B"},"text":"Pub. L. 114–95, § 1401(13)(B)","children":[],"tail":", substituted “attaining a regular high school diploma” for “obtaining a secondary school diploma” and “attaining employment” for “obtaining employment”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e160c5c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e160c5d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
