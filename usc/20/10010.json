{"tag":"section","attrib":{"id":"id0e70af5e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10010"},"text":null,"children":[{"tag":"num","attrib":{"value":"10010"},"text":"§ 10010.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary’s report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit a report to the Committee on Education and Labor of the House of Representatives, the Committee on Health, Education, Labor, and Pensions of the Senate, and the Committees on Appropriations of the House of Representatives and of the Senate, not less than 6 months following the submission of State reports, that evaluates the information provided in the State reports under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s10008"},"text":"section 10008 of this title","children":[],"tail":" and the information required by "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s10005/b/3"},"text":"section 10005(b)(3) of this title","children":[],"tail":" including State-by-State information."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e70af5f-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tXIV/s14010"},"text":"Pub. L. 111–5, div. A, title XIV, § 14010","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/285"},"text":"123 Stat. 285","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e70af60-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e70af61-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id0e70af62-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Education and Labor of House of Representatives changed to Committee on Education and the Workforce of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
