{"tag":"section","attrib":{"id":"id0d41ccc5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1087uu–2"},"text":"§ 1087uu–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for independent students","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d41ccc6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination process for unaccompanied homeless youth","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making a determination of independence under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087vv/d/8"},"text":"section 1087vv(d)(8) of this title","children":[],"tail":", a financial aid administrator shall comply with the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d41ccc7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Consider documentation of the student’s circumstance to be adequate in the absence of documented conflicting information, if such documentation is provided through a documented phone call, written statement, or verifiable electronic data match by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d41ccc8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local educational agency homeless liaison, designated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11432/g/1/J/ii"},"text":"section 11432(g)(1)(J)(ii) of title 42","children":[],"tail":" or a designee of the liaison;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d41ccc9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the director of an emergency or transitional shelter, street outreach program, homeless youth drop-in center, or other program serving individuals who are experiencing homelessness, or a designee of the director;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d41ccca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the director of a project supported by a Federal TRIO program or a Gaining Early Awareness and Readiness for Undergraduate program grant under division 1 or 2 of subpart 2 of part A, or a designee of the director; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d41cccb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a financial aid administrator at another institution who documented the student’s circumstance in the same or a prior award year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d41cccc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If a student is unable to provide documentation from any individual described in paragraph (1), make a case-by-case determination, which shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d41cccd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on a written statement from, or a documented interview with, the student that confirms that the student is an unaccompanied homeless youth, or unaccompanied, at risk of homelessness, and self-supporting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d41ccce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made without regard to the reasons that the student is an unaccompanied homeless youth, or unaccompanied, at risk of homelessness, and self-supporting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d41cccf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consider a determination made under this subsection as distinct from a determination of independence under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087vv/d/9"},"text":"section 1087vv(d)(9) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d41ccd0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documentation process for foster care youth","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an institution requires that a student provide documentation that the student was in foster care when the student was age 13 or older, a financial aid administrator shall consider any of the following as adequate documentation, in the absence of documented conflicting information:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d41ccd1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Submission of a court order or official State documentation that the student received Federal or State support in foster care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d41ccd2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A documented phone call, written statement, or verifiable electronic data match, which confirms the student was in foster care at an applicable age, from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d41ccd3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, county, or tribal agency administering a program under part B or E of title IV of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s621"},"text":"42 U.S.C. 621","children":[],"tail":" et seq. and 670 et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d41ccd4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State Medicaid agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d41ccd5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public or private foster care placing agency or foster care facility or placement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d41ccd6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A documented phone call or a written statement from an attorney, a guardian ad litem, or a Court Appointed Special Advocate that confirms that the student was in foster care at an applicable age and documents the person’s relationship to the student.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d41ccd7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Verification of the student’s eligibility for an education and training voucher under the John H. Chafee Foster Care Program under section 477 of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s677"},"text":"42 U.S.C. 677","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d41ccd8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A documented phone call or written statement from a financial aid administrator who documented the student’s circumstance in the same or a prior award year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d41ccd9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A determination of independence under paragraph (2), (8), or (9) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087vv/d"},"text":"section 1087vv(d) of this title","children":[],"tail":" for a student—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d41ccda-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be made as quickly as practicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d41ccdb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be made as early as the year before the award year for which the student initially submits an application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d41ccdc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be made not later than 60 days after the date of the student’s enrollment during the award year for which the student initially submits an application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d41ccdd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of earlier determinations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d41ccde-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Earlier determination by the institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any student who is determined to be independent under paragraph (2), (8), or (9) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087vv/d"},"text":"section 1087vv(d) of this title","children":[],"tail":" for a preceding award year at an institution shall be presumed to be independent for each subsequent award year at the same institution unless—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d41ccdf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the student informs the institution that circumstances have changed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d41cce0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution has specific conflicting information about the student’s independence and has informed the student of this information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d41cce1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Earlier determination by another institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A financial aid administrator may make a determination of independence pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087tt/c"},"text":"section 1087tt(c) of this title","children":[],"tail":", this section, or paragraph (2), (8), or (9) of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087vv/d"},"text":"section 1087vv(d) of this title","children":[],"tail":", based upon a documented determination of independence that was previously made by another financial aid administrator under such provisions in the same or a prior award year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d443ce2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A financial aid administrator shall retain all documents related to any determination of independence, including documented interviews, for at least the duration of the student’s enrollment and an additional period prescribed by the Secretary to enable a student to utilize the documents for the purposes of subsection (a)(1)(D), (b)(5), or (d) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d443ce3-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s479D"},"text":"Pub. L. 89–329, title IV, § 479D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tVII/s702"},"text":"Pub. L. 116–260, div. FF, title VII, § 702","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1), "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3161"},"text":"134 Stat. 3161","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dR/s103/b"},"text":"Pub. L. 117–103, div. R, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/820"},"text":"136 Stat. 820","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d443ce4-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d443ce5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d443ce6-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (b)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Parts B and E of title IV of the Act are classified generally to parts B (§ 620 et seq.) and E (§ 670 et seq.), respectively, of subchapter IV of chapter 7 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d443ce7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s103/b/1"},"text":"Pub. L. 117–103, § 103(b)(1)","children":[],"tail":", inserted “the same or” before “a prior award”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s103/b/2"},"text":"Pub. L. 117–103, § 103(b)(2)","children":[],"tail":", inserted “the same or” before “a prior award”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s103/b/3"},"text":"Pub. L. 117–103, § 103(b)(3)","children":[],"tail":", inserted “this section, or paragraph (2), (8), or (9) of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087vv/d"},"text":"section 1087vv(d) of this title","children":[],"tail":",” after “pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087tt/c"},"text":"section 1087tt(c) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d443ce8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d443ce9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":" effective as if included in title VII of div. FF of "},{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" and subject to the effective date of section 701(b) of title VII ("},{"tag":"date","attrib":{"date":"2024-07-01"},"text":"July 1, 2024","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dR/s103/d"},"text":"section 103(d) of div. R of Pub. L. 117–103","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a"},"text":"section 1070a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d443cea-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2024-07-01"},"text":"July 1, 2024","children":[],"tail":", except as otherwise expressly provided, and applicable with respect to award year 2024–2025 and each subsequent award year, as determined under this chapter, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/s701/b"},"text":"section 701(b) of Pub. L. 116–260","children":[],"tail":", set out as an Effective Date of 2020 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":". Implementation of section allowed on or after "},{"tag":"date","attrib":{"date":"2023-07-01"},"text":"July 1, 2023","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/s102/c/1/A/iii"},"text":"section 102(c)(1)(A)(iii) of Pub. L. 117–103","children":[],"tail":", set out as an On-Time Effective Date Permitted note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a"},"text":"section 1070a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
