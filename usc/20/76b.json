{"tag":"section","attrib":{"id":"id0c799add-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76b"},"text":null,"children":[{"tag":"num","attrib":{"value":"76b"},"text":"§ 76b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Regents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c799ade-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation of construction funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Regents are authorized to solicit and receive subscriptions of funds from private sources for the purposes specified in this subsection. Funds so received shall be placed in a special deposit account with the Treasurer of the United States, and may be expended by the Regents to meet the cost of the construction of the building, including furnishings and equipment thereof, to obtain necessary drawings and specifications, make necessary surveys and estimates of cost, defray necessary administrative expenses, and secure other needful services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c799adf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of building","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Regents may, subject to the approval of the President, authorize the preparation of the site and the construction of the building, including approaches and landscaping of the grounds: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the Administrator of General Services shall supervise the preparation of the plans and specifications, make all necessary contracts, and supervise construction."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c799ae0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Name of building; supervision and control","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The name of the building shall be the Smithsonian Gallery of Art (hereinafter referred to as the “Gallery”), and it shall be under the supervision and control of the Regents and the Secretary of the Smithsonian Institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c799ae1-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-05-17/ch238/s3"},"text":"May 17, 1938, ch. 238, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/400"},"text":"52 Stat. 400","children":[],"tail":"; 1939 Reorg. Plan No. I, §§ 301, 303, eff. "},{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", 4 F.R. 2729, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1426"},"text":"53 Stat. 1426","children":[],"tail":", 1427; "},{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title I, § 103, "},{"tag":"ref","attrib":{"href":"/us/stat/63/380"},"text":"63 Stat. 380","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c799ae2-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0c799ae3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id0c799ae4-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Federal Works Agency and of all agencies thereof, together with functions of Federal Works Administrator, transferred to Administrator of General Services, and Federal Works Agency and office of Federal Works Administrator abolished by section 103 of act ","children":[{"tag":"date","attrib":{"date":"1949-06-30"},"text":"June 30, 1949","children":[],"tail":". See Historical and Revision Notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s303/b"},"text":"section 303(b) of Title 40","children":[],"tail":", Public Buildings, Property, and Works. "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s303/b"},"text":"Section 303(b) of Title 40","children":[],"tail":" was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/109/313/s2/a/1"},"text":"Pub. L. 109–313, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1734"},"text":"120 Stat. 1734","children":[],"tail":", and, as so amended, no longer relates to the Federal Works Agency and Commissioner of Public Buildings. See 2006 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s303"},"text":"section 303 of Title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id0c799ae5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id0c799ae6-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Director of Procurement relating to selection of location and sites of public buildings transferred to Federal Works Administrator by Reorg. Plan No. I of 1939, set out in the Appendix to Title 5, Government Organization and Employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
