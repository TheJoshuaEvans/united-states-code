{"tag":"section","attrib":{"id":"id0d823119-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161c"},"text":"§ 1161c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Business workforce partnerships for job skill training in high-growth occupations or industries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d82311a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this section is to provide grants to institutions of higher education partnering with employers to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d82311b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide relevant job skill training in high-growth and high-wage industries or occupations to nontraditional students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d82311c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen ties between degree credit offerings at institutions of higher education and business and industry workforce needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d82311d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d82311e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amounts appropriated under subsection (k), the Secretary shall award grants, on a competitive basis, to eligible partnerships for the purpose provided in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d82311f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants under this section for a period of not less than 36 months and not more than 60 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d823120-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement, not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under this section shall be used to supplement, and not supplant, other Federal, State, and local funds available to the eligible partnership for carrying out the activities described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d823121-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In consultation with all of the members of an eligible partnership, grant funds provided under this section may be used to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d823122-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand or create for-credit academic programs or programs of training that provide relevant job skill training for high-growth and high-wage occupations or industries, including offerings connected to registered apprenticeship programs and entrepreneurial training opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d823123-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with faculty in the appropriate departments of an institution of higher education, adapt college offerings to the schedules and needs of working students, such as the creation of evening, weekend, modular, compressed, or distance learning formats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d823124-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase equipment that will facilitate the development of academic programs or programs of training that provide training for high-growth and high-wage occupations or industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d823125-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen outreach efforts that enable students, including students with limited English proficiency, to attend institutions of higher education with academic programs or programs of training focused on high-growth and high-wage occupations or industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d823126-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand worksite learning and training opportunities, including registered apprenticeships as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d823127-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support other activities the Secretary determines to be consistent with the purpose of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d823128-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d823129-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible partnership that desires a grant under this section shall submit an application to the Secretary at such time, in such manner, and accompanied by such additional information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d82312a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application submitted under paragraph (1) shall include a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d82312b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the eligible partnership, through the institution of higher education, will provide relevant job skill training for students to enter high-growth and high-wage occupations or industries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d82312c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the eligible partnership has consulted with employers and, where applicable, labor organizations to identify local high-growth and high-wage occupations or industries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d82312d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award basis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d82312e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give priority to applications focused on serving nontraditional students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d82312f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure an equitable distribution of grant funds under this section among urban and rural areas of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d823130-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" take into consideration the capability of an institution of higher education that is participating in an eligible partnership to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d823131-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer one- or two-year high-quality programs of instruction and job skill training for students entering a high-growth and high-wage occupation or industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d823132-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve the local business community, and to place graduates in employment in high-growth and high-wage occupations or industries in the community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d823133-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve adult workers or displaced workers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d823134-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grantee under this section may use not more than five percent of the grant amount to pay administrative costs associated with activities funded by the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d823135-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide technical assistance to grantees under this section throughout the grant period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d823136-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct an evaluation of the effectiveness of the program under this section based on performance standards developed in consultation with the Department of Labor, and shall disseminate to the public the findings of such evaluation and information related to promising practices developed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d823137-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 36 months after the first grant is awarded under this section, the Comptroller General shall report to the authorizing committees recommendations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d823138-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for changes to this chapter and related Acts, such as the Carl D. Perkins Career and Technical Education Act of 2006 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2301"},"text":"20 U.S.C. 2301","children":[],"tail":" et seq.] and the Workforce Innovation and Opportunity Act (including titles I and II ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3111"},"text":"29 U.S.C. 3111","children":[],"tail":" et seq., 3271 et seq.]), to help create and sustain business and industry workforce partnerships at institutions of higher education; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d823139-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for other changes to this chapter and related Acts to otherwise strengthen the links between business and industry workforce needs, workforce development programs, and other degree credit offerings at institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d82313a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d82313b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible partnership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d82313c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible partnership” means a partnership that includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d82313d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/j/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more institutions of higher education, one of which serves as the fiscal agent and grant recipient for the eligible partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d82313e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/j/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subparagraph (B), an employer, group of employers, local board (as such term is defined in section 3 of the Workforce Innovation and Opportunity Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"29 U.S.C. 3102","children":[],"tail":"]), or workforce intermediary, or any combination thereof; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d82313f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/j/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where applicable, one or more labor organizations that represent workers locally in the businesses or industries that are the focus of the partnership, including as a result of such an organization’s representation of employees at a worksite at which the partnership proposes to conduct activities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d823140-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local boards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (A), if an institution of higher education that is participating in an eligible partnership under this section is located in a State that does not operate local boards, an eligible partnership may include a State board (as such term is defined in section 3 of the Workforce Innovation and Opportunity Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"29 U.S.C. 3102","children":[],"tail":"])."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d823141-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/j/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to prohibit an eligible partnership that is in existence on ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", from applying for a grant under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d823142-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nontraditional student","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “nontraditional student” means a student—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d823143-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is an independent student, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087vv/d"},"text":"section 1087vv(d) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d823144-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who attends an institution of higher education—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d823145-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/j/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on less than a full-time basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d823146-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/j/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" via evening, weekend, modular, or compressed courses; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d823147-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/j/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" via distance education methods; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d823148-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/j/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d823149-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/j/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrolled for the first time in an institution of higher education three or more years after completing high school; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d82314a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/j/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" works full-time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d82314b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161c/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d82314c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s803"},"text":"Pub. L. 89–329, title VIII, § 803","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3382"},"text":"122 Stat. 3382","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tV/s512/n/5"},"text":"Pub. L. 113–128, title V, § 512(n)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1710"},"text":"128 Stat. 1710","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d82314d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d82314e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d82314f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Carl D. Perkins Career and Technical Education Act of 2006, referred to in subsec. (i)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210"},"text":"Pub. L. 88–210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-12-18"},"text":"Dec. 18, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/403"},"text":"77 Stat. 403","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/b"},"text":"Pub. L. 109–270, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/683"},"text":"120 Stat. 683","children":[],"tail":", which is classified generally to chapter 44 (§ 2301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s2301"},"text":"section 2301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Workforce Innovation and Opportunity Act, referred to in subsec. (i)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1425"},"text":"128 Stat. 1425","children":[],"tail":", which enacted chapter 32 (§ 3101 et seq.) of Title 29, Labor, repealed chapter 30 (§ 2801 et seq.) of Title 29 and chapter 73 (§ 9201 et seq.) of Title 20, Education, and made amendments to numerous other sections and notes in the Code. Titles I and II of the Act are classified generally to subchapters I (§ 3111 et seq.) and II (§ 3271 et seq.), respectively, of chapter 32 of Title 29. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d823150-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (i)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s512/n/5/A"},"text":"Pub. L. 113–128, § 512(n)(5)(A)","children":[],"tail":", substituted “for changes to this chapter and related Acts, such as the Carl D. Perkins Career and Technical Education Act of 2006 and the Workforce Innovation and Opportunity Act (including titles I and II), to help create and sustain business and industry workforce partnerships at institutions of higher education” for “for changes to this chapter and related Acts, such as the Carl D. Perkins Career and Technical Education Act of 2006 and the Workforce Investment Act of 1998 (including titles I and II), to help create and sustain business and industry workforce partnerships at institutions of higher education”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s512/n/5/B/i"},"text":"Pub. L. 113–128, § 512(n)(5)(B)(i)","children":[],"tail":", substituted “local board (as such term is defined in section 3 of the Workforce Innovation and Opportunity Act)” for “local board (as such term is defined in section 101 of the Workforce Investment Act of 1998 ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2801"},"text":"29 U.S.C. 2801","children":[],"tail":"))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s512/n/5/B/ii"},"text":"Pub. L. 113–128, § 512(n)(5)(B)(ii)","children":[],"tail":", substituted “a State board (as such term is defined in section 3 of the Workforce Innovation and Opportunity Act)” for “a State board (as such term is defined in section 101 of the Workforce Investment Act of 1998 ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2801"},"text":"29 U.S.C. 2801","children":[],"tail":"))”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d823151-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d823152-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":" effective on the first day of the first full program year after "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
