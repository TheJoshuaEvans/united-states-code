{"tag":"section","attrib":{"id":"id0d633704-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098ee"},"text":null,"children":[{"tag":"num","attrib":{"value":"1098ee"},"text":"§ 1098ee.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d633705-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098ee/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Active duty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “active duty” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/d/1"},"text":"section 101(d)(1) of title 10","children":[],"tail":", except that such term does not include active duty for training or attendance at a service school."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d633706-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098ee/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affected individual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “affected individual” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d633707-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098ee/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is serving on active duty during a war or other military operation or national emergency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d633708-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098ee/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is performing qualifying National Guard duty during a war or other military operation or national emergency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d633709-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098ee/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resides or is employed in an area that is declared a disaster area by any Federal, State, or local official in connection with a national emergency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d63370a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098ee/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suffered direct economic hardship as a direct result of a war or other military operation or national emergency, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d63370b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098ee/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military operation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “military operation” means a contingency operation as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/13"},"text":"section 101(a)(13) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d63370c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098ee/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National emergency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “national emergency” means a national emergency declared by the President of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d63370d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098ee/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Serving on active duty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “serving on active duty during a war or other military operation or national emergency” shall include service by an individual who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d63370e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098ee/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Reserve of an Armed Force ordered to active duty under section 12301(a), 12301(g), 12302, 12304, or 12306 of title 10 or any retired member of an Armed Force ordered to active duty under section 688 of such title, for service in connection with a war or other military operation or national emergency, regardless of the location at which such active duty service is performed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d63370f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098ee/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other member of an Armed Force on active duty in connection with such war, operation, or emergency or subsequent actions or conditions who has been assigned to a duty station at a location other than the location at which such member is normally assigned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d633710-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098ee/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying National Guard duty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualifying National Guard duty during a war or other military operation or national emergency” means service as a member of the National Guard on full-time National Guard duty (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/d/5"},"text":"section 101(d)(5) of title 10","children":[],"tail":") under a call to active service authorized by the President or the Secretary of Defense for a period of more than 30 consecutive days under "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s502/f"},"text":"section 502(f) of title 32","children":[],"tail":", in connection with a war, another military operation, or a national emergency declared by the President and supported by Federal funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d633711-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/76/s5"},"text":"Pub. L. 108–76, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-08-18"},"text":"Aug. 18, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/906"},"text":"117 Stat. 906","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d633712-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d633713-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d633714-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out in a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070"},"text":"section 1070 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Higher Education Relief Opportunities for Students Act of 2003, and not as part of title IV of the Higher Education Act of 1965 which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
