{"tag":"section","attrib":{"id":"id0d7b2c9b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140"},"text":null,"children":[{"tag":"num","attrib":{"value":"1140"},"text":"§ 1140.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7b2c9c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive transition and postsecondary program for students with intellectual disabilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “comprehensive transition and postsecondary program for students with intellectual disabilities” means a degree, certificate, or nondegree program that meets each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7b2c9d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Is offered by an institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7b2c9e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Is designed to support students with intellectual disabilities who are seeking to continue academic, career and technical, and independent living instruction at an institution of higher education in order to prepare for gainful employment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7b2c9f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Includes an advising and curriculum structure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7b2ca0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Requires students with intellectual disabilities to participate on not less than a half-time basis as determined by the institution, with such participation focusing on academic components, and occurring through 1 or more of the following activities:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d7b2ca1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Regular enrollment in credit-bearing courses with nondisabled students offered by the institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7b2ca2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Auditing or participating in courses with nondisabled students offered by the institution for which the student does not receive regular academic credit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7b2ca3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enrollment in noncredit-bearing, nondegree courses with nondisabled students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7b2ca4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Participation in internships or work-based training in settings with nondisabled individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7b2ca5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Requires students with intellectual disabilities to be socially and academically integrated with non-disabled students to the maximum extent possible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7b2ca6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student with an intellectual disability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “student with an intellectual disability” means a student—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7b2ca7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with a cognitive impairment, characterized by significant limitations in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d7b2ca8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intellectual and cognitive functioning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7b2ca9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adaptive behavior as expressed in conceptual, social, and practical adaptive skills; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7b2caa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is currently, or was formerly, eligible for a free appropriate public education under the Individuals with Disabilities Education Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"20 U.S.C. 1400","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d7b2cab-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s760"},"text":"Pub. L. 89–329, title VII, § 760","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVII/s709/2"},"text":"Pub. L. 110–315, title VII, § 709(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3361"},"text":"122 Stat. 3361","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tVII/s701/4"},"text":"Pub. L. 111–39, title VII, § 701(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1954"},"text":"123 Stat. 1954","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/256/s2/a"},"text":"Pub. L. 111–256, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-05"},"text":"Oct. 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2643"},"text":"124 Stat. 2643","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d7b2cac-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d7b2cad-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d7b2cae-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Individuals with Disabilities Education Act, referred to in par. (2)(B), is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230"},"text":"Pub. L. 91–230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/175"},"text":"84 Stat. 175","children":[],"tail":", which is classified generally to chapter 33 (§ 1400 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d7b2caf-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1140, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s761"},"text":"Pub. L. 89–329, title VII, § 761","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVII/s701"},"text":"Pub. L. 105–244, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1801"},"text":"112 Stat. 1801","children":[],"tail":", stated the purpose of former part D, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVII/s709/2"},"text":"Pub. L. 110–315, title VII, § 709(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3361"},"text":"122 Stat. 3361","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d7b2cb0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Par. (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/256"},"text":"Pub. L. 111–256","children":[],"tail":" struck out “mental retardation or” before “a cognitive impairment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" added par. (1) and struck out former par. (1) which contained provisions substantially similar to new subpars. (A) to (D), defining “comprehensive transition and postsecondary program for students with intellectual disabilities”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d7b2cb1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d7b2cb2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" effective as if enacted on the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/s3"},"text":"section 3 of Pub. L. 111–39","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id0d7b2cb3-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For meaning of references to an intellectual disability and to individuals with intellectual disabilities in provisions amended by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/256/s2"},"text":"section 2 of Pub. L. 111–256","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/256/s2/k"},"text":"section 2(k) of Pub. L. 111–256","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
