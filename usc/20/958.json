{"tag":"section","attrib":{"id":"id0cb0618c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s958"},"text":null,"children":[{"tag":"num","attrib":{"value":"958"},"text":"§ 958.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Council on the Arts and the Humanities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cb0618d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s958/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Foundation a Federal Council on the Arts and the Humanities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cb0618e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s958/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition; presiding officer; changes in membership to meet changes in programs or executive branch organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall be composed of the Chairperson of the National Endowment for the Arts, the Chairperson of the National Endowment for the Humanities, the Director of the Institute of Museum and Library Services, the Secretary of Education, the Secretary of the Smithsonian Institution, the Director of the National Science Foundation, the Librarian of Congress, the Director of the National Gallery of Art, the Chairman of the Commission of Fine Arts, the Archivist of the United States, the Commissioner, Public Buildings Service, General Services Administration, the Assistant Secretary for Aging, a member designated by the Secretary of State, and a member designated by the Secretary of the Interior, a member designated by the Chairman of the Senate Commission on Art and Antiquities, and a member designated by the Speaker of the House. The President shall designate the presiding officer of the Council from among the members. The President is authorized to change the membership of the Council from time to time as the President deems necessary to meet changes in Federal programs or executive branch organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cb0618f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s958/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cb06190-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s958/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise and consult with the Chairperson of the National Endowment for the Arts and the Chairperson of the National Endowment for the Humanities on major problems arising in carrying out the purposes of the Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cb06191-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s958/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise and consult with the National Museum Services Board and with the Director of the Institute of Museum and Library Services on major problems arising in carrying out the purposes of such Institute;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cb06192-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s958/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate, by advice and consultation, so far as is practicable, the policies and operations of the National Endowment for the Arts, the National Endowment for the Humanities, and the Institute of Museum and Library Services, including joint support of activities, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cb06193-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s958/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote coordination between the programs and activities of the Foundation and related programs and activities of other Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cb06194-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s958/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plan and coordinate appropriate participation (including productions and projects) in major and historic national events;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cb06195-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s958/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undertake studies and make reports which address the state of the arts and humanities, particularly with respect to their economic needs and problems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cb06196-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s958/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage an ongoing dialogue in support of the arts and the humanities among Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cb06197-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/209/s9"},"text":"Pub. L. 89–209, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-29"},"text":"Sept. 29, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/851"},"text":"79 Stat. 851","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/346/s9"},"text":"Pub. L. 91–346, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-07-20"},"text":"July 20, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/446"},"text":"84 Stat. 446","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/133/s2/a/8"},"text":"Pub. L. 93–133, § 2(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-19"},"text":"Oct. 19, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/464"},"text":"87 Stat. 464","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/462/tII/s208"},"text":"Pub. L. 94–462, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-08"},"text":"Oct. 8, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1977"},"text":"90 Stat. 1977","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/496/tI"},"text":"Pub. L. 96–496, title I","children":[],"tail":", §§ 106, 109(d), "},{"tag":"date","attrib":{"date":"1980-12-04"},"text":"Dec. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2587"},"text":"94 Stat. 2587","children":[],"tail":", 2591; renumbered title I, § 9, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/306"},"text":"Pub. L. 98–306","children":[],"tail":", §§ 2, 6, "},{"tag":"date","attrib":{"date":"1984-05-31"},"text":"May 31, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/223"},"text":"98 Stat. 223","children":[],"tail":", 224; renumbered § 9 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/194/tI"},"text":"Pub. L. 99–194, title I","children":[],"tail":", §§ 101(1), 109, "},{"tag":"date","attrib":{"date":"1985-12-20"},"text":"Dec. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1332"},"text":"99 Stat. 1332","children":[],"tail":", 1339; "},{"tag":"ref","attrib":{"href":"/us/pl/101/512/tIII/s318/tI/s108"},"text":"Pub. L. 101–512, title III, § 318 [title I, § 108]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1960"},"text":"104 Stat. 1960","children":[],"tail":", 1970; "},{"tag":"ref","attrib":{"href":"/us/pl/103/171/s3/b/2"},"text":"Pub. L. 103–171, § 3(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1991"},"text":"107 Stat. 1991","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/340/tII/s208/2"},"text":"Pub. L. 111–340, title II, § 208(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3603"},"text":"124 Stat. 3603","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cb06198-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cb06199-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cb0619a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsecs. (b), (c)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/340"},"text":"Pub. L. 111–340","children":[],"tail":" substituted “Institute of Museum and Library Services” for “Institute of Museum Services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/171"},"text":"Pub. L. 103–171","children":[],"tail":" substituted “Assistant Secretary for Aging” for “Commissioner on Aging”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (c)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/512/s318/tI/s108/a"},"text":"Pub. L. 101–512, § 318 [title I, § 108(a)]","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/512/s318/tI/s108/b"},"text":"Pub. L. 101–512, § 318 [title I, § 108(b)]","children":[],"tail":", struck out subsec. (d) which related to studies on Federal support to museums and the impact of Institute of Museum Services and of conservation and preservation practices."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/194/s109/1"},"text":"Pub. L. 99–194, § 109(1)","children":[],"tail":", substituted “Chairperson” for “Chairman” in two places in first sentence, “presiding officer” for “Chairman” in second sentence, and “the President” for “he” in last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/194/s109/2"},"text":"Pub. L. 99–194, § 109(2)","children":[],"tail":", substituted “Chairperson” for “Chairman” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/194/s109/3"},"text":"Pub. L. 99–194, § 109(3)","children":[],"tail":", added subsec. (d). Former subsec. (d), relating to a study and report to the President and the Congress on artistic employment opportunities, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/194/s109/3"},"text":"Pub. L. 99–194, § 109(3)","children":[],"tail":", struck out subsec. (e) which provided for a study and report to the President and the Congress on arts and artifacts indemnification."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/306/s6/a"},"text":"Pub. L. 98–306, § 6(a)","children":[],"tail":", inserted “the Director of the Institute of Museum Services,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/306/s6/b"},"text":"Pub. L. 98–306, § 6(b)","children":[],"tail":", struck out “and the Institute of Museum Services” after “Foundation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/496"},"text":"Pub. L. 96–496","children":[],"tail":", §§ 106(a), 109(d), inserted “the Commissioner on Aging,” and substituted “Secretary of Education” for “United States Commissioner of Education”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/496/s106/b"},"text":"Pub. L. 96–496, § 106(b)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/496/s106/c"},"text":"Pub. L. 96–496, § 106(c)","children":[],"tail":", added subsecs. (d) and (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (c)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/462/s208/1"},"text":"Pub. L. 94–462, § 208(1)","children":[],"tail":", (2), added par. (2), redesignated former par. (2) as (3), and as so redesignated inserted “and the Institute of Museum Services,” after “Humanities,”. Former par. (3) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/462/s208/1"},"text":"Pub. L. 94–462, § 208(1)","children":[],"tail":", (3), redesignated former par. (3) as (4), inserted “and the Institute of Museum Services” after “Foundation”, and redesignated former par. (4) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/133"},"text":"Pub. L. 93–133","children":[],"tail":" included the Commissioner, Public Buildings Service, General Service Administration, a member designated by the Secretary of the Interior, a member designated by the Chairman of the Senate Commission on Art and Antiquities, and a member designated by the Speaker of the House, as members of the Federal Council on the Arts and Humanities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/346"},"text":"Pub. L. 91–346","children":[],"tail":" included the Archivist of the United States as a member of the Federal Council on the Arts and Humanities."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cb0619b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cb0619c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/512"},"text":"Pub. L. 101–512","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see section 318 [title IV, § 403(a)] of "},{"tag":"ref","attrib":{"href":"/us/pl/101/512"},"text":"Pub. L. 101–512","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s951"},"text":"section 951 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cb0619d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1973 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/133"},"text":"Pub. L. 93–133","children":[],"tail":" effective on and after "},{"tag":"date","attrib":{"date":"1973-07-01"},"text":"July 1, 1973","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/133/s2/b"},"text":"section 2(b) of Pub. L. 93–133","children":[],"tail":", set out a a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s951"},"text":"section 951 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
