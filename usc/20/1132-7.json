{"tag":"section","attrib":{"id":"id0d7400b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"1132–7"},"text":"§ 1132–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting by institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d7400b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The data requirement in subsection (b) shall apply to an institution of higher education that receives funds for a center or program under this subchapter if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7400b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–7/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the contribution (including cash and the fair market value of any property) received from any foreign government or from a foreign private sector corporation or foundation during any fiscal year exceeds $250,000 in the aggregate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7400b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–7/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate contribution, or a significant part of the aggregate contribution, is to be used by a center or program receiving funds under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7400b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require an institution of higher education referred to in subsection (a) to report information listed in subsection (a) to the Secretary consistent with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1011f"},"text":"section 1011f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d7400b7-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s638"},"text":"Pub. L. 89–329, title VI, § 638","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVI/s622"},"text":"Pub. L. 110–315, title VI, § 622","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3345"},"text":"122 Stat. 3345","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
