{"tag":"section","attrib":{"id":"id0c831072-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80e"},"text":null,"children":[{"tag":"num","attrib":{"value":"80e"},"text":"§ 80e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of policy","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress hereby finds and declares—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c831073-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that a living institution expressing the ideals and concerns of Woodrow Wilson would be an appropriate memorial to his accomplishments as the twenty-eighth President of the United States, a distinguished scholar, an outstanding university president, and a brilliant advocate of international understanding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c831074-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the Woodrow Wilson Memorial Commission, created by joint resolution of Congress, recommended that an International Center for Scholars be constructed in the District of Columbia in the area north of the proposed Market Square as part of the Nation’s memorial to Woodrow Wilson;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c831075-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that such a center, symbolizing and strengthening the fruitful relation between the world of learning and the world of public affairs, would be a suitable memorial to the spirit of Woodrow Wilson; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c831076-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the establishment of such a center would be consonant with the purposes of the Smithsonian Institution, created by Congress in 1846 “for the increase and diffusion of knowledge among men.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c831077-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/637/s2"},"text":"Pub. L. 90–637, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-24"},"text":"Oct. 24, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1357"},"text":"82 Stat. 1357","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c831078-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0c831079-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id0c83107a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/637/s1"},"text":"Pub. L. 90–637, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-24"},"text":"Oct. 24, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1356"},"text":"82 Stat. 1356","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/637/s1"},"text":"“That this Act [enacting this subchapter] may be cited as the ‘Woodrow Wilson Memorial Act of 1968’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
