{"tag":"section","attrib":{"id":"id0dad3906-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453"},"text":null,"children":[{"tag":"num","attrib":{"value":"1453"},"text":"§ 1453.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dad3907-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dad3908-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State educational agency that desires to receive a grant under this part shall submit to the Secretary an application at such time, in such manner, and including such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad3909-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The application shall include a plan that identifies and addresses the State and local needs for the personnel preparation and professional development of personnel, as well as individuals who provide direct supplementary aids and services to children with disabilities, and that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dad390a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designed to enable the State to meet the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1412/a/14"},"text":"section 1412(a)(14) of this title","children":[],"tail":" and section 1435(a)(8) and (9) of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad390b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is based on an assessment of State and local needs that identifies critical aspects and areas in need of improvement related to the preparation, ongoing training, and professional development of personnel who serve infants, toddlers, preschoolers, and children with disabilities within the State, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0dad390c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" current and anticipated personnel vacancies and shortages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dad390d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of preservice and inservice programs; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad390e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is integrated and aligned, to the maximum extent possible, with State plans and activities under the Elementary and Secondary Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"20 U.S.C. 6301","children":[],"tail":" et seq.], the Rehabilitation Act of 1973 ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"29 U.S.C. 701","children":[],"tail":" et seq.], and the Higher Education Act of 1965 ["},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"20 U.S.C. 1001","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad390f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State application shall contain an assurance that the State educational agency will carry out each of the strategies described in subsection (b)(4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dad3910-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements of State personnel development plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State personnel development plan under subsection (a)(2) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dad3911-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describe a partnership agreement that is in effect for the period of the grant, which agreement shall specify—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dad3912-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and extent of the partnership described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1452/b"},"text":"section 1452(b) of this title","children":[],"tail":" and the respective roles of each member of the partnership, including the partner described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1452/b/3"},"text":"section 1452(b)(3) of this title","children":[],"tail":" if applicable; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad3913-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the State educational agency will work with other persons and organizations involved in, and concerned with, the education of children with disabilities, including the respective roles of each of the persons and organizations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad3914-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe how the strategies and activities described in paragraph (4) will be coordinated with activities supported with other public resources (including part B [subchapter II] and part C [subchapter III] funds retained for use at the State level for personnel and professional development purposes) and private resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad3915-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe how the State educational agency will align its personnel development plan under this part with the plan and application submitted under sections 1111 and 2101(d), respectively, of the Elementary and Secondary Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311"},"text":"20 U.S.C. 6311","children":[],"tail":", 6611(d)];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad3916-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describe those strategies the State educational agency will use to address the professional development and personnel needs identified under subsection (a)(2) and how such strategies will be implemented, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dad3917-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the programs and activities to be supported under this part that will provide personnel with the knowledge and skills to meet the needs of, and improve the performance and achievement of, infants, toddlers, preschoolers, and children with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad3918-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how such strategies will be integrated, to the maximum extent possible, with other activities supported by grants funded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1462"},"text":"section 1462 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad3919-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an assurance that the State educational agency will provide technical assistance to local educational agencies to improve the quality of professional development available to meet the needs of personnel who serve children with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad391a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an assurance that the State educational agency will provide technical assistance to entities that provide services to infants and toddlers with disabilities to improve the quality of professional development available to meet the needs of personnel serving such children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad391b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe how the State educational agency will recruit and retain teachers who meet the qualifications described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1412/a/14/C"},"text":"section 1412(a)(14)(C) of this title","children":[],"tail":" and other qualified personnel in geographic areas of greatest need;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad391c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the steps the State educational agency will take to ensure that poor and minority children are not taught at higher rates by teachers who do not meet the qualifications described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1412/a/14/C"},"text":"section 1412(a)(14)(C) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad391d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe how the State educational agency will assess, on a regular basis, the extent to which the strategies implemented under this part have been effective in meeting the performance goals described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1412/a/15"},"text":"section 1412(a)(15) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dad391e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dad391f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use a panel of experts who are competent, by virtue of their training, expertise, or experience, to evaluate applications for grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1451/c/1"},"text":"section 1451(c)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad3920-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition of panel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of a panel described in paragraph (1) shall be composed of individuals who are not employees of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad3921-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of fees and expenses of certain members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use available funds appropriated to carry out this part to pay the expenses and fees of panel members who are not employees of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dad3922-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State educational agency that receives a grant under this part shall submit annual performance reports to the Secretary. The reports shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dad3923-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the progress of the State educational agency in implementing its plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad3924-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze the effectiveness of the State educational agency’s activities under this part and of the State educational agency’s strategies for meeting its goals under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1412/a/15"},"text":"section 1412(a)(15) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad3925-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1453/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify changes in the strategies used by the State educational agency and described in subsection (b)(4), if any, to improve the State educational agency’s performance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dad3926-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s653"},"text":"Pub. L. 91–230, title VI, § 653","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2768"},"text":"118 Stat. 2768","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX"},"text":"Pub. L. 114–95, title IX","children":[],"tail":", §§ 9214(d)(3), 9215(ss)(7), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2165"},"text":"129 Stat. 2165","children":[],"tail":", 2183.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dad3927-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dad3928-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0dad3929-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Elementary and Secondary Education Act of 1965, referred to in subsec. (a)(2)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-04-11"},"text":"Apr. 11, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/27"},"text":"79 Stat. 27","children":[],"tail":", which is classified generally to chapter 70 (§ 6301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Rehabilitation Act of 1973, referred to in subsec. (a)(2)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112"},"text":"Pub. L. 93–112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-09-26"},"text":"Sept. 26, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/355"},"text":"87 Stat. 355","children":[],"tail":", which is classified generally to chapter 16 (§ 701 et seq