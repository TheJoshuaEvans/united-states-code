{"tag":"section","attrib":{"id":"id0e21f374-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6843"},"text":null,"children":[{"tag":"num","attrib":{"value":"6843"},"text":"§ 6843.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e21f375-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6843/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Based upon the reports provided to a State educational agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6841"},"text":"section 6841 of this title","children":[],"tail":", each such agency that receives a grant under this part shall prepare and submit every second year to the Secretary a report on programs and activities carried out by the State educational agency under this part and the effectiveness of such programs and activities in improving the education provided to English learners."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e21f376-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6843/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every second year, the Secretary shall prepare and submit to the Committee on Education and the Workforce of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate a report—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e21f377-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6843/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on programs and activities carried out to serve English learners under this part, and the effectiveness of such programs and activities in improving the academic achievement and English proficiency of English learners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f378-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6843/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the types of language instruction educational programs used by local educational agencies or eligible entities receiving funding under this part to teach English learners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f379-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6843/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" containing a critical synthesis of data reported by eligible entities to States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6841/a"},"text":"section 6841(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f37a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6843/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" containing a description of technical assistance and other assistance provided by State educational agencies under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6821/b/2/D"},"text":"section 6821(b)(2)(D) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f37b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6843/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" containing an estimate of the number of certified or licensed teachers working in language instruction educational programs and educating English learners, and an estimate of the number of such teachers that will be needed for the succeeding 5 fiscal years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f37c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6843/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" containing the findings of the most recent evaluation related to English learners carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7981"},"text":"section 7981 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f37d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6843/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" containing the number of programs or activities, if any, that were terminated because the entities carrying out the programs or activities were not able to reach program goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f37e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6843/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" containing the number of English learners served by eligible entities receiving funding under this part who were transitioned out of language instruction educational programs funded under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f37f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6843/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" containing other information gathered from the evaluations from specially qualified agencies and other reports submitted to the Secretary under this part when applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e21f380-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIII/s3122"},"text":"Pub. L. 89–10, title III, § 3122","children":[],"tail":", formerly § 3123, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIII/s301"},"text":"Pub. L. 107–110, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1704"},"text":"115 Stat. 1704","children":[],"tail":"; renumbered § 3122 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIII"},"text":"Pub. L. 114–95, title III","children":[],"tail":", §§ 3001(2)(B), 3003(i), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1953"},"text":"129 Stat. 1953","children":[],"tail":", 1963.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e21f381-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e21f382-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e21f383-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6843, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/1