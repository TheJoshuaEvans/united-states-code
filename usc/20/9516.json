{"tag":"section","attrib":{"id":"id0e6257e3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516"},"text":null,"children":[{"tag":"num","attrib":{"value":"9516"},"text":"§ 9516.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Board for Education Sciences","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e6257e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute shall have a board of directors, which shall be known as the National Board for Education Sciences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6257e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of the Board shall be the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e6257e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To advise and consult with the Director on the policies of the Institute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6257e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To consider and approve priorities proposed by the Director under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9515"},"text":"section 9515 of this title","children":[],"tail":" to guide the work of the Institute."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6257e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To review and approve procedures for technical and scientific peer review of the activities of the Institute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6257e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To advise the Director on the establishment of activities to be supported by the Institute, including the general areas of research to be carried out by the National Center for Education Research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6257ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To present to the Director such recommendations as it may find appropriate for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e6257eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strengthening of education research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6257ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funding of the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6257ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To advise the Director on the funding of applications for grants, contracts, and cooperative agreements for research, after the completion of peer review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6257ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To review and regularly evaluate the work of the Institute, to ensure that scientifically valid research, development, evaluation, and statistical analysis are consistent with the standards for such activities under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6257ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To advise the Director on ensuring that activities conducted or supported by the Institute are objective, secular, neutral, and nonideological and are free of partisan political influence and racial, cultural, gender, or regional bias.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6257f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To solicit advice and information from those in the educational field, particularly practitioners and researchers, to recommend to the Director topics that require long-term, sustained, systematic, programmatic, and integrated research efforts, including knowledge utilization and wide dissemination of research, consistent with the priorities and mission of the Institute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6257f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To advise the Director on opportunities for the participation in, and the advancement of, women, minorities, and persons with disabilities in education research, statistics, and evaluation activities of the Institute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6257f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To recommend to the Director ways to enhance strategic partnerships and collaborative efforts among other Federal and State research agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6257f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To recommend to the Director individuals to serve as Commissioners of the National Education Centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6257f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e6257f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall have 15 voting members appointed by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6257f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall solicit advice regarding individuals to serve on the Board from the National Academy of Sciences, the National Science Board, and the National Science Advisor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6257f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonvoting ex officio members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall have the following nonvoting ex officio members:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e6257f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Institute of Education Sciences.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6257f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each of the Commissioners of the National Education Centers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6257fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Eunice Kennedy Shriver National Institute of Child Health and Human Development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6257fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Census.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6257fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commissioner of Labor Statistics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6257fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6257fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointed membership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e6257ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members appointed under paragraph (1) shall be highly qualified to appraise education research, statistics, evaluations, or development, and shall include the following individuals:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e625800-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not fewer than 8 researchers in the field of statistics, evaluation, social sciences, or physical and biological sciences, which may include those researchers recommended by the National Academy of Sciences.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e625801-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individuals who are knowledgeable about the educational needs of the United States, who may include school-based professional educators, parents (including parents with experience in promoting parental involvement in education), Chief State School Officers, State postsecondary education executives, presidents of institutions of higher education, local educational agency superintendents, early childhood experts, special education experts, principals, members of State or local boards of education or Bureau-funded school boards, and individuals from business and industry with experience in promoting private sector involvement in education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625802-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each member appointed under paragraph (1) shall serve for a term of 4 years, except that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e625803-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the terms of the initial members appointed under such paragraph shall (as determined by a random selection process at the time of appointment) be for staggered terms of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e625804-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 years for each of 5 members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e625805-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 years for each of 5 members; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e625806-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/4/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 years for each of 5 members; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e625807-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no member appointed under such paragraph shall serve for more than 2 consecutive terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625808-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unexpired terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any member appointed to fill a vacancy occurring before the expiration of the term for which the member’s predecessor was appointed shall be appointed only for the remainder of that term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625809-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A voting member of the Board shall be considered a special Government employee for the purposes of chapter 131 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e62580a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall elect a chair from among the members of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e62580b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Board shall serve without pay for such service. Members of the Board who are officers or employees of the United States may not receive additional pay, allowances, or benefits by reason of their service on the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e62580c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Board shall receive travel expenses, including per diem in lieu of subsistence, in accordance with subchapter I of chapter 57 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e62580d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of the Board","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e62580e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall have an Executive Director who shall be appointed by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e62580f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall utilize such additional staff as may be appointed or assigned by the Director, in consultation with the Chair and the Executive Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625810-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail of personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may use the services and facilities of any department or agency of the Federal Government. Upon the request of the Board, the head of any Federal department or agency may detail any of the personnel of that department or agency to the Board to assist the Board in carrying out this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625811-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may enter into contracts or make other arrangements as may be necessary to carry out its functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625812-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/8/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may, to the extent otherwise permitted by law, obtain directly from any executive department or agency of the Federal Government such information as the Board determines necessary to carry out its functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e625813-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall meet not less than 3 times each year. The Board shall hold additional meetings at the call of the Chair or upon the written request of not less than 6 voting members of the Board. Meetings of the Board are subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b"},"text":"section 552b of title 5","children":[],"tail":" (commonly referred to as the Government in the Sunshine Act)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e625814-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the voting members of the Board serving at the time of the meeting shall constitute a quorum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e625815-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standing committees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e625816-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board may establish standing committees—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e625817-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that will each serve 1 of the National Education Centers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625818-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advise, consult with, and make recommendations to the Director and the Commissioner of the appropriate National Education Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e625819-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A majority of the members of each standing committee shall be voting members of the Board whose expertise is needed for the functioning of the committee. In addition, the membership of each standing committee may include, as appropriate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e62581a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experts and scientists in research, statistics, evaluation, or development who are recognized in their discipline as highly qualified to represent such discipline and who are not members of the Board, but who may have been recommended by the Commissioner of the appropriate National Education Center and approved by the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e62581b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ex officio members of the Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e62581c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policymakers and expert practitioners with knowledge of, and experience using, the results of research, evaluation, and statistics who are not members of the Board, but who may have been recommended by the Commissioner of the appropriate National Education Center and approved by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e62581d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each standing committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e62581e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and comment, at the discretion of the Board or the standing committee, on any grant, contract, or cooperative agreement entered into (or proposed to be entered into) by the applicable National Education Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e62581f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare for, and submit to, the Board an annual evaluation of the operations of the applicable National Education Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625820-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and comment on the relevant plan for activities to be undertaken by the applicable National Education Center for each fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625821-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report periodically to the Board regarding the activities of the committee and the applicable National Education Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e625822-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall submit to the Director, the Secretary, and the appropriate congressional committees, not later than July 1 of each year, a report that assesses the effectiveness of the Institute in carrying out its priorities and mission, especially as such priorities and mission relate to carrying out scientifically valid research, conducting unbiased evaluations, collecting and reporting accurate education statistics, and translating research into practice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e625823-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9516/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall submit to the Director, the Secretary, and the appropriate congressional committees a report that includes any recommendations regarding any actions that may be taken to enhance the ability of the Institute to carry out its priorities and mission. The Board shall submit an interim report not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2002-11-05"},"text":"November 5, 2002","children":[],"tail":", and a final report not later than 5 years after such date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e625824-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s116"},"text":"Pub. L. 107–279, title I, § 116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1948"},"text":"116 Stat. 1948","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tII"},"text":"Pub. L. 108–446, title II","children":[],"tail":", §§ 201(b)(2)(D), 202, "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2802"},"text":"118 Stat. 2802","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/154/s1/d"},"text":"Pub. L. 110–154, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-21"},"text":"Dec. 21, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1828"},"text":"121 Stat. 1828","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s2/cc"},"text":"Pub. L. 112–166, § 2(cc)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1290"},"text":"126 Stat. 1290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/c/28"},"text":"Pub. L. 117–286, § 4(c)(28)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4357"},"text":"136 Stat. 4357","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e625825-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e625826-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e625827-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (c)(8)(C), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279"},"text":"Pub. L. 107–279","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1940"},"text":"116 Stat. 1940","children":[],"tail":", which enacted this chapter and "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3419"},"text":"section 3419 of this title","children":[],"tail":", amended sections 1232j, 3412, 3461, 6194, 6311, 6312, 7013, 7451, 7703, 7909, 9007, 9010, 9011, 9573, 9623, and 9624 and former sections 6317, 6491, 6932, 7253c, 7283b, and 7283d of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of Title 5","children":[],"tail":", Government Organization and Employees, transferred sections 9010 and 9011 of this title to sections 9621 and 9622 of this title, respectively, repealed sections 3419, 6011, 6021, 6031, 6041, 6051, 6053 to 6053e, 6054 to 6054b, 6055 to 6055h, 6056, 6056a, 9001 to 9009, and 9012 of this title, enacted provisions set out as notes under section 7703 and 9501 of this title, and repealed provisions set out as notes under sections 1221e and 9001 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e625828-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(4)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 131 of title 5.” for “the Ethics in Government Act of 1978.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166"},"text":"Pub. L. 112–166","children":[],"tail":" struck out “, by and with the advice and consent of the Senate” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (c)(4)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/446/s201/b/2/D"},"text":"Pub. L. 108–446, § 201(b)(2)(D)","children":[],"tail":", inserted “special education experts,” after “early childhood experts,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/446/s202"},"text":"Pub. L. 108–446, § 202","children":[],"tail":", substituted “Meetings of the Board are subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b"},"text":"section 552b of title 5","children":[],"tail":" (commonly referred to as the Government in the Sunshine Act).” for “Meetings of the Board shall be open to the public.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e625829-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id0e62582a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Eunice Kennedy Shriver National Institute of Child Health and Human Development” substituted for “National Institute of Child Health and Human Development” in subsec. (c)(3)(C), on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/154/s1/d"},"text":"section 1(d) of Pub. L. 110–154","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s285g"},"text":"section 285g of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e62582b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166"},"text":"Pub. L. 112–166","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", and applicable to appointments made on and after that effective date, including any nomination pending in the Senate on that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s6/a"},"text":"section 6(a) of Pub. L. 112–166","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s113"},"text":"section 113 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
