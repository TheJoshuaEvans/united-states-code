{"tag":"section","attrib":{"id":"id0cc5e592-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019"},"text":null,"children":[{"tag":"num","attrib":{"value":"1019"},"text":"§ 1019.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cc5e593-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agent” means an officer or employee of a covered institution or an institution-affiliated organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc5e594-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered institution” means any institution of higher education, as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"section 1002 of this title","children":[],"tail":", that receives any Federal funding or assistance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc5e595-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education loan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “education loan” (except when used as part of the term “private education loan”) means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cc5e596-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any loan made, insured, or guaranteed under part B of subchapter IV;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc5e597-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any loan made under part D of subchapter IV; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc5e598-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private education loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc5e599-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible lender","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible lender” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1085/d"},"text":"section 1085(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc5e59a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution-affiliated organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “institution-affiliated organization”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cc5e59b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means any organization that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cc5e59c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is directly or indirectly related to a covered institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cc5e59d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is engaged in the practice of recommending, promoting, or endorsing education loans for students attending such covered institution or the families of such students;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc5e59e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include an alumni organization, athletic organization, foundation, or social, academic, or professional organization, of a covered institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc5e59f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding subparagraphs (A) and (B), does not include any lender with respect to any education loan secured, made, or extended by such lender.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc5e5a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lender","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “lender” (except when used as part of the terms “eligible lender” and “private educational lender”)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cc5e5a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cc5e5a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a loan made, insured, or guaranteed under part B of subchapter IV, an eligible lender;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cc5e5a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any loan issued or provided to a student under part D of subchapter IV, the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cc5e5a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a private education loan, a private educational lender as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1650"},"text":"section 1650 of title 15","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc5e5a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any other person engaged in the business of securing, making, or extending education loans on behalf of the lender.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc5e5a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “officer” includes a director or trustee of a covered institution or institution-affiliated organization, if such individual is treated as an employee of such covered institution or institution-affiliated organization, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc5e5a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferred lender arrangement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “preferred lender arrangement”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cc5e5a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means an arrangement or agreement between a lender and a covered institution or an institution-affiliated organization of such covered institution—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cc5e5a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/8/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under which a lender provides or otherwise issues education loans to the students attending such covered institution or the families of such students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cc5e5aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/8/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that relates to such covered institution or such institution-affiliated organization recommending, promoting, or endorsing the education loan products of the lender; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc5e5ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cc5e5ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrangements or agreements with respect to loans under part D of subchapter IV; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cc5e5ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrangements or agreements with respect to loans that originate through the auction pilot program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1099d/b"},"text":"section 1099d(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc5e5ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private education loan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “private education loan” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1650"},"text":"section 1650 of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cc5e5af-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s151"},"text":"Pub. L. 89–329, title I, § 151","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tI/s120"},"text":"Pub. L. 110–315, title I, § 120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3117"},"text":"122 Stat. 3117","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cc5e5b0-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cc5e5b1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cc5e5b2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1019, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s119"},"text":"Pub. L. 89–329, title I, § 119","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tI/s101/a"},"text":"Pub. L. 96–374, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1383"},"text":"94 Stat. 1383","children":[],"tail":", authorized appropriations for education outreach programs, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
