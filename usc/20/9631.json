{"tag":"section","attrib":{"id":"id0e69836c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631"},"text":null,"children":[{"tag":"num","attrib":{"value":"9631"},"text":"§ 9631.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Center for Research in Advanced Information and Digital Technologies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e69836d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be established, during the first fiscal year for which appropriations are made available under subsection (c), a nonprofit corporation to be known as the National Center for Research in Advanced Information and Digital Technologies, which shall not be an agency or establishment of the Federal Government. The Center shall be subject to the provisions of this section, and, to the extent consistent with this section, to the District of Columbia Nonprofit Corporation Act (sec. 29–501 et seq., D.C. Official Code).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e69836e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the Center shall be to support a comprehensive research and development program to harness the increasing capacity of advanced information and digital technologies to improve all levels of learning and education, formal and informal, in order to provide Americans with the knowledge and skills needed to compete in the global economy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e69836f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e698370-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Center such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e698371-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Center is authorized—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e698372-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept funds from any Federal agency or entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e698373-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept, hold, administer, and spend any gift, devise, or bequest of real or personal property made to the Center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e698374-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enter into competitive contracts with individuals, public or private organizations, professional societies, and government agencies for the purpose of carrying out the functions of the Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e698375-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Center shall not accept gifts, devises, or bequests from a foreign government or foreign source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e698376-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Directors; vacancies; compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e698377-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Board of the Center shall be established to oversee the administration of the Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e698378-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The initial Board shall consist of nine members to be appointed by the Secretary of Education from recommendations received from the Speaker of the House of Representatives, the Minority Leader of the House of Representatives, the majority leader of the Senate, and the minority leader of the Senate, who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e698379-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflect representation from the public and private sectors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e69837a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide, as nearly as practicable, a broad representation of various regions of the United States, various professions and occupations, and various kinds of talent and experience appropriate to the functions and responsibilities of the Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e69837b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be in a position to benefit financially directly from the contracts and grants to eligible institutions under subsection (f)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e69837c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be officers or employees of the Federal Government or a Members of Congress serving at the time of such appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e69837d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies and subsequent appointments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent not inconsistent with paragraph (2), in the case of a vacancy on the Board due to death, resignation, or removal, the vacancy shall be filled through nomination and selection by the sitting members of the Board after—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e69837e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taking into consideration the composition of the Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e69837f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" soliciting recommendations from the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e698380-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Board shall serve without compensation but may be reimbursed for reasonable expenses for transportation, lodging, and other expenses directly related to their duties as members of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e698381-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization and operation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall incorporate and operate the Center in accordance with the laws governing tax exempt organizations in the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e698382-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director and staff","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e698383-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall appoint a Director of the Center after conducting a national, competitive search to find an individual with the appropriate expertise, experience, and knowledge to oversee the operations of the Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e698384-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with procedures established by the Board, the Director shall employ individuals to carry out the functions of the Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e698385-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In no case shall the Director or any employee of the Center receive annual compensation that exceeds an amount equal to the annual rate payable for level II of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e698386-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Center activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e698387-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director, after consultation with the Board, shall use the funds made available to the Center—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e698388-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support research to improve education, teaching, and learning that is in the public interest, but that is determined unlikely to be undertaken entirely with private funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e698389-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to support—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e69838a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" precompetitive research, development, and demonstrations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e69838b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessments of prototypes of innovative digital learning and information technologies, as well as the components and tools needed to create such technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e69838c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/f/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pilot testing and evaluation of prototype systems described in clause (ii); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e69838d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage the widespread adoption and use of effective, innovative digital approaches to improving education, teaching, and learning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e69838e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts and grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e69838f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out the activities described in paragraph (1), the Director, with the agreement of two-thirds of the members of the Board, may award, on a competitive basis, contracts and grants to four-year institutions of higher education, museums, libraries, nonprofit organizations, public institutions with or without for-profit partners, for-profit organizations, and consortia of any such entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e698390-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public domain","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e698391-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The research and development properties and materials associated with any project funded by a grant or contract under this section shall be freely and nonexclusively available to the general public in a timely manner, consistent with regulations prescribed by the Secretary of Education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e698392-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may waive the requirements of clause (i) with respect to a project funded by a grant or contract under this section if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e698393-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/f/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director and the Board (by a unanimous vote of the Board members) determine that the general public will benefit significantly due to the project not being freely and nonexclusively available to the general public in a timely manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e698394-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/f/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board issues a public statement as to the specific reasons of the determination under subclause (I).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e698395-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Proposals for grants or contracts shall be evaluated on the basis of comparative merit by panels of experts who represent diverse interests and perspectives, and who are appointed by the Director based on recommendations from the fields served and from the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e698396-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability and reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e698397-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e698398-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than December 30 of each year beginning in fiscal year 2009, the Director shall prepare and submit to the Secretary of Education and the authorizing committees a report that contains the information described in subparagraph (B) with respect to the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e698399-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A report under subparagraph (A) shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e69839a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/g/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comprehensive and detailed report of the Center’s operations, activities, financial condition, and accomplishments, and such recommendations as the Director determines appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e69839b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/g/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence of coordination with the Department of Education, the National Science Foundation, Office of the Assistant Secretary of Defense for Research and Engineering in the Department of Defense, and other related Federal agencies to carry out the operations and activities of the Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e69839c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/g/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comprehensive and detailed inventory of funds distributed from the Center during the fiscal year for which the report is being prepared; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e69839d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/g/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an independent audit of the Center’s finances and operations, and of the implementation of the goals established by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e69839e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of the Board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subparagraph (A) shall include a statement from the Board containing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e69839f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/g/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a clear description of the plans and priorities of the Board for the subsequent year for activities of the Center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e6983a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/g/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the funds that will be expended by the Center for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6983a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testimony","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director and principal officers of the Center shall testify before the authorizing committees and the Committees on Appropriations of the House of Representatives and the Senate, upon request of such committees, with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e6983a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any report required under paragraph (1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6983a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other matter that such committees may determine appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6983a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds subject to appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority to award grants, enter into contracts, or otherwise expend funds under this section is subject to the availability of amounts deposited into the Center under subsection (c), or amounts otherwise appropriated for such purposes by an Act of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6983a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e6983a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizing committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “authorizing committees” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1003"},"text":"section 1003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6983a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the Board of the Center appointed under subsection (d)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6983a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Center” means the National Center for Research in Advanced Information and Digital Technologies established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6983a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9631/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the Center appointed under subsection (e)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e6983aa-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s802"},"text":"Pub. L. 110–315, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3446"},"text":"122 Stat. 3446","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/c/2/A/vii"},"text":"Pub. L. 112–239, div. A, title X, § 1076(c)(2)(A)(vii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1950"},"text":"126 Stat. 1950","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e6983ab-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e6983ac-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e6983ad-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The District of Columbia Nonprofit Corporation Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/569"},"text":"Pub. L. 87–569","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-08-06"},"text":"Aug. 6, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/265"},"text":"76 Stat. 265","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0e6983ae-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Higher Education Opportunity Act, and not as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279"},"text":"Pub. L. 107–279","children":[],"tail":" which comprises this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e6983af-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (g)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" substituted “Assistant Secretary of Defense for Research and Engineering” for “Director of Defense Research and Engineering”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
