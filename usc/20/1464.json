{"tag":"section","attrib":{"id":"id0daf8211-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464"},"text":null,"children":[{"tag":"num","attrib":{"value":"1464"},"text":"§ 1464.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies and evaluations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0daf8212-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies and evaluations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daf8213-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall delegate to the Director of the Institute of Education Sciences responsibility to carry out this section, other than subsections (d) and (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf8214-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, directly or through grants, contracts, or cooperative agreements awarded to eligible entities on a competitive basis, assess the progress in the implementation of this chapter, including the effectiveness of State and local efforts to provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daf8215-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a free appropriate public education to children with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8216-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early intervention services to infants and toddlers with disabilities, and infants and toddlers who would be at risk of having substantial developmental delays if early intervention services were not provided to the infants and toddlers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daf8217-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of national activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daf8218-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a national assessment of activities carried out with Federal funds under this chapter in order—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daf8219-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine the effectiveness of this chapter in achieving the purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf821a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide timely information to the President, Congress, the States, local educational agencies, and the public on how to implement this chapter more effectively; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf821b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide the President and Congress with information that will be useful in developing legislation to achieve the purposes of this chapter more effectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf821c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The national assessment shall assess activities supported under this chapter, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daf821d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of programs assisted under this chapter and the impact of such programs on addressing the developmental needs of, and improving the academic achievement of, children with disabilities to enable the children to reach challenging developmental goals and challenging State academic content standards based on State academic assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf821e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of programs and services that have demonstrated the greatest likelihood of helping students reach the challenging State academic content standards and developmental goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf821f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of the professional development activities assisted under this chapter and the impact on instruction, student academic achievement, and teacher qualifications to enhance the ability of special education teachers and regular education teachers to improve results for children with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8220-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the effectiveness of schools, local educational agencies, States, other recipients of assistance under this chapter, and the Secretary in achieving the purposes of this chapter by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0daf8221-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the academic achievement of children with disabilities and their performance on regular statewide assessments as compared to nondisabled children, and the performance of children with disabilities on alternate assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0daf8222-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the participation of children with disabilities in the general education curriculum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0daf8223-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the transitions of children with disabilities at natural transition points;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0daf8224-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/b/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" placing and serving children with disabilities, including minority children, in the least restrictive environment appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0daf8225-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/b/2/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing children with disabilities, especially children with emotional disturbances and specific learning disabilities, from dropping out of school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0daf8226-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/b/2/D/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addressing the reading and literacy needs of children with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0daf8227-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/b/2/D/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing the inappropriate overidentification of children, especially minority and limited English proficient children, as having a disability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0daf8228-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/b/2/D/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the participation of parents of children with disabilities in the education of their children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0daf8229-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/b/2/D/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resolving disagreements between education personnel and parents through alternate dispute resolution activities, including mediation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf822a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim and final reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit to the President and Congress—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daf822b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an interim report that summarizes the preliminary findings of the assessment not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2004-12-03"},"text":"December 3, 2004","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf822c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a final report of the findings of the assessment not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2004-12-03"},"text":"December 3, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daf822d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study on ensuring accountability for students who are held to alternative achievement standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a national study or studies to examine—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daf822e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the criteria that States use to determine—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daf822f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligibility for alternate assessments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8230-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and type of children who take those assessments and are held accountable to alternative achievement standards;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf8231-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the validity and reliability of alternate assessment instruments and procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf8232-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alignment of alternate assessments and alternative achievement standards to State academic content standards in reading, mathematics, and science; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf8233-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use and effectiveness of alternate assessments in appropriately measuring student progress and outcomes specific to individualized instructional need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daf8234-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide an annual report to Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daf8235-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summarizes the research conducted under part E of the Education Sciences Reform Act of 2002 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9567"},"text":"20 U.S.C. 9567","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf8236-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyzes and summarizes the data reported by the States and the Secretary of the Interior under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1418"},"text":"section 1418 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf8237-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summarizes the studies and evaluations conducted under this section and the timeline for their completion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf8238-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the extent and progress of the assessment of national activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf8239-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the findings and determinations resulting from reviews of State implementation of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daf823a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary may support objective studies, evaluations, and assessments, including studies that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daf823b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze measurable impact, outcomes, and results achieved by State educational agencies and local educational agencies through their activities to reform policies, procedures, and practices designed to improve educational and transitional services and results for children with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf823c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze State and local needs for professional development, parent training, and other appropriate activities that can reduce the need for disciplinary actions involving children with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf823d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assess educational and transitional services and results for children with disabilities from minority backgrounds, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daf823e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" data on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0daf823f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of minority children who are referred for special education evaluation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0daf8240-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of minority children who are receiving special education and related services and their educational or other service placement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0daf8241-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/e/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of minority children who graduated from secondary programs with a regular diploma in the standard number of years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0daf8242-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/e/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of minority children who drop out of the educational system; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8243-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the performance of children with disabilities from minority backgrounds on State assessments and other performance indicators established for all students;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf8244-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" measure educational and transitional services and results for children with disabilities served under this chapter, including longitudinal studies that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daf8245-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine educational and transitional services and results for children with disabilities who are 3 through 17 years of age and are receiving special education and related services under this chapter, using a national, representative sample of distinct age cohorts and disability categories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8246-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine educational results, transition services, postsecondary placement, and employment status for individuals with disabilities, 18 through 21 years of age, who are receiving or have received special education and related services under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf8247-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and report on the placement of children with disabilities by disability category.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daf8248-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1464/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall study, and report to Congress regarding, the extent to which States adopt policies described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1435/c/1"},"text":"section 1435(c)(1) of this title","children":[],"tail":" and on the effects of those policies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0daf8249-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s664"},"text":"Pub. L. 91–230, title VI, § 664","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2783"},"text":"118 Stat. 2783","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0daf824a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0daf824b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0daf824c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Education Sciences Reform Act of 2002, referred to in subsec. (d)(1), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279"},"text":"Pub. L. 107–279","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1941"},"text":"116 Stat. 1941","children":[],"tail":". Part E of the Act is classified generally to part E (§ 9567 et seq.) of subchapter I of chapter 76 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9501"},"text":"section 9501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
