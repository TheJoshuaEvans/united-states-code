23/c/3"},"text":"Pub. L. 94–482, title I, § 123(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2094"},"text":"90 Stat. 2094","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/43/s1/a/7"},"text":"Pub. L. 95–43, § 1(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-06-15"},"text":"June 15, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/213"},"text":"91 Stat. 213","children":[],"tail":", related to a program of bonus allotments, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tIV/s404/d"},"text":"Pub. L. 96–374, title IV, § 404(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1407"},"text":"94 Stat. 1407","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cf0c61c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/50"},"text":"Pub. L. 100–50","children":[],"tail":" substituted “literacy” for “literary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cf0c61d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cf0c61e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"