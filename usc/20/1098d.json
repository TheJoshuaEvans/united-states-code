{"tag":"section","attrib":{"id":"id0d60ed57-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1098d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1098d"},"text":"§ 1098d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for cancellations and deferments for eligible disabled veterans","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of Veterans Affairs, shall develop and implement a procedure to permit Department of Veterans Affairs physicians to provide the certifications and affidavits needed to enable disabled veterans enrolled in the Department of Veterans Affairs health care system to document such veterans’ eligibility for deferments or cancellations of student loans made, insured, or guaranteed under this subchapter. Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"1998-10-07"},"text":"October 7, 1998","children":[],"tail":", the Secretary and the Secretary of Veterans Affairs jointly shall report to Congress on the progress made in developing and implementing the procedure."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d60ed58-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s493B"},"text":"Pub. L. 89–329, title IV, § 493B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s490F"},"text":"Pub. L. 105–244, title IV, § 490F","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1758"},"text":"112 Stat. 1758","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d60ed59-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d60ed5a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d60ed5b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
