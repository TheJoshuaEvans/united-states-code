{"tag":"section","attrib":{"id":"id0e0c960b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6322"},"text":null,"children":[{"tag":"num","attrib":{"value":"6322"},"text":"§ 6322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e0c960c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each local educational agency receiving assistance under this part shall carry out the activities described in subsection (b) with Head Start agencies and, if feasible, other entities carrying out early childhood development programs. Each local educational agency shall develop agreements with such Head Start agencies and other entities to carry out such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0c960d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The activities referred to in subsection (a) are activities that increase coordination between the local educational agency and a Head Start agency and, if feasible, other entities carrying out early childhood education programs serving children who will attend the schools of the local educational agency, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0c960e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6322/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and implementing a systematic procedure for receiving records regarding such children, transferred with parental consent from a Head Start program or, where applicable, another early childhood education program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c960f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6322/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing channels of communication between school staff and their counterparts (including teachers, social workers, and health staff) in such Head Start agencies or other entities carrying out early childhood education programs, as appropriate, to facilitate coordination of programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c9610-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6322/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting meetings involving parents, kindergarten or elementary school teachers, and Head Start teachers or, if appropriate, teachers from other early childhood education programs, to discuss the developmental and other needs of individual children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c9611-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6322/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizing and participating in joint transition-related training of school staff, Head Start program staff, and, where appropriate, other early childhood education program staff; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c9612-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6322/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" linking the educational services provided by such local educational agency with the services provided by local Head Start agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0c9613-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6322/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall work with the Secretary of Health and Human Services to coordinate regulations promulgated under this part with regulations promulgated under the Head Start Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9831"},"text":"42 U.S.C. 9831","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e0c9614-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1119"},"text":"Pub. L. 89–10, title I, § 1119","children":[],"tail":", formerly § 1120B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1512"},"text":"115 Stat. 1512","children":[],"tail":"; renumbered § 1119 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tI"},"text":"Pub. L. 114–95, title I","children":[],"tail":", §§ 1000(5), 1013, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1814"},"text":"129 Stat. 1814","children":[],"tail":", 1875