{"tag":"section","attrib":{"id":"id0e5426f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7933"},"text":null,"children":[{"tag":"num","attrib":{"value":"7933"},"text":"§ 7933.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preventing improper use of taxpayer funds","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To address the misuse of taxpayer funds, the Secretary of Education shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e5426fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7933/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that each recipient of a grant or subgrant under the Elementary and Secondary Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"20 U.S.C. 6301","children":[],"tail":" et seq.) display, in a public place, the hotline contact information of the Office of Inspector General of the Department of Education so that any individual who observes, detects, or suspects improper use of taxpayer funds can easily report such improper use;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5426fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7933/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annually notify employees of the Department of Education of their responsibility to report fraud; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5426fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7933/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require any applicant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e5426fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7933/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a grant under such Act to provide an assurance to the Secretary that any information submitted when applying for such grant and responding to monitoring and compliance reviews is truthful and accurate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e5426fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7933/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a subgrant under such Act to provide the assurance described in subparagraph (A) to the entity awarding the subgrant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e5426ff-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9203"},"text":"Pub. L. 114–95, title IX, § 9203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2138"},"text":"129 Stat. 2138","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e542700-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e542701-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e542702-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Elementary and Secondary Education Act of 1965 and such Act, referred to in pars. (1) and (3), are ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-04-11"},"text":"Apr. 11, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/27"},"text":"79 Stat. 27","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0e542703-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Every Student Succeeds Act, and not as part of the Elementary and Secondary Education Act of 1965 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e542704-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7933, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIX/s9303"},"text":"Pub. L. 89–10, title IX, § 9303","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3806"},"text":"108 Stat. 3806","children":[],"tail":", stated purpose of former part C of subchapter IX of this chapter, prior to the general amendment of former subchapter IX of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e542705-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e542706-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
