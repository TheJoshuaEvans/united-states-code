{"tag":"section","attrib":{"id":"id0ce0244a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1068d"},"text":"§ 1068d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to institutions under other programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ce0244b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each institution which the Secretary determines to be an institution eligible under part A or an institution eligible under part B may be eligible for waivers in accordance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce0244c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver applicability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce0244d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to, and in accordance with, regulations promulgated for the purpose of this section, in the case of any application by an institution referred to in subsection (a) for assistance under any programs specified in paragraph (2), the Secretary is authorized, if such application is otherwise approvable, to waive any requirement for a non-Federal share of the cost of the program or project, or, to the extent not inconsistent with other law, to give, or require to be given, priority consideration of the application in relation to applications from other institutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce0244e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of this section shall apply to any program authorized by part D or subchapter IV of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce0244f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1068d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not waive, under subsection (b), the non-Federal share requirement for any program for applications which, if approved, would require the expenditure of more than 10 percent of the appropriations for the program for any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ce02450-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s395"},"text":"Pub. L. 89–329, title III, § 395","children":[],"tail":", formerly § 356, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIII/s301/a"},"text":"Pub. L. 99–498, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1306"},"text":"100 Stat. 1306","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIII/s305/d"},"text":"Pub. L. 102–325, title III, § 305(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-0