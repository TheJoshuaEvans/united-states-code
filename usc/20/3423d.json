ompetitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0dd8197d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Office of Educational Research and Improvement","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Office of Educational Research and Improvement was established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3419"},"text":"section 3419 of this title","children":[],"tail":". Section 3419 was repealed and a new section 3419 establishing the Institute of Educational Sciences was enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/107/279/tIV/s402/2"},"text":"Pub. L. 107–279, title IV, § 402(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1985"},"text":"116 Stat. 1985","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
