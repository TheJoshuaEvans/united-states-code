{"tag":"section","attrib":{"id":"id0dd81970-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423d"},"text":null,"children":[{"tag":"num","attrib":{"value":"3423d"},"text":"§ 3423d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of English Language Acquisition, Language Enhancement, and Academic Achievement for Limited English Proficient Students","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dd81971-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be, in the Department, an Office of English Language Acquisition, Language Enhancement, and Academic Achievement for Limited English Proficient Students through which the Secretary shall carry out functions relating to bilingual education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dd81972-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dd81973-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall be headed by a Director of English Language Acquisition, Language Enhancement, and Academic Achievement for Limited English Proficient Students, appointed by the Secretary, to whom the Secretary shall delegate all delegable functions relating to bilingual education. The Director shall also be assigned responsibility for recommending improvements and providing technical assistance to other Federal programs serving language-minority and limited-English-proficient students and their families and for assisting the Assistant Secretary of the Office of Educational Research and Improvement in identifying research priorities which reflect the needs of language-minority and limited-English language proficient students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd81974-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall be organized as the Director determines to be appropriate in order to carry out such functions and responsibilities effectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd81975-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that limited-English-proficient and language-minority students are included in ways that are valid, reliable, and fair under all standards and assessment development conducted or funded by the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dd81976-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tII/s216"},"text":"Pub. L. 96–88, title II, § 216","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s372/2"},"text":"Pub. L. 103–382, title III, § 372(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3978"},"text":"108 Stat. 3978","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1072/b"},"text":"Pub. L. 107–110, title X, § 1072(b)","children":[],"tail":", (c)(2)(B), (d), "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2089"},"text":"115 Stat. 2089","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dd81977-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dd81978-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0dd81979-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s216"},"text":"section 216 of Pub. L. 96–88","children":[],"tail":" was renumbered section 218 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3425"},"text":"section 3425 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0dd8197a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110/s1072/c/2/B"},