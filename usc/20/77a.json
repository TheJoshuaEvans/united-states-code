{"tag":"section","attrib":{"id":"id0c831006-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s77a"},"text":null,"children":[{"tag":"num","attrib":{"value":"77a"},"text":"§ 77a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of museum","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The national air and space museum shall memorialize the national development of aviation and space flight; collect, preserve, and display aeronautical and space flight equipment of historical interest and significance; serve as a repository for scientific equipment and data pertaining to the development of aviation and space flight; and provide educational material for the historical study of aviation and space flight.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c831007-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-12/ch955/s2"},"text":"Aug. 12, 1946, ch. 955, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/998"},"text":"60 Stat. 998","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/509"},"text":"Pub. L. 89–509","children":[],"tail":", pt. I, § 4, "},{"tag":"date","attrib":{"date":"1966-07-19"},"text":"July 19, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/310"},"text":"80 Stat. 310","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c831008-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c831009-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0c83100a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/509"},"text":"Pub. L. 89–509","children":[],"tail":" substituted “national air and space museum” for “national air museum”, inserted “and space flight” after “aviation” wherever appearing, and substituted “aeronautical and space flight equipment” for “aeronautical equipment”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
