{"tag":"section","attrib":{"id":"id0e350660-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423"},"text":null,"children":[{"tag":"num","attrib":{"value":"7423"},"text":"§ 7423.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e350661-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grant awards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e350662-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b) and paragraph (2), the Secretary shall allocate to each local educational agency that has an approved application under this subpart an amount equal to the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e350663-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of Indian children who are eligible under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7427"},"text":"section 7427 of this title","children":[],"tail":" and served by such agency; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e350664-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the greater of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e350665-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average per pupil expenditure of the State in which such agency is located; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e350666-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 80 percent of the average per pupil expenditure of all the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e350667-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall reduce the amount of each allocation otherwise determined under this section in accordance with subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e350668-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum grant","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e350669-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (e), an entity that is eligible for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7422"},"text":"section 7422 of this title","children":[],"tail":", and a school that is operated or supported by the Bureau of Indian Education that is eligible for a grant under subsection (d), that submits an application that is approved by the Secretary, shall, subject to appropriations, receive a grant under this subpart in an amount that is not less than $3,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e35066a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consortia","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Local educational agencies may form a consortium for the purpose of obtaining grants under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e35066b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may increase the minimum grant under paragraph (1) to not more than $4,000 for all grantees if the Secretary determines such increase is necessary to ensure the quality of the programs provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e35066c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this section, the term “average per pupil expenditure”, used with respect to a State, means an amount equal to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e35066d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the aggregate current expenditures of all the local educational agencies in the State, plus any direct current expenditures by the State for the operation of such agencies, without regard to the sources of funds from which such local or State expenditures were made, during the second fiscal year preceding the fiscal year for which the computation is made; divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e35066e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate number of children who were included in average daily attendance for whom such agencies provided free public education during such preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e35066f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schools operated or supported by the Bureau of Indian Education","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e350670-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (e), in addition to the grants awarded under subsection (a), the Secretary shall allocate to the Secretary of the Interior an amount equal to the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e350671-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the total number of Indian children enrolled in schools that are operated by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e350672-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Indian Education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e350673-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe, or an organization controlled or sanctioned by an Indian tribal government, for the children of that tribe under a contract with, or grant from, the Department of the Interior under the Indian Self-Determination Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321"},"text":"25 U.S.C. 5321","children":[],"tail":" et seq.] or the Tribally Controlled Schools Act of 1988 ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2501"},"text":"25 U.S.C. 2501","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e350674-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the greater of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e350675-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average per pupil expenditure of the State in which the school is located; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e350676-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 80 percent of the average per pupil expenditure of all the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e350677-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any school described in paragraph (1)(A) that wishes to receive an allocation under this subpart shall submit an application in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7424"},"text":"section 7424 of this title","children":[],"tail":", and shall otherwise be treated as a local educational agency for the purpose of this subpart, except that such school shall not be subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7424/c/4"},"text":"section 7424(c)(4) of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7428/c"},"text":"section 7428(c) of this title","children":[],"tail":", or "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7429"},"text":"section 7429 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e350678-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7423/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ratable reductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the sums appropriated for any fiscal year under 7492(a) ","children":[{"tag":"ref","attrib":{"idref":"fn002223"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002223"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “section”."}],"tail":" of this title are insufficient to pay in full the amounts determined for local educational agencies under subsection (a)(1) and for the Secretary of the Interior under subsection (d), each of those amounts shall be ratably reduced."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e350679-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVI/s6113"},"text":"Pub. L. 89–10, title VI, § 6113","children":[],"tail":", formerly title VII, § 7113, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVII/s701"},"text":"Pub. L. 107–110, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1908"},"text":"115 Stat. 1908","children":[],"tail":", renumbered title VI, § 6113, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVI"},"text":"Pub. L. 114–95, title VI","children":[],"tail":", §§ 6001(a), (b)(1), (3), § 6002(e), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2046"},"text":"129 Stat. 2046","children":[],"tail":", 2049.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e35067a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e35067b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e35067c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination Act, referred to in subsec. (d)(1)(A)(ii), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2206"},"text":"88 Stat. 2206","children":[],"tail":", which is classified principally to subchapter I (§ 5321 et seq.) of chapter 46 of Title 25, Indians. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Tribally Controlled Schools Act of 1988, referred to in subsec. (d)(1)(A)(ii), is part B (§ 5201–5212) of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297"},"text":"Pub. L. 100–297","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/385"},"text":"102 Stat. 385","children":[],"tail":", which is classified generally to chapter 27 (§ 2501 et seq.) of Title 25, Indians. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2501"},"text":"section 2501 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e35067d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7423, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVII/s7113"},"text":"Pub. L. 89–10, title VII, § 7113","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3720"},"text":"108 Stat. 3720","children":[],"tail":", related to program enhancement projects, prior to the general amendment of former subchapter VII of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s6113"},"text":"section 6113 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7301b"},"text":"section 7301b of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e35067e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6001/b/3/A"},"text":"Pub. L. 114–95, § 6001(b)(3)(A)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7427"},"text":"section 7427 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/e/1"},"text":"Pub. L. 114–95, § 6002(e)(1)","children":[],"tail":", substituted “Bureau of Indian Education” for “Bureau of Indian Affairs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6001/b/3/B"},"text":"Pub. L. 114–95, § 6001(b)(3)(B)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7422"},"text":"section 7422 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/e/2/A"},"text":"Pub. L. 114–95, § 6002(e)(2)(A)","children":[],"tail":", substituted “Indian Education” for “Indian Affairs” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/e/2/B"},"text":"Pub. L. 114–95, § 6002(e)(2)(B)","children":[],"tail":", substituted “Bureau of Indian Education” for “Bureau of Indian Affairs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6001/b/3/C"},"text":"Pub. L. 114–95, § 6001(b)(3)(C)","children":[],"tail":", made technical amendment to references in original act which appear in text as references to sections 7424, 7424(c)(4), 7428(c), and 7429 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6001/b/3/D"},"text":"Pub. L. 114–95, § 6001(b)(3)(D)","children":[],"tail":", substituted “7492(a) of this title” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7492/a"},"text":"section 7492(a) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e35067f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e350680-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
