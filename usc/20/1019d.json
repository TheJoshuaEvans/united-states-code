{"tag":"section","attrib":{"id":"id0cc8300e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1019d"},"text":"§ 1019d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Self-certification form for private education loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cc8300f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Board of Governors of the Federal Reserve System, shall develop the self-certification form for private education loans that shall be used to satisfy the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1638/e/3"},"text":"section 1638(e)(3) of title 15","children":[],"tail":". Such form shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cc83010-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be developed in a standardized format;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc83011-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be made available to the applicant by the relevant institution of higher education, in written or electronic form, upon request of the applicant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc83012-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contain only disclosures that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cc83013-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019d/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant may qualify for Federal student financial assistance through a program under subchapter IV of this chapter, or State or institutional student financial assistance, in place of, or in addition to, a private education loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc83014-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019d/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant is encouraged to discuss the availability of Federal, State, and institutional student financial assistance with financial aid officials at the applicant’s institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc83015-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019d/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private education loan may affect the applicant’s eligibility for free or low-cost Federal, State or institutional student financial assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc83016-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019d/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information that the applicant is required to provide on the form is available from officials at the financial aid office of the institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc83017-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019d/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include a place to provide information on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cc83018-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019d/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant’s cost of attendance at the institution of higher education, as determined by the institution under part F of subchapter IV;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc83019-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019d/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant’s estimated financial assistance, including amounts of financial assistance used to replace the student aid index, as determined by the institution, in accordance with subchapter IV, for students who have completed the Free Application for Federal Student Aid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc8301a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019d/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the difference between the amounts under subparagraphs (A) and (B), as applicable; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc8301b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019d/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a place for the applicant’s signature, in written or electronic form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc8301c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1019d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to create a private right of action against an institution of higher education with respect to the form developed under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cc8301d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s155"},"text":"Pub. L. 89–329, title I, § 155","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tX/s1021/b"},"text":"Pub. L. 110–315, title X, § 1021(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3487"},"text":"122 Stat. 3487","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tI/s101/b/7"},"text":"Pub. L. 111–39, title I, § 101(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1935"},"text":"123 Stat. 1935","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tVII/s704/1"},"text":"Pub. L. 116–260, div. FF, title VII, § 704(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3199"},"text":"134 Stat. 3199","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cc8301e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cc8301f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cc83020-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “the student aid index” for “the expected family contribution”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" added par. (4) and struck out former par. (4) which read as follows: “include a place to provide information on—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the applicant’s cost of attendance at the institution of higher education, as determined by the institution under Part F of subchapter IV;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the applicant’s expected family contribution, as determined under Part F of subchapter IV, as applicable, for students who have completed the free application for Federal student aid;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) the applicant’s estimated financial assistance, as determined by the institution, in accordance with subchapter IV, as applicable;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) the difference between the amounts under subparagraphs (A) and (C), as applicable; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) the sum of the amounts under subparagraphs (B) and (D), as applicable; and”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cc83021-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cc83022-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2024-07-01"},"text":"July 1, 2024","children":[],"tail":", except as otherwise expressly provided, and applicable with respect to award year 2024–2025 and each subsequent award year, as determined under this chapter, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/s701/b"},"text":"section 701(b) of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cc83023-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" effective as if enacted on the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/s3"},"text":"section 3 of Pub. L. 111–39","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
