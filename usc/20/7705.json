{"tag":"section","attrib":{"id":"id0e45cefa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7705"},"text":null,"children":[{"tag":"num","attrib":{"value":"7705"},"text":"§ 7705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for payments under sections 7702 and 7703 of this title","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e45cefb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A local educational agency desiring to receive a payment under section 7702 or 7703 of this title shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e45cefc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7705/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit an application for such payment to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e45cefd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7705/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a copy of such application to the State educational agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e45cefe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each such application shall be submitted in such form and manner as the Secretary may require, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e45ceff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7705/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information to determine the eligibility of the local educational agency for a payment and the amount of such payment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e45cf00-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7705/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where applicable, an assurance that such agency is in compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7704"},"text":"section 7704 of this title","children":[],"tail":" (relating to children residing on Indian lands)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e45cf01-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7705/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish deadlines for the submission of applications under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e45cf02-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7705/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e45cf03-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7705/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall approve an application submitted under this section that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e45cf04-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7705/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in paragraph (2), is filed by the deadline established under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e45cf05-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7705/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise meets the requirements of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e45cf06-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7705/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction in payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall approve an application filed not more than 60 days after a deadline established under subsection (c), or not more than 60 days after the date on which the Secretary sends written notice to the local educational agency pursuant to paragraph (3)(A), as the case may be, that otherwise meets the requirements of this subchapter, except that, notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7703/e"},"text":"section 7703(e) of this title","children":[],"tail":", the Secretary shall reduce the payment based on such late application by 10 percent of the amount that would otherwise be paid."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e45cf07-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7705/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Late applications","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e45cf08-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7705/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, as soon as practicable after the deadline established under subsection (c), provide to each local educational agency that applied for a payment under section 7702 or 7703 of this title for the prior fiscal year, and with respect to which the Secretary has not received an application for a payment under either such section (as the case may be) for the fiscal year in question, written notice of the failure to comply with the deadline and instruction to ensure that the application is filed not later than 60 days after the date on which the Secretary sends the notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e45cf09-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7705/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance and approval of late applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not accept or approve any application of a local educational agency that is filed more than 60 days after the date on which the Secretary sends written notice to the local educational agency pursuant to subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e45cf0a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7705/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State application authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, a State educational agency that had been accepted as an applicant for funds under ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-30/s3"},"text":"section 3 of the Act of September 30, 1950","children":[],"tail":" (Public Law 874, 81st Congress) (as such section was in effect on the day preceding "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"October 20, 1994","children":[],"tail":") in fiscal year 1994 shall be permitted to continue as an applicant under the same conditions by which such agency made application during such fiscal year only if such State educational agency distributes all funds received for the students for which application is being made by such State educational agency to the local educational agencies providing educational services to such students."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e45cf0b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVII/s7005"},"text":"Pub. L. 89–10, title VII, § 7005","children":[],"tail":", formerly title VIII, § 8005, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3761"},"text":"108 Stat. 3761","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XVIII, § 1809], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–382; renumbered title VII, § 7005, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVII"},"text":"Pub. L. 114–95, title VII","children":[],"tail":", §§ 7001(c)(1), (d)(1), 7006, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2074"},"text":"129 Stat. 2074","children":[],"tail":", 2086.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e45cf0c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e45cf0d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e45cf0e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-30/s3"},"text":"Section 3 of the Act of September 30, 1950","children":[],"tail":" (Public Law 874, 81st Congress) (as such section was in effect on the day preceding "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"October 20, 1994","children":[],"tail":"), referred to in subsec. (d)(4), means section 3 of "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-30/ch1124"},"text":"act Sept. 30, 1950, ch. 1124","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s238"},"text":"section 238 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s331/b"},"text":"Pub. L. 103–382, title III, § 331(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3965"},"text":"108 Stat. 3965","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e45cf0f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7706, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8006"},"text":"Pub. L. 89–10, title VIII, § 8006","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3762"},"text":"108 Stat. 3762","children":[],"tail":", related to payments for sudden and substantial increases in attendance of military dependents, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XVIII, § 1810], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–383."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e45cf10-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s7006/1"},"text":"Pub. L. 114–95, § 7006(1)","children":[],"tail":", made technical amendment to reference in original act which appears in section catchline as reference to sections 7702 and 7703 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s7006/2"},"text":"Pub. L. 114–95, § 7006(2)","children":[],"tail":", made technical amendment to reference in original act which appears in introductory provisions as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7703"},"text":"section 7703 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s7001/d/1"},"text":"Pub. L. 114–95, § 7001(d)(1)","children":[],"tail":", made technical amendment to reference in original act which appears in introductory provisions as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7702"},"text":"section 7702 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s7006/3"},"text":"Pub. L. 114–95, § 7006(3)","children":[],"tail":", struck out “, and shall contain such information,” after “in such form and manner” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s7006/3/B"},"text":"Pub. L. 114–95, § 7006(3)(B)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7704"},"text":"section 7704 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s7006/4"},"text":"Pub. L. 114–95, § 7006(4)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7703/e"},"text":"section 7703(e) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s7006/2"},"text":"Pub. L. 114–95, § 7006(2)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7703"},"text":"section 7703 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s7001/d/1"},"text":"Pub. L. 114–95, § 7001(d)(1)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7702"},"text":"section 7702 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XVIII, § 1809(1)], inserted “, or not more than 60 days after the date on which the Secretary sends written notice to the local educational agency pursuant to paragraph (3)(A), as the case may be,” after “subsection (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XVIII, § 1809(2)], amended heading and text generally. Prior to amendment, text read as follows: “The Secretary shall not accept or approve any application that is filed more than 60 days after a deadline established under subsection (c) of this section.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e45cf11-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e45cf12-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", and effective with respect to appropriations for use under this subchapter beginning fiscal year 2017, except as otherwise provided in such amendment, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0e45cf13-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Data To Be Used for Impact Aid Programs in Certain Fiscal Years","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/83"},"text":"Pub. L. 117–83","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-01-21"},"text":"Jan. 21, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6"},"text":"136 Stat. 6","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/83"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This Act may be cited as the ‘Supplemental Impact Aid Flexibility Act’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" IMPACT AID PROGRAM.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“Due to the public health emergency directly relating to COVID–19 and notwithstanding sections 7002(j) and 7003(c) of the Elementary and Secondary Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7702/j"},"text":"20 U.S.C. 7702(j)","children":[],"tail":", 7703(c)), a local educational agency desiring to receive a payment under section 7002 or 7003 of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7702"},"text":"20 U.S.C. 7702","children":[],"tail":", 7703) for fiscal year 2023 that also submitted an application for such payment for fiscal year 2022 shall, in the application submitted under section 7005 of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7705"},"text":"20 U.S.C. 7705","children":[],"tail":") for fiscal year 2023—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to a requested payment under section 7002 of such Act—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the data described in section 7002(j) of such Act relating to calculating such payment that was submitted by the local educational agency in the application for fiscal year 2022; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the data relating to calculating such payment for the fiscal year required under section 7002(j) of such Act; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to a requested payment under section 7003 of such Act—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the student count data relating to calculating such payment that was submitted by the local educational agency in the application for fiscal year 2022, provided that payments for fiscal year 2023 shall be calculated by the Secretary using the expenditures and rates described in clauses (i), (ii), (iii), and (iv) of section 7003(b)(1)(C) of such Act that would otherwise apply for fiscal year 2023; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the student count data relating to calculating such payment for the fiscal year required under section 7003(c) of such Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/211/s2"},"text":"Pub. L. 116–211, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-04"},"text":"Dec. 4, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1017"},"text":"134 Stat. 1017","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/211/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Due to the public health emergency relating to COVID–19 and notwit