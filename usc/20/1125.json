{"tag":"section","attrib":{"id":"id0d6f1e2c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1125"},"text":null,"children":[{"tag":"num","attrib":{"value":"1125"},"text":"§ 1125.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research; studies; annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d6f1e2d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1125/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may, directly or through grants or contracts, conduct research and studies that contribute to achieving the purposes of this part. Such research and studies may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6f1e2e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1125/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies and surveys to determine needs for increased or improved instruction in foreign language, area studies, or other international fields, including the demand for foreign language, area, and other international specialists in government, education, and the private sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e2f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1125/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies and surveys to assess the utilization of graduates of programs supported under this subchapter by governmental, educational, and private sector organizations and other studies assessing the outcomes and effectiveness of programs so supported;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e30-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1125/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluation of the extent to which programs assisted under this subchapter that address national needs would not otherwise be offered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e31-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1125/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comparative studies of the effectiveness of strategies to provide international capabilities at institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e32-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1125/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on more effective methods of providing instruction and achieving competency in foreign languages, area studies, or other international fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e33-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1125/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and publication of specialized materials for use in foreign language, area studies, and other international fields, or for training foreign language, area, and other international specialists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e34-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1125/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies and surveys of the uses of technology in foreign language, area studies, and international studies programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e35-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1125/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies and evaluations of effective practices in the dissemination of international information, materials, research, teaching strategies, and testing techniques throughout the education community, including elementary and secondary schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e36-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1125/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application of performance tests and standards across all areas of foreign language instruction and classroom use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e37-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1125/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluation of the extent to which programs assisted under this subchapter reflect diverse perspectives and a wide range of views and generate debate on world regions and international affairs, as described in the grantee’s application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e38-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1125/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the systematic collection, analysis, and dissemination of data that contribute to achieving the purposes of this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e39-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1125/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support for programs or activities to make data collected, analyzed, or disseminated under this section publicly available and easy to understand.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6f1e3a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1125/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prepare, publish, and announce an annual report listing the books and research materials produced with assistance under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6f1e3b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s605"},"text":"Pub. L. 89–329, title VI, § 605","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVI/s601"},"text":"Pub. L. 105–244, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1780"},"text":"112 Stat. 1780","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVI/s605"},"text":"Pub. L. 110–315, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3337"},"text":"122 Stat. 3337","children":[]