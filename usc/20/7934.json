{"tag":"section","attrib":{"id":"id0e542707-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7934"},"text":null,"children":[{"tag":"num","attrib":{"value":"7934"},"text":"§ 7934.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability to taxpayers through monitoring and oversight","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To improve monitoring and oversight of taxpayer funds authorized for appropriation under the Elementary and Secondary Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"20 U.S.C. 6301","children":[],"tail":" et seq.), and to deter and prohibit waste, fraud, and abuse with respect to such funds, the Secretary of Education shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e542708-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7934/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" notify each recipient of a grant under such Act (and, if applicable, require the grantee to inform each subgrantee) of its responsibility to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e542709-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7934/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with all monitoring requirements under the applicable program or programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e54270a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7934/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor properly any subgrantee under the applicable program or programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e54270b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7934/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" review and analyze the results of monitoring and compliance reviews—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e54270c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7934/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to understand trends and identify common issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e54270d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7934/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to issue guidance to help grantees address such issues before the loss or misuse of taxpayer funding occurs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e54270e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7934/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publicly report the work undertaken by the Secretary to prevent fraud, waste, and abuse with respect to such taxpayer funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e54270f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7934/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with the Office of Inspector General of the Department of Education, as needed, to help ensure that employees of the Department understand how to adequately monitor grantees and to help grantees adequately monitor any subgrantees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e542710-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9204"},"text":"Pub. L. 114–95, title IX, § 9204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2138"},"text":"129 Stat. 2138","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e542711-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e542712-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e542713-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Elementary and Secondary Education Act of 1965 and such Act, referred to in text, are ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-04-11"},"text":"Apr. 11, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/27"},"text":"79 Stat. 27","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0e542714-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Every Student Succeeds Act, and not as part of the Elementary and Secondary Education Act of 1965 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e542715-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 7934 to 7938 were omitted in the general amendment of former subchapter IX of this chapter by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7934, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIX/s9304"},"text":"Pub. L. 89–10, title IX, § 9304","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3806"},"text":"108 Stat. 3806","children":[],"tail":", related to Alaska Native educational planning, curriculum development, and teacher training and recruitment programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7935, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIX/s9305"},"text":"Pub. L. 89–10, title IX, § 9305","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3807"},"text":"108 Stat. 3807","children":[],"tail":", related to Alaska Native home based education for preschool children."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7936, ","children":[{"tag":"ref","attri