{"tag":"section","attrib":{"id":"id0da85754-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432"},"text":null,"children":[{"tag":"num","attrib":{"value":"1432"},"text":"§ 1432.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0da85755-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" At-risk infant or toddler","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “at-risk infant or toddler” means an individual under 3 years of age who would be at risk of experiencing a substantial developmental delay if early intervention services were not provided to the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da85756-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “council” means a State interagency coordinating council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1441"},"text":"section 1441 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da85757-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Developmental delay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “developmental delay”, when used with respect to an individual residing in a State, has the meaning given such term by the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1435/a/1"},"text":"section 1435(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da85758-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early intervention services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “early intervention services” means developmental services that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0da85759-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are provided under public supervision;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da8575a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are provided at no cost except where Federal or State law provides for a system of payments by families, including a schedule of sliding fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da8575b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" are designed to meet the developmental needs of an infant or toddler with a disability, as identified by the individualized family service plan team, in any 1 or more of the following areas:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0da8575c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da8575d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cognitive development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da8575e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communication development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da8575f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" social or emotional development; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da85760-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adaptive development;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da85761-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the standards of the State in which the services are provided, including the requirements of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da85762-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0da85763-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family training, counseling, and home visits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da85764-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da85765-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" speech-language pathology and audiology services, and sign language and cued language services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da85766-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occupational therapy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da85767-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/E/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical therapy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da85768-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/E/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" psychological services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da85769-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/E/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" service coordination services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da8576a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/E/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical services only for diagnostic or evaluation purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da8576b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/E/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early identification, screening, and assessment services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da8576c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/E/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health services necessary to enable the infant or toddler to benefit from the other early intervention services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da8576d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/E/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" social work services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da8576e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/E/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vision services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da8576f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/E/xiii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiii"},"text":"(xiii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistive technology devices and assistive technology services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da85770-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/E/xiv"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiv"},"text":"(xiv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation and related costs that are necessary to enable an infant or toddler and the infant’s or toddler’s family to receive another service described in this paragraph;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da85771-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" are provided by qualified personnel, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0da85772-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special educators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da85773-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" speech-language pathologists and audiologists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da85774-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occupational therapists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da85775-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/F/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical therapists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da85776-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/F/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" psychologists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da85777-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/F/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" social workers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da85778-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/F/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nurses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da85779-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/F/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" registered dietitians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da8577a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/F/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family therapists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da8577b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/F/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vision specialists, including ophthalmologists and optometrists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da8577c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/F/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" orientation and mobility specialists; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da8577d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/F/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pediatricians and other physicians;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da8577e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent appropriate, are provided in natural environments, including the home, and community settings in which children without disabilities participate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da8577f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/4/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are provided in conformity with an individualized family service plan adopted in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1436"},"text":"section 1436 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da85780-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Infant or toddler with a disability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “infant or toddler with a disability”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0da85781-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means an individual under 3 years of age who needs early intervention services because the individual—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0da85782-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is experiencing developmental delays, as measured by appropriate diagnostic instruments and procedures in 1 or more of the areas of cognitive development, physical development, communication development, social or emotional development, and adaptive development; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da85783-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a diagnosed physical or mental condition that has a high probability of resulting in developmental delay; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da85784-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may also include, at a State’s discretion—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0da85785-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at-risk infants and toddlers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da85786-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" children with disabilities who are eligible for services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1419"},"text":"section 1419 of this title","children":[],"tail":" and who previously received services under this subchapter until such children enter, or are eligible under State law to enter, kindergarten or elementary school, as appropriate, provided that any programs under this subchapter serving such children shall include—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id0da85787-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/5/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an educational component that promotes school readiness and incorporates pre-literacy, language, and numeracy skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0da85788-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1432/5/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written notification to parents of their rights and responsibilities in determining whether their child will continue to receive services under this subchapter or participate in preschool programs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1419"},"text":"section 1419 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0da85789-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s632"},"text":"Pub. L. 91–230, title VI, § 632","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2744"},"text":"118 Stat. 2744","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0da8578a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0da8578b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0da8578c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1432, "