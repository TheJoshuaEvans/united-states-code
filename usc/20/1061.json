ren":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/247"},"text":"86 Stat. 247","children":[],"tail":", related to statement of purpose and authorization of appropriations for educational opportunity grants, prior to the general revision of part A of subchapter IV of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/92/318/tI/s131/b/1"},"text":"Pub. L. 92–318, title I, § 131(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/247"},"text":"86 Stat. 247","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cd687c3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" inserted “, in consultation with the Commissioner for Education Statistics” before “and the Commissioner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/369"},"text":"Pub. L. 100–369","children":[],"tail":" inserted “,, except that any branch campus of a southern institution of higher education that prior to "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"September 30, 1986","children":[],"tail":", received a grant as an institution with special needs under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1060"},"text":"section 1060 of this title","children":[],"tail":" and was formally recognized by the National Center for Education Statistics as a Historically Black College or University but was determined not to be a part B institution on or after "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"October 17, 1986","children":[],"tail":", shall, from "},{"tag":"date","attrib":{"date":"1988-07-18"},"text":"July 18, 1988","children":[],"tail":", be considered a part B institution” after “accreditation”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
