{"tag":"section","attrib":{"id":"id0c9fc01c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s806"},"text":null,"children":[{"tag":"num","attrib":{"value":"806"},"text":"§ 806.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated for the purpose of making grants and providing fellowships under this chapter, without fiscal year limitation, not to exceed $30,000,000, which amount shall be increased by $3,500,000 on ","children":[{"tag":"date","attrib":{"date":"1974-07-01"},"text":"July 1, 1974","children":[],"tail":", and by $3,500,000 on "},{"tag":"date","attrib":{"date":"1975-07-01"},"text":"July 1, 1975","children":[],"tail":". Any amounts appropriated under this section shall remain available until expended."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c9fc01d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/560/tVIII/s807"},"text":"Pub. L. 88–560, title VIII, § 807","children":[],"tail":", formerly § 806, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/152/tIII/s307"},"text":"Pub. L. 91–152, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-24"},"text":"Dec. 24, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/394"},"text":"83 Stat. 394","children":[],"tail":"; renumbered § 807 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/383/tIV/s402/c/1"},"text":"Pub. L. 93–383, title IV, § 402(c)(1)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/692"},"text":"88 Stat. 692","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c9fc01e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c9fc01f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0c9fc020-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383/s402"},"text":"Pub. L. 93–383, § 402","children":[],"tail":", provided for amendments to title VIII of the Housing and Urban Development Act of 1964. The amendments of the enumerated sections of such title VIII have been executed to comparable sections of title VIII of the Housing Act of 1964 as the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0c9fc021-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383/s402/d"},"text":"Pub. L. 93–383, § 402(d)","children":[],"tail":", inserted provisions increasing amount by $3,500,000 on "},{"tag":"date","attrib":{"date":"1974-07-01"},"text":"July 1, 1974","children":[],"tail":", and by $3,500,000 on "},{"tag":"date","attrib":{"date":"1975-07-01"},"text":"July 1, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
