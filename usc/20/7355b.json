{"tag":"section","attrib":{"id":"id0e3505f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7355b"},"text":null,"children":[{"tag":"num","attrib":{"value":"7355b"},"text":"§ 7355b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this part shall be construed to prohibit a local educational agency that enters into cooperative arrangements with other local educational agencies for the provision of special, compensatory, or other education services, pursuant to State law or a written agreement, from entering into similar arrangements for the use, or the coordination of the use, of the funds made available under this part.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e3505f9-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5233"},"text":"Pub. L. 89–10, title V, § 5233","children":[],"tail":", formerly title VI, § 6233, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVI/s601"},"text":"Pub. L. 107–110, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1897"},"text":"115 Stat. 1897","children":[],"tail":"; renumbered title V, § 5233, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tV/s5001/a/5"},"text":"Pub. L. 114–95, title V, § 5001(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2039"},"text":"129 Stat. 2039","children":[],"tail":", 2040.)"}],"tail":"\n"}],"tail":null}
