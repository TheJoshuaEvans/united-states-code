{"tag":"section","attrib":{"id":"id0d718e9d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1130–1"},"text":"§ 1130–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Centers for international business education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d718e9e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d718e9f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to coordinate the programs of the Federal Government in the areas of research, education, and training in international business and trade competitiveness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718ea0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to make grants to institutions of higher education, or consortia of such institutions, to pay the Federal share of the cost of planning, establishing and operating centers for international business education which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d718ea1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be national resources for the teaching of improved business techniques, strategies, and methodologies which emphasize the international context in which business is transacted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718ea2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will provide instruction in critical foreign languages and international fields needed to provide understanding of the cultures and customs of United States trading partners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718ea3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will provide research and training in the international aspects of trade, commerce, and other fields of study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718ea4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to providing training to students enrolled in the institution of higher education in which a center is located, such centers shall serve as regional resources to businesses proximately located by offering programs and providing research designed to meet the international training needs of such businesses. Such centers shall also serve other faculty, students, and institutions of higher education located within their region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d718ea5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized expenditures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each grant made under this section may be used to pay the Federal share of the cost of planning, establishing or operating a center, including the cost of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d718ea6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" faculty and staff travel in foreign areas, regions, or countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718ea7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" teaching and research materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718ea8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" curriculum planning and development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718ea9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bringing visiting scholars and faculty to the center to teach or to conduct research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718eaa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and improvement of the staff, for the purpose of, and subject to such conditions as the Secretary finds necessary for, carrying out the objectives of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d718eab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d718eac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Programs and activities to be conducted by centers assisted under this section shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d718ead-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interdisciplinary programs which incorporate foreign language and international studies training into business, finance, management, communications systems, and other professional curricula;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718eae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interdisciplinary programs which provide business, finance, management, communications systems, and other professional training for foreign language and international studies faculty and degree candidates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718eaf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs, such as intensive language programs, available to members of the business community and other professionals which are designed to develop or enhance their international skills, awareness, and expertise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718eb0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborative programs, activities, or research involving other institutions of higher education, local educational agencies, professional associations, businesses, firms, or consortia thereof, to promote the development of international skills, awareness, and expertise among current and prospective members of the business community and other professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718eb1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research designed to strengthen and improve the international aspects of business and professional education and to promote integrated curricula; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718eb2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research designed to promote the international competitiveness of American businesses and firms, including those not currently active in international trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718eb3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Programs and activities to be conducted by centers assisted under this section may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d718eb4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of overseas internship programs for students and faculty designed to provide training and experience in international business activities, except that no Federal funds provided under this section may be used to pay wages or stipends to any participant who is engaged in compensated employment as part of an internship program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718eb5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of linkages overseas with institutions of higher education and other organizations that contribute to the educational objectives of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718eb6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summer institutes in international business, foreign area studies, foreign language studies, and other international studies designed to carry out the purposes of subparagraph (A) of this paragraph;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718eb7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of opportunities for business students to study abroad in locations which are important to the existing and future economic well-being of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718eb8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outreach activities or consortia with business programs located at other institutions of higher education (including those that are eligible to receive assistance under part A or B of subchapter III or under subchapter V) for the purpose of providing expertise regarding the internationalization of such programs, such as assistance in research, curriculum development, faculty development, or educational exchange programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718eb9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs encouraging the advancement and understanding of technology-related disciplines, including manufacturing software systems and technology management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718eba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other eligible activities prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d718ebb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory council","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d718ebc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to be eligible for assistance under this section, an institution of higher education, or consortium of such institutions, shall establish a center advisory council which will conduct extensive planning prior to the establishment of a center concerning the scope of the center’s activities and the design of its programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718ebd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership on advisory council","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The center advisory council shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d718ebe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one representative of an administrative department or office of the institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718ebf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one faculty representative of the business or management school or department of such institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718ec0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one faculty representative of the international studies or foreign language school or department of such institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718ec1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one faculty representative of another professional school or department of such institution, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718ec2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more representatives of local or regional businesses or firms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718ec3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one representative appointed by the Governor of the State in which the institution of higher education is located whose normal responsibilities include official oversight or involvement in State-sponsored trade-related activities or programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718ec4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other individuals as the institution of higher education deems appropriate, such as a representative of a community college in the region served by the center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718ec5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the initial planning activities required under subsection (d)(1), the center advisory council shall meet not less than once each year after the establishment of the center to assess and advise on the programs and activities conducted by the center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d718ec6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant duration; Federal share","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d718ec7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make grants under this section for a minimum of 3 years unless the Secretary determines that the provision of grants of shorter duration is necessary to carry out the objectives of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718ec8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal share of the cost of planning, establishing and operating centers under this section shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d718ec9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 90 percent for the first year in which Federal funds are received;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718eca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 70 percent for the second such year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718ecb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 50 percent for the third such year and for each such year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718ecc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of the cost of planning, establishing, and operating centers under this section may be provided either in cash or in-kind.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718ecd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an institution of higher education receiving a grant under this part and conducting outreach or consortia activities with another institution of higher education in accordance with subsection (c)(2)(E), the Secretary may waive a portion of the requirements for the non-Federal share required in paragraph (2) equal to the amount provided by the institution of higher education receiving such grant to such other institution of higher education for carrying out such outreach or consortia activities. Any such waiver shall be subject to such terms and conditions as the Secretary deems necessary for carrying out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d718ece-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants under this section shall be made on such conditions as the Secretary determines to be necessary to carry out the objectives of this section. Such conditions shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d718ecf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence that the institution of higher education, or consortium of such institutions, will conduct extensive planning prior to the establishment of a center concerning the scope of the center’s activities and the design of its programs in accordance with subsection (d)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718ed0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurance of ongoing collaboration in the establishment and operation of the center by faculty of the business, management, foreign language, international studies, professional international affairs, and other professional schools or departments, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718ed1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurance that the education and training programs of the center will be open to students concentrating in each of these respective areas, as appropriate, and that diverse perspectives will be made available to students in programs under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718ed2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130–1/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurance that the institution of higher education, or consortium of such institutions, will use the assistance provided under this section to supplement and not to supplant activities conducted by institutions of higher education described in subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d718ed3-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s612"},"text":"Pub. L. 89–329, title VI, § 612","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tVI/s6261/2"},"text":"Pub. L. 100–418, title VI, § 6261(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1520"},"text":"102 Stat. 1520","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tVI/s601"},"text":"Pub. L. 102–325, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/729"},"text":"106 Stat. 729","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVI/s602/b"},"text":"Pub. L. 105–244, title VI, § 602(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1783"},"text":"112 Stat. 1783","children":[],"tail":"; "},{"