“combinations” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s610/a"},"text":"Pub. L. 110–315, § 610(a)","children":[],"tail":", substituted “consortia” for “combinations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s611/a/2/A"},"text":"Pub. L. 110–315, § 611(a)(2)(A)","children":[],"tail":", inserted “(including those that are eligible to receive assistance under part A or B of subchapter III or under subchapter V)” after “other institutions of higher education”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(F), (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s611/a/2/B"},"text":"Pub. L. 110–315, § 611(a)(2)(B)","children":[],"tail":"–(D), added subpar. (F) and redesignated former subpar. (F) as (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s610/b"},"text":"Pub. L. 110–315, § 610(b)","children":[],"tail":", substituted “consortium” for “combination”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s610/b"},"text":"Pub. L. 110–315, § 610(b)","children":[],"tail":", substituted “consortium” for “combination”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s611/a/3"},"text":"Pub. L. 110–315, § 611(a)(3)","children":[],"tail":", inserted “, and that diverse perspectives will be made available to students in programs under this section” before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s610/b"},"text":"Pub. L. 110–315, § 610(b)","children":[],"tail":", substituted “consortium” for “combination”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s602/b/1/A/i"},"text":"Pub. L. 105–244, § 602(b)(1)(A)(i)","children":[],"tail":", struck out “advanced” after “faculty and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s602/b/1/A/ii"},"text":"Pub. L. 105–244, § 602(b)(1)(A)(ii)","children":[],"tail":", struck out “evening or summer” before “programs, such”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s602/b/1/B"},"text":"Pub. L. 105–244, § 602(b)(1)(B)","children":[],"tail":", inserted “foreign language studies,” after “area studies,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s602/b/2"},"text":"Pub. L. 105–244, § 602(b)(2)","children":[],"tail":", inserted “, such as a representative of a community college in the region served by the center” before the period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":" amended section generally, substituting present provisions for provisions relating to grants for establishing and operating international business education centers in subsec. (a), costs to be covered by Federal funds in subsec. (b), scope of programs and activities in subsec. (c), center advisory council in subsec. (d), duration of grants and allotment of Federal and non-Federal shares in subsec. (e), and conditions for grants in subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d718ed8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d718ed9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d718eda-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/s2"},"text":"section 2 of Pub. L. 102–325","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
