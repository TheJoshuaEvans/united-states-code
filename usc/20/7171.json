{"tag":"section","attrib":{"id":"id0e26d608-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171"},"text":null,"children":[{"tag":"num","attrib":{"value":"7171"},"text":"§ 7171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose; definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e26d609-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this part is to provide opportunities for communities to establish or expand activities in community learning centers that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e26d60a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide opportunities for academic enrichment, including providing tutorial services to help students, particularly students who attend low-performing schools, to meet the challenging State academic standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d60b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer students a broad array of additional services, programs, and activities, such as youth development activities, service learning, nutrition and health education, drug and violence prevention programs, counseling programs, arts, music, physical fitness and wellness programs, technology education programs, financial literacy programs, environmental literacy programs, mathematics, science, career and technical programs, internship or apprenticeship programs, and other ties to an in-demand industry sector or occupation for high school students that are designed to reinforce and complement the regular academic program of participating students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d60c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer families of students served by community learning centers opportunities for active and meaningful engagement in their children’s education, including opportunities for literacy and related educational development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e26d60d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e26d60e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community learning center","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “community learning center” means an entity that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e26d60f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assists students to meet the challenging State academic standards by providing the students with academic enrichment activities and a broad array of other activities (such as programs and activities described in subsection (a)(2)) during nonschool hours or periods when school is not in session (such as before and after school or during summer recess) that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e26d610-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reinforce and complement the regular academic programs of the schools attended by the students served; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e26d611-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are targeted to the students’ academic needs and aligned with the instruction students receive during the school day; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d612-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offers families of students served by such center opportunities for active and meaningful engagement in their children’s education, including opportunities for literacy and related educational development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d613-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered program” means a program for which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e26d614-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary made a grant under this part (as this part was in effect on the day before the effective date of this part under the Every Student Succeeds Act); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d615-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grant period had not ended on that effective date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d616-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible entity” means a local educational agency, community-based organization, Indian tribe or tribal organization (as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"), another public or private entity, or a consortium of 2 or more such agencies, organizations, or entities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d617-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" External organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “external organization” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e26d618-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization with a record of success in running or working with before and after school (or summer recess) programs and activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d619-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a community where there is no such organization, a nonprofit organization in the community that enters into a written agreement or partnership with an organization described in subparagraph (A) to receive mentoring and guidance in running or working with before and after school (or summer recess) programs and activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d61a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rigorous peer-review process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “rigorous peer-review process” means a process by which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e26d61b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees of a State educational agency who are familiar with the programs and activities assisted under this part review all applications that the State receives for awards under this part for completeness and applicant eligibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d61c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the State educational agency selects peer reviewers for such applications, who shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e26d61d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be selected for their expertise in providing effective academic, enrichment, youth development, and related services to children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e26d61e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not include any applicant, or representative of an applicant, that has submitted an application under this part for the current application period; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d61f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the peer reviewers described in subparagraph (B) review and rate the applications to determine the extent to which the applications meet the requirements under sections 7174(b) and 7175 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d620-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7171/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the 50 States, the District of Columbia, and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e26d621-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4201"},"text":"Pub. L. 89–10, title IV, § 4201","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIV/s401"},"text":"Pub. L. 107–110, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1765"},"text":"115 Stat. 1765","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4201/a"},"text":"Pub. L. 114–95, title IV, § 4201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1982"},"text":"129 Stat. 1982","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e26d622-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e26d623-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e26d624-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part (as this part was in effect on the day before the effective date of this part under the Every Student Succeeds Act), referred to in subsec. (b)(2)(A), means this part as in effect before it was amended generally by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4201/a"},"text":"Pub. L. 114–95, title IV, § 4201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1982"},"text":"129 Stat. 1982","children":[],"tail":". For effective date of "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e26d625-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" amended section generally. Prior to amendment, section related to purpose and definitions of this part."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e26d626-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e26d627-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
