{"tag":"section","attrib":{"id":"id0d339bb4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1087f"},"text":"§ 1087f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d339bb5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts for supplies and services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d339bb6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, to the extent practicable, award contracts for origination, servicing, and collection described in subsection (b). In awarding such contracts, the Secretary shall ensure that such services and supplies are provided at competitive prices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d339bb7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The entities with which the Secretary may enter into contracts shall include only entities which the Secretary determines are qualified to provide such services and supplies and will comply with the procedures applicable to the award of such contracts. In the case of awarding contracts for the origination, servicing, and collection of loans under this part, the Secretary shall enter into contracts only with entities that have extensive and relevant experience and demonstrated effectiveness. The entities with which the Secretary may enter into such contracts shall include, where practicable, agencies with agreements with the Secretary under sections 1078(b) and (c) of this title, if such agencies meet the qualifications as determined by the Secretary under this subsection and if those agencies have such experience and demonstrated effectiveness. In awarding contracts to such State agencies, the Secretary shall, to the extent practicable and consistent with the purposes of this part, give special consideration to State agencies with a history of high quality performance to perform services for institutions of higher education within their State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d339bb8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as a limitation of the authority of any State agency to enter into an agreement for the purposes of this section as a member of a consortium of State agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d339bb9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts for origination, servicing, and data systems","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may enter into contracts for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d339bba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alternative origination of loans to students attending institutions of higher education with agreements to participate in the program under this part (or their parents), if such institutions do not have agreements with the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087d/b"},"text":"section 1087d(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d339bbb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the servicing and collection of loans made or purchased under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d339bbc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment and operation of 1 or more data systems for the maintenance of records on all loans made or purchased under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d339bbd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087f/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other aspects of the direct student loan program as the Secretary determines are necessary to ensure the successful operation of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d339bbe-3a70-11f1-a648-bee82ed8a795"},"text":"(","child