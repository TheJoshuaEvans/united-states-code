{"tag":"section","attrib":{"id":"id0defe7ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4710"},"text":null,"children":[{"tag":"num","attrib":{"value":"4710"},"text":"§ 4710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0defe7af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4710/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to carry out this chapter, the Foundation may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0defe7b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4710/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" appoint and fix the rates of basic pay of not more than three employees (in addition to the Executive Secretary appointed under section 4709 ","children":[{"tag":"ref","attrib":{"idref":"fn002180"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002180"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title) to carry out the provisions of this chapter, without regard to the provisions in chapter 33 of title 5 governing appointment in the competitive service or the provisions of chapter 51 and subchapter III of chapter 53 of such title, except that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0defe7b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4710/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rate of basic pay set under this paragraph may not exceed the maximum rate provided for employees in grade GS–15 of the General Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0defe7b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4710/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee shall be entitled to the applicable locality-based comparability payment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5304"},"text":"section 5304 of title 5","children":[],"tail":", subject to the applicable limitation established under subsection (g) of such section;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe7b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4710/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure temporary and intermittent services of experts and consultants as are necessary to the extent authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":", but at rates not to exceed the rate specified at the time of such service for level IV of the Executive Schedule;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe7b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4710/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe such regulations as it considers necessary governing the manner in which its functions shall be carried out;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe7b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4710/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive money and other property donated, bequeathed, or devised, without condition or restriction other than it be used for the purposes of the Foundation, and to use, sell, or otherwise dispose of such property for the purpose of carrying out its functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe7b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4710/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept and use the services of voluntary and noncompensated personnel and for travel expenses, including per diem, as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe7b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4710/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into contracts or other arrangements, or make grants, to carry out the provisions of this chapter, and enter into such contracts or other arrangements, or make such grants, with the concurrence of two-thirds of the members of the Board, without performance or other bonds and without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe7b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4710/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rent office space in the Washington, District of Columbia, metropolitan area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe7b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4710/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expend not more than 5 percent of the Foundation’s annual operating budget on programs that, in addition to or in conjunction with the Foundation’s scholarship financial awards, support the development of Goldwater Scholars throughout their professional careers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe7ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4710/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expend not more than 5 percent of the Foundation’s annual operating budget to pay the costs associated with fundraising activities, including public and private gatherings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe7bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4710/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make other necessary expenditures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0defe7bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4710/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall submit to the President and to Congress an annual report of its operations under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0defe7bd-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tXIV/s1411"},"text":"Pub. L. 99–661, div. A, title XIV, § 1411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4011"},"text":"100 Stat. 4011","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tXI/s1179/b"},"text":"Pub. L. 103–160, div. A, title XI, § 1179(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1770"},"text":"107 Stat. 1770","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXIII/s6307"},"text":"Pub. L. 117–81, div. F, title LXIII, § 6307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2395"},"text":"135 Stat. 2395","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0defe7be-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0defe7bf-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0defe7c0-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4709"},"text":"Section 4709 of this title","children":[],"tail":", referred to in subsec. (a)(1), was a reference to section 4709 in the original but probably should have been a reference to section 1410 of the Barry Goldwater Scholarship and Excellence in Education Act, "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tXIV"},"text":"Pub. L. 99–661, div. A, title XIV","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4709"},"text":"section 4709 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Level IV of the Executive Schedule, referred to in subsec. (a)(2), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0defe7c1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a)(6), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":"” substituted for “section 3709 of the Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s5"},"text":"41 U.S.C. 5","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0defe7c2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s6307/1"},"text":"Pub. L. 117–81, § 6307(1)","children":[],"tail":", added par. (1) and struck out former par. (1) which related to compensation of personnel."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s6307/2"},"text":"Pub. L. 117–81, § 6307(2)","children":[],"tail":", substituted “level IV of the Executive Schedule” for “grade GS–18 under section 5332 of such title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s6307/3"},"text":"Pub. L. 117–81, § 6307(3)","children":[],"tail":"–(5), added pars. (8) and (9) and redesignated former par. (8) as (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" substituted “the Washington, District of Columbia, metropolitan area” for “the District of Columbia”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
