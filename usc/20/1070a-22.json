{"tag":"section","attrib":{"id":"id0ce99ade-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–22"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070a–22"},"text":"§ 1070a–22.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ce99adf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–22/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants from the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–28"},"text":"section 1070a–28 of this title","children":[],"tail":" for a fiscal year, the Secretary shall make available—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce99ae0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–22/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to eligible entities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–21/c/1"},"text":"section 1070a–21(c)(1) of this title","children":[],"tail":", not less than 33 percent of such amount;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99ae1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–22/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to eligible entities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–21/c/2"},"text":"section 1070a–21(c)(2) of this title","children":[],"tail":", not less than 33 percent of such amount; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99ae2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–22/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to eligible entities described in paragraph (1) or (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–21/c"},"text":"section 1070a–21(c) of this title","children":[],"tail":", the remainder of such amount taking into consideration the number, quality, and promise of the applications for the grants, and, to the extent practicable—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce99ae3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–22/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographic distribution of such grant awards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce99ae4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–22/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distribution of such grant awards between urban and rural applicants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce99ae5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–22/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each eligible entity shall ensure that the activities assisted under this division are, to the extent practicable, coordinated with, and complement and enhance—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce99ae6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–22/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services under this division provided by other eligible entities serving the same school district or State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99ae7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–22/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related services under other Federal or non-Federal programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce99ae8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–22/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of fiscal agent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–21/c/2"},"text":"section 1070a–21(c)(2) of this title","children":[],"tail":" shall designate an institution of higher education or a local educational agency as the fiscal agent for the eligible entity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce99ae9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–22/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cohort approach","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce99aea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–22/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require that eligible entities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–21/c/2"},"text":"section 1070a–21(c)(2) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce99aeb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–22/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide services under this division to at least one grade level of students, beginning not later than 7th grade, in a participating school that has a 7th grade and in which at least 50 percent of the students enrolled are eligible for free or reduced-price lunch under the Richard B. Russell National School Lunch Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"42 U.S.C. 1751","children":[],"tail":" et seq.] (or, if an eligible entity determines that it would promote the effectiveness of a program, an entire grade level of students, beginning not later than the 7th grade, who reside in public housing as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437a/b/1"},"text":"section 1437a(b)(1) of title 42","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce99aec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–22/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the services are provided through the 12th grade to students in the participating grade level and provide the option of continued services through the student’s first year of attendance at an institution of higher education to the extent the provision of such services was described in the eligible entity’s application for assistance under this division; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce99aed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–22/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide services under this division to students who have received services under a previous GEAR UP grant award but have not yet completed the 12th grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99aee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–22/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order for the Secretary to require the cohort approach described in paragraph (1), the Secretary shall, where applicable, ensure that the cohort approach is done in coordination and collaboration with existing early intervention programs and does not duplicate the services already provided to a school or community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce99aef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–22/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement, not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grant funds awarded under this division shall be used to supplement, and not supplant, other Federal, State, and local funds that would otherwise be expended to carry out activities assisted under this division.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ce99af0-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s404B"},"text":"Pub. L. 89–329, title IV, § 404B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s403"},"text":"Pub. L. 105–244, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1657"},"text":"112 Stat. 1657","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tVII/s752/b/8"},"text":"Pub. L. 106–78, title VII, § 752(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1169"},"text":"113 Stat. 1169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s404/b"},"text":"Pub. L. 110–315, title IV, § 404(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3207"},"text":"122 Stat. 3207","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ce99af1-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ce99af2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0ce99af3-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Richard B. Russell National School Lunch Act, referred to in subsec. (d)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281"},"text":"act June 4, 1946, ch. 281","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/230"},"text":"60 Stat. 230","children":[],"tail":", which is classified generally to chapter 13 (§ 1751 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"section 1751 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0ce99af4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1070a–22, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s404B"},"text":"Pub. L. 89–329, title IV, § 404B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s402/a/4"},"text":"Pub. L. 102–325, title IV, § 402(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/492"},"text":"106 Stat. 492","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/b/13"},"text":"Pub. L. 103–208, § 2(b)(13)","children":[],"tail":", (14), "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2459"},"text":"107 Stat. 2459","children":[],"tail":", related to State eligibility and State plan, prior to the general amendment of this division by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0ce99af5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s404/b/1"},"text":"Pub. L. 110–315, § 404(b)(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which related to funding rules."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s404/b/2"},"text":"Pub. L. 110–315, § 404(b)(2)","children":[],"tail":", (3), redesignated subsecs. (c) and (d) as (b) and (c), respectively, and struck out former subsec. (b). Text read as follows: “Each eligible entity described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–21/c/1"},"text":"section 1070a–21(c)(1) of this title","children":[],"tail":", and each eligible entity described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–21/c/2"},"text":"section 1070a–21(c)(2) of this title","children":[],"tail":" that conducts a scholarship component under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–25"},"text":"section 1070a–25 of this title","children":[],"tail":", shall use not less than 25 percent and not more than 50 percent of grant funds received under this division for the early intervention component of an eligible entity’s program under this division, except that the Secretary may waive the 50 percent limitation if the eligible entity demonstrates that the eligible entity has another means of providing the students with financial assistance that is described in the plan submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–23"},"text":"section 1070a–23 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s404/b/3"},"text":"Pub. L. 110–315, § 404(b)(3)","children":[],"tail":", redesignated subsec. (g) as (d). Former subsec. (d) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s404/b/4"},"text":"Pub. L. 110–315, § 404(b)(4)","children":[],"tail":", inserted “and provide the option of continued services through the student’s first year of attendance at an institution of higher education to the extent the provision of such services was described in the eligible entity’s application for assistance under this division” after “grade level” in par. (B) and added par. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s404/b/2"},"text":"Pub. L. 110–315, § 404(b)(2)","children":[],"tail":", (5), added subsec. (e) and struck out former subsec. (e). Prior to amendment, text read as follows: “An eligible entity described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–21/c/2"},"text":"section 1070a–21(c)(2) of this title","children":[],"tail":" shall have a full-time program coordinator or a part-time program coordinator, whose primary responsibility is a project under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–23"},"text":"section 1070a–23 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s404/b/2"},"text":"Pub. L. 110–315, § 404(b)(2)","children":[],"tail":", struck out subsec. (f). Text read as follows: “An eligible entity described in 1070a–21(c)(2) of this title shall ensure that the activities assisted under this division will not displace an employee or eliminate a position at a school assisted under this division, including a partial displacement such as a reduction in hours, wages or employment benefits.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s404/b/3"},"text":"Pub. L. 110–315, § 404(b)(3)","children":[],"tail":", redesignated subsec. (g) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (g)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/78"},"text":"Pub. L. 106–78","children":[],"tail":" substituted “Richard B. Russell National School Lunch Act” for “National School Lunch Act”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
