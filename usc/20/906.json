{"tag":"section","attrib":{"id":"id0ca47b2f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s906"},"text":null,"children":[{"tag":"num","attrib":{"value":"906"},"text":"§ 906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entitlements in addition to basic compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ca47b30-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-of-living increase and additional compensation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations which shall be prescribed by or under authority of the President, each teacher (other than a teacher employed in a substitute capacity) shall be entitled, in addition to basic compensation, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ca47b31-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s906/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cost-of-living allowances equal to those authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5924"},"text":"section 5924 of title 5","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca47b32-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s906/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional compensation equal to that authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5941"},"text":"section 5941 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ca47b33-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post differential","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The cost-of-living allowances and additional compensation provided under subsection (a) of this section for any teacher shall be based on the teaching position in which he rendered services on a school-year basis, except that, if such teacher is employed in another position during any recess period between two school years, such allowances and compensation for such recess period shall be based on the position in which he is employed during such recess period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ca47b34-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/91/s8"},"text":"Pub. L. 86–91, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-07-17"},"text":"July 17, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/216"},"text":"73 Stat. 216","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/tII/s2206/d"},"text":"Pub. L. 96–465, title II, § 2206(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2162"},"text":"94 Stat. 2162","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ca47b35-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ca47b36-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0ca47b37-3a70-11f1-a648-bee82ed8a795