{"tag":"section","attrib":{"id":"id0d29ff6a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–56"},"text":null,"children":[{"tag":"num","attrib":{"value":"1087–56"},"text":"§ 1087–56.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Job location and development programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d29ff6b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–56/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d29ff6c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–56/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary is authorized to enter into agreements with eligible institutions under which such institution may use not more than 10 percent or $75,000 of its allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087–52"},"text":"section 1087–52 of this title","children":[],"tail":", whichever is less, to establish or expand a program under which such institution, separately or in combination with other eligible institutions, locates and develops jobs, including community service jobs, for currently enrolled students."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d29ff6d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–56/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Jobs located and developed under this section shall be jobs that are suitable to the scheduling and other needs of such students and that, to the maximum extent practicable, complement and reinforce the educational programs or vocational goals of such students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d29ff6e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–56/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Agreements under subsection (a) of this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d29ff6f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–56/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that the Federal share of the cost of any program under this section will not exceed 80 percent of such cost;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d29ff70-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–56/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide satisfactory assurance that funds available under this section will not be used to locate or develop jobs at an eligible institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d29ff71-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–56/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide satisfactory assurance that funds available under this section will not be used for the location or development of jobs for students to obtain upon graduation, but rather for the location and development of jobs available to students during and between periods of attendance at such institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d29ff72-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–56/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide satisfactory assurance that the location or development of jobs pursuant to programs assisted under this section will not result in the displacement of employed workers or impair existing contracts for services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d29ff73-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–56/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide satisfactory assurance that Federal funds used for the purpose of this section can realistically be expected to help generate student wages exceeding, in the aggregate, the amount of such funds, and that if such funds are used to contract with another organization, appropriate performance standards are part of such contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d29ff74-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–56/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that the institution will submit to the Secretary an annual report on the uses made of funds provided under this section and an evaluation of the effectiveness of such program in benefiting the students of such institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d29ff75-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s446"},"text":"Pub. L. 89–329, title IV, § 446","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s403/a"},"text":"Pub. L. 99–498, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1435"},"text":"100 Stat. 1435","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/50/s11/d"},"text":"Pub. L. 100–50, § 11(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-06-03"},"text":"June 3, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/348"},"text":"101 Stat. 348","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s445"},"text":"Pub. L. 102–325, title IV, § 445","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/566"},"text":"106 Stat. 566","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s445"},"text":"Pub. L. 110–315, title IV, § 445","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3260"},"text":"122 Stat. 3260","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d29ff76-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d29ff77-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d29ff78-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2756"},"text":"section 2756 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to transfer to this section. See note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was originally enacted as section 126 of the Economic Opportunity Act of 1964, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452"},"text":"Pub. L. 88–452","children":[],"tail":", at which time it was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2756"},"text":"section 2756 of Title 42","children":[],"tail":", The Public Health and Welfare. It was renumbered as section 446 of title IV of the Higher Education Act of 1965, "},{"tag":"ref","attrib":{"href":"/us/pl/89/329"},"text":"Pub. L. 89–329","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/90/575/s131/a"},"text":"Pub. L. 90–575, § 131(a)","children":[],"tail":", (b)(2), and later editorially transferred to this section to merge with the rest of the Act, which is classified to this chapter. For complete credit information on acts affecting this section prior to "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":", see Prior Provisions note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d29ff79-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s446"},"text":"section 446 of Pub. L. 89–329","children":[],"tail":", title IV, formerly "},{"tag":"ref","attrib":{"href":"/us/pl/88/452/tI/s126"},"text":"Pub. L. 88–452, title I, § 126","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-20"},"text":"Aug. 20, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/516"},"text":"78 Stat. 516","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s441/1"},"text":"Pub. L. 89–329, title IV, § 441(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1249"},"text":"79 Stat. 1249","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s446"},"text":"Pub. L. 89–329, title IV, § 446","children":[],"tail":", and amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/575/tI"},"text":"Pub. L. 90–575, title I","children":[],"tail":", §§ 131(a), (b)(2), 133(a), "},{"tag":"date","attrib":{"date":"1968-10-16"},"text":"Oct. 16, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1028"},"text":"82 Stat. 1028","children":[],"tail":", 1029; "},{"tag":"ref","attrib":{"href":"/us/pl/94/43/s2"},"text":"Pub. L. 94–43, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-06-28"},"text":"June 28, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/233"},"text":"89 Stat. 233","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tIV/s435"},"text":"Pub. L. 96–374, title IV, § 435","children":[],"tail":", title XIII, § 1391(a)(1), "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1435"},"text":"94 Stat. 1435","children":[],"tail":", 1503, related to equitable distribution of assistance, prior to the general revision of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087–57"},"text":"section 1087–57 of this title","children":[],"tail":" prior to the general revision of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d29ff7a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" substituted “$75,000” for “$50,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":" amended section generally, restating subsecs. (a) and (b) with changes in substance and structure and striking out subsec. (c) which defined “community services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (b)(3) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/50"},"text":"Pub. L. 100–50","children":[],"tail":" redesignated pars. (4) to (7) as (3) to (6), respectively, and struck out former par. (3) which read as follows: “provide satisfactory assurance that the institution will continue to spend in its own job location and development programs, from sources other than funds received under this section, not less than the average expenditures per year made during the most recent 3 fiscal years preceding the effective date of the agreement;”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d29ff7b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d29ff7c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/s2"},"text":"section 2 of Pub. L. 102–325","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d29ff7d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/50"},"text":"Pub. L. 100–50","children":[],"tail":" effective as if enacted as part of the Higher Education Amendments of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/50/s27"},"text":"section 27 of Pub. L. 100–50","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d29ff7e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to periods of enrollment beginning on or after ","children":[{"tag":"date","attrib":{"date":"1987-07-01"},"text":"July 1, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/s403/b/2"},"text":"section 403(b)(2) of Pub. L. 99–498","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087–53"},"text":"section 1087–53 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
