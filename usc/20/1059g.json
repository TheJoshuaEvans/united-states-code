{"tag":"section","attrib":{"id":"id0cd43d8e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1059g"},"text":"§ 1059g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asian American and Native American Pacific Islander-serving institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cd43d8f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide grants and related assistance to Asian American and Native American Pacific Islander-serving institutions to enable such institutions to improve and expand their capacity to serve Asian Americans and Native American Pacific Islanders and low-income individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd43d90-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd43d91-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asian American","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Asian American” has the meaning given the term “Asian” in the Office of Management and Budget’s Standards for Maintaining, Collecting, and Presenting Federal Data on Race and Ethnicity as published on ","children":[{"tag":"date","attrib":{"date":"1997-10-30"},"text":"October 30, 1997","children":[],"tail":" (62 Fed. Reg. 58789)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd43d92-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asian American and Native American Pacific Islander-serving institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Asian American and Native American Pacific Islander-serving institution” means an institution of higher education that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd43d93-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an eligible institution under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1058/b"},"text":"section 1058(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d94-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time of application, has an enrollment of undergraduate students that is not less than 10 percent students who are Asian American or Native American Pacific Islander.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd43d95-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native American Pacific Islander","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Native American Pacific Islander” means any descendant of the aboriginal people of any island in the Pacific Ocean that is a territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd43d96-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd43d97-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of activities authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants awarded under this section shall be used by Asian American and Native American Pacific Islander-serving institutions to assist such institutions to plan, develop, undertake, and carry out activities to improve and expand such institutions’ capacity to serve Asian Americans and Native American Pacific Islanders and low-income individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd43d98-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examples of authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such programs may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd43d99-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase, rental, or lease of scientific or laboratory equipment for educational purposes, including instructional and research purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d9a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" renovation and improvement in classroom, library, laboratory, and other instructional facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d9b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support of faculty exchanges, and faculty development and faculty fellowships to assist in attaining advanced degrees in the faculty’s field of instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d9c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" curriculum development and academic instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d9d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase of library books, periodicals, microfilm, and other educational materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d9e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds and administrative management, and acquisition of equipment for use in strengthening funds management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d9f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" joint use of facilities such as laboratories and libraries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43da0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic tutoring and counseling programs and student support services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43da1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/c/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing community outreach programs that will encourage elementary school and secondary school students to develop the academic skills and the interest to pursue postsecondary education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43da2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/c/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing or improving an endowment fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43da3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/c/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic instruction in disciplines in which Asian Americans and Native American Pacific Islanders are underrepresented;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43da4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/c/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting research and data collection for Asian American and Native American Pacific Islander populations and subpopulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43da5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/c/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing partnerships with community-based organizations serving Asian Americans and Native American Pacific Islanders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43da6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/c/2/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education or counseling services designed to improve the financial and economic literacy of students or the students’ families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd43da7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application process","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd43da8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutional eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Asian American and Native American Pacific Islander-serving institution desiring to receive assistance under this section shall submit to the Secretary such enrollment data as may be necessary to demonstrate that the institution is an Asian American and Native American Pacific Islander-serving institution as defined in subsection (b), along with such other information and data as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd43da9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any institution that is determined by the Secretary to be an Asian American and Native American Pacific Islander-serving institution may submit an application for assistance under this section to the Secretary. Such application shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd43daa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a five-year plan for improving the assistance provided by the Asian American and Native American Pacific Islander-serving institution to Asian American and Native American Pacific Islander students and low-income individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43dab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information and assurances as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd43dac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd43dad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No Asian American and Native American Pacific Islander-serving institution that receives funds under this section shall concurrently receive funds under any other provision of this part, part B, or subchapter V.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43dae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059/d"},"text":"Section 1059(d) of this title","children":[],"tail":" shall not apply to institutions that are eligible to receive funds under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43daf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this section, the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cd43db0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/d/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent possible and consistent with the competitive process under which such grants are awarded, ensure maximum and equitable distribution among all eligible institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cd43db1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059g/d/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give priority consideration to institutions for which not less than 10 percent of such institution’s Asian American and Native American Pacific Islander students are low-income individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cd43db2-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s320"},"text":"Pub. L. 89–329, title III, § 320","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIII/s307"},"text":"Pub. L. 110–315, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3175"},"text":"122 Stat. 3175","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
