{"tag":"section","attrib":{"id":"id0e21f44b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7013"},"text":null,"children":[{"tag":"num","attrib":{"value":"7013"},"text":"§ 7013.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National clearinghouse","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e21f44c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7013/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish and support the operation of a National Clearinghouse for English Language Acquisition and Language Instruction Educational Programs, which shall collect, analyze, synthesize, and disseminate information about language instruction educational programs for English learners, and related programs. The National Clearinghouse shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e21f44d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7013/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be administered as an adjunct clearinghouse of the Educational Resources Information Center Clearinghouses system supported by the Institute of Education Sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f44e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7013/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate activities with Federal data and information clearinghouses and entities operating Federal dissemination networks and systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e24644f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7013/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a system for improving the operation and effectiveness of federally funded language instruction educational programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e246450-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7013/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" collect and disseminate information on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e246451-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7013/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational research and processes related to the education of English learners, including English learners with a disability, that includes information on best practices on instructing and serving English learners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e246452-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7013/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accountability systems that monitor the academic progress of English learners in language instruction educational programs, including information on academic content and English proficiency assessments for language instruction educational programs; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e246453-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7013/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish, on an annual basis, a list of grant recipients under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e246454-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7013/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall authorize the Secretary to hire additional personnel to execute subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e246455-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIII/s3202"},"text":"Pub. L. 89–10, title III, § 3202","children":[],"tail":", formerly § 3303, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIII/s301"},"text":"Pub. L. 107–110, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1733"},"text":"115 Stat. 1733","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/279/tIV/s404/d/5/B"},"text":"Pub. L. 107–279, title IV, § 404(d)(5)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1986"},"text":"116 Stat. 1986","children":[],"tail":"; renumbered § 3202 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIII"},"text":"Pub. L. 114–95, title III","children":[],"tail":", §§ 3001(5)(C), 3004(b), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1953"},"text":"129 Stat. 1953","children":[],"tail":", 1965.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNot