{"tag":"section","attrib":{"id":"id0ccf5b85-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1033"},"text":null,"children":[{"tag":"num","attrib":{"value":"1033"},"text":"§ 1033.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subpart:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ccf5b86-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1033/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible institution” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ccf5b87-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1033/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an institution of higher education that has a teacher preparation program that is a qualified teacher preparation program and that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0ccf5b88-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1033/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a part B institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1061"},"text":"section 1061 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ccf5b89-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1033/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Hispanic-serving institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1101a"},"text":"section 1101a of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ccf5b8a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1033/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Tribal College or University (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c"},"text":"section 1059c of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ccf5b8b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1033/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Alaska Native-serving institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059d/b"},"text":"section 1059d(b) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ccf5b8c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1033/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Native Hawaiian-serving institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059d/b"},"text":"section 1059d(b) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ccf5b8d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1033/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Predominantly Black Institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059e"},"text":"section 1059e of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ccf5b8e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1033/1/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Asian American and Native American Pacific Islander-serving institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059g/b"},"text":"section 1059g(b) of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ccf5b8f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1033/1/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Native American-serving, nontribal institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059f"},"text":"section 1059f of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ccf5b90-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1033/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium of institutions described in subparagraph (A); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ccf5b91-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1033/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution described in subparagraph (A), or a consortium described in subparagraph (B), in partnership with any other institution of higher education, but only if the center of excellence established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1033a"},"text":"section 1033a of this title","children":[],"tail":" is located at an institution described in subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ccf5b92-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1033/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientifically based reading research","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “scientifically based reading research”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ccf5b93-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1033/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means research that applies rigorous, systemic, and objective procedures to obtain valid knowledge relevant to reading development, reading instruction, and reading difficulties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ccf5b94-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1033/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes research that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0ccf5b95-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1033/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employs systemic, empirical methods that draw on observation or experiment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ccf5b96-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1033/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves rigorous data analyses that are adequate to test the stated hypotheses and justify the general conclusions drawn;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ccf5b97-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1033/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relies on measurements or observational methods that provide valid data across evaluators and observers and across multiple measurements and observations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ccf5b98-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1033/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been accepted by a peer-reviewed journal or approved by a panel of independent experts through a comparably rigorous, objective, and scientific review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ccf5b99-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tII/s241"},"text":"Pub. L. 89–329, title II, § 241","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tII/s201/3"},"text":"Pub. L. 110–315, title II, § 201(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3158"},"text":"122 Stat. 3158","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215"},"text":"Pub. L. 114–95, title IX, § 9215","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"oo","children":[],"tail":")(5), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2179"},"text":"129 Stat. 2179","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ccf5b9a-3a70-11f1-a648-bee82ed8a