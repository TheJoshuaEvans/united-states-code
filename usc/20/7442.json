{"tag":"section","attrib":{"id":"id0e37777b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442"},"text":null,"children":[{"tag":"num","attrib":{"value":"7442"},"text":"§ 7442.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Professional development for teachers and education professionals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e37777c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e37777d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the number of qualified Indian teachers and administrators serving Indian students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e37777e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide pre- and in-service training and support to qualified Indian individuals to enable such individuals to become effective teachers, principals, other school leaders, administrators, paraprofessionals, counselors, social workers, and specialized instructional support personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e37777f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the skills of qualified Indian individuals who serve in the capacities described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e377780-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and implement initiatives to promote retention of effective teachers, principals, and school leaders who have a record of success in helping low-achieving Indian students improve their academic achievement, outcomes, and preparation for postsecondary education or employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e377781-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this section, the term “eligible entity” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e377782-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education, including a Tribal College or University, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c/b"},"text":"section 1059c(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e377783-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State educational agency or local educational agency, in consortium with an institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e377784-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe or organization, in consortium with an institution of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e377785-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Bureau-funded school (as defined in section 2026 ","children":[{"tag":"ref","attrib":{"idref":"fn002225"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002225"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 25) in a consortium with at least one Tribal College or University, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c/b"},"text":"section 1059c(b) of this title","children":[],"tail":", where feasible."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e377786-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to award grants to eligible entities having applications approved under this section to enable those entities to carry out the activities described in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e377787-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e377788-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grant funds under this section shall be used for activities to provide support and training for Indian individuals in a manner consistent with the purpose of this section. Such activities may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e377789-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing education programs, symposia, workshops, and conferences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e37778a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" teacher mentoring programs, professional guidance, and instructional support provided by educators, local traditional leaders, or cultural experts, as appropriate for teachers during their first 3 years of employment as teachers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e37778b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct financial support; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e37778c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs designed to train traditional leaders and cultural experts to assist those personnel referenced in subsection (a)(2), as appropriate, with relevant Native language and cultural mentoring, guidance, and support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e37778d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e37778e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Type of training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For education personnel, the training received pursuant to a grant under this section may be inservice or preservice training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e37778f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For individuals who are being trained to enter any field other than teaching, the training received pursuant to a grant under this section shall be in a program that results in a graduate degree.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e377790-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each eligible entity desiring a grant under this section shall submit an application to the Secretary at such time and in such manner as the Secretary may reasonably require. At a minimum, an application under this section shall describe how the eligible entity will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e377791-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruit qualified Indian individuals, such as students who may not be of traditional college age, to become teachers, principals, or school leaders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e377792-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use funds made available under the grant to support the recruitment, preparation, and professional development of Indian teachers or principals in local educational agencies that serve a high proportion of Indian students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e377793-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist participants in meeting the requirements under subsection (h).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e377794-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this section, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e377795-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may give priority to Tribal Colleges and Universities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e377796-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall consider the prior performance of the eligible entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e377797-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not limit eligibility to receive a grant under this section on the basis of the length of any period for which the eligible entity has received a grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e377798-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants under this section for an initial period of not more than 3 years, and may renew such grants for an additional period of not more than 2 years if the Secretary finds that the grantee is achieving the objectives of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e377799-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service obligation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e37779a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require, by regulation, that an individual who receives training pursuant to a grant made under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e37779b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" perform work—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e37779c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/h/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related to the training received under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e37779d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/h/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that benefits Indian students in a local educational agency that serves a high proportion of Indian students; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e37779e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repay all or a prorated part of the assistance received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e37779f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7442/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish, by regulation, a reporting procedure under which a grant recipient under this section shall, not later than 12 months after the date of completion of the training, and periodically thereafter, provide information concerning compliance with the work requirement under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e3777a0-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVI/s6122"},"text":"Pub. L. 89–10, title VI, § 6122","children":[],"tail":", formerly title VII, § 7122, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVII/s701"},"text":"Pub. L. 107–110, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1922"},"text":"115 Stat. 1922","children":[],"tail":"; renumbered title VI, § 6122, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVI"},"text":"Pub. L. 114–95, title VI","children":[],"tail":", §§ 6001(a), (b)(1), 6002("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2046"},"text":"129 Stat. 2046","children":[],"tail":", 2056.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e3777a1-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e3777a2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e3777a3-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2026"},"text":"Section 2026 of title 25","children":[],"tail":", referred to in subsec. (b)(4), was omitted in the general amendment of chapter 22 of Title 25, Indians, by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1042"},"text":"Pub. L. 107–110, title X, § 1042","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2007"},"text":"115 Stat. 2007","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2021"},"text":"section 2021 of Title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e3777a4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s6122"},"text":"section 6122 of Pub. L. 89–10","children":[],"tail":" was renumbered section 5102 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7305a"},"text":"section 7305a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e3777a5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002"},"text":"Pub. L. 114–95, § 6002","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1)(A), added par. (1) and struck out former par. (1) which read as follows: “to increase the number of qualified Indian individuals in teaching or other education professions that serve Indian people;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002"},"text":"Pub. L. 114–95, § 6002","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1)(B), added par. (2) and struck out former par. (2) which read as follows: “to provide training to qualified Indian individuals to enable such individuals to become teachers, administrators, teacher aides, social workers, and ancillary educational personnel; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002"},"text":"Pub. L. 114–95, § 6002","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1)(C), (D), added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002"},"text":"Pub. L. 114–95, § 6002","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2)(A), substituted “including a Tribal College or University, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c/b"},"text":"section 1059c(b) of this title","children":[],"tail":"” for “including an Indian institution of higher education”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002"},"text":"Pub. L. 114–95, § 6002","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2)(B), inserted before period at end “in a consortium with at least one Tribal College or University, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c/b"},"text":"section 1059c(b) of this title","children":[],"tail":", where feasible”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002"},"text":"Pub. L. 114–95, § 6002","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3), substituted “purpose of this section.” for “purposes of this section.” and “Such activities may include—” and subpars. (A) to (D) for “Such activities may include continuing programs, symposia, workshops, conferences, and direct financial support, and may include programs designed to train tribal elders and seniors.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002"},"text":"Pub. L. 114–95, § 6002","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(4), added subsec. (e) and struck out former subsec. (e). Prior to amendment, text read as follows: “Each eligible entity desiring a grant under this section shall submit an application to the Secretary at such time, in such manner, and accompanied by such information, as the Secretary may reasonably require.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002"},"text":"Pub. L. 114–95, § 6002","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(5), added par. (1), redesignated former pars. (1) and (2) as (2) and (3), respectively, and, in par. (3), substituted “basis of the length of any period for which the eligible entity has received a grant.” for “basis of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the number of previous grants the Secretary has awarded such entity; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the length of any period during which such entity received such grants.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002"},"text":"Pub. L. 114–95, § 6002","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(6), added subsec. (g) and struck out former subsec. (g). Prior to amendment, text read as follows: “Each grant under this section shall be awarded for a period of not more than 5 years.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002"},"text":"Pub. L. 114–95, § 6002","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(7), substituted “students in a local educational agency that serves a high proportion of Indian students” for “people”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e3777a6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e3777a7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
