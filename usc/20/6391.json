{"tag":"section","attrib":{"id":"id0e115182-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6391"},"text":null,"children":[{"tag":"num","attrib":{"value":"6391"},"text":"§ 6391.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this part are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e115183-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6391/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To assist States in supporting high-quality and comprehensive educational programs and services during the school year and, as applicable, during summer or intersession periods, that address the unique educational needs of migratory children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e115184-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6391/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure that migratory children who move among the States are not penalized in any manner by disparities among the States in curriculum, graduation requirements, and challenging State academic standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e115185-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6391/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure that migratory children receive full and appropriate opportunities to meet the same challenging State academic standards that all children are expected to meet.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e115186-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6391/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To help migratory children overcome educational disruption, cultural and language barriers, social isolation, various health-related problems, and other factors that inhibit the ability of such children to succeed in school.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e115187-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6391/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To help migratory children benefit from State and local systemic reforms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e115188-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1301"},"text":"Pub. L. 89–10, title I, § 1301","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1571"},"text":"115 Stat. 1571","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tI/s1301/a"},"text":"Pub. L. 114–95, title I, § 1301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1893"},"text":"129 Stat. 1893","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e115189-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e11518a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e11518b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6391, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1301"},"text":"Pub. L. 89–10, title I, § 1301","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3585"},"text":"108 Stat. 3585","children":[],"tail":", related to program purpose, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e11518c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" amended section generally. Prior to amendment, section related to purposes of this part to assist States: (1) to support high-quality and comprehensive educational programs for migratory children; (2) to ensure that migratory children who move among the States are not penalized in any manner by disparities among the States; (3) to ensure that migratory children are provided with appropriate educational services; (4) to ensure that migratory children receive full and appropriate opportunities to meet challenging State standards; (5) to design programs to help migratory children overcome educational disruption and other factors that inhibit their ability to do well in school; and (6) to ensure that migratory children benefit from State and local systemic reforms."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e11518d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e11518e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
