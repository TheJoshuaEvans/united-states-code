{"tag":"section","attrib":{"id":"id0ded9d8a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4504"},"text":null,"children":[{"tag":"num","attrib":{"value":"4504"},"text":"§ 4504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period for award","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Junior fellowships shall be granted for such periods as the Foundation may prescribe but not to exceed two academic years. Senior fellowship shall be granted for such periods as the Foundation may prescribe, but not to exceed five calendar years.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0ded9d8b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/b/tVIII/s805"},"text":"Pub. L. 99–500, § 101(b) [title VIII, § 805]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-39"},"text":"100 Stat. 1783–39","children":[],"tail":", 1783–77, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/b/tVIII/s805"},"text":"Pub. L. 99–591, § 101(b) [title VIII, § 805]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-39"},"text":"100 Stat. 3341–39","children":[],"tail":", 3341–77.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ded9d8c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ded9d8d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0ded9d8e-3a70-11f1-a648-bee8