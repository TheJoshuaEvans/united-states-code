{"tag":"section","attrib":{"id":"id0e542680-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7919"},"text":null,"children":[{"tag":"num","attrib":{"value":"7919"},"text":"§ 7919.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach and technical assistance for rural local educational agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e542681-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7919/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall engage in outreach to rural local educational agencies regarding opportunities to apply for competitive grant programs under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e542682-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7919/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If requested to do so, the Secretary shall provide technical assistance to rural local educational agencies with locale codes 32, 33, 41, 42, or 43, or an educational service agency representing rural local educational agencies with locale codes 32, 33, 41, 42, or 43 on applications or pre-applications for any competitive grant program under this chapter. No rural local educational agency or educational service agency shall be required to request technical assistance or include any technical assistance provided by the Secretary in any application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e542683-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8539"},"text":"Pub. L. 89–10, title VIII, § 8539","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII/s8031"},"text":"Pub. L. 114–95, title VIII, § 8031","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2117"},"text":"129 Stat. 2117","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e542684-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e542685-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e542686-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
