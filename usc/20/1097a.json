{"tag":"section","attrib":{"id":"id0d5e7ccc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1097a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1097a"},"text":"§ 1097a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative subpoenas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d5e7ccd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1097a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To assist the Secretary in the conduct of investigations of possible violations of the provisions of this subchapter, the Secretary is authorized to require by subpoena the production of information, documents, reports, answers, records, accounts, papers, and other documentary evidence pertaining to participation in any program under this subchapter. The production of any such records may be required from any place in a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d5e7cce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1097a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In case of contumacy by, or refusal to obey a subpoena issued to, any person, the Secretary may request the Attorney General to invoke the aid of any court of the United States where such person resides or transacts business for a court order for the enforcement of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d5e7ccf-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s490A"},"text":"Pub. L. 89–329, title IV, § 490A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s490B"},"text":"Pub. L. 105–244, title IV, § 490B","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1754"},"text":"112 Stat. 1754","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d5e7cd0-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d5e7cd1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d5e7cd2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
