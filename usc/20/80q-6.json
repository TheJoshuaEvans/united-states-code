{"tag":"section","attrib":{"id":"id0c87f249-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"80q–6"},"text":"§ 80q–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Custom House office space and auditorium","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c87f24a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repairs and alterations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of General Services shall make such repairs and alterations as may be necessary in the portion of the Old United States Custom House at One Bowling Green, New York, New York, which is not leased to the Board of Regents under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s80q–5/b"},"text":"section 80q–5(b) of this title","children":[],"tail":" and which, as of "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"November 28, 1989","children":[],"tail":", has not been altered."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c87f24b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Administrator of General Services $25,000,000 from the fund established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s592"},"text":"section 592 of title 40","children":[],"tail":" to carry out this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s80q–5/b/2/B"},"text":"section 80q–5(b)(2)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c87f24c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/185/s8"},"text":"Pub. L. 101–185, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1341"},"text":"103 Stat. 1341","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c87f24d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c87f24e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0c87f24f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s592"},"text":"Section 592 of title 40","children":[],"tail":"” substituted in subsec. (b) for “section 210(f) of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s490/f"},"text":"40 U.S.C. 490(f)","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", the first section of which enacted Title 40, Public Buildings, Property, and Works."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
