{"tag":"section","attrib":{"id":"id0ded9d9a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4507"},"text":null,"children":[{"tag":"num","attrib":{"value":"4507"},"text":"§ 4507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of fellowship recipients","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ded9d9b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Madison Fellows shall be selected for their academic achievements and their potential to become secondary school teachers of social studies and American history.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ded9d9c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competition for selection; application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ded9d9d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4507/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Foundation is authorized, either directly or by contract, to provide for the conduct of a nationwide competition for the selection of fellowship recipients. Each applicant must have a demonstrated interest in pursuing a course of study which emphasizes the Constitution, its principles, and its history, and have a demonstrated record of willingness to devote themselves to civil responsibility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ded9d9e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4507/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each application shall be accompanied by an essay explaining the importance of the study of the Constitution both to the applicant’s career aspirations and contributions to public service, and to citizenship generally in a constitutional regime.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ded9d9f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4507/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ded9da0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4507/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each application shall include a description of a program of study for the graduate program, designating the courses to be taken, and the proposed Master’s thesis, where appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ded9da1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4507/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this paragraph, the Board of Trustees of the Foundation shall establish general criteria for programs in constitutional studies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ded9da2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4507/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional selection of recipients","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall adopt selection procedures which shall assure that at least one Madison Fellow shall be selected each year from each State, the District of Columbia, and the Commonwealth of Puerto Rico, and considered as a single entity, Guam, the Virgin Islands, American Samoa, the Trust Territories of the Pacific Islands, and the Commonwealth of the Northern Marianas in which there are at least two resident applicants who meet the minimum criteria established by the Foundation; and, if sufficient funding is available, to invite applications from scholars overseas for study in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ded9da3-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/b/tVIII/s808"},"text":"Pub. L. 99–500, § 101(b) [title VIII, § 808]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-39"},"text":"100 Stat. 1783–39","children":[],"tail":", 1783–78, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/b/tVIII/s808"},"text":"Pub. L. 99–591, § 101(b) [title VIII, § 808]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-39"},"text":"100 Stat. 3341–39","children":[],"tail":", 3341–78.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ded9da4-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ded9da5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0ded9da6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":" is a corrected version of "},{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id0ded9da7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0ded9da8-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
