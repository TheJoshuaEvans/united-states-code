{"tag":"section","attrib":{"id":"id0e625861-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533"},"text":null,"children":[{"tag":"num","attrib":{"value":"9533"},"text":"§ 9533.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e625862-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Research Center shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e625863-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain published peer-review standards and standards for the conduct and evaluation of all research and development carried out under the auspices of the Research Center in accordance with this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e625864-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" propose to the Director a research plan that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e625865-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with the priorities and mission of the Institute and the mission of the Research Center and includes the activities described in paragraph (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625866-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be carried out pursuant to paragraph (4) and, as appropriate, be updated and modified;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e625867-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out specific, long-term research activities that are consistent with the priorities and mission of the Institute, and are approved by the Director;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e625868-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" implement the plan proposed under paragraph (2) to carry out scientifically valid research that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e625869-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses objective and measurable indicators, including timelines, that are used to assess the progress and results of such research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e62586a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the procedures for peer review established by the Director under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9514/f/5"},"text":"section 9514(f)(5) of this title","children":[],"tail":" and the standards of research described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9534"},"text":"section 9534 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e62586b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes both basic research and applied research, which shall include research conducted through field-initiated research and ongoing research initiatives;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e62586c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the use of scientifically valid research within the Federal Government, including active participation in interagency research projects described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9518"},"text":"section 9518 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e62586d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that research conducted under the direction of the Research Center is relevant to education practice and policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e62586e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" synthesize and disseminate, through the National Center for Education Evaluation and Regional Assistance, the findings and results of education research conducted or supported by the Research Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e62586f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Director in the preparation of a biennial report, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9519"},"text":"section 9519 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e625870-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out research on successful State and local education reform activities, including those that result in increased academic achievement and in closing the achievement gap, as approved by the Director;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e625871-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" carry out research initiatives regarding the impact of technology, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e625872-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research into how technology affects student achievement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625873-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" long-term research into cognition and learning issues as they relate to the uses of technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625874-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/a/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rigorous, peer-reviewed, large-scale, long-term, and broadly applicable empirical research that is designed to determine which approaches to the use of technology are most effective and cost-efficient in practice and under what conditions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625875-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/a/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" field-based research on how teachers implement technology and Internet-based resources in the classroom, including an understanding ","children":[{"tag":"ref","attrib":{"idref":"fn002243"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002243"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “understanding of”."}],"tail":" how these resources are being accessed, put to use, and the effectiveness of such resources; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e625876-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out research that is rigorous, peer-reviewed, and large scale to determine which methods of mathematics and science teaching are most effective, cost efficient, and able to be applied, duplicated, and scaled up for use in elementary and secondary classrooms, including in low-performing schools, to improve the teaching of, and student achievement in, mathematics and science as required under the Elementary and Secondary Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"20 U.S.C. 6301","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e625877-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Research carried out under subsection (a) through contracts, grants, or cooperative agreements shall be carried out only by recipients with the ability and capacity to conduct scientifically valid research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e625878-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National research and development centers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e625879-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out activities under subsection (a)(3), the Research Commissioner shall support not less than 8 national research and development centers. The Research Commissioner shall assign each of the 8 national research and development centers not less than 1 of the topics described in paragraph (2). In addition, the Research Commissioner may assign each of the 8 national research and development centers additional topics of research consistent with the mission and priorities of the Institute and the mission of the Research Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e62587a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Topics of research","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Research Commissioner shall support the following topics of research, through national research and development centers or through other means:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e62587b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adult literacy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e62587c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assessment, standards, and accountability research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e62587d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Early childhood development and education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e62587e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" English language learners research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e62587f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improving low achieving schools.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625880-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Innovation in education reform.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625881-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625882-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Postsecondary education and training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625883-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/c/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rural education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625884-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/c/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Teacher quality.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625885-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/c/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reading and literacy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e625886-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The national research and development centers shall address areas of national need, including in educational technology areas. The Research Commissioner may support additional national research and development centers to address topics of research not described in paragraph (2) if such topics are consistent with the priorities and mission of the Institute and the mission of the Research Center. The research carried out by the centers shall incorporate the potential or existing role of educational technology, where appropriate, in achieving the goals of each center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e625887-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Support for a national research and development center shall be for a period of not more than 5 years, shall be of sufficient size and scope to be effective, and notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9534/b"},"text":"section 9534(b) of this title","children":[],"tail":", may be renewed without competition for not more than 5 additional years if the Director, in consultation with the Research Commissioner and the Board, determines that the research of the national research and development center—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e625888-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continues to address priorities of the Institute; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625889-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" merits renewal (applying the procedures and standards established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9534"},"text":"section 9534 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e62588a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No national research and development center may be supported under this subsection for a period of more than 10 years without submitting to a competitive process for the award of the support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e62588b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall continue awards made to the national research and development centers that are in effect on the day before ","children":[{"tag":"date","attrib":{"date":"2002-11-05"},"text":"November 5, 2002","children":[],"tail":", in accordance with the terms of those awards and may renew them in accordance with paragraphs (4) and (5)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e62588c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9533/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disaggregation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent feasible, research conducted under this subsection shall be disaggregated by age, race, gender, and socioeconomic background.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e62588d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s133"},"text":"Pub. L. 107–279, title I, § 133","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1954"},"text":"116 Stat. 1954","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e62588e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e62588f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e625890-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Elementary and Secondary Education Act of 1965, referred to in subsec. (a)(11), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-04-11"},"text":"Apr. 11, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/27"},"text":"79 Stat. 27","children":[],"tail":", which is classified generally to chapter 70 (§ 6301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
