{"tag":"section","attrib":{"id":"id0e5b2cc2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9151"},"text":null,"children":[{"tag":"num","attrib":{"value":"9151"},"text":"§ 9151.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State advisory councils","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each State desiring assistance under this subchapter may establish a State advisory council which is broadly representative of the library entities in the State, including public, tribal, school, academic, special, and institutional libraries, and libraries serving people of diverse geographic, cultural, and socioeconomic backgrounds, individuals with disabilities, residents of rural and urban areas, Native Americans, military families, veterans, and caregivers.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e5b2cc3-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/462/tII/s251"},"text":"Pub. L. 94–462, title II, § 251","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/e/tVII/s702"},"text":"Pub. L. 104–208, div. A, title I, § 101(e) [title VII, § 702]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-233"},"text":"110 Stat. 3009–233","children":[],"tail":", 3009–301; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/410/s13"},"text":"Pub. L. 115–410, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5417"},"text":"132 Stat. 5417","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e5b2cc4-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e5b2cc5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e5b2cc6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/410"},"text":"Pub. L. 115–410","children":[],"tail":" inserted “tribal,” after “public,” and substituted “and libraries serving people of diverse geographic, cultural, and socioeconomic backgrounds, individuals with disabilities, residents of rural and urban areas, Native Americans, military families, veterans, and caregivers” for “and libraries serving individuals with disabilities”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
