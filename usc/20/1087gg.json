{"tag":"section","attrib":{"id":"id0d3ac7f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087gg"},"text":null,"children":[{"tag":"num","attrib":{"value":"1087gg"},"text":"§ 1087gg.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of defaulted loans: Perkins Loan Revolving Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d3ac7fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087gg/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary to collect referred, transferred, or assigned loans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any loan—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d3ac7fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087gg/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which was made under this part, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d3ac7fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087gg/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is referred, transferred, or assigned to the Secretary by an institution with an agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087cc/a"},"text":"section 1087cc(a) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary is authorized to attempt to collect such loan by any means authorized by law for collecting claims of the United States (including referral to the Attorney General for litigation) and under such terms and conditions as the Secretary may prescribe, including reimbursement for expenses reasonably incurred in attempting such collection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d3ac7fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087gg/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of referred, transferred, or assigned loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall continue to attempt to collect any loan referred, transferred, or assigned under paragraph (4) or (5) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087cc/a"},"text":"section 1087cc(a) of this title","children":[],"tail":" until all appropriate collection efforts, as determined by the Secretary, have been expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d3ac7fe-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s467"},"text":"Pub. L. 89–329, title IV, § 467","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s405/a"},"text":"Pub. L. 99–498, title IV, § 405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1453"},"text":"100 Stat. 1453","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s467"},"text":"Pub. L. 102–325, title IV, § 467","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/584"},"text":"106 Stat. 584","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s467/a"},"text":"Pub. L. 105–244, title IV, § 467(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail