{"tag":"section","attrib":{"id":"id0cd43d00-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1059d"},"text":"§ 1059d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alaska Native and Native Hawaiian-serving institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cd43d01-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide grants and related assistance to Alaska Native-serving institutions and Native Hawaiian-serving institutions to enable such institutions to improve and expand their capacity to serve Alaska Natives and Native Hawaiians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd43d02-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd43d03-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Alaska Native” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7546"},"text":"section 7546 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd43d04-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “Alaska Native-serving institution” means an institution of higher education that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd43d05-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an eligible institution under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1058/b"},"text":"section 1058(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d06-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time of application, has an enrollment of undergraduate students that is at least 20 percent Alaska Native students;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd43d07-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Native Hawaiian” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7517"},"text":"section 7517 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd43d08-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “Native Hawaiian-serving institution” means an institution of higher education which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd43d09-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an eligible institution under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1058/b"},"text":"section 1058(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d0a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time of application, has an enrollment of undergraduate students that is at least 10 percent Native Hawaiian students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd43d0b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd43d0c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of activities authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants awarded under this section shall be used by Alaska Native-serving institutions and Native Hawaiian-serving institutions to assist such institutions to plan, develop, undertake, and carry out activities to improve and expand such institutions’ capacity to serve Alaska Natives or Native Hawaiians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd43d0d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examples of authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such programs may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd43d0e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase, rental, or lease of scientific or laboratory equipment for educational purposes, including instructional and research purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d0f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" renovation and improvement in classroom, library, laboratory, and other instructional facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d10-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support of faculty exchanges, and faculty development and faculty fellowships to assist in attaining advanced degrees in the faculty’s field of instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d11-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" curriculum development and academic instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d12-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase of library books, periodicals, microfilm, and other educational materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d13-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds and administrative management, and acquisition of equipment for use in strengthening funds management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d14-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" joint use of facilities such as laboratories and libraries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d15-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic tutoring and counseling programs and student support services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d16-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/c/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education or counseling services designed to improve the financial literacy and economic literacy of students or the students’ families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd43d17-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application process","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd43d18-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutional eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Alaska Native-serving institution and Native Hawaiian-serving institution desiring to receive assistance under this section shall submit to the Secretary such enrollment data as may be necessary to demonstrate that the institution is an Alaska Native-serving institution or a Native Hawaiian-serving institution as defined in subsection (b), along with such other information and data as the Secretary may by regulation require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd43d19-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any institution which is determined by the Secretary to be an Alaska Native-serving institution or a Native Hawaiian-serving institution may submit an application for assistance under this section to the Secretary. The Secretary shall, to the extent possible, prescribe a simplified and streamlined format for such applications that takes into account the limited number of institutions that are eligible for assistance under this section. Such application shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd43d1a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 5-year plan for improving the assistance provided by the Alaska Native-serving institution or the Native Hawaiian-serving institution to Alaska Native or Native Hawaiian students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d1b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information and assurance as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd43d1c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd43d1d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No Alaskan Native-serving institution or Native Hawaiian-serving institution that receives funds under this section shall concurrently receive funds under other provisions of this part or part B.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d1e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059/d"},"text":"Section 1059(d) of this title","children":[],"tail":" shall not apply to institutions that are eligible to receive funds under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d1f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059d/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Secretary shall, to the extent possible and consistent with the competitive process under which such grants are awarded, ensure maximum and equitable distribution among all eligible institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cd43d20-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s317"},"text":"Pub. L. 89–329, title III, § 317","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIII/s303/f"},"text":"Pub. L. 105–244, title III, § 303(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1641"},"text":"112 Stat. 1641","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/211/s1/a"},"text":"Pub. L. 106–211, § 1(a)","children":[],"tail":", (b)(2), "},{"tag":"date","attrib":{"date":"2000-05-26"},"text":"May 26, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/330"},"text":"114 Stat. 330","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVII/s702/a"},"text":"Pub. L. 107–110, title VII, § 702(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1946"},"text":"115 Stat. 1946","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIII/s304"},"text":"Pub. L. 110–315, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3169"},"text":"122 Stat. 3169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215"},"text":"Pub. L. 114–95, title IX, § 9215","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"oo","children":[],"tail":")(6), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2179"},"text":"129 Stat. 2179","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cd43d21-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cd43d22-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cd43d23-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9215"},"text":"Pub. L. 114–95, § 9215","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"oo","children":[],"tail":")(6)(A), made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7546"},"text":"section 7546 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9215"},"text":"Pub. L. 114–95, § 9215","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"oo","children":[],"tail":")(6)(B), made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7517"},"text":"section 7517 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (c)(2)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" added subpar. (I)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110/s702/a/1"},"text":"Pub. L. 107–110, § 702(a)(1)","children":[],"tail":", substituted “section 7546” for “section 7938”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110/s702/a/2"},"text":"Pub. L. 107–110, § 702(a)(2)","children":[],"tail":", substituted “section 7517” for “section 7912”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/211/s1/a"},"text":"Pub. L. 106–211, § 1(a)","children":[],"tail":", inserted after first sentence “The Secretary shall, to the extent possible, prescribe a simplified and streamlined format for such applications that takes into account the limited number of institutions that are eligible for assistance under this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/211/s1/b/2"},"text":"Pub. L. 106–211, § 1(b)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/211/s1/b/2"},"text":"Pub. L. 106–211, § 1(b)(2)","children":[],"tail":", struck out heading and text of subsec. (e). Text read as follows: “For the purposes of this section, no Alaska Native-serving institution or Native Hawaiian-serving institution which is eligible for and receives funds under this section may concurrently receive other funds under this part or part B of this subchapter.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cd43d24-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cd43d25-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cd43d26-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0cd43d27-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
