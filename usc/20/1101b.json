{"tag":"section","attrib":{"id":"id0d6a62cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1101b"},"text":"§ 1101b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d6a62d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of activities authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants awarded under this subchapter shall be used by Hispanic-serving institutions of higher education to assist the institutions to plan, develop, undertake, and carry out programs to improve and expand the institutions’ capacity to serve Hispanic students and other low-income students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6a62d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under this section shall be used for one or more of the following activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6a62d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Purchase, rental, or lease of scientific or laboratory equipment for educational purposes, including instructional and research purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Construction, maintenance, renovation, and improvement in classrooms, libraries, laboratories, and other instructional facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Support of faculty exchanges, faculty development, curriculum development, academic instruction, and faculty fellowships to assist in attaining advanced degrees in the fellow’s field of instruction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Purchase of library books, periodicals, and other educational materials, including telecommunications program material.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tutoring, counseling, and student service programs designed to improve academic success, including innovative and customized instruction courses (which may include remedial education and English language instruction) designed to help retain students and move the students rapidly into core courses and through program completion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Articulation agreements and student support programs designed to facilitate the transfer from two-year to four-year institutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds management, administrative management, and acquisition of equipment for use in strengthening funds management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Joint use of facilities, such as laboratories and libraries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing or improving a development office to strengthen or improve contributions from alumni and the private sector.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing or improving an endowment fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Creating or improving facilities for Internet or other distance education technologies, including purchase or rental of telecommunications technology equipment or services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing or enhancing a program of teacher education designed to qualify students to teach in public elementary schools and secondary schools.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62de-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing community outreach programs that will encourage elementary school and secondary school students to develop the academic skills and the interest to pursue postsecondary education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62df-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expanding the number of Hispanic and other underrepresented graduate and professional students that can be served by the institution by expanding courses and institutional resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62e0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/b/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing education, counseling services, or financial information designed to improve the financial literacy and economic literacy of students or the students’ families, especially with regard to student indebtedness and student assistance programs under subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/b/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Other activities proposed in the application submitted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1101c"},"text":"section 1101c of this title","children":[],"tail":" that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d6a62e2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/b/16/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute to carrying out the purposes of this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6a62e3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/b/16/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are approved by the Secretary as part of the review and acceptance of such application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6a62e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Endowment fund limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6a62e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Portion of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Hispanic-serving institution may not use more than 20 percent of the grant funds provided under this subchapter for any fiscal year for establishing or improving an endowment fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Hispanic-serving institution that uses any portion of the grant funds provided under this subchapter for any fiscal year for establishing or improving an endowment fund shall provide from non-Federal funds an amount equal to or greater than the portion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a62e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comparability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of part C of subchapter III regarding the establishment or increase of an endowment fund, that the Secretary determines are not inconsistent with this subsection, shall apply to funds used under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6a62e8-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tV/s503"},"text":"Pub. L. 89–329, title V, § 503","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tV/s501"},"text":"Pub. L. 105–244, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1768"},"text":"112 Stat. 1768","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tV/s501"},"text":"Pub. L. 110–315, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3331"},"text":"122 Stat. 3331","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d6a62e9-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d6a62ea-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d6a62eb-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s503"},"text":"section 503 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1102b"},"text":"section 1102b of this title","children":[],"tail":" prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s503"},"text":"section 503 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1091b"},"text":"section 1091b of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/482"},"text":"Pub. L. 94–482","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d6a62ec-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s501/2"},"text":"Pub. L. 110–315, § 501(2)","children":[],"tail":", inserted “, including innovative and customized instruction courses (which may include remedial education and English language instruction) designed to help retain students and move the students rapidly into core courses and through program completion” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6) to (16). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s501/1"},"text":"Pub. L. 110–315, § 501(1)","children":[],"tail":", (3)–(5), added pars. (6) and (15), redesignated former pars. (6), (7), (8), (9), (10), (11), (12), (13), and (14) as pars. (7), (8), (9), (10), (11), (12), (13), (14), and (16), respectively, and in par. (11), substituted “distance education technologies” for “distance learning academic instruction capabilities”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
