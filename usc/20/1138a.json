{"tag":"section","attrib":{"id":"id0d7b2c57-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1138a"},"text":"§ 1138a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Board of the Fund for the Improvement of Postsecondary Education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d7b2c58-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a National Board of the Fund for the Improvement of Postsecondary Education (in this part referred to as the “Board”). The Board shall consist of 15 members appointed by the Secretary for overlapping 3-year terms. A majority of the Board shall constitute a quorum. Any member of the Board who has served for 6 consecutive years shall thereafter be ineligible for appointment to the Board during a 2-year period following the expiration of such sixth year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7b2c59-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate one of the members of the Board as Chairperson of the Board. A majority of the members of the Board shall be public interest representatives, including students, and a minority shall be educational representatives. All members selected shall be individuals able to contribute an important perspective on priorities for improvement in postsecondary education and strategies of educational and institutional change.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7b2c5a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7b2c5b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary on priorities for the improvement of postsecondary education and make such recommendations as the Board may deem appropriate for the improvement of postsecondary education and for the evaluation, dissemination, and adaptation of demonstrated improvements in postsecondary educational practice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7b2c5c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary on the operation of the Fund for the Improvement of Postsecondary Education, including advice on planning documents, guidelines, and procedures for grant competitions prepared by the Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7b2c5d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet at the call of the Chairperson, except that the Board shall meet whenever one-third or more of the members request in writing that a meeting be held.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7b2c5e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information and assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available to the Board such information and assistance as may be necessary to enable the Board to carry out its functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d7b2c5f-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s742"},"text":"Pub. L. 89–329, title VII, § 742","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVII/s701"},"text":"Pub. L. 105–244, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1797"},"text":"112 Stat. 1797","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVII/s707/h/1"},"text":"Pub. L. 110–315, title VII, § 707(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3360"},"text":"122 Stat. 3360","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d7b2c60-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d7b2c61-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"