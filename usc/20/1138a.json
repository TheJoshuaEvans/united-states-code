/110/315/s707/h/1/A"},"text":"Pub. L. 110–315, § 707(h)(1)(A)","children":[],"tail":", struck out par. (1) designation before “The Secretary shall designate” and struck out par. (2). Prior to amendment, text of par. (2) read as follows: “The Secretary shall appoint the Director of the Fund for the Improvement of Postsecondary Education (hereafter in this part referred to as the ‘Director’).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s707/h/1/B"},"text":"Pub. L. 110–315, § 707(h)(1)(B)","children":[],"tail":", struck out “and the Director” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s707/h/1/C"},"text":"Pub. L. 110–315, § 707(h)(1)(C)","children":[],"tail":", substituted “Secretary” for “Director”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
