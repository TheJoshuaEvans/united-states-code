{"tag":"section","attrib":{"id":"id0cf3379a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–34"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070d–34"},"text":"§ 1070d–34.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation among States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cf3379b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–34/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation formula","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the sums appropriated pursuant to the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070d–41"},"text":"section 1070d–41 of this title","children":[],"tail":" for any fiscal year, the Secretary shall allocate to each State that has an agreement under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070d–35"},"text":"section 1070d–35 of this title","children":[],"tail":" an amount equal to $1,500 multiplied by the number of scholarships determined by the Secretary to be available to such State in accordance with subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cf3379c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–34/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of scholarships available","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The number of scholarships to be made available in a State for any fiscal year shall bear the same ratio to the number of scholarships made available to all States as the State’s population ages 5 through 17 bears to the population ages 5 through 17 in all the States, except that not less than 10 scholarships shall be made available to any State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cf3379d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–34/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of census data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this section, the population ages 5 through 17 in a State and in all the States shall be determined by the most recently available data, satisfactory to the Secretary, from the Bureau of the Census.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cf3379e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–34/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidation by Insular Areas prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1469a"},"text":"section 1469a of title 48","children":[],"tail":", funds allocated under this part to an Insular Area described in that section shall be deemed to be direct payments to classes of individuals, and the Insular Area may not consolidate such funds with other funds received by the Insular Area from any department or agency of the United States Government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cf3379f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–34/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FAS eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cf337a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–34/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal years 2000 through 2004","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this subpart, in the case of students from the Freely Associated States who may be selected to receive a scholarship under this subpart for the first time for any of the fiscal years 2000 through 2004—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cf337a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–34/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there shall be 10 scholarships in the aggregate awarded to such students for each of the fiscal years 2000 through 2004; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cf337a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–34/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Pacific Regional Educational Laboratory shall administer the program under this subpart in the case of scholarships for students in the Freely Associated States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf337a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–34/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A student from the Freely Associated States shall not be eligible to receive a scholarship under this subpart after ","children":[{"tag":"date","attrib":{"date":"2004-09-30"},"text":"September 30, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cf337a4-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s419D"},"text":"Pub. L. 89–329, title IV, § 419D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s401/a"},"text":"Pub. L. 99–498, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1344"},"text":"100 Stat. 1344","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s406/c"},"text":"Pub. L. 102–325, title IV, § 406(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/509"},"text":"106 Stat. 509","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/b/29"},"text":"Pub. L. 103–208, § 2(b)(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2460"},"text":"107 Stat. 2460","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s409/a"},"text":"Pub. L. 105–244, title IV, § 409(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1668"},"text":"112 Stat. 1668","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tIV/s401/a/8"},"text":"Pub. L. 111–39, title IV, § 401(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1939"},"text":"1