children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208"},"text":"Pub. L. 103–208","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “From the sums appropriated pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070d–41"},"text":"section 1070d–41 of this title","children":[],"tail":" for any fiscal year, the Secretary shall allocate to each State having an agreement under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070d–35"},"text":"section 1070d–35 of this title","children":[],"tail":"—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) $1,500 multiplied by the number of individuals in the State eligible for scholarships pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070d–37/b"},"text":"section 1070d–37(b) of this title","children":[],"tail":", plus"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) $10,000, plus 5 percent of the amount to which a State is eligible under paragraph (1) of this section.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cf337a9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cf337aa-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"