{"tag":"section","attrib":{"id":"id0ded9d1f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4426"},"text":null,"children":[{"tag":"num","attrib":{"value":"4426"},"text":"§ 4426.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ded9d20-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4426/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall prepare a master plan on the short- and long-term facilities needs of the Institute. The master plan shall include evaluation of all facets of existing Institute programs, including support activities and programs and facilities. The master plan shall include impact projections for the Institute’s move to a new campus site. This master plan shall evaluate development and construction requirements (based on a growth plan approved by the Board), including (but not limited to) items such as infrastructure and site analysis, development of a phased plan with architectural and engineering studies, cost projections, landscaping, and related studies which cover all facets of the Institute’s programs and planned functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ded9d21-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4426/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for transmittal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan required by this subsection shall be transmitted to Congress no later than 18 months after ","children":[{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":". Such plan shall include a prioritization of needs, as determined by the Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ded9d22-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/498/tXV/s1519"},"text":"Pub. L. 99–498, title XV, § 1519","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tXIII/s1331/k"},"text":"Pub. L. 102–325, title XIII, § 1331(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/808"},"text":"106 Stat. 808","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ded9d23-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0ded9d24-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0ded9d25-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/s2"},"text":"section 2 of Pub. L. 102–325","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
