{"tag":"section","attrib":{"id":"id0defe75c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4703"},"text":null,"children":[{"tag":"num","attrib":{"value":"4703"},"text":"§ 4703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Barry Goldwater Scholarship and Excellence in Education Foundation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0defe75d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established, as an independent establishment of the executive branch of the United States Government, the Barry Goldwater Scholarship and Excellence in Education Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0defe75e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Trustees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Foundation shall be subject to the supervision and direction of the Board of Trustees. The Board shall be composed of 13 members, as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0defe75f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4703/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members from the Senate, one appointed by the majority leader and one appointed by the minority leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe760-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4703/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members from the House of Representatives, one appointed by the majority leader and one appointed by the minority leader of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe761-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4703/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Eight members, not more than four of whom shall be of the same political party, to be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe762-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4703/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Education, or his designee, who shall serve ex officio as a member of the Board but shall not be eligible to serve as Chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0defe763-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of office","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0defe764-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4703/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term of office of each member of the Board shall be six years, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0defe765-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4703/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the members first taking office shall serve as designated by the President, four for terms of two years, five for terms of four years, and four for terms of six years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0defe766-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4703/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member appointed to fill a vacancy shall serve for the remainder of the term for which his predecessor was appointed and shall be appointed in the same manner as the original appointment for that vacancy was made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0defe767-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4703/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding the term limitation provided for under this paragraph, a member appointed under subsection (b) may continue to serve under such appointment until the successor to the member is appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe768-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4703/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Member of Congress appointed to the Board under clause (1) or (2) of subsection (b) may not serve as a member of the Board for more than a total of six years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0defe769-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4703/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel and subsistence pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Board shall serve without pay, but shall be entitled to reimbursement for travel, subsistence, and other necessary expenses incurred in the performance of their duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0defe76a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tXIV/s1404"},"text":"Pub. L. 99–661, div. A, title XIV, § 1404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4008"},"text":"100 Stat. 4008","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s3/10"},"text":"Pub. L. 100–26, § 3(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/274"},"text":"101 Stat. 274","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tX/s1089/1"},"text":"Pub. L. 102–190, div. A, title X, § 1089(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1485"},"text":"105 Stat. 1485","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tXI/s1179/a"},"text":"Pub. L. 103–160, div. A, title XI, § 1179(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1770"},"text":"107 Stat. 1770","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0defe76b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0defe76c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0defe76d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (c)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" struck out before period at end “, at least one of whom shall be a representative of the aerospace industry and at least one of whom shall be a representative of a private foundation concerned with aerospace education”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/26"},"text":"Pub. L. 100–26","children":[],"tail":" substituted “clause (1) or (2)” for “clause (2) or (3)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0defe76e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0defe76f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/26"},"text":"Pub. L. 100–26","children":[],"tail":" applicable as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" when enacted on "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s12/a"},"text":"section 12(a) of Pub. L. 100–26","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s776"},"text":"section 776 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
