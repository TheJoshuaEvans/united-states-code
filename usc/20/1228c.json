{"tag":"section","attrib":{"id":"id0d90899c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1228c"},"text":"§ 1228c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d90899d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each educational organization, prior to enrolling a minor and prior to accepting funds for the cost of a minor’s participation in an educational program operated by such organization, shall disclose the following information in written form to the minor or the minor’s parent.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d90899e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of solicitation and selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The method of solicitation and selection of participants in the educational program, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d90899f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the origin of any mailing list used for such solicitation and selection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9089a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recruitment through a local school official, teacher, or school personnel, including any compensation or other benefit offered to such official, teacher, or personnel for the recommendation of a minor for participation in the educational program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9089a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any open enrollment activity, including the method of outreach; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9089a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any cooperation with, or sponsorship by, a membership organization, including a description of the cooperation or sponsorship and the name of each such organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9089a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost and fees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Information regarding the cost of the educational program and information regarding the distribution of any enrollment fee, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9089a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the amount paid for, and the percentage of the total educational program cost of, each feature of the educational program, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d9089a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d9089a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lodging;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d9089a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d9089a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" program staffing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d9089a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/a/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" textbooks, syllabi, or other scholastic educational program materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d9089aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/a/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" speaker fees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d9089ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/a/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" administrative expenses, including expenses related to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d9089ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/a/2/A/vii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preparation of nonscholastic educational program materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d9089ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/a/2/A/vii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of financial assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d9089ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/a/2/A/vii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mailing list rental or other recruitment activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d9089af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/a/2/A/vii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative salaries and consulting fees;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9089b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of the organization or business providing each of the features described in clauses (i) through (vii) of subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9089b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of any relationship of any board member, officer, or employee of the educational organization to any organization or business described in subparagraph (B), including the salary or other compensation paid by such organization or business to such board member, officer, or employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9089b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscriminatory enrollment and service policy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9089b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each educational organization shall include a verifiable statement in all enrollment or recruitment material that the educational organization does not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9089b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail or refuse to hire, or discharge, any individual, or otherwise discriminate against any individual with respect to compensation, terms, conditions, or privileges of employment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9089b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exclude any student from participation in an educational program, discriminate against any student in providing the benefits associated with such program (including any scholarship or financial assistance, and use of any facility), or subject the student to discrimination under such program, on the basis of race, disability, or residence in a low-income area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9089b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subsection shall be construed to entitle a student to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9089b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participation in an educational program or any benefit associated with such program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9089b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a waiver of any fee charged for such participation or benefit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9089b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9089ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9089bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" widely disseminate information about the requirements of this section to State and local school officials and parents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9089bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require educational organizations to submit appropriate information or assurances regarding such organizations’ compliance with this section; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9089bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" take whatever other steps the Secretary determines are appropriate to enforce this section, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9089be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promulgating regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9089bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a complaint process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9089c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referring complaints to the relevant Federal, State, or local authorities for appropriate action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9089c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alerting educational agencies, schools, and parents to the practices of educational organizations that violate the provisions of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9089c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imposing civil fines (not to exceed $1,000 per violation) on educational organizations that knowingly violate this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9089c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9089c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “disability” has the same meaning given to such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12102/2"},"text":"section 12102(2) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9089c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational organization","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9089c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subparagraphs (B) and (C), the term “educational organization” means any organization or entity that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d9089c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides an educational program for a fee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d9089c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruits students through means such as commercial media, direct mailings, school recruitment programs, school administrators, teachers or staff, or current or former participants in an educational program offered by such organization or entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9089c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The definition in subparagraph (A) shall not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d9089ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local educational agency, State educational agency, a State department of education, or an elementary or secondary school (as defined by the terms “elementary school” and “secondary school” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d9089cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d9089cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local organization sponsored by an elementary or secondary school, a recreational organization, an entertainment organization, a local sports activity group, or a social club.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9089cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of subsection (a) only, such term does not include an organization or entity that provides an educational program if such organization or entity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d9089ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruits, for participation in such program, solely through a local school official; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d9089cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not offer a local school official, teacher, or other school personnel compensation (other than compensation for actual expenses incurred in performing chaperon activities or for participating in separate, professionally-staffed teacher training and technical assistance seminars and workshops related to such program) or any other benefit for such recruitment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9089d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9089d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subparagraph (B), the term “educational program” means a special honors program, seminar, citizenship experience, government study program, educational vacation, student exchange program, or other educational experience or honor—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d9089d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is generally directed toward minors or secondary school students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d9089d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which a tuition or enrollment fee is charged;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d9089d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is offered away from a student’s regular place of school attendance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d9089d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that includes not less than one supervised night away from home; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d9089d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is intended to enhance a student’s regular course of study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9089d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such term does not include a recreational program,","children":[{"tag":"ref","attrib":{"idref":"fn002119"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002119"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" or a social or religious activity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9089d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local school official","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “local school official” means the highest administrative official serving a school district, or such individual’s designee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9089d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “minor” means an individual who has not attained the age of 18 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9089da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “membership organization” includes any organization that maintains a membership list or collects dues or membership fees from its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9089db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recreational organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “recreational organization” includes any organization or entity that has as its primary function pleasure, amusement, or sports activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9089dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228c/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recreational program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “recreational program” includes any activity or service that is intended as an entertainment pastime.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9089dd-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/tIV/s429"},"text":"Pub. L. 90–247, title IV, § 429","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tII/s238"},"text":"Pub. L. 103–382, title II, § 238","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3918"},"text":"108 Stat. 3918","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tI/s102/a/6/C"},"text":"Pub. L. 105–244, title I, § 102(a)(6)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1618"},"text":"112 Stat. 1618","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/mm/3"},"text":"Pub. L. 114–95, title IX, § 9215(mm)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2176"},"text":"129 Stat. 2176","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9089de-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9089df-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d9089e0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/s429"},"text":"section 429 of Pub. L. 90–247","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1231f"},"text":"section 1231f of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d9089e1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (d)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" substituted “an elementary or secondary school (as defined by the terms ‘elementary school’ and ‘secondary school’ in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of this title","children":[],"tail":")” for “an elementary or secondary school as defined by the Elementary and Secondary Education Act of 1965”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (d)(2)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" substituted “section 1001” for “section 1141(a)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d9089e2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d9089e3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d9089e4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
