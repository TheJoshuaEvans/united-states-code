{"tag":"section","attrib":{"id":"id0e4cfb8b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7844"},"text":null,"children":[{"tag":"num","attrib":{"value":"7844"},"text":"§ 7844.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General applicability of State educational agency assurances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e4cfb8c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7844/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assurances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State educational agency, in consultation with the Governor of the State, that submits a consolidated State plan or consolidated State application under this chapter, whether separately or under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7842"},"text":"section 7842 of this title","children":[],"tail":", shall have on file with the Secretary a single set of assurances, applicable to each program for which the plan or application is submitted, that provides that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e4cfb8d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7844/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each such program will be administered in accordance with all applicable statutes, regulations, program plans, and applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4cfb8e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7844/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4cfb8f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7844/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the control of funds provided under each such program and title to property acquired with program funds will be in a public agency, a ","children":[{"tag":"ref","attrib":{"idref":"fn002231"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002231"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “an”."}],"tail":" eligible private agency, institution, or organization, or an Indian tribe, if the law authorizing the program provides for assistance to those entities; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4cfb90-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7844/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public agency, eligible private agency, institution, or organization, or Indian tribe will administer those funds and property to the extent required by the authorizing law;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4cfb91-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7844/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the State will adopt and use proper methods of administering each such program, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4cfb92-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7844/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enforcement of any obligations imposed by law on agencies, institutions, organizations, and other recipients responsible for carrying out each program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4cfb93-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7844/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the correction of deficiencies in program operations that are identified through audits, monitoring, or evaluation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4cfb94-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7844/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adoption of written procedures for the receipt and resolution of complaints alleging violations of law in the administration of the programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4cfb95-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7844/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State will cooperate in carrying out any evaluation of each such program conducted by or for the Secretary or other Federal officials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4cfb96-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7844/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State will use such fiscal control and fund accounting procedures as will ensure proper disbursement of, and accounting for, Federal funds paid to the State under each such program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4cfb97-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7844/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the State will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4cfb98-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7844/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make reports to the Secretary as may be necessary to enable the Secretary to perform the Secretary’s duties under each such program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4cfb99-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7844/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain such records, provide such information to the Secretary, and afford such access to the records as the Secretary may find necessary to carry out the Secretary’s duties; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4cfb9a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7844/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the plan or application was submitted to the Secretary, the State afforded a reasonable opportunity for public comment on the plan or application and considered such comment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4cfb9b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7844/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GEPA provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 441 of the General Education Provisions Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232d"},"text":"20 U.S.C. 1232d","children":[],"tail":"] shall not apply to programs under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e4cfb9c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8304"},"text":"Pub. L. 89–10, title VIII, § 8304","children":[],"tail":", formerly title IX, § 9304, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIX/s901"},"text":"Pub. L. 107–110, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1969"},"text":"115 Stat. 1969","children":[],"tail":"; renumbered title VIII, § 8304, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII"},"text":"Pub. L. 114–95, title VIII","children":[],"tail":", §§ 8001(a)(3), (b)(3), 8010, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2088"},"text":"129 Stat. 2088","children":[],"tail":", 2089, 2102.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e4cfb9d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e4cfb9e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e4cfb9f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8001/b/3"},"text":"Pub. L. 114–95, § 8001(b)(3)","children":[],"tail":", made technical amendment to reference in original act which appears in introductory provisions as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7842"},"text":"section 7842 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8010"},"text":"Pub. L. 114–95, § 8010","children":[],"tail":", substituted “eligible” for “nonprofit” in subpars. (A) and (B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e4cfba0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e4cfba1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
