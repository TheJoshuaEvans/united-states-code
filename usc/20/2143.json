{"tag":"section","attrib":{"id":"id0db91f32-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2143"},"text":null,"children":[{"tag":"num","attrib":{"value":"2143"},"text":"§ 2143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0db91f33-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2143/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian of Congress may solicit and accept donations of funds and in-kind contributions to carry out the oral history program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2142"},"text":"section 2142 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db91f34-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2143/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of separate gift account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury (among the accounts of the Library of Congress) a gift account for the oral history program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2142"},"text":"section 2142 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db91f35-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2143/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dedication of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db91f36-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2143/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any funds donated to the Librarian of Congress to carry out the oral history program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2142"},"text":"section 2142 of this title","children":[],"tail":" shall be deposited entirely into the gift account established under subsection (b);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db91f37-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2143/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funds contained in such account shall be used solely to carry out the oral history program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2142"},"text":"section 2142 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db91f38-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2143/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Librarian of Congress may not deposit into such account any funds donated to the Librarian which are not donated for the exclusive purpose of carrying out the oral history program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2142"},"text":"section 2142 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0db91f39-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/380/s4"},"text":"Pub. L. 106–380, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-27"},"text":"Oct. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1448"},"text":"114 Stat. 1448","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
