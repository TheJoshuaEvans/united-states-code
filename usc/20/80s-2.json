{"tag":"section","attrib":{"id":"id0c8a3c86-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80s–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"80s–2"},"text":"§ 80s–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private support for civil rights history project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c8a3c87-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80s–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouraging solicitation and acceptance of donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian of Congress and the Secretary are encouraged to solicit and accept donations of funds and in-kind contributions to support activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s80s–1"},"text":"section 80s–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c8a3c88-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80s–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dedication of funds provided to Library of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c8a3c89-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80s–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any funds donated to the Librarian of Congress to support the activities of the Librarian under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s80s–1"},"text":"section 80s–1 of this title","children":[],"tail":" shall be deposited entirely into an account established for such purpose;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8a3c8a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80s–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funds contained in such account shall be used solely to support such activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8a3c8b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80s–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Librarian of Congress may not deposit into such account any funds donated to the Librarian which are not donated for the exclusive purpose of supporting such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c8a3c8c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/19/s4"},"text":"Pub. L. 111–19, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-12"},"text":"May 12, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1614"},"text":"123 Stat. 1614","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
