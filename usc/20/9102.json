{"tag":"section","attrib":{"id":"id0e58e150-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9102"},"text":null,"children":[{"tag":"num","attrib":{"value":"9102"},"text":"§ 9102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institute of Museum and Library Services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e58e151-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established, within the National Foundation on the Arts and the Humanities, an Institute of Museum and Library Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e58e152-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute shall consist of an Office of Museum Services and an Office of Library Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e58e153-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Museum and Library Services Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be a National Museum and Library Services Board within the Institute, as provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9105a"},"text":"section 9105a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e58e154-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/462/tII/s203"},"text":"Pub. L. 94–462, title II, § 203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/e/tVII/s702"},"text":"Pub. L. 104–208, div. A, title I, § 101(e) [title VII, § 702]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-233"},"text":"110 Stat. 3009–233","children":[],"tail":", 3009–294; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/81/tI/s102"},"text":"Pub. L. 108–81, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-25"},"text":"Sept. 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/992"},"text":"117 Stat. 992","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e58e155-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e58e156-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e58e157-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/462/s203"},"text":"section 203 of Pub. L. 94–462","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s962"},"text":"section 962 of this title","children":[],"tail":" prior to the general amendment of title II of "},{"tag":"ref","attrib":{"href":"/us/pl/94/462"},"text":"Pub. L. 94–462","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e58e158-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/81/s102/1"},"text":"Pub. L. 108–81, § 102(1)","children":[],"tail":", struck out at end “There shall be a National Museum Services Board in the Office of Museum Services.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/81/s102/2"},"text":"Pub. L. 108–81, § 102(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e58e159-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id0e58e15a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/340/tIV/s401/b"},"text":"Pub. L. 111–340, title IV, § 401(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3604"},"text":"124 Stat. 3604","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/340/tIV/s401/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Functions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The functions that the National Commission on Libraries and Information Science exercised before the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":"] shall be transferred to the Institute of Museum and Library Services established under section 203 of the Museum and Library Services Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9102"},"text":"20 U.S.C. 9102","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer and Allocation of Appropriations and Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The personnel and the assets, contracts, property, records, and unexpended balance of appropriations, authorizations, allocations, and other funds employed, held, used, arising from, available to, or to be made available for the functions and activities vested by law in the National Commission on Libraries and Information Science shall be transferred to the Institute of Museum and Library Services upon the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/e/tVII/s704"},"text":"Pub. L. 104–208, div. A, title I, § 101(e) [title VII, § 704]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-233"},"text":"110 Stat. 3009–233","children":[],"tail":", 3009–307, provided for transfer of functions from the Institute of Museum Services and the Library Program Office to Director of Institute of Museum and Library Services, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/108/81/tV/s505/b"},"text":"Pub. L. 108–81, title V, § 505(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-25"},"text":"Sept. 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1004"},"text":"117 Stat. 1004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0e58e15b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to National Commission on Libraries and Information Science Construed To Be References to Institute of Museum and Library Services","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/340/tIV/s401/d"},"text":"Pub. L. 111–340, title IV, § 401(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3605"},"text":"124 Stat. 3605","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/340/tIV/s401/d"},"text":"“Any reference to the National Commission on Libraries and Information Science in any Federal law, Executive Order, rule, delegation of authority, or document shall be construed to refer to the Institute of Museum and Library Services when the reference regards functions transferred under subsection (b) [set out as a note above].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0e58e15c-3a70-11f1-a648-bee82ed8a795"},"text":null,"chil