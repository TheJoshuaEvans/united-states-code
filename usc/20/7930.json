{"tag":"section","attrib":{"id":"id0e5426e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7930"},"text":null,"children":[{"tag":"num","attrib":{"value":"7930"},"text":"§ 7930.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e5426e2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7930/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e5426e3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7930/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This chapter prohibits the Federal Government from mandating, directing, or controlling a State, local educational agency, or school’s curriculum, program of instruction, or allocation of State and local resources, and from mandating a State or any subdivision thereof to spend any funds or incur any costs not paid for under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5426e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7930/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This chapter prohibits the Federal Government from funding the development, pilot testing, field testing, implementation, administration, or distribution of any federally sponsored national test in reading, mathematics, or any other subject, unless specifically and explicitly authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e5426e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7930/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that States and local educational agencies retain the rights and responsibilities of determining educational curriculum, programs of instruction, and assessments for elementary and secondary education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e5426e6-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8549A"},"text":"Pub. L. 89–10, title VIII, § 8549A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII/s8041"},"text":"Pub. L. 114–95, title VIII, § 8041","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2121"},"text":"129 Stat. 2121","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e5426e7-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e5426e8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e5426e9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
