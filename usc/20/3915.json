{"tag":"section","attrib":{"id":"id0de18ed8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3915"},"text":null,"children":[{"tag":"num","attrib":{"value":"3915"},"text":"§ 3915.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Graduate fellowships","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Foundation is authorized, in accordance with the provisions of this subchapter, to establish and carry out a program of graduate fellowships for the purpose of encouraging and assisting promising students to continue their education and research in mathematics, science, and engineering.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0de18ed9-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tI/s105"},"text":"Pub. L. 98–377, title I, § 105","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/159/tII/s201"},"text":"Pub. L. 99–159, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-22"},"text":"Nov. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/896"},"text":"99 Stat. 896","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de18eda-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de18edb-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0de18edc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3915, ","children":[{"tag":"ref","attrib":{"href":"/us/p