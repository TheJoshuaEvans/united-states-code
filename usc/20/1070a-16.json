{"tag":"section","attrib":{"id":"id0ce99a6c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070a–16"},"text":"§ 1070a–16.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational opportunity centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ce99a6d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authority; services provided","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a program to be known as educational opportunity centers which shall be designed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce99a6e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide information with respect to financial and academic assistance available for individuals desiring to pursue a program of postsecondary education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99a6f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide assistance to such persons in applying for admission to institutions at which a program of postsecondary education is offered, including preparing necessary applications for use by admissions and financial aid officers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99a70-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to improve the financial literacy and economic literacy of students, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce99a71-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic personal income, household money management, and financial planning skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce99a72-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic economic decisionmaking skills.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce99a73-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An educational opportunity center assisted under this section may provide services such as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce99a74-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public information campaigns designed to inform the community regarding opportunities for postsecondary education and training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99a75-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic advice and assistance in course selection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99a76-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in completing college admission and financial aid applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99a77-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in preparing for college entrance examinations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99a78-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education or counseling services designed to improve the financial literacy and economic literacy of students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99a79-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidance on secondary school reentry or entry to a general educational development (GED) program or other alternative education programs for secondary school dropouts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99a7a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individualized personal, career, and academic counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99a7b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tutorial services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99a7c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" career workshops and counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99a7d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mentoring programs involving elementary or secondary school teachers, faculty members at institutions of higher education, students, or any combination of such persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99a7e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs and activities as described in paragraphs (1) through (10) that are specially designed for students who are limited English proficient, students from groups that are traditionally underrepresented in postsecondary education, students with disabilities, students who are homeless children and youths (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11434a"},"text":"section 11434a of title 42","children":[],"tail":"), students who are in foster care or are aging out of the foster care system, or other disconnected students."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce99a7f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for approval of applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In approving applications for educational opportunity centers under this section for any fiscal year the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce99a80-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require an assurance that not less than two-thirds of the persons participating in the project proposed to be carried out under any application be low-income individuals who are first generation college students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99a81-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that such participants be persons who are at least nineteen years of age, unless the imposition of such limitation with respect to any person would defeat the purposes of this section or the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–12"},"text":"section 1070a–12 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99a82-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–16/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require an assurance that individuals participating in the project proposed in the application do not have access to services from another project funded under this section or under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–12"},"text":"section 1070a–12 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ce99a83-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s402F"},"text":"Pub. L. 89–329, title IV, § 402F","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s402/a/4"},"text":"Pub. L. 102–325, title IV, § 402(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/490"},"text":"106 Stat. 490","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s403/f"},"text":"Pub. L. 110–315, title IV, § 403(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3203"},"text":"122 Stat. 3203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ce99a84-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ce99a85-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0ce99a86-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/f/1"},"text":"Pub. L. 110–315, § 403(f)(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/f/2/A"},"text":"Pub. L. 110–315, § 403(f)(2)(A)","children":[],"tail":", (B), added par. (5) and redesignated former par. (5) as (6). Former par. (6) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/f/2/C"},"text":"Pub. L. 110–315, § 403(f)(2)(C)","children":[],"tail":", added par. (7) and struck out former par. (7) which read as follows: “personal counseling;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/f/2/A"},"text":"Pub. L. 110–315, § 403(f)(2)(A)","children":[],"tail":", redesignated former par. (6) as (7). Former par. (7) redesignated (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/f/2/A"},"text":"Pub. L. 110–315, § 403(f)(2)(A)","children":[],"tail":", redesignated pars. (7) to (9) as (8) to (10), respectively. Former par. (10) redesignated (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/f/2/D"},"text":"Pub. L. 110–315, § 403(f)(2)(D)","children":[],"tail":", added par. (11) and struck out former par. (11) which read as follows: “programs and activities as described in paragraphs (1) through (9) which are specially designed for students of limited English proficiency.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/f/2/A"},"text":"Pub. L. 110–315, § 403(f)(2)(A)","children":[],"tail":", redesignated par. (10) as (11)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
