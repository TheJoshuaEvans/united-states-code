{"tag":"section","attrib":{"id":"id0e3c31dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514"},"text":null,"children":[{"tag":"num","attrib":{"value":"7514"},"text":"§ 7514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native Hawaiian Education Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e3c31de-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to better effectuate the purposes of this part through the coordination of educational and related services and programs available to Native Hawaiians, including those programs that receive funding under this part, the Secretary shall award a grant to the education council described under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e3c31df-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education Council","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e3c31e0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive the grant under subsection (a), the council shall be an education council (referred to in this section as the “Education Council”) that meets the requirements of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c31e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Education Council shall consist of 15 members, of whom—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e3c31e2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be the President of the University of Hawaii (or a designee);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c31e3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be the Governor of the State of Hawaii (or a designee);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c31e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be the Superintendent of the State of Hawaii Department of Education (or a designee);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c31e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be the chairperson of the Office of Hawaiian Affairs (or a designee);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c31e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be the executive director of Hawaii’s Charter School Network (or a designee);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c31e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be the chief executive officer of the Kamehameha Schools (or a designee);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c31e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be the Chief Executive Officer of the Queen Liliuokalani Trust (or a designee);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c31e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed by the Secretary, in a timely manner, and chosen from a list of 5 individuals who represent one or more private grant-making entities that is submitted to the Secretary by the Education Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c31ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be the Mayor of the County of Hawaii (or a designee);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c31eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be the Mayor of Maui County (or a designee from the Island of Maui);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c31ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be the Mayor of the County of Kauai (or a designee);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c31ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed by the Secretary, in a timely manner, and chosen from a list of 5 individuals who are from the Island of Molokai or the Island of Lanai that is submitted to the Secretary by the Mayor of Maui County;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c31ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be the Mayor of the City and County of Honolulu (or a designee);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c31ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/2/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be the chairperson of the Hawaiian Homes Commission (or a designee); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c31f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/2/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be the chairperson of the Hawaii Workforce Development Council (or a designee representing the private sector).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c31f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any designee serving on the Education Council shall demonstrate, as determined by the individual who appointed such designee with input from the Native Hawaiian community, not less than 5 years of experience as a consumer or provider of Native Hawaiian educational or cultural activities, with traditional cultural experience given due consideration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c31f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member (including a designee), while serving on the Education Council, shall not be a direct recipient or administrator of grant funds that are awarded under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c31f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member who is a designee shall serve for a term of not more than 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c31f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair; Vice Chair","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e3c31f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Education Council shall select a Chairperson and a Vice Chairperson from among the members of the Education Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c31f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term limits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairperson and Vice Chairperson shall each serve for a 2-year term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c31f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions relating to Education Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Education Council shall meet at the call of the Chairperson of the Council, or upon request by a majority of the members of the Education Council, but in any event not less often than every 120 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c31f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the funds made available through the grant may be used to provide compensation to any member of the Education Council or member of a working group established by the Education Council, for functions described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e3c31f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds for coordination activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Education Council shall use funds made available through a grant under subsection (a) to carry out each of the following activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e3c31fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing advice about the coordination of, and serving as a clearinghouse for, the educational and related services and programs available to Native Hawaiians, including the programs assisted under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c31fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assessing the extent to which such services and programs meet the needs of Native Hawaiians, and collecting data on the status of Native Hawaiian education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c31fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing direction and guidance, through the issuance of reports and recommendations, to appropriate Federal, State, and local agencies in order to focus and improve the use of resources, including resources made available under this part, relating to Native Hawaiian education, and serving, where appropriate, in an advisory capacity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c31fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Awarding grants, if such grants enable the Education Council to carry out the activities described in paragraphs (1) through (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c31fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hiring an executive director, who shall assist in executing the duties and powers of the Education Council, as described in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e3c31ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds for technical assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Education Council shall use funds made available through a grant under subsection (a) to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e3c3200-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to Native Hawaiian organizations that are grantees or potential grantees under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c3201-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" obtain from such grantees information and data regarding grants awarded under this part, including information and data about—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e3c3202-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of such grantees in meeting the educational priorities established by the Education Council, as described in paragraph (6)(D), using metrics related to these priorities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c3203-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of such grantees in carrying out any of the activities described in paragraph (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7515/a"},"text":"section 7515(a) of this title","children":[],"tail":" that are related to the specific goals and purposes of each grantee’s grant project, using metrics related to these goals and purposes;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c3204-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess and define the educational needs of Native Hawaiians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c3205-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the programs and services available to address the educational needs of Native Hawaiians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c3206-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess and evaluate the individual and aggregate impact achieved by grantees under this part in improving Native Hawaiian educational performance and meeting the goals of this part, using metrics related to these goals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c3207-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prepare and submit to the Secretary, at the end of each calendar year, an annual report that contains—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e3c3208-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the activities of the Education Council during the calendar year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c3209-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of significant barriers to achieving the goals of this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c320a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/d/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of each community consultation session described in subsection (e); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c320b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/d/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommendations to establish priorities for funding under this part, based on an assessment of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e3c320c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/d/6/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the educational needs of Native Hawaiians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3c320d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/d/6/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs and services available to address such needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3c320e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/d/6/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of programs in improving the educational performance of Native Hawaiian students to help such students meet challenging State academic standards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/1"},"text":"section 6311(b)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3c320f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/d/6/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" priorities for funding in specific geographic communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e3c3210-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds for community consultations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Education Council shall use funds made available through the grant under subsection (a) to hold not less than 1 community consultation each year on each of the islands of Hawaii, Maui, Molokai, Lanai, Oahu, and Kauai, at which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e3c3211-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not fewer than 3 members of the Education Council shall be in attendance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c3212-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Education Council shall gather community input regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e3c3213-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" current grantees under this part, as of the date of the consultation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c3214-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" priorities and needs of Native Hawaiians; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c3215-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Native Hawaiian education issues; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c3216-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Education Council shall report to the community on the outcomes of the activities supported by grants awarded under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e3c3217-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7514/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year, the Secretary shall use the amount described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7515/c/2"},"text":"section 7515(c)(2) of this title","children":[],"tail":", to make a payment under the grant. Funds made available through the grant shall remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e3c3218-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVI/s6204"},"text":"Pub. L. 89–10, title VI, § 6204","children":[],"tail":", formerly title VII, § 7204, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVII/s701"},"text":"Pub. L. 107–110, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1937"},"text":"115 Stat. 1937","children":[],"tail":"; renumbered title VI, § 6204, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVI"},"text":"Pub. L. 114–95, title VI","children":[],"tail":", §§ 6001(a), (b)(1), 6003(b), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2046"},"text":"129 Stat. 2046","children":[],"tail":", 2063.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e3c3219-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","i