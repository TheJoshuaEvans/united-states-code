{"tag":"section","attrib":{"id":"id0db46479-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1710"},"text":null,"children":[{"tag":"num","attrib":{"value":"1710"},"text":"§ 1710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil actions by Attorney General; notice of violations; certification respecting undertaking appropriate remedial action","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall not institute a civil action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1706"},"text":"section 1706 of this title","children":[],"tail":" before he—"}],"tail":null},{"tag":"subsection","attrib":{"id":"id0db4647a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1710/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gives to the appropriate educational agency notice of the condition or conditions which, in his judgment, constitute a violation of part 2 of this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db4647b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1710/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certifies to the appropriate district court of the United States that he is satisfied that such educational agency has not, within a reasonable time after such notice, undertaken appropriate remedial action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0db4647c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/380/tII/s211"},"text":"Pub. L. 93–380, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/516"},"text":"88 Stat. 516","