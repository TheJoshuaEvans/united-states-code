{"tag":"section","attrib":{"id":"id0e4cfb76-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7842"},"text":null,"children":[{"tag":"num","attrib":{"value":"7842"},"text":"§ 7842.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Optional consolidated State plans or applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e4cfb77-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7842/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e4cfb78-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7842/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Simplification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to simplify application requirements and reduce the burden for State educational agencies under this chapter, the Secretary, in accordance with subsection (b), shall establish procedures and criteria under which, after consultation with the Governor, a State educational agency may submit a consolidated State plan or a consolidated State application meeting the requirements of this section for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4cfb79-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7842/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of the covered programs in which the State participates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4cfb7a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7842/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other programs as the Secretary may designate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4cfb7b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7842/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidated applications and plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After consultation with the Governor, a State educational agency that submits a consolidated State plan or a consolidated State application under this section shall not be required to submit separate State plans or applications under any of the programs to which the consolidated State plan or consolidated State application under this section applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4cfb7c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7842/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e4cfb7d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7842/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing criteria and procedures under this section, the Secretary shall collaborate with State educational agencies and, as appropriate, with other State agencies, local educational agencies, public and private agencies, organizations, and institutions, private schools, and representatives of parents, students, and teachers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4cfb7e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7842/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Through the collaborative process described in paragraph (1), the Secretary shall establish, for each program under this chapter to which this section applies, the descriptions, information, assurances, and other material required to be included in a consolidated State plan or consolidated State application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4cfb7f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7842/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Necessary materials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require only descriptions, information, assurances (including assurances of compliance with applicable provisions regarding participation by private school children and teachers), and other materials that are absolutely necessary for the consideration of the consolidated State plan or consolidated State application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e4cfb80-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8302"},"text":"Pub. L. 89–10, title VIII, § 8302","children":[],"tail":", formerly title IX, § 9302, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIX/s901"},"text":"Pub. L. 107–110, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1968"},"text":"115 Stat. 1968","children":[],"tail":"; renumbered title VIII, § 8302, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII"},"text":"Pub. L. 114–95, title VIII","children":[],"tail":", §§ 8001(a)(3), 8009, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2088"},"text":"129 Stat. 2088","children":[],"tail":", 2089, 2102.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e4cfb81-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e4cfb82-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e4cfb83-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8009"},"text":"Pub. L. 114–95, § 8009","children":[],"tail":", struck out “nonprofit” after “public and private”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e4cfb84-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e4cfb85-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
