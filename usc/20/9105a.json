{"tag":"section","attrib":{"id":"id0e58e1a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a"},"text":null,"children":[{"tag":"num","attrib":{"value":"9105a"},"text":"§ 9105a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Museum and Library Services Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e58e1a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Institute a board to be known as the “National Museum and Library Services Board”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e58e1a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e58e1a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number and appointment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Museum and Library Services Board shall be composed of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e58e1a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e58e1a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Deputy Director for the Office of Library Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e58e1a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Deputy Director for the Office of Museum Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e58e1aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ten members appointed by the President, from among individuals who are citizens of the United States and who are specially qualified by virtue of their education, training, or experience in the area of library services, or their commitment to libraries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e58e1ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ten members appointed by the President, from among individuals who are citizens of the United States and who are specially qualified by virtue of their education, training, or experience in the area of museum services, or their commitment to museums.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e58e1ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special qualifications","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e58e1ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Library members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the members of the Museum and Library Services Board appointed under paragraph (1)(D)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e58e1ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" five shall be professional librarians or information specialists, of whom—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e58e1af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/b/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than one shall be knowledgeable about electronic information and technical aspects of library and information services and sciences; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e58e1b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/b/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than one other shall be knowledgeable about the library and information service needs of underserved communities, including rural communities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e58e1b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the remainder shall have special competence in, or knowledge of, the needs for library and information services in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e58e1b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Museum members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the members of the Museum and Library Services Board appointed under paragraph (1)(E)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e58e1b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" five shall be museum professionals who are or have been affiliated with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e58e1b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/b/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resources that, collectively, are broadly representative of the curatorial, conservation, educational, and cultural resources of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e58e1b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/b/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" museums that, collectively, are broadly representative of various types of museums, including museums relating to science, history, technology, art, zoos, botanical gardens, and museums designed for children; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e58e1b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the remainder shall be individuals recognized for their broad knowledge, expertise, or experience in museums or commitment to museums.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e58e1b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic and other representation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Museum and Library Services Board shall be appointed to reflect persons from, and the needs of, various geographic regions of the United States, including rural areas. The Museum and Library Services Board may not include, at any time, more than three appointive members from a single State. In making such appointments, the President shall give due regard to equitable representation of women, minorities, and persons with disabilities who are involved with museums and libraries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e58e1b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, the Deputy Director of the Office of Library Services, the Deputy Director of the Office of Museum Services, and the General Counsel of the Institute shall be nonvoting members of the Museum and Library Services Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e58e1b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e58e1ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Museum and Library Services Board appointed under subparagraph (D) or (E) of subsection (b)(1) shall serve for a term of 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e58e1bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to adjust terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms of the members appointed to the Museum and Library Service Board shall be adjusted by the President as necessary to ensure that the terms of not more than four members expire in the same year. Such adjustments shall be carried out through designation of the adjusted term at the time of appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e58e1bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any member appointed to fill a vacancy shall serve for the remainder of the term for which the predecessor of the member was appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e58e1bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reappointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No appointive member of the Museum and Library Services Board who has been a member for more than 7 consecutive years shall be eligible for reappointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e58e1be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service until successor takes office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this subsection, an appointive member of the Museum and Library Services Board shall serve after the expiration of the term of the member until the successor to the member takes office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e58e1bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and powers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e58e1c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Museum and Library Services Board shall advise the Director on general policies with respect to the duties, powers, and authority of the Institute relating to museum, library, and information services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e58e1c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National awards and medals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Museum and Library Services Board shall advise the Director in awarding national awards and medals under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9107"},"text":"section 9107 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e58e1c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall serve as Chairperson of the Museum and Library Services Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e58e1c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The General Counsel of the Institute shall serve as Secretary of the Museum and Library Services Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e58e1c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e58e1c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Museum and Library Services Board shall meet not less than 2 times each year and at the call of the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e58e1c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vote","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All decisions by the Museum and Library Services Board with respect to the exercise of its duties and powers shall be made by a majority vote of the members of the Board who are present and authorized to vote.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e58e1c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the voting members of the Museum and Library Services Board shall constitute a quorum for the conduct of business at official meetings, but a lesser number of members may hold hearings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e58e1c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and travel expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e58e1c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Museum and Library Services Board who is not an officer or employee of the Federal Government may be compensated at a rate to be fixed by the President, but not to exceed the daily equivalent of the maximum annual rate of pay authorized for a position above grade GS–15 of the General Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5108"},"text":"section 5108 of title 5","children":[],"tail":", for each day (including travel time) during which such member is engaged in the performance of the duties of the Museum and Library Services Board. Members of the Museum and Libraries Services Board who are full-time officers or employees of the Federal Government may not receive additional pay, allowances, or benefits by reason of their service on the Museum and Library Services Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e58e1ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Museum and Library Services Board shall receive travel expenses, including per diem in lieu of subsistence, in accordance with applicable provisions under subchapter I of chapter 57 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e58e1cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9105a/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, with the advice of the Museum and Library Services Board, shall coordinate the development and implementation of policies and activities as described in subsections (f) and (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9103"},"text":"section 9103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e58e1cc-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/462/tII/s207"},"text":"Pub. L. 94–462, title II, § 207","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/81/tI/s104/2"},"text":"Pub. L. 108–81, title I, § 104(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-25"},"text":"Sept. 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/993"},"text":"117 Stat. 993","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/340/tI/s104"},"text":"Pub. L. 111–340, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3597"},"text":"124 Stat. 3597","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s2/r"},"text":"Pub. L. 112–166, § 2(r)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1288"},"text":"126 Stat. 1288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/410/s4"},"text":"Pub. L. 115–410, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5413"},"text":"132 Stat. 5413","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e58e1cd-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e58e1ce-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e58e1cf-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/462/s207"},"text":"section 207 of Pub. L. 94–462","children":[],"tail":" was renumbered section 208 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9106"},"text":"section 9106 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/462/s207"},"text":"section 207 of Pub. L. 94–462","children":[],"tail":" was classified to "},{"tag":"ref","attrib