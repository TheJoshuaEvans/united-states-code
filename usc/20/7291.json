{"tag":"section","attrib":{"id":"id0e304b95-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7291"},"text":null,"children":[{"tag":"num","attrib":{"value":"7291"},"text":"§ 7291.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards for academic enrichment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e304b96-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7291/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From funds reserved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7251/b/2/C"},"text":"section 7251(b)(2)(C) of this title","children":[],"tail":", the Secretary shall award grants, contracts, or cooperative agreements, on a competitive basis, to eligible entities for the purposes of enriching the academic experience of students by promoting—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e304b97-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7291/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arts education for disadvantaged students and students who are children with disabilities, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7292"},"text":"section 7292 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304b98-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7291/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" school readiness through the development and dissemination of accessible instructional programming for preschool and elementary school children and their families, as described in ","children":[{"tag":"ref","attr