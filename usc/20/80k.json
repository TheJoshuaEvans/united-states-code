{"tag":"section","attrib":{"id":"id0c8581b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80k"},"text":null,"children":[{"tag":"num","attrib":{"value":"80k"},"text":"§ 80k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donation and transfer of lands and improvements, works of art, and other assets and property of Museum of African Art to Smithsonian Institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board of Regents of the Smithsonian Institution (hereinafter in this subchapter referred to as the “Board”) is authorized to accept a deed or other instrument donating and transferring to the Smithsonian Institution, the land and improvements thereto, collections of works of art, and all other assets and property of the Museum of African Art.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c8581b4-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/414/s1"},"text":"Pub. L. 95–414, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-05"},"text":"Oct. 5, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/911"},"text":"92 Stat. 911","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c8581b5-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0c8581b6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0c8581b7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/414/s7"},"text":"Pub. L. 95–414, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-05"},"text":"Oct. 5, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/913"},"text":"92 Stat. 913","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/414/s7"},"text":"“Except for the provisions in sections 1 and 6(b) [this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s80p/b"},"text":"section 80p(b) of this title","children":[],"tail":"], the provisions of this Act [this subchapter] shall take effect on the date of transfer of a deed or other instrument under the provisions of section 1 [this section].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
