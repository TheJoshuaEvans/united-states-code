{"tag":"section","attrib":{"id":"id0defe6cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4513"},"text":null,"children":[{"tag":"num","attrib":{"value":"4513"},"text":"§ 4513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0defe6cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General powers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Foundation is authorized—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0defe6cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4513/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to appoint and fix the compensation of such personnel as may be necessary to carry out this chapter,","children":[{"tag":"ref","attrib":{"idref":"fn002174"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002174"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" without regard to the provisions of title 5 governing appointments in the competitive service, but at General Schedule pay rates not in excess of the maximum rate for grade GS–15 of the General Schedule under section 5332 of that title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe6ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4513/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to procure temporary and intermittent services of such experts and consultants as are necessary to the extent authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":", but at rates not to exceed the rate specified at the time of such service for grade GS–18 in section 5332 of such title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe6cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4513/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prescribe such regulations as it deems necessary governing the manner in which its functions shall be carried out;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe6d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4513/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive money and other property donated, bequeathed, or devised, without condition or restriction other than it be used for the purposes of the Foundation; and to use, sell, or otherwise dispose of such property for the purpose of carrying out its functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe6d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4513/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept and utilize the services of voluntary and noncompensated personnel and reimburse them for travel expenses, including per diem, as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe6d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4513/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enter into contracts, grants, or other arrangements, or modifications thereof, to carry out the provisions of this chapter,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and such contracts or modifications thereof may, with the concurrence of two-thirds of the members of the Board, be entered into without performance or other bonds, and without regard to "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe6d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4513/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make advances, progress, and other payments which the Board deems necessary under this chapter without regard to the provisions of section 3324(a) and (b) of title 31;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe6d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4513/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to rent office space in the District of Columbia or its environs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe6d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4513/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct programs in addition to or in conjunction with the Fellowship program which shall further the Foundation’s purpose of encouraging research and study of constitutionalism in America;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe6d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4513/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expend not more than 5 percent of its annual operating budget to pay the costs of fundraising activities, including public and private gatherings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe6d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4513/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make other necessary expenditures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0defe6d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The foundation ","children":[{"tag":"ref","attrib":{"idref":"fn002175"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002175"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" shall submit to the President and to the Congress an annual report of its operations under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0defe6d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4513/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detailing of agency personnel to Foundation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On request of the Chairman of the Foundation, the head of a Federal agency may detail personnel of the agency to the Foundation to assist the Foundation in carrying out this chapter.","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" Details under this subsection shall be without reimbursement by the Foundation to the agency from which personnel are detailed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0defe6da-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/b/tVIII/s814"},"text":"Pub. L. 99–500, § 101(b) [title VIII, § 814]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-39"},"text":"100 Stat. 1783–39","children":[],"tail":", 1783–80, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/b/tVIII/s814"},"text":"Pub. L. 99–591, § 101(b) [title VIII, § 814]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-39"},"text":"100 Stat. 3341–39","children":[],"tail":", 3341–80; "},{"tag":"ref","attrib":{"href":"/us/pl/101/208/s3"},"text":"Pub. L. 101–208, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-07"},"text":"Dec. 7, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1837"},"text":"103 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0defe6db-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0defe6dc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0defe6dd-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a)(1) and (c), was in the original “this Act” and was translated as reading “this title” meaning title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/b"},"text":"section 101(b) of Pub. L. 99–500","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":" which enacted this chapter, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(6), was in the original “this chapter” and was translated as reading “this title” meaning title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/b"},"text":"section 101(b) of Pub. L. 99–500","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":" which enacted this chapter, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0defe6de-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a)(6), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":"” substituted for “"},{"tag":"ref","attrib":{"href":"/us/usc/t41/s5"},"text":"section 5 of title 41","children":[],"tail":"” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a)(7), “section 3324(a) and (b) of title 31” substituted for “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s529"},"text":"section 529 of title 31","children":[],"tail":"” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s4/b"},"text":"Pub. L. 97–258, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", the first section of which enacted Title 31, Money and Finance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":" is a corrected version of "},{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0defe6df-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/208/s3/1/A"},"text":"Pub. L. 101–208, § 3(1)(A)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “to appoint and fix the compensation of such personnel as may be necessary to carry out the provisions of this chapter, except that in no case shall employees other than the Executive Secretary be compensated at a rate to exceed the rate provided for employees in grade GS–15 of the General Schedule set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":";”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/208/s3/1/B"},"text":"Pub. L. 101–208, § 3(1)(B)","children":[],"tail":", amended par. (8) generally. Prior to amendment, par. (8) read as follows: “to rent office space;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(10), (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/208/s3/1/C"},"text":"Pub. L. 101–208, § 3(1)(C)","children":[],"tail":"–(E), added par. (10) and redesignated former par. (10) as (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/208/s3/2"},"text":"Pub. L. 101–208, § 3(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0defe6e0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0defe6e1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (b) of this section relating to submitting an annual report to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and page 176 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
