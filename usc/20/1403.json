{"tag":"section","attrib":{"id":"id0d9c6f48-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1403"},"text":null,"children":[{"tag":"num","attrib":{"value":"1403"},"text":"§ 1403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abrogation of State sovereign immunity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d9c6f49-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State shall not be immune under the 11th amendment to the Constitution of the United States from suit in Federal court for a violation of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9c6f4a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In a suit against a State for a violation of this chapter, remedies (including remedies both at law and in equity) are available for such a violation to the same extent as those remedies are available for such a violation in the suit against any public entity other than a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9c6f4b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1403/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (a) and (b) apply with respect to violations that occur in whole or part after ","children":[{"tag":"date","attrib":{"date":"1990-10-30"},"text":"October 30, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9c6f4c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s604"},"text":"Pub. L. 91–230, title VI, § 604","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2659"},"text":"118 Stat. 2659","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9c6f4d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9c6f4e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d9c6f4f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1403, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s604"},"text":"Pub. L. 91–230, title VI, § 604","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/17/tI/s101"},"text":"Pub. L. 105–17, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-04"},"text":"June 4, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/47"},"text":"111 Stat. 47","children":[],"tail":", related to abrogation of State sovereign immunity, prior to the general amen