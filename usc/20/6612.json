{"tag":"section","attrib":{"id":"id0e187dea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6612"},"text":null,"children":[{"tag":"num","attrib":{"value":"6612"},"text":"§ 6612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subgrants to local educational agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e187deb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds to local educational agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e187dec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6612/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From funds reserved by a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6611/c/1"},"text":"section 6611(c)(1) of this title","children":[],"tail":" for a fiscal year, the State, acting through the State educational agency, shall award subgrants to eligible local educational agencies from allocations described in paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e187ded-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6612/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation formula","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the funds described in paragraph (1), the State educational agency shall allocate to each of the eligible local educational agencies in the State for a fiscal year the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e187dee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6612/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount that bears the same relationship to 20 percent of such funds for such fiscal year as the number of individuals aged 5 through 17 in the geographic area served by the agency, as determined by the Secretary on the basis of the most recent satisfactory data, bears to the number of those individuals in the geographic areas served by all eligible local educational agencies in the State, as so determined; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e187def-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6612/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount that bears the same relationship to 80 percent of the funds for such fiscal year as the number of individuals aged 5 through 17 from families with incomes below the poverty line in the geographic area served by the agency, as determined by the Secretary on the basis of the most recent satisfactory data, bears to the number of those individuals in the geographic areas served by all the eligible local educational agencies in the State, as so determined.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e187df0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6612/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to prohibit a consortium of local educational agencies that are designated with a locale code of 41, 42, or 43, or such local educational agencies designated with a locale code of 41, 42, or 43 that work in cooperation with an educational service agency, from voluntarily combining allocations received under this part for the collective use of funding by the consortium for activities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e187df1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e187df2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6612/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a subgrant under this section, a local educational agency shall submit an application to the State educational agency at such time, in such manner, and containing such information as the State educational agency may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e187df3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6612/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application submitted under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1aedf4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6612/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the activities to be carried out by the local educational agency under this section and how these activities will be aligned with challenging State academic standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aedf5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6612/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the local educational agency’s systems of professional growth and improvement, such as induction for teachers, principals, or other school leaders and opportunities for building the capacity of teachers and opportunities to develop meaningful teacher leadership.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aedf6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6612/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of how the local educational agency will prioritize funds to schools served by the agency that are implementing comprehensive support and improvement activities and targeted support and improvement activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/d"},"text":"section 6311(d) of this title","children":[],"tail":" and have the highest percentage of children counted under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333/c"},"text":"section 6333(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aedf7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6612/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of how the local educational agency will use data and ongoing consultation described in paragraph (3) to continually update and improve activities supported under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aedf8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6612/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assurance that the local educational agency will comply with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7881"},"text":"section 7881 of this title","children":[],"tail":" (regarding participation by private school children and teachers)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aedf9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6612/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assurance that the local educational agency will coordinate professional development activities authorized under this part with professional development activities provided through other Federal, State, and local programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aedfa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6612/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the application described in paragraph (2), a local educational agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1aedfb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6612/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meaningfully consult with teachers, principals, other school leaders, paraprofessionals (including organizations representing such individuals), specialized instructional support personnel, charter school leaders (in a local educational agency that has charter schools), parents, community partners, and other organizations or partners with relevant and demonstrated expertise in programs and activities designed to meet the purpose of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aedfc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6612/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek advice from the individuals and organizations described in subparagraph (A) regarding how best to improve the local educational agency’s activities to meet the purpose of this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1aedfd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6612/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the local educational agency’s activities under this part with other related strategies, programs, and activities being conducted in the community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aedfe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6612/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consultation required under paragraph (3) shall not interfere with the timely submission of the application required under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e1aedff-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2102"},"text":"Pub. L. 89–10, title II, § 2102","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tII/s2002"},"text":"Pub. L. 114–95, title II, § 2002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1925"},"text":"129 Stat. 1925","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e1aee00-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e1aee01-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e1aee02-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6612, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2112"},"text":"Pub. L. 89–10, title II, § 2112","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tII/s201"},"text":"Pub. L. 107–110, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1623"},"text":"115 Stat. 1623","children":[],"tail":", related to State applications, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"Pub. L. 114–95, § 5","children":[],"tail":", title II, § 2002, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1806"},"text":"129 Stat. 1806","children":[],"tail":", 1913, effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s2102"},"text":"section 2102 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6602"},"text":"section 6602 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s2102"},"text":"section 2102 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6622"},"text":"section 6622 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s2102"},"text":"section 2102 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3002"},"text":"section 3002 of this title","children":[],"tail":", prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e1aee03-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e1aee04-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
