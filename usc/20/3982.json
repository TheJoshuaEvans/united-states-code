{"tag":"section","attrib":{"id":"id0de18f19-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3982"},"text":null,"children":[{"tag":"num","attrib":{"value":"3982"},"text":"§ 3982.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de18f1a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3982/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “applicant” means with respect to activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3984/a"},"text":"section 3984(a) of this title","children":[],"tail":" an institution of higher education and the other participants described in paragraph (3) of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3984/a"},"text":"section 3984(a) of this title","children":[],"tail":", and with respect to activities described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3984/b"},"text":"section 3984(b) of this title","children":[],"tail":" a local educational agency and the other participants described in paragraph (3) of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3984/b"},"text":"section 3984(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f1b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3982/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “equipment” includes machinery, utilities, and built-in equipment and any necessary enclosures or structures to house them, and includes all other items necessary for the functioning of a particular facility as a facility for the provision of educational services, including items such as instructional equipment and necessary furniture, printed, published, and audio-visual instructional materials, and books, periodicals, documents, and other related materials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f1c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3982/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State agency for higher education” means the State board of higher education or other agency or officer primarily responsible for the State supervision of higher education, or if there is no such officer or agency, an officer or agency designated by the Governor or by State law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de18f1d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tIII/s303"},"text":"Pub. L. 98–377, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-11"},"text":"Aug. 11, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1283"},"text":"98 Stat. 1283","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/159/tII/s232"},"text":"Pub. L. 99–159, title II, § 232","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-22"},"text":"Nov. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/900"},"text":"99 Stat. 900","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tVI/s6031/b/2"},"text":"Pub. L. 100–418, title VI, § 6031(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1483"},"text":"102 Stat. 1483","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de18f1e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de18f1f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0de18f20-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" substituted “part” for “subchapter” in introductory text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/159"},"text":"Pub. L. 99–159","children":[],"tail":" struck out pars. (3), (4), and (5) which defined “Foundation”, “institution of higher education”, and “States”, respectively, and redesignated par. (6) as (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
