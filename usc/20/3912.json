{"tag":"section","attrib":{"id":"id0ddf45bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3912"},"text":null,"children":[{"tag":"num","attrib":{"value":"3912"},"text":"§ 3912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functional objectives; uses of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ddf45c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out its science and engineering education responsibilities, the Foundation shall have the following functional objectives: public understanding of science and technology, faculty enhancement, student education and training, instructional development and instrumentation, and materials development and dissemination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ddf45c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Funds under this subchapter shall, consistent with such functional objectives, be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ddf45c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3912/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancement of public understanding of science and engineering through informal education activities using a variety of mediums such as broadcasting, museums, clubs, and amateur science societies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf45c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3912/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of new science and engineering faculty resources and talents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf45c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3912/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancement of the quality of science and engineering instruction in colleges of teacher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf45c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3912/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of four-year college faculty and instructors in high technology fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf45c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3912/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of two-year community college faculty and instructors especially in high technology fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf45c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3912/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of precollege mathematics, science and engineering education and training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf45c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3912/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouragement of potential students, including underrepresented and underserved populations, to pursue careers in mathematics, science, engineering, and critical foreign languages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf45c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3912/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of instructional instrumentation and systems for postsecondary technical, engineering, and scientific education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf45ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3912/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of science, engineering, and education networks to aid in the development and dissemination of successful curricula, methods, and materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ddf45cb-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tI/s102"},"text":"Pub. L. 98–377, title I, § 102","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/159/tII/s201"},"text":"Pub. L. 99–159, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-22"},"text":"Nov. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/894"},"text":"99 Stat. 894","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ddf45cc-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ddf45cd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0ddf45ce-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3912, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tI/s102"},"text":"Pub. L. 98–377, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-11"},"text":"Aug. 11, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1268"},"text":"98 Stat. 1268","children":[],"tail":", related to submission, contents, etc., of applications, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/99/159/s201"},"text":"section 201 of Pub. L. 99–159","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
