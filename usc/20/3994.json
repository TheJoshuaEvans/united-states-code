{"tag":"section","attrib":{"id":"id0de18f8c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3994"},"text":null,"children":[{"tag":"num","attrib":{"value":"3994"},"text":"§ 3994.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de18f8d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3994/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may use funds from grants received in any fiscal year under this part for elementary and secondary programs described in this section. The State educational agency shall administer such funds, which shall be awarded to such programs on a competitive basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de18f8e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3994/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds from grants received under this part may be used for the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de18f8f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3994/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improvement of elementary and secondary resources","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such funds may be used for acquisition of equipment, instructional and reference materials, and partnership in education programs designed to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de18f90-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3994/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve instruction in mathematics and science education at the elementary and secondary level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de18f91-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3994/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve laboratory facilities, classroom and library resources in elementary and secondary mathematics and science education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de18f92-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3994/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attract matching dollars and in kind contributions of equipment, learning resources or shared time from business concerns, libraries, museums, nonprofit private organizations, professional mathematics and scientific associations, and appropriate State agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f93-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3994/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced placement programs","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de18f94-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3994/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such funds may be used for advanced placement programs operated by local educational agencies that are designed to allow qualified secondary students to attend college preparatory schools, colleges, or universities on a part-time or full-time basis with respect to science and mathematics instruction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de18f95-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3994/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A local educational agency that receives funds from a grant under this part for an advanced placement program described in subparagraph (A) shall allocate to such program a percentage of funds received from the State on a per student basis according to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0de18f96-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3994/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of students participating in the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de18f97-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3994/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the instruction time such students receive under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de18f98-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tIII/s324"},"text":"Pub. L. 98–377, title III, § 324","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tVI/s6031/a/2"},"text":"Pub. L. 100–418, title VI, § 6031(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1480"},"text":"102 Stat. 1480","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
