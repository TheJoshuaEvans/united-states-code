{"tag":"section","attrib":{"id":"id0dda8aaa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3480"},"text":null,"children":[{"tag":"num","attrib":{"value":"3480"},"text":"§ 3480.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copyrights and patents","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to acquire any of the following described rights if the property acquired thereby is for use by or for, or useful to, the Department:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dda8aab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3480/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" copyrights, patents, and applications for patents, designs, processes, and manufacturing data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dda8aac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3480/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" licenses under copyrights, patents, and applications for patents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dda8aad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3480/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" releases, before suit is brought, for past infringement of patents or copyrights.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dda8aae-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIV/s420"},"text":"Pub. L. 96–88, title IV, § 420","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"