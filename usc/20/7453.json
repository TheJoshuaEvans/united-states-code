{"tag":"section","attrib":{"id":"id0e39e7e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453"},"text":null,"children":[{"tag":"num","attrib":{"value":"7453"},"text":"§ 7453.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native American and Alaska Native language immersion schools and programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e39e7e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e39e7e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish a grant program to support schools that use Native American and Alaska Native languages as the primary language of instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e39e7e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain, protect, and promote the rights and freedom of Native Americans and Alaska Natives to use, practice, maintain, and revitalize their languages, as envisioned in the Native American Languages Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2901"},"text":"25 U.S.C. 2901","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e39e7ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the Nation’s First Peoples’ efforts to maintain and revitalize their languages and cultures, and to improve educational opportunities and student outcomes within Native American and Alaska Native communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e39e7eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e39e7ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From funds reserved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7492/c"},"text":"section 7492(c) of this title","children":[],"tail":", the Secretary shall reserve 20 percent to make grants to eligible entities to develop and maintain, or to improve and expand, programs that support schools, including elementary school and secondary school education sites and streams, using Native American and Alaska Native languages as the primary languages of instruction."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e39e7ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “eligible entity” means any of the following entities that has a plan to develop and maintain, or to improve and expand, programs that support the entity’s use of a Native American or Alaska Native language as the primary language of instruction in elementary schools or secondary schools, or both:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e39e7ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e7ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Tribal College or University (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c"},"text":"section 1059c of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e7f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A tribal education agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e7f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A local educational agency, including a public charter school that is a local educational agency under State law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e7f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A school operated by the Bureau of Indian Education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e7f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Alaska Native Regional Corporation (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1602/g"},"text":"section 1602(g) of title 43","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e7f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A private, tribal, or Alaska Native nonprofit organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e7f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nontribal for-profit organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e39e7f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e39e7f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that desires to receive a grant under this section shall submit an application to the Secretary at such time and in such manner as the Secretary may require, including the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e39e7f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name of the Native American or Alaska Native language to be used for instruction at the school supported by the eligible entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e7f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of students attending such school.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e7fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of hours of instruction in or through 1 or more Native American or Alaska Native languages being provided to targeted students at such school, if any.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e7fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A description of how the eligible entity will—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e39e7fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the funds provided to meet the purposes of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e39e7fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement the activities described in subsection (e);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e39e7fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the implementation of rigorous academic content; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e39e7ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that students progress toward high-level fluency goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e800-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Information regarding the school’s organizational governance or affiliations, including information about—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e39e801-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the school governing entity (such as a local educational agency, tribal education agency or department, charter organization, private organization, or other governing entity);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e39e802-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the school’s accreditation status;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e39e803-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/1/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any partnerships with institutions of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e39e804-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/1/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any indigenous language schooling and research cooperatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e805-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An assurance that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e39e806-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the school is engaged in meeting State or tribally designated long-term goals for students, as may be required by applicable Federal, State, or tribal law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e39e807-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the school provides assessments of students using the Native American or Alaska Native language of instruction, where possible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e39e808-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/1/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the qualifications of all instructional and leadership personnel at such school is sufficient to deliver high-quality education through the Native American or Alaska Native language used in the school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e39e809-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/1/F/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the school will collect and report to the public data relative to student achievement and, if appropriate, rates of high school graduation, career readiness, and enrollment in postsecondary education or workforce development programs, of students who are enrolled in the school’s programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e39e80a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not give a priority in awarding grants under this section based on the information described in paragraph (1)(E).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e39e80b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of certification","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e39e80c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that is a public elementary school or secondary school (including a public charter school or a school operated by the Bureau of Indian Education) or a nontribal for-profit or nonprofit organization shall submit, along with the application requirements described in paragraph (1), a certification described in subparagraph (B) indicating that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e39e80d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the school or organization has the capacity to provide education primarily through a Native American or an Alaska Native language; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e39e80e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are sufficient speakers of the target language at the school or available to be hired by the school or organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e80f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The certification described in subparagraph (A) shall be from one of the following entities, on whose land the school or program is located, that is an entity served by such school, or that is an entity whose members (as defined by that entity) are served by the school:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e39e810-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Tribal College or University (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c"},"text":"section 1059c of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e39e811-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Federally recognized Indian tribe or tribal organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e39e812-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Alaska Native Regional Corporation or an Alaska Native nonprofit organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e39e813-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/c/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Native Hawaiian organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e39e814-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awarding of grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e39e815-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the amount of each grant and the duration of each grant, which shall not exceed 3 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e39e816-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure, to the maximum extent feasible, that diversity in languages is represented.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e39e817-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e39e818-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under this section shall use such funds to carry out the following activities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e39e819-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supporting Native American or Alaska Native language education and development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e81a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing professional development for teachers and, as appropriate, staff and administrators to strengthen the overall language and academic goals of the school that will be served by the grant program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e39e81b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowable activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under this section may use such funds to carry out the following activities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e39e81c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing or refining curriculum, including teaching materials and activities, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e81d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Creating or refining assessments written in the Native American or Alaska Native language of instruction that measure student proficiency and that are aligned with State or tribal academic standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e81e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Carrying out other activities that promote the maintenance and revitalization of the Native American or Alaska Native language relevant to the grant program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e39e81f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each eligible entity that receives a grant under this section shall prepare and submit an annual report to the Secretary, which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e39e820-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities the entity carried out to meet the purposes of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e39e821-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of children served by the program and the number of instructional hours in the Native American or Alaska Native language.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e39e822-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7453/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 5 percent of the funds provided to a grantee under this section for any fiscal year may be used for administrative purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e39e823-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVI/s6133"},"text":"Pub. L. 89–10, title VI, § 6133","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVI/s6002"},"text":"Pub. L. 114–95, title VI, § 6002","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2057"},"text":"129 Stat. 2057","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e39e824-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e39e825-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e39e826-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Native American Languages Act, referred to in subsec. (a)(2), is title I of ","chi