{"tag":"section","attrib":{"id":"id0e13c24e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6421"},"text":null,"children":[{"tag":"num","attrib":{"value":"6421"},"text":"§ 6421.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose and program authorization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e13c24f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6421/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e13c250-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6421/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve educational services for children and youth in local, tribal, and State institutions for neglected or delinquent children and youth so that such children and youth have the opportunity to meet the same challenging State academic standards that all children in the State are expected to meet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e13c251-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6421/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide such children and youth with the services needed to make a successful transition from institutionalization to further schooling or employment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e13c252-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6421/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent at-risk youth from dropping out of school, and to provide dropouts, and children and youth returning from correctional facilities or institutions for neglected or delinquent children and youth, with a support system to ensure their continued education and the involvement of their families and communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e13c253-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6421/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to carry out the purpose of this part and from amounts appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6302/d"},"text":"section 6302(d) of this title","children":[],"tail":", the Secretary shall make grants to State educational agencies to enable such agencies to award subgrants to State agencies and local educational agencies to establish or improve programs of education for neglected, delinquent, or at-risk children and youth."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e13c254-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1401"},"text":"Pub. L. 89–10, title I, § 1401","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1580"},"text":"115 Stat. 1580","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tI/s1401/1"},"text":"Pub. L. 114–95, title I, § 1401(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1900"},"text":"129 Stat. 1900","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e13c255-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e13c256-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e13c257-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6421, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1401"},"text":"Pub. L. 89–10, title I, § 1401","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3591"},"text":"108 Stat. 3591","children":[],"tail":", set out findings and purpose and authorized program, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s1401"},"text":"section 1401 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s2821"},"text":"section 2821 of this title","children":[],"tail":", prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},