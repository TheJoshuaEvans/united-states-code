{"tag":"section","attrib":{"id":"id0de8bb39-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4356"},"text":null,"children":[{"tag":"num","attrib":{"value":"4356"},"text":"§ 4356.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liaison for educational programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de8bb3a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4356/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of liaison","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate an individual in the Office of Special Education and Rehabilitative Services of the Department of Education from among individuals who have experience in the education of individuals who are deaf to serve as liaison between the Department and Gallaudet University, the National Technical Institute for the Deaf, and other postsecondary educational programs for individuals who are deaf under the Individuals with Disabilities Education Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"20 U.S.C. 1400","children":[],"tail":" et seq.], the Rehabilitation Act of 1973 ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"29 U.S.C. 701","children":[],"tail":" et seq.], and other Federal or non-Federal agencies, institutions, or organizations involved with the education or rehabilitation of individuals who are deaf or hard of hearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de8bb3b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4356/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of liaison","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The individual serving as liaison for educational programs for individuals who are deaf or hard of hearing shall:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de8bb3c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4356/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information to institutions regarding the Department’s efforts directly affecting the operation of such programs by such institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de8bb3d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4356/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review research and other activities carried out by the University, NTID, and other Federal or non-Federal agencies, institutions, or organizations involved with the education or rehabilitation of individuals who are deaf or hard of hearing for the purpose of determining overlap and opportunities for coordination among such entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de8bb3e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4356/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such support and assistance as such institutions may request and the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de8bb3f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4356/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed to affect the authority of the Secretary under this chapter or any other Act with respect to Gallaudet University or the National Technical Institute for the Deaf.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de8bb40-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/371/tII/s206"},"text":"Pub. L. 99–371, title II, § 206","children":[],"tail":", formerly title IV, § 406, "},{"tag":"date","attrib":{"date":"1986-08-04"},"text":"Aug. 4, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/790"},"text":"100 Stat. 790","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/476/tIX/s901/a/2"},"text":"Pub. L. 101–476, title IX, § 901(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-30"},"text":"Oct. 30, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1142"},"text":"104 Stat. 1142","children":[],"tail":"; renumbered title II, § 206, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/421/tI"},"text":"Pub. L. 102–421, title I","children":[],"tail":", §§ 101(b)(5), (6), 136, 151(a)(4), (5), "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"Oct. 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2151"},"text":"106 Stat. 2151","children":[],"tail":", 2159, 2164; "},{"tag":"ref","attrib":{"href":"/us/pl/103/73/tII/s204/e"},"text":"Pub. L. 103–73, title II, § 204(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-11"},"text":"Aug. 11, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/735"},"text":"107 Stat. 735","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIX/s908"},"text":"Pub. L. 110–315, title IX, § 908","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3453"},"text":"122 Stat. 3453","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de8bb41-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de8bb42-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0de8bb43-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Individuals with Disabilities Education Act, referred to in subsec. (a), is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230"},"text":"Pub. L. 91–230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/175"},"text":"84 Stat. 175","children":[],"tail":", which is classified generally to chapter 33 (§ 1400 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Rehabilitation Act of 1973, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112"},"text":"Pub. L. 93–112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-09-26"},"text":"Sept. 26, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/355"},"text":"87 Stat. 355","children":[],"tail":", which is classified generally to chapter 16 (§ 701 et seq.) of Title 29, Labor. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"section 701 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0de8bb44-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" substituted “The” for “Not later than 30 days after "},{"tag":"date","attrib":{"date":"1986-08-04"},"text":"August 4, 1986","children":[],"tail":", the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/73"},"text":"Pub. L. 103–73","children":[],"tail":", which directed amendment of subsec. (b) by inserting “or hard of hearing” after “individuals who are deaf”, was executed by making the insertion in introductory provisions but not in par. (2) to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/421/s151/a/5"},"text":"Pub. L. 102–421, § 151(a)(5)","children":[],"tail":", struck out “for the deaf” after “educational programs” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/421/s151/a/4"},"text":"Pub. L. 102–421, § 151(a)(4)","children":[],"tail":", substituted “individuals who are deaf” for “the deaf” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/421/s136/1"},"text":"Pub. L. 102–421, § 136(1)","children":[],"tail":", substituted “, the Rehabilitation Act of 1973, and other Federal or non-Federal agencies, institutions, or organizations involved with the education or rehabilitation of individuals who are deaf or hard of hearing.” for “and the Rehabilitation Act of 1973.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/421/s151/a/4"},"text":"Pub. L. 102–421, § 151(a)(4)","children":[],"tail":", substituted “individuals who are deaf” for “the deaf” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1) to (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/421/s136/2"},"text":"Pub. L. 102–421, § 136(2)","children":[],"tail":", struck out “and” at end of par. (1), added par. (2), and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/476"},"text":"Pub. L. 101–476","children":[],"tail":" substituted “Individuals with Disabilities Education Act” for “Education of the Handicapped Act”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0de8bb45-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0de8bb46-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/421"},"text":"Pub. L. 102–421","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/421/s161"},"text":"section 161 of Pub. L. 102–421","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0de8bb47-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/476"},"text":"Pub. L. 101–476","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/476/s1001"},"text":"section 1001 of Pub. L. 101–476","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087ee"},"text":"section 1087ee of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
