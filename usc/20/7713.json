{"tag":"section","attrib":{"id":"id0e4819d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713"},"text":null,"children":[{"tag":"num","attrib":{"value":"7713"},"text":"§ 7713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e4819d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Armed Forces","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Armed Forces” means the Army, Navy, Air Force, Marine Corps, and Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4819d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Average per-pupil expenditure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “average per-pupil expenditure” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4819d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate current expenditures of all local educational agencies in the State; divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4819d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of children in average daily attendance for whom such agencies provided free public education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4819d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “construction” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4819d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preparation of drawings and specifications for school facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4819d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" erecting, building, acquiring, altering, remodeling, repairing, or extending school facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4819da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspecting and supervising the construction of school facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4819db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" debt service for such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4819dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “current expenditures” means expenditures for free public education, including expenditures for administration, instruction, attendance and health services, pupil transportation services, operation and maintenance of plant, fixed charges, and net expenditures to cover deficits for food services and student body activities, but does not include expenditures for community services, capital outlay, and debt service, or any expenditures made from funds awarded under part A of subchapter I. The determination of whether an expenditure for the replacement of equipment is considered a current expenditure or a capital outlay shall be determined in accordance with generally accepted accounting principles as determined by the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4819dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal property","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4819de-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraphs (B) through (F), the term “Federal property” means real property that is not subject to taxation by any State or any political subdivision of a State due to Federal agreement, law, or policy, and that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e4819df-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by the United States or leased by the United States from another entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e4819e0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e4819e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" held in trust by the United States for individual Indians or Indian tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e4819e2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" held by individual Indians or Indian tribes subject to restrictions on alienation imposed by the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e4819e3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conveyed at any time under the Alaska Native Claims Settlement Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.] to a Native individual, Native group, or village or regional corporation (including single family occupancy properties that may have been subsequently sold or leased to a third party), except that property that is conveyed under such Act—"}],"tail":null},{"tag":"item","attrib":{"id":"id0e4819e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/A/ii/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is not taxed is, for the purposes of this paragraph, considered tax-exempt due to Federal law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id0e4819e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/A/ii/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is considered Federal property for the purpose of this paragraph if the property is located within a Regional Educational Attendance Area that has no taxing power;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e4819e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public land owned by the United States that is designated for the sole use and benefit of individual Indians or Indian tribes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e4819e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/A/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used for low-rent housing, as described in paragraph (10), that is located on land described in subclause (I), (II), (III), or (IV) of this clause or on land that met one of those descriptions immediately before such property’s use for such housing;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e4819e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e4819e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" part of a low-rent housing project assisted under the United States Housing Act of 1937 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"42 U.S.C. 1437","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e4819ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used to provide housing for homeless children at closed military installations pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11411"},"text":"section 11411 of title 42","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e4819eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/A/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used for affordable housing assisted under the Native American Housing Assistance and Self-Determination Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"25 U.S.C. 4101","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e4819ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by a foreign government or by an international organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4819ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schools providing flight training to members of Air Force","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal property” includes, so long as not subject to taxation by any State or any political subdivision of a State, and whether or not that tax exemption is due to Federal agreement, law, or policy, any school providing flight training to members of the Air Force under contract with the Air Force at an airport owned by a State or political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4819ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal easements, leases, licenses, permits, improvements, and certain other real property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal property” includes, whether or not subject to taxation by a State or a political subdivision of a State—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e4819ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any non-Federal easement, lease, license, permit, or other such interest in Federal property as otherwise described in this paragraph, but not including any non-Federal fee-simple interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e4819f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any improvement on Federal property as otherwise described in this paragraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e4819f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" real property that, immediately before its sale or transfer to a non-Federal party, was owned by the United States and otherwise qualified as Federal property described in this paragraph, but only for one year beyond the end of the fiscal year of such sale or transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4819f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain Postal Service property and pipelines and utility lines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this paragraph, the term “Federal property” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e4819f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any real property under the jurisdiction of the United States Postal Service that is used primarily for the provision of postal services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e4819f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pipelines and utility lines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4819f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property with respect to which State or local tax revenues may not be expended, allocated, or available for free public education","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this paragraph, “Federal property” does not include any property on which children reside that is otherwise described in this paragraph if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e4819f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no tax revenues of the State or of any political subdivision of the State may be expended for the free public education of children who reside on that Federal property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e4819f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no tax revenues of the State are allocated or available for the free public education of such children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4819f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property located in the State of Oklahoma owned by Indian housing authority for low-income housing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal property” includes any real property located in the State of Oklahoma that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e4819f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is owned by an Indian housing authority and used for low-income housing (including housing assisted under or authorized by the Native American Housing Assistance and Self-Determination Act of 1996 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"25 U.S.C. 4101","children":[],"tail":" et seq.]); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e4819fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at any time—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e4819fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/F/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was designated by treaty as tribal land; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e4819fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/5/F/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfied the definition of Federal property under ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-30/s403/1/A"},"text":"section 403(1)(A) of the Act of September 30, 1950","children":[],"tail":" (Public Law 874, 81st Congress) (as such Act was in effect on the day preceding "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"October 20, 1994","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4819fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Free public education","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “free public education” means education that is provided—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4819fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at public expense, under public supervision and direction, and without tuition charge; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4819ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as elementary or secondary education, as determined under State law, except that, notwithstanding State law, such term—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e481a00-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes preschool education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e481a01-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include any education provided beyond grade 12.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e481a02-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian lands” means any Federal property described in paragraph (5)(A)(ii) or (5)(F).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e481a03-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local contribution percentage","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e481a04-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “local contribution percentage” means the percentage of current expenditures in the State derived from local and intermediate sources, as reported to and verified by the National Center for Education Statistics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e481a05-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hawaii and District of Columbia","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (A), the local contribution percentage for Hawaii and for the District of Columbia shall be the average local contribution percentage for the 50 States and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4a8a06-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local educational agency","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4a8a07-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), the term “local educational agency”—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e4a8a08-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/9/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a board of education or other legally constituted local school authority having administrative control and direction of free public education in a county, township, independent school district, or other school district; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e4a8a09-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/9/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any State agency that directly operates and maintains facilities for providing free public education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4a8a0a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “local educational agency” does not include any agency or school authority that the Secretary determines on a case-by-case basis—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e4a8a0b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was constituted or reconstituted primarily for the purpose of receiving assistance under this subchapter or the Act of ","children":[{"tag":"date","attrib":{"date":"1950-09-30"},"text":"September 30, 1950","children":[],"tail":" (Public Law 874, 81st Congress) (as such Act was in effect on the day preceding "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"October 20, 1994","children":[],"tail":") or increasing the amount of such assistance; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e4a8a0c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not constituted or reconstituted for legitimate educational purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4a8a0d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-rent housing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “low-rent housing” means housing located on property that is described in paragraph (5)(A)(iii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4a8a0e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modernization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “modernization” means repair, renovation, alteration, or construction, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4a8a0f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the concurrent installation of equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4a8a10-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the complete or partial replacement of an existing school facility, but only if such replacement is less expensive and more cost-effective than repair, renovation, or alteration of the school facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4a8a11-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revenue derived from local sources","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “revenue derived from local sources” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4a8a12-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revenue produced within the boundaries of a local educational agency and available to such agency for such agency’s use; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4a8a13-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds collected by another governmental unit, but distributed back to a local educational agency in the same proportion as such funds were collected as a local revenue source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4a8a14-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" School facilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “school facilities” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4a8a15-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" classrooms and related facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4a8a16-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7713/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipment, machinery, and utilities necessary or appropriate for school purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e4a8a17-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVII/s7013"},"text":"Pub. L. 89–10, title VII, § 7013","children":[],"tail":", formerly title VIII, § 8013, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3769"},"text":"108 Stat. 3769","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XVIII, § 1816], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–387; renumbered title VII, § 7013, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVII"},"text":"Pub. L. 114–95, title VII","children":[],"tail":", §§ 7001(c)(2), 7012, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2074"},"text":"129 Stat. 2074","children":[],"tail":", 2087.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e4a8a18-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e4a8a19-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e4a8a1a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Alaska Native Claims Settlement Act, referred to in par. (5)(A)(ii)(III), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203"},"text":"Pub. L. 92–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"Dec. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/688"},"text":"85 Stat. 688","children":[],"tail":", which is classified generally to chapter 33 (§ 1601 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"section 1601 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The United States Housing Act of 1937, referred to in par. (5)(A)(iii)(I), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"act Sept. 1, 1937, ch. 896","children":[],"tail":", as revised generally by "},{"tag":"ref","attrib":{"href":"/us/pl/93/383/tII/s201/a"},"text":"Pub. L. 93–383, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/653"},"text":"88 Stat. 653","children":[],"tail":", which is classified generally to chapter 8 (§ 1437 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"section 1437 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Native American Housing Assistance and Self-Determination Act of 1996, referred to in par. (5)(A)(iii)(III), (F)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4016"},"text":"110 Stat. 4016","children":[],"tail":", which is classified principally to chapter 43 (§ 4101 et seq.) of Title 25, Indians. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1950-09-30"},"text":"September 30, 1950","children":[],"tail":" (Public Law 874, 81st Congress) (as such Act was in effect on the day preceding "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"October 20, 1994","children":[],"tail":"), referred to in pars. (5)(F)(ii)(II) and (9)(B)(i), is "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-30/ch1124"},"text":"act Sept. 30, 1950, ch. 1124","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/1100"},"text":"64 Stat. 1100","children":[],"tail":", which was classified generally to chapter 13 (§ 236 et seq.) of this title prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s331/b"},"text":"Pub. L. 103–382, title III, § 331(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3965"},"text":"108 Stat. 3965","children":[],"tail":". Section 403 of the Act was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s244"},"text":"section 244 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e4a8a1b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s7012/1"},"text":"Pub. L. 114–95, § 7012(1)","children":[],"tail":", substituted “Marine Corps, and Coast Guard” for “and Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s7012/2"},"text":"Pub. L. 114–95, § 7012(2)","children":[],"tail":", struck out “and subchapter VI” after “part A of subchapter I”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5)(A)(ii)(III). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s7012/3/A"},"text":"Pub. L. 114–95, § 7012(3)(A)","children":[],"tail":", added subcl. (III) and struck out former subcl. (III) which read as follows: “conveyed at any time under the Alaska Native Claims Settlement Act to a Native individual, Native group, or village or regional corporation;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5)(A)(iii)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s7012/3/B/i"},"text":"Pub. L. 114–95, § 7012(3)(B)(i)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11411"},"text":"section 11411 of title 42","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5)(A)(iii)(III). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s7012/3/B/ii"},"text":"Pub. L. 114–95, § 7012(3)(B)(ii)","children":[],"tail":", added subcl. (III) and struck out former subcl. (III) which read as follows: “used for affordable housing assisted under the Native American Housing Assistance and Self-Determination Act of 1996; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Par. (5)(A)(iii)(III). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XVIII, § 1816(1)(A)], added subcl. (III)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5)(F)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XVIII, § 1816(1)(B)], substituted “or authorized by the Native American Housing Assistance and Self-Determination Act of 1996” for “the mutual help ownership opportunity program under section 202 of the United States Housing Act of 1937”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XVIII, § 1816(2)], substituted “the 50 States and the District of Columbia” for “all States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (11) to (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XVIII, § 1816(3), (4)], added par. (11) and redesignated former pars. (11) and (12) as (12) and (13), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e4a8a1c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e4a8a1d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", and effective with respect to appropriations for use under this subchapter beginning fiscal year 2017, except as otherwise provided in such amendment, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
