{"tag":"section","attrib":{"id":"id0e625842-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9518"},"text":null,"children":[{"tag":"num","attrib":{"value":"9518"},"text":"§ 9518.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Institute may carry out research projects of common interest with entities such as the National Science Foundation and the Eunice Kennedy Shriver National Institute of Child Health and Human Development through agreements with such entities that are in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1231"},"text":"section 1231 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e625843-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s118"},"text":"Pub. L. 107–279, title I, § 118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1953"},"text":"116 Stat. 1953","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/154/s1/d"},"text":"Pub. L. 110–154, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-21"},"text":"Dec. 21, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1828"},"text":"121 Stat. 1828","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e625844-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e625845-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","