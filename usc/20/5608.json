{"tag":"section","attrib":{"id":"id0df7128a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5608"},"text":null,"children":[{"tag":"num","attrib":{"value":"5608"},"text":"§ 5608.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0df7128b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5608/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to carry out the provisions of this chapter, the Foundation may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0df7128c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5608/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0df7128d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5608/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint such personnel as may be necessary to carry out the provisions of this chapter, without regard to the provisions of title 5 governing appointments in the competitive service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df7128e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5608/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fix the compensation of the personnel appointed under subparagraph (A) at a rate not to exceed the maximum rate for employees in grade GS–15 of the General Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":", except that up to 4 employees (in addition to the Executive Director under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s5603/f/2"},"text":"section 5603(f)(2) of this title","children":[],"tail":") may be paid at a rate determined by the Board in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5383"},"text":"section 5383 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df7128f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5608/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure or fund the Center to procure temporary and intermittent services of experts and consultants as are necessary to the extent authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":", but at rates not to exceed the rate specified at the time of such service for level IV of the Executive Schedule under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df71290-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5608/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe such regulations as the Foundation considers necessary governing the manner in which its functions shall be carried out;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df71291-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5608/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept, hold, solicit, administer, and utilize donations, grants, and gifts, both real and personal, for the purpose of aiding or facilitating the work of the Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df71292-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5608/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept and utilize the services of voluntary and noncompensated personnel and reimburse such personnel for travel expenses, including per diem, as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df71293-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5608/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into contracts, grants, or other arrangements or modifications thereof, to carry out the provisions of this chapter, and such contracts or modifications thereof may, with the concurrence of two-thirds of the members of the Board of Trustees, be entered into without performance or other bonds, and without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df71294-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5608/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ","children":[{"tag":"ref","attrib":{"idref":"fn002190"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002190"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “to” probably should not appear."}],"tail":" rent office space in the District of Columbia and Tucson, Arizona, or their environs; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df71295-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5608/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make other necessary expenditures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0df71296-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5608/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" The Institute","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authorities set forth above shall apply to the National Center established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5607a"},"text":"section 5607a of this title","children":[],"tail":" and to the activities of the Foundation under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s5604/7"},"text":"section 5604(7) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0df71297-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/259/s12"},"text":"Pub. L. 102–259, § 12","children":[],"tail":", formerly § 10, "},{"tag":"date","attrib":{"date":"1992-03-19"},"text":"Mar. 19, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/83"},"text":"106 Stat. 83","children":[],"tail":"; renumbered § 12, "},{"tag":"ref","attrib":{"href":"/us/pl/105/156/s6/a"},"text":"Pub. L. 105–156, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-02-11"},"text":"Feb. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/9"},"text":"112 Stat. 9","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/h/tV/s517/b"},"text"