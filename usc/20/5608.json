101"},"text":"section 6101 of title 41","children":[],"tail":"” substituted for “section 3709 of the Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s5"},"text":"41 U.S.C. 5","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0df7129b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s308/1/A"},"text":"Pub. L. 116–94, § 308(1)(A)","children":[],"tail":", substituted “accept, hold, solicit, administer, and utilize donations, grants, and gifts” for “accept, hold, administer, and utilize gifts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s308/1/B"},"text":"Pub. L. 116–94, § 308(1)(B)","children":[],"tail":", substituted “in the District of Columbia and Tucson, Arizona, or their environs” for “in the District of Columbia or its environs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s308/2"},"text":"Pub. L. 116–94, § 308(2)","children":[],"tail":", substituted “apply to the National Center” for “, with the exception of paragraph (4), apply to the Institute”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/90/s10/1"},"text":"Pub. L. 111–90, § 10(1)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “appoint and fix the compensation of such personnel as may be necessary to carry out the provisions of this chapter, except that in no case shall employees other than the Executive Director be compensated at a rate to exceed the maximum rate for employees in grade GS–15 of the General Schedule under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":";”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/90/s10/2"},"text":"Pub. L. 111–90, § 10(2)","children":[],"tail":"–(4), added par. (7) and redesignated former par. (7) as (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568"},"text":"Pub. L. 106–568","children":[],"tail":" inserted before period at end “and to the activities of the Foundation under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s5604/7"},"text":"section 5604(7) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
