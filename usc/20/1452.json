{"tag":"section","attrib":{"id":"id0dad38ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452"},"text":null,"children":[{"tag":"num","attrib":{"value":"1452"},"text":"§ 1452.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility and collaborative process","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dad38eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible applicants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State educational agency may apply for a grant under this part for a grant period of not less than 1 year and not more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dad38ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partners","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dad38ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to be considered for a grant under this part, a State educational agency shall establish a partnership with local educational agencies and other State agencies involved in, or concerned with, the education of children with disabilities, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dad38ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 1 institution of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State agencies responsible for administering subchapter III, early education, child care, and vocational rehabilitation programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad38f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other partners","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to be considered for a grant under this part, a State educational agency shall work in partnership with other persons and organizations involved in, and concerned with, the education of children with disabilities, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dad38f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Governor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parents of children with disabilities ages birth through 26;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parents of nondisabled children ages birth through 26;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parent training and information centers or community parent resource centers funded under sections 1471 and 1472 of this title, respectively;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community based and other nonprofit organizations involved in the education and employment of individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1451/b"},"text":"section 1451(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State advisory panel established under subchapter II;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State interagency coordinating council established under subchapter III;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals knowledgeable about vocational education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/b/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State agency for higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/b/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public agencies with jurisdiction in the areas of health, mental health, social services, and juvenile justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/b/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other providers of professional development that work with infants, toddlers, preschoolers, and children with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad38fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/b/2/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad38ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required partner","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If State law assigns responsibility for teacher preparation and certification to an individual, entity, or agency other than the State educational agency, the State educational agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dad3900-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include that individual, entity, or agency as a partner in the partnership under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad3901-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1452/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that any activities the State educational agency will carry out under this part that are within that partner’s jurisdiction (which may include activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1454/b"},"text":"section 1454(b) of this title","children":[],"tail":") are carried out by that partner."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dad3902-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s652"},"text":"Pub. L. 91–230, title VI, § 652","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2767"},"text":"118 Stat. 2767","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dad3903-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dad3904-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0dad3905-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1452, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s652"},"text":"Pub. L. 91–230, title VI, § 652","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/17/tI/s101"},"text":"Pub. L. 105–17, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-04"},"text":"June 4, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/124"},"text":"111 Stat. 124","children":[],"tail":", related to eligibility and collaborative process, prior to the general amendment of subchapters I to IV of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/108/446"},"text":"Pub. L. 108–446","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"