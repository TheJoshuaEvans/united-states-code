{"tag":"section","attrib":{"id":"id0e6258a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9541"},"text":null,"children":[{"tag":"num","attrib":{"value":"9541"},"text":"§ 9541.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e6258a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9541/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Institute a National Center for Education Statistics (in this part referred to as the “Statistics Center”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6258a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9541/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The mission of the Statistics Center shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e6258a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9541/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to collect and analyze education information and statistics in a manner that meets the highest methodological standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6258a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9541/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to report education information and statistics in a timely manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6258aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9541/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to collect, analyze, and report education information and statistics in a manner that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e6258ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9541/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is objective, secular, neutral, and nonideological and is free of partisan political influence and racial, cultural, gender, or regional bias; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6258ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9541/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is relevant and useful to practitioners, researchers, policymakers, and the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e6258ad-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s151"},"text":"Pub. L. 107–279, title I, § 151","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1957"},"text":"116 Stat. 1957","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
