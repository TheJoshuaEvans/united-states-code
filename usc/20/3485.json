{"tag":"section","attrib":{"id":"id0dda8ac8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3485"},"text":null,"children":[{"tag":"num","attrib":{"value":"3485"},"text":"§ 3485.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seal of Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall cause a seal of office to be made for the Department of such design as the Secretary shall approve. Judicial notice shall be taken of such seal.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0dda8ac9-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIV/s425"},"text":"Pub. L. 96–88, title IV, § 425","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/688"},"text":"93 Stat. 688","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
