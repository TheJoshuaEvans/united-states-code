{"tag":"section","attrib":{"id":"id0ded9da9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4508"},"text":null,"children":[{"tag":"num","attrib":{"value":"4508"},"text":"§ 4508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of fellowships","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each student awarded a fellowship shall receive a stipend which shall not exceed the cost to the student for tuition, fees, books, room and board, or $12,000, whichever is less, for each academic year of study.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0ded9daa-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/b/tVIII/s809"},"text":"Pub. L. 99–500, § 101(b) [title VIII, § 809]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-39"},"text":"100 Stat. 1783–39","children":[],"tail":", 1783–78, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/b/tVIII/s809"},"text":"Pub. L. 99–591, § 101(b) [title VIII, § 809]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-39"},"text":"100 Stat. 3341–39","children":[],"tail":", 3341–78.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ded9dab-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ded9dac-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0ded9dad-3a70-11f1-a648-bee82ed8a795"},"text":null,"childre