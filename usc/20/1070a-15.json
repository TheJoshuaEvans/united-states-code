{"tag":"section","attrib":{"id":"id0ce75057-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070a–15"},"text":"§ 1070a–15.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postbaccalaureate achievement program authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ce75058-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a program to be known as the “Ronald E. McNair Postbaccalaureate Achievement Program” that shall be designed to provide disadvantaged college students with effective preparation for doctoral study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce75059-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project assisted under this section shall provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce7505a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities for research or other scholarly activities at the institution or at graduate centers designed to provide students with effective preparation for doctoral study;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce7505b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summer internships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce7505c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seminars and other educational activities designed to prepare students for doctoral study;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce7505d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tutoring;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce7505e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic counseling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce7505f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities designed to assist students participating in the project in securing admission to and financial assistance for enrollment in graduate programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce75060-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project assisted under this section may provide services such as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce75061-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education or counseling services designed to improve the financial literacy and economic literacy of students, including financial planning for postsecondary education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75062-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mentoring programs involving faculty members at institutions of higher education, students, or any combination of such persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75063-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exposure to cultural events and academic programs not usually available to disadvantaged students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce75064-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In approving applications for projects assisted under this section for any fiscal year, the Secretary shall require—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce75065-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that not less than two-thirds of the individuals participating in the project proposed to be carried out under any application be low-income individuals who are first generation college students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75066-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assurance that the remaining persons participating in the project proposed to be carried out be from a group that is underrepresented in graduate education, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce75067-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Alaska Natives, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7546"},"text":"section 7546 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce75068-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Native Hawaiians, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7517"},"text":"section 7517 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce75069-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Native American Pacific Islanders, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059g"},"text":"section 1059g of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce7506a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that participants be enrolled in a degree program at an eligible institution having an agreement with the Secretary in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1094"},"text":"section 1094 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce7506b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that participants in summer research internships have completed their sophomore year in postsecondary education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce7506c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to such other selection criteria as may be prescribed by regulations, the Secretary shall consider in making awards to institutions under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce7506d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quality of research and other scholarly activities in which students will be involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce7506e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of faculty involvement in the project and the description of the research in which students will be involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce7506f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution’s plan for identifying and recruiting participants including students enrolled in projects authorized under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce75070-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum stipends","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Students participating in research under a project under this section may receive an award that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce75071-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include a stipend not to exceed $2,800 per annum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75072-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include, in addition, the costs of summer tuition, summer room and board, and transportation to summer programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce75073-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–15/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts appropriated pursuant to the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–11/g"},"text":"section 1070a–11(g) of this title","children":[],"tail":", the Secretary shall, to the extent practicable, allocate funds for projects authorized by this section in an amount which is not less than $11,000,000 for each of the fiscal years 2009 through 2014."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ce99a64-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s402E"},"text":"Pub. L. 89–329, title IV, § 402E","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s402/a/4"},"text":"Pub. L. 102–325, title IV, § 402(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/489"},"text":"106 Stat. 489","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s402/e"},"text":"Pub. L. 105–244, title IV, § 402(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1655"},"text":"112 Stat. 1655","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s403/e"},"text":"Pub. L. 110–315, title IV, § 403(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3203"},"text":"122 Stat. 3203","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tIV/s401/a/5"},"text":"Pub. L. 111–39, title IV, § 401(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1938"},"text":"123 Stat. 1938","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215"},"text":"Pub. L. 114–95, title IX, § 9215","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"oo","children":[],"tail":")(7), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2179"},"text":"129 Stat. 2179","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ce99a65-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ce99a66-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0ce99a67-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9215"},"text":"Pub. L. 114–95, § 9215","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"oo","children":[],"tail":")(7)(A), made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7546"},"text":"section 7546 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9215"},"text":"Pub. L. 114–95, § 9215","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"oo","children":[],"tail":")(7)(B), made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7517"},"text":"section 7517 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (d)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" struck out period before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/e/1/A"},"text":"Pub. L. 110–315, § 403(e)(1)(A)","children":[],"tail":", (B), inserted “Required” before “services” in heading and, in introductory provisions, substituted “A project assisted under this section shall provide—” for “A postbaccalaureate achievement project assisted under this section may provide services such as—”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/e/1/C"},"text":"Pub. L. 110–315, § 403(e)(1)(C)","children":[],"tail":"–(E), inserted “and” after the semicolon in par. (5), substituted a period for the semicolon in par. (6), and struck out pars. (7) and (8) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(7) mentoring programs involving faculty members at institutions of higher education, students, or any combination of such persons; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(8) exposure to cultural events and academic programs not usually available to disadvantaged students.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/e/3"},"text":"Pub. L. 110–315, § 403(e)(3)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/e/2"},"text":"Pub. L. 110–315, § 403(e)(2)","children":[],"tail":", (4)(A), redesignated subsec. (c) as (d) and struck out “postbaccalaureate achievement” after “applications for” in introductory provisions. Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/e/4/B"},"text":"Pub. L. 110–315, § 403(e)(4)(B)","children":[],"tail":", inserted “, including—” and added subpars. (A) to (C) before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/e/2"},"text":"Pub. L. 110–315, § 403(e)(2)","children":[],"tail":", redesignated subsec. (d) as (e). Former subsec. (e) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/e/2"},"text":"Pub. L. 110–315, § 403(e)(2)","children":[],"tail":", (5), redesignated subsec. (e) as (f) and substituted “project under this section” for “postbaccalaureate achievement project” in introductory provisions. Former subsec. (f) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/e/2"},"text":"Pub. L. 110–315, § 403(e)(2)","children":[],"tail":", (6), redesignated subsec. (f) as (g) and substituted “section 1070a–11(g)” for “section 1070a–11(f)” and “2009 through 2014” for “1993 through 1997”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" substituted “$2,800” for “$2,400”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0ce99a68-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0ce99a69-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0ce99a6a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" effective as if enacted on the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/s3"},"text":"section 3 of Pub. L. 111–39","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0ce99a6b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
