{"tag":"section","attrib":{"id":"id0e5d9cff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9171"},"text":null,"children":[{"tag":"num","attrib":{"value":"9171"},"text":"§ 9171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e5d9d00-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9171/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage and support museums in carrying out their educational role, as core providers of learning and in conjunction with schools, families, and communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5d9d01-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9171/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage and support museums in carrying out their public service role of connecting the whole of society to the cultural, artistic, historical, natural, and scientific understandings that constitute our diverse heritage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5d9d02-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9171/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage leadership, innovation, and applications of the most current technologies and practices to enhance museum services through international, national, regional, State, and local networks and partnerships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5d9d03-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9171/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist, encourage, and support museums in carrying out their stewardship responsibilities to achieve the highest standards in conservation and care of the diverse cultural, historic, natural, and scientific heritage of the United States to benefit future generations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5d9d04-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9171/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist, encourage, and support museums in achieving the highest standards of management and service to the public, and to ease the financial burden borne by museums as they serve their communities in new and different ways;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5d9d05-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9171/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support resource sharing and partnerships among museums, libraries, schools, and other community organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5d9d06-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9171/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage and support museums as a part of economic development and revitalization in communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5d9d07-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9171/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure museums of various types and sizes in diverse geographic regions of the United States are afforded attention and support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5d9d08-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9171/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support efforts at the State and regional levels to leverage museum resources and maximize museum services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5d9d09-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9171/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist museums in their civic engagement efforts to ensure that every person in the United States has access to high-quality museum services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e5d9d0a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/462/tII/s272"},"text":"Pub. L. 94–462, title II, § 272","children":[],"tail":", formerly § 271, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/e/tVII/s702"},"text":"Pub. L. 104–208, div. A, title I, § 101(e) [title VII, § 702]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-233"},"text":"110 Stat. 3009–233","children":[],"tail":", 3009–302; renumbered § 272 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/81/tIII"},"text":"Pub. L. 108–81, title III","children":[],"tail":", §§ 301, 306(1), "},{"tag":"date","attrib":{"date":"2003-09-25"},"text":"Sept. 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1000"},"text":"117 Stat. 1000","children":[],"tail":", 1002; "},{"tag":"ref","attrib":{"href":"/us/pl/111/340/tIII/s301"},"text":"Pub. L. 111–340, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3603"},"text":"124 Stat. 3603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/410/s16"},"text":"Pub. L. 115–410, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5419"},"text":"132 Stat. 5419","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e5d9d0b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e5d9d0c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e5d9d0d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/462/s272"},"text":"section 272 of Pub. L. 94–462","children":[],"tail":" was renumbered section 273 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9172"},"text":"section 9172 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e5d9d0e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/410/s16/1"},"text":"Pub. L. 115–410, § 16(1)","children":[],"tail":", (2), redesignated par. (2) as (1) and struck out former par. (1) which read as follows: “to encourage and support museums in carrying out their public service role of connecting the whole of society to the cultural, artistic, historical, natural, and scientific understandings that constitute our heritage;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/410/s16/3"},"text":"Pub. L. 115–410, § 16(3)","children":[],"tail":", added par. (2). Former par. (2) redesignated (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/410/s16/4"},"text":"Pub. L. 115–410, § 16(4)","children":[],"tail":", inserted “diverse” before “cultural”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/410/s16/5"},"text":"Pub. L. 115–410, § 16(5)","children":[],"tail":", substituted “as they serve their communities in new and different ways” for “as a result of their increasing use by the public”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/410/s16/7"},"text":"Pub. L. 115–410, § 16(7)","children":[],"tail":", substituted “State and regional levels” for “State level” and “services; and” for “services.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/410/s16/6"},"text":"Pub. L. 115–410, § 16(6)","children":[],"tail":", (8), added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/340/s301/1"},"text":"Pub. L. 111–340, § 301(1)","children":[],"tail":", inserted “through international, national, regional, State, and local networks and partnerships” after “services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (7) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/340/s301/2"},"text":"Pub. L. 111–340, § 301(2)","children":[],"tail":"–(4), added pars. (7) to (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/81/s301"},"text":"Pub. L. 108–81, § 301","children":[],"tail":", amended section catchline and text generally. Prior to amendment, text read as follows: “It is the purpose of this subchapter—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) to encourage and assist museums in their educational role, in conjunction with formal systems of elementary, secondary, and postsecondary education and with programs of nonformal education for all age groups;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) to assist museums in modernizing their methods and facilities so that the museums are better able to conserve the cultural, historic, and scientific heritage of the United States; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) to ease the financial burden borne by museums as a result of their increasing use by the public.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
