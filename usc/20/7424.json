{"tag":"section","attrib":{"id":"id0e350681-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424"},"text":null,"children":[{"tag":"num","attrib":{"value":"7424"},"text":"§ 7424.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e350682-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7422/a"},"text":"section 7422(a) of this title","children":[],"tail":" that desires to receive a grant under this subpart shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may reasonably require."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e350683-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive program required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application submitted under subsection (a) shall include a description of a comprehensive program for meeting the needs of Indian children served by the local educational agency, including the language and cultural needs of the children, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e350684-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes how the comprehensive program will offer programs and activities to meet the culturally related academic needs of Indian students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e350685-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e350686-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with the State, tribal, and local plans submitted under other provisions of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e350687-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes program objectives and outcomes for activities under this subpart that are based on the same challenging State academic standards developed by the State under subchapter I for all students;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e350688-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explains how the grantee will use funds made available under this subpart to supplement other Federal, State, and local programs that meet the needs of Indian students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e350689-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates how funds made available under this subpart will be used for activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7425"},"text":"section 7425 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e35068a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describes the professional development opportunities that will be provided, as needed, to ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e35068b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" teachers and other school professionals who are new to the Indian community are prepared to work with Indian children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e35068c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all teachers who will be involved in programs assisted under this subpart have been properly trained to carry out such programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e35068d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describes how the local educational agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e35068e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will periodically assess the progress of all Indian children enrolled in the schools of the local educational agency, including Indian children who do not participate in programs assisted under this subpart, in meeting the goals described in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e35068f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" will provide the results of each assessment referred to in subparagraph (A) to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e350690-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/b/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the committee described in subsection (c)(4);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e350691-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/b/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the community served by the local educational agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e350692-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/b/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian tribes whose children are served by the local educational agency, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232g"},"text":"section 1232g of this title","children":[],"tail":" (commonly referred to as the “Family Educational Rights and Privacy Act of 1974”); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e350693-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is responding to findings of any previous assessments that are similar to the assessments described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e350694-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the process the local educational agency used to meaningfully collaborate with Indian tribes located in the community in a timely, active, and ongoing manner in the development of the comprehensive program and the actions taken as a result of such collaboration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e350695-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assurances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application submitted under subsection (a) shall include assurances that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e350696-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the local educational agency will use funds received under this subpart only to supplement the funds that, in the absence of the Federal funds made available under this subpart, such agency would make available for services described in this subsection, and not to supplant such funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e350697-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the local educational agency will prepare and submit to the Secretary such reports, in such form and containing such information, as the Secretary may require to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e350698-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out the functions of the Secretary under this subpart;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e350699-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the extent to which activities carried out with funds provided to the local educational agency under this subpart are effective in improving the educational achievement of Indian students served by such agency, and meet program objectives and outcomes for activities under this subpart; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e35069a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the extent to which such activities by the local educational agency address the unique cultural, language, and educational needs of Indian students;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e35069b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the program for which assistance is sought—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e35069c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is based on a comprehensive local assessment and prioritization of the unique educational and culturally related academic needs of the Indian students for whom the local educational agency is providing an education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e35069d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will use the best available talents and resources, including individuals from the Indian community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e35069e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was developed by such agency in open consultation with parents of Indian children and teachers, representatives of Indian tribes on Indian lands located within 50 miles of any school that the agency will serve if such tribes have any children in such school, Indian organizations, and, if appropriate, Indian students from secondary schools, including through public hearings held by such agency to provide to the individuals described in this subparagraph a full opportunity to understand the program and to offer recommendations regarding the program;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e35069f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the local educational agency developed the program with the participation and written approval of a committee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e3506a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is composed of, and selected by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e3506a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parents and family members of Indian children in the local educational agency’s schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3506a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of Indian tribes on Indian lands located within 50 miles of any school that the agency will serve if such tribes have any children in such school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3506a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" teachers in the schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3506a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if appropriate, Indian students attending secondary schools of the agency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3506a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a majority of whose members are parents and family members of Indian children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3506a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to an application describing a schoolwide program in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7425/c"},"text":"section 7425(c) of this title","children":[],"tail":", that has—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0e3506a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewed in a timely fashion the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3506a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined that the program will not diminish the availability of culturally related activities for Indian students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3506a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined that the program will directly enhance the educational experience of Indian students; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3506aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has adopted reasonable bylaws for the conduct of the activities of the committee and abides by such bylaws;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3506ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the local educational agency will coordinate activities under this subchapter with other Federal programs supporting educational and related services administered by such agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3506ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the local educational agency conducted outreach to parents and family members to meet the requirements under this paragraph;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3506ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the local educational agency will use funds received under this subpart only for activities described and authorized in this subpart; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3506ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the local educational agency has set forth such policies and procedures, including policies and procedures relating to the hiring of personnel, as will ensure that the program for which assistance is sought will be operated and evaluated in consultation with, and with the involvement of, parents and family members of the children, and representatives of the area, to be served.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e3506af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, directly or by contract, provide technical assistance to a local educational agency or Bureau of Indian Education school upon request (in addition to any technical assistance available under other provisions of this chapter or available through the Institute of Education Sciences) to support the services and activities provided under this subpart, including technical assistance for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e3506b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of applications under this subpart, including identifying eligible entities that have not applied for such grants and undertaking appropriate activities to encourage such entities to apply for grants under this subpart;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3506b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improvement in the quality of implementation, content, and evaluation of activities supported under this subpart; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3506b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7424/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integration of activities under this subpart with other educational activities carried out by the local educational agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e3506b3-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVI/s6114"},"text":"Pub. L. 89–10, title VI, § 6114","children":[],"tail":", formerly title VII, § 7114, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVII/s701"},"text":"Pub. L. 107–110, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1910"},"text":"115 Stat. 1910","children":[],"tail":", renumbered title VI, § 6114, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVI"},"text":"Pub. L. 114–95, title VI","children":[],"tail":", §§ 6001(a), (b)(1), (4), § 6002(f), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2046"},"text":"129 Stat. 2046","children":[],"tail":", 2049.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e3506b4-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e3506b5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e3506b6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7424, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVII/s7114"},"text":"Pub. L. 89–10, title VII, § 7114","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3721"},"text":"108 Stat. 3721","children":[],"tail":", related to comprehensive school grants, prior to the general amendment of former subchapter VII of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e3506b7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/f/1"},"text":"Pub. L. 114–95, § 6002(f)(1)","children":[],"tail":", substituted “Each entity described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7422/a"},"text":"section 7422(a) of this title","children":[],"tail":"” for “Each local educational agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/f/2/A"},"text":"Pub. L. 114–95, § 6002(f)(2)(A)","children":[],"tail":", substituted “Indian” for “American Indian and Alaska Native”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/f/2/B/i"},"text":"Pub. L. 114–95, § 6002(f)(2)(B)(i)","children":[],"tail":", substituted “is consistent with the State, tribal, and local plans” for “is consistent with the State and local plans”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/f/2/B/ii"},"text":"Pub. L. 114–95, § 6002(f)(2)(B)(ii)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “includes academic content and student academic achievement goals for such children, and benchmarks for attaining such goals, that are based on the challenging State academic content and student academic achievement standards adopted under subchapter I of this chapter for all children;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/f/2/C"},"text":"Pub. L. 114–95, § 6002(f)(2)(C)","children":[],"tail":", added par. (3) and struck out former par. (3) which read as follows: “explains how Federal, State, and local programs, especially programs carried out under subchapter I of this chapter, will meet the needs of such students;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6001/b/4/A"},"text":"Pub. L. 114–95, § 6001(b)(4)(A)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7425"},"text":"section 7425 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/f/2/E/i"},"text":"Pub. L. 114–95, § 6002(f)(2)(E)(i)","children":[],"tail":", added cl. (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/f/2/D"},"text":"Pub. L. 114–95, § 6002(f)(2)(D)","children":[],"tail":", (E)(ii), (F), added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/f/3/A"},"text":"Pub. L. 114–95, § 6002(f)(3)(A)","children":[],"tail":", substituted “for services described in this subsection,” for “for the education of Indian children,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/f/3/B/ii"},"text":"Pub. L. 114–95, § 6002(f)(3)(B)(ii)","children":[],"tail":", substituted “served by such agency, and meet program objectives and outcomes for activities under this subpart; and” for “served by such agency;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/f/3/B/i"},"text":"Pub. L. 114–95, § 6002(f)(3)(B)(i)","children":[],"tail":", (iii), added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/f/3/C/i"},"text":"Pub. L. 114–95, § 6002(f)(3)(C)(i)","children":[],"tail":", substituted “Indian” for “American Indian and Alaska Native”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/f/3/C/ii"},"text":"Pub. L. 114–95, § 6002(f)(3)(C)(ii)","children":[],"tail":", inserted “representatives of Indian tribes on Indian lands located within 50 miles of any school that the agency will serve if such tribes have any children in such school, Indian organizations,” after “parents of Indian children and teachers,” and struck out “and” after semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/f/3/D/i/I"},"text":"Pub. L. 114–95, § 6002(f)(3)(D)(i)(I)","children":[],"tail":", inserted “and family members” after “parents”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(A)(ii) to (iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/f/3/D/i/II"},"text":"Pub. L. 114–95, § 6002(f)(3)(D)(i)(II)","children":[],"tail":", (III), added cl. (ii) and redesignated former cls. (ii) and (iii) as (iii) and (iv), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/f/3/D/ii"},"text":"Pub. L. 114–95, § 6002(f)(3)(D)(ii)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “a majority of whose members are parents of Indian children;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/f/3/D/iii"},"text":"Pub. L. 114–95, § 6002(f)(3)(D)(iii)","children":[],"tail":", (iv), redesignated subpar. (D) as (C) and struck out former subpar. (C) which read as follows: “that has set forth such policies and procedures, including policies and procedures relating to the hiring of personnel, as will ensure that the program for which assistance is sought will be operated and evaluated in consultation with, and with the involvement of, parents of the children, and representatives of the area, to be served;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/f/3/D/v/II"},"text":"Pub. L. 114–95, § 6002(f)(3)(D)(v)(II)","children":[],"tail":", substituted “Indian” for “American Indian and Alaska Native”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(C)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/f/3/D/v/I"},"text":"Pub. L. 114–95, § 6002(f)(3)(D)(v)(I)","children":[],"tail":", (III), added cl. (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/f/3/D/iv"},"text":"Pub. L. 114–95, § 6002(f)(3)(D)(iv)","children":[],"tail":", (vi), redesignated subpar. (E) as (D) and substituted semicolon for period at end. Former subpar. (D) redesignated (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6001/b/4/B"},"text":"Pub. L. 114–95, § 6001(b)(4)(B)","children":[],"tail":", made technical amendment to reference in original act which appears in text of introductory provisions as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7425/c"},"text":"section 7425(c) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/f/3/D/iv"},"text":"Pub. L. 114–95, § 6002(f)(3)(D)(iv)","children":[],"tail":", redesignated subpar. (E) as (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/f/3/E"},"text":"Pub. L. 114–95, § 6002(f)(3)(E)","children":[],"tail":", added pars. (5) to (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/f/4"},"text":"Pub. L. 114–95, § 6002(f)(4)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e3506b8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e3506b9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
