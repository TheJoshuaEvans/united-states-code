{"tag":"section","attrib":{"id":"id0e2b9050-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221h"},"text":null,"children":[{"tag":"num","attrib":{"value":"7221h"},"text":"§ 7221h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Paperwork reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To the extent practicable, the Secretary and each authorized public chartering agency shall ensure that implementation of this subpart results in a minimum of paperwork for any eligible applicant or charter school.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e2b9051-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4309"},"text":"Pub. L. 89–10, title IV, § 4309","children":[],"tail":", formerly title V, § 5209, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1798"},"text":"115 Stat. 1798","children":[],"tail":"; renumbered title IV, § 4309, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4001/b/2/A"},"text":"Pub. L. 114–95, title IV, § 4001(b)(2)(A)","children":[],"tail":", (B), (D)(iii), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1967"},"text":"129 Stat. 1967","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
