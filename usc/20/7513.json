{"tag":"section","attrib":{"id":"id0e3c31d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7513"},"text":null,"children":[{"tag":"num","attrib":{"value":"7513"},"text":"§ 7513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this part are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e3c31d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7513/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize and develop innovative educational programs to assist Native Hawaiians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c31d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7513/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide direction and guidance to appropriate Federal, State, and local agencies to focus resources, including resources made available under this part, on Native Hawaiian education, and to provide periodic assessment and data collection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c31d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7513/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supplement and expand programs and authorities in the area of education to further the purposes of this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c31d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7513/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the maximum participation of Native Hawaiians in planning and management of Native Hawaiian education programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e3c31d9-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVI/s6203"},"text":"Pub. L. 89–10, title VI, § 6203","children":[],"tail":", formerly title VII, § 7203, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVII/s701"},"text":"Pub. L. 107–110, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1937"},"text":"115 Stat. 1937","children":[],"tail":"; renumbered title VI, § 6203, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVI/s6001/a"},"text":"Pub. L. 114–95, title VI, § 6001(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2046"},"text":"129 Stat. 2046","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e3c31da-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e3c31db-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e3c31dc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7513, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVII/s7203"},"text":"Pub. L. 89–10, title VII, § 7203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3737"},"text":"108 Stat. 3737","children":[],"tail":", authorized foreign language assistance program, prior to the general amendment of former subchapter VII of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
