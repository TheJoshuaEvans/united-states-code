{"tag":"section","attrib":{"id":"id0cb2d341-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s974"},"text":null,"children":[{"tag":"num","attrib":{"value":"974"},"text":"§ 974.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indemnity limits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cb2d342-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s974/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of estimated values","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon receipt of an application meeting the requirements of subsections (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s973"},"text":"section 973 of this title","children":[],"tail":", the Council shall review the estimated value of the items for which coverage by an indemnity agreement is sought. If the Council agrees with such estimated value, for the purposes of this chapter, the Council shall, after approval of the application as provided in subsection (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s973"},"text":"section 973 of this title","children":[],"tail":", make an indemnity agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cb2d343-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s974/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum limits of coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The aggregate of loss or damage covered by indemnity agreements made under this chapter shall not exceed $15,000,000,000 at any one time for international exhibitions, and $7,500,000,000 at any one time for domestic exhibitions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cb2d344-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s974/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit for single exhibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No indemnity agreement for a single exhibition shall cover loss or damage in excess of $1,800,000,000 for international exhibitions, or $1,000,000,000 for domestic exhibitions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cb2d345-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s974/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deductible limit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the estimated value of the items covered by an indemnity agreement for a single exhibition is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cb2d346-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s974/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000 or less, then coverage under this chapter shall extend only to loss or damage in excess of the first $15,000 of loss or damage to items covered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cb2d347-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s974/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than $2,000,000 but less than $10,000,000 then coverage under this chapter shall extend only to loss or damage in excess of the first $25,000 of loss or damage to items covered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cb2d348-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s974/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $10,000,000 but less than $125,000,000, then coverage under this chapter shall extend to loss or damage in excess of the first $50,000 of loss or damage to items covered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cb2d349-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s974/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $125,000,000 but less than $200,000,","children":[{"tag":"ref","attrib":{"idref":"fn002025"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002025"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “$200,000,000,”."}],"tail":" then coverage under this chapter shall extend to loss or damage in excess of the first $100,000 of loss or damage to items covered;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cb2d34a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s974/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $200,000,000 but less than $300,000,000, then coverage under the ","children":[{"tag":"ref","attrib":{"idref":"fn002026"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002026"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “this”."}],"tail":" chapter shall extend only to loss or damage in excess of the first $200,000, of loss or damage to items covered;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cb2d34b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s974/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $300,000,000 but less than $400,000,000, then coverage under this chapter shall extend only to loss or damage in excess of the first $300,000 of loss or damage to items covered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cb2d34c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s974/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $400,000,000 but less than $500,000,000, then coverage under this chapter shall extend only to loss or damage in excess of the first $400,000 of loss or damage to items covered; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cb2d34d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s974/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $500,000,000 or more, then coverage under this chapter shall extend only to loss or damage in excess of the first $500,000 of loss or damage to items covered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cb2d34e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/158/s5"},"text":"Pub. L. 94–158, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-20"},"text":"Dec. 20, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/845"},"text":"89 Stat. 845","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/496/tIII"},"text":"Pub. L. 96–496, title III","children":[],"tail":", §§ 301, 302, "},{"tag":"date","attrib":{"date":"1980-12-04"},"text":"Dec. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2593"},"text":"94 Stat. 2593","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/194/tIII/s303"},"text":"Pub. L. 99–194, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-20"},"text":"Dec. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1345"},"text":"99 Stat. 1345","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/g/tII/s201"},"text":"Pub. L. 100–202, § 101(g) [title II, § 201]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-213"},"text":"101 Stat. 1329–213","children":[],"tail":", 1329–249; "},{"tag":"ref","attrib":{"href":"/us/pl/101/512/tIII/s318/tIII/s301"},"text":"Pub. L. 101–512, title III, § 318 [title III, § 301]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1960"},"text":"104 Stat. 1960","children":[],"tail":", 1976; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tIII/s333"},"text":"Pub. L. 105–277, div. A, § 101(e) [title III, § 333]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–294; "},{"tag":"ref","attrib":{"href":"/us/pl/108/81/tV/s501"},"text":"Pub. L. 108–81, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-25"},"text":"Sept. 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1003"},"text":"117 Stat. 1003","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/54/tIV/s427"},"text":"Pub. L. 109–54, title IV, § 427","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/555"},"text":"119 Stat. 555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dF/tIV/s426/2"},"text":"Pub. L. 110–161, div. F, title IV, § 426(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2151"},"text":"121 Stat. 2151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dF/tIV/s416"},"text":"Pub. L. 113–235, div. F, title IV, § 416","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2448"},"text":"128 Stat. 2448","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cb2d34f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cb2d350-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cb2d351-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s416/1"},"text":"Pub. L. 113–235, § 416(1)","children":[],"tail":", substituted “$15,000,000,000” for “$10,000,000,000” and “$7,500,000,000” for “$5,000,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s416/2"},"text":"Pub. L. 113–235, § 416(2)","children":[],"tail":", substituted “$1,800,000,000” for “$1,200,000,000” and “$1,000,000,000” for “$750,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s426/2"},"text":"Pub. L. 110–161, § 426(2)","children":[],"tail":", inserted “for international exhibitions, and $5,000,000,000 at any one time for domestic exhibitions” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s426/3"},"text":"Pub. L. 110–161, § 426(3)","children":[],"tail":", inserted “for international exhibitions, or $750,000,000 for domestic exhibitions” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/54/s427/1"},"text":"Pub. L. 109–54, § 427(1)","children":[],"tail":", substituted “$10,000,000,000” for “8,000,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/54/s427/2"},"text":"Pub. L. 109–54, § 427(2)","children":[],"tail":", substituted “$1,200,000,000” for “$600,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/81/s501/1"},"text":"Pub. L. 108–81, § 501(1)","children":[],"tail":", substituted “$8,000,000,000” for “$5,000,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/81/s501/2"},"text":"Pub. L. 108–81, § 501(2)","children":[],"tail":", substituted “$600,000,000” for “$500,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/81/s501/3"},"text":"Pub. L. 108–81, § 501(3)","children":[],"tail":", added pars. (7) and (8) and struck out former par. (7) which read as follows: “$400,000,000 or more, then coverage under this chapter shall extend only to loss or damage in excess of the first $400,000 of loss or damage to items covered.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/e/tIII/s333/1"},"text":"Pub. L. 105–277, § 101(e) [title III, § 333(1)]","children":[],"tail":", substituted “$5,000,000,000” for “$3,000,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/e/tIII/s333/2"},"text":"Pub. L. 105–277, § 101(e) [title III, § 333(2)]","children":[],"tail":", substituted “$500,000,000” for “$300,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/e/tIII/s333/3"},"text":"Pub. L. 105–277, § 101(e) [title III, § 333(3)]","children":[],"tail":", struck out “or” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/e/tIII/s333/4"},"text":"Pub. L. 105–277, § 101(e) [title III, § 333(4)]","children":[],"tail":", substituted “not less than $200,000,000 but less than $300,000,000” for “$200,000,000 or more” and substituted semicolon for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/e/tIII/s333/5"},"text":"Pub. L. 105–277, § 101(e) [title III, § 333(5)]","children":[],"tail":", added pars. (6) and (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/512/s318/tIII/s301/a"},"text":"Pub. L. 101–512, § 318 [title III, § 301(a)]","children":[],"tail":", substituted “$3,000,000,000” for “$1,200,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/512/s318/tIII/s301/b/1"},"text":"Pub. L. 101–512, § 318 [title III, § 301(b)(1)]","children":[],"tail":", substituted “$300,000,000” for “$125,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/512/s318/tIII/s301/b/2/B"},"text":"Pub. L. 101–512, § 318 [title III, § 301(b)(2)(B)]","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows: “$10,000,000 or more, then coverage under this chapter shall extend only to loss or damage in excess of the first $50,000 of loss or damage to items covered.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/512/s318/tIII/s301/b/2/A"},"text":"Pub. L. 101–512, § 318 [title III, § 301(b)(2)(A), (C)]","children":[],"tail":", added pars. (4) and (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" substituted “$1,200,000,000” for “$650,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" substituted “$125,000,000” for “$75,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/194/s303/a"},"text":"Pub. L. 99–194, § 303(a)","children":[],"tail":", substituted “$650,000,000” for “$400,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/194/s303/b"},"text":"Pub. L. 99–194, § 303(b)","children":[],"tail":", substituted “$75,000,000” for “$50,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/496/s301"},"text":"Pub. L. 96–496, § 301","children":[],"tail":", substituted “$400,000,000” for “$250,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/496/s302"},"text":"Pub. L. 96–496, § 302","children":[],"tail":", substituted provisions relating to deductible amounts under indemnity agreements for provisions limiting coverage under this chapter to loss or damage in excess of the first $15,000 resulting from a single exhibition."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cb2d352-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cb2d353-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/512"},"text":"Pub. L. 101–512","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see section 318 [title IV, § 403(b)] of "},{"tag":"ref","attrib":{"href":"/us/pl/101/512"},"text":"Pub. L. 101–512","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s951"},"text":"section 951 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
