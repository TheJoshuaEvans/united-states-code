{"tag":"section","attrib":{"id":"id0e0c963f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6332"},"text":null,"children":[{"tag":"num","attrib":{"value":"6332"},"text":"§ 6332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e0c9640-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6332/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation formula","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6302/a"},"text":"section 6302(a) of this title","children":[],"tail":" to carry out this part for each of fiscal years 2017–2020 (referred to in this subsection as the current fiscal year)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0c9641-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6332/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the amount made available to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333"},"text":"section 6333 of this title","children":[],"tail":" for fiscal year 2001 shall be allocated in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333"},"text":"section 6333 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c9642-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6332/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the amount made available to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6334"},"text":"section 6334 of this title","children":[],"tail":" for fiscal year 2001 shall be allocated in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6334"},"text":"section 6334 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c9643-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6332/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to 100 percent of the amount, if any, by which the total amount made available under this subsection for the current fiscal year for which the determination is made exceeds the total amount available to carry out sections 6333 and 6334 of this title for fiscal year 2001 shall be used to carry out sections 6335 and 6337 of this title and such amount shall be divided equally between sections 6335 and 6337 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0c9644-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6332/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments where necessitated by appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0c9645-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6332/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the sums available under this subpart for any fiscal year are insufficient to pay the full amounts that all local educational agencies in States are eligible to receive under sections 6333, 6334, and 6335 of this title for such year, the Secretary shall ratably reduce the allocations to such local educational agencies, subject to subsections (c) and (d) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c9646-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6332/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If additional funds become available for making payments under sections 6333, 6334, and 6335 of this title for such fiscal year, allocations that were reduced under paragraph (1) shall be increased on the same basis as they were reduced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0c9647-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6332/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hold-harmless amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0c9648-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6332/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts for sections 6333, 6334, and 6335","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each fiscal year, the amount made available to each local educational agency under each of sections 6333, 6334, and 6335 of this title shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0c9649-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6332/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 95 percent of the amount made available for the preceding fiscal year if the number of children counted for grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333"},"text":"section 6333 of this title","children":[],"tail":" is not less than 30 percent of the total number of children aged 5 to 17 years, inclusive, in the local educational agency;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0c964a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6332/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 90 percent of the amount made available for the preceding fiscal year if the percentage described in subparagraph (A) is between 15 percent and 30 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0c964b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6332/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 85 percent of the amount made available for the preceding fiscal year if the percentage described in subparagraph (A) is below 15 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c964c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6332/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If sufficient funds are appropriated, the amounts described in paragraph (1) shall be paid to all local educational agencies that received grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6334"},"text":"section 6334 of this title","children":[],"tail":" for the preceding fiscal year, regardless of whether the local educational agency meets the minimum eligibility criteria for that fiscal year described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6334/a/1/A"},"text":"section 6334(a)(1)(A) of this title","children":[],"tail":" except that a local educational agency that does not meet such minimum eligibility criteria for 4 consecutive years shall no longer be eligible to receive a hold harmless amount referred to in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c964d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6332/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary shall not take into consideration the hold-harmless provisions of this subsection for any fiscal year for purposes of calculating State or local allocations for the fiscal year under any program administered by the Secretary other than a program authorized under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c964e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6332/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Population data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any fiscal year for which the Secretary calculates grants on the basis of population data for counties, the Secretary shall apply the hold-harmless percentages in paragraphs (1) and (2) to counties and, if the Secretary’s allocation for a county is not sufficient to meet the hold-harmless requirements of this subsection for every local educational agency within that county, the State educational agency shall reallocate funds proportionately from all other local educational agencies in the State that are receiving funds in excess of the hold-harmless amounts specified in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0c964f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6332/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ratable reductions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0c9650-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6332/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the sums made available under this subpart for any fiscal year are insufficient to pay the full amounts that local educational agencies in all States are eligible to receive under subsection (c) for such year, the Secretary shall ratably reduce such amounts for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c9651-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6332/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If additional funds become available for making payments under subsection (c) for such fiscal year, amounts that were reduced under paragraph (1) shall be increased on the same basis as such amounts were reduced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0c9652-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6332/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this section and sections 6333, 6334, 6335, and 6337 of this title, the term “State” means each of the 50 States, the District of Columbia, and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e0c9653-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1122"},"text":"Pub. L. 89–10, title I, § 1122","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1515"},"text":"115 Stat. 1515","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tI/s1015"},"text":"Pub. L. 114–95, title I, § 1015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1878"},"text":"129 Stat. 1878","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e0c9654-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e0c9655-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e0c9656-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6332, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1122"},"text":"Pub. L. 89–10, title I, § 1122","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3562"},"text":"108 Stat. 3562","children":[],"tail":", related to allocations to States, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e0c9657-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1015/1"},"text":"Pub. L. 114–95, § 1015(1)","children":[],"tail":", substituted “2017–2020” for “2002–2007” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1015/2"},"text":"Pub. L. 114–95, § 1015(2)","children":[],"tail":", added par. (3) and struck out former par. (3) which read as follows: “an amount equal to 100 percent of the amount, if any, by which the amount made available to carry out sections 6333, 6334, and 6335 of this title for the current fiscal year for which the determination is made exceeds the amount available to carry out sections 6333 and 6334 of this title for fiscal year 2001 shall be allocated in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6335"},"text":"section 6335 of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e0c9658-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e0c9659-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
