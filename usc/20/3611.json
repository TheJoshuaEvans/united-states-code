{"tag":"section","attrib":{"id":"id0ddcd500-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3611"},"text":null,"children":[{"tag":"num","attrib":{"value":"3611"},"text":"§ 3611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ddcd501-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3611/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sums available during obligation period for asbestos detection and asbestos hazards control loan programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ddcd502-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3611/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There are authorized to be appropriated—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ddcd503-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3611/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the asbestos detection program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3604"},"text":"section 3604 of this title","children":[],"tail":", for the fiscal year ending "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":", and for the succeeding fiscal year, a total of not more than $22,500,000; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ddcd504-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3611/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the asbestos hazards control loan program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3605"},"text":"section 3605 of this title","children":[],"tail":", not more than $75,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":", and $75,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf4505-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3611/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sums appropriated under paragraph (1) of this subsection shall remain available for obligation until ","children":[{"tag":"date","attrib":{"date":"1983-09-30"},"text":"September 30, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ddf4506-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3611/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs automatically eligible for contingent extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Programs under this chapter shall be considered automatically eligible for the one-year contingent extension under section 1226a ","children":[{"tag":"ref","attrib":{"idref":"fn002153"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002153"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ddf4507-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3611/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Greatest financial need as basis for approval of applications in case of insufficient funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If funds appropriated to carry out this chapter are insufficient to pay the total amount required to make all the grants and loans authorized under this chapter, the Secretary shall establish criteria to be used in determining which applicants for grants or loans under this chapter have the greatest financial need for receiving funds under this chapter and shall make determinations regarding the approval of applications for such grants or loans in accordance with such criteria.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ddf4508-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3611/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary dependent on specific appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, the authority of the Secretary to enter into agreements, or to make payments, under this chapter shall be effective for any fiscal year only to the extent or in such amounts as are provided in appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ddf4509-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/270/s12"},"text":"Pub. L. 96–270, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-14"},"text":"June 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/497"},"text":"94 Stat. 497","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ddf450a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ddf450b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0ddf450c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1226a"},"text":"Section 1226a of this title","children":[],"tail":", referred to in subsec. (b), was in the original a reference to section 414 of the General Education Provisions Act. Section 414 of that Act was renumbered as section 422 by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tII/s212/b/1"},"text":"Pub. L. 103–382, title II, § 212(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3913"},"text":"108 Stat. 3913","children":[],"tail":", and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1226a"},"text":"section 1226a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
