 for fiscal year 1999 and the 4 succeeding fiscal years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":", which directed amendment of section 415 of the Higher Education Act of 1965 in section 415A(a)(2) by substituting “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070c–3a"},"text":"section 1070c–3a of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070c–4"},"text":"section 1070c–4 of this title","children":[],"tail":"”, was executed by making the substitution in subsec. (a)(2) of this section, which is section 415A of the Higher Education Act of 1965, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s407/c/1"},"text":"Pub. L. 105–244, § 407(c)(1)","children":[],"tail":", amended heading and text of subsec. (a) generally. Prior to amendment, text read as follows: “It is the purpose of this subpart to make incentive grants available to States to assist States in providing grants to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) eligible students attending institutions of higher education or participating in programs of study abroad that are approved for credit by institutions of higher education at which such students are enrolled; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) eligible students for campus-based community service work-study.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s407/b/1"},"text":"Pub. L. 105–244, § 407(b)(1)","children":[],"tail":", substituted “1999” for “1993”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s407/b/2"},"text":"Pub. L. 105–244, § 407(b)(2)","children":[],"tail":", (3), added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":" amended section generally. Prior to amendment, section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Purpose of Subpart","children":[],"tail":".—It is the purpose of this subpart to make incentive grants available to the States to assist them in providing grants to eligible students attending institutions of higher education and grants to eligible students for campus-based community service work learning study."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations; Availability","children":[],"tail":".—(1) There are authorized to be appropriated $85,000,000 for fiscal year 1987, and such sums as may be necessary for the 4 succeeding fiscal years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Sums appropriated pursuant to paragraph (1) for any fiscal year shall remain available for payments to States under this subpart until the end of the fiscal year succeeding the fiscal year for which such sums were appropriated.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cee7c6e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cee7c6f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","