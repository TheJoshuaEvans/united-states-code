{"tag":"section","attrib":{"id":"id0cee7c5f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070c"},"text":"§ 1070c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose; appropriations authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cee7c60-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of subpart","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this subpart to make incentive grants available to States to assist States in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cee7c61-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing grants to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cee7c62-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible students attending institutions of higher education or participating in programs of study abroad that are approved for credit by institutions of higher education at which such students are enrolled; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cee7c63-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible students for campus-based community service work-study; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cee7c64-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out the activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070c–3a"},"text":"section 1070c–3a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cee7c65-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; availability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cee7c66-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this subpart $200,000,000 for fiscal year 2009 and such sums as may be necessary for each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cee7c67-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any fiscal year for which the amount appropriated under paragraph (1) exceeds $30,000,000, the excess amount shall be available to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070c–3a"},"text":"section 1070c–3a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cee7c68-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sums appropriated pursuant to the authority of paragraph (1) for any fiscal year shall remain available for payments to States under this subpart until the end of the fiscal year succeeding the fiscal year for which such sums were appropriated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cee7c69-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s415A"},"text":"Pub. L. 89–329, title IV, § 415A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s401/a"},"text":"Pub. L. 99–498, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1332"},"text":"100 Stat. 1332","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s404/a"},"text":"Pub. L. 102–325, title IV, § 404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/506"},"text":"106 Stat. 506","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s407/b"},"text":"Pub. L. 105–244, title IV, § 407(b)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1666"},"text":"112 Stat. 1666","children":[],"tail":", 