{"tag":"section","attrib":{"id":"id0ce99a96-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070a–18"},"text":"§ 1070a–18.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports, evaluations, and grants for project improvement and dissemination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ce99a97-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to the authorizing committees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce99a98-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit annually, to the authorizing committees, a report that documents the performance of all programs funded under this division. Such report shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce99a99-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be submitted not later than 12 months after the eligible entities receiving funds under this division are required to report their performance to the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce99a9a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" focus on the programs’ performance on the relevant outcome criteria determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–11/f/4"},"text":"section 1070a–11(f)(4) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce99a9b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aggregate individual project performance data on the outcome criteria in order to provide national performance data for each program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce99a9c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include, when appropriate, descriptive data, multi-year data, and multi-cohort data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce99a9d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include comparable data on the performance nationally of low-income students, first-generation students, and students with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99a9e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide, with each report submitted under paragraph (1), information on the impact of the secondary review process described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–11/c/8/C/iv"},"text":"section 1070a–11(c)(8)(C)(iv) of this title","children":[],"tail":", including the number and type of secondary reviews, the disposition of the secondary reviews, the effect on timing of awards, and any other information the Secretary determines is necessary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce99a9f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce99aa0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce99aa1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of grants and contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of improving the effectiveness of the programs and projects assisted under this division, the Secretary shall make grants to, or enter into contracts with, institutions of higher education and other public and private institutions and organizations to rigorously evaluate the effectiveness of the programs and projects assisted under this division, including a rigorous evaluation of the programs and projects assisted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–13"},"text":"section 1070a–13 of this title","children":[],"tail":". The evaluation of the programs and projects assisted under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–13"},"text":"section 1070a–13 of this title","children":[],"tail":" shall be implemented not later than "},{"tag":"date","attrib":{"date":"2010-06-30"},"text":"June 30, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce99aa2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of upward bound evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The evaluation of the programs and projects assisted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–13"},"text":"section 1070a–13 of this title","children":[],"tail":" that is described in subparagraph (A) shall examine the characteristics of the students who benefit most from the Upward Bound program under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–13"},"text":"section 1070a–13 of this title","children":[],"tail":" and the characteristics of the programs and projects that most benefit students."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce99aa3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each evaluation described in this paragraph shall be implemented in accordance with the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99aa4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Practices","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce99aa5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The evaluations described in paragraph (1) shall identify institutional, community, and program or project practices that are effective in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0ce99aa6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing the access of low-income individuals and first-generation college students to postsecondary education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ce99aa7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preparation of such individuals and students for postsecondary education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ce99aa8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fostering the success of the individuals and students in postsecondary education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce99aa9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Primary purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any evaluation conducted under this division shall have as the evaluation’s primary purpose the identification of particular practices that further the achievement of the outcome criteria determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–11/f/4"},"text":"section 1070a–11(f)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce99aaa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination and use of evaluation findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall disseminate to eligible entities and make available to the public the practices identified under subparagraph (B). The practices may be used by eligible entities that receive assistance under this division after the dissemination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99aab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule related to evaluation participation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not require an eligible entity, as a condition for receiving, or that receives, assistance under any program or project under this division to participate in an evaluation under this section that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce99aac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires the eligible entity to recruit additional students beyond those the program or project would normally recruit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce99aad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results in the denial of services for an eligible student under the program or project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99aae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When designing an evaluation under this subsection, the Secretary shall continue to consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce99aaf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the burden placed on the program participants or the eligible entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce99ab0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the evaluation meets generally accepted standards of institutional review boards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce99ab1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may award grants to institutions of higher education or other private and public institutions and organizations, that are carrying out a program or project assisted under this division prior to ","children":[{"tag":"date","attrib":{"date":"1998-10-07"},"text":"October 7, 1998","children":[],"tail":", to enable the institutions and organizations to expand and leverage the success of such programs or projects by working in partnership with other institutions, community-based organizations, or combinations of such institutions and organizations, that are not receiving assistance under this division and are serving low-income students and first generation college students, in order to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce99ab2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate and replicate best practices of programs or projects assisted under this division; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99ab3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance regarding programs and projects assisted under this division.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce99ab4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–18/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Results","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to improve overall program or project effectiveness, the results of evaluations and grants described in this section shall be disseminated by the Secretary to similar programs or projects assisted under this subpart, as well as other individuals concerned with postsecondary access for and retention of low-income individuals and first-generation college students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ce99ab5-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s402H"},"text":"Pub. L. 89–329, title IV, § 402H","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s402/a/4"},"text":"Pub. L. 102–325, title IV, § 402(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/491"},"text":"106 Stat. 491","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s402/g"},"text":"Pub. L. 105–244, title IV, § 402(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1655"},"text":"112 Stat. 1655","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s403/h"},"text":"Pub. L. 110–315, title IV, § 403(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3204"},"text":"122 Stat. 3204","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ce99ab6-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ce99ab7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0ce99ab8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/h/1"},"text":"Pub. L. 110–315, § 403(h)(1)","children":[],"tail":", substituted “Reports, evaluations, and grants for project improvement and dissemination” for “Evaluations and grants for project improvement and dissemination partnership projects” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/h/3"},"text":"Pub. L. 110–315, § 403(h)(3)","children":[],"tail":", added subsec. (a). Former subsec. (a) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/h/2"},"text":"Pub. L. 110–315, § 403(h)(2)","children":[],"tail":", (4), redesignated subsec. (a) as (b), added pars. (1) to (4), and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1)","children":[{"tag":"inline","attrib":{},"text":" In general","children":[],"tail":".—For the purpose of improving the effectiveness of the programs and projects assisted under this division, the Secretary may make grants to or enter into contracts with institutions of higher education and other public and private institutions and organizations to evaluate the effectiveness of the programs and projects assisted under this division."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2)","children":[{"tag":"inline","attrib":{},"text":" Practices","children":[],"tail":".—The evaluations described in paragraph (1) shall identify institutional, community, and program or project practices that are particularly effective in enhancing the access of low-income individuals and first-generation college students to postsecondary education, the preparation of the individuals and students for postsecondary education, and the success of the individuals and students in postsecondary education. Such evaluations shall also investigate the effectiveness of alternative and innovative methods within Federal TRIO programs of increasing access to, and retention of, students in postsecondary education.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Former subsec. (b) redesignated (c).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/h/2"},"text":"Pub. L. 110–315, § 403(h)(2)","children":[],"tail":", redesignated subsecs. (b) and (c) as (c) and (d), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" amended section generally, revising and restating former subsecs. (a) to (c) relating to evaluation for project improvement."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0ce99ab9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0ce99aba-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
