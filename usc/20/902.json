{"tag":"section","attrib":{"id":"id0ca47ae0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s902"},"text":null,"children":[{"tag":"num","attrib":{"value":"902"},"text":"§ 902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations of Secretary of Defense","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ca47ae1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment, compensation, etc., of teachers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than the ninetieth day following ","children":[{"tag":"date","attrib":{"date":"1959-07-17"},"text":"July 17, 1959","children":[],"tail":", the Secretary of Defense shall prescribe and issue regulations to carry out the purposes of this chapter. Such regulations shall govern—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ca47ae2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s902/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of teaching positions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca47ae3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s902/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fixing of basic compensation for teachers and teaching positions at rates equal to the average of the range of rates of basic compensation for similar positions of a comparable level of duties and responsibilities in urban school jurisdictions in the United States of 100,000 or more population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca47ae4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s902/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entitlement of teachers to compensation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca47ae5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s902/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment of compensation to teachers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca47ae6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s902/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appointment of teachers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca47ae7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s902/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conditions of employment of teachers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca47ae8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s902/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the length of the school year or school years applicable to teaching positions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca47ae9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s902/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the leave system for teachers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca47aea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s902/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quarters, allowances, and additional compensation for teachers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca47aeb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s902/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other matters as may be relevant and appropriate to the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ca47aec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations prescribed and issued by the Secretary of Defense under subsection (a) of this section shall become effective on such date as the Secretary of Defense shall prescribe but not later than the ninetieth day following the date of issuance of such regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ca47aed-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/91/s4"},"text":"Pub. L. 86–91, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-07-17"},"text":"July 17, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/214"},"text":"73 Stat. 214","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/391/s1/a"},"text":"Pub. L. 89–391, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-04-14"},"text":"Apr. 14, 1966","children":[],"tail":", "},{"