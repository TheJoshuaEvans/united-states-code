{"tag":"section","attrib":{"id":"id0cf337cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–38"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070d–38"},"text":"§ 1070d–38.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stipends and scholarship conditions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cf337cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–38/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of award","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each student awarded a scholarship under this subpart shall receive a stipend of $1,500 for the academic year of study for which the scholarship is awarded, except that in no case shall the total amount of financial aid awarded to such student exceed such student’s total cost-of-attendance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cf337ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–38/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of award","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State educational agency shall establish procedures to assure that a scholar awarded a scholarship under this subpart pursues a course of study at an institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cf337cf-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s419H"},"text":"Pub. L. 89–329, title IV, § 419H","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s401/a"},"text":"Pub. L. 99–498, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1345"},"text":"100 Stat. 1345","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s406/e"},"text":"Pub. L. 102–325, title IV, § 406(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/509"},"text":"106 Stat. 509","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cf337d0-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cf337d1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cf337d2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1070d–38, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s419H"},"text":"Pub. L. 89–329, title IV, § 419H","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/558/tVIII/s801/a"},"text":"Pub. L. 98–558, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2902"},"text":"98 Stat. 2902","children":[],"tail":", related to stipends and scholarship conditions for students receiving scholarships under Robert C. Byrd Honors Scholarship Program, prior to the general revision of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cf337d3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":" inserted before period at end “, except that in no case shall the total amount of financial aid awarded to such student exceed such student’s total cost-of-attendance”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
