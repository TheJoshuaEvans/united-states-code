{"tag":"section","attrib":{"id":"id0db91f43-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2301"},"text":null,"children":[{"tag":"num","attrib":{"value":"2301"},"text":"§ 2301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this chapter is to develop more fully the academic knowledge and technical and employability skills of secondary education students and postsecondary education students who elect to enroll in career and technical education programs and programs of study, by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db91f44-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building on the efforts of States and localities to develop challenging academic and technical standards and to assist students in meeting such standards, including preparation for high skill, high wage, or in-demand occupations in current or emerging professions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db91f45-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting the development of services and activities that integrate rigorous and challenging academic and career and technical instruction, and that link secondary education and postsecondary education for participating career and technical education students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db91f46-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing State and local flexibility in providing services and activities designed to develop, implement, and improve career and technical education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db91f47-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2301/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting and disseminating national research and disseminating information on best practices that improve career and technical education programs and programs of study, services, and activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db91f48-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2301/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing technical assistance that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db91f49-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2301/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotes leadership, initial preparation, and professional development at the State and local levels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db91f4a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2301/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improves the quality of career and technical education teachers, faculty, administrators, and counselors;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db91f4b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2301/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting partnerships among secondary schools, postsecondary institutions, baccalaureate degree granting institutions, area career and technical education schools, local workforce investment boards, business and industry, and intermediaries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db91f4c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2301/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing individuals with opportunities throughout their lifetimes to develop, in conjunction with other education and training programs, the knowledge and skills needed to keep the United States competitive; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db91f4d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2301/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the employment opportunities for populations who are chronically unemployed or underemployed, including individuals with disabilities, individuals from economically disadvantaged families, out-of-workforce individuals, youth who are in, or have aged out of, the foster care system, and homeless individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0db91f4e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/s2"},"text":"Pub. L. 88–210, § 2","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/b"},"text":"Pub. L. 109–270, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/684"},"text":"120 Stat. 684","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/224/s6"},"text":"Pub. L. 115–224, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-07-31"},"text":"July 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1565"},"text":"132 Stat. 1565","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0db91f4f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0db91f50-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0db91f51-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2301, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/s2"},"text":"Pub. L. 88–210, § 2","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/332/s1/b"},"text":"Pub. L. 105–332, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3077"},"text":"112 Stat. 3077","children":[],"tail":", stated purpose of this chapter, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/109/270"},"text":"Pub. L. 109–270","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2301, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/s2"},"text":"Pub. L. 88–210, § 2","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/524/s1"},"text":"Pub. L. 98–524, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2437"},"text":"98 Stat. 2437","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/392/s2"},"text":"Pub. L. 101–392, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-09-25"},"text":"Sept. 25, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/756"},"text":"104 Stat. 756","children":[],"tail":", stated purpose of this chapter, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/332"},"text":"Pub. L. 105–332","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0db91f52-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/224/s6/1"},"text":"Pub. L. 115–224, § 6(1)","children":[],"tail":", in introductory provisions, substituted “academic knowledge and technical and employability skills” for “academic and career and technical skills” and inserted “and programs of study” after “technical education programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/224/s6/2"},"text":"Pub. L. 115–224, § 6(2)","children":[],"tail":", substituted “in-demand occupations” for “high demand occupations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/224/s6/3"},"text":"Pub. L. 115–224, § 6(3)","children":[],"tail":", struck out “, including tech prep education” after “technical education”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/224/s6/4"},"text":"Pub. L. 115–224, § 6(4)","children":[],"tail":", inserted “and programs of study” after “technical education programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/224/s6/5"},"text":"Pub. L. 115–224, § 6(5)","children":[],"tail":"–(7), added par. (8)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0db91f53-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0db91f54-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/224/s4"},"text":"Pub. L. 115–224, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-07-31"},"text":"July 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1564"},"text":"132 Stat. 1564","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/224/s4"},"text":"“This Act [see Short Title of 2018 Amendment note below], and the amendments made by this Act, shall take effect beginning on ","children":[{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0db91f55-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/224/s1"},"text":"Pub. L. 115–224, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-07-31"},"text":"July 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1563"},"text":"132 Stat. 1563","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/224/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2399"},"text":"section 2399 of this title","children":[],"tail":", amending numerous sections throughout this chapter, sections 6311, 7425, and 7544 of this title, and sections 49"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–2 and 3174 of Title 29 Labor, repealing subchapter II of this chapter, and enacting provisions set out as a note under this section] may be cited as the ‘Strengthening Career and Technical Education for the 21st Century Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0db91f56-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/a"},"text":"Pub. L. 109–270, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/683"},"text":"120 Stat. 683","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/270/s1/a"},"text":"“This Act [see Tables for classification] may be cited as the ‘Carl D. Perkins Career and Technical Education Improvement Act of 2006’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0db91f57-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/332/s1/a"},"text":"Pub. L. 105–332, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3076"},"text":"112 Stat. 3076","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/332/s1/a"},"text":"“This Act [see Tables for classification] may be cited as the ‘Carl D. Perkins Vocational and Applied Technology Education Amendments of 1998’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0db91f58-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/392/s1/a"},"text":"Pub. L. 101–392, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-09-25"},"text":"Sept. 25, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/753"},"text":"104 Stat. 753","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/392/s1/a"},"text":"“This Act [see Tables for classification] may be cited as the ‘Carl D. Perkins Vocational and Applied Technology Education Act Amendments of 1990’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0db91f59-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/576/s1"},"text":"Pub. L. 90–576, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-16"},"text":"Oct. 16, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1064"},"text":"82 Stat. 1064","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/576/s1"},"text":"“This Act [enacting sections 6, 1119c to 1119c–4, 1226, 1241 to 1248, 1261 to 1264, 1281 to 1284, 1301 to 1305, 1321 to 1323, 1341, 1351 to 1355, 1371 to 1374, and 1391 of this title, amending sections 237, 237 note, 238, 239, 240, 241, 403, 421, 422, 423, 423 note, 425, 425 note, 426, 441, 442, 442 note, 443, 444, 462, 464, 481, 482, 482 note, 483, 484, 491, 511, 521, 541, 551, 561, 563, 588, 589, 611, 633, 644, 645, 1202, and 1221 of this title, repealing sections 15i, 15i note, 15j to 15q, 15aa to 15jj, 15aaa to 15ggg, 30, 31 to 33, and 34 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1667"},"text":"section 1667 of Title 48","children":[],"tail":", Territories and Insular Possessions, and enacting provisions set out as notes under sections 6, 11, 240, 886, 1202, 1321, and 2301 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2809"},"text":"section 2809 of Title 42","children":[],"tail":", The Public Health and Welfare may be cited as the ‘Vocational Education Amendments of 1968’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id0db91f5a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/s1/a"},"text":"Pub. L. 88–210, § 1(a)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/b"},"text":"Pub. L. 109–270, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/683"},"text":"120 Stat. 683","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/270/s1/b"},"text":"“This Act [enacting this chapter] may be cited as the ‘Carl D. Perkins Career and Technical Education Act of 2006’.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tII/s201"},"text":"Pub. L. 88–210, title II, § 201","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/105/332/s1/b"},"text":"Pub. L. 105–332, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3117"},"text":"112 Stat. 3117","children":[],"tail":", which provided that title II of "},{"tag":"ref","attrib":{"href":"/us/pl/88/210"},"text":"Pub. L. 88–210","children":[],"tail":", enacting subchapter II of this chapter, could be cited as the “Tech-Prep Education Act”, was omitted in the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/88/210"},"text":"Pub. L. 88–210","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/b"},"text":"Pub. L. 109–270, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/683"},"text":"120 Stat. 683","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0db91f5b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Vocational Education Policy","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/524/s6"},"text":"Pub. L. 98–524, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2491"},"text":"98 Stat. 2491","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/524/s6"},"text":"“It is the sense of the Congress that effective vocational education programs are essential to our future as a free and democratic society; that such programs are best administered by local communities, and community colleges school boards, where the primacy of parental control can be emphasized with a minimum of Federal interference; and that as a means to strengthening vocational education and training programs, nongovernmental alternatives promoting links between public school needs and private sector sources of support should be encouraged and implemented.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
