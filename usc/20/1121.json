{"tag":"section","attrib":{"id":"id0d6cd399-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121"},"text":null,"children":[{"tag":"num","attrib":{"value":"1121"},"text":"§ 1121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings; purposes; consultation; survey","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d6cd39a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6cd39b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The security, stability, and economic vitality of the United States in a complex global era depend upon American experts in and citizens knowledgeable about world regions, foreign languages, and international affairs, as well as upon a strong research base in these areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6cd39c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advances in communications technology and the growth of regional and global problems make knowledge of other countries and the ability to communicate in other languages more essential to the promotion of mutual understanding and cooperation among nations and their peoples.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6cd39d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Dramatic changes in the world’s geopolitical and economic landscapes are creating needs for American expertise and knowledge about a greater diversity of less commonly taught foreign languages and nations of the world.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6cd39e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Systematic efforts are necessary to enhance the capacity of institutions of higher education in the United States for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d6cd39f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" producing graduates with international and foreign language expertise and knowledge; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6cd3a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research regarding such expertise and knowledge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6cd3a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cooperative efforts among the Federal Government, institutions of higher education, and the private sector are necessary to promote the generation and dissemination of information about world regions, foreign languages, and international affairs throughout education, government, business, civic, and nonprofit sectors in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6cd3a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this part are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6cd3a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d6cd3a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support centers, programs, and fellowships in institutions of higher education in the United States for producing increased numbers of trained personnel and research in foreign languages, area studies, and other international studies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6cd3a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop a pool of international experts to meet national needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6cd3a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and validate specialized materials and techniques for foreign language acquisition and fluency, emphasizing (but not limited to) the less commonly taught languages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6cd3a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote access to research and training overseas, including through linkages with overseas institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6cd3a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advance the internationalization of a variety of disciplines throughout undergraduate and graduate education;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6cd3a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support cooperative efforts promoting access to and the dissemination of international and foreign language knowledge, teaching materials, and research, throughout education, government, business, civic, and nonprofit sectors in the United States, through the use of advanced technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6cd3aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate the programs of the Federal Government in the areas of foreign language, area studies, and other international studies, including professional international affairs education and research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6cd3ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6cd3ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, prior to requesting applications for funding under this subchapter during each grant cycle, consult with and receive recommendations regarding national need for expertise in foreign languages and world regions from the head officials of a wide range of Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6cd3ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considering recommendations; providing information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d6cd3ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may take into account the recommendations described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6cd3af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d6cd3b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information collected under paragraph (1) when requesting applications for funding under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d6cd3b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available to applicants a list of areas identified as areas of national need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6cd3b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1121/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall assist grantees in developing a survey to administer to students who have completed programs under this subchapter to determine postgraduate employment, education, or training. All grantees, where applicable, shall administer such survey once every two years and report survey results to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6cd3b3-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s601"},"text":"Pub. L. 89–329, title VI, § 601","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVI/s601"},"text":"Pub. L. 105–244, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1774"},"text":"112 Stat. 1774","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVI/s601"},"text":"Pub. L. 110–315, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3333"},"text":"122 Stat. 3333","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d6cd3b4-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d6cd3b5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d6cd3b6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1121, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s601"},"text":"Pub. L. 89–329, title VI, § 601","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tVI/s601/a"},"text":"Pub. L. 96–374, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1464"},"text":"94 Stat. 1464","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tVI/s601"},"text":"Pub. L. 99–498, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1514"},"text":"100 Stat. 1514","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tVI/s601"},"text":"Pub. L. 102–325, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/720"},"text":"106 Stat. 720","children":[],"tail":", set out findings of Congress and purpose of this part, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1121, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s601"},"text":"Pub. L. 89–329, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1261"},"text":"79 Stat. 1261","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/752/s3/b"},"text":"Pub. L. 89–752, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-03"},"text":"Nov. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1241"},"text":"80 Stat. 1241","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/575/tII"},"text":"Pub. L. 90–575, title II","children":[],"tail":", §§ 241, 242(a), "},{"tag":"date","attrib":{"date":"1968-10-16"},"text":"Oct. 16, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1041"},"text":"82 Stat. 1041","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/318/tI/s151/a"},"text":"Pub. L. 92–318, title I, § 151(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/288"},"text":"86 Stat. 288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/482/tI/s156"},"text":"Pub. L. 94–482, title I, § 156","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2155"},"text":"90 Stat. 2155","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/49/s7"},"text":"Pub. L. 96–49, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-13"},"text":"Aug. 13, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/353"},"text":"93 Stat. 353","children":[],"tail":", set out the Congressional statement of purpose and the authorization of appropriations for the program of equipment grants to institutions of higher education, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/96/374"},"text":"Pub. L. 96–374","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d6cd3b7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s601/1"},"text":"Pub. L. 110–315, § 601(1)","children":[],"tail":", substituted “; purposes; consultation; survey” for “and purposes” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s601/2"},"text":"Pub. L. 110–315, § 601(2)","children":[],"tail":", struck out “post-Cold War” after “Dramatic”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s601/3"},"text":"Pub. L. 110–315, § 601(3)","children":[],"tail":", inserted “, including through linkages with overseas institutions” before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s601/4"},"text":"Pub. L. 110–315, § 601(4)","children":[],"tail":", added subsecs. (c) and (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d6cd3b8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d6cd3b9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Part effective ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0d6cd3ba-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Endowment for International Studies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/498/tXIII/s1302"},"text":"Pub. L. 99–498, title XIII, § 1302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1580"},"text":"100 Stat. 1580","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/50/s23/2"},"text":"Pub. L. 100–50, § 23(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-06-03"},"text":"June 3, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/362"},"text":"101 Stat. 362","children":[],"tail":", required Secretary of Education, in consultation with Director of United States Information Agency, Director of the Agency for International Development, Secretary of State, and Secretary of Defense, to conduct a study on establishment of a National Endowment for International Studies, such study to develop a program, a funding plan, and priorities for such an Endowment, with the Secretary to prepare and submit to Congress, not later than one year after "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", a report on the study, together with such recommendations, including recommendations for legislation, as the Secretary deemed appropriate, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/332/s6/a"},"text":"Pub. L. 105–332, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3127"},"text":"112 Stat. 3127","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
