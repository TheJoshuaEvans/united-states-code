{"tag":"section","attrib":{"id":"id0e1d391e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6675"},"text":null,"children":[{"tag":"num","attrib":{"value":"6675"},"text":"§ 6675.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" STEM master teacher corps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e1d391f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6675/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the funds reserved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6671/4"},"text":"section 6671(4) of this title","children":[],"tail":" for a fiscal year, the Secretary may award grants to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1d3920-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6675/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State educational agencies to enable such agencies to support the development of a State-wide STEM master teacher corps; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d3921-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6675/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State educational agencies, or nonprofit organizations in partnership with State educational agencies, to support the implementation, replication, or expansion of effective science, technology, engineering, and mathematics professional development programs in schools across the State through collaboration with school administrators, principals, and STEM educators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1d3922-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6675/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" STEM master teacher corps","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “STEM master teacher corps” means a State-led effort to elevate the status of the science, technology, engineering, and mathematics teaching profession by recognizing, rewarding, attracting, and retaining outstanding science, technology, engineering, and mathematics teachers, particularly in high-need and rural schools, by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1d3923-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6675/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" selecting candidates to be master teachers in the corps on the basis of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1d3924-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6675/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" content knowledge based on a screening examination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1d3925-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6675/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pedagogical knowledge of and success in teaching;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d3926-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6675/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" offering such teachers opportunities to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1d3927-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6675/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with one another in scholarly communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1d3928-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6675/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in and lead high-quality professional development; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d3929-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6675/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing such teachers with additional appropriate and substantial compensation for the work described in paragraph (2) and in the master teacher community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e1d392a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2245"},"text":"Pub. L. 89–10, title II, § 2245","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tII/s2002"},"text":"Pub. L. 114–95, title II, § 2002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1952"},"text":"129 Stat. 1952","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e1d392b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"edito