{"tag":"section","attrib":{"id":"id0dda8a7a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3474"},"text":null,"children":[{"tag":"num","attrib":{"value":"3474"},"text":"§ 3474.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to prescribe such rules and regulations as the Secretary determines necessary or appropriate to administer and manage the functions of the Secretary or the Department.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0dda8a7b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIV/s414"},"text":"Pub. L. 96–88, title IV, § 414","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/685"},"text":"93 Stat. 685","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXII/s1204/a/5"},"text":"Pub. L. 99–145, title XII, § 1204(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/720"},"text":"99 Stat. 720","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tII/s271/d/1"},"text":"Pub. L. 103–382, title II, § 271(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3930"},"text":"108 Stat. 3930","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dda8a7c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dda8a7d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0dda8a7e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":" struck out subsec. (a) designation and subsec. (b) which read as follows: “The Secretary, in promulgating rules and regulations as authorized by statute, shall prescribe such rules and regulations in accordance with chapter 5 of title 5. "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232"},"text":"Section 1232 of this title","children":[],"tail":" also shall apply to such rules and regulations to the extent applicable immediately prior to "},{"tag":"date","attrib":{"date":"1980-05-04"},"text":"May 4, 1980","children":[],"tail":", and to rules and regulations promulgated with respect to programs transferred under sections 3441(a)(1), (2), and (4), 3443, 3444, 3445, and 3446 of this title.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" struck out reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3442"},"text":"section 3442 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
