{"tag":"section","attrib":{"id":"id0e2e019b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261"},"text":null,"children":[{"tag":"num","attrib":{"value":"7261"},"text":"§ 7261.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for education innovation and research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e2e019c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2e019d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From funds reserved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7251/b/2/A"},"text":"section 7251(b)(2)(A) of this title","children":[],"tail":", the Secretary shall make grants to eligible entities to enable the eligible entities to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2e019e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create, develop, implement, replicate, or take to scale entrepreneurial, evidence-based, field-initiated innovations to improve student achievement and attainment for high-need students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e019f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rigorously evaluate such innovations, in accordance with subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e01a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The grants described in paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2e01a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early-phase grants to fund the development, implementation, and feasibility testing of a program, which prior research suggests has promise, for the purpose of determining whether the program can successfully improve student achievement or attainment for high-need students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e01a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mid-phase grants to fund implementation and a rigorous evaluation of a program that has been successfully implemented under an early-phase grant described in subparagraph (A) or other effort meeting similar criteria, for the purpose of measuring the program’s impact and cost effectiveness, if possible using existing administrative data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e01a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" expansion grants to fund implementation and a rigorous replication evaluation of a program that has been found to produce sizable, important impacts under a mid-phase grant described in subparagraph (B) or other effort meeting similar criteria, for the purposes of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e2e01a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining whether such impacts can be successfully reproduced and sustained over time; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2e01a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying the conditions in which the program is most effective.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2e01a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subpart, the term “eligible entity” means any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2e01a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A local educational agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e01a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State educational agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e01a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Bureau of Indian Education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e01aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A consortium of State educational agencies or local educational agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e01ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nonprofit organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e01ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A State educational agency, a local educational agency, a consortium described in paragraph (4), or the Bureau of Indian Education, in partnership with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2e01ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e01ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e01af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an educational service agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e01b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/b/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2e01b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural areas","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2e01b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under subsection (a), the Secretary shall ensure that not less than 25 percent of the funds made available for any fiscal year are awarded for programs that meet both of the following requirements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2e01b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The grantee is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e2e01b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local educational agency with an urban-centric district locale code of 32, 33, 41, 42, or 43, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2e01b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium of such local educational agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2e01b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an educational service agency or a nonprofit organization in partnership with such a local educational agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2e01b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/c/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a grantee described in clause (i) or (ii) in partnership with a State educational agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e01b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A majority of the schools to be served by the program are designated with a locale code of 32, 33, 41, 42, or 43, or a combination of such codes, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e01b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), the Secretary shall reduce the amount of funds made available under such paragraph if the Secretary does not receive a sufficient number of applications of sufficient quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2e01ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to receive a grant under subsection (a), an eligible entity shall demonstrate that the eligible entity will provide matching funds, in cash or through in-kind contributions, from Federal, State, local, or private sources in an amount equal to 10 percent of the funds provided under such grant, except that the Secretary may waive the matching funds requirement, on a case-by-case basis, upon a showing of exceptional circumstances, such as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2e01bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the difficulty of raising matching funds for a program to serve a rural area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e01bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the difficulty of raising matching funds in areas with a concentration of local educational agencies or schools with a high percentage of students aged 5 through 17—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2e01bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who are in poverty, as counted in the most recent census data approved by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e01be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who are eligible for a free or reduced price lunch under the Richard B. Russell National School Lunch Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"42 U.S.C. 1751","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e01bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose families receive assistance under the State program funded under part A of title IV of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s601"},"text":"42 U.S.C. 601","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e01c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who are eligible to receive medical assistance under the Medicaid program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e01c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the difficulty of raising funds on tribal land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2e01c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient of a grant under this section shall conduct an independent evaluation of the effectiveness of the program carried out under such grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2e01c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may reserve not more than 5 percent of the funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7251/b/2/A"},"text":"section 7251(b)(2)(A) of this title","children":[],"tail":" for each fiscal year to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2e01c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance for eligibility entities, which may include pre-application workshops, web-based seminars, and evaluation support; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e01c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7261/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to disseminate best practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e2e01c6-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4611"},"text":"Pub. L. 89–10, title IV, § 4611","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4601"},"text":"Pub. L. 114–95, title IV, § 4601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2021"},"text":"129 Stat. 2021","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e2e01c7-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e2e01c8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e2e01c9-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Richard B. Russell National School Lunch Act, referred to in subsec. (d)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281"},"text":"act June 4, 1946, ch. 281","children":[],"tail":", "},{"ta