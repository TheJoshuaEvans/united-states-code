{"tag":"section","attrib":{"id":"id0e2b9006-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d"},"text":null,"children":[{"tag":"num","attrib":{"value":"7221d"},"text":"§ 7221d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e2b9007-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amount reserved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7221a/b/2"},"text":"section 7221a(b)(2) of this title","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2b9008-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use not more than 80 percent of such funds to award grants in accordance with subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b9009-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use not more than 9 percent of such funds to award grants, on a competitive basis, to eligible applicants for the purpose of carrying out the activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7221b/h"},"text":"section 7221b(h) of this title","children":[],"tail":" in a State that did not receive a grant under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7221b"},"text":"section 7221b of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b900a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after the uses described in paragraphs (1) and (2), use the remainder of such funds to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2b900b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" disseminate technical assistance to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e2b900c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State entities in awarding subgrants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7221b/b/1"},"text":"section 7221b(b)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2b900d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible entities and States receiving grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7221c"},"text":"section 7221c of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b900e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate best practices regarding charter schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b900f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the impact of the charter school program carried out under this part, including the impact on student achievement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2b9010-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for the replication and expansion of high-quality charter schools","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2b9011-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make grants, on a competitive basis, to eligible entities having applications approved under paragraph (3) to enable such entities to open and prepare for the operation of one or more replicated high-quality charter schools or to expand one or more high-quality charter schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b9012-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “eligible entity” means a charter management organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b9013-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity desiring to receive a grant under this subsection shall submit an application to the Secretary at such time and in such manner as the Secretary may require. The application shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2b9014-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing charter school data","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each charter school currently operated or managed by the eligible entity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e2b9015-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" student assessment results for all students and for each subgroup of students described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/c/2"},"text":"section 6311(c)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2b9016-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attendance and student retention rates for the most recently completed school year and, if applicable, the most recent available 4-year adjusted cohort graduation rates and extended-year adjusted cohort graduation rates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2b9017-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on any significant compliance and management issues encountered within the last 3 school years by any school operated or managed by the eligible entity, including in the areas of student safety and finance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b9018-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Descriptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A description of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e2b9019-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible entity’s objectives for implementing a high-quality charter school program with funding under this subsection, including a description of the proposed number of high-quality charter schools the eligible entity proposes to open as a result of the replication of a high-quality charter school or to expand with funding under this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2b901a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the educational program that the eligible entity will implement in such charter schools, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e2b901b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on how the program will enable all students to meet the challenging State academic standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e2b901c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grade levels or ages of students who will be served; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e2b901d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/3/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the instructional practices that will be used;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2b901e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the operation of such charter schools will be sustained after the grant under this subsection has ended, which shall include a multi-year financial and operating model for the eligible entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2b901f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the eligible entity will ensure that such charter schools will recruit and enroll students, including children with disabilities, English learners, and other educationally disadvantaged students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2b9020-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any request and justification for any waivers of Federal statutory or regulatory requirements that the eligible entity believes are necessary for the successful operation of such charter schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b9021-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An assurance that the eligible entity has sufficient procedures in effect to ensure timely closure of low-performing or financially mismanaged charter schools and clear plans and procedures in effect for the students in such schools to attend other high-quality schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b9022-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall select eligible entities to receive grants under this subsection, on the basis of the quality of the applications submitted under paragraph (3), after taking into consideration such factors as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2b9023-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree to which the eligible entity has demonstrated success in increasing academic achievement for all students and for each of the subgroups of students described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/c/2"},"text":"section 6311(c)(2) of this title","children":[],"tail":" attending the charter schools the eligible entity operates or manages;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b9024-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a determination that the eligible entity has not operated or managed a significant proportion of charter schools that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e2b9025-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been closed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2b9026-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have had the school’s charter revoked due to problems with statutory or regulatory compliance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2b9027-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have had the school’s affiliation with the eligible entity revoked or terminated, including through voluntary disaffiliation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b9028-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a determination that the eligible entity has not experienced significant problems with statutory or regulatory compliance that could lead to the revocation of a school’s charter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b9029-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this section, the Secretary shall give priority to eligible entities that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2b902a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plan to operate or manage high-quality charter schools with racially and socioeconomically diverse student bodies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b902b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221d/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate success in working with schools identified by the State for comprehensive support and improvement under ","children":[{"tag":"ref","at