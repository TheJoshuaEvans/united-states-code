{"tag":"section","attrib":{"id":"id0e0ee080-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6339"},"text":null,"children":[{"tag":"num","attrib":{"value":"6339"},"text":"§ 6339.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryover and waiver","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e0ee081-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6339/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on carryover","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1225/b"},"text":"section 1225(b) of this title","children":[],"tail":" or any other provision of law, not more than 15 percent of the funds allocated to a local educational agency for any fiscal year under this subpart (but not including funds received through any reallocation under this subpart) may remain available for obligation by such agency for one additional fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0ee082-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6339/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State educational agency may, once every 3 years, waive the percentage limitation in subsection (a) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0ee083-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6339/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency determines that the request of a local educational agency is reasonable and necessary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0ee084-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6339/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supplemental appropriations for this subpart become available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0ee085-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6339/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The percentage limitation under subsection (a) shall not apply to any local educational agency that receives less than $50,000 under this subpart for any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e0ee086-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1127"},"text":"Pub. L. 89–10, title I, § 1127","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1534"},"text":"115 Stat. 1534","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e0ee087-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e0ee088-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e0ee089-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s1127"},"text":"section 1127 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6338"},"text":"section 6338 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
