{"tag":"section","attrib":{"id":"id0e600e05-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409"},"text":null,"children":[{"tag":"num","attrib":{"value":"9409"},"text":"§ 9409.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e600e06-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use not more than 3 percent of the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9404"},"text":"section 9404 of this title","children":[],"tail":" for a fiscal year to pay for the administrative costs of carrying out this chapter, including the monitoring and evaluation of State and local efforts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e600e07-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State administrative costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State that receives a grant under this chapter may use—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e600e08-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 2 percent of the funds made available through the grant to carry out activities designed to coordinate early learning programs on the State level, including programs funded or operated by the State educational agency, health, children and family, and human service agencies, and any State-level collaboration or coordination council involving early learning and education, such as the entities funded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9835/a/2/B/vi"},"text":"section 9835(a)(2)(B)(vi) of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e09-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 2 percent of the funds made available through the grant for the administrative costs of carrying out the grant program and the costs of reporting State and local efforts to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e0a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 3 percent of the funds made available through the grant for training, technical assistance, and wage incentives provided by the State to Local Councils.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e600e0b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lead State Agency","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e600e0c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive an allotment under this chapter, the Governor of a State shall appoint, after consultation with the leadership of the State legislature, a Lead State Agency to carry out the functions described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e0d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lead State Agency","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e600e0e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Lead State Agency described in paragraph (1) shall allocate funds to Local Councils as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9411"},"text":"section 9411 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600e0f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to allocating funds pursuant to subparagraph (A), the Lead State Agency shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e600e10-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise and assist Local Councils in the performance of their duties under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e600e11-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and submit the State application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e600e12-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate and approve applications submitted by Local Councils under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9412"},"text":"section 9412 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e600e13-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure collaboration with respect to assistance provided under this chapter between the State agency responsible for education and the State agency responsible for children and family services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e600e14-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/c/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prepare and submit to the Secretary, an annual report on the activities carried out in the State under this chapter, which shall include a statement describing how all funds received under this chapter are expended and documentation of the effects that resources under this chapter have had on—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e600e15-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/c/2/B/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parental capacity to improve learning readiness in their young children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e600e16-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/c/2/B/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early childhood literacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e600e17-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/c/2/B/v/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" linkages among early learning programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e600e18-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/c/2/B/v/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" linkages between early learning programs and health care services for young children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e600e19-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/c/2/B/v/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to early learning activities for young children with special needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e600e1a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/c/2/B/v/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to existing early learning programs through expansion of the days or times that children are served;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e600e1b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/c/2/B/v/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to existing early learning programs through expansion of the number of young children served;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e600e1c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/c/2/B/v/VIII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VIII"},"text":"(VIII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to and affordability of existing early learning programs for low-income families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e600e1d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/c/2/B/v/IX"},"text":null,"children":[{"tag":"num","attrib":{"value":"IX"},"text":"(IX)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quality of early learning programs resulting from professional development, and recruitment and retention incentives for caregivers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e600e1e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/c/2/B/v/X"},"text":null,"children":[{"tag":"num","attrib":{"value":"X"},"text":"(X)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" removal of ancillary barriers to early learning, including transportation difficulties and absence of programs during nontraditional work times; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e600e1f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9409/c/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that training and research is made available to Local Councils and that such training and research reflects the latest available brain development and early childhood development research related to early learning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e600e20-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/1/tVIII/s810"},"text":"Pub. L. 106–554, § 1(a)(1) [title VIII, § 810]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–85; "},{"tag":"ref","attrib":{"href":"/us/pl/110/134/s29/b"},"text":"Pub. L. 110–134, § 29(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-12"},"text":"Dec. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1449"},"text":"121 Stat. 1449","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e600e21-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e600e22-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e600e23-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/134"},"text":"Pub. L. 110–134","children":[],"tail":" substituted “entities funded under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9835/a/2/B/vi"},"text":"section 9835(a)(2)(B)(vi) of title 42","children":[],"tail":"” for “entities funded under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9835/a/5"},"text":"section 9835(a)(5) of title 42","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
