{"tag":"section","attrib":{"id":"id0dad397b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1461"},"text":null,"children":[{"tag":"num","attrib":{"value":"1461"},"text":"§ 1461.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose; definition of eligible entity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dad397c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1461/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this part is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dad397d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1461/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide Federal funding for personnel preparation, technical assistance, model demonstration projects, information dissemination, and studies and evaluations, in order to improve early intervention, educational, and transitional results for children with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad397e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1461/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist State educational agencies and local educational agencies in improving their education systems for children with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dad397f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1461/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible entity","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dad3980-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1461/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this part, the term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dad3981-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1461/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State educational agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad3982-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1461/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local educational agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad3983-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1461/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public charter school that is a local educational agency under State law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad3984-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1461/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad3985-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1461/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public agency not described in subparagraphs (A) through (D);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad3986-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1461/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private nonprofit organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad3987-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1461/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an outlying area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad3988-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1461/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe or a tribal organization (as defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad3989-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1461/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a for-profit organization, if the Secretary finds it appropriate in light of the purposes of a particular competition for a grant, contract, or cooperative agreement under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad398a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1461/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may limit which eligible entities described in paragraph (1) are eligible for a grant, contract, or cooperative agreement under this part to 1 or more of the categories of eligible entities described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dad398b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s661"},"text":"Pub. L. 91–230, title VI, § 661","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2774"},"text":"118 Stat. 2774","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dad398c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dad398d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0dad398e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1461, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s661"},"text":"Pub. L. 91–230, title VI, § 661","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/17/tI/s101"},"text":"Pub. L. 105–17, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-04"},"text":"June