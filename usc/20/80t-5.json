{"tag":"section","attrib":{"id":"id0c8cacef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"80t–5"},"text":"§ 80t–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Building","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c8cacf0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c8cacf1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Board of Regents shall designate a site for the Museum."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8cacf2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sites for consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In designating a site under paragraph (1), the Board of Regents shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c8cacf3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select a site in the District of Columbia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8cacf4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include the consideration of the following sites:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0c8cacf5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The site known as the “South Monument site”, located on the National Mall and bordered by 14th Street Northwest, Jefferson Drive Southwest, Raoul Wallenberg Place Southwest, and Independence Ave Southwest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c8cacf6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Northwest United States Capitol site, bordered by 3rd Street Northwest, Constitution Avenue Northwest, 1st Street Northwest, and Pennsylvania Ave Northwest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8cacf7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors considered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In designating a site under paragraph (1), the Board of Regents shall take into consideration each of the following factors:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c8cacf8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An estimate of the costs associated with each potential site.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8cacf9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the suitability of the space of each potential site, including size, proximity to other buildings and transportation, and other external environmental conditions, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8cacfa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The recommendations of the Congressional Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8cacfb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board of Regents shall carry out its duties under this subsection in consultation with each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c8cacfc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chair of the National Capital Planning Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8cacfd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8cacfe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chair of the National Capital Memorial Advisory Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8cacff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chair of the Commission on Fine Arts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8cad00-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chair of the Congressional Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8cad01-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Architect of the Capitol.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8cad02-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The chair and ranking member of each of the following committees:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0c8cad03-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/4/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Rules and Administration of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c8cad04-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/4/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on House Administration of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c8cad05-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/4/G/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Energy and Natural Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c8cad06-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/4/G/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Natural Resources of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c8cad07-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/4/G/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Transportation and Infrastructure of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c8cad08-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/4/G/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c8cad09-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/4/G/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Appropriations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8cad0a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intent of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the intent of Congress that the Museum be located on or near the National Mall, to the maximum extent practicable, in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c8cad0b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Site under the jurisdiction of another Federal agency","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c8cad0c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written notification of agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Regents shall not designate a site for the Museum that is under the administrative jurisdiction of another Federal agency or entity unless the head of the Federal agency or entity submits to each of the committees described in subsection (a)(4)(G) written notification stating that the head of the Federal agency or entity concurs with locating the Museum on the land or in the structure that is under the administrative jurisdiction of the Federal agency or entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8cad0d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after the date on which Congress receives the written notification described in paragraph (1), the head of the Federal agency or entity shall transfer to the Smithsonian Institution its administrative jurisdiction over the land or structure that has been designated as the site for the Museum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c8cad0e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of building","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Regents, in consultation with the council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s80t–2"},"text":"section 80t–2 of this title","children":[],"tail":", may plan, design, and construct a building for the Museum, which shall be located at the site designated by the Board of Regents under subsection (a), in accordance with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c8cad0f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commemorative Works Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 89 of title 40 shall not apply with respect to the Museum, except that the Museum shall not be located in the Reserve (as defined in section 8902(a) of that title).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c8cad10-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board of Regents shall pay—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c8cad11-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the costs of carrying out this section from Federal funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8cad12-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–5/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the costs of carrying out this section from non-Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c8cad13-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dT/tI/s107"},"text":"Pub. L. 116–260, div. T, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2276"},"text":"134 Stat. 2276","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
