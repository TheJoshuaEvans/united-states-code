{"tag":"section","attrib":{"id":"id0db463e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1687"},"text":null,"children":[{"tag":"num","attrib":{"value":"1687"},"text":"§ 1687.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interpretation of “program or activity”","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter, the term “program or activity” and “program” mean all of the operations of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db463ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1687/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db463eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1687/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a department, agency, special purpose district, or other instrumentality of a State or of a local government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db463ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1687/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entity of such State or local government that distributes such assistance and each such department or agency (and each other State or local government entity) to which the assistance is extended, in the case of assistance to a State or local government;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db463ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1687/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db463ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1687/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a college, university, or other postsecondary institution, or a public system of higher education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db463ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1687/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local educational agency (as defined in section section ","children":[{"tag":"ref","attrib":{"idref":"fn002130"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002130"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" 7801 of this title), system of vocational education, or other school system;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db463f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1687/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db463f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1687/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an entire corporation, partnership, or other private organization, or an entire sole proprietorship—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0db463f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1687/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if assistance is extended to such corporation, partnership, private organization, or sole proprietorship as a whole; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0db463f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1687/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is principally engaged in the business of providing education, health care, housing, social services, or parks and recreation; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db463f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1687/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entire plant or other comparable, geographically separate facility to which Federal financial assistance is extended, in the case of any other corporation, partnership, private organization, or sole proprietorship; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db463f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1687/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other entity which is established by two or more of the entities described in paragraph (1), (2), or (3);","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"any part of which is extended Federal financial assistance, except that such term does not include any operation of an entity which is controlled by a religious organization if the application of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1681"},"text":"section 1681 of this title","children":[],"tail":" to such operation would not be consistent with the religious tenets of such organization."}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0db463f6-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/318/tIX/s908"},"text":"Pub. L. 92–318, title IX, § 908","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/259/s3/a"},"text":"Pub. L. 100–259, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-03-22"},"text":"Mar. 22, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/28"},"text":"102 Stat. 28","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s391/g"},"text":"Pub. L. 103–382, title III, § 391(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4023"},"text":"108 Stat. 4023","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1076/j"},"text":"Pub. L. 107–110, title X, § 1076(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2091"},"text":"115 Stat. 2091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/bb"},"text":"Pub. L. 114–95, title IX, § 9215(bb)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2173"},"text":"129 Stat. 2173","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0db463f7-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0db463f8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0db463f9-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title IX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/318"},"text":"Pub. L. 92–318","children":[],"tail":" which enacted this chapter and amended sections 203 and 213 of Title 29, Labor, and sections 2000c, 2000c–6, 2000c–9, and 2000h–2 of Title 42, The Public Health and Welfare. For complete classification of title IX to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1681"},"text":"section 1681 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0db463fa-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Par. (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of this title","children":[],"tail":"), system of vocational education, or other school system;” for “7801 of this title), system of vocational education, or other school system;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Par. (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":" substituted “7801” for “8801”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":" substituted “section 8801” for “section 2854(a)(10)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0db463fb-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0db463fc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0db463fd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0db463fe-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings of Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/259/s2"},"text":"Pub. L. 100–259, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-03-22"},"text":"Mar. 22, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/28"},"text":"102 Stat. 28","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/259/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certain aspects of recent decisions and opinions of the Supreme Court have unduly narrowed or cast doubt upon the broad application of title IX of the Education Amendments of 1972 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1681"},"text":"20 U.S.C. 1681","children":[],"tail":" et seq.], section 504 of the Rehabilitation Act of 1973 ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"29 U.S.C. 794","children":[],"tail":"], the Age Discrimination Act of 1975 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6101"},"text":"42 U.S.C. 6101","children":[],"tail":" et seq.], and title VI of the Civil Rights Act of 1964 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000d"},"text":"42 U.S.C. 2000d","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legislative action is necessary to restore the prior consistent and long-standing executive branch interpretation and broad, institution-wide application of those laws as previously administered.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0db463ff-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/259/s7"},"text":"Pub. L. 100–259, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-03-22"},"text":"Mar. 22, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/31"},"text":"102 Stat. 31","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/259/s7"},"text":"“Nothing in the amendments made by this Act [see Short Title of 1988 Amendment note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1681"},"text":"section 1681 of this title","children":[],"tail":"] shall be construed to extend the application of the Acts so amended [Education Amendments of 1972, "},{"tag":"ref","attrib":{"href":"/us/pl/92/318"},"text":"Pub. L. 92–318","children":[],"tail":", see Short Title of 1972 Amendment, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":", Rehabilitation Act of 1973, "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"29 U.S.C. 701","children":[],"tail":" et seq., Age Discrimination Act of 1975, "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6101"},"text":"42 U.S.C. 6101","children":[],"tail":" et seq., and Civil Rights Act of 1964, "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000a"},"text":"42 U.S.C. 2000a","children":[],"tail":" et seq.] to ultimate beneficiaries of Federal financial assistance excluded from coverage before the enactment of this Act ["},{"tag":"date","attrib":{"date":"1988-03-22"},"text":"Mar. 22, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0db46400-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Abortion Neutrality","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section not to be construed to force or require any individual or hospital or any other institution, program, or activity receiving Federal funds to perform or pay for an abortion, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/259/s8"},"text":"section 8 of Pub. L. 100–259","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1688"},"text":"section 1688 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
