{"tag":"section","attrib":{"id":"id0d871330-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161l–1"},"text":"§ 1161l–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model emergency response policies, procedures, and practices","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Attorney General and the Secretary of Homeland Security, shall continue to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d871331-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–1/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise institutions of higher education on model emergency response policies, procedures, and practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d871332-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l–1/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate information concerning those policies, procedures, and practices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d871333-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s822"},"text":"Pub. L. 89–329, title VIII, § 822","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3410"},"text":"122 Stat. 3410","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
