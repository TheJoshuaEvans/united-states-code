nts","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s7001/a/1"},"text":"Pub. L. 114–95, § 7001(a)(1)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/s563/c/4"},"text":"Pub. L. 112–239, § 563(c)(4)","children":[],"tail":". See 2013 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s7010/1/A"},"text":"Pub. L. 114–95, § 7010(1)(A)","children":[],"tail":", made technical amendment to reference in original act which appears in heading as reference to section 7703(a)(1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s7001/d/3"},"text":"Pub. L. 114–95, § 7001(d)(3)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7703/a/1"},"text":"section 7703(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s7010/1/B"},"text":"Pub. L. 114–95, § 7010(1)(B)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7709/b"},"text":"section 7709(b) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s7001/d/6"},"text":"Pub. L. 114–95, § 7001(d)(6)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7703/b"},"text":"section 7703(b) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s7010/2"},"text":"Pub. L. 114–95, § 7010(2)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7714"},"text":"section 7714 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s563/c/4"},"text":"Pub. L. 112–239, § 563(c)(4)","children":[],"tail":", which directed repeal of the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/s563/b/3/B"},"text":"Pub. L. 112–239, § 563(b)(3)(B)","children":[],"tail":", on the day after the 5-year period that began on "},{"tag":"date","attrib":{"date":"2013-01-03"},"text":"Jan. 3, 2013","children":[],"tail":", was itself repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s7001/a/1"},"text":"Pub. L. 114–95, § 7001(a)(1)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s563/b/3/A"},"text":"Pub. L. 112–239, § 563(b)(3)(A)","children":[],"tail":", substituted “paragraph (2)” for “paragraph (3) of this subsection” in subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s563/b/3/B"},"text":"Pub. L. 112–239, § 563(b)(3)(B)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XVIII, § 1813(1), (2)], redesignated par. (2) as (1) and struck out heading and text of former par. (1). Text read as follows: “Notwithstanding any other provision of law, for any fiscal year before fiscal year 1995, the Secretary shall treat as eligible under subsection (a) or (b) of "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-30/s3"},"text":"section 3 of the Act of September 30, 1950","children":[],"tail":" (Public Law 874, 81st Congress) (as such subsection was in effect on the day preceding "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"October 20, 1994","children":[],"tail":"), and shall forgive the obligation of a local educational agency to repay any amounts that such agency received under such section for such fiscal year based on, any child who would be eligible under such subsections except that such child does not meet the requirements of subsection (a)(1)(B) or (b)(2)(B), respectively, of such section 3, if such child meets the requirements of paragraph (3) of this subsection.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XVIII, § 1813(2)], redesignated par. (3) as (2). Former par. (2) redesignated (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XVIII, § 1813(3)(A)], struck out “"},{"tag":"ref","attrib":{"href":"/us/act/1950-09-30/s5/d/2"},"text":"section 5(d)(2) of the Act of September 30, 1950","children":[],"tail":" (Public Law 874, 81st Congress) (as such section was in effect on the day preceding "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"October 20, 1994","children":[],"tail":") or” after “otherwise permitted under”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XVIII, § 1813(3)(B)], substituted “1999” for “1994”, struck out “(or such section’s predecessor authority)” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7703/b"},"text":"section 7703(b) of this title","children":[],"tail":"”, and substituted “paragraph (1)” for “paragraph (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XVIII, § 1813(2)], redesignated par. (3) as (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e4819bc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e4819bd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", and effective with respect to appropriations for use under this subchapter beginning fiscal year 2017, except as otherwise provided in such amendment, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
