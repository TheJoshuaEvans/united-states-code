{"tag":"section","attrib":{"id":"id0e4819a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7710"},"text":null,"children":[{"tag":"num","attrib":{"value":"7710"},"text":"§ 7710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e4819a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7710/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments in whole dollar amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall round any payments under this subchapter to the nearest whole dollar amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4819a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7710/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal agency administering Federal property on which children reside, and each agency principally responsible for an activity that may occasion assistance under this subchapter, shall, to the maximum extent practicable, comply with requests of the Secretary for information the Secretary may require to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4819a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7710/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e4819aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7710/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain children eligible under subparagraphs (A) and (G)(ii) of section 7703(a)(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4819ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7710/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall treat as eligible under subparagraph (A) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7703/a/1"},"text":"section 7703(a)(1) of this title","children":[],"tail":" any child who would be eligible under such subparagraph except that the Federal property on which the child resides or on which the child’s parent is employed is not in the same State in which the child attends school, if such child meets the requirements of paragraph (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4819ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7710/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall treat as eligible under subparagraph (G) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7703/a/1"},"text":"section 7703(a)(1) of this title","children":[],"tail":" any child who would be eligible under such subparagraph except that such child does not meet the requirements of clause (ii) of such subparagraph, if such child meets the requirements of paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4819ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7710/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A child meets the requirements of this paragraph if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4819ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7710/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such child resides—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e4819af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7710/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a State adjacent to the State in which the local educational agency serving the school such child attends is located; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e4819b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7710/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with a parent employed on Federal property in a State adjacent to the State in which such agency is located;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4819b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7710/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the schools of such agency are within a more reasonable commuting distance of such child’s home than the schools of the local educational agency that serves the school attendance area where such child resides;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4819b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7710/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attending the schools of the local educational agency that serves the school attendance area where such child resides will impose a substantial hardship on such child;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4819b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7710/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State in which such child attends school provides funds for the education of such child on the same basis as all other public school children in the State, unless otherwise permitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7709/b"},"text":"section 7709(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4819b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7710/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such agency received a payment for fiscal year 1999 under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7703/b"},"text":"section 7703(b) of this title","children":[],"tail":" on behalf of children described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4819b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7710/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timely payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e4819b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7710/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary shall pay a local educational agency the full amount that the agency is eligible to receive under this subchapter for a fiscal year not later than September 30 of the second fiscal year following the fiscal year for which such amount has been appropriated if, not later than 1 calendar year following the fiscal year in which such amount has been appropriated, such local educational agency submits to the Secretary all the data and information necessary for the Secretary to pay the full amount that the agency is eligible to receive under this subchapter for such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4819b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7710/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments with respect of fiscal years in which insufficient funds are appropriated","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For a fiscal year in which the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7714"},"text":"section 7714 of this title","children":[],"tail":" is insufficient to pay the full amount a local educational agency is eligible to receive under this subchapter, paragraph (1) shall be applied by substituting “is available to pay the agency” for “the agency is eligible to receive” each place the term appears."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e4819b8-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVII/s7010"},"text":"Pub. L. 89–10, title VII, § 7010","children":[],"tail":", formerly title VIII, § 8010, as added "},{"tag":"ref","attrib"