tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0de8bb0e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s691f"},"text":"section 691f of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/371"},"text":"Pub. L. 99–371","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0de8bb0f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" substituted “and subsections (a), (b), and (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4359a"},"text":"section 4359a of this title","children":[],"tail":".” for “and subsections (b) and (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4359a"},"text":"section 4359a of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s905/1/A"},"text":"Pub. L. 110–315, § 905(1)(A)","children":[],"tail":", substituted “sections 4302(b), 4305(b)(4), 4332(b)(5), 4353(c), 4357(b)(2) of this title, subsections (c) through (f) of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4357"},"text":"section 4357 of this title","children":[],"tail":", and subsections (b) and (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4359a"},"text":"section 4359a of this title","children":[],"tail":"” for “sections 4302(b), 4305(b)(4), 4332(b)(5) of this title, and subsection (c) of this section, paragraphs (2) and (3) of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4357/b"},"text":"section 4357(b) of this title","children":[],"tail":", subsections (b)(2), (b)(3), and (c) through (f), of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4357"},"text":"section 4357 of this title","children":[],"tail":", and subsections (b) and (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4359a"},"text":"section 4359a of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s905/1/B"},"text":"Pub. L. 110–315, § 905(1)(B)","children":[],"tail":", inserted “and the Committee on Education and Labor of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s905/2"},"text":"Pub. L. 110–315, § 905(2)","children":[],"tail":", substituted “Committee on Health, Education, Labor, and Pensions of the Senate” for “Committee on Labor and Human Resources of the Senate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in heading and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" amended heading and text of subsec. (b) generally. Prior to amendment, text read as follows: “Gallaudet University shall have an annual independent financial audit made of the programs and activities of the University. The institution of higher education with which the Secretary has an agreement under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4332"},"text":"section 4332 of this title","children":[],"tail":" shall have an annual independent financial audit made of the programs and activities of such institution of higher education, including NTID, and containing specific schedules and analyses for all NTID funds, as determined by the Secretary.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/73/s204/b"},"text":"Pub. L. 103–73, § 204(b)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “Gallaudet University and the institution of higher education operating the National Technical Institute for the Deaf shall have an annual independent audit made of the programs and activities of the University and of NTID, respectively.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/73/s202"},"text":"Pub. L. 103–73, § 202","children":[],"tail":", substituted “NTID” for “the Institute”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/421/s133"},"text":"Pub. L. 102–421, § 133","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0de8bb10-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id0de8bb11-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Education and Labor of House of Representatives changed to Committee on Education and the Workforce of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":