{"tag":"section","attrib":{"id":"id0de8baf0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353"},"text":null,"children":[{"tag":"num","attrib":{"value":"4353"},"text":"§ 4353.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de8baf1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government Accountability Office authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All financial transactions and accounts of the corporation or institution of higher education, as the case may be, in connection with the expenditure of any moneys appropriated by any law of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de8baf2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the benefit of Gallaudet University or for the construction of facilities for its use; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de8baf3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the benefit of the National Technical Institute for the Deaf or for the construction of facilities for its use,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be settled and adjusted in the Government Accountability Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de8baf4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent financial and compliance audit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de8baf5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gallaudet University shall have an annual independent financial and compliance audit made of the programs and activities of the University, including the national mission and school operations of the elementary and secondary education programs at Gallaudet. The institution of higher education with which the Secretary has an agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4332"},"text":"section 4332 of this title","children":[],"tail":" shall have an annual independent financial and compliance audit made of the programs and activities of such institution of higher education, including NTID, and containing specific schedules and analyses for all NTID funds, as determined by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de8baf6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in paragraph (1), compliance means compliance with sections 4302(b), 4305(b)(4), 4332(b)(5), 4353(c),","children":[{"tag":"ref","attrib":{"idref":"fn002163"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002163"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “and”."}],"tail":" 4357(b)(2) of this title, subsections (c) through (f) of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4357"},"text":"section 4357 of this title","children":[],"tail":", and subsections (a), (b), and (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4359a"},"text":"section 4359a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de8baf7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A copy of each audit described in paragraph (1) shall be provided to the Secretary and the Committee on Education and Labor of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate within 15 days of acceptance of the audit by the University or the institution authorized to establish and operate the NTID under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4332/a"},"text":"section 4332(a) of this title","children":[],"tail":", as the case may be, but not later than January 10 of each year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de8baf8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations regarding expenditure of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de8baf9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No funds appropriated under this chapter for Gallaudet University, including the Kendall Demonstration Elementary School and the Model Secondary School for the Deaf, or for the National Technical Institute for the Deaf may be expended on the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de8bafa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Alcoholic beverages.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de8bafb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Goods or services for personal use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de8bafc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Housing and personal living expenses (but only to the extent such expenses are not required by written employment agreement).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de8bafd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lobbying, except that nothing in this subparagraph shall be construed to prohibit the University and NTID from educating the Congress, the Secretary, and others regarding programs, projects, and activities conducted at those institutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de8bafe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Membership in country clubs and social or dining clubs and organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de8baff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de8bb00-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-16"},"text":"October 16, 1992","children":[],"tail":", the University and NTID shall develop policies, to be applied uniformly, for the allowability of expenditures for each institution. These policies should reflect the unique nature of these institutions. The principles established by the Office of Management and Budget for costs of educational institutions may be used as guidance in developing these policies. General principles relating to allowability and reasonableness of all costs associated with the operations of the institutions shall be addressed. These policies shall be submitted to the Secretary for review and comments, and to the Committee on Education and Labor of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de8bb01-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Policies under subparagraph (A) shall include the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0de8bb02-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Noninstitutional professional activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de8bb03-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fringe benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de8bb04-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interest on loans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de8bb05-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rental cost of buildings and equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de8bb06-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/c/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sabbatical leave.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de8bb07-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/c/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Severance pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de8bb08-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/c/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Travel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de8bb09-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/c/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Royalties and other costs for uses of patents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de8bb0a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4353/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary is not authorized to add items to those specified in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de8bb0b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/371/tII/s203"},"text":"Pub. L. 99–371, title II, § 203","children":[],"tail":", formerly title IV, § 403, "},{"tag":"date","attrib":{"date":"1986-08-04"},"text":"Aug. 4, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/790"},"text":"100 Stat. 790","children":[],"tail":"; renumbered title II, § 203, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/421/tI"},"text":"Pub. L. 102–421, title I","children":[],"tail":", §§ 101(b)(5), (6), 133, "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"Oct. 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2151"},"text":"106 Stat. 2151","children":[],"tail":", 215