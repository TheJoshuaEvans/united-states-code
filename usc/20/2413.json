{"tag":"section","attrib":{"id":"id0dc77768-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2413"},"text":null,"children":[{"tag":"num","attrib":{"value":"2413"},"text":"§ 2413.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State administrative costs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dc77769-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2413/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), for each fiscal year for which an eligible agency receives assistance under this chapter, the eligible agency shall provide, from non-Federal sources for the costs the eligible agency incurs for the administration of programs under this chapter, an amount that is not less than the amount provided by the eligible agency from non-Federal sources for such costs for the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc7776a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2413/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the amount made available from Federal sources for the administration of programs under this chapter for a fiscal year (referred to in this section as the “determination year”) is less than the amount made available from Federal sources for the administration of programs under this chapter for the preceding fiscal year, then the amount the eligible agency is required to provide from non-Federal sources for costs the eligible agency incurs for the administration of programs under this chapter for the determination year under subsection (a) shall bear the same ratio to the amount the eligible agency provided from non-Federal sources for such costs for the preceding fiscal year, as the amount made available from Federal sources for the administration of programs under this chapter for the determination year bears to the amount made available from Federal sources for the administration of programs under this chapter for the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dc7776b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tII/s223"},"text":"Pub. L. 88–210, title II, § 223","children":[],"tail":", formerly title III, § 323, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/b"},"text":"Pub. L. 109–270, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/745"},"text":"120 Stat. 745","children":[],"tail":"; renumbered title II, § 223, "},{"tag":"ref","attrib":{"href":"/us/pl/115/224/tII/s201/a/5"},"text":"Pub. L. 115–224, title II, § 201(a)(5)","children":[],"tail":", (7), "},{"tag":"date","attrib":{"date":"2018-07-31"},"text":"July 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1621"},"text":"132 Stat. 1621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dc7776c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dc7776d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0dc7776e-3a70-11f1-a648-b