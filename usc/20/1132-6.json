{"tag":"section","attrib":{"id":"id0d74009b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"1132–6"},"text":"§ 1132–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Science and technology advanced foreign language education grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d74009c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this section to support programs in institutions of higher education that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d74009d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–6/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" encourage students to develop—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d74009e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–6/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an understanding of science and technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d74009f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–6/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign language proficiency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7400a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–6/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster future international scientific collaboration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7400a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–6/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for professional development opportunities for elementary school and secondary school teachers of critical foreign languages to increase the number of highly qualified teachers in critical foreign languages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7400a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–6/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the number of United States students who achieve the highest level of proficiency in foreign languages critical to the security and competitiveness of the Nation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7400a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop a program for the awarding of grants to institutions of higher education that develop innovative programs for the teaching of foreign languages, which may include the preparation of teachers to teach foreign languages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7400a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall promulgate regulations for the awarding of grants under subsection (b). Such regulations may require institutions of higher education to use grant funds for, among other things—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7400a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–6/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of an on-campus cultural awareness program by which students attend classes taught in a foreign language and study the science and technology developments and practices in a non-English speaking country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7400a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–6/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immersion programs where students take science or technology related course work in a non-English speaking country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7400a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–6/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other programs, such as summer workshops, that emphasize the intense study of a foreign language and science technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7400a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–6/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, recruiting highly qualified teachers in critical foreign languages, and providing professional development activities for such teachers at the elementary school and secondary school levels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7400a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–6/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing innovative opportunities for students that will allow for critical language learning, such as immersion environments, intensive study opportunities, internships, and distance learning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7400aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–6/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant distribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In distributing grants to institutions of higher education under this section, the Secretary shall give priority to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7400ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–6/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions that have programs focusing on curricula that combine the study of foreign languages and the study of science and technology and produce graduates who have both skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7400ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–6/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions teaching critical foreign languages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7400ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–6/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on best practices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7400ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–6/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a study to identify the best practices to strengthen the role of institutions of higher education that receive funding under subchapter III or subchapter V in increasing the critical foreign language education efforts in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7400af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–6/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit a report on the results of such study to the authorizing committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7400b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–6/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section, such sums as may be necessary for fiscal year 2009 and for each subsequent fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d7400b1-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s637"},"text":"Pub. L. 89–329, title VI, § 637","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVI/s622"},"text":"Pub. L. 110–315, title VI, § 622","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3343"},"text":"122 Stat. 3343","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
