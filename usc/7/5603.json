{"tag":"section","attrib":{"id":"idefc6c37a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603"},"text":null,"children":[{"tag":"num","attrib":{"value":"5603"},"text":"§ 5603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural export promotion strategy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefc6c37b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall develop a strategy for implementing Federal agricultural export promotion programs that takes into account the new market opportunities for agricultural products, including opportunities that result from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc6c37c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the North American Free Trade Agreement and the Uruguay Round Agreements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c37d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any accession to membership in the World Trade Organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc9337e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the continued economic growth in the Pacific Rim; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc9337f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other developments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc93380-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The strategy developed under subsection (a) shall encourage the maintenance, development, and expansion of export markets for United States agricultural commodities and related products, including high-value and value-added products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc93381-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals of strategy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategy developed under subsection (a) shall have the following goals:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc93382-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increase the value of United States agricultural exports each year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc93383-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increase the value of United States agricultural exports each year at a faster rate than the rate of increase in the value of overall world export trade in agricultural products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc93384-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increase the value of United States high-value and value-added agricultural exports each year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc93385-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increase the value of United States high-value and value-added agricultural exports each year at a faster rate than the rate of increase in the value of overall world export trade in high-value and value-added agricultural products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc93386-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Ensure that to the extent practicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc93387-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all obligations undertaken in the Uruguay Round Agreement on Agriculture that significantly increase access for United States agricultural commodities are implemented to the extent required by the Uruguay Round Agreements; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc93388-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable United States laws are used to secure United States rights under the Uruguay Round Agreement on Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc93389-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority markets","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc9338a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of markets","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the strategy required under subsection (a), the Secretary shall annually identify as priority markets—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc9338b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those markets in which imports of agricultural products show the greatest potential for increase; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc9338c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those markets in which, with the assistance of Federal export promotion programs, exports of United States agricultural products show the greatest potential for increase.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc9338d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of supporting offices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall identify annually in the budget of the United States Government submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":" each overseas office of the Foreign Agricultural Service that provides assistance to United States exporters in each of the priority markets identified under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefc9338e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/tI/s103"},"text":"Pub. L. 95–501, title I, § 103","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1531"},"text":"Pub. L. 101–624, title XV, § 1531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3670"},"text":"104 Stat. 3670","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIII/s308"},"text":"Pub. L. 102–237, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1856"},"text":"105 Stat. 1856","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s241/a"},"text":"Pub. L. 104–127, title II, § 241(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/963"},"text":"110 Stat. 963","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefc9338f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefc93390-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefc93391-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" amended section generally, substituting present provisions for provisions requiring development of long-term agricultural trade strategy and providing for goals and contents of strategy, establishment of priority markets, review of strategy, confidentiality, withholding of information from Congress, and termination of section on "},{"tag":"date","attrib":{"date":"1995-12-31"},"text":"Dec. 31, 1995","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" inserted a closing parenthesis before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefc93392-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idefc93393-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prohibition on Use of Funds for Promotion of Tobacco or Tobacco Products","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dA/tVII/s770"},"text":"Pub. L. 108–199, div. A, title VII, § 770","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/40"},"text":"118 Stat. 40","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/199/dA/tVII/s770"},"text":"“Hereafter, no funds provided in this or any other Act shall be available to the Secretary of Agriculture acting through the Foreign Agricultural Service to promote the sale or export of tobacco or tobacco products.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idefc93394-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Use of Department of Agriculture Programs for Promotion of Wood and Processed Wood Products","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tIV/s4404"},"text":"Pub. L. 100–418, title IV, § 4404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1402"},"text":"102 Stat. 1402","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/418/tIV/s4404"},"text":"“The Secretary of Agriculture shall actively use Department of Agriculture concessional programs and export credit guarantee programs to promote the export of wood and processed wood products.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
