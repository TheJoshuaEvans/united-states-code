{"tag":"section","attrib":{"id":"idf00e534b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484"},"text":null,"children":[{"tag":"num","attrib":{"value":"7484"},"text":"§ 7484.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required terms in orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf00e534c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An order shall contain the terms and conditions specified in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e534d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and membership of Popcorn Board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00e534e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide for the establishment of, and appointment of members to, a Popcorn Board that shall consist of not fewer than 4 members and not more than 9 members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e534f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nominations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Board shall be processors appointed by the Secretary from nominations submitted by processors in a manner authorized by the Secretary, subject to paragraph (3). Not more than 1 member may be appointed to the Board from nominations submitted by any 1 processor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5350-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographical diversity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making appointments, the Secretary shall take into account, to the extent practicable, the geographical distribution of popcorn production throughout the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5351-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of appointment of each member of the Board shall be 3 years, except that the members appointed to the initial Board shall serve, proportionately, for terms of 2, 3, and 4 years, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5352-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Board shall serve without compensation, but shall be reimbursed for the expenses of the member incurred in the performance of duties for the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e5353-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers and duties of Board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The order shall define the powers and duties of the Board, which shall include the power and duty—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00e5354-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to administer the order in accordance with the terms and provisions of the order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5355-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to issue regulations to effectuate the terms and provisions of the order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5356-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to appoint members of the Board to serve on an executive committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5357-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to propose, receive, evaluate, and approve budgets, plans, and projects of promotion, research, consumer information, and industry information, and to contract with appropriate persons to implement the plans or projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5358-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept and receive voluntary contributions, gifts, and market promotion or similar funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5359-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to invest, pending disbursement under a plan or project, funds collected through assessments authorized under subsection (f), only in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00e535a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obligations of the United States or an agency of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00e535b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" general obligations of a State or a political subdivision of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00e535c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an interest-bearing account or certificate of deposit of a bank that is a member of the Federal Reserve System; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00e535d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/c/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obligations fully guaranteed as to principal and interest by the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e535e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive, investigate, and report to the Secretary complaints of violations of the order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e535f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recommend to the Secretary amendments to the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e5360-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans and budgets","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00e5361-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide that the Board shall submit to the Secretary for approval any plan or project of promotion, research, consumer information, or industry information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5362-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budgets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall require the Board to submit to the Secretary for approval budgets on a fiscal year basis of the anticipated expenses and disbursements of the Board in the implementation of the order, including projected costs of plans and projects of promotion, research, consumer information, and industry information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e5363-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts and agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00e5364-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide that the Board may enter into contracts or agreements for the implementation and carrying out of plans or projects of promotion, research, consumer information, or industry information, including contracts with a processor organization, and for the payment of the cost of the plans or projects with funds collected by the Board under the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5365-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A contract or agreement under paragraph (1) shall provide that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00e5366-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contracting party shall develop and submit to the Board a plan or project, together with a budget that shows the estimated costs to be incurred for the plan or project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00e5367-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan or project shall become effective on the approval of the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00e5368-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contracting party shall keep accurate records of each transaction of the party, account for funds received and expended, make periodic reports to the Board of activities conducted, and make such other reports as the Board or the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5369-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Processor organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide that the Board may contract with processor organizations for any services required in addition to the services described in paragraph (1). The contract shall include provisions comparable to the provisions required by paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e536a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00e536b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Processors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide that each processor marketing popcorn in the United States or for export shall, in the manner prescribed in the order, pay assessments and remit the assessments to the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e536c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct marketers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A processor that markets popcorn produced by the processor directly to consumers shall pay and remit the assessments on the popcorn directly to the Board in the manner prescribed in the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e536d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00e536e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rate of assessment prescribed in the order shall be a rate established by the Board but not more than $.08 per hundredweight of popcorn.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00e536f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide that the Board, with the approval of the Secretary, may raise or lower the rate of assessment annually up to a maximum of $.08 per hundredweight of popcorn.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5370-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of assessments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00e5371-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraphs (B) and (C) and subsection (c)(5), the order shall provide that the assessments collected shall be used by the Board—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf00e5372-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/f/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay expenses incurred in implementing and administering the order, with provision for a reasonable reserve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf00e5373-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/f/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to cover such administrative costs as are incurred by the Secretary, except that the administrative costs incurred by the Secretary (other than any legal expenses incurred to defend and enforce the order) that may be reimbursed by the Board may not exceed 15 percent of the projected annual revenues of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00e5374-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures based on source of assessments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In implementing plans and projects of promotion, research, consumer information, and industry information, the Board shall expend funds on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf00e5375-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/f/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans and projects for popcorn marketed in the United States or Canada in proportion to the amount of assessments collected on domestically marketed popcorn; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf00e5376-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/f/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans and projects for exported popcorn in proportion to the amount of assessments collected on exported popcorn.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00e5377-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/f/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the administrative costs incurred by the Secretary that are reimbursed by the Board exceed 10 percent of the projected annual revenues of the Board, the Secretary shall notify as soon as practicable the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e5378-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall prohibit any funds collected by the Board under the order from being used to influence government action or policy, other than the use of funds by the Board for the development and recommendation to the Secretary of amendments to the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e5379-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Books and records of Board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The order shall require the Board to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00e537a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain such books and records (which shall be available to the Secretary for inspection and audit) as the Secretary may prescribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e537b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit to the Secretary, from time to time, such reports as the Secretary may prescribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e537c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" account for the receipt and disbursement of all funds entrusted to the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e537d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Books and records of processors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00e537e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance and reporting of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The order shall require that each processor of popcorn for the market shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00e537f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain, and make available for inspection, such books and records as are required by the order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00e5380-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file reports at such time, in such manner, and having such content as is prescribed in the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5381-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall authorize the use of information regarding processors that may be accumulated under a law or regulation other than this subchapter or a regulation issued under this subchapter. The information shall be made available to the Secretary as appropriate for the administration or enforcement of this subchapter, the order, or any regulation issued under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5382-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00e5383-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraphs (B), (C), and (D), all information obtained by the Secretary under paragraphs (1) and (2) shall be kept confidential by all officers, employees, and agents of the Board and the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00e5384-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure by Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Information referred to in subparagraph (A) may be disclosed if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf00e5385-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/i/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary considers the information relevant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf00e5386-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/i/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information is revealed in a suit or administrative hearing brought at the request of the Secretary, or to which the Secretary or any officer of the United States is a party; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf00e5387-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/i/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information relates to the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00e5388-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/i/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure to other agency of Federal Government","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf00e5389-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/i/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No information obtained under the authority of this subchapter may be made available to another agency or officer of the Federal Government for any purpose other than the implementation of this subchapter and any investigatory or enforcement activity necessary for the implementation of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf00e538a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/i/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person who knowingly violates this subparagraph shall, on conviction, be subject to a fine of not more than $1,000 or to imprisonment for not more than 1 year, or both, and if an officer, employee, or agent of the Board or the Department, shall be removed from office or terminated from employment, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00e538b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/i/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General statements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this paragraph prohibits—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf00e538c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/i/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuance of general statements based on the reports of a number of persons subject to an order or statistical data collected from the reports, if the statements do not identify the information provided by any person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf00e538d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/i/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the publication, by direction of the Secretary, of the name of a person violating the order, together with a statement of the particular provisions of the order violated by the person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e538e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7484/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall contain such other terms and conditions, consistent with this subchapter, as are necessary to effectuate this subchapter, including regulations relating to the assessment of late payment charges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf00e538f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s575"},"text":"Pub. L. 104–127, title V, § 575","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1077"},"text":"110 Stat. 1077","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
