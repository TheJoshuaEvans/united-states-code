{"tag":"section","attrib":{"id":"idef7a7797-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2254b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2254b"},"text":"§ 2254b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds appropriated for Agricultural Research Service for research related to tobacco or tobacco products; exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"2007-12-26"},"text":"December 26, 2007","children":[],"tail":", none of the funds appropriated under this heading shall be available to carry out research related to the production, processing, or marketing of tobacco or tobacco products: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That on and after "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"December 26, 2007","children":[],"tail":", this paragraph shall not apply to research on the medical, biotechnological, food, and industrial uses of tobacco."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef7a7798-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/dA/tI"},"text":"Pub. L. 110–161, div. A, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1851"},"text":"121 Stat. 1851","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7a7799-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef7a779a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attr