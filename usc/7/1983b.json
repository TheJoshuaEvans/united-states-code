{"tag":"section","attrib":{"id":"idef18a82b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1983b"},"text":"§ 1983b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beginning farmer and rancher individual development accounts pilot program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef18a82c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef18a82d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “demonstration program” means a demonstration program carried out by a qualified entity under the pilot program established in subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef18a82e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible participant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible participant” means a qualified beginning farmer or rancher that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef18a82f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lacks significant financial resources or assets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef18a830-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has an income that is less than—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef18a831-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 80 percent of the median income of the State in which the farmer or rancher resides; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef18a832-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 200 percent of the most recent annual Federal Poverty Income Guidelines published by the Department of Health and Human Services for the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef18a833-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual development account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “individual development account” means a savings account described in subsection (b)(4)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef18a834-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified entity","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef18a835-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified entity” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef18a836-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 1 or more organizations—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef18a837-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/a/4/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef18a838-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/a/4/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempt from taxation under section 501(a) of such title; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef18a839-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, local, or tribal government submitting an application jointly with an organization described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef18a83a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No prohibition on collaboration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An organization described in subparagraph (A)(i) may collaborate with a financial institution or for-profit community development corporation to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef18a83b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef18a83c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a pilot program to be known as the “New Farmer Individual Development Accounts Pilot Program” under which the Secretary shall work through qualified entities to establish demonstration programs—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef18a83d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of at least 5 years in duration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef18a83e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in at least 15 States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef18a83f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall operate the pilot program through, and in coordination with the farm loan programs of, the Farm Service Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef18a840-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef18a841-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A qualified entity carrying out a demonstration program under this section shall establish a reserve fund consisting of a non-Federal match of 50 percent of the total amount of the grant awarded to the demonstration program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef18a842-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the qualified entity has deposited the non-Federal matching funds described in subparagraph (A) in the reserve fund, the Secretary shall provide the total amount of the grant awarded under this section to the demonstration program for deposit in the reserve fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef18a843-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds deposited under subparagraph (B) in the reserve fund established for a demonstration program, the qualified entity carrying out the demonstration program—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef18a844-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use up to 10 percent for administrative expenses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef18a845-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall use the remainder in making matching awards described in paragraph (4)(B)(ii)(I).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef18a846-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any interest earned on amounts in a reserve fund established under subparagraph (A) may be used by the qualified entity as additional matching funds for, or to administer, the demonstration program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef18a847-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue guidance regarding the investment requirements of reserve funds established under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef18a848-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reversion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the date on which all funds remaining in any individual development account established by a qualified entity have reverted under paragraph (5)(B)(ii) to the reserve fund established by the qualified entity, there shall revert to the Treasury of the United States a percentage of the amount (if any) in the reserve fund equal to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef18a849-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/3/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of Federal funds deposited in the reserve fund under subparagraph (B) that were not used for administrative expenses; divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef18a84a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/3/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of funds deposited in the reserve fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef18a84b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual development accounts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef18a84c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A qualified entity receiving a grant under this section shall establish and administer individual development accounts for eligible participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef18a84d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive funds under this section from a qualified entity, an eligible participant shall enter into a contract with only 1 qualified entity under which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef18a84e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the eligible participant agrees—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef18a84f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to deposit a certain amount of funds of the eligible participant in a personal savings account, as prescribed by the contractual agreement between the eligible participant and the qualified entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef18a850-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use the funds described in subclause (I) only for 1 or more eligible expenditures described in paragraph (5)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef18a851-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/4/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to complete financial training; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef18a852-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the qualified entity agrees—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef18a853-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to deposit, not later than 1 month after an amount is deposited pursuant to clause (i)(I), at least a 100-percent, and up to a 200-percent, match of that amount into the individual development account established for the eligible participant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef18a854-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with uses of funds proposed by the eligible participant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef18a855-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef18a856-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A qualified entity administering a demonstration program under this section may provide not more than $6,000 for each fiscal year in matching funds to the individual development account established by the qualified entity for an eligible participant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef18a857-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An amount provided under clause (i) shall not be considered to be a gift or loan for mortgage purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef18a858-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible expenditures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef18a859-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible expenditure described in this subparagraph is an expenditure—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef18a85a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to purchase farmland or make a down payment on an accepted purchase offer for farmland;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef18a85b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make mortgage payments on farmland purchased pursuant to clause (i), for up to 180 days after the date of the purchase;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef18a85c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to purchase breeding stock, fruit or nut trees, or trees to harvest for timber; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef18a85d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/5/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for other similar expenditures, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef18a85e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef18a85f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible participant may make an eligible expenditure at any time during the 2-year period beginning on the date on which the last matching funds are provided under paragraph (4)(B)(ii)(I) to the individual development account established for the eligible participant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef18a860-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unexpended funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the end of the period described in clause (i), any funds remaining in an individual development account established for an eligible participant shall revert to the reserve fund of the demonstration program under which the account was established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef18a861-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef18a862-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A qualified entity that seeks to carry out a demonstration program under this section may submit to the Secretary an application at such time, in such form, and containing such information as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef18a863-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In considering whether to approve an application to carry out a demonstration program under this section, the Secretary shall assess—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef18a864-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree to which the demonstration program described in the application is likely to aid eligible participants in successfully pursuing new farming opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef18a865-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the experience and ability of the qualified entity to responsibly administer the demonstration program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef18a866-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the experience and ability of the qualified entity in recruiting, educating, and assisting eligible participants to increase economic independence and pursue or advance farming opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef18a867-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of direct funds from non-Federal public sector and private sources that are formally committed to the demonstration program as matching contributions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef18a868-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy of the plan of the qualified entity to provide information relevant to an evaluation of the demonstration program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef18a869-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other factors as the Secretary considers to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef18a86a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferences","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In considering an application to conduct a demonstration program under this section, the Secretary shall give preference to an application from a qualified entity that demonstrates—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef18a86b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a track record of serving clients targeted by the program, including, as appropriate, socially disadvantaged farmers or ranchers (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2003/e/2"},"text":"section 2003(e)(2) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef18a86c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expertise in dealing with financial management aspects of farming.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef18a86d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the date of enactment of this section, in accordance with this section, the Secretary shall, on a competitive basis, approve such applications to conduct demonstration programs as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef18a86e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary approves an application to carry out a demonstration program, the Secretary shall authorize the applicant to carry out the project for a period of 5 years, plus an additional 2 years to make eligible expenditures in accordance with subsection (b)(5)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef18a86f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef18a870-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make a grant to a qualified entity authorized to carry out a demonstration program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef18a871-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The aggregate amount of grant funds provided to a demonstration program carried out under this section shall not exceed $250,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef18a872-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of grant payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall pay the amounts awarded under a grant made under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef18a873-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the awarding of the grant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef18a874-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to such payment plan as the qualified entity may specify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef18a875-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef18a876-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual progress reports","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef18a877-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the end of the calendar year in which the Secretary authorizes a qualified entity to carry out a demonstration program under this section, and annually thereafter until the conclusion of the demonstration program, the qualified entity shall prepare an annual report that includes, for the period covered by the report—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef18a878-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the progress of the demonstration program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef18a879-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information about the demonstration program, including the eligible participants and the individual development accounts that have been established; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef18a87a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/e/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef18a87b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A qualified entity shall submit each report required under subparagraph (A) to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef18a87c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by the Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the date on which all demonstration programs under this section are concluded, the Secretary shall submit to Congress a final report that describes the results and findings of all reports and evaluations carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef18a87d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may conduct an annual review of the financial records of a qualified entity—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef18a87e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assess the financial soundness of the qualified entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef18a87f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine the use of grant funds made available to the qualified entity under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef18a880-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary may promulgate regulations to ensure that the program includes provisions for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef18a881-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the termination of demonstration programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef18a882-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" control of the reserve funds in the case of such a termination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef18a883-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer of demonstration programs to other qualified entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef18a884-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remissions from a reserve fund to the Secretary in a case in which a demonstration program is terminated without transfer to a new qualified entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef18a885-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2008 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef18a886-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s333B"},"text":"Pub. L. 87–128, title III, § 333B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tV/s5301"},"text":"Pub. L. 110–234, title V, § 5301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1147"},"text":"122 Stat. 1147","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us