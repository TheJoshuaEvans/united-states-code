{"tag":"section","attrib":{"id":"idef81a3c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2323"},"text":null,"children":[{"tag":"num","attrib":{"value":"2323"},"text":"§ 2323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The organization of the Plant Variety Protection Office shall, except as provided herein, be determined by the Secretary of Agriculture (hereinafter called the Secretary). The office shall devote itself substantially exclusively to the administration of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef81a3c6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tI/s3"},"text":"Pub. L. 91–577, title I, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1542"},"text":"84 Stat. 1542","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
