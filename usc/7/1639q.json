{"tag":"section","attrib":{"id":"ideee1e159-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q"},"text":null,"children":[{"tag":"num","attrib":{"value":"1639q"},"text":"§ 1639q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Agriculture","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideee1e15a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Agriculture plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee1e15b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a State or Indian tribe for which a State or Tribal plan is not approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1639p"},"text":"section 1639p of this title","children":[],"tail":", the production of hemp in that State or the territory of that Indian tribe shall be subject to a plan established by the Secretary to monitor and regulate that production in accordance with paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e15c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A plan established by the Secretary under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee1e15d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a practice to maintain relevant information regarding land on which hemp is produced in the State or territory of the Indian tribe, including a legal description of the land, for a period of not less than 3 calendar years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e15e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a procedure for testing, using post-decarboxylation or other similarly reliable methods, delta-9 tetrahydrocannabinol concentration levels of hemp produced in the State or territory of the Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e15f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a procedure for the effective disposal of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideee1e160-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plants, whether growing or not, that are produced in violation of this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideee1e161-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" products derived from those plants;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e162-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a procedure to comply with the enforcement procedures under subsection (c)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e163-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a procedure for conducting annual inspections of, at a minimum, a random sample of hemp producers to verify that hemp is not produced in violation of this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e164-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other practices or procedures as the Secretary considers to be appropriate, to the extent that the practice or procedure is consistent with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee1e165-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a procedure to issue licenses to hemp producers in accordance with a plan established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee1e166-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee1e167-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a State or Indian tribe for which a State or Tribal plan is not approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1639p"},"text":"section 1639p of this title","children":[],"tail":", it shall be unlawful to produce hemp in that State or the territory of that Indian tribe without a license issued by the Secretary under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e168-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negligent and other violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A violation of a plan established under subsection (a) shall be subject to enforcement in accordance with paragraphs (2) and (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1639p/e"},"text":"section 1639p(e) of this title","children":[],"tail":", except that the Secretary shall carry out that enforcement instead of a State department of agriculture or Tribal government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e169-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting to Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a State or Indian tribe covered by paragraph (1), the Secretary shall report the production of hemp without a license issued by the Secretary under subsection (b) to the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee1e16a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information sharing for law enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee1e16b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee1e16c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect the information described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e16d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the information collected under subparagraph (A) accessible in real time to Federal, State, territorial, and local law enforcement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e16e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information collected by the Secretary under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee1e16f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contact information for each hemp producer in a State or the territory of an Indian tribe for which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideee1e170-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or Tribal plan is approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1639p/b"},"text":"section 1639p(b) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideee1e171-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan is established by the Secretary under this section;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e172-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a legal description of the land on which hemp is grown by each hemp producer described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e173-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each hemp producer described in subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideee1e174-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the status of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ideee1e175-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/d/2/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a license or other required authorization from the State department of agriculture or Tribal government, as applicable; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideee1e176-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/d/2/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a license from the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideee1e177-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639q/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any changes to the status.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideee1e178-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 297C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tX/s10113"},"text":"Pub. L. 115–334, title X, § 10113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4912"},"text":"132 Stat. 4912","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
