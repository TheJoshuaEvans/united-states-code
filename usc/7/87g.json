{"tag":"section","attrib":{"id":"idedf1186f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87g"},"text":null,"children":[{"tag":"num","attrib":{"value":"87g"},"text":"§ 87g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to State and local laws; separability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idedf11870-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No State or subdivision thereof may require the inspection or description in accordance with any standards of kind, class, quality, condition, or other characteristics of grain as a condition of shipment, or sale, of such grain in interstate or foreign commerce, or require any license for, or impose any other restrictions upon the performance of any official inspection or weighing function under this chapter by official inspection personnel. Otherwise nothing in this chapter shall invalidate any law or other provision of any State or subdivision thereof in the absence of a conflict with this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf11871-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If any provision of this chapter or the application thereof to any person or circumstances is held invalid, the validity of the remainder of the chapter and of the application of such provision to other persons and circumstances shall not be affected thereby.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idedf11872-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. B, § 18, 