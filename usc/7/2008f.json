{"tag":"section","attrib":{"id":"idef249002-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008f"},"text":null,"children":[{"tag":"num","attrib":{"value":"2008f"},"text":"§ 2008f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crop insurance requirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef249003-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of obtaining any benefit (including a direct loan, loan guarantee, or payment) described in subsection (b), a borrower must obtain at least catastrophic risk protection insurance coverage under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1508"},"text":"section 1508 of this title","children":[],"tail":" for the crop and crop year for which the benefit is sought, if the coverage is offered by the Corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef249004-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef249005-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a farm ownership loan (FO) under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1923"},"text":"section 1923 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef249006-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an operating loan (OL) under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1942"},"text":"section 1942 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef249007-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an emergency loan (EM) under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1961"},"text":"section 1961 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef249008-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s371"},"text":"Pub. L. 87–128, title III, § 371","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tI/s119/b"},"text":"Pub. L. 103–354, title I, § 119(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3208"},"text":"108 Stat. 3208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef249009-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef24900a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idef24900b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":nu