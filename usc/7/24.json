{"tag":"section","attrib":{"id":"idede04f8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24"},"text":null,"children":[{"tag":"num","attrib":{"value":"24"},"text":"§ 24.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Customer property with respect to commodity broker debtors; definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idede04f8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations respecting commodity broker debtors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding title 11, the Commission may provide, with respect to a commodity broker that is a debtor under chapter 7 of title 11, by rule or regulation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idede04f8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that certain cash, securities, other property, or commodity contracts are to be included in or excluded from customer property or member property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede04f90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that certain cash, securities, other property, or commodity contracts are to be specifically identifiable to a particular customer in a specific capacity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede04f91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the method by which the business of such commodity broker is to be conducted or liquidated after the date of the filing of the petition under such chapter, including the payment and allocation of margin with respect to commodity contracts not specifically identifiable to a particular customer pending their orderly liquidation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede04f92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any persons to which customer property and commodity contracts may be transferred under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s766"},"text":"section 766 of title 11","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede04f93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the net equity of a customer is to be determined.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idede04f94-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the terms “commodity broker”, “commodity contract”, “customer”, “customer property”, “member property”, “net equity”, and “security” have the meanings assigned such terms for the purposes of subchapter IV of chapter 7 of title 11.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idede04f95-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Portfolio margining accounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall exercise its authority to ensure that securities held in a portfolio margining account carried as a futures account are customer property and the owners of those accounts are customers for the purposes of subchapter IV of chapter 7 of title 11.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idede04f96-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369/s20"},"text":"Sept. 21, 1922, ch. 369, § 20","children":[],"tail":", formerly § 19, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/tIII/s302"},"text":"Pub. L. 95–598, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2673"},"text":"92 Stat. 2673","children":[],"tail":"; renumbered and amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/222/s20"},"text":"Pub. L. 97–222, § 20","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-07-27"},"text":"July 27, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/241"},"text":"96 Stat. 241","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVII/s713/c"},"text":"Pub. L. 111–203, title VII, § 713(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1647"},"text":"124 Stat. 1647","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idede04f97-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idede04f98-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idede04f99-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/222/s20/b"},"text":"Pub. L. 97–222, § 20(b)","children":[],"tail":", inserted “, including the payment and allocation of margin with respect to commodity contracts not specifically identifiable to a particular customer pending their orderly liquidation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idede04f9a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idede04f9b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the later of 360 days after "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", or, to the extent a provision of subtitle A (§§ 711–754) of title VII of "},{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" requires a rulemaking, not less than 60 days after publication of the final rule or regulation implementing such provision of subtitle A, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s754"},"text":"section 754 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1a"},"text":"section 1a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idede04f9c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/s402/d"},"text":"section 402(d) of Pub. L. 95–598","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":", Bankruptcy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
