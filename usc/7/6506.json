{"tag":"section","attrib":{"id":"idefe5bbfa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506"},"text":null,"children":[{"tag":"num","attrib":{"value":"6506"},"text":"§ 6506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe5bbfb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A program established under this chapter shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bbfc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide that an agricultural product to be sold or labeled as organically produced must—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe5bbfd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be produced only on certified organic farms and handled only through certified organic handling operations in accordance with this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bbfe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be produced and handled in accordance with such program;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that producers and handlers desiring to participate under such program establish an organic plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6513"},"text":"section 6513 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc00-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for procedures that allow producers and handlers to appeal an adverse administrative determination under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc01-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require each certified organic farm or each certified organic handling operation to certify to the Secretary, the governing State official (if applicable), and the certifying agent on an annual basis, that such farm or handler has not produced or handled any agricultural product sold or labeled as organically produced except in accordance with this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc02-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for annual on-site inspection by the certifying agent of each farm and handling operation that has been certified under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc03-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require periodic residue testing by certifying agents of agricultural products that have been produced on certified organic farms and handled through certified organic handling operations to determine whether such products contain any pesticide or other nonorganic residue or natural toxicants and to require certifying agents, to the extent that such agents are aware of a violation of applicable laws relating to food safety, to report such violation to the appropriate health agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc04-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for appropriate and adequate enforcement procedures, as determined by the Secretary to be necessary and consistent with this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc05-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect against conflict-of-interest as specified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6515/g"},"text":"section 6515(g) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc06-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for public access to certification documents and laboratory analyses that pertain to certification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc07-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the collection of reasonable fees from producers, certifying agents and handlers who participate in such program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc08-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require such other terms and conditions as may be determined by the Secretary to be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc09-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An organic certification program established under this chapter may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bc0a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide for the certification of an entire farm or handling operation or specific fields of a farm or parts of a handling operation if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe5bc0b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a farm or field, the area to be certified has distinct, defined boundaries and buffer zones separating the land being operated through the use of organic methods from land that is not being operated through the use of such methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bc0c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operators of such farm or handling operation maintain records of all organic operations separate from records relating to other operations and make such records available at all times for inspection by the Secretary, the certifying agent, and the governing State official; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bc0d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate physical facilities, machinery, and management practices are established to prevent the possibility of a mixing of organic and nonorganic products or a penetration of prohibited chemicals or other substances on the certified area; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc0e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for reasonable exemptions from specific requirements of this chapter (except the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6511"},"text":"section 6511 of this title","children":[],"tail":") with respect to agricultural products produced on certified organic farms if such farms are subject to a Federal or State emergency pest or disease treatment program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wild seafood","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bc10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the requirement of subsection (a)(1)(A) requiring products be produced only on certified organic farms, the Secretary shall allow, through regulations promulgated after public notice and opportunity for comment, wild seafood to be certified or labeled as organic.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and accommodation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe5bc12-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consult with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefe5bc13-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe5bc14-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Organic Standards Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6518"},"text":"section 6518 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe5bc15-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" producers, processors, and sellers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe5bc16-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other interested members of the public; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bc17-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, accommodate the unique characteristics of the industries in the United States that harvest and process wild seafood.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc18-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State organic certification program approved under this chapter may contain additional guidelines governing the production or handling of products sold or labeled as organically produced in such State as required in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6507"},"text":"section 6507 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc19-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bc1a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees collected under subsection (a)(10) (including late payment penalties and interest earned from investment of the fees) shall be credited to the account that incurs the cost of the services provided under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc1b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6506/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The collected fees shall be available to the Secretary, without further appropriation or fiscal-year limitation, to pay the expenses of the Secretary incurred in providing accreditation services under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe5bc1c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXI/s2107"},"text":"Pub. L. 101–624, title XXI, § 2107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3938"},"text":"104 Stat. 3938","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tVI/s601/a"},"text":"Pub. L. 105–185, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/585"},"text":"112 Stat. 585","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/11/tII/s2105"},"text":"Pub. L. 108–11, title II, § 2105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-16"},"text":"Apr. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/589"},"text":"117 Stat. 589","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tX/s10005/b/2"},"text":"Pub. L. 113–79, title X, § 10005(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/944"},"text":"128 Stat. 944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefe5bc1d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefe5bc1e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefe5bc1f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" substituted “section 6515(g)” for “section 6515(h)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/11"},"text":"Pub. L. 108–11","children":[],"tail":" added subsec. (c) and redesignated former subsecs. (c) and (d) as (d) and (e), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185"},"text":"Pub. L. 105–185","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
