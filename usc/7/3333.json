{"tag":"section","attrib":{"id":"idefaa3ad1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3333"},"text":null,"children":[{"tag":"num","attrib":{"value":"3333"},"text":"§ 3333.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rangeland research grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefaa3ad2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3333/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make grants to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefaa3ad3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3333/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land-grant colleges and universities, State agricultural experiment stations, and colleges, universities, and Federal laboratories having a demonstrable capacity in rangeland research, as determined by the Secretary, to carry out rangeland research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefaa3ad4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3333/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Joe Skeen Institute for Rangeland Restoration for the purposes of facilitating and expanding ongoing State-Federal range management, animal husbandry, and agricultural research, education, and extension programs to meet the targeted, emerging, and future needs of western United States rangelands and associated natural resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac83c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3333/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefac83c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3333/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), this grant program shall be based on a matching formula of 50 percent Federal and 50 percent non-Federal funding (including funding from an agricultural commodity promotion, research, and information program).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefac83c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3333/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to a grant to a Federal laboratory or a grant under subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefac83c8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1480"},"text":"Pub. L. 95–113, title XIV, § 1480","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXIV/s1440/a"},"text":"Pub. L. 97–98, title XIV, § 1440(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1319"},"text":"95 Stat. 1319","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7209/d"},"text":"Pub. L. 107–171, title VII, § 7209(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/445"},"text":"116 Stat. 445","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7128/b/1/C"},"text":"Pub. L. 113–79, title VII, § 7128(b)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/878"},"text":"128 Stat. 878","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7614/b/1/C"},"text":"Pub. L. 115–334, title VII, § 7614(b)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4834"},"text":"132 Stat. 4834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefac83c9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefac83ca-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefac83cb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" struck out subsec. (a) designation and heading and subsec. (b). Prior to amendment, subsec. (b) related to matching requirements."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" inserted section catchline and amended text generally. Prior to amendment, text read as follows: “The Secretary may make grants to land-grant colleges and universities, State agricultural experiment stations, and to colleges, universities, and Federal laboratories having a demonstrable capacity in rangeland research, as determined by the Secretary, to carry out rangeland research. Except in the case of Federal laboratories, this grant program shall be based on a matching formula of 50 per centum Federal and 50 per centum non-Federal funding.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefac83cc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idefac83cd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" applicable to grants, cooperative agreements, or other awards made after "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", with matching funds requirement in effect on "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", to continue to apply to such grant, cooperative agreement, or other award, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7614/c"},"text":"section 7614(c) of Pub. L. 115–334","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3151"},"text":"section 3151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefac83ce-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1801"},"text":"section 1801 of Pub. L. 97–98","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
