{"tag":"section","attrib":{"id":"idee19880e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s178n"},"text":null,"children":[{"tag":"num","attrib":{"value":"178n"},"text":"§ 178n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration and funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee19880f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s178n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations to Secretary of Agriculture","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary of Agriculture to carry out this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee198810-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s178n/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for each of fiscal years 1991 through 2013; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee198811-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s178n/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee198812-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s178n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration and management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No more than 3 per centum of funds authorized under subsection (a) shall be available for administration and management of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee198813-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s178n/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract authority as limited by amounts provided in appropriations acts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this subchapter the authority to enter into contracts shall be effective for any fiscal year only to such extent or in such amounts as are provided in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee198814-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s178n/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities limited to critical materials other than native latex after fiscal 1988","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this subchapter, the Secretaries and the Joint Commission shall limit their activities under this subchapter to critical agricultural materials other than native latex after the close of the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1988-09-30"},"text":"September 30, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee198815-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/592/s16"},"text":"Pub. L. 95–592, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-04"},"text":"Nov. 4, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"hr