{"tag":"section","attrib":{"id":"ideeb48f10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1471e"},"text":"§ 1471e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideeb48f11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the assistance provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1471d"},"text":"section 1471d of this title","children":[],"tail":", if the Secretary determines that the livestock emergency also requires the implementation of one or more of the assistance programs described in subsection (b), the Secretary shall implement such programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeb48f12-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Special assistance under this section includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeb48f13-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the donation of feed owned by the Commodity Credit Corporation for use in feeding livestock stranded and unidentified as to its owner, including the cost of transporting feed to the affected area, during such period as the Secretary, by regulation, may prescribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f14-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reimbursement of not to exceed 50 percent of the cost of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeb48f15-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471e/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" installing pipelines (if that is the least expensive method) or other facilities, including tanks or troughs, for livestock water;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeb48f16-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471e/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction or deepening of wells or ponds for livestock water; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeb48f17-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471e/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing springs or seeps for livestock water,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as appropriate in drought areas to facilitate more efficient and better-distributed grazing on land normally used for grazing. Such cost-share assistance may not be made available to provide water for wildlife or recreational livestock, dry lot feeding, or barns or corrals, or to acquire pumping equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f18-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimbursement of not to exceed 50 percent of the cost of burning prickly pear cactus to make it suitable for animal feed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f19-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making commodities owned by the Commodity Credit Corporation available to livestock producers through the use of a catalog that specifies lots of a size that are economically feasible for a small producer to obtain by means of certificate exchanges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeb48f1a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water development projects for 1988 and 1989 emergencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make available at least $25,000,000 to provide special assistance under subsection (b)(2) for livestock emergencies in 1988 and 1989.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideeb48f1b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-31/ch792"},"text":"Oct. 31, 1949, ch. 792","children":[],"tail":", title VI, § 607, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/387/tI/s101/a"},"text":"Pub. L. 100–387, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-11"},"text":"Aug. 11, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/930"},"text":"102 Stat. 930","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/82/tI/s142"},"text":"Pub. L. 101–82, title I, § 142","children":[],"tail":", title II, § 203, "},{"tag":"date","attrib":{"date":"1989-08-14"},"text":"Aug. 14, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/579"},"text":"103 Stat. 579","children":[],"tail":", 581.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideeb48f1c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideeb48f1d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideeb48f1e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/82/s142"},"text":"Pub. L. 101–82, § 142","children":[],"tail":", inserted “or ponds”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/82/s203"},"text":"Pub. L. 101–82, § 203","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideeb48f1f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideeb48f20-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Eff