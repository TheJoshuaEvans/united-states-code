{"tag":"section","attrib":{"id":"idee2c9b4d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390"},"text":null,"children":[{"tag":"num","attrib":{"value":"390"},"text":"§ 390.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee2c9b4e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural research facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agricultural research facility” means a proposed facility for research in food and agricultural sciences for which Federal funds are requested by an entity eligible to receive funds under a capacity and infrastructure program (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6971/f/1/C"},"text":"section 6971(f)(1)(C) of this title","children":[],"tail":") to assist in the construction, alteration, acquisition, modernization, renovation, or remodeling of the facility."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee2c9b4f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional agriculture committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “congressional agriculture committees” means the Committee on Appropriations and the Committee on Agriculture of the House of Representatives and the Committee on Appropriations and the Committee on Agriculture, Nutrition, and Forestry of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee2c9b50-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food and agricultural sciences","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “food and agricultural sciences” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3103"},"text":"section 3103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee2c9b51-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee2c9b52-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/74/s2"},"text":"Pub. L. 88–74, § 2","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s884/a"},"text":"Pub. L. 104–127, title VIII, § 884(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1176"},"text":"110 Stat. 1176","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII"},"text":"Pub. L. 107–171, title VII","children":[],"tail":", §§ 7214, 7308(b), "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/448"},"text":"116 Stat. 448","chil