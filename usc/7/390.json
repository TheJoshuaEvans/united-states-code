":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee2c9b56-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 390, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/74/s1"},"text":"Pub. L. 88–74, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-07-22"},"text":"July 22, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/90"},"text":"77 Stat. 90","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1416/3"},"text":"Pub. L. 95–113, title XIV, § 1416(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/996"},"text":"91 Stat. 996","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXIV/s1411/a"},"text":"Pub. L. 99–198, title XIV, § 1411(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1547"},"text":"99 Stat. 1547","children":[],"tail":", related to congressional declaration of policy, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/74/s2"},"text":"section 2 of Pub. L. 88–74","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s390a"},"text":"section 390a of this title","children":[],"tail":" prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee2f0b57-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “an entity eligible to receive funds under a capacity and infrastructure program (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6971/f/1/C"},"text":"section 6971(f)(1)(C) of this title","children":[],"tail":")” for “a college, university, or nonprofit institution”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7101/b/1"},"text":"Pub. L. 110–246, § 7101(b)(1)","children":[],"tail":", substituted “3103” for “3103(8)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7214"},"text":"Pub. L. 107–171, § 7214","children":[],"tail":", reenacted heading without change and amended text of par. (3) generally. Prior to amendment, text read as follows: “The term ‘food and agricultural sciences’ means—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) agriculture, including soil and water conservation and use, the use of organic materials to improve soil tilth and fertility, plant and animal production and protection, and plant and animal health;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the processing, distribution, marketing, and utilization of food and agricultural products;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) forestry, including range management, production of forest and range products, multiple use of forests and rangelands, and urban forestry;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) aquaculture (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3103/3"},"text":"section 3103(3) of this title","children":[],"tail":");"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) human nutrition;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(F) production inputs, such as energy, to improve productivity; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(G) germ plasm collection and preservation.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7308/b"},"text":"Pub. L. 107–171, § 7308(b)","children":[],"tail":", struck out heading and text of par. (5). Text read as follows: “The term ‘task force’ means the Strategic Planning Task Force established under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s390b"},"text":"section 390b of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee2f0b58-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee2f0b59-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idee2f0b5a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s884/b"},"text":"Pub. L. 104–127, title VIII, § 884(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1179"},"text":"110 Stat. 1179","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/127/tVIII/s884/b"},"text":"“The amendment made by subsection (a) [enacting this subchapter], other than section 4 of the Research Facilities Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s390b"},"text":"section 390b of this title","children":[],"tail":"] (as amended by subsection (a)), shall not apply to any project for an agricultural research facility for which funds have been made available for a feasibility study or for any phase of the project prior to "},{"tag":"date","attrib":{"date":"1995-10-01"},"text":"October 1, 1995","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idee2f0b5b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/88/74/s1"},"text":"Pub. L. 88–74, § 1","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"hre