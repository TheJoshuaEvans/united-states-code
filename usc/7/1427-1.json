{"tag":"section","attrib":{"id":"idee9a50a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1427–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1427–1"},"text":"§ 1427–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quality requirements for Commodity Credit Corporation owned grain","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee9a50a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1427–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of minimum standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary shall establish minimum quality standards that shall apply to grain that is deposited for storage for the account of the Commodity Credit Corporation. In establishing such standards, the Secretary shall take into consideration factors related to the ability of grain to withstand storage and assurance of acceptable end-use performance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee9a50a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1427–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection of grain acquisitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commodity Credit Corporation shall utilize Federal Grain Inspection Service approved procedures to inspect and evaluate the condition of the grain it acquires from producers. In no case shall this section require the use of an official inspection unless the producer so requests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee9a50a5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-31/ch792"},"text":"Oct. 31, 1949, ch. 792","children":[],"tail":", title IV, § 407A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXX/s2012"},"text":"Pub. L. 101–624, title XX, § 2012","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3933"},"text":"104 Stat. 3933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee9a50a6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee9a50a7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idee9a50a8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inapplicability of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section inapplicable to 2014 through 2018 crops of covered commodities, cotton, and sugar and inapplicable to milk during period beginning ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9092/b/10"},"text":"section 9092(b)(10) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section inapplicable to 2008 through 2012 crops of covered commodities, peanuts, and sugar and inapplicable to milk during period beginning ","children":[{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", through "},{"tag":"date","attrib