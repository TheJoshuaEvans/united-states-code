{"tag":"section","attrib":{"id":"idefbd4cad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4610a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4610a"},"text":"§ 4610a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations and power to subpoena","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefbd4cae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4610a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make such investigations as the Secretary determines necessary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbd4caf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4610a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the effective administration of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbd4cb0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4610a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine whether a person has engaged or is engaging in any act or practice that constitutes a violation of any provision of this chapter, or of any order, rule, or regulation issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbd4cb1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4610a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Power to subpoena","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbd4cb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4610a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of an investigation made under subsection (a), the Secretary is authorized to administer oaths and affirmations and to issue a subpoena to require the production of any records that are relevant to the inquiry. The production of any such records may be required from any place in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbd4cb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4610a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of an administrative hearing held under section 4609 or 4610 of this title, the presiding officer is authorized to administer oaths and affirmations, subpoena witnesses, compel their attendance, take evidence, and require the production of any records that are relevant to the inquiry. Such attendance of witnesses and the production of any such records may be required from any place in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbd4cb4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4610a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aid of courts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In case of contumacy by, or refusal to obey a subpoena issued to, any person, the Secretary may invoke the aid of any court of the United States within the jurisdiction of which such investigation or proceeding is carried on, or where such person resides or carries on business, in order to enforce a subpoena issued by the Secretary under subsection (b). The court may issue an order requiring such person to comply with such a subpoena.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbd4cb5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4610a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contempt","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any failure to obey such order of the court may be punished by such court as a contempt thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbd4cb6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4610a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Process in any such case may be served in the judicial district in which such person resides or conducts business or wherever such person may be found.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbd4cb7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4610a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearing site","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The site of any hearings held under section 4609 or 4610 of this title shall be within the judicial district where such person resides or has a principal place of business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefbd4cb8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/590/s11A"},"text":"Pub. L. 98–590, § 11A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1986"},"text":"Pub. L. 101–624, title XIX, § 1986","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3908"},"text":"104 Stat. 3908","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tVIII/s807/2"},"text":"Pub. L. 102–237, title VIII, § 807(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1883"},"text":"105 Stat. 1883","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefbd4cb9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefbd4cba-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefbd4cbb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" struck out “section” after “4609 or”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
