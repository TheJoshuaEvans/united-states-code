{"tag":"section","attrib":{"id":"idf00e530e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7471"},"text":null,"children":[{"tag":"num","attrib":{"value":"7471"},"text":"§ 7471.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension or termination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf00e530f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7471/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary finds that an order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7463"},"text":"section 7463 of this title","children":[],"tail":", or a provision of the order, obstructs or does not tend to effectuate the purposes of this subchapter, the Secretary shall suspend or terminate the operation of the order or provision."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e5310-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7471/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The suspension or termination of any order, or any provision of an order, shall not be considered an order under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf00e5311-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s562"},"text":"Pub. L. 104–127, title V, § 562","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1074"},"text":"110 Stat. 1074","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
