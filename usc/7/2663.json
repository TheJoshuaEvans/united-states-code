tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s792/b/2/A/ii"},"text":"Pub. L. 104–127, § 792(b)(2)(A)(ii)","children":[],"tail":", (iii), which directed substitution of “subsections (e), (h), and (i) of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2662"},"text":"section 2662 of this title","children":[],"tail":" shall be distributed” for “section 2662(e)” and all that follows through “shall be distributed” and “objectives of subsections (e), (h), and (i) of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2662"},"text":"section 2662 of this title","children":[],"tail":"” for “objectives of” and all that follows through “title”, could not be executed because of prior amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":", which substituted “subsections (e) and (i) of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2662"},"text":"section 2662 of this title","children":[],"tail":" shall be distributed” for “the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2662/e"},"text":"section 2662(e) of this title","children":[],"tail":" shall be distributed” and “objectives of those subsections” for “objectives of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2662/e"},"text":"section 2662(e) of this title","children":[],"tail":"”. See 1991 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s792/b/2/A/i"},"text":"Pub. L. 104–127, § 792(b)(2)(A)(i)","children":[],"tail":", (B), struck out “(1)” before “Such sums” and struck out par. (2) which read as follows: “The Secretary shall distribute the amounts appropriated to carry out "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2662/f"},"text":"section 2662(f) of this title","children":[],"tail":" to colleges and universities in accordance with the requirements of such subsection.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “subsections (e) and (i) of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2662"},"text":"section 2662 of this title","children":[],"tail":"” for “the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2662/e"},"text":"section 2662(e) of this title","children":[],"tail":"” and “objectives of those subsections” for “objectives of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2662/e"},"text":"section 2662(e) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s2390/b/2"},"text":"Pub. L. 101–624, § 2390(b)(2)","children":[],"tail":", which directed substitution of “"},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2662/f"},"text":"section 2662(f) of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2662/h"},"text":"section 2662(h) of this title","children":[],"tail":"” for “and "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2662/f"},"text":"section 2662(f) of this title","children":[],"tail":"”, could not be executed because of prior amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/s2389/c/2/B"},"text":"Pub. L. 101–624, § 2389(c)(2)(B)","children":[],"tail":", which struck out “and section 2662(f)” wherever appearing in par. (1). See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s2389/c/2"},"text":"Pub. L. 101–624, § 2389(c)(2)","children":[],"tail":", inserted heading, designated existing provisions as par. (1), struck out “and section 2662(f)” before “of this title” in two places, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":" inserted references to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2662/f"},"text":"section 2662(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef8b18c4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idef8b18c5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1801"},"text":"section 1801 of Pub. L. 97–98","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
