{"tag":"section","attrib":{"id":"idf02adb74-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7981"},"text":null,"children":[{"tag":"num","attrib":{"value":"7981"},"text":"§ 7981.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Milk price support program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf02adb75-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7981/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the period beginning on ","children":[{"tag":"date","attrib":{"date":"2002-06-01"},"text":"June 1, 2002","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2007-12-31"},"text":"December 31, 2007","children":[],"tail":", the Secretary of Agriculture shall support the price of milk produced in the 48 contiguous States through the purchase of cheese, butter, and nonfat dry milk produced from the milk."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adb76-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7981/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the period specified in subsection (a), the price of milk shall be supported at a rate equal to $9.90 per hundredweight for milk containing 3.67 percent butterfat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adb77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7981/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase prices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adb78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7981/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform prices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The support purchase prices under this section for each of the products of milk (butter, cheese, and nonfat dry milk) announced by the Secretary shall be the same for all of that product sold by persons offering to sell the product to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adb79-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7981/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sufficient prices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purchase prices shall be sufficient to enable plants of average efficiency to pay producers, on average, a price that is not less than the rate of price support for milk in effect under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adb7a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7981/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for butter and nonfat dry milk purchase prices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adb7b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7981/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of purchase prices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may allocate the rate of price support between the purchase prices for nonfat dry milk and butter in a manner that will result in the lowest level of expenditures by the Commodity Credit Corporation or achieve such other objectives as the Secretary considers appropriate. Not later than 10 days after making or changing an allocation, the Secretary shall notify the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate of the allocation. ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"Section 553 of title 5","children":[],"tail":" shall not apply with respect to the implementation of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adb7c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7981/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of purchase price adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make any such adjustments in the purchase prices for nonfat dry milk and butter the Secretary considers to be necessary not more than twice in each calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adb7d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7981/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodity Credit Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out the program authorized by this section through the Commodity Credit Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf02adb7e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1501"},"text":"Pub. L. 107–171, title I, § 1501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/205"},"text":"116 Stat. 205","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
