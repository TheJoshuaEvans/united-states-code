{"tag":"section","attrib":{"id":"idef7a7833-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2270"},"text":null,"children":[{"tag":"num","attrib":{"value":"2270"},"text":"§ 2270.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Office of Inspector General","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any person who is employed in the Office of the Inspector General, Department of Agriculture, who conducts investigations of alleged or suspected felony criminal violations of statutes, including but not limited to the Food and Nutrition Act of 2008 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2011"},"text":"7 U.S.C. 2011","children":[],"tail":" et seq.], administered by the Secretary of Agriculture or any agency of the Department of Agriculture and who is designated by the Inspector General of the Department of Agriculture may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7a7834-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2270/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make an arrest without a warrant for any such criminal felony violation if such violation is committed, or if such employee has probable cause to believe that such violation is being committed, in the presence of such employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7a7835-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2270/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execute a warrant for an arrest, for the search of premises, or the seizure of evidence if such warrant is issued under authority of the United States upon probable cause to believe that such violation has been committed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7a7836-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2270/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry a firearm;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in accordance with rules issued by the Secretary of Agriculture, while such employee is engaged in the performance of official duties under the authority provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s406"},"text":"section 406 of title 5","children":[],"tail":", or described in section 9 "},{"tag":"ref","attrib":{"idref":"fn002257"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002257"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Inspector General Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/pl/95/452"},"text":"Public Law 95–452","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1107"},"text":"92 Stat. 1107","children":[],"tail":"). The Attorney General of the United States may disapprove any designation made by the Inspector General under this section."}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7a7837-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXIII/s1337"},"text":"Pub. L. 97–98, title XIII, § 1337","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1294"},"text":"95 Stat. 1294","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tIV/s4002/b/1/B"},"text":"Pub. L. 110–234, title IV, § 4002(b)(1)(B)","children":[],"tail":", (2)(II), "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1096"},"text":"1