{"tag":"section","attrib":{"id":"idefcdee95-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5712"},"text":null,"children":[{"tag":"num","attrib":{"value":"5712"},"text":"§ 5712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export reporting and contract sanctity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefcdee96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export sales reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcdee97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5712/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All exporters of wheat and wheat flour, feed grains, oil seeds, cotton, pork, beef, and products thereof, and other commodities that the Secretary may designate produced in the United States shall report to the Secretary of Agriculture, on a weekly basis, the following information regarding any contract for export sales entered into or subsequently modified in any manner during the reporting period:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefcdee98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5712/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" type, class, and quantity of the commodity sought to be exported;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdee99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5712/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the marketing year of shipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdee9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5712/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" destination, if known.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdee9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5712/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality and compilation of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Individual reports shall remain confidential but shall be compiled by the Secretary and published in compilation form each week following the week of reporting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdee9c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5712/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immediate reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All exporters of agricultural commodities produced in the United States shall, upon request of the Secretary, immediately report to the Secretary any information with respect to export sales of agricultural commodities and at such times as the Secretary may request. When the Secretary requires that such information be reported by exporters on a daily basis, the information compiled from individual reports shall be made available to the public daily.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdee9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5712/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monthly reporting permitted","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may, with respect to any commodity or type or class thereof during any period in which the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefcdee9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5712/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a domestic supply of such commodity substantially in excess of the quantity needed to meet domestic requirements,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdee9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5712/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" total supplies of such commodity in the exporting countries are estimated to be in surplus,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdeea0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5712/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" anticipated exports will not result in excessive drain on domestic supplies, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdeea1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5712/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require the reports to be made will unduly hamper export sales,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"provide for such reports by exporters and publishing of such data to be on a monthly basis rather than on a weekly basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdeea2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who knowingly fails to make any report required under this section shall be fined not more than $25,000 or imprisoned for not more than 1 year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdeea3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5712/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract sanctity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the President shall not prohibit or curtail the export of any agricultural commodity under an export sales contract—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcdeea4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5712/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is entered into before the President announces an action that would otherwise prohibit or curtail the export of the commodity, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdeea5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5712/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms of which require delivery of the commodity within 270 days after the date of the suspension of trade is imposed,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that the President may prohibit or curtail the export of any agricultural commodity during a period for which the President has declared a national emergency or for which the Congress has declared war.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefcdeea6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/tVI/s602"},"text":"Pub. L. 95–501, title VI, § 602","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1531"},"text":"Pub. L. 101–624, title XV, § 1531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3688"},"text":"104 Stat. 3688","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIII/s327"},"text":"Pub. L. 102–237, title III, § 327","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1858"},"text":"105 Stat. 1858","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tIX/s921"},"text":"Pub. L. 106–78, title IX, § 921","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1206"},"text":"113 Stat. 1206","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/239/s2/c"},"text":"Pub. L. 111–239, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2502"},"text":"124 Stat. 2502","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefcdeea7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idefcdeea8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/78/s942"},"text":"section 942 of Pub. L. 106–78","children":[],"tail":", see Termination Date of 1999 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefcdeea9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idefcdeeaa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/s602"},"text":"section 602 of Pub. L. 95–501","children":[],"tail":" enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1765b–1"},"text":"section 1765b–1 of this title","children":[],"tail":" prior to the complete revision of "},{"tag":"ref","attrib":{"href":"/us/pl/95/501"},"text":"Pub. L. 95–501","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefcdeeab-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/239"},"text":"Pub. L. 111–239","children":[],"tail":" substituted “cotton, pork,” for “cotton,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/78"},"text":"Pub. L. 106–78","children":[],"tail":", §§ 921, 942, temporarily inserted “, beef,” after “cotton” in introductory provisions. See Termination Date of 1999 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s327/1"},"text":"Pub. L. 102–237, § 327(1)","children":[],"tail":", substituted “designate produced” for “designate as produced” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s327/2"},"text":"Pub. L. 102–237, § 327(2)","children":[],"tail":", struck out “in accordance with subsection (c)” after “shall remain confidential”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefcdeeac-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"terminationDate","id":"idefcdeead-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/78"},"text":"Pub. L. 106–78","children":[],"tail":" to terminate "},{"tag":"date","attrib":{"date":"2025-03-14"},"text":"Mar. 14, 2025","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/s942"},"text":"section 942 of Pub. L. 106–78","children":[],"tail":", set out in a Livestock Mandatory Reporting note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1635"},"text":"section 1635 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
