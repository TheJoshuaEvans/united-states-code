{"tag":"section","attrib":{"id":"idefa7c967-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3318a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3318a"},"text":"§ 3318a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative research projects; agreements with and receipt of funds from State and other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1963-12-30"},"text":"December 30, 1963","children":[],"tail":", the Administrator of the Agricultural Research Service may enter into agreements with and receive funds from any State, other political subdivision, organization, or individual for the purpose of conducting cooperative research projects with such cooperators."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefa7c968-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/250/tI"},"text":"Pub. L. 88–250, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-12-30"},"text":"Dec. 30, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/820"},"text":"77 Stat. 820","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa7c969-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefa7c96a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefa7c96b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s450a"},"text":"section 450a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of Agriculture and Related Agencies Appropriation Act, 1964, and not as part of the National Agricultural Research, Extension, and Teaching Policy Act of 1977 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
