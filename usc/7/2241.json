{"tag":"section","attrib":{"id":"idef780701-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2241"},"text":null,"children":[{"tag":"num","attrib":{"value":"2241"},"text":"§ 2241.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale or exchange of animals or animal products","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture is authorized to sell in the open market or to exchange for other livestock such animals or animal products as cease to be needed in the work of the department, and all moneys received from the sale of such animals or animal products or as a bonus in the exchange of the same shall be deposited in the Treasury of the United States as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef780702-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1915-03-04/ch144"},"text":"Mar. 4, 1915, ch. 144","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/1114"},"text":"38 Stat. 1114","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef780703-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef780704-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef780705-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s549"},"text":"section 549 of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
