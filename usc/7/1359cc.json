{"tag":"section","attrib":{"id":"idee89af22-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"1359cc"},"text":"§ 1359cc.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of flexible marketing allotments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee89af23-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish flexible marketing allotments for sugar for any crop year in which the allotments are required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1359bb/b"},"text":"section 1359bb(b) of this title","children":[],"tail":" in accordance with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee89af24-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overall allotment quantity","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee89af25-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish the overall quantity of sugar to be allotted for the crop year (referred to in this subpart as the “overall allotment quantity”) at a level that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee89af26-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sufficient to maintain raw and refined sugar prices above forfeiture levels to avoid forfeiture of sugar to the Commodity Credit Corporation; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee89af27-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than a quantity equal to 85 percent of the estimated quantity of sugar for domestic human consumption for the crop year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee89af28-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (1), the Secretary shall adjust the overall allotment quantity to maintain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee89af29-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" raw and refined sugar prices above forfeiture levels to avoid the forfeiture of sugar to the Commodity Credit Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee89af2a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate supplies of raw and refined sugar in the domestic market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee89af2b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marketing allotment for sugar derived from sugar beets and sugar derived from sugarcane","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The overall allotment quantity for the crop year shall be allotted between—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee89af2c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sugar derived from sugar beets by establishing a marketing allotment for a crop year at a quantity equal to the product of multiplying the overall allotment quantity for the crop year by 54.35 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee89af2d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sugar derived from sugarcane by establishing a marketing allotment for a crop year at a quantity equal to the product of multiplying the overall allotment quantity for the crop year by 45.65 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee89af2e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filling cane sugar and beet sugar allotments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee89af2f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cane sugar","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each marketing allotment for cane sugar established under this section may only be filled with sugar processed from domestically grown sugarcane.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee89af30-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beet sugar","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each marketing allotment for beet sugar established under this section may only be filled with sugar domestically processed from sugar beets or in-process beet sugar.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee89af31-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State cane sugar allotments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee89af32-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The allotment for sugar derived from sugarcane shall be further allotted, among the States in the United States in which sugarcane is produced, after a hearing (if requested by the affected sugarcane processors and growers) and on such notice as the Secretary by regulation may prescribe, in a fair and equitable manner as provided in this subsection and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1359dd/b/1/D"},"text":"section 1359dd(b)(1)(D) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee89af33-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offshore allotment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee89af34-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collectively","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to the allotment of sugar derived from sugarcane to any other State, 325,000 short tons, raw value shall be allotted to the offshore States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee89af35-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individually","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The collective offshore State allotment provided for under subparagraph (A) shall be further allotted among the offshore States in which sugarcane is produced, after a hearing (if requested by the affected sugarcane processors and growers) and on such notice as the Secretary by regulation may prescribe, in a fair and equitable manner on the basis of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee89af36-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" past marketings of sugar, based on the average of the 2 highest years of production of raw cane sugar from the 1996 through 2000 crops;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee89af37-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of processors to market the sugar covered under the allotments for the crop year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee89af38-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" past processings of sugar from sugarcane, based on the 3-year average of the 1998 through 2000 crop years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee89af39-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mainland allotment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The allotment for sugar derived from sugarcane, less the amount provided for under paragraph (2), shall be allotted among the mainland States in the United States in which sugarcane is produced, after a hearing (if requested by the affected sugarcane processors and growers) and on such notice as the Secretary by regulation may prescribe, in a fair and equitable manner on the basis of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee89af3a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" past marketings of sugar, based on the average of the 2 highest years of production of raw cane sugar from the 1996 through 2000 crops;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee89af3b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of processors to market the sugar covered under the allotments for the crop year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee89af3c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" past processings of sugar from sugarcane, based on the 3 crop years with the greatest processings (in the mainland States collectively) during the 1991 through 2000 crop years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee89af3d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filling cane sugar allotments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1359ee"},"text":"section 1359ee of this title","children":[],"tail":", a State cane sugar allotment established under subsection (e) for a crop year may be filled only with sugar processed from sugarcane grown in the State covered by the allotment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee89af3e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of marketing allotments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee89af3f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee89af40-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the Secretary shall, based on reestimates under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1359bb/a/3"},"text":"section 1359bb(a)(3) of this title","children":[],"tail":", adjust upward or downward marketing allotments in a fair and equitable manner, as the Secretary determines appropriate, to reflect changes in estimated sugar consumption, stocks, production, or imports."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee89af41-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subparagraph (A), the Secretary may not reduce the overall allotment quantity to a quantity of less than 85 percent of the estimated quantity of sugar for domestic human consumption for the crop year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee89af42-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation to processors","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee89af43-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), in the case of any increase or decrease in an allotment, each allocation to a processor of the allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1359dd"},"text":"section 1359dd of this title","children":[],"tail":", and each proportionate share established with respect to the allotment under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1359ff/c"},"text":"section 1359ff(c) of this title","children":[],"tail":", shall be increased or decreased by the same percentage that the allotment is increased or decreased."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee89af44-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary makes an upward adjustment under paragraph (1)(A), in adjusting allocations among beet sugar processors, the Secretary shall give priority to beet sugar processors with available sugar.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee89af45-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359cc/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carry-over of reductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever a marketing allotment for a crop year is required to be reduced during the crop year under this subsection, if, at the time of the reduction, the quantity of sugar marketed exceeds the processor’s reduced allocation, the allocation of an allotment next established for the processor shall be reduced by the quantity of the excess sugar marketed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee89af46-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title III, § 359c, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1403"},"text":"Pub. L. 107–171, title I, § 1403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/189"},"text":"116 Stat. 189","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1403/c"},"text":"Pub. L. 110–234, title I, § 1403(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/983"},"text":"122 Stat. 983","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1403(c), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1712; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10312/c/2"},"text":"Pub. L. 119–21, title I, § 10312(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/97"},"text":"139 Stat. 97","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee89af47-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee89af48-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee89af49-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee89af4a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1359cc, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30/tIII/s359c"},"text":"act Feb. 16, 1938, ch. 30, title III, § 359c","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tIX/s902"},"text":"Pub. L. 101–624, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3481"},"text":"104 Stat. 3481","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tI/s111/e"},"text":"Pub. L. 102–237, title I, § 111(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1832"},"text":"105 Stat. 1832","children":[],"tail":", related to establishment of marketing allotments, prior to the general amendment of this subpart by "},{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee89af4b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" designated existing provisions as subpar. (A), inserted heading, substituted “Except as provided in subparagraph (B), in the case” for “In the case”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1403/c/1"},"text":"Pub. L. 110–246, § 1403(c)(1)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which related to: in par. (1), establishment of the overall allotment quantity by deducting from the sum of the estimated sugar consumption and reasonable carryover stocks for the crop year 1,532,000 short tons, raw value, and carry-in stocks of sugar, including sugar in Commodity Credit Corporation inventory; and in par. (2), adjustment of overall allotment quantity to avoid the forfeiture of sugar to the Commodity Credit Corporation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1403/c/2"},"text":"Pub. L. 110–246, § 1403(c)(2)","children":[],"tail":", inserted “or in-process beet sugar” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1403/c/3"},"text":"Pub. L. 110–246, § 1403(c)(3)","children":[],"tail":", substituted “Adjustments” for “In general” in par. heading, designated existing provisions as subpar. (A), inserted subpar. heading, substituted “Subject to subparagraph (B), the Secretary” for “The Secretary”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1403/c/4"},"text":"Pub. L. 110–246, § 1403(c)(4)","children":[],"tail":", struck out subsec. (h). Prior to amendment, text read as follows: “Whenever the Secretary estimates or reestimates under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1359bb/a"},"text":"section 1359bb(a) of this title","children":[],"tail":", or has reason to believe, that imports of sugars, syrups or molasses for human consumption or to be used for the extraction of sugar for human consumption, whether under a tariff-rate quota or in excess or outside of a tariff-rate quota, will exceed 1,532,000 short tons (raw value equivalent) (excluding any imports attributable to reassignment under paragraph (1)(D) or (2)(C) of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1359ee/b"},"text":"section 1359ee(b) of this title","children":[],"tail":"), and that the imports would lead to a reduction of the overall allotment quantity, the Secretary shall suspend the marketing allotments established under this section until such time as the imports have been restricted, eliminated, or reduced to or below the level of 1,532,000 short tons (raw value equivalent).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee89af4c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee89af4d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
