{"tag":"section","attrib":{"id":"idefe3733a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6408"},"text":null,"children":[{"tag":"num","attrib":{"value":"6408"},"text":"§ 6408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissive terms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe3733b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6408/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each order issued under this chapter may contain one or more of the terms and conditions described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe3733c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6408/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advertising","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order may provide for the establishment, issuance, effectuation, and administration of appropriate programs or projects for the advertising of fluid milk products and the use of funds collected under this chapter for such programs or projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe3733d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6408/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order may provide for establishing and carrying out research projects and studies to support the advertising efforts for fluid milk products, and the use of funds collected under the order for such projects and studies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe3733e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6408/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order may provide authority to accumulate reserve funds from assessments collected pursuant to the order, to permit an effective and continuous coordinated program of research and advertising in years when the assessment income may be reduced, except that the total reserve fund may not exceed 25 percent of the amount budgeted for the operation in the current fiscal year of the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe3733f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6408/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order may contain such other terms and conditions incidental to and not inconsistent with the terms and conditions specified in this chapter as are necessary to effectuate the other provisions of the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe37340-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1999I"},"text":"Pub. L. 101–624, title XIX, § 1999I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3920"},"text":"104 Stat. 3920","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
