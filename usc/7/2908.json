{"tag":"section","attrib":{"id":"idef8ffb8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2908"},"text":null,"children":[{"tag":"num","attrib":{"value":"2908"},"text":"§ 2908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8ffb8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restraining order; civil penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary believes that the administration and enforcement of this chapter or an order would be adequately served by such procedure, following an opportunity for an administrative hearing on the record, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8ffb90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2908/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue an order to restrain or prevent a person from violating an order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffb91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2908/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess a civil penalty of not more than $5,000 for violation of such order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8ffb92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of district court","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The district courts of the United States are vested with jurisdiction specifically to enforce, and to prevent and restrain a person from violating, an order or regulation made or issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8ffb93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2908/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action to be referred to Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A civil action authorized to be brought under this section shall be referred to the Attorney General for appropriate action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8ffb94-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/294/s9"},"text":"Pub. L. 94–294, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-28"},"text":"May 28, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/534"},"text":"90 Stat. 534","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/334/tIII/s302"},"text":"Pub. L. 95–334, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-04"},"text":"Aug. 4, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/433"},"text":"92 Stat. 433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1601/b"},"text":"Pub. L. 99–198, title XVI, § 1601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1605"},"text":"99 Stat. 1605","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8ffb95-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef8ffb96-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef8ffb97-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":" amended section generally, substituting provisions relating to enforcement for provisions relating to referendum and cattle producer approval of orders, reimbursement of expenses by Secretary, procedural requirements, and bonding requirements."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/334"},"text":"Pub. L. 95–334","children":[],"tail":" substituted “a majority” for “not less than two-thirds”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef8ffb98-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef8ffb99-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1986-01-01"},"text":"Jan. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1601/c"},"text":"section 1601(c) of Pub. L. 99–198","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2901"},"text":"section 2901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
