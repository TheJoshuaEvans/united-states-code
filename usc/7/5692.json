{"tag":"section","attrib":{"id":"idefcdee74-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5692"},"text":null,"children":[{"tag":"num","attrib":{"value":"5692"},"text":"§ 5692.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator of Foreign Agricultural Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefcdee75-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5692/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established in the Department of Agriculture the position of Administrator of the Foreign Agricultural Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdee76-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5692/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Foreign Agricultural Service is authorized to exercise such functions and perform such duties related to foreign agriculture, and shall perform such other duties, as may be required by law or prescribed by the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdee77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5692/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the duties under this section, the Administrator shall oversee the operations of the Foreign Agricultural Service, the General Sales Manager, and the Agricultural Attaché Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefcdee78-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/tV/s502"},"text":"Pub. L. 95–501, title V, § 502","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1531"},"text":"Pub. L. 101–624, title XV, § 1531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3686"},"text":"104 Stat. 3686","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
