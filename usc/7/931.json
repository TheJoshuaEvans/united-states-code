{"tag":"section","attrib":{"id":"idee5c5d2d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s931"},"text":null,"children":[{"tag":"num","attrib":{"value":"931"},"text":"§ 931.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural Electrification and Telephone Revolving Fund","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There is hereby established in the Treasury of the United States a fund, to be known as the Rural Electrification and Telephone Revolving Fund (hereinafter referred to as the “fund”), consisting of:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee5c5d2e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s931/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all notes, bonds, obligations, liens, mortgages, and property delivered or assigned to the Secretary pursuant to loans heretofore or hereafter made under sections 904, 905,","children":[{"tag":"ref","attrib":{"idref":"fn002122"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002122"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and 922 of this title and under this subchapter, as of "},{"tag":"date","attrib":{"date":"1973-05-11"},"text":"May 11, 1973","children":[],"tail":", and all proceeds from the sales hereunder of such notes, bonds, obligations, liens, mortgages, and property, which shall be transferred to and be assets of the funds;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5c5d2f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s931/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undisbursed balances of electric and telephone loans made under sections 904, 905,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and 922 of this title, which as of "},{"tag":"date","attrib":{"date":"1973-05-11"},"text":"May 11, 1973","children":[],"tail":", shall be transferred to and be assets of the fund;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5c5d30-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s931/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all collections of principal and interest received on and after ","children":[{"tag":"date","attrib":{"date":"1972-07-01"},"text":"July 1, 1972","children":[],"tail":", on notes, bonds, judgments, or other obligations made or held under subchapters I and II of this chapter and under this subchapter, which shall be paid into and be assets of the fund;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5c5d31-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s931/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all appropriations for interest subsidies and losses required under this subchapter which may hereafter be made by the Congress and the unobligated balances of any funds made available for loans under the item “Rural Electrification Administration” in the Department of Agriculture and Agriculture-Environmental and Consumer Protection Appropriations Acts; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5c5d32-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s931/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" moneys borrowed from the Secretary of the Treasury pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s934/a"},"text":"section 934(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee5c5d33-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title III, § 301, as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/12/s2"},"text":"Pub. L. 92–12, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-05-07"},"text":"May 7, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/29"},"text":"85 Stat. 29","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/32/s2"},"text":"Pub. L. 93–32, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-05-11"},"text":"May 11, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/66"},"text":"87 Stat. 66","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/570/s2"},"text":"Pub. L. 94–570, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-20"},"text":"Oct. 20, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2701"},"text":"90 Stat. 2701","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s235/a/13"},"text":"Pub. L. 103–354, title II, § 235(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3221"},"text":"108 Stat. 3221","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s772/b/1"},"text":"Pub. L. 104–127, title VII, § 772(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1149"},"text":"110 Stat. 1149","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6602/b/7"},"text":"Pub. L. 115–334, title VI, § 6602(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4776"},"text":"132 Stat. 4776","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee5c5d34-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee5c5d35-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idee5c5d36-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s905"},"text":"Section 905 of this title","children":[],"tail":", referred to in pars. (1) and (2), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s774/a"},"text":"Pub. L. 104–127, title VII, § 774(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1150"},"text":"110 Stat. 1150","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee5c5d37-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6602/b/7/A"},"text":"Pub. L. 115–334, § 6602(b)(7)(A)","children":[],"tail":", struck out “except for net collection proceeds previously appropriated for the purchase of class A stock in the Rural Telephone Bank,” after “under this subchapter,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6602/b/7/B"},"text":"Pub. L. 115–334, § 6602(b)(7)(B)","children":[],"tail":"–(D), struck out par. (6) which read as follows: “shares of the capital stock of the Rural Telephone Bank purchased by the United States pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s946/a"},"text":"section 946(a) of this title","children":[],"tail":" and moneys received from said bank upon retirement of said shares of stock in accordance with the provisions of subchapter IV of this chapter, which said shares and moneys shall be assets of the fund.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" struck out “(a)” before “There is hereby” in introductory provisions and struck out “notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s903/a"},"text":"section 903(a) of this title","children":[],"tail":",” before “all collections” in par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/570"},"text":"Pub. L. 94–570","children":[],"tail":" provided for inclusion in the fund the unobligated balances of any funds made available for loans under item “Rural Electrification Administration” in the Department of Agriculture and Agriculture-Environmental and Consumer Protection Appropriation Acts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/32"},"text":"Pub. L. 93–32","children":[],"tail":" substituted provisions establishing the Rural Electrification and Telephone Revolving Fund and enumerating its constituent parts, for provisions establishing a rural telephone account in the United States Treasury."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee5c5d38-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee5c5d39-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/570"},"text":"Pub. L. 94–570","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1976-10-20"},"text":"Oct. 20, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/570/s4"},"text":"section 4 of Pub. L. 94–570","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s935"},"text":"section 935 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee5c5d3a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1973 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/32"},"text":"Pub. L. 93–32","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1973-05-11"},"text":"May 11, 1973","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/32/s12"},"text":"section 12 of Pub. L. 93–32","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s930"},"text":"section 930 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idee5c5d3b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/12/s7"},"text":"Pub. L. 92–12, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-05-14"},"text":"May 14, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/37"},"text":"85 Stat. 37","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/92/12/s7"},"text":"“This Act [enacting this section and sections 921a, 932, and 941 to 950b of this title, amending sections 903 and 922 of this title and sections 856 and 868 of former Title 31, and enacting provisions set out as notes under sections 856 and 868 of former Title 31] shall take effect upon enactment [","children":[{"tag":"date","attrib":{"date":"1971-05-07"},"text":"May 7, 1971","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idee5c5d3c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reservation of Right To Repeal, Alter, or Amend ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/12"},"text":"Pub. L. 92–12","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/12/s6"},"text":"Pub. L. 92–12, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-05-14"},"text":"May 14, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/37"},"text":"85 Stat. 37","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/92/12/s6"},"text":"“The right to repeal, alter, or amend this Act [enacting this section and sections 921a, 932, and 941 to 950b of this title, amending sections 903 and 922 of this title and sections 856 and 868 of former Title 31, and enacting provisions set out as notes under sections 856 and 868 of former Title 31] is expressly reserved.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
