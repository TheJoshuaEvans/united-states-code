{"tag":"section","attrib":{"id":"idefcdeedb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811"},"text":null,"children":[{"tag":"num","attrib":{"value":"5811"},"text":"§ 5811.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and extension projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefcdeedc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct research and extension projects to obtain data, develop conclusions, demonstrate technologies, and conduct educational programs that promote the purposes of this part, including research and extension projects that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcdeedd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" facilitate and increase scientific investigation and education in order to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefcdeede-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce, to the extent feasible and practicable, the use of chemical pesticides, fertilizers, and toxic natural materials in agricultural production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdeedf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve low-input farm management to enhance agricultural productivity, profitability, and competitiveness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdeee0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote crop, livestock, and enterprise diversification; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdeee1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" facilitate the conduct of projects in order to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefcdeee2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" study, to the extent practicable, agricultural production systems that are located in areas that possess various soil, climate, and physical characteristics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdeee3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" study farms that have been, and will continue to be, managed using farm production practices that rely on low-input and conservation practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdeee4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take advantage of the experience and expertise of farmers and ranchers through their direct participation and leadership in projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdeee5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer practical, reliable and timely information to farmers and ranchers concerning low-input sustainable farming practices and systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdeee6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote a partnership between farmers, nonprofit organizations, agribusiness, and public and private research and extension institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdeee7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out this section through agreements entered into with land-grant colleges or universities, other universities, State agricultural experiment stations, the State cooperative extension services, nonprofit organizations with demonstrable expertise, or Federal or State governmental entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdeee8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcdeee9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall select research and extension projects to be conducted under this section on the basis of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefcdeeea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relevance of the project to the purposes of this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdeeeb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriateness of the design of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdeeec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the likelihood of obtaining the objectives of the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdeeed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national or regional applicability of the findings and outcomes of the proposed project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdeeee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting projects under this section, the Secretary shall give priority to projects that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefcdeeef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" closely coordinate research and extension activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdeef0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicate the manner in which the findings of the project will be made readily usable by farmers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdeef1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximize the involvement and cooperation of farmers, including projects involving on-farm research and demonstration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdeef2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve a multidisciplinary systems approach; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdeef3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve cooperation between farms, non-profit organizations, colleges and universities, and government agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdeef4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diversification of research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct projects and studies under this section in areas that are broadly representative of the diversity of United States agricultural production, including production on family farms, mixed-crop livestock farms and dairy operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdeef5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On-farm research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may conduct projects and activities that involve on-farm research and demonstration in carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdeef6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Impact studies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may approve study projects concerning the national and regional economic, global competitiveness, social and environmental implications of the adoption of low-input sustainable agricultural practices and systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdeef7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project duration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcdeef8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may approve projects to be conducted under this section that have a duration of more than one fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdeef9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sequence planting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a research project conducted under this section that involves the planting of a sequence of crops or crop rotations, the Secretary shall approve such projects for a term that is appropriate to the sequence or rotation being studied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdeefa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that research projects conducted under this section are open for public observation at specified times.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdeefb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indemnification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcdeefc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary may indemnify the operator of a project conducted under this section for damage incurred or undue losses sustained as a result of a rigid requirement of research or demonstration under such project that is not experienced in normal farming operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdeefd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5811/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subject to agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An indemnity payment under paragraph (1) shall be subject to any agreement between a project grantee and operator entered into prior to the initiation of such project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefcdeefe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1621"},"text":"Pub. L. 101–624, title XVI, § 1621","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3734"},"text":"104 Stat. 3734","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s860/c/2"},"text":"Pub. L. 104–127, title VIII, § 860(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1173"},"text":"110 Stat. 1173","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefcdeeff-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefcdef00-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefcdef01-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s860/c/2/A"},"text":"Pub. L. 104–127, § 860(c)(2)(A)","children":[],"tail":", redesignated subpars. (B) to (E) as (A) to (D), respectively, and struck out former subpar. (A) which read as follows: “the recommendations of the Advisory Council;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s860/c/2/B"},"text":"Pub. L. 104–127, § 860(c)(2)(B)","children":[],"tail":", redesignated subpars. (B) to (F) as (A) to (E), respectively, and struck out former subpar. (A) which read as follows: “are recommended by the Advisory Council;”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
