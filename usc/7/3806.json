{"tag":"section","attrib":{"id":"idefb13eb8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3806"},"text":null,"children":[{"tag":"num","attrib":{"value":"3806"},"text":"§ 3806.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefb13eb9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3806/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever willfully violates any provision of this chapter or the regulations of the Secretary issued hereunder shall be guilty of a misdemeanor and shall be fined not more than $10,000, or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb13eba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3806/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any person who fails to obey any order of the Secretary issued under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3804"},"text":"section 3804 of this title","children":[],"tail":", or such order as modified—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefb13ebb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3806/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the expiration of the time allowed for filing a petition in the court of appeals to review such order, if no such petition has been filed within such time; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb13ebc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3806/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the expiration of the time allowed for applying for a writ of certiorari, if such order, or such order as modified, has been sustained by the court of appeals and no such writ has been applied for within such time; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb13ebd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3806/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after such order, or such order as modified, has been sustained by the courts as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3804/b"},"text":"section 3804(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall on conviction be fined not more than $10,000, or imprisoned for not more than one year, or both. Each day during which such failure continues shall be deemed a separate offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefb13ebe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/468/s7"},"text":"Pub. L. 96–468, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2231"},"text":"94 Stat. 2231","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
