{"tag":"section","attrib":{"id":"idee65d33f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"950cc"},"text":"§ 950cc.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notice, assessments, and reporting requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee65d340-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall promptly make available to the public,","children":[{"tag":"ref","attrib":{"idref":"fn002129"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002129"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" a fully searchable database on the website of the Rural Utilities Service that contains information on all retail broadband projects provided assistance or for which assistance is sought that are administered by the Secretary, including, at a minimum—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idee65d341-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" notice of each application for assistance describing the application, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee65d342-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of the applicant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d343-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of each application, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee65d344-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a map of the proposed service area of the applicant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee65d345-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and type of support requested by each applicant;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d346-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of each application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d347-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated number and proportion of service points in the proposed service territory without fixed broadband service, whether terrestrial or wireless;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d348-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" notice of each entity receiving assistance administered by the Secretary, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee65d349-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d34a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of assistance being received;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d34b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purpose for which the entity is receiving the assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d34c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each annual report submitted under subsection (c) (redacted to protect any proprietary information in the report); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d34d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as is sufficient to allow the public to understand assistance provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d34e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service area assessment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee65d34f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, with respect to a retail broadband application for assistance, which is outside an area in which the applicant receives Federal universal service support—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee65d350-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after giving notice required by subsection (a)(1), afford service providers not less than 45 days to voluntarily submit information required by the Secretary onto the agency’s online mapping tool with respect to areas that are coterminous with the proposed service area of the application (or any parts thereof), such that the Secretary may assess whether the application submitted meets the eligibility requirements under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d351-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if no broadband service provider submits information under paragraph (1), consider the number of providers in the proposed service area to be established by using any other data regarding the availability of broadband service that the Secretary may collect or obtain through reasonable efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d352-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of unserved communities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an application given the highest priority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s950bb/c/2/A/i"},"text":"section 950bb(c)(2)(A)(i) of this title","children":[],"tail":", the Secretary shall confirm that each unserved rural community identified in the application is eligible for funding by—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee65d353-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conferring with, and obtaining data from, the Chair of the Federal Communications Commission and the Administrator of the National Telecommunications and Information Administration with respect to the service level in the service area proposed in the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d354-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing any other source that is relevant to service data validation, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d355-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing site-specific testing to verify the unavailability of any retail broadband service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d356-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FOIA exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":", information received by the Secretary pursuant to paragraph (1)(A) of this subsection shall be exempt from disclosure pursuant to subsection (b)(2)(B) of such section 552."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d357-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting broadband improvements to USDA","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee65d358-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require any entity receiving assistance for a project which provides retail broadband service to submit an annual report for 3 years after completion of the project, in a format specified by the Secretary, that describes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee65d359-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use by the entity of the assistance, including new equipment and capacity enhancements that support high-speed broadband access for educational institutions, health care providers, and public safety service providers (including the estimated number of end users who are currently using or forecasted to use the new or upgraded infrastructure); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d35a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the progress towards fulfilling the objectives for which the assistance was granted, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee65d35b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of service points that will receive new broadband service, existing network service improvements, and facility upgrades resulting from the Federal assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee65d35c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the speed of broadband service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee65d35d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average price of the most subscribed tier of broadband service in a proposed service area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee65d35e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new subscribers generated from the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee65d35f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/c/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any metrics the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d360-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional reporting","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee65d361-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broadband buildout data","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As a condition of receiving assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s950bb"},"text":"section 950bb of this title","children":[],"tail":", a recipient of assistance shall provide to the Secretary complete, reliable, and precise geolocation information that indicates the location of new broadband service that is being provided or upgraded within the service territory supported by the grant, loan, or loan guarantee not later than 30 days after the earlier of—"}],"tail":null},{"tag":"clause","attrib":{"id":"idee65d362-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of completion of any project milestone established by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee65d363-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of completion of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d364-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting for middle mile projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require any entity receiving assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s950bb–1"},"text":"section 950bb–1 of this title","children":[],"tail":" to submit a semiannual report for 5 years after completion of the project, in a format specified by the Secretary, that describes—"}],"tail":null},{"tag":"clause","attrib":{"id":"idee65d365-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use by the entity of the assistance to construct, improve, or acquire middle mile infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee65d366-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress towards meeting the end-user connection plan submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s950bb–1/d/1/A/iii"},"text":"section 950bb–1(d)(1)(A)(iii) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee65d367-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional metrics the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d368-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may require any additional reporting and information by any recipient of any broadband assistance under this chapter so as to ensure compliance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d369-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on broadband projects and service to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each year, the Secretary shall submit to the Congress a report that describes the extent of participation in the broadband assistance programs administered by the Secretary for the preceding fiscal year, including a description of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee65d36a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of applications received and accepted, including any special loan terms or conditions for which the Secretary provided additional assistance to unserved areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d36b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee65d36c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the communities proposed to be served in each application submitted for the fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d36d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the communities served by projects funded by broadband assistance programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d36e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of time required to approve each loan application under broadband programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d36f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any outreach activities carried out by the Secretary to encourage entities in rural areas without broadband service to submit applications under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d370-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the method by which the Secretary determines that a service enables a subscriber to originate and receive high-quality voice, data, graphics, and video for purposes of providing broadband service under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d371-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each broadband service, including the type and speed of broadband service, for which assistance was sought, and each broadband service for which assistance was provided, under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d372-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the overall progress towards fulfilling the goal of improving the quality of rural life by expanding rural broadband access, as demonstrated by metrics, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee65d373-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/d/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of residences and businesses receiving new broadband services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d374-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/d/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" network improvements, including facility upgrades and equipment purchases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d375-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/d/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" average broadband speeds and prices on a local and statewide basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d376-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/d/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any changes in broadband adoption rates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d377-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/d/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any specific activities that increased high speed broadband access for educational institutions, health care providers, and public safety service providers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d378-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on reservation of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less than 3 but not more than 5 percent of program level amounts available pursuant to amounts appropriated to carry out subchapter VI shall be set aside to be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee65d379-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting oversight under such subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d37a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing accountability measures and related activities authorized under such subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d37b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950cc/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee65d37c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title VII, § 701, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6207"},"text":"Pub. L. 115–334, title VI, § 6207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4740"},"text":"132 Stat. 4740","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
