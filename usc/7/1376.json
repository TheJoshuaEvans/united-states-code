{"tag":"section","attrib":{"id":"idee8e69c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1376"},"text":null,"children":[{"tag":"num","attrib":{"value":"1376"},"text":"§ 1376.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court jurisdiction; duties of United States attorneys; remedies and penalties as additional","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The several district courts of the United States are vested with jurisdiction specifically to enforce the provisions of this subchapter. If and when the Secretary shall so request, it shall be the duty of the several United States attorneys in their respective districts, under the direction of the Attorney General, to institute proceedings to collect the penalties provided in this subchapter. The remedies and penalties provided for herein shall be in addition to, and not exclusive of, any of the remedies or penalties under existing law. This section also shall be applicable to liquidated damages provided for pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1349"},"text":"section 1349 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee8e69c9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title III, § 376, "},{"tag":"ref","attrib":{"href":"/us/stat/52/66"},"text":"52 Stat. 66","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s1"},"text":"June 25, 1948, ch. 646, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/869"},"text":"62 Stat. 869","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/297/tI/s106/2"},"text":"Pub. L. 88–297, title I, § 106(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-04-11"},"text":"Apr. 11, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/176"},"text":"78 Stat. 176","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee8e69ca-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee8e69cb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee8e69cc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1964—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/297"},"text":"Pub. L. 88–297","children":[],"tail":" provided for application of this section to liquidated damages under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1349"},"text":"section 1349 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee8e69cd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idee8e69ce-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":", substituted “United States attorneys” for “district attorneys”. See "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s541"},"text":"section 541 of Title 28",