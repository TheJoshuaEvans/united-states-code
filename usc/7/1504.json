{"tag":"section","attrib":{"id":"ideeb700b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1504"},"text":null,"children":[{"tag":"num","attrib":{"value":"1504"},"text":"§ 1504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital stock of Corporation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideeb700b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subscription by United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall have a capital stock of $500,000,000 subscribed by the United States of America, payment for which shall, with the approval of the Secretary, be subject to call in whole or in part by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeb700b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated such sums as are necessary for the purpose of subscribing to the capital stock of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeb700b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of stock to Secretary of the Treasury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Receipts for payments by the United States of America for or on account of such stock shall be issued by the Corporation to the Secretary of the Treasury and shall be evidence of the stock ownership by the United States of America.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeb700b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1504/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cancellation of receipts; nonliability of Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within thirty days after ","children":[{"tag":"date","attrib":{"date":"1980-09-26"},"text":"September 26, 1980","children":[],"tail":", the Secretary of the Treasury shall cancel, without consideration, receipts for payments for or on account of the stock of the Corporation outstanding on "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"September 26, 1980","children":[],"tail":", and such receipts shall cease to be liabilities of the Corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideeb700b9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title V, § 504, "},{"tag":"ref","attrib":{"href":"/us/stat/52/72"},"text":"52 Stat. 72","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-08-25/ch512"},"text":"Aug. 25, 1949, ch. 512","children":[],"tail":", §§ 4, 6, "},{"tag":"ref","attrib":{"href":"/us/stat/63/665"},"text":"63 Stat. 665","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/47"},"text":"Pub. L. 95–47","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-06-16"},"text":"June 16, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/228"},"text":"91 Stat. 228","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/181/s1"},"text":"Pub. L. 95–181, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-15"},"text":"Nov. 15, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1373"},"text":"91 Stat. 1373","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/365/tI/s101"},"text":"Pub. L. 96–365, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1312"},"text":"94 Stat. 1312","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tI/s102/b/2"},"text":"Pub. L. 103–354, title I, § 102(b)(2)","children":[],"tail":", (4)(C), "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3180"},"text":"108 Stat. 3180","children":[],"tail":", 3181.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideeb700ba-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideeb700bb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideeb700bc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/s102/b/2/A"},"text":"Pub. L. 103–354, § 102(b)(2)(A)","children":[],"tail":", (4)(C), struck out “of Agriculture” after “Secretary” and “of Directors of the Corporation” after “Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/s102/b/2/B"},"text":"Pub. L. 103–354, § 102(b)(2)(B)","children":[],"tail":", struck out “Federal Crop Insurance” before “Corporation outstanding”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/365/s101/a"},"text":"Pub. L. 96–365, § 101(a)","children":[],"tail":", substituted “$500,000,000” for “$200,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/365/s101/b"},"text":"Pub. L. 96–365, § 101(b)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/181"},"text":"Pub. L. 95–181","children":[],"tail":" substituted “$200,000,000” for “$150,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/47"},"text":"Pub. L. 95–47","children":[],"tail":" substituted “$150,000,000” for “$100,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1949—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1949-08-25"},"text":"Aug. 25, 1949","children":[],"tail":", § 4, struck out second sentence relating to restoration of impairment of capital stock."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). Act ","children":[{"tag":"date","attrib":{"date":"1949-08-25"},"text":"Aug. 25, 1949","children":[],"tail":", § 6, authorized appropriations for subscribing to corporation’s capital stock in order to offset losses suffered prior to time program was placed on an experimental basis in 1947."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideeb700bd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideeb700be-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", and applicable to provision of crop insurance under Federal Crop Insurance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"7 U.S.C. 1501","children":[],"tail":" et seq.) beginning with 1995 crop year, with such Act, as in effect on the day before "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", to continue to apply with respect to 1994 crop year, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/s120"},"text":"section 120 of Pub. L. 103–354","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1502"},"text":"section 1502 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideeb700bf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/365/tI/s112"},"text":"Pub. L. 96–365, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1319"},"text":"94 Stat. 1319","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/365/tI/s112"},"text":"“Except as otherwise provided in this Act, the provisions of this Act amending the Federal Crop Insurance Act [amending sections 1504, 1505 to 1507, 1508, and 1518 of this title and repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1515"},"text":"section 1515 of this title","children":[],"tail":"] shall become effective on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/365/tI/s101/a"},"text":"Pub. L. 96–365, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1312"},"text":"94 Stat. 1312","children":[],"tail":", provided that the amendment made by section 101(a) is effective "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideeb700c0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Cancellation of Outstanding Receipts for Stock in Excess of $27,000,000","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-25/ch512/s5"},"text":"Act Aug. 25, 1949, ch. 512, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/665"},"text":"63 Stat. 665","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1949-08-25/ch512/s5"},"text":"“The Secretary of the Treasury is authorized and directed to cancel, without consideration, outstanding receipts for payments for or on account of the stock of the Corporation in excess of $27,000,000.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideeb700c1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Institution of Expanded Program; Payment of Cost for Fiscal Year 1950","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-25/ch512/s11"},"text":"Act Aug. 25, 1949, ch. 512, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/666"},"text":"63 Stat. 666","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1949-08-25/ch512/s11"},"text":"“The expanded program authorized herein [sections 1504, 1505, 1506, 1507, and 1508 of this title] shall be instituted beginning with the 1950 crop year, the additional cost for fiscal year 1950 to be financed, pending the appropriation of supplemental funds, from any appropriation available for operating and administrative expenses of the Corporation for such fiscal year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ideeb700c2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"ideeb700c3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Administration of program of Federal Crop Insurance Corporation transferred to Secretary of Agriculture by 1946 Reorg. Plan No. 3, § 501, eff. ","children":[{"tag":"date","attrib":{"date":"1946-07-16"},"text":"July 16, 1946","children":[],"tail":", 11 F.R. 7877, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1100"},"text":"60 Stat. 1100","children":[],"tail":". See note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1503"},"text":"section 1503 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Wartime consolidation of Federal Crop Insurance Corporation into Agricultural Conservation and Adjustment Administration, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1503"},"text":"section 1503 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
