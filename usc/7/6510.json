{"tag":"section","attrib":{"id":"idefe5bc59-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6510"},"text":null,"children":[{"tag":"num","attrib":{"value":"6510"},"text":"§ 6510.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Handling","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe5bc5a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6510/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For a handling operation to be certified under this chapter, each person on such handling operation shall not, with respect to any agricultural product covered by this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bc5b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6510/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" add any synthetic ingredient not appearing on the National List during the processing or any postharvest handling of the product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc5c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6510/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" add any ingredient known to contain levels of nitrates, heavy metals, or toxic residues in excess of those permitted by the applicable organic certification program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc5d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6510/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" add any sulfites, except in the production of wine, nitrates, or nitrites;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc5e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6510/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" add any ingredients that are not organically produced in accordance with this chapter and the applicable organic certification program, unless such ingredients are included on the National List and represent not more than 5 percent of the weight of the total finished product (excluding salt and water);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc5f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6510/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use any packaging materials, storage containers or bins that contain synthetic fungicides, preservatives, or fumigants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc60-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6510/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use any bag or container that had previously been in contact with any substance in such a manner as to compromise the organic quality of such product; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc61-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6510/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use, in such product water that does not meet all Safe Drinking Water Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300f"},"text":"42 U.S.C. 300f","children":[],"tail":" et seq.] requirements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc62-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6510/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meat","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For a farm or handling operation to be organically certified under this chapter, producers on such farm or persons on such handling operation shall ensure that organically produced meat does not come in contact with nonorganically produced meat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe5bc63-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXI/s2111"},"text":"Pub. L. 101–624, title XXI, § 2111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3941"},"text":"104 Stat. 3941","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tX/s1001/3"},"text":"Pub. L. 102–237, title X, § 1001(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1893"},"text":"105 Stat. 1893","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/387/s1/a/tVII/s748"},"text":"Pub. L. 106–387, § 1(a) [title VII, § 748]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1549"},"text":"114 Stat. 1549","children":[],"tail":", 1549A–41; "},{"tag":"ref","attrib":{"href":"/us/pl/109/97/tVII/s797/a"},"text":"Pub. L. 109–97, title VII, § 797(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-10"},"text":"Nov. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2165"},"text":"119 Stat. 2165","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefe5bc64-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefe5bc65-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefe5bc66-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Safe Drinking Water Act, referred to in subsec. (a)(7), is title XIV of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1974-12-16"},"text":"Dec. 16, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/523/s2/a"},"text":"Pub. L. 93–523, § 2(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1660"},"text":"88 Stat. 1660","children":[],"tail":", which is classified generally to subchapter XII (§ 300f et seq.) of chapter 6A of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefe5bc67-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/97"},"text":"Pub. L. 109–97","children":[],"tail":" inserted “not appearing on the National List” after “ingredient”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387"},"text":"Pub. L. 106–387","children":[],"tail":" inserted “except in the production of wine,” after “sulfites,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “postharvest” for “post harvest”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
