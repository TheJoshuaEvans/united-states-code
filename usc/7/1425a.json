b":{"href":"/us/stat/109/331"},"text":"109 Stat. 331","children":[],"tail":", provided that none of the funds appropriated or otherwise made available by "},{"tag":"ref","attrib":{"href":"/us/pl/104/37"},"text":"Pub. L. 104–37","children":[],"tail":" were to be used by the Secretary of Agriculture to provide total amount of payments and/or total amount of loan forfeitures to a person to support the price of honey under this section or former "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1446h"},"text":"section 1446h of this title","children":[],"tail":" in excess of zero dollars in the 1994, 1995, and 1996 crop years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/330/tVII/s723"},"text":"Pub. L. 103–330, title VII, § 723","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-30"},"text":"Sept. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2469"},"text":"108 Stat. 2469","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/111/tVII/s728"},"text":"Pub. L. 103–111, title VII, § 728","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-10-21"},"text":"Oct. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1081"},"text":"107 Stat. 1081","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
