{"tag":"section","attrib":{"id":"ideedab549-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635"},"text":null,"children":[{"tag":"num","attrib":{"value":"1635"},"text":"§ 1635.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this subchapter is to establish a program of information regarding the marketing of cattle, swine, lambs, and products of such livestock that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedab54a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides information that can be readily understood by producers, packers, and other market participants, including information with respect to the pricing, contracting for purchase, and supply and demand conditions for livestock, livestock production, and livestock products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab54b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improves the price and supply reporting services of the Department of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab54c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourages competition in the marketplace for livestock and livestock products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideedab54d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 211, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tIX/s911/2"},"text":"Pub. L. 106–78, title IX, § 911(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1188"},"text":"113 Stat. 1188","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideedab54e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideedab54f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideedab550-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Livestock Mandatory Reporting","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/78/tIX"},"text":"Pub. L. 106–78, title IX","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1188"},"text":"113 Stat. 1188","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/444/s1"},"text":"Pub. L. 108–444, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2635"},"text":"118 Stat. 2635","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/296/s1/b"},"text":"Pub. L. 109–296, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-05"},"text":"Oct. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1464"},"text":"120 Stat. 1464","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/239/s2/a/2"},"text":"Pub. L. 111–239, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2501"},"text":"124 Stat. 2501","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/54/tI/s101/b"},"text":"Pub. L. 114–54, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-09-30"},"text":"Sept. 30, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/513"},"text":"129 Stat. 513","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dO/tIII/s301/b"},"text":"Pub. L. 117–103, div. O, title III, § 301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/788"},"text":"136 Stat. 788","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dA/tVII/s776/b"},"text":"Pub. L. 117–328, div. A, title VII, § 776(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4510"},"text":"136 Stat. 4510","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/42/dB/tVII/s793/b"},"text":"Pub. L. 118–42, div. B, title VII, § 793(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-09"},"text":"Mar. 9, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/120"},"text":"138 Stat. 120","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/4/dA/tII/s1203/b"},"text":"Pub. L. 119–4, div. A, title II, § 1203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-03-15"},"text":"Mar. 15, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/16"},"text":"139 Stat. 16","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/37/dB/tVII/s774/b"},"text":"Pub. L. 119–37, div. B, title VII, § 774(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-11-12"},"text":"Nov. 12, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/557"},"text":"139 Stat. 557","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/37/dB/tVII/s774/b"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"901"},"text":"“SEC. 901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This title [enacting sections 198 to 198b and 1635 to 1636h of this title and this note, amending sections 192 and 5712 of this title, repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s229a"},"text":"section 229a of this title","children":[],"tail":", and amending provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of this title","children":[],"tail":"] may be cited as the ‘Livestock Mandatory Reporting Act of 1999’."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subtitle","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“Subtitle A—","children":[],"tail":null},{"tag":"heading","attrib":{},"text":"Livestock Mandatory Reporting","children":[],"tail":null},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"911"},"text":"“SEC. 911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" LIVESTOCK MANDATORY REPORTING.","children":[],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideedab551-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"“[Enacted this subchapter.]","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"912"},"text":"“SEC. 912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" UNJUST DISQUALIFICATION.","children":[],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideedab552-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"“[Amended ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s192"},"text":"section 192 of this title","children":[],"tail":".]"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"913"},"text":"“SEC. 913.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CONFORMING AMENDMENTS.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" [Repealed ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s229a"},"text":"section 229a of this title","children":[],"tail":".]"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideedab553-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"p","attrib":{},"text":" [Amended section 101(a) [title XI, § 1127] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", former "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"7 U.S.C. 1421","children":[],"tail":" note.]"}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null},{"tag":"subtitle","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“Subtitle B—","children":[],"tail":null},{"tag":"heading","attrib":{},"text":"Related Beef Reporting Provisions","children":[],"tail":null},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"921"},"text":"“SEC. 921.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" BEEF EXPORT REPORTING.","children":[],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideedab554-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"“[Amended ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5712"},"text":"section 5712 of this title","children":[],"tail":".]"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"922"},"text":"“SEC. 922.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" EXPORT CERTIFICATES FOR MEAT AND MEAT FOOD PRODUCTS.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“Not later than 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":"], the Secretary of Agriculture shall fully implement a program, through the use of a streamlined electronic online system, to issue and report export certificates for all meat and meat products."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"923"},"text":"“SEC. 923.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" IMPORTS OF BEEF, BEEF VARIETY MEATS, AND CATTLE.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain information regarding the import of beef and beef variety meats (consistent with the information categories reported for beef exports under section 602(a) of the Agricultural Trade Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5712/a"},"text":"7 U.S.C. 5712(a)","children":[],"tail":")) and cattle using available information sources; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish the information in a timely manner weekly and in a form that maximizes the utility of the information to beef producers, packers, and other market participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The published information shall include information reporting the year-to-date cumulative annual imports of beef, beef variety meats, and cattle for the current and prior marketing years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"924"},"text":"“SEC. 924.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" AUTHORIZATION OF APPROPRIATIONS.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“There are authorized to be appropriated such sums as are necessary to carry out sections 922 and 923.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null},{"tag":"subtitle","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“Subtitle C—","children":[],"tail":null},{"tag":"heading","attrib":{},"text":"Related Swine Reporting Provisions","children":[],"tail":null},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"931"},"text":"“SEC. 931.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" IMPROVEMENT OF HOGS AND PIGS INVENTORY REPORT.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Effective beginning not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":"], the Secretary of Agriculture shall publish on a monthly basis the Hogs and Pigs Inventory Report."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Gestating Sows","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall include in a separate category of the Report the number of bred female swine that are assumed, or have been confirmed, to be pregnant during the reporting period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Phase-Out","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Effective for a period of eight quarters after the implementation of the monthly report required under subsection (a), the Secretary shall continue to maintain and publish on a quarterly basis the Hogs and Pigs Inventory Report published on or before the date of the enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"932"},"text":"“SEC. 932.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" BARROW AND GILT SLAUGHTER.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Agriculture shall promptly obtain and maintain, through an appropriate collection system or valid sampling system at packing plants, information on the total slaughter of swine that reflects differences in numbers between barrows and gilts, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The information shall be made available to swine producers, packers, and other market participants in a report published by the Secretary not less frequently than weekly.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall administer the collection and compilation of information, and the publication of the report, required by this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nondelegation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall not delegate the collection, compilation, or administration of the information required by this section to any packer (as defined in section 201 of the Packers and Stockyards Act, 1921 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s191"},"text":"7 U.S.C. 191","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"933"},"text":"“SEC. 933.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" AVERAGE TRIM LOSS CORRELATION STUDY AND REPORT.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Agriculture shall contract with a qualified contractor to conduct a correlation study and prepare a report establishing a baseline and standards for determining and improving average trim loss measurements and processing techniques for pork processors to employ in the slaughter of swine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Correlation Study and Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study and report shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze processing techniques that would assist the pork processing industry in improving procedures for uniformity and transparency in how trim loss is discounted (in dollars per hundred pounds carcass weight) by different packers and processors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze slaughter inspection procedures that could be improved so that trimming procedures and policies of the Secretary are uniform to the maximum extent determined practicable by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine how the Secretary may be able to foster improved breeding techniques and animal handling and transportation procedures through training programs made available to swine producers so as to minimize trim loss in slaughter processing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations that are designed to effect changes in the pork industry so as to achieve continuous improvement in average trim losses and discounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsequent Reports on Status of Improvements and Updates in Baseline","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less frequently than once every 2 years after the initial publication of the report required under this section, the Secretary shall make subsequent periodic reports that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine the status of the improvement in reducing trim loss discounts in the pork processing industry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" update the baseline to reflect changes in trim loss discounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of Reports to Congress, Producers, Packers, and Others","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The reports required under this section shall be made available to—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public on the Internet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture, Nutrition, and Forestry of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" producers and packers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other market participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"934"},"text":"“SEC. 934.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SWINE PACKER MARKETING CONTRACTS.","children":[],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideedd2555-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"“[Enacted sections 198 to 198b of this title.]","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"935"},"text":"“SEC. 935.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" AUTHORIZATION OF APPROPRIATIONS.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“There are authorized to be appropriated such sums as are necessary to carry out this subtitle and the amendments made by this subtitle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null},{"tag":"subtitle","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“Subtitle D—","children":[],"tail":null},{"tag":"heading","attrib":{},"text":"Implementation","children":[],"tail":null},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"941"},"text":"“SEC. 941.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" REGULATIONS.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":"], the Secretary of Agriculture shall publish final regulations to implement this title and the amendments made by this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication of Proposed Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of the enactment of this Act, the Secretary shall publish proposed regulations to implement this title and the amendments made by this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comment Period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall provide an opportunity for comment on the proposed regulations during the 30-day period beginning on the date of the publication of the proposed regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Final Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after the conclusion of the comment period, the Secretary shall publish the final regulations and implement this title and the amendments made by this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"942"},"text":"“SEC. 942.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" TERMINATION OF AUTHORITY.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The authority provided by this title [enacting sections 198 to 198b and 1635 to 1636h of this title and this note, amending sections 192 and 5712 of this title, repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s229a"},"text":"section 229a of this title","children":[],"tail":", and amending provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of this title","children":[],"tail":"] and the amendments made by this title (other than section 911 of subtitle A [enacting this subchapter] and the amendments made by that section) terminate [sic] on "},{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
