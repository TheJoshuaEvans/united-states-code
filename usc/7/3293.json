{"tag":"section","attrib":{"id":"idefa558ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293"},"text":null,"children":[{"tag":"num","attrib":{"value":"3293"},"text":"§ 3293.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural fellowship program for middle income countries, emerging democracies, and emerging markets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa558ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture shall establish a fellowship program for,","children":[{"tag":"ref","attrib":{"idref":"fn002277"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002277"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “for” probably should not appear."}],"tail":" to be known as the “Cochran Fellowship Program”, to provide fellowships to individuals from eligible countries (as determined under subsection (b)) who specialize in agriculture for study—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa558ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa558af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at a college or university located in an eligible country that the Secretary determines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa558b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has sufficient scientific and technical facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa558b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has established a partnership with at least one college or university in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa558b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has substantial participation by faculty members of the United States college or university in the design of the fellowship curriculum and classroom instruction under the fellowship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa558b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible countries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Countries described in any of the following paragraphs shall be eligible to participate in the program established under this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa558b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Middle-income country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A country that has developed economically to the point where it no longer qualifies for bilateral foreign aid assistance from the United States because its per capita income level exceeds the eligibility requirements of such assistance programs (hereafter referred to in this section as a “middle-income” country).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa558b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ongoing relationship","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A middle-income country that has never qualified for bilateral foreign aid assistance from the United States, but with respect to which an ongoing relationship with the United States, including technical assistance and training, would provide mutual benefits to such country and the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa558b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Type of government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A country that has recently begun the transformation of its system of government from a non-representative type of government to a representative democracy and that is encouraging democratic institution building, and the cultural values, institutions, and organizations of democratic pluralism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa558b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent states of the former Soviet Union","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A country that is an independent state of the former Soviet Union (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5602/8"},"text":"section 5602(8) of this title","children":[],"tail":"), to the extent that the Secretary of Agriculture determines that such country should be eligible to participate in the program established under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa558b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emerging market","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any emerging market, as defined in section 1542(e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa558b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of fellowships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Fellowships under this section shall be provided to permit the recipients to gain knowledge and skills that will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa558ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist eligible countries to develop agricultural systems (which may include agricultural extension services) necessary to meet the food and fiber needs of their domestic populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa558bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" strengthen and enhance—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa558bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trade linkages between eligible countries and agricultural interests in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa558bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" linkages between agricultural interests in the United States and regulatory systems governing sanitary and phytosanitary standards for agricultural products that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefa558be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enter the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefa558bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may pose risks to human, animal, or plant life or health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa558c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individuals who may receive fellowships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall utilize the expertise of United States agricultural counselors, trade officers, and commodity trade promotion groups working in participating countries to help identify program candidates for fellowships under this section from both the public and private sectors of those countries. The Secretary may provide fellowships under the program authorized by this section to private agricultural producers from eligible countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa558c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with other United States Government agencies, United States universities, and the private agribusiness sector, as appropriate, to design and administer training programs to accomplish the objectives of the program established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa558c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated without fiscal year limitation such sums as may be necessary to carry out the program established under this section, except that the amount of such funds in any fiscal year shall not exceed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa558c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for eligible countries that meet the requirements of subsection (b)(1), $4,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa558c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for eligible countries that meet the requirements of subsection (b)(2), $3,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa558c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for eligible countries that meet the requirements of subsection (b)(3), $6,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa558c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3293/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complementary funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary of Agriculture determines that it is advisable in furtherance of the purposes of the program established under this section, the Secretary may accept money, funds, property, and services of every kind by gift, devise, bequest, grant, or otherwise, and may, in any manner, dispose of all such holdings and use the receipts generated from such disposition as general program funds under this section. All funds so designated for the program established under this section shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa558c7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1543"},"text":"Pub. L. 101–624, title XV, § 1543","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3694"},"text":"104 Stat. 3694","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tX/s1002"},"text":"Pub. L. 102–237, title X, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1894"},"text":"105 Stat. 1894","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/511/tVII/s705"},"text":"Pub. L. 102–511, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3349"},"text":"106 Stat. 3349","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s277/b"},"text":"Pub. L. 104–127, title II, § 277(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/978"},"text":"110 Stat. 978","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIII"},"text":"Pub. L. 115–334, title III","children":[],"tail":", §§ 3201(b)(3)(B), 3305, "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4616"},"text":"132 Stat. 4616","children":[],"tail":", 4619.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa558c8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefa558c9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefa558ca-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1542(e), referred to in subsec. (b)(5), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1542/e"},"text":"section 1542(e) of Pub. L. 101–624","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s5622"},"text":"section 5622 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefa558cb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agricultural Development and Trade Act of 1990, and also as part of the Food, Agriculture, Conservation, and Trade Act of 1990, and not as part of the National Agricultural Research, Extension, and Teaching Policy Act of 1977 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefa558cc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3305/1"},"text":"Pub. L. 115–334, § 3305(1)","children":[],"tail":", substituted “for study—” for “for study in the United States.” and added pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3201/b/3/B"},"text":"Pub. L. 115–334, § 3201(b)(3)(B)","children":[],"tail":", substituted “section 1542(e)” for “section 1542(f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3305/2/A"},"text":"Pub. L. 115–334, § 3305(2)(A)","children":[],"tail":", inserted “(which may include agricultural extension services)” after “agricultural systems”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3305/2/B"},"text":"Pub. L. 115–334, § 3305(2)(B)","children":[],"tail":", inserted dash after “enhance” and subpar. (A) designation before “trade” and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3305/3/A"},"text":"Pub. L. 115–334, § 3305(3)(A)","children":[],"tail":", substituted “$4,000,000” for “$3,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3305/3/B"},"text":"Pub. L. 115–334, § 3305(3)(B)","children":[],"tail":", substituted “$3,000,000” for “$2,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3305/3/C"},"text":"Pub. L. 115–334, § 3305(3)(C)","children":[],"tail":", substituted “$6,000,000” for “$5,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s277/b/1"},"text":"Pub. L. 104–127, § 277(b)(1)","children":[],"tail":", in section catchline, substituted “middle income countries, emerging democracies, and emerging markets” for “middle income countries and emerging democracies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s277/b/2"},"text":"Pub. L. 104–127, § 277(b)(2)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s277/b/3"},"text":"Pub. L. 104–127, § 277(b)(3)","children":[],"tail":", substituted “food and fiber needs” for “food needs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511/s705/a/1"},"text":"Pub. L. 102–511, § 705(a)(1)","children":[],"tail":", struck out “middle income countries and emerging democracies” after “fellowship program for” and inserted “(as determined under subsection (b))” after “eligible countries”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511/s705/a/2"},"text":"Pub. L. 102–511, § 705(a)(2)","children":[],"tail":", substituted “described in any of the following paragraphs” for “that meet the following requirements” in introductory provisions and added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511/s705/b"},"text":"Pub. L. 102–511, § 705(b)","children":[],"tail":", inserted at end “The Secretary may provide fellowships under the program authorized by this section to private agricultural producers from eligible countries.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “program” for “Program”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
