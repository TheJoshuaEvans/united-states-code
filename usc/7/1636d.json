{"tag":"section","attrib":{"id":"ideedf6fbd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1636d"},"text":"§ 1636d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideedf6fbe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), each packer required to report information to the Secretary under this subchapter shall maintain, and make available to the Secretary on request, for 2 years—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf6fbf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the original contracts, agreements, receipts and other records associated with any transaction relating to the purchase, sale, pricing, transportation, delivery, weighing, slaughter, or carcass characteristics of all livestock; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6fc0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such records or other information as is necessary or appropriate to verify the accuracy of the information required to be reported under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf6fc1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under subsection (a)(2), the Secretary may not require a packer to provide new or additional information if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf6fc2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information is not generally available or maintained by packers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6fc3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of the information would be unduly burdensome.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf6fc4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchases of cattle or swine","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A record of a purchase of a lot of cattle or a lot of swine by a packer shall evidence whether the purchase occurred—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf6fc5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before 10:00 a.m. Central Time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6fc6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between 10:00 a.m. and 2:00 p.m. Central Time; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6fc7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after 2:00 p.m. Central Time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideedf6fc8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 255, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tIX/s911/2"},"text":"Pub. L. 106–78, title IX, § 911(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1203"},"text":"113 Stat. 1203","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
