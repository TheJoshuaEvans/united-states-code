{"tag":"section","attrib":{"id":"idefe82ddd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6611"},"text":null,"children":[{"tag":"num","attrib":{"value":"6611"},"text":"§ 6611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe82dde-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6611/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe82ddf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6611/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic well-being of rural America is vital to our national growth and prosperity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82de0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6611/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic well-being of many rural communities depends upon the goods and services that are derived from National Forest System land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82de1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6611/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economies of many of these communities suffer from a lack of industrial and business diversity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82de2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6611/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this lack of diversity is particularly serious in communities whose economies are predominantly dependent on timber and recreation resources and where management decisions made on National Forest System land by Federal and private organizations may disrupt the supply of those resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82de3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6611/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Forest Service has expertise and resources that could be directed to promote modernization and economic diversification of existing industries and services based on natural resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82de4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6611/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Forest Service has the technical expertise to provide leadership, in cooperation with other governmental agencies and the private sector, to assist rural communities dependent upon National Forest System land resources to upgrade existing industries and diversify by developing new economic activity in non-forest-related industries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82de5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6611/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance, training, education, and other assistance provided by the Department of Agriculture can be targeted to provide immediate help to those rural communities in greatest need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82de6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6611/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this subchapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe82de7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6611/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide assistance to rural communities that are located in or near National Forest System land and that are economically dependent upon natural resources or are likely to be economically disadvantaged by Federal or private sector land management practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82de8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6611/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to aid in diversifying such communities’ economic bases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82de9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6611/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the economic, social, and environmental well-being of rural America.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe82dea-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2373"},"text":"Pub. L. 101–624, title XXIII, § 2373","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4046"},"text":"104 Stat. 4046","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/3/tIII/s345/a"},"text":"Pub. L. 106–113, div. B, § 1000(a)(3) [title III, § 345(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–203.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefe82deb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefe82dec-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefe82ded-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/3/tIII/s345/a/1/A"},"text":"Pub. L. 106–113, § 1000(a)(3) [title III, § 345(a)(1)(A)]","children":[],"tail":", substituted “National Forest System land;” for “national forests;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/3/tIII/s345/a/1/B"},"text":"Pub. L. 106–113, § 1000(a)(3) [title III, § 345(a)(1)(B)]","children":[],"tail":", substituted “National Forest System land” for “the national forests”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/3/tIII/s345/a/1/C"},"text":"Pub. L. 106–113, § 1000(a)(3) [title III, § 345(a)(1)(C)]","children":[],"tail":", substituted “natural resources;” for “forest resources;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/3/tIII/s345/a/1/D"},"text":"Pub. L. 106–113, § 1000(a)(3) [title III, § 345(a)(1)(D)]","children":[],"tail":", substituted “National Forest System land resources” for “national forest resources”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/3/tIII/s345/a/2"},"text":"Pub. L. 106–113, § 1000(a)(3) [title III, § 345(a)(2)]","children":[],"tail":", substituted “National Forest System land” for “national forests” and “natural resources” for “forest resources”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
