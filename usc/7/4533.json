{"tag":"section","attrib":{"id":"idefb86b02-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4533"},"text":null,"children":[{"tag":"num","attrib":{"value":"4533"},"text":"§ 4533.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of order","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefb86b03-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4533/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication in Federal Register; public comment; submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After receipt of a proposed dairy products research order, the Secretary may publish such proposed order in the Federal Register and shall give notice and reasonable opportunity for public comment on such proposed order. Such proposed order may be submitted by an organization certified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4505"},"text":"section 4505 of this title","children":[],"tail":" or by any interested person affected by the provisions of subchapter I."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb86b04-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4533/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the Secretary provides for such publication and a reasonable opportunity for a hearing under subsection (a), the Secretary may issue the dairy products research order. The order so issued shall become effective not later than 90 days after publication in the Federal Register of the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb86b05-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4533/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may amend, from time to time, the dairy products research order issued under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefb86b06-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/180/tI/s132"},"text":"Pub. L. 98–180, title I, § 132","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tI/s121"},"text":"Pub. L. 99–198, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1369"},"text":"99 Stat. 1369","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
