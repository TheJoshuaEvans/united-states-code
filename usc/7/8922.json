{"tag":"section","attrib":{"id":"idf0451ade-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8922"},"text":null,"children":[{"tag":"num","attrib":{"value":"8922"},"text":"§ 8922.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural biosecurity grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0451adf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8922/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grant program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a competitive grant program to promote the development of teaching programs in agriculture, veterinary medicine, and disciplines closely allied to the food and agriculture system to increase the number of trained individuals with an expertise in agricultural biosecurity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0451ae0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8922/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may award a grant under this section only to an entity that is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0451ae1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8922/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an accredited school of veterinary medicine; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451ae2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8922/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a department of an institution of higher education with a primary focus on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0451ae3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8922/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comparative medicine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451ae4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8922/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterinary science; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451ae5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8922/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agricultural biosecurity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0451ae6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8922/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall give preference in awarding grants based on the ability of an applicant—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0451ae7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8922/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the number of veterinarians or individuals with advanced degrees in food and agriculture disciplines who are trained in agricultural biosecurity practice areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451ae8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8922/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase research capacity in areas of agricultural biosecurity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451ae9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8922/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fill critical agricultural biosecurity shortage situations outside of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0451aea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8922/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0451aeb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8922/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts received under this section shall be used by a grantee to pay—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0451aec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8922/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs associated with the acquisition of equipment and other capital costs relating to the expansion of food, agriculture, and veterinary medicine teaching programs in agricultural biosecurity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451aed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8922/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capital costs associated with the expansion of academic programs that offer postgraduate training for veterinarians or concurrent training for veterinary students in specific areas of specialization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451aee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8922/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other capacity and infrastructure program costs that the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451aef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8922/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds received under this section may not be used for the construction, renovation, or rehabilitation of a building or facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0451af0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8922/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0451af1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8922/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for each of fiscal years 2008 through 2013, to remain available until expended; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451af2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8922/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for each of fiscal years 2014 through 2023, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0451af3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14122"},"text":"Pub. L. 110–234, title XIV, § 14122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1456"},"text":"122 Stat. 1456","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14122, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2218; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7504"},"text":"Pub. L. 113–79, title VII, § 7504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/901"},"text":"128 Stat. 901","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7404"},"text":"Pub. L. 115–334, title VII, § 7404","children":[],"tail":", "},{"tag"