{"tag":"section","attrib":{"id":"ideff1a47b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6931"},"text":null,"children":[{"tag":"num","attrib":{"value":"6931"},"text":"§ 6931.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary of Agriculture for Farm Production and Conservation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff1a47c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6931/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to establish in the Department the position of Under Secretary of Agriculture for Farm Production and Conservation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a47d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6931/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confirmation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary establishes the position of Under Secretary of Agriculture for Farm Production and Conservation authorized under subsection (a), the Under Secretary shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a47e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6931/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Undersecretary ","children":[{"tag":"ref","attrib":{"idref":"fn002320"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002320"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Under Secretary”."}],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary of Agriculture for Farm Production and Conservation shall perform such functions and duties as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a47f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6931/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Succession","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any official who is serving as Under Secretary of Agriculture for Farm and Foreign Agricultural Services on ","children":[{"tag":"date","attrib":{"date":"2018-03-23"},"text":"March 23, 2018","children":[],"tail":", and who was appointed by the President, by and with the advice and consent of the Senate, shall not be required to be reappointed under subsection (b) to the successor position authorized under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff1a480-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s225"},"text":"Pub. L. 103–354, title II, § 225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3213"},"text":"108 Stat. 3213","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dA/tVII/s772/a/2"},"text":"Pub. L. 115–141, div. A, title VII, § 772(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/397"},"text":"132 Stat. 397","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideff1a481-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideff1a482-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideff1a483-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/s225"},"text":"section 225 of Pub. L. 103–354","children":[],"tail":". Subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/s225"},"text":"section 225 of Pub. L. 103–354","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of Title 5","children":[],"tail":", Government Organization and Employees, and repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s5691"},"text":"section 5691 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/s225"},"text":"section 225 of Pub. L. 103–354","children":[],"tail":" is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6925"},"text":"section 6925 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideff1a484-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" amended section generally. Prior to amendment, section related to Under Secretary of Agriculture for Farm and Foreign Agricultural Services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
