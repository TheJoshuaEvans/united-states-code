{"tag":"section","attrib":{"id":"idf023d7d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7913"},"text":null,"children":[{"tag":"num","attrib":{"value":"7913"},"text":"§ 7913.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of direct payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf023d7d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7913/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of the 2002 through 2007 crop years of each covered commodity, the Secretary shall make direct payments to producers on farms for which payment yields and base acres are established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf023d7d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7913/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The payment rates used to make direct payments with respect to covered commodities for a crop year are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf023d7d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7913/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Wheat, $0.52 per bushel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d7d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7913/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Corn, $0.28 per bushel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d7d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7913/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grain sorghum, $0.35 per bushel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d7d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7913/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Barley, $0.24 per bushel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d7d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7913/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Oats, $0.024 per bushel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d7d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7913/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upland cotton, $0.0667 per pound.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d7d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7913/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rice, $2.35 per hundredweight.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d7da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7913/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Soybeans, $0.44 per bushel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d7db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7913/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other oilseeds, $0.0080 per pound.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf023d7dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7913/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the direct payment to be paid to the producers on a farm for a covered commodity for a crop year shall be equal to the product of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf023d7dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7913/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The payment rate specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d7de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7913/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The payment acres of the covered commodity on the farm.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d7df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7913/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The payment yield for the covered commodity for the farm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf023d7e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7913/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for payment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf023d7e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7913/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make direct payments—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf023d7e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7913/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the 2002 crop year, as soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf023d7e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7913/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of each of the 2003 through 2007 crop years, not before October 1 of the calendar year in which the crop of the covered commodity is harvested.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d7e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7913/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the option of the producers on a farm, up to 50 percent of the direct payment for a covered commodity for any of the 2003 through 2005 crop years, up to 40 percent of the direct payment for a covered commodity for the 2006 crop year, and up to 22 percent of the direct payment for a covered commodity for the 2007 crop year, shall be paid to the producers in advance. The producers shall select the month within which the advance payment for a crop year will be made. The month selected may be any month during the period beginning on December 1 of the calendar year before the calendar year in which the crop of the covered commodity is harvested through the month within which the direct payment would otherwise be made. The producers may change the selected month for a subsequent advance payment by providing advance notice to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d7e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7913/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of advance payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a producer on a farm that receives an advance direct payment for a crop year ceases to be a producer on that farm, or the extent to which the producer shares in the risk of producing a crop changes, before the date the remainder of the direct payment is made, the producer shall be responsible for repaying the Secretary the applicable amount of the advance payment, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf023d7e6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1103"},"text":"Pub. L. 107–171, title I, § 1103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/149"},"text":"116 Stat. 149","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/tI/s1102/a"},"text":"Pub. L. 109–171, title I, § 1102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/5"},"text":"120 Stat. 5","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf023d7e7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf023d7e8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf023d7e9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171"},"text":"Pub. L. 109–171","children":[],"tail":" substituted “2005 crop years, up to 40 percent of the direct payment for a covered commodity for the 2006 crop year, and up to 22 percent of the direct payment for a covered commodity for the 2007 crop year,” for “2007 crop years”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
