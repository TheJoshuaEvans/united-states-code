n subsec. (b)(4), was in the original “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/307"},"text":"75 Stat. 307","children":[],"tail":", known as the Consolidated Farm and Rural Development Act, which is classified principally to this chapter. For complete classification of title III to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279/e"},"text":"Section 2279(e) of this title","children":[],"tail":", referred to in subsec. (c)(2)(B), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279/a"},"text":"section 2279(a) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12301/b/3"},"text":"section 12301(b)(3) of Pub. L. 115–334","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef117c4c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef117c4d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s5101/1"},"text":"Pub. L. 113–79, § 5101(1)","children":[],"tail":"–(5), designated existing provisions as par. (1) and inserted heading, in first sentence, substituted “limited liability companies, and such other legal entities as the Secretary considers appropriate,” for “and limited liability companies”, in second sentence, redesignated pars. (1) to (4) as subpars. (A) to (D), respectively, and substituted “limited liability companies, and such other legal entities” for “and limited liability companies” in two places, and, in third sentence, substituted “limited liability companies, and such other legal entities” for “and limited liability companies” in two places, “subparagraph (C)” for “clause (3)” and “subparagraph (D)” for “clause (4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s5101/6"},"text":"Pub. L. 113–79, § 5101(6)","children":[],"tail":", added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s5102"},"text":"Pub. L. 113–79, § 5102","children":[],"tail":", struck out “who are rural residents” after “youths”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s5103"},"text":"Pub. L. 113–79, § 5103","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s5106/b/1"},"text":"Pub. L. 113–79, § 5106(b)(1)","children":[],"tail":", added par. (2) and struck out former par. (2). Prior to amendment, text read as follows: “In this subsection, the term ‘direct operating loan’ shall not include a loan made to a youth under subsection (b) of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s5104"},"text":"Pub. L. 113–79, § 5104","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s5101"},"text":"Pub. L. 110–246, § 5101","children":[],"tail":", inserted section catchline and, in subsec. (a), inserted heading, substituted “The Secretary may” for “The Secretary is authorized to” in introductory provisions, and inserted “, taking into consideration all farming experience of the applicant, without regard to any lapse between farming experiences” after “farming operations” in cl. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s5302/a"},"text":"Pub. L. 107–171, § 5302(a)","children":[],"tail":", substituted “joint operations, trusts, and limited liability companies” for “and joint operations” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s5101/1/A"},"text":"Pub. L. 107–171, § 5101(1)(A)","children":[],"tail":", substituted “paragraphs (3) and (4)” for “paragraph (3)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s5101/1/B"},"text":"Pub. L. 107–171, § 5101(1)(B)","children":[],"tail":", struck out “who has not operated a farm or ranch, or who has operated a farm or ranch for not more than 5 years” before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s5101/2"},"text":"Pub. L. 107–171, § 5101(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" inserted “for direct loans only,” before “have either” in cl. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s661/f"},"text":"Pub. L. 104–127, § 661(f)","children":[],"tail":", struck out “and for the purposes specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1942"},"text":"section 1942 of this title","children":[],"tail":"” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s611/b"},"text":"Pub. L. 104–127, § 611(b)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s611/a"},"text":"Pub. L. 104–127, § 611(a)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c) which read as follows: “The Secretary may not restrict eligibility for loans made or insured under this subchapter for purposes set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1942"},"text":"section 1942 of this title","children":[],"tail":" solely to borrowers of loans that are outstanding on "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"December 23, 1985","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1301/a"},"text":"Pub. L. 99–198, § 1301(a)","children":[],"tail":", substituted—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(1) “, partnerships, and joint operations” for “and partnerships” wherever appearing after “corporations”;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(2) “, partnerships, and joint operations” for “, and partnerships” wherever appearing after “corporations”; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(3) “individuals” for “members, stockholders, or partners, as applicable,” wherever appearing.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1303"},"text":"Pub. L. 99–198, § 1303","children":[],"tail":", in cl. (3) parenthetical, inserted provision treating blood or marriage related owner-operators of the entire farm interest as separate interest holders of not larger than family farms though collective ownership constitutes a larger than a family farm."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1302/b"},"text":"Pub. L. 99–198, § 1302(b)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98"},"text":"Pub. L. 97–98","children":[],"tail":" substituted “corporations and partnerships, the family farm” for “cooperatives, corporations, and partnerships, the family farm” and “as well to the entity in the case of cooperatives, corporations, and partnerships” for “as well to the entity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/334"},"text":"Pub. L. 95–334","children":[],"tail":" substituted provisions setting forth eligibility criteria for loans to farmers and ranchers in the United States, and to farm cooperatives and private domestic corporations and partnerships controlled by farmers and ranchers and engaged primarily and directly in farming or ranching in the United States, for provisions setting forth eligibility criteria for loans to farmers and ranchers in the United States, Puerto Rico, and the Virgin Islands."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/419"},"text":"Pub. L. 92–419","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef117c4e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef117c4f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef117c50-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s611"},"text":"section 611 of Pub. L. 104–127","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", and amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/s661/f"},"text":"section 661(f) of Pub. L. 104–127","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", see section 663(a), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1922"},"text":"section 1922 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef117c51-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98"},"text":"Pub. L. 97–98","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1801"},"text":"section 1801 of Pub. L. 97–98","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef117c52-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Farm Operating Loan Eligibility","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/tII/s255"},"text":"Pub. L. 106–224, title II, § 255","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/424"},"text":"114 Stat. 424","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/224/tII/s255"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“During the period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":"] and ending on "},{"tag":"date","attrib":{"date":"2002-12-31"},"text":"December 31, 2002","children":[],"tail":"—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 311(c) and 319 of the Consolidated Farm and Rural Development Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1941/c"},"text":"7 U.S.C. 1941(c)","children":[],"tail":", 1949) shall have no force or effect; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in making direct loans under subtitle B of that Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1941"},"text":"7 U.S.C. 1941","children":[],"tail":" et seq.), the Secretary shall give priority to a qualified beginning farmer or rancher who has not operated a farm or ranch, or who has operated a farm or ranch for not more than 5 years.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef117c53-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authority of Secretary To Make or Guarantee Certain Loans","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/tII/s2002"},"text":"Pub. L. 104–134, title II, § 2002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321-313"},"text":"110 Stat. 1321–313","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/134/tII/s2002"},"text":"“Notwithstanding any other provision of law, the Secretary of Agriculture is hereby authorized to make or guarantee an operating loan under Subtitle B [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1941"},"text":"7 U.S.C. 1941","children":[],"tail":" et seq.] or an emergency loan under Subtitle C ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1961"},"text":"7 U.S.C. 1961","children":[],"tail":" et seq.] of the Consolidated Farm and Rural Development Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1922"},"text":"7 U.S.C. 1922","children":[],"tail":" et. seq.), as in effect prior to "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"April 4, 1996","children":[],"tail":", to a loan applicant who was less than 90 days delinquent on "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"April 4, 1996","children":[],"tail":", if the loan applicant had submitted an application for the loan prior to "},{"tag":"date","attrib":{"date":"1996-04-05"},"text":"April 5, 1996","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef117c54-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1989 Farm Operating Loans","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/82/tIII/s302"},"text":"Pub. L. 101–82, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-14"},"text":"Aug. 14, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/582"},"text":"103 Stat. 582","children":[],"tail":", required the Secretary of Agriculture to ensure that direct operating loans made or insured under this subchapter for 1990 crop production were to be made available to farmers and ranchers suffering major losses due to excess moisture, freeze, storm, or related condition occurring in 1989 or drought or related condition occurring in 1988 or 1989."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior act:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/387/tIII/s312"},"text":"Pub. L. 100–387, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-11"},"text":"Aug. 11, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/948"},"text":"102 Stat. 948","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
