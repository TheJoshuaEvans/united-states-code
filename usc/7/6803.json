{"tag":"section","attrib":{"id":"idefece8d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6803"},"text":null,"children":[{"tag":"num","attrib":{"value":"6803"},"text":"§ 6803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefece8d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefece8d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6803/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To effectuate the policy of this chapter specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6801/b"},"text":"section 6801(b) of this title","children":[],"tail":", the Secretary, subject to the procedures provided in subsection (b), shall issue orders under this chapter applicable to qualified handlers of cut flowers and cut greens."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefece8d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6803/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any order shall be national in scope.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefece8d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6803/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" One order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 1 order shall be in effect at any 1 time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefece8d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefece8d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6803/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposal for an order","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefece8d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6803/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may propose the issuance of an order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefece8da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6803/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An industry group that represents a substantial number of the industry members who are to be assessed under the order, or any other person who will be affected by this chapter, may request the issuance of, and submit a proposal for, an order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefece8db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6803/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of proposal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall publish a proposed order and give notice and opportunity for public comment on the proposed order not later than 60 days after the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefece8dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6803/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the Secretary proposes an order, as provided in paragraph (1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefece8dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6803/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the receipt by the Secretary of a proposal for an order, as provided in paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefece8de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6803/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of order","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefece8df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6803/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After notice and opportunity for public comment are provided in accordance with paragraph (2), the Secretary shall issue the order, taking into consideration the comments received and including in the order such provisions as are necessary to ensure that the order is in conformity with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefece8e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6803/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall be issued and become effective not later than 180 days after publication of the proposed order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefece8e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6803/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, from time to time, may amend an order. The provisions of this chapter applicable to an order shall be applicable to any amendment to an order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefece8e2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/190/s4"},"text":"Pub. L. 103–190, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2271"},"text":"107 Stat. 2271","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
