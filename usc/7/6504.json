{"tag":"section","attrib":{"id":"idefe5bbe6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6504"},"text":null,"children":[{"tag":"num","attrib":{"value":"6504"},"text":"§ 6504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National standards for organic production","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To be sold or labeled as an organically produced agricultural product under this chapter, an agricultural product shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bbe7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6504/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been produced and handled without the use of synthetic chemicals, except as otherwise provided in this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbe8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6504/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as otherwise provided in this chapter and excluding livestock, not be produced on land to which any prohibited substances, including synthetic chemicals, have been applied during the 3 years immediately preceding the harvest of the agricultural products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbe9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6504/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be produced and handled in compliance with an organic plan agreed to by the producer and handler of such product and the certifying agent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe5bbea-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXI/s2105"},"text":"Pub. L. 101–624, title XXI, § 2105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3937"},"text":"104 Stat. 3937","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tX/s1001/1"},"text":"Pub. L. 102–237, title X, § 1001(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1893"},"text":"105 Stat. 1893","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefe5bbeb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefe5bbec-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefe5bbed-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “; and” for period at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
