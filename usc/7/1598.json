{"tag":"section","attrib":{"id":"ideed13fd5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1598"},"text":null,"children":[{"tag":"num","attrib":{"value":"1598"},"text":"§ 1598.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of intention to prosecute","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Before any violation of this chapter is reported by the Secretary of Agriculture to any United States attorney for institution of a criminal proceeding, the person against whom such proceeding is contemplated shall be given appropriate notice and an opportunity to prevent ","children":[{"tag":"ref","attrib":{"idref":"fn002182"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002182"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “present”."}],"tail":" his views, either orally or in writing, with regard to such contemplated proceeding."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideed13fd6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-09/ch615"},"text":"Aug. 9, 1939, ch. 615","children":[],"tail":", title IV, § 408, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1286"},"text":"53 Stat. 1286","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideed13fd7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideed13fd8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideed13fd9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1610"},"text":"section 1610 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
