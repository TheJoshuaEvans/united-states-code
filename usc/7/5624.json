{"tag":"section","attrib":{"id":"idefcb7d84-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5624"},"text":null,"children":[{"tag":"num","attrib":{"value":"5624"},"text":"§ 5624.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Barter of agricultural commodities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefcb7d85-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5624/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the Commodity Credit Corporation may provide eligible commodities in barter for foreign products under such terms and conditions as the Secretary or the Corporation shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcb7d86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5624/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible commodities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless otherwise specified, eligible commodities shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcb7d87-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5624/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agricultural commodities acquired by the Commodity Credit Corporation through price support operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7d88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5624/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agricultural commodities acquired by the Secretary or the Commodity Credit Corporation in the normal course of business and available for disposition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcb7d89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5624/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Barter by exporters of agricultural commodities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcb7d8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5624/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary or the Commodity Credit Corporation shall encourage exporters of agricultural commodities to barter such commodities for foreign products—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefcb7d8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5624/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire such foreign products needed by such exporters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcb7d8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5624/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop, maintain, or expand foreign markets for United States agricultural exports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7d8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5624/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the Commodity Credit Corporation may provide eligible commodities to exporters to assist such exporters in barter transactions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7d8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5624/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the Commodity Credit Corporation shall provide technical advice and assistance relating to the barter of agricultural commodities to any United States exporter who requests such advice or assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcb7d8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5624/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of foreign products to other Government agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the Commodity Credit Corporation may transfer any foreign products that the Secretary or such Corporation obtains through barter activities to other Government agencies if the Corporation receives assurances that it will receive full reimbursement from the agency within the same fiscal year in which such transfer occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcb7d90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5624/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporation authority not limited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing contained in this section shall limit the authority of the Commodity Credit Corporation to acquire, hold, or dispose of such foreign materials as such Corporation determines appropriate in carrying out the functions and protecting the assets of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcb7d91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5624/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary or the Commodity Credit Corporation shall take reasonable precautions to prevent the misuse of eligible commodities in a barter or exchange program, including activities that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcb7d92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5624/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" displace or interfere with commercial sales of United States agricultural commodities that otherwise might be made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7d93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5624/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unduly disrupt world prices of agricultural commodities or the normal patterns of commercial trade with recipient countries; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7d94-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5624/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit the resale or transshipment of eligible commodities to countries other than the intended recipient country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefcb7d95-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/tII/s204"},"text":"Pub. L. 95–501, title II, § 204","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1531"},"text":"Pub. L. 101–624, title XV, § 1531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3676"},"text":"104 Stat. 3676","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIII/s320"},"text":"Pub. L. 102–237, title III, § 320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1857"},"text":"105 Stat. 1857","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefcb7d96-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefcb7d97-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefcb7d98-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" amended heading and substituted “Government” for “government” in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
