{"tag":"section","attrib":{"id":"idf04519c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8789"},"text":null,"children":[{"tag":"num","attrib":{"value":"8789"},"text":"§ 8789.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Storage facility loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf04519c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8789/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after the date of enactment of this Act, the Secretary shall establish a storage facility loan program to provide funds for producers of grains, oilseeds, pulse crops, hay, renewable biomass, and other storable commodities (other than sugar), as determined by the Secretary, to construct or upgrade storage and handling facilities for the commodities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04519c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8789/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible producers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A storage facility loan under this section shall be made available to any producer described in subsection (a) that, as determined by the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04519c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8789/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a satisfactory credit history;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04519c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8789/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a need for increased storage capacity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04519c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8789/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates an ability to repay the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04519c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8789/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A storage facility loan under this section shall have a maximum term of 12 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04519ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8789/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maximum principal amount of a storage facility loan under this section shall be $500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04519cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8789/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan disbursements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for 1 partial disbursement of loan principal and 1 final disbursement of loan principal, as determined to be appropriate and subject to acceptable documentation, to facilitate the purchase and construction of eligible facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04519cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8789/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan security","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Approval of a storage facility loan under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04519cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8789/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require the borrower to provide loan security to the Secretary, in the form of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04519ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8789/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lien on the real estate parcel on which the storage facility is located; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04519cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8789/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other security as is acceptable to the Secretary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04519d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8789/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" under such rules and regulations as the Secretary may prescribe, not require a severance agreement from the holder of any prior lien on the real estate parcel on which the storage facility is located, if the borrower—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04519d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8789/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees to increase the down payment on the storage facility by an amount determined appropriate by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04519d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8789/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides other security acceptable to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04519d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8789/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" allow a borrower, upon the approval of the Secretary, to define a subparcel of real estate as security for the storage facility loan if the subparcel is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04519d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8789/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of adequate size and value to adequately secure the loan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04519d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8789/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not subject to any other liens or mortgages that are superior to the lien interest of the Commodity Credit Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf04519d6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1614"},"text":"Pub. L. 110–234, title I, § 1614","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1020"},"text":"122 Stat. 1020","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1614, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1748.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf04519d7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf04519d8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf04519d9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this Act, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf04519da-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf04519db-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf04519dc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
