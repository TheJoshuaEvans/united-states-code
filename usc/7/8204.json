{"tag":"section","attrib":{"id":"idf034784e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8204"},"text":null,"children":[{"tag":"num","attrib":{"value":"8204"},"text":"§ 8204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf034784f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of payments that a person shall be entitled to receive under this chapter may not exceed $75,000, or an equivalent value in tree seedlings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0347850-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acres","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total quantity of acres planted to trees or tree seedlings for which a person shall be entitled to receive payments under this chapter may not exceed 500 acres.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0347851-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8204/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall promulgate regulations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0347852-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8204/c/1"},"text":null,"chi