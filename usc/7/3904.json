{"tag":"section","attrib":{"id":"idefb13ef7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3904"},"text":null,"children":[{"tag":"num","attrib":{"value":"3904"},"text":"§ 3904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; restriction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefb13ef8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are hereby authorized to be appropriated to administer the program under this chapter $25,000,000 for fiscal year 1982, and $25,000,000 annually thereafter through the end of fiscal year 1986.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb13ef9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 30 per centum of any of the amounts appropriated under this section in any fiscal year may be obligated for research under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3902"},"text":"section 3902 of this title","children":[],"tail":" at facilities of the Department of Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefb13efa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/469/s5"},"text":"Pub. L. 96–469, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2235"},"text":"94 Stat. 2235","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
