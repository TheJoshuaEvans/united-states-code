{"tag":"section","attrib":{"id":"idedcd3d55-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"7b–1"},"text":"§ 7b–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of securities exchanges and associations as contract markets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idedcd3d56-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any board of trade that is registered with the Securities and Exchange Commission as a national securities exchange, is a national securities association registered pursuant to section 78","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–3(a) of title 15, or is an alternative trading system shall be a designated contract market in security futures products if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idedcd3d57-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such national securities exchange, national securities association, or alternative trading system lists or trades no other contracts of sale for future delivery, except for security futures products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcd3d58-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such national securities exchange, national securities association, or alternative trading system files written notice with the Commission in such form as the Commission, by rule, may prescribe containing such information as the Commission, by rule, may prescribe as necessary or appropriate in the public interest or for the protection of customers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcd3d59-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the registration of such national securities exchange, national securities association, or alternative trading system is not suspended pursuant to an order by the Securities and Exchange Commission.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such designation shall be effective contemporaneously with the submission of notice, in written or electronic form, to the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedcd3d5a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedcd3d5b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A national securities exchange, national securities association, or alternative trading system that is designated as a contract market pursuant to this section shall be exempt from the following provisions of this chapter and the rules thereunder:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcd3d5c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsections (c), (e), and (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6c"},"text":"section 6c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcd3d5d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6j"},"text":"Section 6j of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcd3d5e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7"},"text":"Section 7 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcd3d5f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7a–2"},"text":"Section 7a–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcd3d60-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s10a"},"text":"Section 10a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcd3d61-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s12/d"},"text":"Section 12(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcd3d62-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 13(f) ","children":[{"tag":"ref","attrib":{"idref":"fn002035"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002035"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcd3d63-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s20"},"text":"Section 20 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcd3d64-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An alternative trading system that is a designated contract market under this section shall be required to be a member of a futures association registered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s21"},"text":"section 21 of this title","children":[],"tail":" and shall be exempt from any provision of this chapter that would require such alternative trading system to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcd3d65-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set rules governing the conduct of subscribers other than the conduct of such subscribers’ trading on such alternative trading system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcd3d66-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discipline subscribers other than by exclusion from trading.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcd3d67-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent that an alternative trading system is exempt from any provision of this chapter pursuant to paragraph (2) of this subsection, the futures association registered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s21"},"text":"section 21 of this title","children":[],"tail":" of which the alternative trading system is a member shall set rules governing the conduct of subscribers to the alternative trading system and discipline the subscribers."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcd3d68-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcd3d69-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (B), but notwithstanding any other provision of this chapter, the Commission, by rule, regulation, or order, may conditionally or unconditionally exempt any designated contract market in security futures subject to the designation requirement of this section from any provision of this chapter or of any rule or regulation thereunder, to the extent such exemption is necessary or appropriate in the public interest and is consistent with the protection of investors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcd3d6a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall, by rule or regulation, determine the procedures under which an exemptive order under this section is granted and may, in its sole discretion, decline to entertain any application for an order of exemption under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcd3d6b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–1/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An alternative trading system shall not be deemed to be an exchange for any purpose as a result of the designation of such alternative trading system as a contract market under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idedcd3d6c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369/s5f"},"text":"Sept. 21, 1922, ch. 369, § 5f","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tII/s252/a"},"text":"Pub. L. 106–554, § 1(a)(5) [title II, § 252(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–445.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idedcd3d6d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idedcd3d6e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idedcd3d6f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s13"},"text":"section 13 of this title","children":[],"tail":", referred to in subsec. (b)(1)(G), was redesignated subsec. (e) by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tXIII/s13105/h/2"},"text":"Pub. L. 110–246, title XIII, § 13105(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2197"},"text":"122 Stat. 2197","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
