{"tag":"section","attrib":{"id":"idf0262095-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7933"},"text":null,"children":[{"tag":"num","attrib":{"value":"7933"},"text":"§ 7933.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0262096-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7933/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of loan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of each loan commodity, a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7931"},"text":"section 7931 of this title","children":[],"tail":" shall have a term of 9 months beginning on the first day of the first month after the month in which the loan is made."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0262097-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7933/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extensions prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not extend the term of a marketing assistance loan for any loan commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0262098-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1203"},"text":"Pub. L. 107–171, title I, § 1203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/156"},"text":"116 Stat. 156","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
