{"tag":"section","attrib":{"id":"ideefc1f59-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1764"},"text":null,"children":[{"tag":"num","attrib":{"value":"1764"},"text":"§ 1764.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports and dispatches","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideefc1f5a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1764/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to Department of State and interested Government agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reports and dispatches prepared by the officers appointed or assigned under this subchapter shall be made available to the Department of State, and may be made available to other interested agencies of the Government, and the agricultural reports and dispatches and related information produced by officers of the Foreign Service shall be available to the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideefc1f5b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1764/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office space, equipment, and administrative and clerical services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State is authorized upon request of the Secretary of Agriculture to provide office space, equipment, facilities, and such other administrative and clerical services as may be required for the personnel affected by this subchapter. The Secretary of Agriculture is authorized to reimburse or advance funds to the Secretary of State for such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideefc1f5c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1764/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency services, personnel, and facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the request of the Secretary of Agriculture, each Federal agency may make its services, personnel, and facilities available to officers and employees appointed and assigned to a post abroad under this subchapter in the performance of the functions of such officers and employees. The Secretary of Agriculture may reimburse or advance funds to any such agency for services, personnel, and facilities so made available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideefc1f5d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-28/ch1041"},"text":"Aug. 28, 1954, ch. 1041","children":[],"tail":", title VI, § 604, "},{"tag":"ref","attrib":{"href":"/us/stat/68/909"},"text":"68 Stat. 909","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/501/tIII/s301/4"},"text":"Pub. L. 95–501, title III, § 301(4)","children":[],"tail":", (6), "},{"tag":"date","attrib":{"date":"1978-10-21"},"text":"Oct. 21, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1688"},"text":"92 Stat. 1688","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideefc1f5e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideefc1f5f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideefc1f60-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/s301/4"},"text":"Pub. L. 95–501, § 301(4)","children":[],"tail":", substituted “this subchapter” for “this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/s301/6"},"text":"Pub. L. 95–501, § 301(6)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
