{"tag":"section","attrib":{"id":"idefe372ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6309"},"text":null,"children":[{"tag":"num","attrib":{"value":"6309"},"text":"§ 6309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe372ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6309/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), nothing in this chapter may be construed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe372ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6309/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preempt or supersede any other program relating to soybean promotion, research, consumer information, or industry information organized and operated under the laws of the United States or any State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe372af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6309/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize the withholding of any information from Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe372b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6309/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State laws","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe372b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6309/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referenda on qualified State soybean boards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To ensure the proper administration of this chapter, no State may conduct a referendum relating to the continuation or termination of a qualified State soybean board or State soybean assessment—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe372b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6309/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the period beginning on the date an order is issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6303"},"text":"section 6303 of this title","children":[],"tail":" and ending 18 months after the referendum on such order is conducted under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6305/a"},"text":"section 6305(a) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe372b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6309/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such order is approved under the referendum conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6305/a"},"text":"section 6305(a) of this title","children":[],"tail":" by a majority of producers voting in such State, such State law shall be suspended for an additional 36 months."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe372b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6309/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not be construed to apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe372b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6309/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State referendum concerning the approval of modifications to a State soybean promotion program that does not involve termination of the qualified State soybean board or State soybean assessment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe372b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6309/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State referendum regarding a State soybean promotion program that is originated by soybean producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe372b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6309/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments collected by qualified State soybean boards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To ensure adequate funding of the operations of qualified State soybean boards under this chapter, whenever an order is in effect under this chapter, no State law or regulation that limits the rate of assessment that the qualified State soybean board in that State may collect from producers on soybeans produced in such State, or that has the effect of limiting such rate, may be applied to prohibit such State board from collecting, and expending for authorized purposes, assessments from producers of up to the full amount of the credit authorized for producer contributions to qualified State soybean boards under section 6304(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(4) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe372b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6309/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments to orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this chapter applicable to orders shall be applicable to amendments to orders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe372b9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1974"},"text":"Pub. L. 101–624, title XIX, § 1974","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3903"},"text":"104 Stat. 3903","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tVIII/s806/3"},"text":"Pub. L. 102–237, title VIII, § 806(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1883"},"text":"105 Stat. 1883","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefe372ba-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefe372bb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefe372bc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s806/3/B"},"text":"Pub. L. 102–237, § 806(3)(B)","children":[],"tail":", redesignated second subsec. (b), relating to amendments to orders, as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s806/3/A"},"text":"Pub. L. 102–237, § 806(3)(A)","children":[],"tail":", substituted “section 6304("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(4)” for “section 6304(k)(4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s806/3/B"},"text":"Pub. L. 102–237, § 806(3)(B)","children":[],"tail":", redesignated second subsec. (b), relating to amendments of orders, as (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
