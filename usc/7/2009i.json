{"tag":"section","attrib":{"id":"idef29715c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009i"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009i"},"text":"§ 2009i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interstate collaboration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall permit the establishment of voluntary pooling arrangements among States, and regional fund-sharing agreements, to carry out projects receiving assistance under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef29715d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s381J"},"text":"Pub. L. 87–128, title III, § 381J","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s761"},"text":"Pub. L. 104–127, title VII, § 761","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1146"},"text":"110 Stat. 1146","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
