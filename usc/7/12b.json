{"tag":"section","attrib":{"id":"idedd468b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s12b"},"text":null,"children":[{"tag":"num","attrib":{"value":"12b"},"text":"§ 12b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trading ban violations; prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any person, against whom there is outstanding any order of the Commission prohibiting him from trading on or subject to the rules of any registered entity, to make or cause to be made in contravention of such order, any contract for future delivery of any commodity, on or subject to the rules of any registered entity.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idedd468b6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369/s8b"},"text":"Sept. 21, 1922, ch. 369, § 8b","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/258/s24"},"text":"Pub. L. 90–258, § 24","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-02-19"},"text":"Feb. 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/33"},"text":"82 Stat. 33","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/463/tI/s103/a"},"text":"Pub. L. 93–463, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-23"},"text":"Oct. 23, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1392"},"text":"88 Stat. 1392","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tI/s123/a/20"},"text":"Pub. L. 106–554, § 1(a)(5) [title I, § 123(a)(20)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 