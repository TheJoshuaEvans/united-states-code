ndment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/487"},"text":"Pub. L. 90–487","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/487/s2"},"text":"section 2 of Pub. L. 90–487","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s78"},"text":"section 78 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
