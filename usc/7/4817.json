{"tag":"section","attrib":{"id":"idefbf9797-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4817"},"text":null,"children":[{"tag":"num","attrib":{"value":"4817"},"text":"§ 4817.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefbf9798-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4817/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion and consumer education; funds from pork producers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This chapter is intended to occupy the field of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf9799-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4817/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotion and consumer education involving pork and pork products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf979a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4817/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtaining funds therefor from pork producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf979b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4817/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional or different State regulation prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulation of such activity (other than a regulation or requirement relating to a matter of public health or the provision of State or local funds for such activity) that is in addition to or different from this chapter may not be imposed by a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf979c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4817/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply only during a period beginning on the date of the commencement of the collection of assessments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4809"},"text":"section 4809 of this title","children":[],"tail":" and ending on the date of the termination of the collection of assessments under section 4811(a)(3) or 4811(b)(1)(B) "},{"tag":"ref","attrib":{"idref":"fn002300"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002300"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section 4811(b)(2)(A) or 4812(b)(1)(B)”."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefbf979d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1628"},"text":"Pub. L. 99–198, title XVI, § 1628","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1621"},"text":"99 Stat. 1621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefbf979e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefbf979f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{