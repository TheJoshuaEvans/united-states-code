{"tag":"section","attrib":{"id":"idef8d8b0c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2902"},"text":null,"children":[{"tag":"num","attrib":{"value":"2902"},"text":"§ 2902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8d8b0d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2902/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “beef” means flesh of cattle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8b0e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2902/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “beef products” means edible products produced in whole or in part from beef, exclusive of milk and products made therefrom;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8b0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2902/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Board” means the Cattlemen’s Beef Promotion and Research Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2904/1"},"text":"section 2904(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8b10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2902/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “cattle” means live domesticated bovine animals regardless of age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8b11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2902/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Committee” means the Beef Promotion Operating Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2904/5"},"text":"section 2904(5) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8b12-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2902/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “consumer information” means nutritional data and other information that will assist consumers and other persons in making evaluations and decisions regarding the purchasing, preparing, and use of beef and beef products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8b13-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2902/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Department” means the Department of Agriculture.","children":[{"tag":"ref","attrib":{"idref":"fn002266"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002266"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8b14-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2902/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “importer” means any person who imports cattle, beef, or beef products from outside the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8b15-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2902/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “industry information” means information and programs that will lead to the development of new markets, marketing strategies, increased efficiency, and activities to enhance the image of the cattle industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8b16-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2902/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The ","children":[{"tag":"ref","attrib":{"idref":"fn002267"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002267"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" term “order” means a beef promotion and research order issued under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2903"},"text":"section 2903 of this title","children":[],"tail":"."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8b17-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2902/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “person” means any individual, group of individuals, partnership, corporation, association, cooperative, or any other entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8b18-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2902/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “producer” means any person who owns or acquires ownership of cattle, except that a person shall not be considered to be a producer if the person’s only share in the proceeds of a sale of cattle or beef is a sales commission, handling fee, or other service fee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8b19-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2902/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “promotion” means any action, including paid advertising, to advance the image and desirability of beef and beef products with the express intent of improving the competitive position and stimulating sales of beef and beef products in the marketplace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8b1a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2902/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “qualified State beef council” means a beef promotion entity that is authorized by State statute or is organized and operating within a State, that receives voluntary contributions and conducts beef promotion, research, and consumer information programs, and that is recognized by the Board as the beef promotion entity within such State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8b1b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2902/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “research” means studies testing the effectiveness of market development and promotion efforts, studies relating to the nutritional value of beef and beef products, other related food science research, and new product development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8b1c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2902/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8b1d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2902/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" term “State” means each of the 50 States; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8b1e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2902/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “United States” means the several States and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8d8b1f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/294/s3"},"text":"Pub. L. 94–294, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-28"},"text":"May 28, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/530"},"text":"90 Stat. 530","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1601/b"},"text":"Pub. L. 99–198, title XVI, § 1601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1598"},"text":"99 Stat. 1598","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8d8b20-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef8d8b21-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef8d8b22-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":" amended section generally."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef8d8b23-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef8d8b24-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1986-01-01"},"text":"Jan. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1601/c"},"text":"section 1601(c) of Pub. L. 99–198","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2901"},"text":"section 2901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
