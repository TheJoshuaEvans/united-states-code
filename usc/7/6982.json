{"tag":"section","attrib":{"id":"ideff8ceee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6982"},"text":null,"children":[{"tag":"num","attrib":{"value":"6982"},"text":"§ 6982.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for implementation of alterations in the level of additives allowed in animal diets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff8ceef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6982/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Food and Drug Administration shall not implement or enforce the final rule described in subsection (b) to alter the level of selenium allowed to be used as a supplement in animal diets unless the Commissioner of the Food and Drug Administration makes a determination that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff8cef0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6982/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selenium additives are not essential, at levels authorized in the absence of such final rule, to maintain animal nutrition and protect animal health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cef1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6982/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selenium at such levels is not safe to the animals consuming the additive;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cef2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6982/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selenium at such levels is not safe to individuals consuming edible portions of animals that receive the additive;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cef3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6982/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selenium at such levels does not achieve its intended effect of promoting normal growth and reproduction of livestock and poultry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cef4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6982/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manufacture and use of selenium at such levels cannot reasonably be controlled by adherence to current good manufacturing practice requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff8cef5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6982/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final rule described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The final rule referred to in subsection (a) is the final rule issued by the Food and Drug Administration and published in the Federal Register on ","children":[{"tag":"date","attrib":{"date":"1993-09-13"},"text":"September 13, 1993","children":[],"tail":" (58 Fed. Reg. 47962), in which the Administration stayed 1987 amendments to the selenium food additive regulations, and any modification of such rule issued after "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"October 13, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff8cef6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s262"},"text":"Pub. L. 103–354, title II, § 262","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3227"},"text":"108 Stat. 3227","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
