{"tag":"section","attrib":{"id":"idf02adb62-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7971"},"text":null,"children":[{"tag":"num","attrib":{"value":"7971"},"text":"§ 7971.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Storage facility loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf02adb63-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7971/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law and as soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", the Commodity Credit Corporation shall amend part 1436 of title 7, Code of Federal Regulations, to establish a sugar storage facility loan program to provide financing for processors of domestically-produced sugarcane and sugar beets to construct or upgrade storage and handling facilities for raw sugars and refined sugars."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adb64-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7971/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible processors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A storage facility loan described in subsection (a) shall be made available to any processor of domestically produced sugarcane or sugar beets that (as determined by the Secretary)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adb65-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7971/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a satisfactory credit history;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adb66-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7971/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a need for increased storage capacity, taking into account the effects of marketing allotments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adb67-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7971/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates an ability to repay the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adb68-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7971/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of loans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A storage facility loan described in subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adb69-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7971/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a minimum term of 7 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adb6a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7971/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not include any penalty for prepayment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adb6b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7971/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in such amounts and on such other terms and conditions (including terms and conditions relating to downpayments, collateral, and eligible facilities) as are normal, customary, and appropriate for the size and commercial nature of the borrower.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf02adb6c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1402"},"text":"Pub. L. 107–171, title I, § 1402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/187"},"text":"116 Stat. 187","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1404"},"text":"Pub. L. 110–234, title I, § 1404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/989"},"text":"122 Stat. 989","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1404, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1718.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf02adb6d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf02adb6e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":