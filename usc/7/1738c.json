{"tag":"section","attrib":{"id":"ideef9ae52-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1738c"},"text":"§ 1738c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of certain debt","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideef9ae53-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to reduce debt","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef9ae54-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the President may reduce the amount owed to the United States or any agency of the United States, and outstanding as of ","children":[{"tag":"date","attrib":{"date":"1990-01-01"},"text":"January 1, 1990","children":[],"tail":", as a result of any credits extended under subchapter II to a country eligible for benefits from the Facility."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9ae55-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authorities under this section may be exercised only to the extent provided for in advance in appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9ae56-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A debt reduction authorized under subsection (a) shall be accomplished, at the direction of the Facility, through the exchange of a new obligation under this subchapter for obligations of the type referred to in subsection (a) outstanding as of ","children":[{"tag":"date","attrib":{"date":"1990-01-01"},"text":"January 1, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9ae57-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange of obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Facility shall notify the Commodity Credit Corporation of an agreement entered into under subsection (b) with an eligible country to exchange a new obligation for outstanding obligations. At the direction of the Facility, the old obligations that are the subject of the agreement may be canceled and a new debt obligation may be established for the country relating to the agreement. The Commodity Credit Corporation shall make an adjustment in its accounts to reflect a debt reduction under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideef9ae58-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title VI, § 604, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3658"},"text":"104 Stat. 3658","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIII/s303"},"text":"Pub. L. 102–237, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1855"},"text":"105 Stat. 1855","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideef9ae59-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideef9ae5a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideef9ae5b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “Availability” for “Avali­ability” in heading."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ideef9ae5c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"ideef9ae5d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under subsec. (a) of this section, see section 1 of Ex. Ord. No. 13345, ","children":[{"tag":"date","attrib":{"date":"2004-07-08"},"text":"July 8, 2004","children":[],"tail":", 69 F.R. 41901, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738"},"text":"section 1738 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
