{"tag":"section","attrib":{"id":"idef7f327e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279–2"},"text":"§ 2279–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report of civil rights complaints, resolutions, and actions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each year, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7f327f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–2/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prepare a report that describes, for each agency of the Department of Agriculture—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7f3280-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–2/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of civil rights complaints filed that relate to the agency, including whether a complaint is a program complaint or an employment complaint;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7f3281-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–2/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the length of time the agency took to process each civil rights complaint;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7f3282-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–2/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of proceedings brought against the agency, including the number of complaints described in paragraph (1) that were resolved with a finding of discrimination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7f3283-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–2/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and type of personnel actions taken by the agency following resolution of civil rights complaints;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f3284-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–2/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a copy of the report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f3285-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–2/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the report available to the public by posting the report on the website of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7f3286-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14010"},"text":"Pub. L. 110–234, title XIV, § 14010","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1447"},"text":"122 Stat. 1447","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14010, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","chil