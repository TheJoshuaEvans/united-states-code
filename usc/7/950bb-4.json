{"tag":"section","attrib":{"id":"idee65d312-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"950bb–4"},"text":"§ 950bb–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outdated broadband systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee65d313-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), the Secretary shall consider any portion of a service territory that is subject to an outstanding grant agreement between the Secretary and a broadband provider to be unserved for the purposes of all broadband assistance programs under this chapter, if the broadband service in that portion of a service territory is less than 10 Mbps downstream transmission capacity or less than 1 Mbps upstream transmission capacity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d314-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not consider a portion of a service territory described in subsection (a) to be unserved if the broadband service provider has constructed or begun to construct broadband facilities that meet the minimum acceptable level of service established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s950bb/e"},"text":"section 950bb(e) of this title","children":[],"tail":", in that portion of the service territory."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee65d315-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title VI, § 605, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6205/a"},"text":"Pub. L. 115–334, title VI, § 6205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4739"},"text":"132 Stat. 4739","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee65d316-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee65d317-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idee65d318-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6205/b"},"text":"Pub. L. 115–334, title VI, § 6205(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4739"},"text":"132 Stat. 4739","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/334/tVI/s6205/b"},"text":"“The amendment made by this section [enacting this section] shall not take effect until ","children":[{"tag":"date","attrib":{"date":"2020-10-01"},"text":"October 1, 2020","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}