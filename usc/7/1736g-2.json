{"tag":"section","attrib":{"id":"ideef28397-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736g–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1736g–2"},"text":"§ 1736g–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Micronutrient fortification programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideef28398-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736g–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef28399-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736g–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2008-09-30"},"text":"September 30, 2008","children":[],"tail":", the Administrator, in consultation with the Secretary, shall establish micronutrient fortification programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef2839a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736g–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of a program shall be to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideef2839b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736g–2/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist developing countries in correcting micronutrient dietary deficiencies among segments of the populations of the countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef2839c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736g–2/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess and apply technologies and systems to improve and ensure the quality, shelf life, bioavailability, and safety of fortified food aid agricultural commodities, and products of those agricultural commodities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef2839d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736g–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fortification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under a program, grains and other commodities made available to a developing country selected to participate in a program may be fortified with 1 or more micronutrients (such as vitamin A, iron, iodine, and folic acid) with respect to which a substantial portion of the population in the country is deficient. The commodity may be fortified in the United States or in the developing country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef2839e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736g–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority to carry out programs established under this section shall terminate on ","children":[{"tag":"date","attrib":{"date":"2023-09-30"},"text":"September 30, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideef2839f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title IV, § 415, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s222"},"text":"Pub. L. 104–127, title II, § 222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/958"},"text":"110 Stat. 958","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIII/s3013"},"text":"Pub. L. 107–171, title III, § 3013","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/284"},"text":"116 Stat. 284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3023"},"text":"Pub. L. 110–246, title III, § 3023","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1830"},"text":"122 Stat. 1830","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIII/s3013"},"text":"Pub. L. 113–79, title III, § 3013","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/777"},"text":"128 Stat. 777","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIII/s3115"},"text":"Pub. L. 115–334, title III, § 3115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4607"},"text":"132 Stat. 4607","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideef283a0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideef283a1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideef283a2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The authorities provided by each provision of, and each amendment made by, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"Sept. 30, 2023","children":[],"tail":", to continue, and authorities to be carried out, until the later of "},{"tag":"date","attrib":{"date":"2024-09-30"},"text":"Sept. 30, 2024","children":[],"tail":", or the date specified in the provision of, or amendment made by, "},{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/a"},"text":"section 102(a) of Pub. L. 118–22","children":[],"tail":", set out in an Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The authorities provided by each provision of, and each amendment made by, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"2012-09-30"},"text":"Sept. 30, 2012","children":[],"tail":", to continue, and the Secretary of Agriculture to carry out the authorities, until the later of "},{"tag":"date","attrib":{"date":"2013-09-30"},"text":"Sept. 30, 2013","children":[],"tail":", or the date specified in the provision of, or amendment made by, "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/240/s701/a"},"text":"section 701(a) of Pub. L. 112–240","children":[],"tail":", set out in a 1-Year Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideef4f3a3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3013/a"},"text":"Pub. L. 113–79, § 3013(a)","children":[],"tail":", struck out “, using recommendations included in the report entitled ‘Micronutrient Compliance Review of Fortified Public Law 480 Commodities’, published in October 2001, with implementation by independent entities with proven experience and expertise in food aid commodity quality enhancements” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3013/b"},"text":"Pub. L. 113–79, § 3013(b)","children":[],"tail":", substituted “2018” for “2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3023/1/A"},"text":"Pub. L. 110–246, § 3023(1)(A)","children":[],"tail":", substituted “2008” for “2003”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3023/1/B"},"text":"Pub. L. 110–246, § 3023(1)(B)","children":[],"tail":", in subpar. (A), inserted “and” at end, added subpar. (B), and struck out former subpars. (B) and (C) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) encourage the development of technologies for the fortification of grains and other commodities that are readily transferable to developing countries; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) assess and apply technologies and systems to improve and ensure the quality, shelf life, bioavailability, and safety of fortified food aid commodities, and products of those commodities, that are provided to developing countries, by using the same mechanism that was used to assess the micronutrient fortification program in the report entitled ‘Micronutrient Compliance Review of Fortified P.L. 480 Commodities’, published October 2001 with funds from the Bureau for Humanitarian Response of the United States Agency for International Development.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3023/2"},"text":"Pub. L. 110–246, § 3023(2)","children":[],"tail":", (3), redesignated subsecs. (c) and (d) as (b) and (c), respectively, in subsec. (c), substituted “2012” for “2007”, and struck out former subsec. (b). Prior to amendment, text read as follows: “From among the countries eligible for assistance under this chapter, the Secretary may select not more than 5 developing countries to participate in a program under this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s3013/1"},"text":"Pub. L. 107–171, § 3013(1)","children":[],"tail":", substituted “programs” for “pilot program” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s3013/2"},"text":"Pub. L. 107–171, § 3013(2)","children":[],"tail":", designated first sentence as par. (1), inserted heading, and substituted “Not later than "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"September 30, 2003","children":[],"tail":", the Administrator, in consultation with the Secretary, shall establish micronutrient fortification programs.” for “Subject to the availability of practical technology and to cost effectiveness, not later than "},{"tag":"date","attrib":{"date":"1997-09-30"},"text":"September 30, 1997","children":[],"tail":", the Secretary, in consultation with the Administrator, shall establish a micronutrient fortification pilot program under this chapter.”, designated second sentence as par. (2), inserted heading, and substituted “The purpose of a program” for “The purpose of the program”, redesignated former pars. (1) and (2) as subpars. (A) and (B) of par. (2), respectively, struck out “and” at end of subpar. (A), struck out “whole” before “grains and other commodities” and substituted “; and” for period at end of subpar. (B), and added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s3013/3"},"text":"Pub. L. 107–171, § 3013(3)","children":[],"tail":", substituted “a program under this section” for “the pilot program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s3013/4"},"text":"Pub. L. 107–171, § 3013(4)","children":[],"tail":", substituted “a program, grains” for “the pilot program, whole grains”, “a program may be fortified” for “the pilot program may be fortified”, and “(such as vitamin A, iron, iodine, and folic acid)” for “(including vitamin A, iron, and iodine)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s3013/5"},"text":"Pub. L. 107–171, § 3013(5)","children":[],"tail":", substituted “programs” for “the pilot program” and “2007” for “2002”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideef4f3a4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideef4f3a5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/b"},"text":"section 4(b) of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
