{"tag":"section","attrib":{"id":"idedeea6b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b"},"text":null,"children":[{"tag":"num","attrib":{"value":"87b"},"text":"§ 87b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idedeea6b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No person shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedeea6b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly falsely make, issue, alter, forge, or counterfeit any official certificate or other official form or official mark;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedeea6b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly utter, publish, or use as true any falsely made, issued, altered, forged, or counterfeited official certificate or other official form or official mark, or knowingly possess, without promptly notifying the Secretary or the representative of the Secretary, or fail to surrender to such a representative upon demand, any falsely made, issued, altered, forged, or counterfeited official certificate or other official form, or any device for making any official mark or simulation thereof, or knowingly possess any grain in a container bearing any falsely made, issued, altered, forged, or counterfeited official mark without promptly giving such notice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedeea6ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly cause or attempt (whether successfully or not) to cause the issuance of a false or incorrect official certificate or other official form by any means, including but not limited to deceptive loading, handling, weighing, or sampling of grain, or submitting grain for official inspection or official weighing or supervision of weighing knowing that it has been deceptively loaded, handled, weighed, or sampled, without disclosing such knowledge to the official inspection personnel before official sampling or official weighing or supervision of weighing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedeea6bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alter any official sample of grain in any manner or, knowing that an official sample has been altered, thereafter represent it as an official sample;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedeea6bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly use any official grade designation or official mark on any container of grain by means of a tag, label, or otherwise, unless the grain in such container was officially inspected on the basis of an official sample taken while the grain was being loaded into or was in such container or officially weighed, respectively, and the grain was found to qualify for such designation or mark;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedeea6bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly make any false representation that any grain has been officially inspected, or officially inspected and found to be of a particular kind, class, quality, or condition, or that particular facts have been established with respect to grain by official inspection under this chapter, or that any weighing service under this chapter has been performed with respect to grain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedeea6be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improperly influence, or attempt to improperly influence, any official inspection personnel or personnel of agencies delegated authority or of agencies or other persons designated under this chapter or any officer or employee of the Department of Agriculture with respect to the performance of the duties of the officer, employee, or other person under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedeea6bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forcibly assault, resist, oppose, impede, intimidate, or interfere with any official inspection personnel or personnel of agencies delegated authority or of agencies or other persons designated under this chapter or any officer or employee of the Department of Agriculture in, or on account of, the performance of the duties of the officer, employee, or other person under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedeea6c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" falsely represent that the person is licensed or authorized to perform an official inspection or official weighing or supervision of weighing function under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedeea6c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use any false or misleading means in connection with the making or filing of an application for official inspection or official weighing or supervision of weighing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedeea6c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violate section 77, 78, 79, 79a, 79b, 84, 87, 87a, 87e, or 87f–1 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedeea6c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly engage in falsely stating or falsifying the weight of any grain shipped in interstate or foreign commerce by any means, including, but not limited to, the use of inaccurate, faulty, or defective weighing equipment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedeea6c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly prevent or impede any buyer or seller of grain or other person having a financial interest in grain, or the authorized agent of any such person, from observing the loading of the grain inspected under this chapter and the weighing, sampling, and inspection of such grain under conditions prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedeea6c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No person licensed or authorized to perform any function under this chapter shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedeea6c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commit any offense prohibited by subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedeea6c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly perform improperly any official sampling or other official inspection or weighing function under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedeea6c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly execute or issue any false or incorrect official certificate or other official form; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedeea6c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept money or other consideration, directly or indirectly, for any neglect or improper performance of duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedeea6ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An offense shall be deemed to have been committed knowingly under this chapter if it resulted from gross negligence or was committed with knowledge of the pertinent facts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedeea6cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedeea6cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraphs (2) and (3), to ensure the quality of grain marketed in or exported from the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedeea6cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no dockage or foreign material, as defined by the Secretary, once removed from grain shall be recombined with any grain; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedeea6ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no dockage or foreign material of any origin may be added to any grain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedeea6cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in paragraph (1) shall be construed to prohibit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedeea6d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the treatment of grain to suppress, destroy, or prevent insects and fungi injurious to stored grain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedeea6d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the marketing, domestically or for export, of dockage or foreign material removed from grain if such dockage or foreign material is marketed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idedeea6d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" separately and uncombined with any such whole grain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedeea6d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in pelletized form; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedeea6d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a part of a processed ration for livestock, poultry, or fish;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedeea6d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the blending of grain with similar grain of a different quality to adjust the quality of the resulting mixture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedeea6d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recombination of broken corn or broken kernels, as defined by the Secretary, with grain of the type from which the broken corn or broken kernels were derived;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedeea6d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" effective for the period ending ","children":[{"tag":"date","attrib":{"date":"1987-12-31"},"text":"December 31, 1987","children":[],"tail":", the recombination of dockage or foreign material, except dust, removed at an export loading facility from grain destined for shipment as a cargo under one export official certificate of inspection if—"}],"tail":null},{"tag":"clause","attrib":{"id":"idedeea6d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/d/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recombination occurs during the loading of the cargo;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedeea6d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/d/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purpose is to ensure uniformity of dockage or foreign material throughout that specific cargo; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedeea6da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/d/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the separation and recombination are conducted in accordance with regulations issued by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedeea6db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the addition to grain of a dust suppressant, or the addition of confetti or any other similar material that serves the same purpose in a quantity necessary to facilitate identification of ownership or origin of a particular lot of grain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedeea6dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedeea6dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may, by regulation, exempt from paragraph (1) the last handling of grain in the final sale and shipment of such grain to a domestic user or processor if such exemption is determined by the Secretary to be in the best economic interest of producers, grain merchants, the industry involved, and the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedeea6de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grain sold under an exemption authorized by this paragraph shall be consumed or processed into one or more products by the purchaser, but may not be resold into commercial channels for such grain or blended with other grain for resale. Neither products nor byproducts derived therefrom (except vegetable oils as defined by the Secretary and used as a dust suppressant) shall be blended with or added to grain in commercial channels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedeea6df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedeea6e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may prohibit the contamination of sound and pure grain, or prohibit disguising the quality of grain, as a result of the introduction of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedeea6e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nongrain substances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedeea6e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grain unfit for ordinary commercial purposes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedeea6e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grain that exceeds action limits established by the Food and Drug Administration or grain having residues that exceed the tolerance levels established by the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedeea6e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No prohibition imposed under this section shall be construed to restrict the marketing of any grain so long as the grade or condition of the grain is properly identified.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedeea6e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prior to taking action under this subsection, the Secretary shall promulgate regulations after providing for notice and an opportunity for public comment, that identify and define actions and conditions that are subject to prohibition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedeea6e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In no case shall the Secretary prohibit the blending of an entire grade of grain.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedeea6e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87b/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In implementing paragraph (1)(C), the Secretary shall report any prohibitions to other appropriate public health agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idedeea6e8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. B, § 13, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/487/s1"},"text":"Pub. L. 90–487, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-15"},"text":"Aug. 15, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/766"},"text":"82 Stat. 766","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/582/s15"},"text":"Pub. L. 94–582, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2883"},"text":"90 Stat. 2883","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXVI"},"text":"Pub. L. 95–113, title XVI","children":[],"tail":", §§ 1604(j), 1606(h), "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1029"},"text":"91 Stat. 1029","children":[],"tail":", 1030; "},{"tag":"ref","attrib":{"href":"/us/pl/99/641/tIII/s303/a"},"text":"Pub. L. 99–641, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3564"},"text":"100 Stat. 3564","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXX/s2008"},"text":"Pub. L. 101–624, title XX, § 2008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3931"},"text":"104 Stat. 3931","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/156"},"text":"Pub. L. 103–156","children":[],"tail":", §§ 7, 12("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1993-11-24"},"text":"Nov. 24, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1526"},"text":"107 Stat. 1526","children":[],"tail":", 1529; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s293/a/7"},"text":"Pub. L. 103–354, title II, § 293(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3237"},"text":"108 Stat. 3237","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/472/tI/s107"},"text":"Pub. L. 106–472, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2060"},"text":"114 Stat. 2060","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idedeea6e9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idedeea6ea-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idedeea6eb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/472"},"text":"Pub. L. 106–472","children":[],"tail":" inserted “, or prohibit disguising the quality of grain,” after “sound and pure grain” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsecs. (a)(2), (13), (d)(2)(D), (E)(iii), (e)(1), (3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/156/s12"},"text":"Pub. L. 103–156, § 12","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), which directed amendment of “Section 13”, without specifying the name of the Act being amended, was executed to this section, which is section 13 of the United States Grain Standards Act, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/156/s12"},"text":"Pub. L. 103–156, § 12","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1), substituted “the representative of the Administrator” for “his representative”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/156/s12"},"text":"Pub. L. 103–156, § 12","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2), substituted “the duties of the officer, employee, or other person” for “his duties”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/156/s12"},"text":"Pub. L. 103–156, § 12","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3), substituted “the person” for “he”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/156/s7"},"text":"Pub. L. 103–156, § 7","children":[],"tail":", amended par. (11) generally. Prior to amendment, par. (11) read as follows: “violate any provision of section 77; 78; 79(f)(2), (3), or (4); 79a; 79b(c); 84; 87; 87a; or 87f–1 of this title;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/641"},"text":"Pub. L. 99–641","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113"},"text":"Pub. L. 95–113","children":[],"tail":", §§ 1604(j)(1), 1606(h), substituted “or condition” for “condition, or quantity” and inserted “, or that any weighing service under this chapter has been performed with respect to grain” after “official inspection under this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/s1604/j/2"},"text":"Pub. L. 95–113, § 1604(j)(2)","children":[],"tail":", inserted references to sections 79(f)(3) and (4) and 87f–1 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/s1604/j/3"},"text":"Pub. L. 95–113, § 1604(j)(3)","children":[],"tail":", substituted “weighing equipment” for “testing equipment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/s1604/j/4"},"text":"Pub. L. 95–113, § 1604(j)(4)","children":[],"tail":", substituted “financial interest in grain” for “financial interest in the grain” and “loading of the grain” for “loading of grain”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/582/s15/a/1"},"text":"Pub. L. 94–582, § 15(a)(1)","children":[],"tail":", substituted “official mark” for “official inspection mark”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/582/s15/a/2"},"text":"Pub. L. 94–582, § 15(a)(2)","children":[],"tail":", substituted “official mark” for “official inspection mark” in three places, “official certificate” for “official inspection certificate” and “Administrator” for “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/582/s15/a/2"},"text":"Pub. L. 94–582, § 15(a)(2)","children":[],"tail":", prohibited deceptive weighing of grain or submitting grain for official weighing or supervision of weighing knowing it has been deceptively weighed without disclosure before official weighing or supervision of weighing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/582/s15/a/3"},"text":"Pub. L. 94–582, § 15(a)(3)","children":[],"tail":", substituted “official mark” for “official inspection mark” and inserted “or officially weighed, respectively,” after “such container”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a)(7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/582/s15/a/4"},"text":"Pub. L. 94–582, § 15(a)(4)","children":[],"tail":", inserted “or personnel of agencies delegated authority or of agencies or other persons designated under this chapter” after “personnel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9). ","childr