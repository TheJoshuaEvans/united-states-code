{"tag":"section","attrib":{"id":"idef7806bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2231"},"text":null,"children":[{"tag":"num","attrib":{"value":"2231"},"text":"§ 2231.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Official expenses of employees stationed abroad","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Employees of the Department of Agriculture stationed abroad may, with the approval of the Secretary of Agriculture, enter into leases for official quarters, for periods not exceeding one year, and may pay rent, telephone, subscriptions to publications, and other charges incident to the conduct of their offices and the discharge of their duties, in advance, in any foreign country where custom or practice requires payment in advance.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef7806be-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-09-21/ch412"},"text":"Sept. 21, 1944, ch. 412","children":[],"tail":", title VII, § 705(c), "},{"tag":"ref","attrib":{"href":"/us/stat/58/742"},"text":"58 Stat. 742","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7806bf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef7806c0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef7806c1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section was enacted as part of the Department of Agriculture Organic Act of 1944.","children":[],"tail":"\n"},{"tag