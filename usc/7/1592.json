{"tag":"section","attrib":{"id":"ideed13f9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1592"},"text":null,"children":[{"tag":"num","attrib":{"value":"1592"},"text":"§ 1592.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideed13f9c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1592/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture shall make such rules and regulations as he may deem necessary for the effective enforcement of this chapter, except as otherwise provided in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideed13f9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1592/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury and the Secretary of Agriculture shall make, jointly or severally, such rules and regulations as they may deem necessary for the effective enforcement of subchapter III of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideed13f9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1592/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prior to the promulgation of any rule or regulation under this chapter, due notice shall be given by publication in the Federal Register of intention to promulgate and the time and place of a public hearing to be held with reference thereto, and no rule or regulation may be promulgated until after such hearing. Any rule or regulation shall become effective on the date fixed in the promulgation, which date shall be not less than thirty days after publication in the Federal Register and may be amended or revoked in the manner provided for its promulgation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideed13f9f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-09/ch615"},"text":"Aug. 9, 1939, ch. 615","children":[],"tail":", title IV, § 402, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1285"},"text":"53 Stat. 1285","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideed13fa0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideed13fa1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideed13fa2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1610"},"text":"section 1610 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
