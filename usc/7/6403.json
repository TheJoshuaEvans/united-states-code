{"tag":"section","attrib":{"id":"idefe372e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6403"},"text":null,"children":[{"tag":"num","attrib":{"value":"6403"},"text":"§ 6403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to issue orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe372e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To effectuate the declared policy under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6401/b"},"text":"section 6401(b) of this title","children":[],"tail":", the Secretary shall issue and from time to time may amend, orders applicable to all fluid milk processors, authorizing—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe372ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6403/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collection of assessments on fluid milk products subject to this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe372eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6403/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of the assessments to provide research and advertising in a manner prescribed by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe372ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any order issued under this chapter shall be national in scope.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe372ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6403/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" One order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than one order shall be in effect under this chapter at any one time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe372ee-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1999D"},"text":"Pub. L. 101–624, title XIX, § 1999D","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3916"},"text":"104 Stat. 3916","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
