{"tag":"section","attrib":{"id":"ideff8cf63-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7000"},"text":null,"children":[{"tag":"num","attrib":{"value":"7000"},"text":"§ 7000.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of final determinations of Division","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff8cf64-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7000/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the return of a case to an agency pursuant to the final determination of the Division, the head of the agency shall implement the final determination not later than 30 days after the effective date of the notice of the final determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff8cf65-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7000/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff8cf66-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7000/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of the enactment of this subsection, and every 180 days thereafter, the head of each agency shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate, and publish on the website of the Department, a report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff8cf67-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7000/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of all cases returned to the agency during the period covered by the report pursuant to a final determination of the Division;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff8cf68-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7000/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of implementation of each final determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff8cf69-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7000/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the final determination has not been implemented—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff8cf6a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7000/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reason that the final determination has not been implemented; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff8cf6b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7000/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projected date of implementation of the final determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cf6c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7000/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each month, the head of each agency shall publish on the website of the Department any updates to the reports submitted under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff8cf6d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s280"},"text":"Pub. L. 103–354, title II, § 280","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3233"},"text":"108 Stat. 3233","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14009"},"text":"Pub. L. 110–234, title XIV, § 14009","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1446"},"text":"122 Stat. 1446","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14009, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2208.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideff8cf6e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideff8cf6f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topi