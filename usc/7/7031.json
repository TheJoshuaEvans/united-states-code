peau","attrib":{},"text":" provide a method by which agricultural producers may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff8cfeb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7031/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" download from the Internet the forms of the agencies specified in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff8cfec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7031/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit completed forms via electronic facsimile, mail, or similar means;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cfed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7031/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" redesign the forms by incorporating into the forms user-friendly formats and self-help guidance materials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cfee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7031/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that the agencies specified in subsection (b)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff8cfef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7031/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use computer hardware and software that is compatible among the agencies and will operate in a common computing environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff8cff0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7031/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop common Internet user-interface locations and applications to consolidate the agencies’ news, information, and program materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff8cff1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7031/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Progress reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", the Secretary shall submit to Congress a report that describes the progress made toward implementing the Internet-based system required under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideffb3ff2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/222/s2"},"text":"Pub. L. 106–222, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/353"},"text":"114 Stat. 353","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
