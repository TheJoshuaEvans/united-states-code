{"tag":"section","attrib":{"id":"ideff8cfe2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7031"},"text":null,"children":[{"tag":"num","attrib":{"value":"7031"},"text":"§ 7031.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic filing and retrieval","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff8cfe3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7031/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", in accordance with subsection (c), the Secretary of Agriculture (referred to in this subchapter as the “Secretary”) shall, to the maximum extent practicable, establish an Internet-based system that enables agricultural producers to access all forms of the agencies of the Department of Agriculture (referred to in this subchapter as the “Department”) specified in subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff8cfe4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7031/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The agencies referred to in subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff8cfe5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7031/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Farm Service Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","at