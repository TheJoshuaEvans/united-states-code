{"tag":"section","attrib":{"id":"ideefc1f99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1765f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1765f"},"text":"§ 1765f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of agency services, personnel, and facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon the request of the Secretary of Agriculture, each Federal agency may make its services, personnel, and facilities available to a United States Agricultural Trade Office in the performance of its functions. The Secretary of Agriculture may reimburse or advance funds to any such agency for services, personnel, and facilities so made available.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideefc1f9a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-28/ch1041"},"text":"Aug. 28, 1954, ch. 1041","children":[],"tail":", title VI, § 605F, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/501/tIV/s401/1"},"text":"Pub. L. 95–501, title IV, § 401(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-21"},"text":"Oct. 21, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1690"},"text":"92 Stat. 1690","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
