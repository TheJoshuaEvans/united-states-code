{"tag":"section","attrib":{"id":"idf021663b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802"},"text":null,"children":[{"tag":"num","attrib":{"value":"7802"},"text":"§ 7802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf021663c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “Avocado Board” and “Board” mean the Hass Avocado Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7804"},"text":"section 7804 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf021663d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “conflict of interest” means a situation in which a member or employee of the Board has a direct or indirect financial interest in a person that performs a service for, or enters into a contract with, the Board for anything of economic value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf021663e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “consumer information” means any action or program that provides information to consumers and other persons on the use, nutritional attributes, and other information that will assist consumers and other persons in making evaluations and decisions regarding the purchase, preparation, and use of Hass avocados.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf021663f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Customs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Customs” means the United States Customs Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0216640-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department” means the United States Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0216641-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hass avocado","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0216642-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Hass avocado” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0216643-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fruit of any Hass variety avocado tree; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0216644-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other type of avocado fruit that the Board, with the approval of the Secretary, determines is so similar to the Hass variety avocado as to be indistinguishable to consumers in fresh form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0216645-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of fruit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (C), the term includes avocado fruit described in subparagraph (A) whether in fresh, frozen, or any other processed form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0216646-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which a handler further processes avocados described in subparagraph (A), or products of such avocados, for sale to a retailer, the Board, with the approval of the Secretary, may determine that such further processed products do not constitute a substantial value of the product and that, based on its determination, the product shall not be treated as a product of Hass avocados subject to assessment under the order. In addition, the Board, with the approval of the Secretary, may exempt certain frozen avocado products from assessment under the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0216647-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Handler","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0216648-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First handler","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “first handler” means a person operating in the Hass avocados marketing system that sells domestic or imported Hass avocados for United States domestic consumption, and who is responsible for remitting assessments to the Board. The term includes an importer or producer who sells directly to consumers Hass avocados that the importer or producer has imported into the United States or produced, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0216649-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exempt handler","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “exempt handler” means a person who would otherwise be considered a first handler, except that all avocados purchased by the person have already been subject to the assessment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7804/h"},"text":"section 7804(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf021664a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “importer” means any person who imports Hass avocados into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf021664b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industry information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “industry information” means information and programs that are designed to increase efficiency in processing, enhance the development of new markets and marketing strategies, increase marketing efficiency, and activities to enhance the image of Hass avocados and the Hass avocado industry domestically.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf021664c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “order” means the Hass avocado promotion, research, and information order issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf021664d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means any individual, group of individuals, firm, partnership, corporation, joint stock company, association, cooperative, or other legal entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf021664e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “producer” means any person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf021664f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is engaged in the domestic production of Hass avocados for commercial use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0216650-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owns, or shares the ownership and risk of loss, of such Hass avocados.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0216651-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “promotion” means any action to advance the image, desirability, or marketability of Hass avocados, including paid advertising, sales promotion, and publicity, in order to improve the competitive position and stimulate sales of Hass avocados in the domestic marketplace.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0216652-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “research” means any type of test, study, or analysis relating to market research, market development, and marketing efforts, or relating to the use, quality, or nutritional value of Hass avocados, other related food science research, or research designed to advance the image, desirability, and marketability of Hass avocados.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0216653-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0216654-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, the United States Virgin Islands, Guam, American Samoa, the Republic of the Marshall Islands, and the Federated States of Micronesia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0216655-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7802/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” means the United States collectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0216656-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387/s1/a/tXII/s1203"},"text":"Pub. L. 106–387, § 1(a) [title XII, § 1203]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1549"},"text":"114 Stat. 1549","children":[],"tail":", 1549A–79.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0216657-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf0216658-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idf0216659-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the United States Customs Service of the Department of the Treasury, including functions of the Secretary of the Treasury relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see sections 203(1), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":". For establishment of U.S. Customs and Border Protection in the Department of Homeland Security, treated as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/114/125"},"text":"Pub. L. 114–125","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/s802/b"},"text":"section 802(b) of Pub. L. 114–125","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
