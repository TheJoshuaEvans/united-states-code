{"tag":"section","attrib":{"id":"idee2324b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s246"},"text":null,"children":[{"tag":"num","attrib":{"value":"246"},"text":"§ 246.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of records","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To facilitate the administration of this chapter, the following persons shall maintain such records and make such reports, as the Secretary may by regulation require:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee2324b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s246/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A warehouse operator that is licensed under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee2324b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s246/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person operating a system for the electronic recording and transfer of receipts and other documents that are authorized under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee2324b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s246/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other person engaged in the issuance of electronic receipts or the transfer of documents under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee2324b6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, § 7, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/472/tII/s201"},"text":"Pub. L. 106–472, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2065"},"text":"114 Stat. 2065","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee2324b7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee2324b8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee2324b9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 246, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, § 25, "},{"tag":"ref","attrib":{"href":"/us/stat/39/490"},"text":"39 Stat. 490","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1931-03-02/ch366/s8"},"text":"Mar. 2, 1931, ch. 366, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/1465"},"text":"46 Stat. 1465","children":[],"tail":", related to suspension and revocation of license, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/472"},"text":"Pub. L. 106–472","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s252"},"text":"section 252 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 7 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"act Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, was classified to "},{"tag":"ref","attrib":{"href":"/us/us