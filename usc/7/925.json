{"tag":"section","attrib":{"id":"idee5c5cf9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s925"},"text":null,"children":[{"tag":"num","attrib":{"value":"925"},"text":"§ 925.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan feasibility","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary may not, as a condition of making a telephone loan to an applicant therefor, require the applicant to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee5c5cfa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s925/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the rates charged to the applicant’s customers or subscribers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5c5cfb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s925/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" increase the applicant’s ratio of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee5c5cfc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s925/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" net income or margins before interest; to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee5c5cfd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s925/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interest requirements on all of the applicant’s outstanding and proposed loans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee5c5cfe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title II, § 204, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2355"},"text":"Pub. L. 101–624, title XXIII, § 2355","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4039"},"text":"104 Stat. 4039","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s235/a/13"},"text":"Pub. L. 103–354, title II, § 235(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3221"},"text":"108 Stat. 3221","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6602/b/2"},"text":"Pub. L. 115–334, title VI, § 6602(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4776"},"text":"132 Stat. 4776","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee5c5cff-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee5c5d00-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee5c5d01-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" struck out “and the Governor of the telephone bank” after “The Secretary” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" substituted “Secretary” for “Administrator”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
