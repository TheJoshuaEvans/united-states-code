{"tag":"section","attrib":{"id":"ideee1e0b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1639a"},"text":"§ 1639a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideee1e0b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subchapter shall apply to any claim in a disclosure that a food bears that indicates that the food is a bioengineered food.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee1e0b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The definition of the term “bioengineering” under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1639"},"text":"section 1639 of this title","children":[],"tail":" shall not affect any other definition, program, rule, or regulation of the Federal Government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee1e0b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to foods","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subchapter shall apply only to a food subject to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee1e0b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the labeling requirements under the Federal Food, Drug, and Cosmetic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e0b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the labeling requirements under the Federal Meat Inspection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s601"},"text":"21 U.S.C. 601","children":[],"tail":" et seq.), the Poultry Products Inspection Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s451"},"text":"21 U.S.C. 451","children":[],"tail":" et seq.), or the Egg Products Inspection Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1031"},"text":"21 U.S.C. 1031","children":[],"tail":" et seq.) only if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee1e0b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most predominant ingredient of the food would independently be subject to the labeling requirements under the Federal Food, Drug, and Cosmetic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e0b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideee1e0b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639a/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most predominant ingredient of the food is broth, stock, water, or a similar solution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideee1e0b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639a/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the second-most predominant ingredient of the food would independently be subject to the labeling requirements under the Federal Food, Drug, and Cosmetic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideee1e0ba-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 292, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/216/s1"},"text":"Pub. L. 114–216, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-29"},"text":"July 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/834"},"text":"130 Stat. 834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideee1e0bb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideee1e0bc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText