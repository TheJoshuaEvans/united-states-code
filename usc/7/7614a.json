{"tag":"section","attrib":{"id":"idf0157f28-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614a"},"text":null,"children":[{"tag":"num","attrib":{"value":"7614a"},"text":"§ 7614a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Roadmap","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0157f29-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date of enactment of this Act, the Secretary, acting through the Under Secretary of Research, Education, and Economics (referred to in this section as the “Under Secretary”), shall commence preparation of a roadmap for agricultural research, education, and extension that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0157f2a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies current trends and constraints;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157f2b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies major opportunities and gaps that no single entity within the Department of Agriculture would be able to address individually;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157f2c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" involves—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0157f2d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interested parties from the Federal Government and nongovernmental entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157f2e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Agricultural Research, Extension, Education, and Economics Advisory Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3123"},"text":"section 3123 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157f2f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporates roadmaps for agricultural research, education, and extension made publicly available by other Federal entities, agencies, or offices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157f30-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describes recommended funding levels for areas of agricultural research, education, and extension, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0157f31-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614a/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" competitive programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157f32-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614a/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" capacity and infrastructure programs, with attention to the future growth needs of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0157f33-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614a/a/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small 1862 Institutions, 1890 Institutions, and 1994 Institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0157f34-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614a/a/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hispanic-serving agricultural colleges and universities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0157f35-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614a/a/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" NLGCA Institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0157f36-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614a/a/5/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" colleges of veterinary medicine; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157f37-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614a/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intramural programs at agencies within the research, education, and economics mission area; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157f38-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes how organizational changes enacted by this Act have impacted agricultural research, extension, and education across the Department of Agriculture, including minimization of unnecessary programmatic and administrative duplication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157f39-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviewability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The roadmap described in this section shall not be subject to review by any officer or employee of the Federal Government other than the Secretary (or a designee of the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157f3a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Roadmap implementation and report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date on which the Secretary commences preparation of the roadmap under this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0157f3b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement and use the roadmap to set the research, education, and extension agenda of the Department of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157f3c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the roadmap available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0157f3d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7504"},"text":"Pub. L. 110–234, title VII, § 7504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1257"},"text":"122 Stat. 1257","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7504, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2019.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0157f3e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0157f3f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf0157f40-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attr