{"tag":"section","attrib":{"id":"idefea9e8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711"},"text":null,"children":[{"tag":"num","attrib":{"value":"6711"},"text":"§ 6711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carbon cycle research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefea9e8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent funds are made available for this purpose, the Secretary shall provide a grant to the Consortium for Agricultural Soils Mitigation of Greenhouse Gases, acting through Kansas State University, to develop, analyze, and implement, through the land grant universities described in subsection (b), carbon cycle research at the national, regional, and local levels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefea9e8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land grant universities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The land grant universities referred to in subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefea9e8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Colorado State University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Iowa State University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Kansas State University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Michigan State University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Montana State University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Purdue University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ohio State University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e94-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Texas A&M University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e95-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" University of Nebraska.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefea9e96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Land grant universities described in subsection (b) shall use funds made available under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefea9e97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct research to improve the scientific basis of using land management practices to increase soil carbon sequestration, including research on the use of new technologies to increase carbon cycle effectiveness, such as biotechnology and nanotechnology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to enter into partnerships to identify, develop, and evaluate agricultural best practices, including partnerships between—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefea9e99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, State, or private entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefea9e9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop necessary computer models to predict and assess the carbon cycle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e9c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to estimate and develop mechanisms to measure carbon levels made available as a result of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefea9e9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" voluntary Federal conservation programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefea9e9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private and Federal forests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefea9e9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other land uses;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9ea0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop outreach programs, in coordination with Extension Services, to share information on carbon cycle and agricultural best practices that is useful to agricultural producers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9ea1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to collaborate with the Great Plains Regional Earth Science Application Center to develop a space-based carbon cycle remote sensing technology program to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefea9ea2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, on a near-continual basis, a real-time and comprehensive view of vegetation conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefea9ea3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess and model agricultural carbon sequestration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefea9ea4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop commercial products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefea9ea5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefea9ea6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, the Secretary, in cooperation with departments and agencies participating in the U.S. Global Change Research Program (which may use any of their statutory authorities) and with eligible entities, may carry out research to promote understanding of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefea9ea7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the flux of carbon in soils and plants (including trees); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefea9ea8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the exchange of other greenhouse gases from agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9ea9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Research under this subsection may be carried out through the competitive awarding of grants and cooperative agreements to colleges and universities (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3103"},"text":"section 3103 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9eaa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative research purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Research conducted under this subsection shall encourage collaboration among scientists with expertise in the areas of soil science, agronomy, agricultural economics, forestry, and other agricultural sciences to focus on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefea9eab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing data addressing carbon losses and gains in soils and plants (including trees) and the exchange of methane and nitrous oxide from agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefea9eac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" understanding how agricultural and forestry practices affect the sequestration of carbon in soils and plants (including trees) and the exchange of other greenhouse gases, including the effects of new technologies such as biotechnology and nanotechnology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefea9ead-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing cost-effective means of measuring and monitoring changes in carbon pools in soils and plants (including trees), including computer models;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefea9eae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating the linkage between federal conservation programs and carbon sequestration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefea9eaf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing methods, including remote sensing, to measure the exchange of carbon and other greenhouse gases sequestered, and to evaluate leakage, performance, and permanence issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefea9eb0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/d/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the applicability of the results of research conducted under this subsection for developing methods to account for the impact of agricultural activities (including forestry) on the exchange of greenhouse gases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9eb1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this subsection for each of fiscal years 2002 through 2007.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefea9eb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefea9eb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in cooperation with departments and agencies participating in the U.S. Global Change Research Program (which may use any of their statutory authorities), and local extension agents, experts from institutions of higher education that offer a curriculum in agricultural and biological sciences, and other local agricultural or conservation organizations, may implement extension projects (including on-farm projects with direct involvement of agricultural producers) that combine measurement tools and modeling techniques into integrated packages to monitor the carbon sequestering benefits of conservation practices and the exchange of greenhouse gas emissions from agriculture which demonstrate the feasibility of methods of measuring and monitoring—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefea9eb4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes in carbon content and other carbon pools in soils and plants (including trees); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefea9eb5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the exchange of other greenhouse gases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9eb6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension project results","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may disseminate to farmers, ranchers, private forest landowners, and appropriate State agencies in each State information concerning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefea9eb7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of projects under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefea9eb8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which the methods used in the projects might be applicable to the operations of the farmers, ranchers, private forest landowners, and State agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9eb9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this subsection for each of fiscal years 2002 through 2007.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefea9eba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 3 percent of the funds made available for this section may be used by the Secretary to pay administrative costs incurred in carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefea9ebb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6711/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $15,000,000 for each of fiscal years 2007 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefea9ebc-3a6e-11f1-addd-b