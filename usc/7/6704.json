"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for the international forestry activities of the Forest Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e63-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6704/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the activities of the Forest Service in implementing the provisions of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e64-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6704/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as Forest Service liaison to the director for the program established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6701"},"text":"section 6701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefea9e65-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for each of fiscal years 1996 through 2018 such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefea9e66-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIV/s2405"},"text":"Pub. L. 101–624, title XXIV, § 2405","children":[],"tail":", "},{"tag":"date","attrib"