{"tag":"section","attrib":{"id":"idefcdef22-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5813"},"text":null,"children":[{"tag":"num","attrib":{"value":"5813"},"text":"§ 5813.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal-State matching grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefcdef23-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5813/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a Federal-State matching grant program to make grants to States to assist in the creation or enhancement of State sustainable agriculture research, extension, and education programs, in furtherance of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdef24-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5813/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible programs and activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"States eligible to receive a grant under this section may conduct a variety of activities designed to carry out the purpose of this subchapter, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcdef25-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5813/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities that encourage the incorporation and integration of sustainable agriculture concerns in all State research, extension, and education projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef26-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5813/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational programs for farmers, educators, and the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef27-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5813/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and funding of innovative research, extension, and education programs regarding sustainable agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef28-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5813/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of research and demonstration projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef29-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5813/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of technical assistance to farmers and ranchers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef2a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5813/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities that encourage farmer-to-farmer information exchanges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef2b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5813/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the incorporation of sustainable agriculture studies in undergraduate and graduate degree programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef2c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5813/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other activities that are appropriate to the agricultural concerns of the State that are consistent with the purpose of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdef2d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5813/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcdef2e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5813/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"States that elect to apply for a grant under this section shall prepare and submit, to the appropriate Regional Administrative Council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5812"},"text":"section 5812 of this title","children":[],"tail":", a State plan and schedule for approval by such council and the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef2f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5813/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"State plans prepared under paragraph (1) shall provide details of the proposed program to be implemented using funds provided under this section for fiscal years 1991 through 1995, or any 5-year period thereafter, and shall identify the sources of matching State funds for the same fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef30-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5813/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation of farmers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible for approval, State plans submitted under this subsection shall demonstrate that there will be extensive and direct participation of farmers in the development, implementation, and evaluation of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdef31-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5813/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant award","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcdef32-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5813/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary shall provide grants to eligible States in an amount not to exceed 50 percent of the cost of the establishment or enhancement of a State sustainable agriculture program under a plan approved by the Secretary under subsection (c) for a period not to exceed 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef33-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5813/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State contribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, a State shall agree to pay, from State appropriated funds, other State revenue, or from private contributions received by the State, not less than 50 percent of the cost of the establishment or enhancement of the sustainable agriculture program under an approved plan under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefcdef34-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1623"},"text":"Pub. L. 101–624, title XVI, § 1623","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3738"},"text":"104 Stat. 3738","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7128/b/2/A"},"text":"Pub. L. 113–79, title VII, § 7128(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/878"},"text":"128 Stat. 878","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7614/b/2/A"},"text":"Pub. L. 115–334, title VII, § 7614(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4834"},"text":"132 Stat. 4834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefcdef35-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefcdef36-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefcdef37-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" struck out at end “The matching funds requirement under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3371"},"text":"section 3371 of this title","children":[],"tail":" shall not apply to grants awarded under this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" inserted at end “The matching funds requirement under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3371"},"text":"section 3371 of this title","children":[],"tail":" shall not apply to grants awarded under this section.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefcdef38-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idefcdef39-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" applicable to grants, cooperative agreements, or other awards made after "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", with matching funds requirement in effect on "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", to continue to apply to such grant, cooperative agreement, or other award, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7614/c"},"text":"section 7614(c) of Pub. L. 115–334","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3151"},"text":"section 3151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
