{"tag":"section","attrib":{"id":"idee8bf8f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359hh"},"text":null,"children":[{"tag":"num","attrib":{"value":"1359hh"},"text":"§ 1359hh.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations; violations; publication of Secretary’s determinations; jurisdiction of the courts; United States attorneys","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee8bf8f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359hh/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the Commodity Credit Corporation, as appropriate, shall issue such regulations as may be necessary to carry out the authority vested in the Secretary in administering this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee8bf8fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359hh/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person knowingly violating any regulation of the Secretary issued under subsection (a) shall be subject to a civil penalty of not more than $5,000 for each violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee8bf8fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359hh/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication in Federal Register","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each determination issued by the Secretary to establish, adjust, or suspend allotments under this subpart shall be promptly published in the Federal Register and shall be accompanied by a statement of the reasons for the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee8bf8fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359hh/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of courts; United States attorneys","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee8bf8fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359hh/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of courts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The several district courts of the United States are vested with jurisdiction specifically to enforce, and to prevent and restrain any person from violating, this subpart or any regulation issued thereunder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee8bf8fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359hh/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States attorneys","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Secretary shall so request, it shall be the duty of the several United States attorneys, in their respective districts, to institute proceedings to enforce the remedies and to collect the penalties provided for in this subpart. The Secretary may elect not to refer to a United States attorney any violation of this subpart or regulation when the Secretary determines that the administration and enforcement of this subpart would be adequately served by written notice or warning to any person committing the violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee8bf8ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359hh/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonexclusivity of remedies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The remedies and penalties provided for in this subpart shall be in addition to, and not exclusive of, any remedies or penalties existing at law or in equity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee8bf900-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title III, § 359h, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1403"},"text":"Pub. L. 107–171, title I, § 1403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/202"},"text":"116 Stat. 202","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee8bf901-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee8bf902-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee8bf903-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1359hh, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30/tIII/s359h"},"text":"act Feb. 16, 1938, ch. 30, title III, § 359h","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tIX/s902"},"text":"Pub. L. 101–624, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3486"},"text":"104 Stat. 3486","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tI/s111/j"},"text":"Pub. L. 102–237, title I, § 111(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1836"},"text":"105 Stat. 1836","children":[],"tail":", related to regulations, violations, publication of Secretary’s determinations, jurisdiction of courts, and United States attorneys, prior to the general amendment of this subpart by "},{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
