{"tag":"section","attrib":{"id":"idf039338b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8352"},"text":null,"children":[{"tag":"num","attrib":{"value":"8352"},"text":"§ 8352.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of expenditures for the eradication and control of predatory and other wild animals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture is authorized to make such expenditures for equipment, supplies, and materials, including the employment of persons and means in the District of Columbia and elsewhere, and to employ such means as may be necessary to execute the functions imposed upon him by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8351"},"text":"section 8351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf039338c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1931-03-02/ch370/s3"},"text":"Mar. 2, 1931, ch. 370, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/1469"},"text":"46 Stat. 1469","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf039338d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf039338e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf039338f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s426b"},"text":"section 426b of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idf0393390-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idf0393391-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Secretary of Agriculture administered through Bureau of Biological Survey, relating to conservation of wildlife, game, and migratory birds, transferred to Secretary of the Interior by 1939 Reorg. Plan No. II, § 4(f), eff. ","children":[{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees. See also sections 401 to 404 of said plan for provisions relating to transfer of functions, records, property, personnel, and funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
