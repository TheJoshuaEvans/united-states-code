{"tag":"section","attrib":{"id":"idee8011ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1338"},"text":null,"children":[{"tag":"num","attrib":{"value":"1338"},"text":"§ 1338.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of quotas","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Farm marketing quotas for wheat shall not be transferable, but, in accordance with regulations prescribed by the Secretary for such purpose, any farm marketing quota in excess of the supply of wheat for such farm for any marketing year may be allocated to other farms on which the acreage allotment has not been exceeded.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee8011cb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title III, § 338, "},{"tag":"ref","attrib":{"href":"/us/stat/52/55"},"text":"52 Stat. 55","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tIII/s307"},"text":"Pub. L. 99–198, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1382"},"text":"99 Stat. 1382","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee8011cc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee8011cd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee8011ce-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[