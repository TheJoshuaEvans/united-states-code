{"tag":"section","attrib":{"id":"idf04519eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8791"},"text":null,"children":[{"tag":"num","attrib":{"value":"8791"},"text":"§ 8791.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information gathering","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf04519ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8791/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geospatial systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that all the geospatial data of the agencies of the Department of Agriculture are portable and standardized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04519ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8791/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on disclosures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04519ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8791/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of agricultural operation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “agricultural operation” includes the production and marketing of agricultural commodities and livestock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04519ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8791/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraphs (3) and (4), the Secretary, any officer or employee of the Department of Agriculture, or any contractor or cooperator of the Department, shall not disclose—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04519f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8791/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information provided by an agricultural producer or owner of agricultural land concerning the agricultural operation, farming or conservation practices, or the land itself, in order to participate in programs of the Department; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04519f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8791/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geospatial information otherwise maintained by the Secretary about agricultural land or operations for which information described in subparagraph (A) is provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04519f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8791/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized disclosures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04519f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8791/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited release of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines that the information described in paragraph (2) will not be subsequently disclosed except in accordance with paragraph (4), the Secretary may release or disclose the information to a person or Federal, State, local, or tribal agency working in cooperation with the Secretary in any Department program—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf04519f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8791/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when providing technical or financial assistance with respect to the agricultural operation, agricultural land, or farming or conservation practices; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04519f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8791/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when responding to a disease or pest threat to agricultural operations, if the Secretary determines that a threat to agricultural operations exists and the disclosure of information to a person or cooperating government entity is necessary to assist the Secretary in responding to the disease or pest threat as authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04519f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8791/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subsection affects—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04519f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8791/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disclosure of payment information (including payment information and the names and addresses of recipients of payments) under any Department program that is otherwise authorized by law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04519f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8791/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the disclosure of information described in paragraph (2) if the information has been transformed into a statistical or aggregate form without naming any—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf04519f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8791/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individual owner, operator, or producer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04519fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8791/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific data gathering site; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04519fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8791/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disclosure of information described in paragraph (2) pursuant to the consent of the agricultural producer or owner of agricultural land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04519fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8791/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition of other programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The participation of the agricultural producer or owner of agricultural land in, or receipt of any benefit under, any program administered by the Secretary may not be conditioned on the consent of the agricultural producer or owner of agricultural land under paragraph (4)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04519fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8791/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of privilege or protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The disclosure of information under paragraph (2) shall not constitute a waiver of any applicable privilege or protection under Federal law, including trade secret protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf04519fe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1619"},"text":"Pub. L. 110–234, title I, § 1619","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1022"},"text":"122 Stat. 1022","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1619, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1750.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf04519ff-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0451a00-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf0451a01-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf0451a02-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf0451a03-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
