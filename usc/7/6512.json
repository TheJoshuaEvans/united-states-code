{"tag":"section","attrib":{"id":"idefe5bc74-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6512"},"text":null,"children":[{"tag":"num","attrib":{"value":"6512"},"text":"§ 6512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other production and handling practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If a production or handling practice is not prohibited or otherwise restricted under this chapter, such practice shall be permitted unless it is determined that such practice would be inconsistent with the applicable organic certification program.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefe5bc75-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXI/s2113"},"text":"Pub. L. 101–624, title XXI, § 2113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3943"},"text":"104 Stat. 3943","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
