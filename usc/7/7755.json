{"tag":"section","attrib":{"id":"idf01ef484-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7755"},"text":null,"children":[{"tag":"num","attrib":{"value":"7755"},"text":"§ 7755.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection for mail handlers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This chapter shall not apply to any employee of the United States in the performance of the duties of the employee in handling the mail.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf01ef485-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/tIV/s435"},"text":"Pub. L. 106–224, title IV, § 435","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/453"},"text":"114 Stat. 453","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf01ef486-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf01ef487-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf01ef488-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224"},"text":"Pub. L. 106–224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/438"},"text":"114 Stat. 438","children":[],"tail":", known as the Plant Protection Act, which is classified principally to this chapter. For complete classification of title IV to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7701"},"text":"section 7701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
