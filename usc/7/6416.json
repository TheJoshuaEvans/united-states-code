{"tag":"section","attrib":{"id":"idefe373ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6416"},"text":null,"children":[{"tag":"num","attrib":{"value":"6416"},"text":"§ 6416.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent evaluation of programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe373ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6416/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Comptroller General of the United States shall review and evaluate the order to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe373af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6416/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the effectiveness of the promotion program conducted under this chapter on fluid milk sales;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe373b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6416/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine if the assessments for the program have been passed back to milk producers by fluid milk processors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe373b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6416/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations for future funding and assessment levels for the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe373b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6416/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General shall submit a report to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate on the valuations made under this section no later than ","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"January 1, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe373b3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1999Q"},"text":"Pub. L. 101–624, title XIX, § 1999Q","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3926"},"text":"104 Stat. 3926","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
