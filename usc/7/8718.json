{"tag":"section","attrib":{"id":"idf03deee2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8718"},"text":null,"children":[{"tag":"num","attrib":{"value":"8718"},"text":"§ 8718.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for long grain and medium grain rice","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf03deee3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8718/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation method","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsections (b) and (c), for the purposes of determining the amount of the counter-cyclical payments to be paid to the producers on a farm for long grain rice and medium grain rice under section 8714 ","children":[{"tag":"ref","attrib":{"idref":"fn002376"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002376"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, the base acres of rice on the farm shall be apportioned using the 4-year average of the percentages of acreage planted in the applicable State to long grain rice and medium grain rice during the 2003 through 2006 crop years, as determined by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03deee4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8718/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer election","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As an alternative to the calculation method described in subsection (a), the Secretary shall provide producers on a farm the opportunity to elect to apportion rice base acres on the farm using the 4-year average of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03deee5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8718/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentages of acreage planted on the farm to long grain rice and medium grain rice during the 2003 through 2006 crop years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03deee6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8718/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentages of any acreage on the farm that the producers were prevented from planting to long grain rice and medium grain rice during the 2003 through 2006 crop years because of drought, flood, other natural disaster, or other condition beyond the control of the producers, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03deee7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8718/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a crop year for which a producer on a farm elected not to plant to long grain and medium grain rice during the 2003 through 2006 crop years, the percentages of acreage planted in the applicable State to long grain rice and medium grain rice, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03deee8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8718/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall use the same total base acres, payment acres, and payment yields established with respect to rice under sections 7911 and 7912 of this title, as in effect on ","children":[{"tag":"date","attrib":{"date":"2007-09-30"},"text":"September 30, 2007","children":[],"tail":", subject to any adjustment under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8711"},"text":"section 8711 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf03deee9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1108"},"text":"Pub. L. 110–234, title I, § 1108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/952"},"text":"122 Stat. 952","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1108, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1681.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf03deeea-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf03deeeb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf03deeec-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","att