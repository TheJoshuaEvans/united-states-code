{"tag":"section","attrib":{"id":"idef7f3303-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279f"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279f"},"text":"§ 2279f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpoena authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef7f3304-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary concerned shall have power to subpoena the attendance and testimony of any witness, and the production of all documentary evidence relating to the enforcement of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279e"},"text":"section 2279e of this title","children":[],"tail":" or any matter under investigation in connection with this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279e"},"text":"section 2279e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f3305-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location of production","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The attendance of any witness and the production of documentary evidence may be required from any place in the United States at any designated place of hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f3306-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of subpoena","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of disobedience to a subpoena by any person, the Secretary concerned may request the Attorney General to invoke the aid of any court of the United States within the jurisdiction in which the investigation is conducted, or where the person resides, is found, transacts business, is licensed to do business, or is incorporated, in requiring the attendance and testimony of any witness and the production of documentary evidence. In case of a refusal to obey a subpoena issued to any person, a court may order the person to appear before the Secretary concerned and give evidence concerning the matter in question or to produce documentary evidence. Any failure to obey the court’s order may be punished by the court as a contempt of the court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f3307-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Witnesses summoned by the Secretary concerned shall be paid the same fees and mileage that are paid to witnesses in courts of the United States, and witnesses whose depositions are taken, and the persons taking the depositions shall be entitled to the same fees that are paid for similar services in the courts of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f3308-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary concerned shall publish procedures for the issuance of subpoenas under this section. Such procedures shall include a requirement that subpoenas be reviewed for legal sufficiency and signed by the Secretary concerned. If the authority to sign a subpoena is delegated, the agency receiving the delegation shall seek review for legal sufficiency outside that agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f3309-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279f/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of subpoena","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subpoenas for witnesses to attend court in any judicial district or testify or produce evidence at an administrative hearing in any judicial district in any action or proceeding arising under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279e"},"text":"section 2279e of this title","children":[],"tail":" may run to any other judicial district."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7f330a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/tV/s502"},"text":"Pub. L. 106–224, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/455"},"text":"114 Stat. 455","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIV/s421/h/2"},"text":"Pub. L. 107–296, title IV, § 421(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2184"},"text":"116 Stat. 2184","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7f330b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef7f330c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef7f330d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsecs. (a), (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “Secretary concerned” for “Secretary” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef7f330e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef7f330f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s4"},"text":"section 4 of Pub. L. 107–296","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
