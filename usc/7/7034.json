{"tag":"section","attrib":{"id":"ideffb4004-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7034"},"text":null,"children":[{"tag":"num","attrib":{"value":"7034"},"text":"§ 7034.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Crop Insurance Corporation and Risk Management Agency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideffb4005-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7034/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2000-12-01"},"text":"December 1, 2000","children":[],"tail":", the Federal Crop Insurance Corporation and the Risk Management Agency shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a plan, that is consistent with this subchapter, to allow agricultural producers to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffb4006-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7034/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain, over the Internet, from approved insurance providers all forms and other information concerning the program under the jurisdiction of the Corporation and Agency in which the agricultural producer is a participant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb4007-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7034/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file electronically all paperwork required for participation in the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffb4008-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7034/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffb4009-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7034/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conform to sections 7031(c) and 7032(b) of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb400a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7034/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prescribe—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideffb400b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7034/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location and type of data to be made available to agricultural producers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffb400c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7034/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location where agricultural producers can electronically file their paperwork; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffb400d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7034/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the responsibilities of the applicable parties, including agricultural producers, the Risk Management Agency, the Federal Crop Insurance Corporation, approved insurance providers, crop insurance agents, and brokers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffb400e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7034/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2001-12-01"},"text":"December 1, 2001","children":[],"tail":", the Federal Crop Insurance Corporation and the Risk Management Agency shall complete implementation of the plan submitted under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideffb400f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/222/s5"},"text":"Pub. L. 106–222, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/355"},"text":"114 Stat. 355","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
