{"tag":"section","attrib":{"id":"idef865eb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2614"},"text":null,"children":[{"tag":"num","attrib":{"value":"2614"},"text":"§ 2614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When sufficient evidence is presented to the Secretary by interested persons, or whenever the Secretary has reason to believe that a plan will tend to effectuate the declared policy of this chapter, he shall give due notice and opportunity for a hearing upon a proposed plan. Such hearing may be requested by any interested person, including the Secretary, when the request for such hearing is accompanied by a proposal for a plan.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef865eb4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/670/tIII/s305"},"text":"Pub. L. 91–670, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-11"},"text":"Jan. 11, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2042"},"text":"84 Stat. 2042","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1939"},"text":"Pub. L. 101–624, title XIX, § 1939","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3866"},"text":"104 Stat. 3866","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef865eb5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef865eb6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef865eb7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" substituted “interested persons” for “potato producers” in first sentence and “by any interested person, including the Secretary” for “by potato producers or by any other interested person or persons, including the Secretary” in second sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
