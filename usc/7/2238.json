{"tag":"section","attrib":{"id":"idef7806ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2238"},"text":null,"children":[{"tag":"num","attrib":{"value":"2238"},"text":"§ 2238.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of field work funds for purchase of arms and ammunition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds available for field work in the Department of Agriculture may be used for the purchase of arms and ammunition whenever the individual purchase does not exceed $50, and for individual purchases exceeding $50, when such arms and ammunition cannot advantageously be supplied by the Secretary of the Army pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7655"},"text":"section 7655 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef7806ef-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-04/ch489"},"text":"June 4, 1936, ch. 489","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1422"},"text":"49 Stat. 1422","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s809/d"},"text":"Pub. L. 115–232, div. A, title VIII, § 809(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1841"},"text":"132 Stat. 1841","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7806f0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef7806f1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attr