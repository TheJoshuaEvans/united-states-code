{"tag":"section","attrib":{"id":"ideef03867-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1734"},"text":null,"children":[{"tag":"num","attrib":{"value":"1734"},"text":"§ 1734.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideef03868-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1734/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before entering into agreements with foreign countries under subchapters II and III–A for the provision of commodities, the Secretary or the Administrator, as appropriate, shall consider the extent to which the recipient country is undertaking measures for economic development purposes in order to improve food security and agricultural development, alleviate poverty, and promote broad-based, equitable, and sustainable development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef03869-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1734/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agreement entered into under this chapter shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef0386a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1734/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include an estimate of the annual value or volume of agricultural commodities proposed to be made available to the country or eligible organization under the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef0386b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1734/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to agreements entered into with foreign countries under subchapters II and III–A, include a statement of the manner in which the agricultural commodities provided under the agreement or the revenues generated by the sale of such commodities (if such commodities are sold), will be integrated into the overall development plans of the country to improve food security and agricultural development, alleviate poverty, and promote broad-based, equitable, and sustainable agriculture and broad-based economic growth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef0386c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1734/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to agreements entered into under subchapters II and III–A, include a statement of the manner in which competitive private sector participation within the recipient country in the storage, marketing, transportation, and distribution of agricultural commodities made available under this chapter will be encouraged;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef0386d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1734/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a statement that such agreement shall be subject to the availability, during each fiscal year to which the agreement applies, of the necessary appropriations and agricultural commodities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef0386e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1734/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain such other terms and conditions as the Secretary or the Administrator, as appropriate, determines to be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef0386f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1734/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multi-year agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef03870-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1734/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Agreements to provide assistance on a multi-year basis to recipient countries or to eligible organizations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideef03871-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1734/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be made available under subchapters II and III–A; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef03872-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1734/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be made available under subchapter III.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef03873-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1734/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary or the Administrator, as appropriate, may determine not to make assistance available on a multi-year basis with respect to a recipient country or an eligible organization if it is determined that assistance should be provided to such country or through such organization only on an annual basis because—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideef03874-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1734/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the past performance of the country or organization in meeting program objectives does not warrant a multi-year agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef03875-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1734/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is anticipated that the need of the country or organization for food aid does not extend beyond 1 year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef03876-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1734/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other circumstances, as determined by the Secretary or the Administrator, as appropriate, indicate there is only a need for a 1 year agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef03877-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1734/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary or the Administrator, as appropriate, may make a determination to terminate, or refuse to enter into, a multi-year agreement with respect to a recipient country if the Secretary or the Administrator determines that such country is not fulfilling the objectives or requirements of this chapter. In making such a determination, the Secretary or the Administrator, as appropriate, may consider the extent to which the country is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef03878-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1734/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making significant economic development reforms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef03879-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1734/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting free and open markets for food and agricultural producers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef0387a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1734/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fostering increased food security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideef0387b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title IV, § 404, as added "},{"tag":"ref","attrib":{"href":"/us/pl/86/341/tI/s14"},"text":"Pub. L. 86–341, title I, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-21"},"text":"Sept. 21, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/610"},"text":"73 Stat. 610","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/808/s2/E"},"text":"Pub. L. 89–808, § 2(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-11"},"text":"Nov. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1536"},"text":"80 Stat. 1536","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/53/tII/s209"},"text":"Pub. L. 96–53, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/370"},"text":"93 Stat. 370","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3648"},"text":"104 Stat. 3648","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s214"},"text":"Pub. L. 104–127, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/956"},"text":"110 Stat. 956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideef0387c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideef0387d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideef0387e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s214/1"},"text":"Pub. L. 104–127, § 214(1)","children":[],"tail":", inserted “with foreign countries” after “Before entering into agreements”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s214/2"},"text":"Pub. L. 104–127, § 214(2)","children":[],"tail":", inserted “with foreign countries” after “agreements entered into” and “and broad-based economic growth” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s214/3"},"text":"Pub. L. 104–127, § 214(3)","children":[],"tail":", added par. (1) and struck out heading and text of former par. (1). Text read as follows: “Agreements to provide assistance on a multi-year basis under this chapter shall be made available to recipient countries or to eligible organizations.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" amended section generally, substituting present provisions for provisions outlining aims of assistance programs, namely humanitarian and national interest objectives, and requiring assessments of recipient countries to determine types and quantities of commodities needed, conditions under which distribution should take place, most suitable timing for delivery, etc."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/53"},"text":"Pub. L. 96–53","children":[],"tail":" designated existing provisions as subsec. (a), substituted provisions relating to aims of programs of assistance conducted under this chapter and sections 1427 and 1431 of this title and the types and quantities of agricultural commodities to be made available, for provisions relating to aims of assistance programs undertaken pursuant to this chapter and sections 1427 and 1431 of this title, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/808"},"text":"Pub. L. 89–808","children":[],"tail":" substituted provision declaratory of aims of assistance programs as the attainment of humanitarian objectives and the national interest for provisions requiring the Secretary of Agriculture to maximize the sale of commodities and avoid displacement of cash sales, now provided for by sections 1703(n) and 1707(b) of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideef0387f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideef03880-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1991-01-01"},"text":"Jan. 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1513"},"text":"section 1513 of Pub. L. 101–624","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideef03881-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/53"},"text":"Pub. L. 96–53","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/53/s512/a"},"text":"section 512(a) of Pub. L. 96–53","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideef03882-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1966 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/808"},"text":"Pub. L. 89–808","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1967-01-01"},"text":"Jan. 1, 1967","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/89/808/s5"},"text":"section 5 of Pub. L. 89–808","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
