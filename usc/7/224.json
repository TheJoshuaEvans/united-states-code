{"tag":"section","attrib":{"id":"idee1e43a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s224"},"text":null,"children":[{"tag":"num","attrib":{"value":"224"},"text":"§ 224.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney General to institute court proceedings for enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may report any violation of this chapter to the Attorney General of the United States, who shall cause appropriate proceedings to be commenced and prosecuted in the proper courts of the United States without delay.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee1e43a7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-08-15/ch64"},"text":"Aug. 15, 1921, ch. 64","children":[],"tail":", title IV, § 404, "},{"tag":"ref","attrib":{"href":"/us/stat/42/168"},"text":"42 Stat. 168","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1921-08-15/ch64"},"text":"Aug. 15, 1921, ch. 64","children":[],"tail":", title V, § 503, as added "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch532"},"text":"Aug. 14, 1935, ch. 532","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/649"},"text":"49 Stat. 649","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee1e43a8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee1e43a9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee1e43aa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{