{"tag":"section","attrib":{"id":"ideed38905-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1606"},"text":null,"children":[{"tag":"num","attrib":{"value":"1606"},"text":"§ 1606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture is authorized to make such expenditures for rent, outside of the District of Columbia, printing, binding, telegrams, telephones, books of reference, publications, furniture, stationery, office and laboratory equipment, travel, and other supplies, including reporting services, such research necessary to develop methods of processing, bulking, blending, sampling, testing, and merchandising seeds necessary to the administration of this chapter and other necessary expenses in the District of Columbia and elsewhere, and as may be appropriated for by the Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideed38906-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-09/ch615"},"text":"Aug. 9, 1939, ch. 615","children":[],"tail":", title IV, § 416, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1289"},"text":"53 Stat. 1289","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideed38907-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideed38908-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideed38909-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1610"},"text":"section 1610 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
