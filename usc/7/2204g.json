{"tag":"section","attrib":{"id":"idef734c02-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204g"},"text":null,"children":[{"tag":"num","attrib":{"value":"2204g"},"text":"§ 2204g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary of Agriculture to conduct census of agriculture","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef734c03-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Census of agriculture required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef734c04-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In 1998 and every fifth year thereafter, the Secretary of Agriculture shall take a census of agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734c05-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of specialty crops","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective beginning with the census of agriculture required to be conducted in 2008, the Secretary shall conduct as part of each census of agriculture a census of specialty crops (as that term is defined in section 3 of the Specialty Crops Competitiveness Act of 2004 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1621"},"text":"7 U.S.C. 1621","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/108/465"},"text":"Public Law 108–465","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef734c06-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In connection with the census, the Secretary may conduct any survey or other information collection, and employ any sampling or other statistical method, that the Secretary determines is appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef734c07-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Year of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The information collected in each census taken under this section shall relate to the year immediately preceding the year in which the census is taken.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef734c08-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef734c09-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204g/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraud","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person over 18 years of age who willfully gives an answer that is false to a question, which is authorized by the Secretary to be submitted to the person in connection with a census under this section, shall be fined not more than $500.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734c0a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204g/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refusal or neglect to answer questions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person over 18 years of age who refuses or willfully neglects to answer a question, which is authorized by the Secretary to be submitted to the person in connection with a census under this section, shall be fined not more than $100.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734c0b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204g/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Social Security number","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The failure or refusal of a person to disclose the person’s Social Security number in response to a request made in connection with any census or other activity under this section shall not be a violation under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734c0c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204g/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Religious information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section, no person shall be compelled to disclose information relative to the religious beliefs of the person or to membership of the person in a religious body.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef734c0d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204g/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic coverage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A census under this section shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef734c0e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204g/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of the several States of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734c0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204g/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as determined appropriate by the Secretary, the District of Columbia, the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, the United States Virgin Islands, and Guam; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734c10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204g/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the concurrence of the Secretary and the Secretary of State, any other possession or area over which the United States exercises jurisdiction, control, or sovereignty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef734c11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204g/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with Secretary of Commerce","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef734c12-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204g/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information provided to Secretary of Agriculture","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On a written request by the Secretary of Agriculture, the Secretary of Commerce may provide to the Secretary of Agriculture any information collected under title 13 that the Secretary of Agriculture considers necessary for the taking of a census or survey under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734c13-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204g/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information provided to Secretary of Commerce","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On a written request by the Secretary of Commerce, the Secretary of Agriculture may provide to the Secretary of Commerce any information collected in a census taken under this section that the Secretary of Commerce considers necessary for the taking of a census or survey under title 13.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734c14-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204g/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information obtained under this subsection may not be used for any purpose other than the statistical purposes for which the information is supplied. For purposes of sections 9 and 214 of title 13, any information provided under paragraph (2) shall be considered information furnished under the provisions of title 13.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef734c15-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204g/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A regulation necessary to carry out this section may be promulgated by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef734c16-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204g/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, to the extent that a matter under the jurisdiction of the Secretary is involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734c17-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204g/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Commerce, to the extent that a matter under the jurisdiction of the Secretary of Commerce is involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef734c18-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/113/s2"},"text":"Pub. L. 105–113, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2274"},"text":"111 Stat. 2274","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tX/s10103"},"text":"Pub. L. 110–234, title X, § 10103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1336"},"text":"122 Stat. 1336","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title X, § 10103, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2097.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef734c19-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef734c1a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef734c1b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef734c1c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s10103"},"text":"Pub. L. 110–246, § 10103","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef734c1d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef734c1e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"