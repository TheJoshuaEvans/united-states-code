{"tag":"section","attrib":{"id":"idefe5bbb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502"},"text":null,"children":[{"tag":"num","attrib":{"value":"6502"},"text":"§ 6502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bbb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agricultural product” means any agricultural commodity or product, whether raw or processed, including any commodity or product derived from livestock that is marketed in the United States for human or livestock consumption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbb4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Botanical pesticides","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “botanical pesticides” means natural pesticides derived from plants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbb5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certifying agent","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe5bbb6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “certifying agent” means the chief executive officer of a State or, in the case of a State that provides for the Statewide election of an official to be responsible solely for the administration of the agricultural operations of the State, such official, and any person (including private entities) who is accredited by the Secretary as a certifying agent for the purpose of certifying a farm or handling operation as a certified organic farm or handling operation in accordance with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bbb7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign operations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When used in the context of a certifying agent operating in a foreign country, the term “certifying agent” includes any person (including a private entity)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefe5bbb8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accredited in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6514/d"},"text":"section 6514(d) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe5bbb9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accredited by a foreign government that acted under an equivalency agreement negotiated between the United States and the foreign government from which the agricultural product is imported.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certified organic farm","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “certified organic farm” means a farm, or portion of a farm, or site where agricultural products or livestock are produced, that is certified by the certifying agent under this chapter as utilizing a system of organic farming as described by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbbb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certified organic handling operation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “certified organic handling operation” means any operation, or portion of any handling operation, that is certified by the certifying agent under this chapter as utilizing a system of organic handling as described under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbbc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crop year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “crop year” means the normal growing season for a crop as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbbd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governing State official","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “governing State official” means the chief executive official of a State or, in the case of a State that provides for the Statewide election of an official to be responsible solely for the administration of the agricultural operations of the State, such official, who administers an organic certification program under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbbe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Handle","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “handle” means to sell, process or package agricultural products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbbf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Handler","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “handler” means any person engaged in the business of handling agricultural products, except such term shall not include final retailers of agricultural products that do not process agricultural products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbc0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Handling operation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “handling operation” means any operation or portion of an operation (except final retailers of agricultural products that do not process agricultural products) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe5bbc1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receives or otherwise acquires agricultural products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bbc2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processes, packages, or stores such products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbc3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Livestock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “livestock” means any cattle, sheep, goats, swine, poultry, equine animals used for food or in the production of food, fish used for food, wild or domesticated game, or other nonplant life.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbc4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National List","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National List” means a list of approved and prohibited substances as provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6517"},"text":"section 6517 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbc5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National organic program import certificate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “national organic program import certificate” means a form developed for purposes of the program under this chapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe5bbc6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide documentation sufficient to verify that an agricultural product imported for sale in the United States satisfies the requirement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6514/c"},"text":"section 6514(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bbc7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which shall include, at a minimum, information sufficient to indicate, with respect to the agricultural product—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefe5bbc8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/13/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the origin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe5bbc9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/13/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the destination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe5bbca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/13/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the certifying agent issuing the national organic program import certificate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe5bbcb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/13/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the harmonized tariff code, if a harmonized tariff code exists for the agricultural product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe5bbcc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/13/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total weight; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe5bbcd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/13/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the organic standard to which the agricultural product is certified; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bbce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is not more than otherwise required under an equivalency agreement negotiated between the United States and the foreign government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbcf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organic plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “organic plan” means a plan of management of an organic farming or handling operation that has been agreed to by the producer or handler and the certifying agent and that includes written plans concerning all aspects of agricultural production or handling described in this chapter including crop rotation and other practices as required under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbd0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organically produced","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “organically produced” means an agricultural product that is produced and handled in accordance with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbd1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means an individual, group of individuals, corporation, association, organization, cooperative, or other entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbd2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pesticide","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “pesticide” means any substance which alone, in chemical combination, or in any formulation with one or more substances, is defined as a pesticide in the Federal Insecticide, Fungicide, and Rodenticide Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136"},"text":"7 U.S.C. 136","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbd3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Processing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “processing” means cooking, baking, heating, drying, mixing, grinding, churning, separating, extracting, cutting, fermenting, eviscerating, preserving, dehydrating, freezing, or otherwise manufacturing, and includes the packaging, canning, jarring, or otherwise enclosing food in a container.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbd4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “producer” means a person who engages in the business of growing or producing food or feed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbd5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbd6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State organic certification program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State organic certification program” means a program that meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6506"},"text":"section 6506 of this title","children":[],"tail":", is approved by the Secretary, and that is designed to ensure that a product that is sold or labeled as “organically produced” under this chapter is produced and handled using organic methods."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bbd7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6502/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Synthetic","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “synthetic” means a substance that is formulated or manufactured by a chemical process or by a process that chemically changes a substance extracted from naturally occurring plant, animal, or mineral sources, except that such term shall not apply to substances created by naturally occurring biological processes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe5bbd8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXI/s2103"},"text":"Pub. L. 101–624, title XXI, § 2103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3935"},"text":"104 Stat. 3935","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tX/s10104/b"},"text":"Pub. L. 115–334, title X, § 10104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4899"},"text":"132 Stat. 4899","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefe5bbd9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefe5bbda-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefe5bbdb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Insecticide, Fungicide, and Rodenticide Act, referred to in par. (17), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-25/ch125"},"text":"act June 25, 1947, ch. 125","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/92/516"},"text":"Pub. L. 92–516","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/973"},"text":"86 Stat. 973","children":[],"tail":", which is classified generally to subchapter II (§ 136 et seq.) of chapter 6 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136"},"text":"section 136 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefe5bbdc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10104/b/1"},"text":"Pub. L. 115–334, § 10104(b)(1)","children":[],"tail":", designated existing provisions as subpar. (A), inserted heading, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (13) to (22). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10104/b/2"},"text":"Pub. L. 115–334, § 10104(b)(2)","children":[],"tail":", (3), added par. (13) and redesignated former pars. (13) to (21) as (14) to (22), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
