{"tag":"section","attrib":{"id":"idf00997e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417"},"text":null,"children":[{"tag":"num","attrib":{"value":"7417"},"text":"§ 7417.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referenda","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf00997e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial referendum","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00997e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Optional referendum","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of ascertaining whether the persons to be covered by an order favor the order going into effect, the order may provide for the Secretary to conduct an initial referendum among persons to be subject to an assessment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7416"},"text":"section 7416 of this title","children":[],"tail":" who, during a representative period determined by the Secretary, engaged in—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00997e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production or handling of the agricultural commodity covered by the order; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00997e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importation of the agricultural commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00997e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The results of the referendum shall be determined in accordance with subsection (e). The Secretary may require that the agricultural commodity industry involved post a bond or other collateral to cover the cost of the referendum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00997ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required referenda","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00997eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of ascertaining whether the persons covered by an order favor the continuation, suspension, or termination of the order, the Secretary shall conduct a referendum among persons subject to assessments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7416"},"text":"section 7416 of this title","children":[],"tail":" who, during a representative period determined by the Secretary, have engaged in—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00997ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production or handling of the agricultural commodity covered by the order; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00997ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importation of the agricultural commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00997ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for referendum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The referendum shall be conducted not later than 3 years after assessments first begin under the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00997ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not apply if an initial referendum was conducted under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00997f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent referenda","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct a subsequent referendum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00997f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 7 years after assessments first begin under the order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00997f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the request of the board established under the order; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00997f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the request of 10 percent or more of the number of persons eligible to vote under subsection (b)(1);","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to determine if the persons favor the continuation, suspension, or termination of the order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00997f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other referenda","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may conduct a referendum at any time to determine whether the continuation, suspension, or termination of the order or a provision of the order is favored by persons eligible to vote under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00997f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of order","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An order may provide for its approval in a referendum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00997f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a majority of those persons voting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00997f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by persons voting for approval who represent a majority of the volume of the agricultural commodity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00997f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a majority of those persons voting for approval who also represent a majority of the volume of the agricultural commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00997f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs of referenda","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The board established under an order with respect to which a referendum is conducted under this section shall reimburse the Secretary for any expenses incurred by the Secretary to conduct the referendum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00997fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of conducting referenda","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00997fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A referendum conducted under this section shall be conducted in the manner determined by the Secretary to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00997fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that an advance registration of eligible voters in a referendum is necessary before the voting period in order to facilitate the conduct of the referendum, the Secretary may institute the advance registration procedures by mail, or in person through the use of national and local offices of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00997fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Eligible voters may vote by mail ballot in the referendum or in person if so prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00997fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7417/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days before a referendum is conducted under this section with respect to an order, the Secretary shall notify the agricultural commodity industry involved, in such manner as determined by the Secretary, of the period during which voting in the referendum will occur. The notice shall explain any registration and voting procedures established under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf00997ff-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s518"},"text":"Pub. L. 104–127, title V, § 518","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1043"},"text":"110 Stat. 1043","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
