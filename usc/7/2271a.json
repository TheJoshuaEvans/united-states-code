{"tag":"section","attrib":{"id":"idef7a784f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2271a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2271a"},"text":"§ 2271a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced marketing training for farmers and ranchers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture may establish a program to train farmers and ranchers in advanced techniques for the marketing of agricultural commodities, livestock, and aquacultural products produced by such farmers and ranchers, including (where appropriate as determined by the Secretary) training in the use of futures and options markets.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef7a7850-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/641/tII/s206/b"},"text":"Pub. L. 99–641, title II, § 206(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3564"},"text":"100 Stat. 3564","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7a7851-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef7a7852-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef7a7853-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study and Report of Marketing Practices of Applicants and Borrowers of Farm Loans","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/641/tII/s206/a"},"text":"Pub. L. 99–641, title II, § 206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3563"},"text":"100 Stat. 3563","children":[],"tail":", provided that the Comptroller General of the United States should conduct a study, to be reported to Congress within 1 year after "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", of marketing practices used by applicants for and borrowers of farm loans made, insured, or guaranteed under the Consolidated Farm and Rural Development Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"7 U.S.C. 1921","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
