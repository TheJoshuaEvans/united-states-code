{"tag":"section","attrib":{"id":"idefc933ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5608"},"text":null,"children":[{"tag":"num","attrib":{"value":"5608"},"text":"§ 5608.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign trade missions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefc933ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5608/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal representation on trade missions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc933af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5608/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Tribal Advisory Committee established under subsection (b)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6921"},"text":"section 6921 of this title","children":[],"tail":" (referred to in this section as the “Advisory Committee”), shall seek—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc933b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5608/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the greater inclusion of Tribal agricultural and food products in Federal trade-related activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc933b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5608/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the collaboration between Federal trade promotion efforts and other Federal trade-related activities in support of the greater inclusion sought under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc933b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5608/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interdepartmental coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out activities to increase the collaboration described in paragraph (1)(B), the Secretary shall coordinate with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc933b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5608/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc933b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5608/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc933b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5608/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc933b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5608/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the heads of any other relevant Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc933b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5608/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report; goals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc933b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5608/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", the Secretary shall submit a report describing the efforts of the Department of Agriculture and other Federal agencies under this section to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc933b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5608/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Advisory Committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc933ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5608/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc933bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5608/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc933bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5608/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture, Nutrition, and Forestry of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc933bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5608/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc933be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5608/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Indian Affairs of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc933bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5608/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", the Secretary shall establish goals for measuring, in an objective and quantifiable format, the extent to which Indian Tribes and Tribal agricultural and food products are included in the trade-related activities of the Department of Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefc933c0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib