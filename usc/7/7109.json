{"tag":"section","attrib":{"id":"ideffdb13a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7109"},"text":null,"children":[{"tag":"num","attrib":{"value":"7109"},"text":"§ 7109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideffdb13b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter preempts or supersedes any other program relating to sheep promotion, research, or information organized and operated under the laws of the United States or any State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffdb13c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments to orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this chapter applicable to an order shall be applicable to amendments to the order, except that the Secretary is not required to conduct a referendum on a proposed amendment to an order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideffdb13d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/407/s10"},"text":"Pub. L. 103–407, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4226"},"text":"108 Stat. 4226","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
