{"tag":"section","attrib":{"id":"idf00998d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445"},"text":null,"children":[{"tag":"num","attrib":{"value":"7445"},"text":"§ 7445.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf00998d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00998d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First purchasers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the effective period of an order issued pursuant to this subchapter, assessments shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00998d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" levied on all canola or rapeseed produced in the United States and marketed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00998da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deducted from the payment made to a producer for all canola or rapeseed sold to a first purchaser.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00998db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct processing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide that any person processing canola or rapeseed of that person’s own production and marketing the canola or rapeseed, or canola or rapeseed products, shall remit to the Board or a State organization certified to represent producers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7444/b/6"},"text":"section 7444(b)(6) of this title","children":[],"tail":", in the manner prescribed by the order, an assessment established at a rate equivalent to the rate provided for under subsection (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00998dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No more than 1 assessment may be assessed under subsection (a) on any canola or rapeseed produced (as remitted by a first purchaser).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00998dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remitting of assessments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00998de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assessments required under subsection (a) shall be remitted to the Board by a first purchaser. The Board shall use State organizations certified to represent producers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7444/b/6"},"text":"section 7444(b)(6) of this title","children":[],"tail":" to collect the assessments. If an appropriate certified State organization does not exist to collect an assessment, the assessment shall be collected by the Board. There shall be only 1 certified State organization in each State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00998df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Times to remit assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each first purchaser shall remit the assessment to the Board as provided for in the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00998e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment rate","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00998e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The initial assessment rate shall be 4 cents per hundredweight of canola or rapeseed produced and marketed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00998e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The assessment rate may be increased on recommendation by the Board to a rate not exceeding 10 cents per hundredweight of canola or rapeseed produced and marketed in a State, unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00998e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the initial referendum is held under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7446/a"},"text":"section 7446(a) of this title","children":[],"tail":", the Board recommends an increase above 10 cents per hundredweight; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00998e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the increase is approved in a referendum under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7446/b"},"text":"section 7446(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00998e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A producer who demonstrates to the Board that the producer is participating in a program of a State organization certified to represent producers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7444/b/6"},"text":"section 7444(b)(6) of this title","children":[],"tail":" shall receive credit, in determining the assessment due from the producer, for contributions to the program of up to 2 cents per hundredweight of canola or rapeseed marketed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00998e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Late payment charge","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00998e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be a late payment charge imposed on any person who fails to remit, on or before the date provided for in the order, to the Board the total amount for which the person is liable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00998e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of charge","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the late payment charge imposed under paragraph (1) shall be prescribed by the Board with the approval of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00be1d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refund of assessments from escrow account","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00be1da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of escrow account","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the period beginning on the date on which an order is first issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7443/b/3"},"text":"section 7443(b)(3) of this title","children":[],"tail":" and ending on the date on which a referendum is conducted under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7446/a"},"text":"section 7446(a) of this title","children":[],"tail":", the Board shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00be1db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and maintain an escrow account to be used for assessment refunds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be1dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" place funds in the account in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be1dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Placement of funds in account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall place in the account, from assessments collected during the period referred to in paragraph (1), an amount equal to the product obtained by multiplying the total amount of assessments collected during the period by 10 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be1de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to receive refund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall refund to a producer the assessments paid by or on behalf of the producer if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00be1df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the producer is required to pay the assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be1e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the producer does not support the program established under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be1e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the producer demands the refund prior to the conduct of the referendum under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7446/a"},"text":"section 7446(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be1e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of demand","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The demand shall be made in accordance with such regulations, in such form, and within such time period as prescribed by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be1e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Making of refund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The refund shall be made on submission of proof satisfactory to the Board that the producer paid the assessment for which the refund is demanded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be1e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00be1e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/f/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount in the escrow account required by paragraph (1) is not sufficient to refund the total amount of assessments demanded by eligible producers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be1e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/f/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the order is not approved pursuant to the referendum conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7446/a"},"text":"section 7446(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Board shall prorate the amount of the refunds among all eligible producers who demand a refund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be1e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7445/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program approved","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the plan is approved pursuant to the referendum conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7446/a"},"text":"section 7446(a) of this title","children":[],"tail":", all funds in the escrow account shall be returned to the Board for use by the Board in accordance with this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf00be1e8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s536"},"text":"Pub. L. 104–127, title V, § 536","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1056"},"text":"110 Stat. 1056","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
