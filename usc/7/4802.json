{"tag":"section","attrib":{"id":"idefbd4d26-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802"},"text":null,"children":[{"tag":"num","attrib":{"value":"4802"},"text":"§ 4802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbd4d27-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Board” means the National Pork Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4808"},"text":"section 4808 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbd4d28-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “consumer information” means an activity intended to broaden the understanding of sound nutritional attributes of pork or pork products, including the role of pork or pork products in a balanced, healthy diet.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbd4d29-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Delegate Body” means the National Pork Producers Delegate Body established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4806"},"text":"section 4806 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbd4d2a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “imported” means entered, or withdrawn from a warehouse for consumption, in the customs territory of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbd4d2b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “importer” means a person who imports porcine animals, pork, or pork products into the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbd4d2c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “order” means a pork and pork products promotion, research, and consumer information order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4803"},"text":"section 4803 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbd4d2d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” means an individual, group of individuals, partnership, corporation, association, organization, cooperative, or other entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf961e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “porcine animal” means a swine raised for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf961f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" feeder pigs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf9620-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seedstock; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf9621-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" slaughter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9622-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “pork” means the flesh of a porcine animal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9623-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “pork product” means a product produced or processed in whole or in part from pork.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9624-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “producer” means a person who produces porcine animals in the United States for sale in commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9625-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “promotion” means an action, including paid advertising, taken to present a favorable image for porcine animals, pork, or pork products to the public with the intent of improving the competitive position and stimulating sales of porcine animals, pork, or pork products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9626-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “research” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf9627-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research designed to advance, expand, or improve the image, desirability, nutritional value, usage, marketability, production, or quality of porcine animals, pork, or pork products; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf9628-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dissemination to a person of the results of such research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9629-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf962a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means each of the 50 States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf962b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “State association” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf962c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/16/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the single organization of pork producers in a State that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefbf962d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/16/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organized under the laws of the State in which such association operates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefbf962e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/16/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognized by the chief executive officer of such State as representing the pork producers of such State; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf962f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/16/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such organization does not exist on ","children":[{"tag":"date","attrib":{"date":"1986-01-01"},"text":"January 1, 1986","children":[],"tail":", an organization that represents not fewer than 50 pork producers who market annually, in the aggregate, not less than 10 percent of the volume (measured in pounds) of porcine animals marketed in such State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9630-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4802/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “to market” means to sell or to otherwise dispose of a porcine animal, pork, or pork product in commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefbf9631-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1613"},"text":"Pub. L. 99–198, title XVI, § 1613","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1607"},"text":"99 Stat. 1607","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefbf9632-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefbf9633-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefbf9634-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1986-01-01"},"text":"Jan. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1631"},"text":"section 1631 of Pub. L. 99–198","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4801"},"text":"section 4801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
