{"tag":"section","attrib":{"id":"idef297168-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009l"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009l"},"text":"§ 2009l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Rural Economic and Community Development State Offices","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In carrying out this subchapter, the Director of a Rural Economic and Community Development State Office shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef297169-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, ensure that the State strategic plan referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009c"},"text":"section 2009c of this title","children":[],"tail":" is implemented;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef29716a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate community development objectives within the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef29716b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009l/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish links between local, State, and field office program administrators of the Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef29716c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009l/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that recipient communities comply with applicable Federal and State laws and requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef29716d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009l/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrate State development programs with assistance under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef29716e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s381M"},"text":"Pub. L. 87–128, title III, § 381M","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s761"},"text":"Pub. L. 104–127, title VII, § 761","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1146"},"text":"110 Stat. 1146","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
