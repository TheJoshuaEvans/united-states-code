{"tag":"section","attrib":{"id":"idefd05fbf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843"},"text":null,"children":[{"tag":"num","attrib":{"value":"5843"},"text":"§ 5843.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefd05fc0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd05fc1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an advisory council for the program for the purpose of advising, assisting, consulting with, and making recommendations to, the Secretary and Director concerning matters related to the activities, policies and operations of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fc2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The advisory council shall consist of ex officio members and not more than 13 members appointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fc3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd05fc4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making recommendations under paragraph (1), the advisory council shall include recommendations on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefd05fc5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the state of public cultivar development, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idefd05fc6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/a/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of existing cultivar research investments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idefd05fc7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/a/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the research gaps relating to the development of cultivars across a diverse range of crops; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idefd05fc8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/a/3/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the state of commercialization of federally funded cultivars;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefd05fc9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training and resources needed to meet future breeding challenges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefd05fca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate levels of Federal funding for cultivar development for underserved crops and geographic areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefd05fcb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/a/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of the plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5841/d/6"},"text":"section 5841(d)(6) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05fcc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ex officio members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The ex officio members of the advisory council shall consist of the following persons (or their designees):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd05fcd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of Agriculture for Science and Education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fcf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Agricultural Library.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fd0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Institutes of Health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fd1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fd2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fd3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Science and Technology Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fd4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such additional officers and employees of the United States as the Secretary determines are necessary for the advisory council to effectively carry out its functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05fd5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of other members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The members of the advisory council who are not ex officio members shall be appointed by the Secretary as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd05fd6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6 of the members shall be appointed from among the leading representatives of the scientific disciplines relevant to the activities of the program, including agricultural sciences, economics and policy, environmental sciences, natural resource sciences, health sciences, and nutritional sciences.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fd7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 of the members shall be appointed from the general public and shall include leaders in fields of public policy, community development, trade, international development, law, or management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fd8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 of the members shall be appointed from among individuals with expertise in public cultivar and animal breed development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fd9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 4 of the members shall be appointed from among individuals representing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd05fda-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1862 Institutions (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7601"},"text":"section 7601 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd05fdb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1890 Institutions (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7601"},"text":"section 7601 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd05fdc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hispanic-serving institutions (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3103"},"text":"section 3103 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd05fdd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1994 Institutions (as defined in section 532 of the Equity in Educational Land-Grant Status Act of 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s301"},"text":"7 U.S.C. 301","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Public Law 103–382","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05fde-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the advisory council shall serve without compensation, if not otherwise officers or employees of the United States, except that they shall, while away from their homes or regular places of business in the performance of services for the advisory council, be allowed travel expenses, including per diem in lieu of subsistence, in the same manner as persons employed intermittently in the Government service are allowed expenses under sections 5701 through 5707 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05fdf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of office of appointees; vacancies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd05fe0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of office of a member appointed under subsection (c) is four years, except that any member appointed to fill a vacancy occurring before the expiration of the term for which the predecessor of such member was appointed shall be appointed only for the remainder of such term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fe1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make appointments to the advisory council so as to ensure that the terms of the members appointed under subsection (c) do not all expire in the same year. A member may serve after the expiration of the member’s term until a successor takes office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fe2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reappointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member who is appointed for a term of four years may not be reappointed to the advisory council before two years after the date of expiration of such term of office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fe3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a vacancy occurs in the advisory council among the members appointed under subsection (c), the Secretary shall make an appointment to fill such vacancy within 90 days after the date such vacancy occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05fe4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall select as the chair of the advisory council one of the members appointed under subsection (c). The term of office of the chair shall be two years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05fe5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The advisory council shall meet at the call of the chair or on the request of the Director, but at least two times each fiscal year. The location of the meetings of the advisory council shall be subject to the approval of the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05fe6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall make available to the advisory council such staff, information, and other assistance as it may require to carry out its functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05fe7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Orientation and training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall provide such orientation and training for new members of the advisory council as may be appropriate for their effective participation in the functions of the advisory council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05fe8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comments and recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The advisory council may prepare, for inclusion in a report submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5842"},"text":"section 5842 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd05fe9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comments respecting the activities of the advisory council during the period covered by the report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comments on the progress of the program in meeting its objectives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05feb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations respecting the future directions, program, and policy emphasis of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05fec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The advisory council may prepare such reports as the advisory council determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05fed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5843/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":