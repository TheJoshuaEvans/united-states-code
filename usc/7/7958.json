{"tag":"section","attrib":{"id":"idf0289224-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958"},"text":null,"children":[{"tag":"num","attrib":{"value":"7958"},"text":"§ 7958.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0289225-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory inspection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All peanuts marketed in the United States shall be officially inspected and graded by Federal or Federal-State inspectors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0289226-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of Peanut Administrative Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Peanut Administrative Committee established under Marketing Agreement No. 146 issued pursuant to the Agricultural Adjustment Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s601"},"text":"7 U.S.C. 601","children":[],"tail":" et seq.), reenacted with amendments by the Agricultural Marketing Agreement Act of 1937, is terminated."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0289227-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peanut Standards Board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0289228-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a Peanut Standards Board for the purpose of advising the Secretary regarding the establishment of quality and handling standards for domestically produced and imported peanuts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0289229-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership and appointment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf028922a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Total members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall consist of 18 members, with representation equally divided between peanut producers and peanut industry representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf028922b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment process for producers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall appoint—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf028922c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 producers from the Southeast (Alabama, Georgia, and Florida) peanut producing region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf028922d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 producers from the Southwest (Texas, Oklahoma, and New Mexico) peanut producing region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf028922e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 producers from the Virginia/Carolina (Virginia, North Carolina, and South Carolina) peanut producing region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf028922f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment process for industry representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint 3 peanut industry representatives from each of the 3 peanut producing regions in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0289230-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0289231-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Board shall serve a 3-year term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0289232-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial appointment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making the initial appointments to the Board, the Secretary shall stagger the terms of the members so that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0289233-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 producer member and peanut industry member from each peanut producing region serves a 1-year term;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0289234-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 producer member and peanut industry member from each peanut producing region serves a 2-year term; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0289235-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 producer member and peanut industry member from each peanut producing region serves a 3-year term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0289236-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with the Board in advance whenever the Secretary establishes or changes, or considers the establishment of or a change to, quality and handling standards for peanuts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0289237-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply to the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0289238-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make identifying and combating the presence of all quality concerns related to peanuts a priority in the development of quality and handling standards for peanuts and in the inspection of domestically produced and imported peanuts. The Secretary shall consult with appropriate Federal and State agencies to provide adequate safeguards against all quality concerns related to peanuts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0289239-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistent standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Imported peanuts shall be subject to the same quality and handling standards as apply to domestically produced peanuts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf028923a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf028923b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to other funds that are available to carry out this section, there is authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf028923c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of Board expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The expenses of the Peanut Standards Board shall not be counted toward any general limitation on the expenses of advisory committees, panels, commissions, and task forces of the Department of Agriculture, whether enacted before, on, or after ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", unless the limitation specifically refers to this paragraph and specifically includes the Peanut Standards Board within the general limitation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf028923d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition rule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf028923e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary designation of Peanut Administrative Committee members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the appointment process specified in subsection (c) for the Peanut Standards Board, during the transition period, the Secretary may designate persons serving as members of the Peanut Administrative Committee on the day before ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", to serve as members of the Peanut Standards Board for the purpose of carrying out the duties of the Board described in this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf028923f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may transfer any funds available to carry out the activities of the Peanut Administrative Committee to the Peanut Standards Board to carry out the duties of the Board described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0289240-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In paragraph (1), the term “transition period” means the period beginning on ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", and ending on the earlier of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0289241-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date the Secretary appoints the members of the Peanut Standards Board pursuant to subsection (c); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0289242-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 180 days after ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0289243-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7958/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect with the 2002 crop of peanuts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0289244-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1308"},"text":"Pub. L. 107–171, title I, § 1308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/178"},"text":"116 Stat. 178","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12517"},"text":"Pub. L. 115–334, title XII, § 12517","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5000"},"text":"132 Stat. 5000","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/41"},"text":"Pub. L. 117–286, § 4(a)(41)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4309"},"text":"136 Stat. 4309","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0289245-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0289246-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf0289247-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Agricultural Adjustment Act, as reenacted with amendments by the Agricultural Marketing Agreement Act of 1937, referred to in subsec. (b), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-12/ch25"},"text":"act May 12, 1933, ch. 25","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/31"},"text":"48 Stat. 31","children":[],"tail":", which is classified generally to chapter 26 (§ 601 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s601"},"text":"section 601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf0289248-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “Federal Advisory Committee Act” in heading and “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(2)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “Virginia, North Carolina, and South Carolina” for “Virginia and North Carolina”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
