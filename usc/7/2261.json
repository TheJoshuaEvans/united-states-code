{"tag":"section","attrib":{"id":"idef7a77df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2261"},"text":null,"children":[{"tag":"num","attrib":{"value":"2261"},"text":"§ 2261.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit of donations and proceeds from exhibitions to appropriations concerned with foreign market development programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the conduct of foreign market development programs, the Secretary of Agriculture is authorized to credit contributions from individuals, firms, associations, agencies, and other groups, and the proceeds received from space rentals, and sales of products and materials at exhibitions, to the appropriations charged with the cost of acquiring such space, products, and materials.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef7a77e0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tII/s203"},"text":"Pub. L. 87–128, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/307"},"text":"75 Stat. 307","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7a77e1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef7a77e2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef7a77e3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s577"},"text":"section 577 of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
