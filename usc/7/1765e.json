{"tag":"section","attrib":{"id":"ideefc1f97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1765e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1765e"},"text":"§ 1765e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location of offices","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"United States Agricultural Trade Offices shall be centrally located in the cities of assignment to facilitate foreign trade meetings and foreign trade reliance on such offices for assistance in marketing activities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideefc1f98-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-28/ch1041"},"text":"Aug. 28, 1954, ch. 1041","children":[],"tail":", title VI, § 605E, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/501/tIV/s401/1"},"text":"Pub. L. 95–501, title IV, § 401(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-21"},"text":"Oct. 21, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1690"},"text":"92 Stat. 1690","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
