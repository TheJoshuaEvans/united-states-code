{"tag":"section","attrib":{"id":"idef1d8a41-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1987"},"text":null,"children":[{"tag":"num","attrib":{"value":"1987"},"text":"§ 1987.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debt adjustment and credit counseling; “summary period” defined; loan summary statements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef1d8a42-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1987/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may provide voluntary debt adjustment assistance between farmers and their creditors and may cooperate with State, territorial, and local agencies and committees engaged in such debt adjustment, and may give credit counseling.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef1d8a43-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1987/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef1d8a44-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1987/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this subsection, the term “summary period” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef1d8a45-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1987/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period beginning on ","children":[{"tag":"date","attrib":{"date":"1985-12-23"},"text":"December 23, 1985","children":[],"tail":", and ending on the date on which the first loan summary statement is issued after "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"December 23, 1985","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef1d8a46-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1987/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period beginning on the date of issuance of the preceding loan summary statement and ending on the date of issuance of the current loan summary statement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef1d8a47-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1987/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" On the request of a borrower of a loan made or insured (but not guaranteed) under this chapter, the Secretary shall issue to such borrower a loan summary statement that reflects the account activity during the summary period for each loan made or insured under this chapter to such borrower, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef1d8a48-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1987/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the outstanding amount of principal due on each such loan at the beginning of the summary period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef1d8a49-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1987/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interest rate charged on each such loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef1d8a4a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1987/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of payments made on and their application to each such loan during the summary period and an explanation of the basis for the application of such payments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef1d8a4b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1987/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of principal and interest due on each such loan at the end of the summary period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef1d8a4c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1987/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of unpaid principal and interest on all such loans at the end of the summary period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef1d8a4d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1987/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any delinquency in the repayment of any such loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef1d8a4e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1987/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a schedule of the amount and date of payments due on each such loan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef1d8a4f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1987/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procedure the borrower may use to obtain more information concerning the status of such loans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef1d8a50-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s337"},"text":"Pub. L. 87–128, title III, § 337","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/316"},"text":"75 Stat. 316","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXIII/s1316"},"text":"Pub. L. 99–198, title XIII, § 1316","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1528"},"text":"99 Stat. 1528","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef1d8a51-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef1d8a52-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef1d8a53-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b)(2), was in the original “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/307"},"text":"75 Stat. 307","children":[],"tail":", known as the Consolidated Farm and Rural Development Act, which is classified principally to this chapter. For complete classification of title III to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef1d8a54-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
