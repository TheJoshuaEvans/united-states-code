{"tag":"section","attrib":{"id":"idedcaf20d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"§ 7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of boards of trade as contract markets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idedcaf20e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A board of trade applying to the Commission for designation as a contract market shall submit an application to the Commission that includes any relevant materials and records the Commission may require consistent with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedcaf20f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVII/s735/a"},"text":"Pub. L. 111–203, title VII, § 735(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1718"},"text":"124 Stat. 1718","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedcaf210-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing contract markets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A board of trade that is designated as a contract market on ","children":[{"tag":"date","attrib":{"date":"2000-12-21"},"text":"December 21, 2000","children":[],"tail":", shall be considered to be a designated contract market under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedcaf211-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Core principles for contract markets","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedcaf212-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation as contract market","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcaf213-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be designated, and maintain a designation, as a contract market, a board of trade shall comply with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idedcaf214-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any core principle described in this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcaf215-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any requirement that the Commission may impose by rule or regulation pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s12a/5"},"text":"section 12a(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcaf216-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable discretion of contract market","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless otherwise determined by the Commission by rule or regulation, a board of trade described in subparagraph (A) shall have reasonable discretion in establishing the manner in which the board of trade complies with the core principles described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf217-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with rules","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcaf218-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The board of trade shall establish, monitor, and enforce compliance with the rules of the contract market, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idedcaf219-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcaf21a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms and conditions of any contracts to be traded on the contract market; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcaf21b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rules prohibiting abusive trade practices on the contract market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcaf21c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capacity of contract market","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The board of trade shall have the capacity to detect, investigate, and apply appropriate sanctions to any person that violates any rule of the contract market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcaf21d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rules of the contract market shall provide the board of trade with the ability and authority to obtain any necessary information to perform any function described in this subsection, including the capacity to carry out such international information-sharing agreements as the Commission may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf21e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts not readily subject to manipulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The board of trade shall list on the contract market only contracts that are not readily susceptible to manipulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf21f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention of market disruption","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The board of trade shall have the capacity and responsibility to prevent manipulation, price distortion, and disruptions of the delivery or cash-settlement process through market surveillance, compliance, and enforcement practices and procedures, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcaf220-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods for conducting real-time monitoring of trading; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcaf221-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comprehensive and accurate trade reconstructions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf222-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Position limitations or accountability","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcaf223-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To reduce the potential threat of market manipulation or congestion (especially during trading in the delivery month), the board of trade shall adopt for each contract of the board of trade, as is necessary and appropriate, position limitations or position accountability for speculators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcaf224-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum allowable position limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any contract that is subject to a position limitation established by the Commission pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6a/a"},"text":"section 6a(a) of this title","children":[],"tail":", the board of trade shall set the position limitation of the board of trade at a level not higher than the position limitation established by the Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf225-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The board of trade, in consultation or cooperation with the Commission, shall adopt rules to provide for the exercise of emergency authority, as is necessary and appropriate, including the authority—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcaf226-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to liquidate or transfer open positions in any contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcaf227-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to suspend or curtail trading in any contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcaf228-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require market participants in any contract to meet special margin requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf229-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of general information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The board of trade shall make available to market authorities, market participants, and the public accurate information concerning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcaf22a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms and conditions of the contracts of the contract market; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcaf22b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idedcaf22c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rules, regulations, and mechanisms for executing transactions on or through the facilities of the contract market; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcaf22d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the rules and specifications describing the operation of the contract market’s—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idedcaf22e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/7/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electronic matching platform; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idedcaf22f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/7/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trade execution facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf230-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Daily publication of trading information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The board of trade shall make public daily information on settlement prices, volume, open interest, and opening and closing ranges for actively traded contracts on the contract market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf231-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Execution of transactions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcaf232-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The board of trade shall provide a competitive, open, and efficient market and mechanism for executing transactions that protects the price discovery process of trading in the centralized market of the board of trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcaf233-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rules of the board of trade may authorize, for bona fide business purposes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idedcaf234-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer trades or office trades;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcaf235-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an exchange of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idedcaf236-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/9/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" futures in connection with a cash commodity transaction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idedcaf237-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/9/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" futures for cash commodities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idedcaf238-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/9/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" futures for swaps; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcaf239-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/9/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a futures commission merchant, acting as principal or agent, to enter into or confirm the execution of a contract for the purchase or sale of a commodity for future delivery if the contract is reported, recorded, or cleared in accordance with the rules of the contract market or a derivatives clearing organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf23a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The board of trade shall maintain rules and procedures to provide for the recording and safe storage of all identifying trade information in a manner that enables the contract market to use the information—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcaf23b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist in the prevention of customer and market abuses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcaf23c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide evidence of any violations of the rules of the contract market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf23d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial integrity of transactions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The board of trade shall establish and enforce—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcaf23e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rules and procedures for ensuring the financial integrity of transactions entered into on or through the facilities of the contract market (including the clearance and settlement of the transactions with a derivatives clearing organization); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcaf23f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" rules to ensure—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idedcaf240-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/11/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the financial integrity of any—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idedcaf241-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/11/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" futures commission merchant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idedcaf242-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/11/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" introducing broker; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcaf243-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/11/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of customer funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf244-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of markets and market participants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The board of trade shall establish and enforce rules—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcaf245-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect markets and market participants from abusive practices committed by any party, including abusive practices committed by a party acting as an agent for a participant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcaf246-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote fair and equitable trading on the contract market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf247-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disciplinary procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The board of trade shall establish and enforce disciplinary procedures that authorize the board of trade to discipline, suspend, or expel members or market participants that violate the rules of the board of trade, or similar methods for performing the same functions, including delegation of the functions to third parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf248-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dispute resolution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The board of trade shall establish and enforce rules regarding, and provide facilities for alternative dispute resolution as appropriate for, market participants and any market intermediaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf249-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governance fitness standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The board of trade shall establish and enforce appropriate fitness standards for directors, members of any disciplinary committee, members of the contract market, and any other person with direct access to the facility (including any party affiliated with any person described in this paragraph).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf24a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts of interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The board of trade shall establish and enforce rules—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcaf24b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/16/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to minimize conflicts of interest in the decision-making process of the contract market; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcaf24c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/16/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish a process for resolving conflicts of interest described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf24d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition of governing boards of contract markets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The governance arrangements of the board of trade shall be designed to permit consideration of the views of market participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf24e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The board of trade shall maintain records of all activities relating to the business of the contract market—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcaf24f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/18/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a form and manner that is acceptable to the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcaf250-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/18/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a period of at least 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf251-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antitrust considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless necessary or appropriate to achieve the purposes of this chapter, the board of trade shall not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcaf252-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/19/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt any rule or taking ","children":[{"tag":"ref","attrib":{"idref":"fn002031"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002031"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “take”."}],"tail":" any action that results in any unreasonable restraint of trade; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcaf253-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/19/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impose any material anticompetitive burden on trading on the contract market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf254-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" System safeguards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The board of trade shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcaf255-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/20/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and maintain a program of risk analysis and oversight to identify and minimize sources of operational risk, through the development of appropriate controls and procedures, and the development of automated systems, that are reliable, secure, and have adequate scalable capacity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcaf256-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/20/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and maintain emergency procedures, backup facilities, and a plan for disaster recovery that allow for the timely recovery and resumption of operations and the fulfillment of the responsibilities and obligations of the board of trade; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcaf257-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/20/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically conduct tests to verify that backup resources are sufficient to ensure continued order processing and trade matching, price reporting, market surveillance, and maintenance of a comprehensive and accurate audit trail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf258-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial resources","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcaf259-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/21/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The board of trade shall have adequate financial, operational, and managerial resources to discharge each responsibility of the board of trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcaf25a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/21/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of adequacy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The financial resources of the board of trade shall be considered to be adequate if the value of the financial resources exceeds the total amount that would enable the contract market to cover the operating costs of the contract market for a 1-year period, as calculated on a rolling basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf25b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diversity of board of directors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The board of trade, if a publicly traded company, shall endeavor to recruit individuals to serve on the board of directors and the other decision-making bodies (as determined by the Commission) of the board of trade from among, and to have the composition of the bodies reflect, a broad and culturally diverse pool of qualified candidates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf25c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/d/23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"(23)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Securities and Exchange Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The board of trade shall keep any such records relating to swaps defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1a/47/A/v"},"text":"section 1a(47)(A)(v) of this title","children":[],"tail":" open to inspection and examination by the Securities and Exchange Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedcaf25d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current agricultural commodities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedcaf25e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2) of this subsection, a contract for purchase or sale for future delivery of an agricultural commodity enumerated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1a/9"},"text":"section 1a(9) of this title","children":[],"tail":" that is available for trade on a contract market, as of "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"December 21, 2000","children":[],"tail":", may be traded only on a contract market designated under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf25f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to promote responsible economic or financial innovation and fair competition, the Commission, on application by any person, after notice and public comment and opportunity for hearing, may prescribe rules and regulations to provide for the offer and sale of contracts for future delivery or options on such contracts to be conducted on a derivatives transaction execution facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idedcaf260-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369/s5"},"text":"Sept. 21, 1922, ch. 369, § 5","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tI/s110/2"},"text":"Pub. L. 106–554, § 1(a)(5) [title I, § 110(2)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–384; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVII"},"text":"Pu