{"tag":"section","attrib":{"id":"idf01ef46e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7753"},"text":null,"children":[{"tag":"num","attrib":{"value":"7753"},"text":"§ 7753.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursable agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf01ef46f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7753/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to enter into agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into reimbursable fee agreements with persons for preclearance of plants, plant products, biological control organisms, and articles at locations outside the United States for movement into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01ef470-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7753/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds collected for preclearance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds collected for preclearance shall be credited to accounts which may be established by the Secretary for this purpose and shall remain available until expended for the preclearance activities without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01ef471-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7753/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01ef472-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7753/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other law, the Secretary may pay employees of the Department of Agriculture performing services relating to imports into and exports from the United States, for all overtime, night, or holiday work performed by them, at rates of pay established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01ef473-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7753/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of the Secretary","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01ef474-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7753/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may require persons for whom the services are performed to reimburse the Secretary for any sums of money paid by the Secretary for the services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01ef475-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7753/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All funds collected under this paragraph shall be credited to the account that incurs the costs and shall remain available until expended without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01ef476-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7753/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Late payment penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01ef477-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7753/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon failure to reimburse the Secretary in accordance with this section, the Secretary may assess a late payment penalty, and the overdue funds shall accrue interest, as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3717"},"text":"section 3717 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01ef478-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7753/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any late payment penalty and any accrued interest shall be credited to the account that incurs the costs and shall remain available until expended without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf01ef479-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/tIV/s433"},"text":"Pub. L. 106–224, title IV, § 433","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/452"},"text":"114 Stat. 452","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf01ef47a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf01ef47b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idf01ef47c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of the Secretary of Agriculture relating to agricultural import and entry inspection activities under this chapter to the Secretary of Homeland Security, and for treatment of related references, see sections 231, 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
