{"tag":"section","attrib":{"id":"idf042d115-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8772"},"text":null,"children":[{"tag":"num","attrib":{"value":"8772"},"text":"§ 8772.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dairy forward pricing program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf042d116-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8772/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program under which milk producers and cooperative associations of producers are authorized to voluntarily enter into forward price contracts with milk handlers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf042d117-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8772/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum milk price requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Payments made by milk handlers to milk producers and cooperative associations of producers, and prices received by milk producers and cooperative associations, in accordance with the terms of a forward price contract authorized by subsection (a), shall be treated as satisfying—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf042d118-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8772/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all uniform and minimum milk price requirements of subparagraphs (B) and (F) of paragraph (5) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s608c"},"text":"section 608c of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf042d119-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8772/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total payment requirement of subparagraph (C) of that paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf042d11a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8772/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Milk covered by program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf042d11b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8772/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered milk","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program shall apply only with respect to the marketing of federally regulated milk that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf042d11c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8772/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not classified as Class I milk or otherwise intended for fluid use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf042d11d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8772/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the current of interstate or foreign commerce or directly burdens, obstructs, or affects interstate or foreign commerce in federally regulated milk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf042d11e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8772/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to Class I milk","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To assist milk handlers in complying with paragraph (1)(A) without having to segregate or otherwise individually track the source and disposition of milk, a milk handler may allocate milk receipts from producers, cooperatives, and other sources that are not subject to a forward contract to satisfy the obligations of the handler with regard to Class I milk usage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf042d11f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8772/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf042d120-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8772/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A milk handler may not require participation in a forward pricing contract as a condition of the handler receiving milk from a producer or cooperative association of producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf042d121-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8772/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pricing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A producer or cooperative association described in paragraph (1) may continue to have their ","children":[{"tag":"ref","attrib":{"idref":"fn002383"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002383"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “its”."}],"tail":" milk priced in accordance with the minimum payment provisions of the Federal milk marketing order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf042d122-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8772/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complaints","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf042d123-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8772/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall investigate complaints made by producers or cooperative associations of coercion by handlers to enter into forward contracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf042d124-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8772/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary finds evidence of coercion, the Secretary shall take appropriate action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf042d125-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8772/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf042d126-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8772/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No forward price contract may be entered into under the program established under this section after ","children":[{"tag":"date","attrib":{"date":"2023-09-30"},"text":"September 30, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf042d127-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8772/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No forward contract entered into under the program may extend beyond ","children":[{"tag":"date","attrib":{"date":"2029-09-30"},"text":"September 30, 2029","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf042d128-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1502"},"text":"Pub. L. 110–234, title I, § 1502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/991"},"tex