{"tag":"section","attrib":{"id":"ideec2e7c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1509"},"text":null,"children":[{"tag":"num","attrib":{"value":"1509"},"text":"§ 1509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption of indemnities from levy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Claims for indemnities under this subchapter shall not be liable to attachment, levy, garnishment, or any other legal process before payment to the insured or to deduction on account of the indebtedness of the insured or the estate of the insured to the United States except claims of the United States or the Corporation arising under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideec2e7c6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title V, § 509, "},{"tag":"ref","attrib":{"href":"/us/stat/52/75"},"text":"52 Stat. 75","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tI/s115/c"},"text":"Pub. L. 103–354, title I, § 115(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3204"},"text":"108 Stat. 3204","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXII/s12033/c/2/B"},"text":"Pub. L. 110–234, title XII, § 12033(c)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1405"},"text":"122 Stat. 1405","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XII, § 12033(c)(2)(B), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008"