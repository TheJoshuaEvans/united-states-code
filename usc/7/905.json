{"tag":"section","attrib":{"id":"idee59ec14-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s905"},"text":null,"children":[{"tag":"num","attrib":{"value":"905"},"text":"§ 905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees for certain loan guarantees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee59ec15-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For electrification baseload generation loan guarantees, the Secretary shall, at the request of the borrower, charge an upfront fee to cover the costs of the loan guarantee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee59ec16-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fee described in subsection (a) for a loan guarantee shall be equal to the costs of the loan guarantee (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a/5/C"},"text":"section 661a(5)(C) of title 2","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee59ec17-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds received from a borrower to pay the fee described in this section shall not be derived from a loan or other debt obligation that is made or guaranteed by the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee59ec18-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title I, § 5, as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVI/s6101"},"text":"Pub. L. 113–79, title VI, § 6101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/850"},"text":"128 Stat. 850","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee59ec19-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee59ec1a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee59ec1b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 905, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title I, § 5, "},{"tag":"ref","attrib":{"href":"/us/stat/49/1365"},"text":"49 Stat. 1365","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1944-09-21/ch412"},"text":"Sept. 21, 1944, ch. 412","children":[],"tail":", title V, § 502(b), "},{"tag":"ref","attrib":{"href":"/us/stat/58/739"},"text":"58 Stat. 739","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-10-28/ch776/s2"},"text":"Oct. 28, 1949, 