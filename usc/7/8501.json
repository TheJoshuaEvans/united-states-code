{"tag":"section","attrib":{"id":"idf03ba49e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8501"},"text":null,"children":[{"tag":"num","attrib":{"value":"8501"},"text":"§ 8501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03ba49f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Brown tree snake","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “brown tree snake” means the species of the snake Boiga irregularis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03ba4a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compact of Free Association","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Compact of Free Association” means the Compacts of Free Association entered into between the United States and the governments of the Federated States of Micronesia and the Republic of the Marshall Islands, as approved by and contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/188"},"text":"Public Law 108–188","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/117/2720"},"text":"117 Stat. 2720","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1921"},"text":"48 U.S.C. 1921","children":[],"tail":" et seq.), and the Compact of Free Association entered into between the United States and the government of the Republic of Palau, as approved by and contained in "},{"tag":"ref","attrib":{"href":"/us/pl/99/658"},"text":"Public Law 99–658","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/100/3673"},"text":"100 Stat. 3673","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1931"},"text":"48 U.S.C. 1931","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03ba4a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Freely Associated States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Freely Associated States” means the Republic of Palau, the Federated States of Micronesia, and the Republic of the Marshall Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03ba4a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8501/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Introduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “introduce” and “introduction” refer to the expansion of the brown tree snake outside of the range where this species is endemic.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03ba4a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8501/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Secretary concerned” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03ba4a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8501/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior, with respect to matters under the jurisdiction of the Department of the Interior; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03ba4a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8501/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, with respect to matters under the jurisdiction of the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03ba4a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8501/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretaries” means both the Secretary of the Interior and the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03ba4a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8501/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical Working Group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Technical Working Group” means Brown Tree Snake Technical Working Group established under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4728"},"text":"section 4728 of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03ba4a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8501/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territorial","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “territorial”, when used to refer to a government, means the Government of Guam, the Government of American Samoa, and the Government of the Commonwealth of the Northern Mariana Islands, as well as autonomous agencies and instrumentalities of such a government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03ba4a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8501/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States”, when used in the geographic sense, means the several States, the District of Colombia,","children":[{"tag":"ref","attrib":{"idref":"fn002372"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002372"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Columbia,”."}],"tail":" American Samoa, Guam, the Commonwealth of the Northern Mariana Islands, the Commonwealth of Puerto Rico, the United States Virgin Islands, any other possession of the United States, and any waters within the jurisdiction of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf03ba4aa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/384/s2"},"text":"Pub. L. 108–384, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},