{"tag":"section","attrib":{"id":"ideefc1fcc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1769"},"text":null,"children":[{"tag":"num","attrib":{"value":"1769"},"text":"§ 1769.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Agricultural commodity” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The term “agricultural commodity” as used in this chapter includes any agricultural commodity or product thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideefc1fcd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-28/ch1041"},"text":"Aug. 28, 1954, ch. 1041","children":[],"tail":", title VI, § 609, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/501/tIV/s401/6"},"text":"Pub. L. 95–501, title IV, § 401(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-21"},"text":"Oct. 21, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1691"},"text":"92 Stat. 1691","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
