{"tag":"section","attrib":{"id":"idef034c35-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1925"},"text":null,"children":[{"tag":"num","attrib":{"value":"1925"},"text":"§ 1925.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on amount of farm ownership loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef034c36-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1925/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make or insure no loan under sections 1922, 1923, 1924, 1934, and 1935 of this title that would cause the unpaid indebtedness under such sections of any one borrower to exceed the smaller of (1) the value of the farm or other security, or (2) in the case of a loan other than a loan guaranteed by the Secretary, $600,000, or, in the case of a loan guaranteed by the Secretary, $1,750,000 (increased, beginning with fiscal year 2019, by the inflation percentage applicable to the fiscal year in which the loan is guaranteed and reduced by the amount of any unpaid indebtedness of the borrower on loans under subchapter II that are guaranteed by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef034c37-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1925/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of value","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the value of the farm, the Secretary shall consider appraisals made by competent appraisers under rules established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef034c38-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1925/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation percentage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the inflation percentage applicable to a fiscal year is the percentage (if any) by which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef034c39-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1925/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average of the Prices Paid By Farmers Index (as compiled by the National Agricultural Statistics Service of the Department of Agriculture) for the 12-month period ending on July 31 of the immediately preceding fiscal year; exceeds","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef034c3a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1925/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average of such index (as so defined) for the 12-month period that immediately precedes the 12-month period described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef034c3b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s305"},"text":"Pub. L. 87–128, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/308"},"text":"75 Stat. 308","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/620/s1"},"text":"Pub. L. 91–620, § 1","children":[],"tail":",