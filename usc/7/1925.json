“$300,000”, designated second sentence as subsec. (b) and inserted heading, and added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/554"},"text":"Pub. L. 102–554","children":[],"tail":" inserted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1935"},"text":"section 1935 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/334"},"text":"Pub. L. 95–334","children":[],"tail":" substituted provisions setting forth requirements for loans under sections 1922, 1923, 1924, and 1934 of this title for provisions setting forth requirements for loans under sections 1922, 1923, and 1924 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/524/s807"},"text":"Pub. L. 91–524, § 807","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/93/86"},"text":"Pub. L. 93–86","children":[],"tail":", substituted “$225,000” for “$100,000” in cl. (a), added cl. (b), and redesignated former cl. (b) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/419"},"text":"Pub. L. 92–419","children":[],"tail":" struck out “normal” before “value” in first and second sentences and before “market value” in last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/620"},"text":"Pub. L. 91–620","children":[],"tail":" substituted “$100,000” for “$60,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef034c40-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attr