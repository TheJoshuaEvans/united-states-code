b":{"href":"/us/usc/t7/s361a–361i"},"text":"7 U.S.C. 361a–361i","children":[],"tail":"), is excluded and is provided for in subsection (b) of this section, such sums as may be necessary for each of fiscal years 1991 through 2023."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa7c90e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural research at State agricultural experiment stations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any authorization for appropriations for agricultural research at State agricultural experiment stations in any Act enacted prior to ","children":[{"tag":"date","attrib":{"date":"1977-09-29"},"text":"September 29, 1977","children":[],"tail":", there are authorized to be appropriated for the purpose of conducting agricultural research at State agricultural experiment stations pursuant to the Act of "},{"tag":"date","attrib":{"date":"1887-03-02"},"text":"March 2, 1887","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/24/440-442"},"text":"24 Stat. 440–442","children":[],"tail":", as amended; "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s361a–361i"},"text":"7 U.S.C. 361a–361i","children":[],"tail":"), such sums as may be necessary for each of fiscal years 1991 through 2023."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa7c90f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3311/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding requirements for programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law effe