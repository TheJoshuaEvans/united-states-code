{"tag":"section","attrib":{"id":"idefa30db0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222b–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"3222b–2"},"text":"§ 3222b–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to upgrade agriculture and food sciences facilities and equipment and support tropical and subtropical agricultural research at insular area land-grant colleges and universities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa30db1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222b–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the intent of Congress to assist the land-grant colleges and universities in the insular areas in efforts to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa30db2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222b–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire, alter, or repair facilities or relevant equipment necessary for conducting agricultural research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa30db3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222b–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support tropical and subtropical agricultural research, including pest and disease research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa30db4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222b–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of awarding grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants awarded pursuant to this section shall be made in such amounts and under such terms and conditions as the Secretary determines necessary to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa30db5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222b–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may promulgate such rules and regulations as the Secretary considers to be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa30db6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222b–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $8,000,000 for each of fiscal years 2008 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa30db7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1447B"},"text":"Pub. L. 95–113, title XIV, § 1447B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7125"},"text":"Pub. L. 110–234, title VII, § 7125","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":