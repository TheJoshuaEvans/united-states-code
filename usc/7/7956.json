{"tag":"section","attrib":{"id":"idf02891e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7956"},"text":null,"children":[{"tag":"num","attrib":{"value":"7956"},"text":"§ 7956.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planting flexibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf02891e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7956/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitted crops","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), any commodity or crop may be planted on the base acres for peanuts on a farm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02891e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7956/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations regarding certain commodities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02891ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7956/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The planting of an agricultural commodity specified in paragraph (2) shall be prohibited on base acres for peanuts unless the commodity, if planted, is destroyed before harvest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02891eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7956/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of trees and other perennials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The planting of an agricultural commodity specified in paragraph (3) that is produced on a tree or other perennial plant shall be prohibited on base acres for peanuts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02891ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7956/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered agricultural commodities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraphs (1) and (2) apply to the following agricultural commodities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02891ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7956/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fruits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02891ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7956/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Vegetables (other than lentils, mung beans, and dry peas).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02891ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7956/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Wild rice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02891f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7956/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraphs (1) and (2) of subsection (b) shall not limit the planting of an agricultural commodity specified in paragraph (3) of that subsection—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02891f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7956/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any region in which there is a history of double-cropping of peanuts with agricultural commodities specified in subsection (b)(3), as determined by the Secretary, in which case the double-cropping shall be permitted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02891f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7956/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a farm that the Secretary determines has a history of planting agricultural commodities specified in subsection (b)(3) on the base acres for peanuts, except that direct payments and counter-cyclical payments shall be reduced by an acre for each acre planted to such an agricultural commodity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02891f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7956/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" by the producers on a farm that the Secretary determines has an established planting history of a specific agricultural commodity specified in subsection (b)(3), except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02891f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7956/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity planted may not exceed the average annual planting history of such agricultural commodity by the producers on the farm in the 1991 through 1995 or 1998 through 2001 crop years (excluding any crop year in which no plantings were made), as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02891f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7956/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct payments and counter-cyclical payments shall be reduced by an acre for each acre planted to such agricultural commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf02891f6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1306"},"text":"Pub. L. 107–171, title I, § 1306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/174"},"text":"116 Stat. 174","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
