{"tag":"section","attrib":{"id":"idef8414c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2481"},"text":null,"children":[{"tag":"num","attrib":{"value":"2481"},"text":"§ 2481.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plant variety protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8414c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2481/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If it appears that a certificate of plant variety protection should be issued on an application, a written notice of allowance shall be given or mailed to the owner. The notice shall specify the sum, constituting the issue fee, which shall be paid within one month thereafter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8414c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2481/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon timely payment of this sum, and provided that deposit of seed has been made in accordance with section 2422(3) ","children":[{"tag":"ref","attrib":{"idref":"fn002260"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002260"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, the certificate of plant variety protection shall issue."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8414ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2481/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If any payment required by this section is not timely made, but is submitted with an additional fee prescribed by the Secretary within nine months after the due date or within such further time as the Secretary may allow, it shall be accepted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8414cb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tII/s81"},"text":"Pub. L. 91–577, title II, § 81","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1551"},"text":"84 Stat. 1551","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8414cc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef8414cd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef8414ce-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2422/3"},"text":"Section 2422(3) of this title","children":[],"tail":", referred to in subsec. (b), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2422/4"},"text":"section 2422(4) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/103/349/s4"},"text":"Pub. L. 103–349, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-06"},"text":"Oct. 6, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3139"},"text":"108 Stat. 3139","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
