{"tag":"section","attrib":{"id":"idf034782c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8115"},"text":null,"children":[{"tag":"num","attrib":{"value":"8115"},"text":"§ 8115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carbon utilization and biogas education program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf034782d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf034782e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8115/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carbon dioxide","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “carbon dioxide” means carbon dioxide that is produced as a byproduct of the production of a biobased product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf034782f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8115/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means an entity that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0347830-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8115/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0347831-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8115/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":" and exempt from taxation under section 501(a) of that title; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0347832-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8115/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"section 1001(a) of title 20","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0347833-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8115/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has demonstrated knowledge about—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0347834-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8115/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sequestration and utilization of carbon dioxide; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0347835-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8115/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aggregation of organic waste from multiple sources into a single biogas system; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0347836-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8115/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a demonstrated ability to conduct educational and technical support programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0347837-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Secretary of Energy, shall make competitive grants to eligible entities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0347838-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8115/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide education to the public about the economic and emissions benefits of permanent sequestration or utilization of carbon dioxide with a primary objective of providing benefits and opportunities for rural businesses, rural communities, and utilities serving rural communities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0347839-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8115/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide education to agricultural producers and other stakeholders about opportunities for aggregation of organic waste from multiple sources into a single biogas system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf034783a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8115/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated for each of fiscal years 2019 through 2023—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf034783b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8115/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 to carry out subsection (b)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf034783c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8115/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 to carry out subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf034783d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIX/s9014"},"text":"Pub. L. 107–171, title IX, § 9014","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIX/s9011"},"text":"Pub. L. 115–334, title IX, § 9011","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4887"},"text":"132 Stat. 4887","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
