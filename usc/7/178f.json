{"tag":"section","attrib":{"id":"idee1987d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s178f"},"text":null,"children":[{"tag":"num","attrib":{"value":"178f"},"text":"§ 178f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance from States and public agencies; contracts and agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretaries are authorized to accept financial or other assistance from any State or public agency to aid in carrying out the provisions of this subchapter and to enter into contracts with respect to such assistance and to enter into agreements with any State or public agency for the purpose of demonstrating, transferring, or applying results of research or methods of economic development relating to native latex or to other critical agricultural materials.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee1987d6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/592/s8"},"text":"Pub. L. 95–592, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-04"},"text":"Nov. 4, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2532"},"text":"92 Stat. 2532","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/284/s8"},"text":"Pub. L. 98–284, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-05-16"},"text":"May 16, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/183"},"text":"98 Stat. 183","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee1987d7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee1987d8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee1987d9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/284"},"text":"Pub. L. 98–284","children":[],"tail":" inserted “or to other critical agricultural materials”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
