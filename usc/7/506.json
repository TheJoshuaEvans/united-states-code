{"tag":"section","attrib":{"id":"idee3af2fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s506"},"text":null,"children":[{"tag":"num","attrib":{"value":"506"},"text":"§ 506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns under oath; administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The returns provided for in this chapter shall be made under oath before a collector or deputy collector of internal revenue, a postmaster, assistant postmaster, or anyone authorized to administer oaths by State or Federal law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee3af2fd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1929-01-14/ch69/s6"},"text":"Jan. 14, 1929, ch. 69, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1080"},"text":"45 Stat. 1080","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee3af2fe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idee3af2ff-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idee3af300-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Offices and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"See note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s505"},"text":"section 505 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
