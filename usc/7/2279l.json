{"tag":"section","attrib":{"id":"idef81a33c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279l"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279l"},"text":"§ 2279l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Detector Dog Training Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef81a33d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a National Detector Dog Training Center (referred to in this section as the “Center”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef81a33e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Center shall have the following duties:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef81a33f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279l/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training dogs for the purpose of safeguarding domestic agricultural and natural resources from foreign and invasive pests and diseases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef81a340-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279l/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training human handlers to successfully select and train dogs for the purpose described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef81a341-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279l/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Collaborating with relevant Federal agencies, including U.S. Customs and Border Protection, to safeguard domestic agricultural and natural resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef81a342-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279l/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Collaborating with external stakeholders, including State departments of agriculture, local and county agricultural officials, private sector entities, and other relevant non-Federal partners.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef81a343-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279l/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ensuring the health and welfare of all dogs under the care of the Center, including by ensuring access to necessary veterinary care, adequate shelter, and proper nutrition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef81a344-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279l/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing opportunities for private adoption of retirement-age trained dogs and dogs that do not complete training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef81a345-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279l/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other duties necessary to safeguard domestic agricultural and natural resources from foreign and invasive pests and diseases, as determined by the Secretary of Agriculture, acting through the Administrator of the Animal and Plant Health Inspection Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef81a346-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/191/s2"},"text":"Pub. L. 118–191, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2658"},"text":"138 Stat. 2658","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef81a347-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef81a348-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef81a349-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/191"},"text":"Pub. L. 118–191","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2658"},"text":"138 Stat. 2658","children":[],"tail":", which enacted this section, provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2201"},"text":"section 2201 of this title","children":[],"tail":", and provisions relating to reporting requirements that are not set out in the Code. For complete classification of this Act to the Code, see Short Title of 2024 note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2201"},"text":"section 2201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
