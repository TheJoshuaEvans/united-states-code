{"tag":"section","attrib":{"id":"idedf11838-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"87f–1"},"text":"§ 87f–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idedf11839-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide, by regulation, for the registration of all persons engaged in the business of buying grain for sale in foreign commerce, and in the business of handling, weighing, or transporting of grain for sale in foreign commerce. This section shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedf1183a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person who only incidentally or occasionally buys for sale, or handles, weighs, or transports grain for sale and is not engaged in the regular business of buying grain for sale, or handling, weighing, or transporting grain for sale;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedf1183b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any producer of grain who only incidentally or occasionally sells or transports grain which the producer has purchased;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedf1183c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person who transports grain for hire and does not own a financial interest in such grain; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedf1183d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person who buys grain for feeding or processing and not for the purpose of reselling and only incidentally or occasionally sells such grain as grain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf1183e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedf1183f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" All persons required to register under this chapter shall submit the following information to the Secretary:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedf11840-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and principal address of the business,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedf11841-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the names of all directors of such business,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedf11842-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–1/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the names of the principal officers of such business,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedf11843-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–1/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the names of all persons in a control relationship with respect to such business,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedf11844-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–1/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of locations where the business conducts substantial operations, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedf11845-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–1/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary deems necessary to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Persons required to register under this section shall also submit to the Secretary the information specified in clauses (A) through (F) of this paragraph with respect to any business engaged in the business of buying grain for sale in interstate commerce, and in the business of handling, weighing, or transporting of grain for sale in interstate commerce, if, with respect to such business, the person otherwise required to register under this section is in a control relationship.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedf11846-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purposes of this section, a person shall be deemed to be in a “control relationship” with respect to a business required to register under subsection (a) and with respect to applicable interstate businesses if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedf11847-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person has an ownership interest of 10 per centum or more in such business, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedf11848-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a business or group of business entities, with respect to which such person is in a control relationship, has an ownership interest of 10 per centum or more in such business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedf11849-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of clauses (A) and (B) of paragraph (2) of this subsection, a person shall be considered to own the ownership interest which is owned by his or her spouse, minor children, and relatives living in the same household.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf1184a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certificate of registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue a certificate of registration to persons who comply with the provisions of this section. The certificate of registration issued in accordance with this section shall be renewed annually. If there has been any change in the information required under subsection (b), the person holding such certificate shall, within thirty days of the discovery of such change, notify the Secretary of such change. No person shall engage in the business of buying grain for sale in foreign commerce, and in the business of handling, weighing, or transporting of grain in foreign commerce unless the person has registered with the Secretary as required by this chapter and has an unsuspended and unrevoked certificate of registration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf1184b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension or registration of certificate of registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may suspend or revoke any certificate of registration issued under this section whenever, after the person holding such certificate has been afforded an opportunity for a hearing in accordance with sections 554, 556, and 557 of title 5, the Secretary shall determine that such person has violated any provision of this chapter or of the regulations promulgated thereunder, or has been convicted of any violation involving the handling, weighing, or inspection of grain under title 18.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf1184c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall charge and collect fees from any person registered under this section. The amount of such fees shall be determined on the basis of the costs of the Secretary in administering the registration required by this section. Such fees shall be deposited in, and used as part of, the fund described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s79/j"},"text":"section 79(j) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idedf1184d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. B, § 17A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/582/s22"},"text":"Pub. L. 94–582, § 22","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2886"},"text":"90 Stat. 2886","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXVI/s1604"},"text":"Pub. L. 95–113, title XVI, § 1604","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1029"},"text":"91 Stat. 1029","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/156/s12/p"},"text":"Pub. L. 103–156, § 12(p)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-24"},"text":"Nov. 24, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1529"},"text":"107 Stat. 1529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s293/a/7"},"text":"Pub. L. 103–354, title II, § 293(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3237"},"text":"108 Stat. 3237","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idedf1184e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idedf1184f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idedf11850-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsecs. (a), (b)(1), (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/156/s12/p"},"text":"Pub. L. 103–156, § 12(p)","children":[],"tail":", which directed amendment of “Section 17A”, without specifying the name of the Act being amended, was executed to this section, which is section 17A of the United States Grain Standards Act, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/156/s12/p/1"},"text":"Pub. L. 103–156, § 12(p)(1)","children":[],"tail":", substituted “the producer” for “he”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/156/s12/p/2"},"text":"Pub. L. 103–156, § 12(p)(2)","children":[],"tail":", substituted “the person” for “he” in last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113"},"text":"Pub. L. 95–113","children":[],"tail":" substituted “All persons required to register” for “All persons registered” in provisions preceding subpar. (A)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idedf11851-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idedf11852-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113"},"text":"Pub. L. 95–113","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/s1901"},"text":"section 1901 of Pub. L. 95–113","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1307"},"text":"section 1307 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idedf11853-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 30 days after ","children":[{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/582/s27"},"text":"section 27 of Pub. L. 94–582","children":[],"tail":", as amended, set out as an Effective Date of 1976 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s74"},"text":"section 74 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
