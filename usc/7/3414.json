{"tag":"section","attrib":{"id":"idefaef4d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3414"},"text":null,"children":[{"tag":"num","attrib":{"value":"3414"},"text":"§ 3414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other programs relating to wheat or wheat food research or nutrition education","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to preempt or interfere with the workings of any other program relating to wheat or wheat foods research or nutrition education organized and operating under the laws of the United States or any State.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefaef4d1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXVII/s1715"},"text":"Pub. L. 95–113, title XVII, § 1715","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1040"},"text":"91 Stat. 1040","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefaef4d2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefaef4d3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefaef4d4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/u