{"tag":"section","attrib":{"id":"idf0512855-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a"},"text":null,"children":[{"tag":"num","attrib":{"value":"9071a"},"text":"§ 9071a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dairy donation program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0512856-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0512857-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible dairy organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible dairy organization” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9071/a"},"text":"section 9071(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0512858-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible dairy product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible dairy product” means a product primarily made from milk, including fluid milk, that is produced and processed in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0512859-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible distributor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible distributor” means a public or private nonprofit organization that distributes donated eligible dairy products to recipient individuals and families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf051285a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible partnership” means a partnership between an eligible dairy organization and an eligible distributor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf051285b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall establish and administer a dairy donation program for the purposes of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf051285c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating the timely donation of eligible dairy products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf051285d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing and minimizing food waste.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf051285e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donation and distribution plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf051285f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive reimbursement under subsection (d), an eligible partnership shall submit to the Secretary a donation and distribution plan that describes the process that the eligible partnership will use for the donation, processing, transportation, temporary storage, and distribution of eligible dairy products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0512860-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and approval","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0512861-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 15 business days after receiving a plan described in paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0512862-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review that plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0512863-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue an approval or disapproval of that plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0512864-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency and disaster-related prioritization","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0512865-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In receiving and reviewing a donation and distribution plan submitted under paragraph (1), the Secretary shall determine whether an emergency or disaster was a substantial factor in the submission, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf0512866-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/c/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a declared or renewed public health emergency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d"},"text":"section 247d of title 42","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0512867-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/c/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a disaster designated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0512868-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On making an affirmative determination under clause (i) with respect to a donation and distribution plan submitted under paragraph (1), the Secretary shall give priority to the approval or disapproval of that plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0512869-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf051286a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On receipt of appropriate documentation under paragraph (3), the Secretary shall reimburse an eligible dairy organization that is a member of an eligible partnership for which the Secretary has approved a donation and distribution plan under subsection (c)(2)(A)(ii) at a rate equal to the product obtained by multiplying—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf051286b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current reimbursement price described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf051286c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the volume of milk required to make the donated eligible dairy product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf051286d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement price","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf051286e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall set the reimbursement price referred to in paragraph (1)(A) at a value that shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf051286f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be representative of the cost of the milk required to make the donated eligible dairy product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0512870-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be between the lowest and highest of the class I, II, III, or IV milk prices on the date of the production of the eligible dairy product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0512871-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be sufficient to avoid food waste; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0512872-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not interfere with the commercial marketing of milk or dairy products;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0512873-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may set appropriate reimbursement prices under subparagraph (A) for different eligible dairy products by class and region for the purpose of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0512874-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging the donation of surplus eligible dairy products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0512875-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating the orderly marketing of milk;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0512876-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing volatility relating to significant market disruptions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0512877-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining traditional price relationships between classes of milk; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0512878-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stabilizing on-farm milk prices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0512879-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documentation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf051287a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible dairy organization shall submit to the Secretary such documentation as the Secretary may require to demonstrate—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf051287b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production of the eligible dairy product; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf051287c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the donation of the eligible dairy product to an eligible distributor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf051287d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may verify the accuracy of documentation submitted under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf051287e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retroactive reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing reimbursements under paragraph (1), the Secretary may provide reimbursements for eligible dairy product costs incurred before the date on which the donation and distribution plan for the applicable participating partnership was approved by the Secretary under subsection (c)(2)(A)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf051287f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency and disaster-related prioritization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing reimbursements under paragraph (1), the Secretary shall give priority to reimbursements to eligible dairy organizations covered by a donation and distribution plan for which the Secretary makes an affirmative determination under subsection (c)(2)(B)(i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0512880-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on resale of products","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0512881-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible distributor that receives eligible dairy products donated under this section may not sell the eligible dairy products into commercial markets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0512882-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on future participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible distributor that the Secretary determines has violated paragraph (1) shall not be eligible for any future participation in the program established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0512883-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviews","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct appropriate reviews or audits to ensure the integrity of the program established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0512884-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of donation activity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Administrator of the Agricultural Marketing Service, shall publish on the publicly accessible website of the Agricultural Marketing Service periodic reports describing donation activity under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0512885-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental reimbursements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0512886-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make a supplemental reimbursement to an eligible dairy organization that received a reimbursement under the milk donation program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9071"},"text":"section 9071 of this title","children":[],"tail":" during the period beginning on "},{"tag":"date","attrib":{"date":"2020-01-01"},"text":"January 1, 2020","children":[],"tail":", and ending on the date on which amounts made available under subsection (i) are no longer available."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0512887-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement calculation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A supplemental reimbursement described in paragraph (1) shall be an amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0512888-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reimbursement calculated under subsection (d); minus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0512889-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reimbursement under the milk donation program described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf051288a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of any amounts of the Treasury not otherwise appropriated, there is appropriated to the Secretary to carry out this section $400,000,000, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf051288b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tVII/s762"},"text":"Pub. L. 116–260, div. N, title VII, § 762","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2111"},"text":"134 Stat. 2111","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf051288c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf051288d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf051288e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Consolidated Appropriations Act, 2021, and not as part of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" which comprises this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf051288f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idf0512890-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “Secretary” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/s760"},"text":"section 760 of div. N of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s5936a"},"text":"section 5936a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
