{"tag":"section","attrib":{"id":"idefaef542-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3601"},"text":null,"children":[{"tag":"num","attrib":{"value":"3601"},"text":"§ 3601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefaef543-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3601/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Agreement” means the International Sugar Agreement, 1977, signed at New York City on ","children":[{"tag":"date","attrib":{"date":"1977-12-09"},"text":"December 9, 1977","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefaef544-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3601/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “sugar” has the same meaning as is given to such term in paragraph (12) of Article 2 of the Agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefaef545-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3601/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “entry” means entry, or withdrawal from warehouse, for consumption in the customs territory of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefaef546-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/236/s1"},"text":"Pub. L. 96–236, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-22"},"text":"Apr. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/336"},"text":"94 Stat. 336","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
