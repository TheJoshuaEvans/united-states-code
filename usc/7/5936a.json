{"tag":"section","attrib":{"id":"idefd78ba3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5936a"},"text":"§ 5936a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for farm stress programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefd78ba4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make grants to State departments of agriculture (or such equivalent department) to expand or sustain stress assistance programs for individuals who are engaged in farming, ranching, and other agriculture-related occupations, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd78ba5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs that meet the criteria specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5936/b/1"},"text":"section 5936(b)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78ba6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State initiatives carried out as of ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", that provide stress assistance for such individuals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd78ba7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant timing and amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants under subsection (a), not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", and subject to subsection (c), the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd78ba8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make awards to States submitting State plans that meet the criteria specified in paragraph (1) of such subsection within the time period specified by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78ba9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the amounts made available under subsection (f), allocate among such States, an amount to be determined by the Secretary, which in no case may exceed $500,000 for each State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd78baa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd78bab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State department of agriculture seeking a grant under subsection (a) shall submit to the Secretary a State plan to expand or sustain stress assistance programs described in that subsection that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd78bac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of each activity and the estimated amount of funding to support each program and activity carried out through such a program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd78bad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimated timeline for the operation of each such program and activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd78bae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of funding sought; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd78baf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the State department of agriculture will comply with the reporting requirement under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78bb0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 20 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall issue guidance for States with respect to the submission of a State plan under paragraph (1) and the allocation criteria under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78bb1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, after the first grants are awarded pursuant to allocation under subsection (b), any funds made available under subsection (f) to carry out this subsection remain unobligated, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd78bb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform States that submit plans as described in subsection (b), of such availability; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd78bb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reallocate such funds among such States, as the Secretary determines to be appropriate and equitable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd78bb4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may issue guidance to encourage State departments of agriculture to use funds provided under this section to support programs described in subsection (a) that are operated by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd78bb5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian tribes (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78bb6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State cooperative extension services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78bb7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nongovernmental organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd78bb8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the COVID–19 public health emergency ends, each State receiving additional grants under subsection (b) shall submit a report to the Secretary describing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd78bb9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities conducted using such funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78bba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funds used to support each such activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78bbb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated number of individuals served by each such activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd78bbc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of the funds of the Treasury not otherwise appropriated, there is appropriated to carry out this section $28,000,000, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd78bbd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “State” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd78bbe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78bbf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78bc0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commonwealth of Puerto Rico; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78bc1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936a/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefd78bc2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tVII/s766"},"text":"Pub. L. 116–260, div. N, title VII, § 766","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2118"},"text":"134 Stat. 2118","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefd78bc3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefd78bc4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefd78bc5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Consolidated Appropriations Act, 2021, and not as part of subtitle H of title XVI of the Food, Agriculture, Conservation, and Trade Act of 1990 which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefd78bc6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idefd78bc7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tVII/s760"},"text":"Pub. L. 116–260, div. N, title VII, § 760","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2109"},"text":"134 Stat. 2109","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dN/tVII/s760"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this chapter [chapter 2 (§§ 760–766) of subtitle B of title VII of div. N of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":", enacting this section and sections 217b and 9071a of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s473"},"text":"section 473 of Title 21","children":[],"tail":", Food and Drugs, and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9056"},"text":"section 9056 of this title","children":[],"tail":"]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘COVID–19’ means the disease caused by SARS–CoV–2, or any viral strain mutating therefrom with pandemic potential.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘COVID–19 public health emergency’ means the public health emergency declared by the Secretary of Health and Human Services under section 319 of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d"},"text":"42 U.S.C. 247d","children":[],"tail":") on "},{"tag":"date","attrib":{"date":"2020-01-31"},"text":"January 31, 2020","children":[],"tail":", with respect to COVID–19 (or any renewal of that declaration)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘Secretary’ means the Secretary of Agriculture.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
