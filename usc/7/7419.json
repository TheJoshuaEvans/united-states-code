{"tag":"section","attrib":{"id":"idf0099810-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7419"},"text":null,"children":[{"tag":"num","attrib":{"value":"7419"},"text":"§ 7419.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0099811-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7419/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The district courts of the United States shall have jurisdiction specifically to enforce, and to prevent and restrain a person from violating, an order or regulation issued under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0099812-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7419/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referral to Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A civil action authorized to be brought under this section shall be referred to the Attorney General for appropriate action, except that the Secretary shall not be required to refer to the Attorney General a violation of this subchapter if the Secretary believes that the administration and enforcement of this subchapter would be adequately served by providing a suitable written notice or warning to the person who committed the violation or by an administrative action under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0099813-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7419/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties and orders","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0099814-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7419/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person who willfully violates an order or regulation issued by the Secretary under this subchapter may be assessed by the Secretary a civil penalty of not less than $1,000 and not more than $10,000 for each violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099815-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7419/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate offense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each violation and each day during which there is a failure to comply with an order or regulation issued by the Secretary shall be considered to be a separate offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099816-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7419/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cease-and-desist orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to, or in lieu of, a civil penalty, the Secretary may issue an order requiring a person to cease and desist from violating the order or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099817-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7419/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No order assessing a penalty or cease-and-desist order may be issued by the Secretary under this subsection unless the Secretary provides notice and an opportunity for a hearing on the record with respect to the violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099818-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7419/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An order assessing a penalty or a cease-and-desist order issued under this subsection by the Secretary shall be final and conclusive unless the person against whom the order is issued files an appeal from the order with the United States court of appeals, as provided in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0099819-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7419/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review by court of appeals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf009981a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7419/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person against whom an order is issued under subsection (c) may obtain review of the order by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf009981b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7419/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" filing, not later than 30 days after the person receives notice of the order, a notice of appeal in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf009981c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7419/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States court of appeals for the circuit in which the person resides or carries on business; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf009981d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7419/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Court of Appeals for the District of Columbia Circuit; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf009981e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7419/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" simultaneously sending a copy of the notice of appeal by certified mail to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf009981f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7419/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Record","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall file with the court a certified copy of the record on which the Secretary has determined that the person has committed a violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099820-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7419/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard of review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A finding of the Secretary under this section shall be set aside only if the finding is found to be unsupported by substantial evidence on the record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0099821-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7419/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to obey cease-and-desist orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person who fails to obey a valid cease-and-desist order issued by the Secretary under this section, after an opportunity for a hearing, shall be subject to a civil penalty assessed by the Secretary of not less than $1,000 and not more than $10,000 for each offense. Each day during which the failure continues shall be considered to be a separate violation of the cease-and-desist order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0099822-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7419/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to pay penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a person fails to pay a civil penalty imposed under this section by the Secretary, the Secretary shall refer the matter to the Attorney General for recovery of the amount assessed in the district court of the United States for any district in which the person resides or carries on business. In the action, the validity and appropriateness of the order imposing the civil penalty shall not be subject to review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0099823-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7419/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional remedies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The remedies provided in this section shall be in addition to, and not exclusive of, other remedies that may be available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0099824-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s520"},"text":"Pub. L. 104–127, title V, § 520","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1045"},"text":"110 Stat. 1045","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0099825-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0099826-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf0099827-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (c)(1), was in the original “this Act” and was translated as reading “this subtitle”, meaning subtitle B (§§ 511–526) of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1032"},"text":"110 Stat. 1032","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
