{"tag":"section","attrib":{"id":"idef7a77cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2257"},"text":null,"children":[{"tag":"num","attrib":{"value":"2257"},"text":"§ 2257.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interchangeability of funds for miscellaneous expenses and general expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not to exceed 7 per centum of the amounts appropriated for any fiscal year for the miscellaneous expenses of the work of any bureau, division, or office of the Department of Agriculture shall be available interchangeably for expenditures on the objects included within the general expenses of such bureau, division, or office, but no more than 7 per centum shall be added to any one item of appropriation except in cases of extraordinary emergency.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef7a77cc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-09-21/ch412"},"text":"Sept. 21, 1944, ch. 412","children":[],"tail":", title VII, § 702(b), "},{"tag":"ref","attrib":{"href":"/us/stat/58/741"},"text":"58 Stat. 741","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7a77cd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef7a77ce-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef7a77cf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section was enacted as part of the Department of Agriculture Organic Act of 1944.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s572"},"text":"section 572 of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
