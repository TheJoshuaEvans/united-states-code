{"tag":"section","attrib":{"id":"idee3fadb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s599"},"text":null,"children":[{"tag":"num","attrib":{"value":"599"},"text":"§ 599.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"When used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee3fadb4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s599/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” includes individuals, partnerships, corporations, and associations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3fadb5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s599/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3fadb6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s599/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided herein, the term “foreign commerce” means commerce between any State, or the District of Columbia, and any place outside of the United States or its possessions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3fadb7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s599/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “grapes” means vinifera species table grapes, European type, whether or not they have been in storage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3fadb8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s599/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “plums” means both European and Japanese type, whether or not they have been in storage, but does not mean Italian-type prunes, nor damson-type plums.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee3fadb9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/687/s9"},"text":"Pub. L. 86–687, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-02"},"text":"Sept. 2, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/735"},"text":"74 Stat. 735","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
