{"tag":"section","attrib":{"id":"ideef9ae8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738i"},"text":null,"children":[{"tag":"num","attrib":{"value":"1738i"},"text":"§ 1738i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enterprise for the Americas Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideef9ae8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a board to be known as the “Enterprise for the Americas Board” (hereafter referred to in this subchapter as the “Board”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9ae8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership and chairperson","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef9ae8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall be composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideef9ae90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738i/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" six representatives from the United States Government, at least one of whom shall be a representative of the Department of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef9ae91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738i/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" five representatives from private nongovernmental environmental, child survival and child development, community development, scientific, and academic organizations with experience and expertise in Latin America and the Caribbean, at least one of whom shall be a representative from a child survival and child development organization;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to be appointed by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9ae92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall be headed by a chairperson who shall be appointed by the President from among the representatives appointed under paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9ae93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef9ae94-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738i/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the President on the negotiations for the environmental framework agreements described in subsections (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738f"},"text":"section 1738f of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9ae95-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738i/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure, in consultation with the government of the appropriate eligible country, with nongovernmental organizations of such eligible country, and if appropriate, of the region, and with environmental, scientific, and academic leaders of such eligible country and, as appropriate, of the region, that a suitable body referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738f/c"},"text":"section 1738f(c) of this title","children":[],"tail":" is identified; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9ae96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738i/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the programs, operations, and fiscal audits of the bodies referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738f/c"},"text":"section 1738f(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideef9ae97-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title VI, § 610, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3661"},"text":"104 Stat. 3661","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIII/s339"},"text":"Pub. L. 102–237, title III, § 339","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1861"},"text":"105 Stat. 1861","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/549/tVI/s603"},"text":"Pub. L. 102–549, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3669"},"text":"106 Stat. 3669","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideef9ae98-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideef9ae99-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideef9ae9a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/549/s603/1"},"text":"Pub. L. 102–549, § 603(1)","children":[],"tail":", substituted “Enterprise” for “Environment” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/549/s603/2"},"text":"Pub. L. 102–549, § 603(2)","children":[],"tail":", substituted “Enterprise” for “Environment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/549/s603/3"},"text":"Pub. L. 102–549, § 603(3)","children":[],"tail":", inserted “child survival and child development,” after “environmental,” and “, at least one of whom shall be a representative from a child survival and child development organization”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s339/1"},"text":"Pub. L. 102–237, § 339(1)","children":[],"tail":", substituted “six” for “five” and inserted “, at least one of whom shall be a representative of the Department of Agriculture” after “Government”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s339/2"},"text":"Pub. L. 102–237, § 339(2)","children":[],"tail":", substituted “five” for “four”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
