{"tag":"section","attrib":{"id":"ideeeb572b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1726b"},"text":"§ 1726b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International food relief partnership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideeeb572c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may provide grants to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeeb572d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States nonprofit organizations (described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":" and exempt from tax under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/a"},"text":"section 501(a) of title 26","children":[],"tail":") for the preparation of shelf-stable prepackaged foods requested by eligible organizations and the establishment and maintenance of stockpiles of the foods in the United States; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb572e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private voluntary organizations and international organizations for the rapid transportation, delivery, and distribution of shelf-stable prepackaged foods described in paragraph (1) to needy individuals in foreign countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeeb572f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for establishment of stockpiles","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeeb5730-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 70 percent of the amount made available to carry out this section shall be used to provide grants under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb5731-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing grants under subsection (a)(1), the Administrator shall provide a preference to a United States nonprofit organization that agrees to provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeeb5732-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" non-Federal funds in an amount equal to 50 percent of the amount of funds received under a grant under subsection (a)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeeb5733-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an in-kind contribution in an amount equal to that percentage; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeeb5734-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726b/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a combination of such funds and an in-kind contribution,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for the preparation of shelf-stable prepackaged foods and the establishment and maintenance of stockpiles of the foods in the United States in accordance with subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeeb5735-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for rapid transportation, delivery, and distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 20 percent of the amount made available to carry out this section shall be used to provide grants under subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeeb5736-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 10 percent of the amount made available to carry out this section may be used by the Administrator for the administration of grants under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeeb5737-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations or guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2000-11-09"},"text":"November 9, 2000","children":[],"tail":", the Administrator, in consultation with the Secretary, shall issue such regulations or guidelines as the Administrator determines to be necessary to carry out this section, including regulations or guidelines that provide to United States nonprofit organizations eligible to receive grants under subsection (a)(1) guidance with respect to the requirements for qualified shelf-stable prepackaged foods and the quantity of the foods to be stockpiled by the organizations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeeb5738-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Administrator to carry out this section, in addition to amounts otherwise available to carry out this section, $10,000,000 for each of fiscal years 2014 through 2023, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideeeb5739-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title II, § 208, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/472/tIII/s310/a"},"text":"Pub. L. 106–472, title III, § 310(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2075"},"text":"114 Stat. 2075","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIII/s3008"},"text":"Pub. L. 107–171, title III, § 3008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/283"},"text":"116 Stat. 283","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3013"},"text":"Pub. L. 110–246, title III, § 3013","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1826"},"text":"122 Stat. 1826","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIII/s3007"},"text":"Pub. L. 113–79, title III, § 3007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/775"},"text":"128 Stat. 775","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIII/s3108"},"text":"Pub. L. 115–334, title III, § 3108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4604"},"text":"132 Stat. 4604","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideeeb573a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideeeb573b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideeeb573c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":" Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":" A prior section 1726b, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469/tII/s208"},"text":"act July 10, 1954, ch. 469, title II, § 208","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s15"},"text":"Pub. L. 100–202, § 15","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-449"},"text":"101 Stat. 1329–449","children":[],"tail":", which related to periods for review of proposals for famine relief and promulgation of guidelines for such proposals, was omitted in the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3633"},"text":"104 Stat. 3633","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideeeb573d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3108/1"},"text":"Pub. L. 115–334, § 3108(1)","children":[],"tail":", amended section catchline generally. Prior to amendment, section catchline read as follows: “Assistance for stockpiling and rapid transportation, delivery, and distribution of shelf-stable prepackaged foods”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3108/2"},"text":"Pub. L. 115–334, § 3108(2)","children":[],"tail":", substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" substituted “$10,000,000 for each of fiscal years 2014 through 2018” for “$8,000,000 for each of fiscal years 2001 through 2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" substituted “$8,000,000” for “$3,000,000” and “2012” for “2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" substituted “through 2007” for “and 2002”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideeeb573e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideeeb573f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/b"},"text":"section 4(b) of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
