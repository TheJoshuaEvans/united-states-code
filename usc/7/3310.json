{"tag":"section","attrib":{"id":"idefa7c8f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3310"},"text":null,"children":[{"tag":"num","attrib":{"value":"3310"},"text":"§ 3310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on indirect costs for agricultural research, education, and extension programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa7c8f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3310/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in law, indirect costs charged against any agricultural research, education, or extension grant awarded under this Act or any other Act pursuant to authority delegated to the Under Secretary of Agriculture for Research, Education, and Economics shall not exceed 30 percent of the total Federal funds provided under the grant award, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa7c8f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3310/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (a) and (c) shall not apply to a grant awarded competitively under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s638"},"text":"section 638 of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa7c8f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3310/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of subgrants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a grant described in subsection (a), the limitation on indirect costs specified in such subsection shall be applied to both the initial grant award and any subgrant of the Federal funds provided under the initial grant award so that the total of all indirect costs charged against the total of the Federal funds provided under the initial grant award does not exceed such limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa7c8f6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1462"},"text":"Pub. L. 95–113, title XIV, § 1462","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tII/s230/a"},"text":"Pub. L. 105–185, title II, § 230(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/546"},"text":"112 Stat. 546","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7222"},"text":"Pub. L. 107–171, title VII, § 7222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/454"},"text":"116 Stat. 454","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7132/a"},"text":"Pub. L. 110–234, title VII, § 7132(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1228"},"text":"122 Stat. 1228","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7132(