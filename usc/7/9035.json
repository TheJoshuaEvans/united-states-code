{"tag":"section","attrib":{"id":"idf04c46aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9035"},"text":null,"children":[{"tag":"num","attrib":{"value":"9035"},"text":"§ 9035.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan deficiency payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf04c46ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9035/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of loan deficiency payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04c46ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9035/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (d), the Secretary may make loan deficiency payments available to producers on a farm that, although eligible to obtain a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9031"},"text":"section 9031 of this title","children":[],"tail":" with respect to a loan commodity, agree to forgo obtaining the loan for the commodity in return for loan deficiency payments under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c46ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9035/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unshorn pelts, hay, and silage","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c46ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9035/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marketing assistance loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), nongraded wool in the form of unshorn pelts and hay and silage derived from a loan commodity are not eligible for a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9031"},"text":"section 9031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c46af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9035/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan deficiency payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective for each of the 2014 through 2031 crop years, the Secretary may make loan deficiency payments available under this section to producers on a farm that produce unshorn pelts or hay and silage derived from a loan commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c46b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9035/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A loan deficiency payment for a loan commodity or commodity referred to in subsection (a)(2) shall be equal to the product obtained by multiplying—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04c46b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9035/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment rate determined under subsection (c) for the commodity; by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c46b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9035/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of the commodity produced by the eligible producers, excluding any quantity for which the producers obtain a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9031"},"text":"section 9031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c46b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9035/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment rate","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04c46b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9035/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a loan commodity, the payment rate shall be the amount by which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c46b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9035/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9032"},"text":"section 9032 of this title","children":[],"tail":" for the loan commodity; exceeds"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c46b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9035/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate at which a marketing assistance loan for the loan commodity may be repaid under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9034"},"text":"section 9034 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c46b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9035/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unshorn pelts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of unshorn pelts, the payment rate shall be the amount by which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c46b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9035/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9032"},"text":"section 9032 of this title","children":[],"tail":" for ungraded wool; exceeds"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c46b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9035/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate at which a marketing assistance loan for ungraded wool may be repaid under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9034"},"text":"section 9034 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c46ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9035/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hay and silage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of hay or silage derived from a loan commodity, the payment rate shall be the amount by which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c46bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9035/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9032"},"text":"section 9032 of this title","children":[],"tail":" for the loan commodity from which the hay or silage is derived; exceeds"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c46bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9035/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate at which a marketing assistance loan for the loan commodity may be repaid under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9034"},"text":"section 9034 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c46bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9035/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for extra long staple cotton","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply with respect to extra long staple cotton.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c46be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9035/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date for payment rate determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine the amount of the loan deficiency payment to be made under this section to the producers on a farm with respect to a quantity of a loan commodity or commodity referred to in subsection (a)(2) using the payment rate in effect under subsection (c) as of the date the producers request the payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf04c46bf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1205"},"text":"Pub. L. 113–79, title I, § 1205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/679"},"text":"128 Stat. 679","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI/s1201/c/1"},"text":"Pub. L. 115–334, title I, § 1201(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4509"},"text":"132 Stat. 4509","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10309/d/1"},"text":"Pub. L. 119–21, title I, § 10309(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/94"},"text":"139 Stat. 94","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf04c46c0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf04c46c1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf04c46c2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of law applicable to a loan commodity for the 2023 crop year pursuant to title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" applicable to the 2024 crop year for that loan commodity, see "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/c/1"},"text":"section 102(c)(1) of Pub. L. 118–22","children":[],"tail":", set out in an Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf04c46c3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" substituted “2031” for “2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “2023” for “2018”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
