{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefd78b64-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10604/d/1"},"text":"Pub. L. 119–21, § 10604(d)(1)","children":[],"tail":", inserted “and subsection (d)” after “paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10604/d/2"},"text":"Pub. L. 119–21, § 10604(d)(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7214/1"},"text":"Pub. L. 115–334, § 7214(1)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7214/2"},"text":"Pub. L. 115–334, § 7214(2)","children":[],"tail":", inserted “(including veterans)” after “individuals” and “or, in the case of veterans with disabilities, who are pursuing new farming opportunities” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7214/3"},"text":"Pub. L. 115–334, § 7214(3)","children":[],"tail":", substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" substituted “are” for “is” and “section—” for “section $6,000,000 for each of fiscal years 1999 through 2012.” and added subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7210"},"text":"Pub. L. 110–246, § 7210","children":[],"tail":", substituted “2012” for “2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7208/c"},"text":"Pub. L. 107–171, § 7208(c)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7122"},"text":"Pub. L. 107–171, § 7122","children":[],"tail":", substituted “2007” for “2002”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s246/1"},"text":"Pub. L. 105–185, § 246(1)","children":[],"tail":", struck out heading and text of par. (6). Text read as follows: “There are authorized to be appropriated to carry out this subsection—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) not less than $3,000,000 for each of the fiscal years 1991 and 1992; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) not less than $5,000,000 for each of the fiscal years 1993 through 1997.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s246/2"},"text":"Pub. L. 105–185, § 246(2)","children":[],"tail":", struck out par. (1) designation and heading and struck out heading and text of par. (2). Text read as follows: “There are authorized to be appropriated $1,000,000 to carry out this subsection for each of the fiscal years 1991 through 1997.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s246/3"},"text":"Pub. L. 105–185, § 246(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsecs. (a)(6)(B), (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" substituted “1997” for “1996”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefd78b65-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idefd78b66-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
