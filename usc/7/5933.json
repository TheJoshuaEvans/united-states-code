{"tag":"section","attrib":{"id":"idefd78b49-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933"},"text":null,"children":[{"tag":"num","attrib":{"value":"5933"},"text":"§ 5933.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistive technology program for farmers with disabilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefd78b4a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special demonstration grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd78b4b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture, in consultation with other appropriate Federal agencies, shall make demonstration grants to support cooperative programs between State Cooperative Extension Service agencies and private nonprofit disability organizations to provide on-the-farm agricultural education and assistance directed at accommodating disability in farm operations for individuals with disabilities who are engaged in farming and farm-related occupations and their families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78b4c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants awarded under paragraph (1) may be used to support programs serving individuals with disabilities, and their families, who are engaged in farming and farm-related occupations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78b4d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under paragraph (1) may be used to initiate, expand, or sustain programs that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd78b4e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide direct education and assistance to accommodate disability in farming to individuals with disabilities who engage in farming and farm-related occupations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd78b4f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide on-the-farm technical advice concerning the design, fabrication, and use of agricultural and related equipment, machinery, and tools, and assist in the modification of farm worksites, operations, and living arrangements to accommodate individuals with disabilities who engage in farming, farm living and farm-related tasks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd78b50-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve community and health care professionals, including Extension Service agents and others, in the early identification of farm and rural families that are in need of services related to the disability of an individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd78b51-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide specialized education programs to enhance the professional competencies of rural agricultural professionals, rehabilitation and health care providers, vocational counselors, and other providers of service to individuals with disabilities, and their families, who engage in farming or farm-related occupations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd78b52-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mobilize rural volunteer resources, including peer counseling among farmers with disabilities and rural ingenuity networks promoting cost effective methods or accommodating disabilities in farming and farm-related activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78b53-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension Service agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants shall be awarded under this subsection directly to State Extension Service agencies to enable them to enter into contracts, on a multiyear basis, with private nonprofit community-based direct service organizations to initiate, expand, or sustain cooperative programs described under paragraphs (2) and (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78b54-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under this subsection may not be less than $150,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78b55-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration for grants for new programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year that amounts are made available for grants under this subsection, the Secretary may make grants in a manner that ensures that eligible entities who apply for grants, but have not previously received a grant under this subsection, are given full consideration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78b56-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification of application of provisions to veterans with disabilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection shall apply with respect to veterans with disabilities, and their families, who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd78b57-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are engaged in farming or farm-related occupations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd78b58-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are pursuing new farming opportunities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd78b59-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National grant for technical assistance, training, and dissemination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall award a competitive grant to a national private nonprofit disability organization to enable such organization to provide technical assistance, training, information dissemination and other activities to support community-based direct service programs of on-site rural rehabilitation and assistive technology for individuals (including veterans) with disabilities, and their families, who are engaged in farming or farm-related occupations or, in the case of veterans with disabilities, who are pursuing new farming opportunities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd78b5a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd78b5b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), there are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd78b5c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $6,000,000 for each of fiscal years 1999 through 2013; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd78b5d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78b5e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 15 percent of the amounts made available under paragraph (1) and subsection (d) for a fiscal year shall be used to carry out subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd78b5f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5933/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (c)(2), of the funds of the Commodity Credit Corporation, the Secretary shall use to carry out this section $8,000,000 for fiscal year 2026, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefd78b60-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1680"},"text":"Pub. L. 101–624, title XVI, § 1680","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3781"},"text":"104 Stat. 3781","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s841"},"text":"Pub. L. 104–127, title VIII, § 841","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1170"},"text":"110 Stat. 1170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tII/s246"},"text":"Pub. L. 105–185, title II, § 246","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/556"},"text":"112 Stat. 556","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII"},"text":"Pub. L. 107–171, title VII","children":[],"tail":", §§ 7122, 7208(c), "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/434"},"text":"116 Stat. 434","children":[],"tail":", 444; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7210"},"text":"Pub. L. 110–234, title VII, § 7210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","childr