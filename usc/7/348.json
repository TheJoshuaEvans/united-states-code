{"tag":"section","attrib":{"id":"idee2a505b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s348"},"text":null,"children":[{"tag":"num","attrib":{"value":"348"},"text":"§ 348.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture is authorized to make such rules and regulations as may be necessary for carrying out the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee2a505c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-05-08/ch79/s9"},"text":"May 8, 1914, ch. 79, § 9","children":[],"tail":", formerly § 8, "},{"tag":"ref","attrib":{"href":"/us/stat/38/374"},"text":"38 Stat. 374","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1953-06-26/ch157/s1"},"text":"June 26, 1953, ch. 157, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/85"},"text":"67 Stat. 85","children":[],"tail":"; renumbered § 9, "},{"tag":"ref","attrib":{"href":"/us/act/1955-08-11/ch798/s1/b"},"text":"Aug. 11, 1955, ch. 798, § 1(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/684"},"text":"69 Stat. 684","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee2a505d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee2a505e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee2a505f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1953—Act ","children":[{"tag":"date","attrib":{"date":"1953-06-26"},"text":"June 26, 1953","children":[],"tail":", substituted provisions for rules and regulations for provisions empowering Congress to alter, amend, or repeal sections 341 to 343 and 344 to 348 of this title at any time."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
