{"tag":"section","attrib":{"id":"idefd51ae3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925f"},"text":null,"children":[{"tag":"num","attrib":{"value":"5925f"},"text":"§ 5925f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farm business management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefd51ae4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make competitive research and extension grants for the purpose of improving the farm management knowledge and skills of agricultural producers by maintaining and expanding a national, publicly available farm financial management database to support improved farm management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd51ae5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In allocating funds made available to carry out this section, the Secretary may give priority to grants that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd51ae6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate an ability to work directly with agricultural producers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51ae7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with farm management educational programs and associations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51ae8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address the farm management needs of a variety of crops and regions of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51ae9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925f/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute data to the national farm financial management database.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd51aea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraphs (4), (7), (8), and (11)(B) of subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3157"},"text":"section 3157 of this title","children":[],"tail":" shall apply with respect to the making of grants under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd51aeb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd51aec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for fiscal year 2013; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51aed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefd51aee-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1672D"},"text":"Pub. L. 101–624, title XVI, § 1672D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7208"},"text":"Pub. L. 110–234, title VII, § 7208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1241"},"text":"122 Stat. 1241","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7208, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2002; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7213"},"text":"Pub. L. 113–79, title VII, § 7213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/886"},"tex