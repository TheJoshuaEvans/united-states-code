e competitive research and extension grants for the purpose of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) improving the farm management knowledge and skills of agricultural producers; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) establishing and maintaining a national, publicly available farm financial management database to support improved farm management.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7211/2/A"},"text":"Pub. L. 115–334, § 7211(2)(A)","children":[],"tail":", substituted “educational programs and” for “and producer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7211/2/B"},"text":"Pub. L. 115–334, § 7211(2)(B)","children":[],"tail":", substituted “contribute data to” for “use and support”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7211/3"},"text":"Pub. L. 115–334, § 7211(3)","children":[],"tail":", substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" substituted “to carry out this section—” for “such sums as are necessary to carry out this section.” and added pars. (1) and (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefd51af3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefd51af4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"t