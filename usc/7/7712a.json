{"tag":"section","attrib":{"id":"idf01a3a27-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7712a"},"text":null,"children":[{"tag":"num","attrib":{"value":"7712a"},"text":"§ 7712a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction in backlog of agricultural export petitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf01a3a28-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7712a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction efforts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, the Secretary of Agriculture shall endeavor to reduce the backlog in the number of applications for permits for the export of United States agricultural commodities. In achieving such reduction, the Secretary shall not dilute or diminish existing personnel resources that are currently managing sanitary and phytosanitary issues for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01a3a29-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7712a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States agricultural commodities for which exportation is sought; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a3a2a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7712a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interdiction and control of pests and diseases, including for the evaluation of pest and disease concerns of foreign agricultural commodities for which importation is sought.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01a3a2b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7712a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate an annual report specifying, for the year covered by the report—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01a3a2c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7712a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of applications processed to completion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a3a2d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7712a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of backlog applications processed to completion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a3a2e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7712a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of backlog applications processed to completion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a3a2f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7712a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of backlog applications remaining.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf01a3a30-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/465/tII/s202"},"text":"Pub. L. 108–465, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-21"},"text":"Dec. 21, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3884"},"text":"118 Stat. 3884","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf01a3a31-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf01a3a32-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf01a3a33-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Specialty Crops Competitiveness Act of 2004, and not as part of the Plant Protection Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
