{"tag":"section","attrib":{"id":"ideef28390-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736g–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1736g–1"},"text":"§ 1736g–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance in furtherance of narcotics control objectives of United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideef28391-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736g–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantial injury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Local currencies that are made available for use under this chapter may not be used to finance the production for export of agricultural commodities (or products thereof) that would compete in the world market with similar agricultural commodities (or products thereof) produced in the United States, if such competition would cause substantial injury to the United States producers, as determined by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef28392-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736g–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for narcotics control","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (a), the President may provide assistance under this chapter, including assistance through the use of local currencies generated by the sale of commodities under such chapter, for economic development activities undertaken in an eligible country that is a major illicit drug producing country (as defined in section 2291(i)(2) ","children":[{"tag":"ref","attrib":{"idref":"fn002200"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002200"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be section “2291(e)(2)”."}],"tail":" of title 22), for the purpose of reducing the dependence of the economy of such country on the production of crops from which narcotic and psychotropic drugs are derived."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideef28393-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title IV, § 414, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3656"},"text":"104 Stat. 3656","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideef28394-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideef28395-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideef28396-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1991-01-01"},"text":"Jan. 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1513"},"text":"section 1513 of Pub. L. 101–624","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
