{"tag":"section","attrib":{"id":"idefcb7dac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5652"},"text":null,"children":[{"tag":"num","attrib":{"value":"5652"},"text":"§ 5652.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief from unfair trade practices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefcb7dad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5652/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcb7dae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5652/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, for each article described in paragraph (2), make available some or all of the commercial export promotion programs of the Department of Agriculture and the Commodity Credit Corporation to help mitigate or offset the effects of the unfair trade practice serving as the basis for the proceeding described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7daf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5652/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodities specified","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall apply in the case of articles for which the United States has instituted, under any international trade agreement, any dispute settlement proceeding based on an unfair trade practice if such proceeding has been prevented from progressing to a decision by the refusal of the party maintaining the unfair trade practice to permit the proceeding to progress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcb7db0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5652/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any article described in subsection (a)(2), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcb7db1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5652/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promptly consult with representatives of the industry producing such articles and other allied groups or individuals regarding specific actions or the development of an integrated marketing strategy utilizing some or all of the commercial export programs of the Department of Agriculture and the Commodity Credit Corporation to help mitigate or offset the effects of the unfair trade practice identified in subsection (a)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7db2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5652/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ascertain and take into account the industry preference for the practical use of available commercial export promotion programs in implementing subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefcb7db3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/tIII/s301"},"text":"Pub. L. 95–501, title III, § 301","children":[],"tail":", formerly § 302, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1531"},"text":"Pub. L. 101–624, title XV, § 1531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3680"},"text":"104 Stat. 3680","children":[],"tail":"; renumbered § 301, "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3103/b/2"},"text":"Pub. L. 110–246, title III, § 3103(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1832"},"text":"122 Stat. 1832","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefcb7db4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefcb7db5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idefcb7db6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/s301"},"text":"section 301 of Pub. L. 95–501","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s5651"},"text":"section 5651 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/s301"},"text":"section 301 of Pub. L. 95–501","children":[],"tail":" amended sections 1761, 1762, 1764, and 1765 of this title prior to the complete revision of "},{"tag":"ref","attrib":{"href":"/us/pl/95/501"},"text":"Pub. L. 95–501","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
