{"tag":"section","attrib":{"id":"idef734c43-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204i"},"text":null,"children":[{"tag":"num","attrib":{"value":"2204i"},"text":"§ 2204i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on land access and farmland ownership data collection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef734c44-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land access","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", the Secretary of Agriculture, in consultation with the Chief Economist, shall submit to Congress and make publicly available a report identifying—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef734c45-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the barriers that prevent or hinder the ability of beginning farmers and ranchers (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279/a"},"text":"section 2279(a) of this title","children":[],"tail":") and socially disadvantaged farmers and ranchers (as defined in such section) to acquire or access farmland;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734c46-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the extent to which Federal programs, including agricultural conservation easement programs, land transition programs, and financing programs, are improving—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef734c47-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204i/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" farmland access and tenure for beginning farmers and ranchers and socially disadvantaged farmers and ranchers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef734c48-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204i/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" farmland transition and succession; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734c49-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204i/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the regulatory, operational, or statutory changes that are necessary to improve—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef734c4a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204i/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of beginning farmers and ranchers and socially disadvantaged farmers and ranchers to acquire or access farmland;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef734c4b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204i/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" farmland tenure for beginning farmers and ranchers and socially disadvantaged farmers and ranchers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef734c4c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204i/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" farmland transition and succession.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef734c4d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farmland ownership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall collect and, not less frequently than once every 3 years report, data and analysis on farmland ownership, tenure, transition, and entry of beginning farmers and ranchers and socially disadvantaged farmers and ranchers (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279/a"},"text":"section 2279(a) of this title","children":[],"tail":"). In carrying out this subsection, the Secretary shall, at a minimum—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef75bc4e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and distribute comprehensive reporting of trends in farmland ownership, tenure, transition, barriers to entry, profitability, and viability of beginning farmers and ranchers and socially disadvantaged farmers and ranchers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef75bc4f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop surveys and report statistical and economic analysis on farmland ownership, tenure, transition, barriers to entry, profitability, and viability of beginning farmers and ranchers, including a regular follow-on survey to each Census of Agriculture with results of the follow-on survey made public not later than 3 years after the previous Census of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef75bc50-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204i/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require the National Agricultural Statistics Service to include in the Tenure, Ownership, and Transition of Agricultural Land survey questions relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef75bc51-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204i/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which non-farming landowners are purchasing and holding onto farmland for the sole purpose of real estate investment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef75bc52-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204i/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of these farmland ownership trends on the successful entry and viability of beginning farmers and ranchers and socially disadvantaged farmers and ranchers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef75bc53-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204i/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which farm and ranch land with undivided interests and no administrative authority identified have farms or ranches operating on that land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef75bc54-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204i/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the impact of land tenure patterns, categorized by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef75bc55-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204i/b/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" race, gender, and ethnicity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef75bc56-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204i/b/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef75bc57-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $3,000,000 for each fiscal ","children":[{"tag":"ref","attrib":{"idref":"fn002254"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002254"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “of”."}],"tail":" years 2019 through 2023, to remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef75bc58-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12607"},"text":"Pub. L. 115–334, title XII, § 12607","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5006"},"text":"132 Stat. 5006","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
