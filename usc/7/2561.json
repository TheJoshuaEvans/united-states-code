{"tag":"section","attrib":{"id":"idef865e4f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2561"},"text":null,"children":[{"tag":"num","attrib":{"value":"2561"},"text":"§ 2561.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedy for infringement of plant variety protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An owner shall have remedy by civil action for infringement of plant variety protection under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2541"},"text":"section 2541 of this title","children":[],"tail":". If a variety is sold under the name of a variety shown in a certificate, there is a prima facie presumption that it is the same variety."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef865e50-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tIII/s121"},"text":"Pub. L. 91–577, title III, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1556"},"text":"84 Stat. 1556","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/349/s13/t"},"text":"Pub. L. 103–349, § 13(t)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-06"},"text":"Oct. 6, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3144"},"text":"108 Stat. 3144","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef865e51-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef865e52-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendmen