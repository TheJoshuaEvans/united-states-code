{"tag":"section","attrib":{"id":"idee1e432b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s209"},"text":null,"children":[{"tag":"num","attrib":{"value":"209"},"text":"§ 209.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability to individuals for violations; enforcement generally","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee1e432c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s209/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If any person subject to this chapter violates any of the provisions of this chapter, or of any order of the Secretary under this chapter, relating to the purchase, sale, or handling of livestock, the purchase or sale of poultry, or relating to any poultry growing arrangement or swine production contract, he shall be liable to the person or persons injured thereby for the full amount of damages sustained in consequence of such violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1e432d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s209/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such liability may be enforced either (1) by complaint to the Secretary as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s210"},"text":"section 210 of this title","children":[],"tail":", or (2) by suit in any district court of the United States of competent jurisdiction; but this section shall not in any way abridge or alter the remedies now existing at common law or by statute, but the provisions of this chapter are in addition to such remedies."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee1e432e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-08-15/ch64"},"text":"Aug. 15, 1921, ch. 64","children":[],"tail":", title III, § 308, "},{"tag":"ref","attrib":{"href":"/us/stat/42/165"},"text":"42 Stat. 165","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/410/s6"},"text":"Pub. L. 94–410, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-13"},"text":"Sept. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1250"},"text":"90 Stat. 1250","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/173/s5"},"text":"Pub. L. 100–173, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-23"},"text":"Nov. 23, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/918"},"text":"101 Stat. 918","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10502/b/2/B"},"text":"Pub. L. 107–171, title X, § 10502(b)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/510"},"text":"116 Stat. 510","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee1e432f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee1e4330-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee1e4331-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" inserted “or swine production contract” after “poultry growing arrangement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/173"},"text":"Pub. L. 100–173","children":[],"tail":" inserted “the purchase or sale of poultry, or relating to any poultry growing arrangement,” after “livestock,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/410"},"text":"Pub. L. 94–410","children":[],"tail":" struck out references to violations of specific sections and added packers to categories of regulated persons against whom private action could be brought for violation of chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee1e4332-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee1e4333-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/173"},"text":"Pub. L. 100–173","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1987-11-23"},"text":"Nov. 23, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/173/s12"},"text":"section 12 of Pub. L. 100–173","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s182"},"text":"section 182 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
