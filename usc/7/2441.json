{"tag":"section","attrib":{"id":"idef8414a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2441"},"text":null,"children":[{"tag":"num","attrib":{"value":"2441"},"text":"§ 2441.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination of application","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall cause an examination to be made of the application and if on such examination it is determined that the applicant is entitled to plant variety protection under the law, the Secretary shall issue a notice of allowance of plant variety protection therefor as hereinafter provided.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef8414a5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tII/s61"},"text":"Pub. L. 91–577, title II, § 61","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1549"},"text":"84 Stat. 1549","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
