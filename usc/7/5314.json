{"tag":"section","attrib":{"id":"idefc47997-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5314"},"text":null,"children":[{"tag":"num","attrib":{"value":"5314"},"text":"§ 5314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of comprehensive plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefc47998-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The comprehensive plan shall be carried out during the period ending with the close of the ninth fiscal year following the fiscal year in which the comprehensive plan is submitted in its final form under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5313/d/2"},"text":"section 5313(d)(2) of this title","children":[],"tail":" and shall be—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc47999-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5314/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carried out in accordance with, and meet the program objectives specified in, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5313/a"},"text":"section 5313(a) of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s5313/b"},"text":"section 5313(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc4799a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5314/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carried out, by the Federal agencies involved, in accordance with the allocation of functions and activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5313/c"},"text":"section 5313(c) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc4799b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5314/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funded by appropriations made to such agencies for each fiscal year of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc4799c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing law not affected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter may be construed to grant any new regulatory authority or to limit, expand, or otherwise modify any regulatory authority under existing law, or to establish new criteria, standards, or requirements for regulation under existing law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefc4799d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/445/tI/s104"},"text":"Pub. L. 101–445, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-22"},"text":"Oct. 22, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1040"},"text":"104 Stat. 1040","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
