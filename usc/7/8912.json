{"tag":"section","attrib":{"id":"idf0451a4e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8912"},"text":null,"children":[{"tag":"num","attrib":{"value":"8912"},"text":"§ 8912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural biosecurity communication center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0451a4f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a communication center within the Department to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0451a50-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8912/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and disseminate information and prepare for an agricultural disease emergency, agroterrorist act, or other threat to agricultural biosecurity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a51-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8912/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate activities described in paragraph (1) among agencies and offices within the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0451a52-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to existing DHS communication systems","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0451a53-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8912/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency and coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The communication center established under subsection (a) shall, to the maximum extent practicable, share and coordinate the dissemination of timely information with the Department of Homeland Security and other communication systems of appropriate Federal departments and agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a54-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8912/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Avoiding redundancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not be construed to impede, conflict with, or duplicate the communications activities performed by the Secretary of Homeland Security under any provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0451a55-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8912/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0451a56-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8912/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for each of fiscal years 2008 through 2013; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a57-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8912/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0451a58-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14112"},"text":"Pub. L. 110–234, title XIV, § 14112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1455"},"text":"122 Stat. 1455","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14112, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2217; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7501"},"text":"Pub. L. 113–79, title VII, § 7501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/900"},"text":"128 Stat. 900","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7401"},"text":"Pub. L. 115–334, title VII, § 7401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4817"},"text":"132 Stat. 4817","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0451a59-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n"