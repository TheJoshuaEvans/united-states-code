{"tag":"section","attrib":{"id":"idee59ec80-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s915"},"text":null,"children":[{"tag":"num","attrib":{"value":"915"},"text":"§ 915.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of financial and credit reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture is authorized to purchase such financial and credit reports as may be necessary to carry out the Secretary’s authorized work: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That purchases under this authority shall not be made unless provision is made therefor in the applicable appropriation and the cost thereof is not in excess of limitations prescribed therein."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee59ec81-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-09-21/ch412"},"text":"Sept. 21, 1944, ch. 412","children":[],"tail":", title V, § 505, "},{"tag":"ref","attrib":{"href":"/us/stat/58/740"},"text":"58 Stat. 740","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s235/b/2"},"text":"Pub. L. 103–354, title II, § 235(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3221"},"text":"108 Stat. 3221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee59ec82-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee59ec83-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee59ec84-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of Agriculture Organic Act of 1944, and not as part of the Rural Electrification Act of 1936 which constitutes this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee59ec85-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" substituted “Secretary of Agriculture” for “Rural Electrification Administration” and “the Secretary’s” for “its”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
