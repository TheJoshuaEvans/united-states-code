{"tag":"section","attrib":{"id":"idee97df0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1421d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1421d"},"text":"§ 1421d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodity reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee97df10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1421d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crop reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture (hereafter in this section referred to as the “Secretary”) shall gather data from producers to be used to develop crop reports to be distributed by the Secretary during the growing season. The report shall contain statements of the conditions of those crops by State, with such explanations, comparisons, and information as may be useful for illustrating such reports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee97df11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1421d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee97df12-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1421d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the reports compiled pursuant to subsection (a), the Secretary shall annually survey producers for information for reports regarding supply, acreage, production, disposition, and prices for the following commodities as determined by the Secretary:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee97df13-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1421d/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 fresh market vegetables;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee97df14-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1421d/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 processing vegetables;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee97df15-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1421d/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6 fruits and nuts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee97df16-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1421d/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 17 forage and turf seeds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee97df17-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1421d/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 vegetable seeds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee97df18-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1421d/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maple syrup.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee97df19-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1421d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall annually prepare a report containing results of the surveys described in paragraph (1) in such States as determined by the Secretary. Such reports shall be submitted to and officially approved by the Secretary of Agriculture before being issued or published.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee97df1a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1421d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tree inventories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall survey producers for information for reports regarding fruit and nut tree inventories. Such surveys and reports shall be conducted, printed, and distributed on a regular basis every 3 to 5 years as determined by the Secretary. Reports shall be submitted to and officially approved by the Secretary before being issued or published.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee97df1b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1421d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee97df1c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1421d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee97df1d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXV/s2514"},"text":"Pub. L. 101–624, title XXV, § 2514","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4074"},"text":"104 Stat. 4074","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee97df1e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee97df1f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee97df20-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food, Agriculture, Conservation, and Trade Act of 1990, and not as part of the Agricultural Act of 1949 which is classified principally to this chapter. For complete classification of the 1949 Act to the Code, see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s2514"},"text":"section 2514 of Pub. L. 101–624","children":[],"tail":". Subsec. (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/s2514"},"text":"section 2514 of Pub. L. 101–624","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s411a"},"text":"section 411a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
