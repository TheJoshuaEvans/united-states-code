{"tag":"section","attrib":{"id":"idefb6214c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4405"},"text":null,"children":[{"tag":"num","attrib":{"value":"4405"},"text":"§ 4405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees and charges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefb6214d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4405/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testing or inspection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any organization designated by the Secretary of Agriculture to test or inspect equipment may establish reasonable fees to cover the costs of such testing or inspection. Such fees shall be payable directly to the organization by those seeking inspection or testing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb6214e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4405/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of certificates of compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture may, effective ","children":[{"tag":"date","attrib":{"date":"1982-10-01"},"text":"October 1, 1982","children":[],"tail":", fix and cause to be collected reasonable fees to cover, as nearly as practicable, the costs to the Department of Agriculture incurred in connection with the issuance of certificates of compliance as provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4403/2"},"text":"section 4403(2) of this title","children":[],"tail":". All fees collected shall be credited to the current appropriation account that incurs the cost and shall be available without fiscal year limitation to pay the expenses of the Secretary of Agriculture incident to the issuance of certificates of compliance under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefb6214f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/325/s6"},"text":"Pub. L. 97–325, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1605"},"text":"96 Stat. 1605","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefb62150-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefb62151-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefb62152-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/325"},"text":"Pub. L. 97–325","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1603"},"text":"96 Stat. 1603","children":[],"tail":", known as the International Carriage of Perishable Foodstuffs Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4401"},"text":"section 4401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
