{"tag":"section","attrib":{"id":"idee3af2c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s499p"},"text":null,"children":[{"tag":"num","attrib":{"value":"499p"},"text":"§ 499p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of licensees for acts and omissions of agents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In construing and enforcing the provisions of this chapter, the act, omission, or failure of any agent, officer, or other person acting for or employed by any commission merchant, dealer, or broker, within the scope of his employment or office, shall in every case be deemed the act, omission, or failure of such commission merchant, dealer, or broker as that of such agent, officer, or other person.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee3af2ca-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-10/ch436/s16"},"text":"June 10, 1930, ch. 436, § 16","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/538"},"text":"46 Stat. 538","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee3af2cb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee3af2cc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee3af2cd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s566"},"text":"section 566 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
