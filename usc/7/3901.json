{"tag":"section","attrib":{"id":"idefb13ee8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3901"},"text":null,"children":[{"tag":"num","attrib":{"value":"3901"},"text":"§ 3901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefb13ee9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic research on malignant tumors or cancers is essential to protect the health of domestic animals, poultry, and wildlife, including birds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb13eea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carcinogenic agents have not been adequately identified in domestic animals, poultry, and wildlife management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb13eeb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3901/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic research in diagnosis, prevention, and control of malignant tumors in animals and birds has not been adequately coordinated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb13eec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3901/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant theories of a common factor in malignant tumors, such as chorionic gonad­otropin, have not been pursued in depth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb13eed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3901/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on diagnosis, prevention, and control of cancer in animals and birds will be beneficial in identifying any common factors in human and animal malignant tumors, if such exist; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb13eee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3901/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is imperative for the Department of Agriculture and the National Institutes of Health to coordinate and consult with regard to the research authorized under this chapter to achieve the maximum benefits from such research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefb13eef-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/469/s2"},"text":"Pub. L. 96–469, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2235"},"text":"94 Stat. 2235","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefb13ef0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefb13ef1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idefb13ef2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/469/s1"},"text":"Pub. L. 96–469, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2235"},"text":"94 Stat. 2235","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/469/s1"},"text":"“That this Act [enacting this chapter] may be cited as the ‘Animal Cancer Research Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
