{"tag":"section","attrib":{"id":"idefe5bc8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6514"},"text":null,"children":[{"tag":"num","attrib":{"value":"6514"},"text":"§ 6514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accreditation program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe5bc8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6514/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish and implement a program to accredit a governing State official, and any private person, that meets the requirements of this section as a certifying agent for the purpose of certifying a farm or handling operation as a certified organic farm or handling operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6514/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be accredited as a certifying agent under this section, a governing State official or private person shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bc8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6514/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit, to the Secretary, an application for such accreditation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6514/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have sufficient expertise in organic farming and handling techniques as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6514/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with the requirements of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6515"},"text":"section 6515 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6514/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional documentation and verification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Deputy Administrator of the national organic program established under this chapter, has the authority, and shall grant a certifying agent the authority, to require producers and handlers to provide additional documentation or verification before granting a certification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6503"},"text":"section 6503 of this title","children":[],"tail":", in the case of a compliance risk with respect to meeting the national standards for organic production established under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6504"},"text":"section 6504 of this title","children":[],"tail":", as determined by the Secretary or the certifying agent."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6514/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accreditation of foreign organic certification program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bc94-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6514/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For an agricultural product being imported into the United States to be represented as organically produced, the Secretary shall require the agricultural product to be accompanied by a complete and valid national organic import certificate, which shall be available as an electronic record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc95-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6514/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tracking system","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe5bc96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6514/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a system to track national organic import certificates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bc97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6514/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing the system under subparagraph (A), the Secretary may integrate the system into any existing information tracking systems for imports of agricultural products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6514/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of accreditation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An accreditation made under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bc99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6514/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraph (2), shall be for a period of not more than 5 years, as determined appropriate by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6514/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a certifying agent operating in a foreign country, shall be for a period of time that is consistent with the certification of a domestic certifying agent, as determined appropriate by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6514/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be renewed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe5bc9c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXI/s2115"},"text":"Pub. L. 101–624, title XXI, § 2115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3944"},"text":"104 Stat. 3944","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tX/s10104/c"},"text":"Pub. L. 115–334, title X, § 10104(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4900"},"text":"132 Stat. 4900","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefe5bc9d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefe5bc9e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefe5bc9f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" added subsecs. (c) to (e) and struck out former subsec. (c). Prior to amendment, text of subsec. (c) read as follows: “An accreditation made under this section shall be for a period of not to exceed 5 years, as determined appropriate by the Secretary, and may be renewed.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
