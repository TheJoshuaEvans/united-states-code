{"tag":"section","attrib":{"id":"ideff684ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6952"},"text":null,"children":[{"tag":"num","attrib":{"value":"6952"},"text":"§ 6952.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiagency task force","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff684ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6952/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish, in the office of the Under Secretary for Food, Nutrition, and Consumer Services, a multiagency task force for the purpose of providing coordination and direction for commodity programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff684ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6952/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force shall be composed of at least 4 members, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff684ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6952/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a representative from the Food Distribution Division of the Food and Nutrition Service, who shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff684f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6952/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appointed by the Under Secretary for Food, Nutrition, and Consumer Services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff684f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6952/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as Chairperson of the Task Force;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff684f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6952/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 representative from the Agricultural Marketing Service, who shall be appointed by the Under Secretary for Marketing and Regulatory Programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff684f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6952/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 representative from the Farm Services Agency, who shall be appointed by the Under Secretary of Agriculture for Farm Production and Conservation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff684f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6952/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 representative from the Food Safety and Inspection Service, who shall be appointed by the Under Secretary for Food Safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff684f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6952/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff684f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6952/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force shall be responsible for evaluation and monitoring of the commodity programs to ensure that the commodity programs meet the mission of the Department—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff684f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6952/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the United States farm sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff684f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6952/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to contribute to the health and well-being of individuals in the United States through the distribution of domestic agricultural products through commodity programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff684f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6952/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), the Task Force shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff684fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6952/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and make recommendations regarding the specifications used for the procurement of food commodities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff684fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6952/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and make recommendations regarding the efficient and effective distribution of food commodities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff684fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6952/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and make recommendations regarding the degree to which the quantity, quality, and specifications of procured food commodities align the needs of producers and the preferences of recipient agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff684fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6952/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":", and annually thereafter, the Secretary shall submit to Congress a report that describes, for the period covered by the report—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff684fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6952/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the findings and recommendations of the Task Force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff684ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6952/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies implemented for the improvement of commodity procurement programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff68500-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s242"},"text":"Pub. L. 103–354, title II, § 242","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIV/s4205"},"text":"Pub. L. 113–79, title IV, § 4205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/823"},"text":"128 Stat. 823","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12405/b"},"text":"Pub. L. 115–334, title XII, § 12405(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4975"},"text":"132 Stat. 4975","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideff68501-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideff68502-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideff68503-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “Under Secretary of Agriculture for Farm Production and Conservation” for “Under Secretary for Farm and Foreign Agricultural Services”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
