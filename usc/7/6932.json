{"tag":"section","attrib":{"id":"ideff1a485-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932"},"text":null,"children":[{"tag":"num","attrib":{"value":"6932"},"text":"§ 6932.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farm Service Agency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff1a486-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to establish and maintain in the Department a Farm Service Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a487-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary establishes the Farm Service Agency under subsection (a), the Secretary is authorized to assign to the Agency jurisdiction over the following functions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff1a488-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Agricultural price and income support programs, production adjustment programs, and related programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a489-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s194/c"},"text":"Pub. L. 104–127, title I, § 194(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/946"},"text":"110 Stat. 946","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a48a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Agricultural credit programs assigned before ","children":[{"tag":"date","attrib":{"date":"1994-10-13"},"text":"October 13, 1994","children":[],"tail":", by law to the Farmers Home Administration (including farm ownership and operating, emergency, and disaster loan programs) and other lending programs for agricultural producers and others engaged in the production of agricultural commodities."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a48b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subchapter B of chapter 1 of subtitle D of title XII of the Food Security Act of 1985 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3831"},"text":"16 U.S.C. 3831","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a48c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other functions as the Secretary considers appropriate, except for those programs assigned by the Secretary to the Natural Resources Conservation Service or another agency of the Department under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6936/b"},"text":"section 6936(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a48d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special concurrence requirements for certain functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the programs specified in subsection (b)(4), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff1a48e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acting on the recommendations of the Farm Service Agency, with the concurrence of the Natural Resources Conservation Service, issue regulations to carry out such programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a48f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the Farm Service Agency, in establishing policies, priorities, and guidelines for such programs, does so with the concurrence of the Natural Resources Conservation Service at national, State, and local levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a490-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that, in reaching such concurrence at the local level, the Natural Resources Conservation Service works in cooperation with Soil and Water Conservation Districts or similar organizations established under State law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a491-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that officials of county and area committees established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s590h/b/5"},"text":"section 590h(b)(5) of title 16","children":[],"tail":" meet annually with officials of such Districts or similar organizations to consider local conservation priorities and guidelines; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a492-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take steps to ensure that the concurrence process does not interfere with the effective delivery of such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a493-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction over conservation program appeals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff1a494-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Until such time as an adverse decision described in this paragraph is referred to the National Appeals Division for consideration, the Farm Service Agency shall have initial jurisdiction over any administrative appeal resulting from an adverse decision made under title XII of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3801"},"text":"16 U.S.C. 3801","children":[],"tail":" et seq.), including an adverse decision involving technical determinations made by the Natural Resources Conservation Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a495-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of technical determination","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a496-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to administrative appeals involving a technical determination made by the Natural Resources Conservation Service, the Farm Service Agency, by rule with the concurrence of the Natural Resources Conservation Service, shall establish procedures for obtaining review by the Natural Resources Conservation Service of the technical determinations involved. Such rules shall ensure that technical criteria established by the Natural Resources Conservation Service shall be used by the Farm Service Agency as the basis for any decisions regarding technical determinations. If no review is requested, the technical determination of the Natural Resources Conservation Service shall be the technical basis for any decision rendered by a county or area committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s590h/b/5"},"text":"section 590h(b)(5) of title 16","children":[],"tail":". If the committee requests a review by the Natural Resources Conservation Service of a wetlands determination of the Service, the Farm Service Agency shall consult with other Federal agencies whenever required by law or under a memorandum of agreement in existence on "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"October 13, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a497-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic hardship","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After a technical determination has been made, on a producer’s request, if a county or area committee determines that the application of the producer’s conservation system would impose an undue economic hardship on the producer, the committee shall provide the producer with relief to avoid the hardship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a498-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reinstatement of program benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules issued to carry out this subsection shall provide for the prompt reinstatement of benefits to a producer who is determined in an administrative appeal to meet the requirements of title XII of the Food Security Act of 1985 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3801"},"text":"16 U.S.C. 3801","children":[],"tail":" et seq.] applicable to the producer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a499-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Federal and non-Federal employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff1a49a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the implementation of programs and activities assigned to the Farm Service Agency, the Secretary may use interchangeably in local offices of the Agency both Federal employees of the Department and non-Federal employees of county and area committees established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s590h/b/5"},"text":"section 590h(b)(5) of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a49b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), no personnel action (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2302/a/2/A"},"text":"section 2302(a)(2)(A) of title 5","children":[],"tail":") may be taken with respect to a Federal employee unless such action is taken by another Federal employee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a49c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, the Secretary shall collocate county offices of the Farm Service Agency with county offices of the Natural Resources Conservation Service in order to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff1a49d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximize savings from shared equipment, office space, and administrative support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a49e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" simplify paperwork and regulatory requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a49f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide improved services to agricultural producers and landowners affected by programs administered by the Agency and the Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a4a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieve computer compatibility between the Agency and the Service to maximize efficiency and savings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a4a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsections (c) through (f) of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff1a4a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A reference to the “Farm Service Agency” includes any other office, agency, or administrative unit of the Department assigned the functions authorized for the Farm Service Agency under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a4a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A reference to the “Natural Resources Conservation Service” includes any other office, agency, or administrative unit of the Department assigned the functions authorized for the Natural Resources Conservation Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6936/b"},"text":"section 6936(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff1a4a4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s226"},"text":"Pub. L. 103–354, title II, § 226","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3214"},"text":"108 Stat. 3214","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s194/c"},"text":"Pub. L. 104–127, title I, § 194(c)","children":[],"tail":", title III, §§ 315(b), 336(a)(2)(C), "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/946"},"text":"110 Stat. 946","children":[],"tail":", 985, 1005; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII"},"text":"Pub. L. 115–334, title XII","children":[],"tail":", §§ 12404(a), 12410(c)(2)(A), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4974"},"text":"132 Stat. 4974","children":[],"tail":", 4978.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideff1a4a5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideff1a4a6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideff1a4a7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Food Security Act of 1985, referred to in subsecs. (b)(4) and (d)(1), (3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1354"},"text":"99 Stat. 1354","children":[],"tail":". Title XII of the Act is classified principally to chapter 58 (§ 3801 et seq.) of Title 16, Conservation. Subchapter B of chapter 1 of subtitle D of title XII of the Act is classified generally to subpart B (§ 3831 et seq.) of part I of subchapter IV of chapter 58 of Title 16. For complete classification of this Act to the Code, see Short Title of 1985 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1281"},"text":"section 1281 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideff1a4a8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/s226"},"text":"section 226 of Pub. L. 103–354","children":[],"tail":". Subsec. (h) of "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/s226"},"text":"section 226 of Pub. L. 103–354","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1981"},"text":"section 1981 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideff1a4a9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12404/a/1"},"text":"Pub. L. 115–334, § 12404(a)(1)","children":[],"tail":", (3), substituted “Farm” for “Consolidated Farm” in section catchline and wherever appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12404/a/2"},"text":"Pub. L. 115–334, § 12404(a)(2)","children":[],"tail":", struck out “of Consolidated Farm Service Agency” after “Functions” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b)(5), (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12410/c/2/A"},"text":"Pub. L. 115–334, § 12410(c)(2)(A)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6936/b"},"text":"section 6936(b) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6962/b"},"text":"section 6962(b) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s194/c"},"text":"Pub. L. 104–127, § 194(c)","children":[],"tail":", struck out par. (2) which read as follows: “General supervision of the Federal Crop Insurance Corporation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s336/a/2/C"},"text":"Pub. L. 104–127, § 336(a)(2)(C)","children":[],"tail":", struck out before period at end “and the agricultural conservation program under the Soil Conservation and Domestic Allotment Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s590g"},"text":"16 U.S.C. 590g","children":[],"tail":" et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s315/b"},"text":"Pub. L. 104–127, § 315(b)","children":[],"tail":", designated existing provisions as subpar. (A), inserted heading, and added subpar. (B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideff1a4aa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideff1a4ab-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Farm Service Agency Accountability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI/s1705"},"text":"Pub. L. 115–334, title I, § 1705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4526"},"text":"132 Stat. 4526","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/334/tI/s1705"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":"], the Secretary [of Agriculture] shall establish policies, procedures, and plans to improve program accountability and integrity through targeted and coordinated activities, including utilizing data mining to identify and reduce errors, waste, fraud, and abuse in programs administered by the Farm Service Agency."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 3 years after the date of enactment of this Act, the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report describing the progress and results of the activities conducted under subsection (a).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
