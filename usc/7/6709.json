{"tag":"section","attrib":{"id":"idefea9e7f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6709"},"text":null,"children":[{"tag":"num","attrib":{"value":"6709"},"text":"§ 6709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency cooperation to maximize biomass growth","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into an agreement with the Secretary of Defense to develop a program to manage forests and land on Department of Defense military installations so as to maximize their potential for biomass growth and sequestering carbon dioxide.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefea9e80-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIV/s2411"},"text":"Pub. L. 101–624, title XXIV, § 2411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4062"},"text":"104 Stat. 4062","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVIII/s8301/b"},"text":"Pub. L. 115–334, title VIII, § 8301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4840"},"text":"132 Stat. 4840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefea9e81-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefea9e82-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefea9e83-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “to” for “to—” and “develop a program to manage forests and land on Department of Defense military installations” for “(2) develop a program to manage such forests and lands” and struck out par. (1) which read as follows: “conduct a study of reforestation and improved management of Department of Defense military installations and lands; and”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
