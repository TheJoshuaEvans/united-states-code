{"tag":"section","attrib":{"id":"idefe372bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6311"},"text":null,"children":[{"tag":"num","attrib":{"value":"6311"},"text":"§ 6311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe372c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for each fiscal year such funds as are necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe372c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated under subsection (a) shall not be available for payment of the expenses or expenditures of the Board or the Committee in administering any provision of any order issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe372c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6311/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may issue such regulations as are necessary to carry out this chapter, including regulations relating to the assessment of late payment charges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe372c3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1976"},"text":"Pub. L. 101–624, title XIX, § 1976","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3904"},"text":"104 Stat. 3904","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
