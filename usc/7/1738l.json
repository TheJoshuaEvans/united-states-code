{"tag":"section","attrib":{"id":"ideef9aeb1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738l"},"text":null,"children":[{"tag":"num","attrib":{"value":"1738l"},"text":"§ 1738l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouraging multilateral debt donations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideef9aeb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouraging donations from official creditors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President should actively encourage other official creditors of an eligible country to provide debt reduction to such eligible country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9aeb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouraging donations from other sources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall make every effort to insure that programs established through Environmental Funds are able to receive donations from private and public entities, and private creditors of the eligible country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideef9aeb4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title VI, § 613, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3662"},"text":"104 Stat. 3662","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
