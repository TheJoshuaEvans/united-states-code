{"tag":"section","attrib":{"id":"idee8bf8d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg"},"text":null,"children":[{"tag":"num","attrib":{"value":"1359gg"},"text":"§ 1359gg.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee8bf8d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of acreage base history","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee8bf8d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of establishing proportionate shares for sugarcane farms under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1359ff/c"},"text":"section 1359ff(c) of this title","children":[],"tail":", the Secretary, on application of any producer, with the written consent of all owners of a farm, may transfer the acreage base history of the farm to any other parcels of land of the applicant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee8bf8d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Converted acreage base","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee8bf8d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sugarcane acreage base established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1359ff/c"},"text":"section 1359ff(c) of this title","children":[],"tail":" that has been or is converted to nonagricultural use on or after "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", may be transferred to other land suitable for the production of sugarcane that can be delivered to a processor in a proportionate share State in accordance with this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee8bf8da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the Secretary becomes aware of a conversion of any sugarcane acreage base to a nonagricultural use, the Secretary shall notify the 1 or more affected landowners of the transferability of the applicable sugarcane acreage base.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee8bf8db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial transfer period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The owner of the base attributable to the acreage at the time of the conversion shall be afforded 90 days from the date of the receipt of the notification under subparagraph (B) to transfer the base to 1 or more farms owned by the owner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee8bf8dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grower of record","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a transfer under subparagraph (C) cannot be accomplished during the period specified in that subparagraph, the grower of record with regard to the acreage base on the date on which the acreage was converted to nonagricultural use shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee8bf8dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be notified; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee8bf8de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have 90 days from the date of the receipt of the notification to transfer the base to 1 or more farms operated by the grower.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee8bf8df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pool distribution","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee8bf8e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/a/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If transfers under subparagraphs (B) and (C) cannot be accomplished during the periods specified in those subparagraphs, the county committee of the Farm Service Agency for the applicable county shall place the acreage base in a pool for possible assignment to other farms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee8bf8e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/a/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of requests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After providing reasonable notice to farm owners, operators, and growers of record in the county, the county committee shall accept requests from owners, operators, and growers of record in the county.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee8bf8e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/a/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The county committee shall assign the acreage base to other farms in the county that are eligible and capable of accepting the acreage base, based on a random drawing from among the requests received under clause (ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee8bf8e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statewide reallocation","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee8bf8e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/a/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any acreage base remaining unassigned after the transfers and processes described in subparagraphs (A) through (E) shall be made available to the State committee of the Farm Service Agency for allocation among the remaining county committees in the State representing counties with farms eligible for assignment of the base, based on a random drawing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee8bf8e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/a/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any county committee receiving acreage base under this subparagraph shall allocate the acreage base to eligible farms using the process described in subparagraph (E).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee8bf8e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of reassigned base","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After acreage base has been reassigned in accordance with this subparagraph, the acreage base shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee8bf8e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/a/2/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain on the farm; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee8bf8e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/a/2/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be subject to the transfer provisions of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee8bf8e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of acreage base history","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If for reasons beyond the control of a producer on a farm, the producer is unable to harvest an acreage of sugarcane for sugar or seed with respect to all or a portion of the proportionate share established for the farm under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1359ff/c"},"text":"section 1359ff(c) of this title","children":[],"tail":", the Secretary, on the application of the producer and with the written consent of all owners of the farm, may preserve for a period of not more than 5 consecutive years the acreage base history of the farm to the extent of the proportionate share involved. The Secretary may permit the proportionate share to be redistributed to other farms, but no acreage base history for purposes of establishing acreage bases shall accrue to the other farms by virtue of the redistribution of the proportionate share."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee8bf8ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revisions of allocations and proportionate shares","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, after such notice as the Secretary by regulation may prescribe, may revise or amend any allocation of a marketing allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1359dd"},"text":"section 1359dd of this title","children":[],"tail":", or any proportionate share established or adjusted for a farm under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1359ff/c"},"text":"section 1359ff(c) of this title","children":[],"tail":", on the same basis as the initial allocation or proportionate share was required to be established."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee8bf8eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of mill allocations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee8bf8ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A producer in a proportionate share State, upon written consent from all affected crop-share owners (or the representative of the affected crop-share owners) of a farm may deliver sugarcane to another processing company if the additional delivery, when combined with such other processing company’s existing deliveries, does not exceed the processing capacity of the company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee8bf8ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1359dd"},"text":"section 1359dd of this title","children":[],"tail":", the Secretary shall adjust the allocations of each of such processing companies affected by a transfer under paragraph (1) to reflect the change in deliveries, based on—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee8bf8ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of acres of sugarcane base being transferred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee8bf8ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359gg/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pro rata amount of allocation at the processing company holding the applicable allocation that equals the contribution of the grower to allocation of the processing company for the sugarcane acreage base being transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee8bf8f0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title III, § 359g, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1403"},"text":"Pub. L. 107–171, title I, § 1403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/201"},"text":"116 Stat. 201","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1403/g"},"text":"Pub. L. 110–234, title I, § 1403(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/987"},"text":"122 Stat. 987","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1403(g), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1715.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee8bf8f1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee8bf8f2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee8bf8f3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee8bf8f4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1359gg, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30/tIII/s359g"},"text":"act Feb. 16, 1938, ch. 30, title III, § 359g","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tIX/s902"},"text":"Pub. L. 101–624, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3486"},"text":"104 Stat. 3486","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tI/s111/i"},"text":"Pub. L. 102–237, title I, § 111(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1835"},"text":"105 Stat. 1835","children":[],"tail":", related to special rules, prior to the general amendment of this subpart by "},{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee8bf8f5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1403/g/1"},"text":"Pub. L. 110–246, § 1403(g)(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a). Prior to amendment, text read as follows: “For the purpose of establishing proportionate shares for sugarcane farms under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1359ff/c"},"text":"section 1359ff(c) of this title","children":[],"tail":", the Secretary, on application of any producer, with the written consent of all owners of a farm, may transfer the acreage base history of the farm to any other parcels of land of the applicant.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1403/g/2/A"},"text":"Pub. L. 110–246, § 1403(g)(2)(A)","children":[],"tail":", inserted “affected” before “crop-share owners” in two places and struck out “, and from the processing company holding the applicable allocation for such shares,” before “may deliver”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1403/g/2/B"},"text":"Pub. L. 110–246, § 1403(g)(2)(B)","children":[],"tail":", struck out “the product of” after “based on” in introductory provisions, added subpars. (A) and (B), and struck out former subpars. (A) and (B) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the number of acres of proportionate shares being transferred; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the State’s per acre yield goal established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1359ff/c/3"},"text":"section 1359ff(c)(3) of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee8bf8f6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee8bf8f7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
