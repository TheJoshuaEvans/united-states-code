{"tag":"section","attrib":{"id":"idefef5a4c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6915"},"text":null,"children":[{"tag":"num","attrib":{"value":"6915"},"text":"§ 6915.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Combination of field offices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefef5a4d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6915/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Combination of offices required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where practicable and to the extent consistent with efficient, effective, and improved service, the Secretary shall combine field offices of agencies within the Department to reduce personnel and duplicative overhead expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefef5a4e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6915/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint use of resources and offices required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When two or more agencies of the Department share a common field office, the Secretary shall require the agencies to jointly use office space, equipment, office supplies, administrative personnel, and clerical personnel associated with that field office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefef5a4f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s215"},"text":"Pub. L. 103–354, title II, § 215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3211"},"text":"108 Stat. 3211","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
