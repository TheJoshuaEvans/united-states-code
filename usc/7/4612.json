{"tag":"section","attrib":{"id":"idefbd4ccd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4612"},"text":null,"children":[{"tag":"num","attrib":{"value":"4612"},"text":"§ 4612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination or suspension","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefbd4cce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Person” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “person” means a producer, importer, or handler.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbd4ccf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary finds that an order issued under this chapter, or any provision of the order, obstructs or does not tend to effectuate the purposes of this chapter, the Secretary shall terminate or suspend the operation of the order or provision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbd4cd0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4612/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic referenda","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (d)(3) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4613/g"},"text":"section 4613(g) of this title","children":[],"tail":", on the date that is 5 years after the date on which the Secretary issues an order authorizing the collection of assessments on honey or honey products under this chapter, and every 5 years thereafter, the Secretary shall conduct a referendum to determine if the persons subject to assessment under the order approve continuation of the order in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4611"},"text":"section 4611 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbd4cd1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4612/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referenda on request","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbd4cd2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4612/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the request of the Honey Board or the petition of at least 10 percent of the total number of persons subject to assessment under the order, the Secretary shall conduct a referendum to determine if the persons subject to assessment under the order approve continuation of the order in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4611"},"text":"section 4611 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbd4cd3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4612/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Referenda conducted under paragraph (1) may not be held more than once every 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbd4cd4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4612/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on periodic referenda","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a referendum is conducted under this subsection and the Secretary determines that continuation of the order is approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4611"},"text":"section 4611 of this title","children":[],"tail":", any referendum otherwise required to be conducted under subsection (c) shall not be held before the date that is 5 years after the date of the referendum conducted under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbd4cd5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4612/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing and requirements for termination or suspension","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbd4cd6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4612/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall terminate or suspend an order at the end of the marketing year during which a referendum is conducted under subsection (c) or (d) if the Secretary determines that continuation of an order is not approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4611"},"text":"section 4611 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbd4cd7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4612/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent referendum","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary terminates or suspends an order that assesses the handling of honey and honey products under paragraph (1), the Secretary shall, not later than 90 days after submission of a proposed order by an interested party—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbd4cd8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4612/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" propose another order to establish a research, promotion, and consumer information program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbd4cd9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4612/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a referendum on the order among persons that would be subject to assessment under the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbd4cda-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4612/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effectiveness of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4611"},"text":"Section 4611 of this title","children":[],"tail":" shall apply in determining the effectiveness of the subsequent amended order under paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefbd4cdb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/590/s13"},"text":"Pub. L. 98–590, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3123"},"text":"98 Stat. 3123","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1985"},"text":"Pub. L. 101–624, title XIX, § 1985","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3907"},"text":"104 Stat. 3907","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tVI/s605"},"text":"Pub. L. 105–185, title VI, § 605","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/601"},"text":"112 Stat. 601","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefbd4cdc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefbd4cdd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefbd4cde-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185"},"text":"Pub. L. 105–185","children":[],"tail":" amended section catchline and text generally, substituting present provisions for provisions which in subsec. (a) authorized Secretary to terminate or suspend order, in subsec. (b) provided for conducting of referendum every five years and alternative first referendum, in subsec. (c) provided for referendum upon request of Honey Board or petition of ten percent or more of producers and importers, and in subsec. (d) directed termination or suspension of order where favored by majority voting in referendum and majority produce and import more than 50 percent of volume of honey of those voting."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1985/a"},"text":"Pub. L. 101–624, § 1985(a)","children":[],"tail":", designated existing provisions as par. (1), substituted “Except as otherwise provided in paragraph (2), five” for “Five” and “termination” for “continuation, termination,” and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1985/b"},"text":"Pub. L. 101–624, § 1985(b)","children":[],"tail":", substituted “an order” for “such order”, inserted “in which a referendum is conducted under subsection (b) or (c) of this section” after “marketing year”, and struck out “of the order” before “is favored by”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
