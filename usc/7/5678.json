{"tag":"section","attrib":{"id":"idefcb7e33-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678"},"text":null,"children":[{"tag":"num","attrib":{"value":"5678"},"text":"§ 5678.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Edward R. Madigan United States Agricultural Export Excellence Award","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefcb7e34-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcb7e35-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States producers of agricultural products are some of the most productive and efficient producers of agricultural products in the world;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7e36-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continued growth and expansion of markets for United States agricultural exports is crucial to the continued development and economic well-being of rural areas of the United States and the agricultural sector of the United States economy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7e37-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in recent years, United States agricultural exports have steadily increased, surpassing $54,000,000,000 in value in 1995;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7e38-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as United States agricultural producers move toward a market-oriented system in which planting and other decisions by producers are driven by national and international market signals, developing new and expanding agricultural export markets is vital to maintaining a vibrant and healthy agricultural sector and rural economy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7e39-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a United States agricultural export excellence award will increase United States agricultural exports by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefcb7e3a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying efforts of United States entities to develop and expand markets for United States agricultural exports through the development of new products and services and through the use of innovative marketing techniques;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcb7e3b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognizing achievements of those who have exhibited or supported entrepreneurial efforts to expand and create new markets for United States agricultural exports or increase the volume or value of United States agricultural exports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcb7e3c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminating information on successful methods used to develop and expand markets for United States agricultural exports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcb7e3d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Edward R. Madigan United States Agricultural Export Excellence Award, which shall be evidenced by a medal bearing the inscription “Edward R. Madigan United States Agricultural Export Excellence Award”. The medal shall be of such design and materials and bear such additional inscriptions as the Secretary of Agriculture (referred to in this section as the “Secretary”) may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcb7e3e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of recipient","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President or the Secretary (on the basis of recommendations received from the board established under subsection (h)) shall periodically provide the award to companies and other entities that in the judgment of the President or the Secretary substantially encourage entrepreneurial efforts in the food and agriculture sector for advancing United States agricultural exports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcb7e3f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presentation of award","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The presentation of the award shall be made by the President or the Secretary with such ceremonies as the President or the Secretary considers proper.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcb7e40-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of award","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity to which an award is made under this section may publicize the receipt of the award by the entity and use the award in advertising of the entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcb7e41-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Categories for which award may be given","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Separate awards shall be made to qualifying entities in each of the following categories:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcb7e42-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development of new products or services for agricultural export markets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7e43-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development of new agricultural export markets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7e44-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Creative marketing of products or services in agricultural export markets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcb7e45-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for qualification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity may qualify for an award under this section only if the entity—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcb7e46-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefcb7e47-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applies to the board established under subsection (h) in writing for the award; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcb7e48-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is recommended for the award by a Governor of a State;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7e49-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefcb7e4a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has exhibited significant entrepreneurial effort to create new markets for United States agricultural exports or increase United States agricultural exports; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcb7e4b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has provided significant assistance to others in an effort to create new markets for United States agricultural exports or increase United States agricultural exports;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7e4c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not received another award in the same category under subsection (f) during the preceding 5-year period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7e4d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets such other requirements and specifications as the Secretary determines are appropriate to achieve the objectives of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcb7e4e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcb7e4f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint a board of evaluators, consisting of at least 5 individuals from the private sector selected for their knowledge and experience in exporting United States agricultural products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7e50-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The board shall meet at least once annually to review and evaluate all applicants and entities recommended by States under subsection (g)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7e51-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations of board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The board shall report its recommendations concerning the making of the award to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7e52-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the board may serve a term of not to exceed 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcb7e53-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5678/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may seek and accept gifts from public and private sources to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefcdee54-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s261"},"text":"Pub. L. 104–127, title II, § 261","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/972"},"text":"110 Stat. 972","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefcdee55-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefcdee56-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefcdee57-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Federal Agriculture Improvement and Reform Act of 1996, and not as part of the Agricultural Trade Act of 1978 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
