) applies to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0130ed5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7611/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research activities conducted by the Agricultural Research Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0130ed6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7611/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research, extension, or education activities administered, on a competitive basis, by the National Institute of Food and Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0130ed7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/tI/s101"},"text":"Pub. L. 105–185, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/526"},"text":"112 Stat. 526","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7511/c/29"},"text":"Pub. L. 110–234, title VII, § 7511(c)(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1270"},"text":"122 Stat. 1270","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7511(c)(29), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2031.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNot