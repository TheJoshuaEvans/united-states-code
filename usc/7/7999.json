{"tag":"section","attrib":{"id":"idf02adc3b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7999"},"text":null,"children":[{"tag":"num","attrib":{"value":"7999"},"text":"§ 7999.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of incentive payments for certain producers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf02adc3c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7999/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentive payments required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), the Secretary shall make available a total of $20,000,000 of funds of the Commodity Credit Corporation during the 2003 through 2005 crop years to provide incentive payments to producers of hard white wheat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adc3d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7999/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions on implementation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall implement subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adc3e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7999/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only with regard to production that meets minimum quality criteria; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adc3f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7999/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on not more than 2,000,000 acres or the equivalent volume of production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adc40-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7999/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demand for wheat","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to obtain an incentive payment under subsection (a), a producer shall demonstrate to the satisfaction of the Secretary that buyers and end-users are available for the wheat to be covered by the incentive payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf02adc41-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1616"},"text":"Pub. L. 107–171, title I, § 1616","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/222"},"text":"116 Stat. 222","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
