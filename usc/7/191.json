{"tag":"section","attrib":{"id":"idee1bf84a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s191"},"text":null,"children":[{"tag":"num","attrib":{"value":"191"},"text":"§ 191.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Packer” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When used in this chapter the term “packer” means any person engaged in the business (a) of buying livestock in commerce for purposes of slaughter, or (b) of manufacturing or preparing meats or meat food products for sale or shipment in commerce, or (c) of marketing meats, meat food products, or livestock products in an unmanufactured form acting as a wholesale broker, dealer, or distributor in commerce.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee1bf84b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-08-15/ch64"},"text":"Aug. 15, 1921, ch. 64","children":[],"tail":", title II, § 201, "},{"tag":"ref","attrib":{"href":"/us/stat/42/160"},"text":"42 Stat. 160","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/410/s2"},"text":"Pub. L. 94–410, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-13"},"text":"Sept. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1249"},"text":"90 Stat. 1249","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee1bf84c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee1bf84d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee1bf84e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/410"},"text":"Pub. L. 94–410","children":[],"tail":" substituted definition of “packer” for former definition which included provisions dealing with direct or indirect control of specified businesses through stock ownership or otherwise."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
