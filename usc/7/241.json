{"tag":"section","attrib":{"id":"idee20b458-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s241"},"text":null,"children":[{"tag":"num","attrib":{"value":"241"},"text":"§ 241.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee20b459-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s241/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agricultural product” means an agricultural commodity, as determined by the Secretary, including a processed product of an agricultural commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee20b45a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s241/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “approval” means the consent provided by the Secretary for a person to engage in an activity authorized by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee20b45b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s241/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department” means the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee20b45c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s241/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic document","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “electronic document” means a document that is generated, sent, received, or stored by electronic, optical, or similar means, including electronic data interchange, electronic mail, telegram, telex, or telecopy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee20b45d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s241/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic receipt","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “electronic receipt” means a receipt that is authorized by the Secretary to be issued or transmitted under this chapter in the form of an electronic document.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee20b45e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s241/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Holder","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “holder” means a person that has possession in fact or by operation of law of a receipt or any electronic document.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee20b45f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s241/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee20b460-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s241/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t1/s1"},"text":"section 1 of title 1","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee20b461-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s241/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee20b462-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s241/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee20b463-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s241/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “receipt” means a warehouse receipt issued in accordance with this chapter, including an electronic receipt.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee20b464-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s241/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee20b465-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s241/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Warehouse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “warehouse” means a structure or other approved storage facility, as determined by the Secretary, in which any agricultural product may be stored or handled for the purposes of interstate or foreign commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee232466-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s241/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Warehouse operator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “warehouse operator” means a person that is lawfully engaged in the business of storing or handling agricultural products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee232467-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, § 2, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/472/tII/s201"},"text":"Pub. L. 106–472, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2061"},"text":"114 Stat. 2061","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee232468-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee232469-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee23246a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter constitutes part C of “An act making appropriations for the Department of Agriculture for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1917-06-13"},"text":"June 13, 1917","children":[],"tail":", and for other purposes,” approved "},{"tag":"date","attrib":{"date":"1916-08-11"},"text":"Aug. 11, 1916","children":[],"tail":". Part A of "},{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"act of Aug. 11, 1916, ch. 313","children":[],"tail":", containing the “United States Cotton Futures Act” formerly classified to chapter 13 of Title 26, Internal Revenue Code, was repealed by section 4 of "},{"tag":"ref","attrib":{"href":"/us/act/1939-02-10/ch2"},"text":"act Feb. 10, 1939, ch. 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1"},"text":"53 Stat. 1","children":[],"tail":". Part B of that act contained the “United States Grain Standards Act” and constitutes section 71 et seq. of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee23246b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 241, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"act Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, § 1, "},{"tag":"ref","attrib":{"href":"/us/stat/39/486"},"text":"39 Stat. 486","children":[],"tail":", set forth short title, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/472"},"text":"Pub. L. 106–472","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 2 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"act Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s242"},"text":"section 242 of this title","children":[],"tail":", prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/472"},"text":"Pub. L. 106–472","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee23246c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idee23246d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Act Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, § 1, as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/472/tII/s201"},"text":"Pub. L. 106–472, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2061"},"text":"114 Stat. 2061","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/472/tII/s201"},"text":"“This Act [enacting this chapter] may be cited as the ‘United States Warehouse Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idee23246e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date; Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/472/tII/s202"},"text":"Pub. L. 106–472, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2068"},"text":"114 Stat. 2068","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/472/tII/s202"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proposed Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":"], the Secretary of Agriculture shall publish in the Federal Register proposed regulations for carrying out the amendment made by section 201 [enacting this chapter]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Final Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act, the Secretary shall promulgate final regulations for carrying out the amendment made by section 201.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effectiveness of Existing Act","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The United States Warehouse Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s241"},"text":"7 U.S.C. 241","children":[],"tail":" et seq.) (as it existed before the amendment made by section 201) shall be effective until the earlier of—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which final regulations are promulgated under subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2001-08-01"},"text":"August 1, 2001","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
