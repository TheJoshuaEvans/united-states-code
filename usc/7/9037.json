{"tag":"section","attrib":{"id":"idf04c46e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037"},"text":null,"children":[{"tag":"num","attrib":{"value":"9037"},"text":"§ 9037.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special marketing loan provisions for upland cotton","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf04c46e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special import quota","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04c46e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of special import quota","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “special import quota” means a quantity of imports that is not subject to the over-quota tariff rate of a tariff-rate quota.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c46e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c46e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall carry out an import quota program beginning on ","children":[{"tag":"date","attrib":{"date":"2014-08-01"},"text":"August 1, 2014","children":[],"tail":", as provided in this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c46ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Secretary determines and announces that for any consecutive 4-week period, the Friday through Thursday average price quotation for the lowest-priced United States growth, as quoted for Middling (M) 1","children":[{"tag":"sup","attrib":{},"text":"3","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"32","children":[],"tail":"-inch cotton, delivered to a definable and significant international market, as determined by the Secretary, exceeds the prevailing world market price, there shall immediately be in effect a special import quota."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c46eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quantity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The quota shall be equal to the consumption during a 1-week period of cotton by domestic mills at the seasonally adjusted average rate of the most recent 3 months for which official data of the Department of Agriculture are available or, in the absence of sufficient data, as estimated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c46ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The quota shall apply to upland cotton purchased not later than 90 days after the date of the Secretary’s announcement under paragraph (2) and entered into the United States not later than 180 days after that date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c46ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overlap","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A special quota period may be established that overlaps any existing quota period if required by paragraph (2), except that a special quota period may not be established under this subsection if a quota period has been established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c46ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferential tariff treatment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The quantity under a special import quota shall be considered to be an in-quota quantity for purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c46ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2703/d"},"text":"section 2703(d) of title 19","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c46f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3203"},"text":"section 3203 of title 19","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c46f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2463/d"},"text":"section 2463(d) of title 19","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c46f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/a/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" General Note 3(a)(iv) to the Harmonized Tariff Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c46f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The quantity of cotton entered into the United States during any marketing year under the special import quota established under this subsection may not exceed the equivalent of 10 weeks’ consumption of upland cotton by domestic mills at the seasonally adjusted average rate of the 3 months immediately preceding the first special import quota established in any marketing year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c46f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited global import quota for upland cotton","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04c46f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c46f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demand","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “demand” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf04c46f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average seasonally adjusted annual rate of domestic mill consumption of cotton during the most recent 3 months for which official data of the Department of Agriculture are available or, in the absence of sufficient data, as estimated by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04c46f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the larger of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf04c46f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/b/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" average exports of upland cotton during the preceding 6 marketing years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf04c46fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/b/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cumulative exports of upland cotton plus outstanding export sales for the marketing year in which the quota is established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c46fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited global import quota","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “limited global import quota” means a quantity of imports that is not subject to the over-quota tariff rate of a tariff-rate quota.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c46fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supply","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “supply” means, using the latest official data of the Department of Agriculture—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf04c46fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the carry-over of upland cotton at the beginning of the marketing year (adjusted to 480-pound bales) in which the quota is established;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04c46fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" production of the current crop; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04c46ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imports to the latest date available during the marketing year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c4700-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall carry out an import quota program that provides that whenever the Secretary determines and announces that the average price of the base quality of upland cotton, as determined by the Secretary, in the designated spot markets for a month exceeded 130 percent of the average price of the quality of cotton in the markets for the preceding 36 months, notwithstanding any other provision of law, there shall immediately be in effect a limited global import quota subject to the following conditions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c4701-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quantity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The quantity of the quota shall be equal to 21 days of domestic mill consumption of upland cotton at the seasonally adjusted average rate of the most recent 3 months for which official data of the Department of Agriculture are available or, in the absence of sufficient data, as estimated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c4702-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quantity if prior quota","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a quota has been established under this subsection during the preceding 12 months, the quantity of the quota next established under this subsection shall be the smaller of 21 days of domestic mill consumption calculated under subparagraph (A) or the quantity required to increase the supply to 130 percent of the demand.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c4703-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferential tariff treatment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The quantity under a limited global import quota shall be considered to be an in-quota quantity for purposes of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf04c4704-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2703/d"},"text":"section 2703(d) of title 19","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04c4705-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3203"},"text":"section 3203 of title 19","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04c4706-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2463/d"},"text":"section 2463(d) of title 19","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04c4707-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/b/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" General Note 3(a)(iv) to the Harmonized Tariff Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c4708-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quota entry period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When a quota is established under this subsection, cotton may be entered under the quota during the 90-day period beginning on the date the quota is established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c4709-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No overlap","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (2), a quota period may not be established that overlaps an existing quota period or a special quota period established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c470a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic adjustment assistance for textile mills","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04c470b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary shall, on a monthly basis, make economic adjustment assistance available to domestic users of upland cotton in the form of payments for all documented use of that upland cotton during the previous monthly period regardless of the origin of the upland cotton.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c470c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Value of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The value of the assistance provided under paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c470d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the period beginning on ","children":[{"tag":"date","attrib":{"date":"2013-08-01"},"text":"August 1, 2013","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2025-07-31"},"text":"July 31, 2025","children":[],"tail":", 3 cents per pound; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c470e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning on ","children":[{"tag":"date","attrib":{"date":"2025-08-01"},"text":"August 1, 2025","children":[],"tail":", 5 cents per pound."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c470f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowable purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Economic adjustment assistance under this subsection shall be made available only to domestic users of upland cotton that certify that the assistance shall be used only to acquire, construct, install, modernize, develop, convert, or expand land, plant, buildings, equipment, facilities, or machinery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c4710-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review or audit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may conduct such review or audit of the records of a domestic user under this subsection as the Secretary determines necessary to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c4711-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improper use of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines, after a review or audit of the records of the domestic user, that economic adjustment assistance under this subsection was not used for the purposes specified in paragraph (3), the domestic user shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c4712-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" liable for the repayment of the assistance to the Secretary, plus interest, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c4713-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9037/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ineligible to receive assistance under this subsection for a period of 1 year following the determination of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf04c4714-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1207"},"text":"Pub. L. 113–79, title I, § 1207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/682"},"text":"128 Stat. 682","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI/s1203/b"},"text":"Pub. L. 115–334, title I, § 1203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4510"},"text":"132 Stat. 4510","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10311"},"text":"Pub. L. 119–21, title I, § 10311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/96"},"text":"139 Stat. 96","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf04c4715-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf04c4716-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf04c4717-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Harmonized Tariff Schedule, referred to in subsecs. (a)(6)(D) and (b)(2)(C)(iv), is not set out in the Code. See Publication of Harmonized Tariff Schedule note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of Title 19","children":[],"tail":", Customs Duties."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf04c4718-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" added par. (2) and struck out former par. (2). Prior to amendment, text read as follows: “Effective beginning on "},{"tag":"date","attrib":{"date":"2013-08-01"},"text":"August 1, 2013","children":[],"tail":", the value of the assistance provided under paragraph (1) shall be 3 cents per pound.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “Economic adjustment assistance for textile mills” for “Economic adjustment assistance to users of upland cotton” in heading."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
