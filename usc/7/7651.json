{"tag":"section","attrib":{"id":"idf017c9f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7651"},"text":null,"children":[{"tag":"num","attrib":{"value":"7651"},"text":"§ 7651.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nutrient composition data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf017c9f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7651/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall update, on a periodic basis, nutrient composition data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf017c9f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7651/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that describes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf017c9f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7651/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the method the Secretary will use to update nutrient composition data, including the quality assurance criteria that will be used and the method for generating the data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf017c9f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7651/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the timing for updating the data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf017c9f6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/tVI/s611"},"text":"Pub. L. 105–185, title VI, § 611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/605"},"text":"112 Stat. 605","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
