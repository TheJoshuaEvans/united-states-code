{"tag":"section","attrib":{"id":"idedc88120-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r"},"text":null,"children":[{"tag":"num","attrib":{"value":"6r"},"text":"§ 6r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting and recordkeeping for uncleared swaps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idedc88121-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required reporting of swaps not accepted by any derivatives clearing organization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedc88122-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each swap that is not accepted for clearing by any derivatives clearing organization shall be reported to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedc88123-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a swap data repository described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s24a"},"text":"section 24a of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedc88124-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case in which there is no swap data repository that would accept the swap, to the Commission pursuant to this section within such time period as the Commission may by rule or regulation prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedc88125-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition rule for preenactment swaps","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedc88126-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Swaps entered into before ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":null}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each swap entered into before ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", the terms of which have not expired as of "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", shall be reported to a registered swap data repository or the Commission by a date that is not later than—"}],"tail":null},{"tag":"clause","attrib":{"id":"idedc88127-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 30 days after issuance of the interim final rule; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedc88128-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other period as the Commission determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedc88129-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall promulgate an interim final rule within 90 days of ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", providing for the reporting of each swap entered into before "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedc8812a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reporting provisions described in this section shall be effective upon the enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedc8812b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting obligations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedc8812c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Swaps in which only 1 counterparty is a swap dealer or major swap participant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a swap in which only 1 counterparty is a swap dealer or major swap participant, the swap dealer or major swap participant shall report the swap as required under paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedc8812d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Swaps in which 1 counterparty is a swap dealer and the other a major swap participant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a swap in which 1 counterparty is a swap dealer and the other a major swap participant, the swap dealer shall report the swap as required under paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedc8812e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other swaps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any other swap not described in subparagraph (A) or (B), the counterparties to the swap shall select a counterparty to report the swap as required under paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedc8812f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of certain individuals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any individual or entity that enters into a swap shall meet each requirement described in subsection (c) if the individual or entity did not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedc88130-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clear the swap in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2/h/1"},"text":"section 2(h)(1) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedc88131-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the data regarding the swap accepted by a swap data repository in accordance with rules (including timeframes) adopted by the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s24a"},"text":"section 24a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedc88132-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual or entity described in subsection (b) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedc88133-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon written request from the Commission, provide reports regarding the swaps held by the individual or entity to the Commission in such form and in such manner as the Commission may request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedc88134-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" maintain books and records pertaining to the swaps held by the individual or entity in such form, in such manner, and for such period as the Commission may require, which shall be open to inspection by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedc88135-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any representative of the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedc88136-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appropriate prudential regulator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedc88137-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Securities and Exchange Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedc88138-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Financial Stability Oversight Council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedc88139-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Justice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedc8813a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6r/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identical data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In prescribing rules under this section, the Commission shall require individuals and entities described in subsection (b) to submit to the Commission a report that contains data that is not less comprehensive than the data required to be collected by swap data repositories under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s24a"},"text":"section 24a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idedc8813b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369/s4r"},"text":"Sept. 21, 1922, ch. 369, § 4r","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVII/s729"},"text":"Pub. L. 111–203, title VII, § 729","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1701"},"text":"124 Stat. 1701","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idedc8813c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idedc8813d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idedc8813e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the later of 360 days after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", or, to the extent a provision of subtitle A (§§ 711–754) of title VII of "},{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" requires a rulemaking, not less than 60 days after publication of the final rule or regulation implementing such provision of subtitle A, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s754"},"text":"section 754 of Pub. L. 111–203","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1a"},"text":"section 1a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
