{"tag":"section","attrib":{"id":"idf0405f9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8735"},"text":null,"children":[{"tag":"num","attrib":{"value":"8735"},"text":"§ 8735.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan deficiency payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0405f9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8735/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of loan deficiency payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0405fa0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8735/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (d), the Secretary may make loan deficiency payments available to producers on a farm that, although eligible to obtain a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8731"},"text":"section 8731 of this title","children":[],"tail":" with respect to a loan commodity, agree to forgo obtaining the loan for the commodity in return for loan deficiency payments under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0405fa1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8735/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unshorn pelts, hay, and silage","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0405fa2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8735/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marketing assistance loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), nongraded wool in the form of unshorn pelts and hay and silage derived from a loan commodity are not eligible for a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8731"},"text":"section 8731 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0405fa3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8735/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan deficiency payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective for the 2008 through 2012 crop years, the Secretary may make loan deficiency payments available under this section to producers on a farm that produce unshorn pelts or hay and silage derived from a loan commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0405fa4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8735/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A loan deficiency payment for a loan commodity or commodity referred to in subsection (a)(2) shall be computed by multiplying—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0405fa5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8735/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment rate determined under subsection (c) for the commodity; by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0405fa6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8735/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of the commodity produced by the eligible producers, excluding any quantity for which the producers obtain a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8731"},"text":"section 8731 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0405fa7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8735/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment rate","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0405fa8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8735/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a loan commodity, the payment rate shall be the amount by which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0405fa9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8735/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8732"},"text":"section 8732 of this title","children":[],"tail":" for the loan commodity; exceeds"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0405faa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8735/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate at which a marketing assistance loan for the loan commodity may be repaid under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8734"},"text":"section 8734 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0405fab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8735/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unshorn pelts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of unshorn pelts, the payment rate shall be the amount by which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0405fac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8735/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8732"},"text":"section 8732 of this title","children":[],"tail":" for ungraded wool; exceeds"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0405fad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8735/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate at which a marketing assistance loan for ungraded wool may be repaid under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8734"},"text":"section 8734 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0405fae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8735/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hay and silage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of hay or silage derived from a loan commodity, the payment rate shall be the amount by which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0405faf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8735/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8732"},"text":"section 8732 of this title","children":[],"tail":" for the loan commodity from which the hay or silage is derived; exceeds"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0405fb0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8735/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate at which a marketing assistance loan for the loan commodity may be repaid under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8734"},"text":"section 8734 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0405fb1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8735/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for extra long staple cotton","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply with respect to extra long staple cotton.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0405fb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8735/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date for payment rate determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine the amount of the loan deficiency payment to be made under this section to the producers on a farm with respect to a quantity of a loan commodity or commodity referred to in subsection (a)(2) using the payment rate in effect under subsection (c) as of the date the producers request the payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0405fb3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1205"},"text":"Pub. L. 110–234, title I, § 1205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/958"},"text":"122 Stat. 958","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1205, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1686.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0405fb4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0405fb5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf0405fb6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf0405fb7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf0405fb8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
