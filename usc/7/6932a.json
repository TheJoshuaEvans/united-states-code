{"tag":"section","attrib":{"id":"ideff413ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6932a"},"text":"§ 6932a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on closure or relocation of county offices for the Farm Service Agency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff413ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary prohibition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff413ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), until the date that is two years after the date of the enactment of this Act, the Secretary of Agriculture may not close or relocate a county or field office of the Farm Service Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff413af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff413b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an office that is located not more than 20 miles from another office of the Farm Service Agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff413b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relocation of an office within the same county in the course of routine leasing operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff413b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on closure; notice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff413b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After the period referred to in subsection (a)(1), the Secretary shall, before closing any office of the Farm Service Agency that is located more than 20 miles from another office of the Farm Service Agency, to the maximum extent practicable, first close any offices of the Farm Service Agency that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff413b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are located less than 20 miles from another office of the Farm Service Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff413b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have two or fewer permanent full-time employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff413b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After the period referred to in subsection (a)(1), the Secretary of Agriculture may not close a county or field office of the Farm Service Agency unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff413b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 30 days after the Secretary proposes to close such office, the Secretary holds a public meeting regarding the proposed closure in the county in which such office is located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff413b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6932a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the public meeting referred to in subparagraph (A), but not less than 90 days before the date on which the Secretary approves the closure of such office, the Secretary notifies the Committee on Agriculture and the Committee on Appropriations of the House of Representatives, the Committee on Agriculture, Nutrition, and Forestry and the Committee on Appropriations of the Senate, each Senator representing the State in which the office proposed to be closed is located, and the member of the House of Representatives who represents the Congressional district in which the office proposed to be closed is located of the proposed closure of such office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff413b9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14212"},"text":"Pub. L. 110–234, title XIV, § 14212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1465"},"text":"122 Stat. 1465","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14212, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2227.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideff413ba-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideff413bb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideff413bc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this Act, referred to in subsec. (a)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideff413bd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food, Conservation, and Energy Act of 2008, and not as part of the Department of Agriculture Reorganization Act of 1994, which in part comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideff413be-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideff413bf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
