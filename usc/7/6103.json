{"tag":"section","attrib":{"id":"idefdc46e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6103"},"text":null,"children":[{"tag":"num","attrib":{"value":"6103"},"text":"§ 6103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefdc46e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To effectuate the declared policy of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6101/b"},"text":"section 6101(b) of this title","children":[],"tail":", the Secretary, subject to the procedures provided in subsection (b), shall issue orders under this chapter applicable to producers, importers, and first handlers of mushrooms. Any such order shall be national in scope. Not more than one order shall be in effect under this chapter at any one time."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc46e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefdc46ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of an order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may propose the issuance of an order under this chapter, or an association of mushroom producers or any other person that will be affected by this chapter may request the issuance of, and submit a proposal for, such an order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the receipt of a request and proposal by an interested person for an order, or when the Secretary determines to propose an order, the Secretary shall publish the proposed order and give due notice and opportunity for public comment on the proposed order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After notice and opportunity for public comment are given, as provided in paragraph (2), the Secretary shall issue the order, taking into consideration the comments received and including in the order provisions necessary to ensure that the order is in conformity with the requirements of this chapter. Such order shall be issued and, if approved by producers and importers of mushrooms as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6105/a"},"text":"section 6105(a) of this title","children":[],"tail":", shall become effective not later than 180 days following publication of the proposed order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc46ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefdc46ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, from time to time, may amend any order issued under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of chapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this chapter applicable to an order shall be applicable to amendments to the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefdc46f0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1924"},"text":"Pub. L. 101–624, title XIX, § 1924","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3856"},"text":"104 Stat. 3856","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
