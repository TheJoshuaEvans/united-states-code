{"tag":"section","attrib":{"id":"idedc3c68e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6h"},"text":null,"children":[{"tag":"num","attrib":{"value":"6h"},"text":"§ 6h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False self-representation as registered entity member prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any person falsely to represent such person to be a member of a registered entity or the representative or agent of such member, or to be a registrant under this chapter or the representative or agent of any registrant, in soliciting or handling any order or contract for the purchase or sale of any commodity in interstate commerce or for future delivery, or falsely to represent in connection with the handling of any such order or contract that the same is to be or has been executed on, or by or through a member of, any registered entity.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idedc3c68f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369/s4h"},"text":"Sept. 21, 1922, ch. 369, § 4h","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-15/ch545/s5"},"text":"June 15, 1936, ch. 545, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1496"},"text":"49 Stat. 1496","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/444/tII/s210"},"text":"Pub. L. 97–444, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-11"},"text":"Jan. 11, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2302"},"text":"96 Stat. 2302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tI/s123/a/8"},"text":"Pub. L. 106–554, § 1(a)(5) [title I, § 123(a)(8)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–407.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idedc3c690-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idedc3c691-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idedc3c692-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" substituted “registered entity” for “contract market” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/444"},"text":"Pub. L. 97–444","children":[],"tail":" struck out provisions formerly designated as par. (1) relating to conduct of offices or places of business anywhere in the United States or its territories that were used for dealing in commodities for future delivery unless such dealings were executed or consummated by or through a member of a contract market, which provisions were transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6/a"},"text":"section 6(a) of this title","children":[],"tail":", and broadened remaining provisions, formerly designated as par. (2), to prohibit false representations that a person is registered with the Commission in any capacity, and not only as a futures commission merchant, as previously provided."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idedc3c693-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idedc3c694-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/444"},"text":"Pub. L. 97–444","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1983-01-11"},"text":"Jan. 11, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/444/s239"},"text":"section 239 of Pub. L. 97–444","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idedc3c695-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of section, see section 13 of act ","children":[{"tag":"date","attrib":{"date":"1936-06-15"},"text":"June 15, 1936","children":[],"tail":", set out as an Effective Date of 1936 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
