{"tag":"section","attrib":{"id":"idefbadbbb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4605"},"text":null,"children":[{"tag":"num","attrib":{"value":"4605"},"text":"§ 4605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and issuance of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"After notice and opportunity for comment has been provided in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4604/a"},"text":"section 4604(a) of this title","children":[],"tail":", the Secretary shall issue an order, an amendment to an order, or a regulation under this chapter, if the Secretary finds, and specifies in the order, amendment, or regulation, that the issuance of the order, amendment, or regulation will assist in carrying out the purposes of this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefbadbbc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/590/s6"},"text":"Pub. L. 98–590, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3117"},"text":"98 Stat. 3117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tVI/s605/e"},"text":"Pub. L. 105–185, title VI, § 605(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/589"},"text":"112 Stat. 589","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefbadbbd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefbadbbe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefbadbbf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185"},"text":"Pub. L. 105–185","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows: “After notice of and opportunity for a hearing has been provided in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4604"},"text":"section 4604 of this title","children":[],"tail":", the Secretary shall issue an order if the Secretary finds, and sets forth in such order, that, upon the evidence introduced at such hearing, the issuance of such order and all the terms and conditions thereof will assist in carrying out the purpose of this chapter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
