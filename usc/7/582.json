{"tag":"section","attrib":{"id":"idee3fad64-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s582"},"text":null,"children":[{"tag":"num","attrib":{"value":"582"},"text":"§ 582.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of establishment of standards; shipments under contracts made before adoption of standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall give reasonable notice through one or more trade papers of the effective date of standards of export established or designated by him under this chapter: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That any apples may be certified and shipped for export in fulfillment of any contract made within six months prior to the date of such shipment if the terms of such contract were in accordance with the grades and regulations of the Secretary in effect at the time the contract was made."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee3fad65-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-10/ch59/s2"},"text":"June 10, 1933, ch. 59, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/123"},"text":"48 Stat. 123","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/96/s1/c/2"},"text":"Pub. L. 106–96, § 1(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1321"},"text":"113 Stat. 1321","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee3fad66-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee3fad67-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee3fad68-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/96"},"text":"Pub. L. 106–96","children":[],"tail":" struck out “or pears” after “any apples”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
