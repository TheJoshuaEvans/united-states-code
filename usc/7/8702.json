{"tag":"section","attrib":{"id":"idf03dee1b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702"},"text":null,"children":[{"tag":"num","attrib":{"value":"8702"},"text":"§ 8702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter (other than subchapter III):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03dee1c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Average crop revenue election payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “average crop revenue election payment” means a payment made to producers on a farm under section 8715 ","children":[{"tag":"ref","attrib":{"idref":"fn002373"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002373"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee1d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Base acres","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03dee1e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “base acres”, with respect to a covered commodity on a farm, means the number of acres established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7911"},"text":"section 7911 of this title","children":[],"tail":" as in effect on "},{"tag":"date","attrib":{"date":"2007-09-30"},"text":"September 30, 2007","children":[],"tail":", subject to any adjustment under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8711"},"text":"section 8711 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03dee1f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peanuts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “base acres for peanuts” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8751"},"text":"section 8751 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee20-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counter-cyclical payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “counter-cyclical payment” means a payment made to producers on a farm under section 8714 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee21-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered commodity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered commodity” means wheat, corn, grain sorghum, barley, oats, upland cotton, long grain rice, medium grain rice, pulse crops, soybeans, and other oilseeds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee22-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “direct payment” means a payment made to producers on a farm under section 8713 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee23-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “effective price”, with respect to a covered commodity for a crop year, means the price calculated by the Secretary under section 8714 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title to determine whether counter-cyclical payments are required to be made for that crop year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee24-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extra long staple cotton","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “extra long staple cotton” means cotton that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03dee25-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is produced from pure strain varieties of the Barbadense species or any hybrid of the species, or other similar types of extra long staple cotton, designated by the Secretary, having characteristics needed for various end uses for which United States upland cotton is not suitable and grown in irrigated cotton-growing regions of the United States designated by the Secretary or other areas designated by the Secretary as suitable for the production of the varieties or types; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03dee26-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is ginned on a roller-type gin or, if authorized by the Secretary, ginned on another type gin for experimental purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee27-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan commodity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “loan commodity” means wheat, corn, grain sorghum, barley, oats, upland cotton, extra long staple cotton, long grain rice, medium grain rice, soybeans, other oilseeds, graded wool, nongraded wool, mohair, honey, dry peas, lentils, small chickpeas, and large chickpeas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee28-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medium grain rice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “medium grain rice” includes short grain rice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee29-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other oilseed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “other oilseed” means a crop of sunflower seed, rapeseed, canola, safflower, flaxseed, mustard seed, crambe, sesame seed, or any oilseed designated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee2a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment acres","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “payment acres” means, in the case of direct payments and counter-cyclical payments—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03dee2b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subparagraph (B), 85 percent of the base acres of a covered commodity on a farm on which direct payments or counter-cyclical payments are made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03dee2c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of direct payments for each of the 2009 through 2011 crop years, 83.3 percent of the base acres for the covered commodity on a farm on which direct payments are made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee2d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment yield","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “payment yield” means the yield established for direct payments and the yield established for counter-cyclical payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7912"},"text":"section 7912 of this title","children":[],"tail":" as in effect on "},{"tag":"date","attrib":{"date":"2007-09-30"},"text":"September 30, 2007","children":[],"tail":", or under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8712"},"text":"section 8712 of this title","children":[],"tail":", for a farm for a covered commodity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee2e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03dee2f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “producer” means an owner, operator, landlord, tenant, or sharecropper that shares in the risk of producing a crop and is entitled to share in the crop available for marketing from the farm, or would have shared had the crop been produced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03dee30-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hybrid seed","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether a grower of hybrid seed is a producer, the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf03dee31-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/13/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not take into consideration the existence of a hybrid seed contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf03dee32-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/13/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that program requirements do not adversely affect the ability of the grower to receive a payment under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee33-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pulse crop","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “pulse crop” means dry peas, lentils, small chickpeas, and large chickpeas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee34-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03dee35-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03dee36-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03dee37-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/15/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commonwealth of Puerto Rico; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03dee38-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/15/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee39-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Target price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “target price” means the price per bushel, pound, or hundredweight (or other appropriate unit) of a covered commodity used to determine the payment rate for counter-cyclical payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee3a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States”, when used in a geographical sense, means all of the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee3b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8702/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Premium Factor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States Premium Factor” means the percentage by which the difference in the United States loan schedule premiums for Strict Middling (SM) 1⅛-inch upland cotton and for Middling (M) 1","children":[{"tag":"sup","attrib":{},"text":"3","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"32","children":[],"tail":"-inch upland cotton exceeds the difference in the applicable premiums for comparable international qualities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf03dee3c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{