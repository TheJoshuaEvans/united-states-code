{"tag":"section","attrib":{"id":"idee20b415-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s228b–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"228b–4"},"text":"§ 228b–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violation of final order by live poultry dealer; penalty","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any live poultry dealer, or any officer, director, agent, or employee of a live poultry dealer, who fails to obey any order of the Secretary issued under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s228b–2"},"text":"section 228b–2 of this title","children":[],"tail":", or such order as modified—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idee20b416-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s228b–4/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the expiration of the time allowed for filing a petition in the court of appeals to set aside or modify such order, if no such petition has been filed within such time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee20b417-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s228b–4/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the expiration of the time allowed for applying for a writ of certiorari, if such order, or such order as modified, has been sustained by the court of appeals and no such writ has been applied for within such time; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee20b418-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s228b–4/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after such order, or such order as modified, has been sustained by the courts as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s228b–3"},"text":"section 228b–3 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall on conviction be fined not less than $1,000 nor more than $20,000. Each day during which such failure continues shall be deemed a separate offense.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee20b419-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-08-15/ch64"},"text":"Aug. 15, 1921, ch. 64","children":[],"tail":", title IV, § 413, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/173/s9/2"},"text":"Pub. L. 100–173, § 9(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-23"},"text":"Nov. 23, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/922"},"text":"101 Stat. 922","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee20b41a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee20b41b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idee20b41c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1987-11-23"},"text":"Nov. 23, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/173/s12"},"text":"section 12 of Pub. L. 100–173","children":[],"tail":", set out as an Effective Date of 1987 Amendment note under "},{"tag":"ref","at