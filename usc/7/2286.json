{"tag":"section","attrib":{"id":"idef81a379-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2286"},"text":null,"children":[{"tag":"num","attrib":{"value":"2286"},"text":"§ 2286.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of committees","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall terminate any advisory committee upon a finding that any such advisory committee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef81a37a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2286/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has expended funds in excess of its estimated annual operating costs by more than 10 per centum or $500, whichever is greater, without the prior approval of the Secretary pursuant to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2285"},"text":"section 2285 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef81a37b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2286/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has failed to file all reports required under the provisions of chapter 10 of title 5 or this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef81a37c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2286/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has failed to meet for two consecutive years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef81a37d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2286/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is responsible for functions that otherwise would be or should be performed by Federal employees; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef81a37e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2286/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not serve or has ceased to serve an essential public function.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef81a37f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXVIII/s1806"},"text":"Pub. L. 95–113, title XVIII, § 1806","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1042"},"text":"91 Stat. 1042","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXI/s1116/a"},"text":"Pub. L. 97–98, title XI, § 1116(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1271"},"text":"95 Stat. 1271","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/30"},"text":"Pub. L. 117–286, § 4(a)(30)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4308"},"text":"136 Stat. 4308","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef81a380-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef81a381-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef81a382-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5” for “the Federal Advisory Committee Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98"},"text":"Pub. L. 97–98","children":[],"tail":" substituted provision relating to termination of advisory committees for provision relating to advisory committee charter requirements."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef81a383-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef81a384-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98"},"text":"Pub. L. 97–98","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1801"},"text":"section 1801 of Pub. L. 97–98","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idef81a385-3a6e-11f1-addd-bbaf0b3f68