{"tag":"section","attrib":{"id":"ideeb21eab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471"},"text":null,"children":[{"tag":"num","attrib":{"value":"1471"},"text":"§ 1471.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeb21eac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “livestock producer” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeb21ead-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a person that is actively engaged in farming and that receives a substantial amount of total income from the production of grain or livestock, as determined by the Secretary, that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideeb21eae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an established producer or husbander of livestock or a dairy producer who is a citizen of, or legal resident alien in, the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideeb21eaf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a farm cooperative, private domestic corporation, partnership, or joint operation in which a majority interest is held by members, stockholders, or partners who are citizens of, or legal resident aliens in, the United States, if such cooperative, corporation, partnership, or joint operation is engaged in livestock production or husbandry, or dairy production; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeb21eb0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any ","children":[{"tag":"ref","attrib":{"idref":"fn002163"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002163"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" of the following entities that is actively engaged in livestock production or husbandry, or dairy production—"}],"tail":null},{"tag":"clause","attrib":{"id":"ideeb21eb1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Indian tribe (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/b"},"text":"section 5304(b) of title 25","children":[],"tail":"); "},{"tag":"ref","attrib":{"idref":"fn002164"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002164"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideeb21eb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Indian organization or entity chartered under the Act of ","children":[{"tag":"date","attrib":{"date":"1934-06-18"},"text":"June 18, 1934","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/48/984"},"text":"48 Stat. 984","children":[],"tail":", chapter 576; "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s461"},"text":"25 U.S.C. 461","children":[],"tail":" et seq.),"},{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" commonly known as the “Indian Reorganization Act”;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideeb21eb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any tribal organization (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/c"},"text":"section 5304(c) of title 25","children":[],"tail":"); "},{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideeb21eb4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any economic enterprise (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1452/e"},"text":"section 1452(e) of title 25","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb21eb5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “livestock” means cattle, elk, reindeer, bison, horses, deer, sheep, goats, swine, poultry (including egg-producing poultry), llamas, alpacas, live fish, crawfish, and other animals that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeb21eb6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are part of a foundation herd (including producing dairy cattle) or offspring; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeb21eb7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are purchased as part of a normal operation and not to obtain additional benefits under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb21eb8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means any State of the United States, the Commonwealth of Puerto Rico, the Virgin Islands, or Guam.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb21eb9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “feed”, for the purposes of emergency feed assistance, means any type of feed (including feed grain, oilseed meal, premix or mixed feed, liquid or dry supplemental feed, roughage, pasture, or forage) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeb21eba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" best suits the livestock producer’s operation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeb21ebb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with acceptable feed practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb21ebc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “area” includes any Indian reservation (as defined in section 1985(e)(1)(D)(ii) ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" of this title)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideeb21ebd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-31/ch792"},"text":"Oct. 31, 1949, ch. 792","children":[],"tail":", title VI, § 602, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/387/tI/s101/a"},"text":"Pub. L. 100–387, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-11"},"text":"Aug. 11, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/926"},"text":"102 Stat. 926","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dA/tVII/s785/b/1"},"text":"Pub. L. 108–447, div. A, title VII, § 785(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2850"},"text":"118 Stat. 2850","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/97/tVII/s784/b/1"},"text":"Pub. L. 109–97, title VII, § 784(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-10"},"text":"Nov. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2162"},"text":"119 Stat. 2162","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12104"},"text":"Pub. L. 115–334, title XII, § 12104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4942"},"text":"132 Stat. 4942","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideeb21ebe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideeb21ebf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideeb21ec0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"Section 5304 of title 25","children":[],"tail":", referred to in par. (1)(B)(i), (iii), has been amended, and subsecs. (b) and (c) of section 5304 no longer define the terms “Indian tribe” and “tribal organization”. However, such terms are defined elsewhere in that section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1934-06-18"},"text":"June 18, 1934","children":[],"tail":", referred to in par. (1)(B)(ii), is "},{"tag":"ref","attrib":{"href":"/us/act/1934-06-18/ch576"},"text":"act June 18, 1934, ch. 576","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/984"},"text":"48 Stat. 984","children":[],"tail":", popularly known as the Indian Reorganization Act, which was classified generally to subchapter V (§ 461 et seq.) of chapter 14 of Title 25, Indians, prior to editorial reclassification as chapter 45 (§ 5101 et seq.) of Title 25. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5101"},"text":"section 5101 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1985/e/1/D/ii"},"text":"Section 1985(e)(1)(D)(ii) of this title","children":[],"tail":", referred to in par. (5), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1985/e/1/A/ii"},"text":"section 1985(e)(1)(A)(ii) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVI/s638/3/A/ii"},"text":"Pub. L. 104–127, title VI, § 638(3)(A)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1096"},"text":"110 Stat. 1096","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideeb21ec1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “llamas, alpacas, live fish, crawfish, and other animals that” for “fish used for food, and other animals designated by the Secretary (at the Secretary’s sole discretion) that” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/97"},"text":"Pub. L. 109–97","children":[],"tail":", in introductory provisions, inserted “horses, deer,” after “bison,” and struck out “equine animals used for food or in the production of food,” before “fish”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":" inserted “elk, reindeer, bison,” after “means cattle,” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideeb21ec2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideeb21ec3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/97/tVII/s784/c"},"text":"Pub. L. 109–97, title VII, § 784(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-10"},"text":"Nov. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2163"},"text":"119 Stat. 2163","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/97/tVII/s784/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1472"},"text":"section 1472 of this title","children":[],"tail":" and enacting provisions set out as a note under this section] and the amendments made by this section apply to losses resulting from a disaster that occurs on or after "},{"tag":"date","attrib":{"date":"2005-07-28"},"text":"July 28, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prior losses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section and the amendments made by this section do not apply to losses resulting from a disaster that occurred before ","children":[{"tag":"date","attrib":{"date":"2005-07-28"},"text":"July 28, 2005","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideeb21ec4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 15 days after ","children":[{"tag":"date","attrib":{"date":"1988-08-11"},"text":"Aug. 11, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/387/s101/c/1"},"text":"section 101(c)(1) of Pub. L. 100–387","children":[],"tail":", set out as an Effective and Termination Dates of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1427"},"text":"section 1427 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"ideeb21ec5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-31/ch792"},"text":"act Oct. 31, 1949, ch. 792","children":[],"tail":", which enacted this subchapter, as the “Emergency Livestock Feed Assistance Act of 1988”, see Short Title of 1988 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideeb21ec6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inclusion of Horses and Deer Within Definition of “Livestock”","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/97/tVII/s784/a"},"text":"Pub. L. 109–97, title VII, § 784(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-10"},"text":"Nov. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2162"},"text":"119 Stat. 2162","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/97/tVII/s784/a"},"text":"“In carrying out a livestock assistance, compensation, or feed program, the Secretary of Agriculture shall include horses and deer within the definition of ‘livestock’ covered by the program.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideeb21ec7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inapplicability of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section inapplicable to 2014 through 2018 crops of covered commodities, cotton, and sugar and inapplicable to milk during period beginning ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9092/b/12"},"text":"section 9092(b)(12) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section inapplicable to 2008 through 2012 crops of covered commodities, peanuts, and sugar and inapplicable to milk during period beginning ","children":[{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"2012-12-31"},"text":"Dec. 31, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8782/b/12"},"text":"section 8782(b)(12) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section inapplicable to 2002 through 2007 crops of covered commodities, peanuts, and sugar and inapplicable to milk during period beginning ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"2007-12-31"},"text":"Dec. 31, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7992/b/12"},"text":"section 7992(b)(12) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section inapplicable to 1996 through 2002 crops of loan commodities, peanuts, and sugar and inapplicable to milk during period beginning ","children":[{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"2002-12-31"},"text":"Dec. 31, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7301/b/1/L"},"text":"section 7301(b)(1)(L) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
