{"tag":"section","attrib":{"id":"idf023d75a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7811"},"text":null,"children":[{"tag":"num","attrib":{"value":"7811"},"text":"§ 7811.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf023d75b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7811/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination or suspension not an order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The termination or suspension of an order, or a provision of an order, shall not be considered an order under the meaning of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf023d75c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7811/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf023d75d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7811/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be construed to provide for control of production or otherwise limit the right of individual Hass avocado growers, handlers and importers to produce, handle, or import Hass avocados; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d75e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7811/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be construed to treat all persons producing, handling, and importing Hass avocados fairly and to implement any order in an equitable manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf023d75f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7811/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter may be construed to preempt or supersede any other program relating to Hass avocado promotion, research, industry information, and consumer information organized and operated under the laws of the United States or of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf023d760-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387/s1/a/tXII/s1212"},"text":"Pub. L. 106–387, § 1(a) [title XII, § 1212]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1549"},"text":"114 Stat. 1549","children":[],"tail":", 1549A–96.)"}],"tail":"\n"}],"tail":null}
