{"tag":"section","attrib":{"id":"idefe37397-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6414"},"text":null,"children":[{"tag":"num","attrib":{"value":"6414"},"text":"§ 6414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension or termination of orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe37398-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6414/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension or termination by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, whenever the Secretary finds that the order or any provision of the order obstructs or does not tend to effectuate the declared policy of this chapter, terminate or suspend the operation of the order or provision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe37399-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6414/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other referenda","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe3739a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6414/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may conduct at any time a referendum of persons who, during a representative period as determined by the Secretary, have been fluid milk processors on whether to suspend or terminate the order, and shall hold such a referendum on request of the Board or any group of such processors that among them marketed during a representative period, as determined by the Secretary, 10 percent or more of the volume of fluid milk products marketed by fluid milk processors voting in the preceding referendum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe3739b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6414/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension or termination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines that the suspension or termination is favored—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe3739c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6414/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by at least 50 percent of fluid milk processors voting in the referendum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe3739d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6414/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by fluid milk processors voting in the referendum that marketed during a representative period, as determined by the Secretary, 40 percent or more of the volume of fluid milk products marketed by fluid milk processors voting in the referendum;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary shall, within 6 months after making the determination, suspend or terminate, as appropriate, collection of assessments under the order, and suspend or terminate, as appropriate, activities under the order in an orderly manner as soon as practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe3739e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6414/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs; manner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (c) and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6413"},"text":"section 6413 of this title","children":[],"tail":" shall apply to a referendum conducted under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe3739f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1999O"},"text":"Pub. L. 101–624, title XIX, § 1999O","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3925"},"text":"104 Stat. 3925","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s146/d/2"},"text":"Pub. L. 104–127, title I, § 146(d)(2)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/919"},"text":"110 Stat. 919","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1506/c"},"text":"Pub. L. 107–171, title I, § 1506(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/210"},"text":"116 Stat. 210","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefe373a0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefe373a1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefe373a2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" redesignated subsecs. (b) and (c) as (a) and (b), respectively, and struck out heading and text of former subsec. (a). Text read as follows: “Any order effective under this chapter shall be terminated "},{"tag":"date","attrib":{"date":"2002-12-31"},"text":"December 31, 2002","children":[],"tail":". The Secretary shall—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) terminate the collection of assessments under the order upon such date; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) terminate activities under the order in an orderly manner as soon as practicable after such date.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s146/e"},"text":"Pub. L. 104–127, § 146(e)","children":[],"tail":", substituted “2002” for “1996” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s146/d/2/A"},"text":"Pub. L. 104–127, § 146(d)(2)(A)","children":[],"tail":", substituted “fluid milk processors voting in the preceding referendum” for “all processors”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s146/d/2/B"},"text":"Pub. L. 104–127, § 146(d)(2)(B)","children":[],"tail":", substituted “fluid milk processors voting in the referendum;” for “all processors;”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
