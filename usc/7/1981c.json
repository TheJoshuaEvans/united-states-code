{"tag":"section","attrib":{"id":"idef165e96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1981c"},"text":"§ 1981c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oil and gas royalty payments on loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef165e97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall permit a borrower of a loan made or insured under this chapter to make a prospective payment on such loan with proceeds from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef165e98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the leasing of oil, gas, or other mineral rights to real property used to secure such loan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef165e99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale of oil, gas, or other minerals removed from real property used to secure such loan, if the value of the rights to such oil, gas, or other minerals has not been used to secure such loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef165e9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) shall not apply to a borrower of a loan made or insured under this chapter with respect to which a liquidation or foreclosure proceeding is pending on ","children":[{"tag":"date","attrib":{"date":"1985-12-23"},"text":"December 23, 1985","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef165e9b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s331C"},"text":"Pub. L. 87–128, title III, § 331C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXIII/s1310/a"},"text":"Pub. L. 99–198, title XIII, § 1310(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1523"},"text":"99 Stat. 1523","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef165e9c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef165e9d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef165e9e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/307"},"text":"75 Stat. 307","children":[],"tail":", known as the Consolidated Farm and Rural Development Act, which is classified principally to this chapter. For complete classification of title III to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
