{"tag":"section","attrib":{"id":"idf00be1e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446"},"text":null,"children":[{"tag":"num","attrib":{"value":"7446"},"text":"§ 7446.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referenda","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf00be1ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial referendum","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00be1eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the period ending 30 months after the date on which an order is first issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7443/b/3"},"text":"section 7443(b)(3) of this title","children":[],"tail":", the Secretary shall conduct a referendum among producers who, during a representative period as determined by the Secretary, have been engaged in the production of canola or rapeseed for the purpose of ascertaining whether the order then in effect shall be continued."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be1ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, to the extent practicable, provide broad public notice in advance of any referendum. The notice shall be provided, without advertising expenses, by means of newspapers, county newsletters, the electronic media, and press releases, through the use of notices posted in State and county cooperative extension offices and county Consolidated Farm Service Agency ","children":[{"tag":"ref","attrib":{"idref":"fn002339"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002339"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" offices, and by other appropriate means specified in the order. The notice shall contain information on when the referendum will be held, registration and voting requirements, rules regarding absentee voting, and other pertinent information."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be1ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall be continued only if the Secretary determines that the order has been approved by not less than a majority of the producers voting in the referendum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be1ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If continuation of the order is not approved by a majority of the producers voting in the referendum, the Secretary shall terminate collection of assessments under the order within 180 days after the referendum and shall terminate the order in an orderly manner as soon as practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00be1ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional referenda","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00be1f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00be1f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the initial referendum on an order, the Secretary shall conduct additional referenda, as described in subparagraph (C), if requested by a representative group of producers, as described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be1f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representative group of producers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An additional referendum on an order shall be conducted if requested by 10 percent or more of the producers who, during a representative period as determined by the Secretary, have been engaged in the production of canola or rapeseed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be1f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible producers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each additional referendum shall be conducted among all producers who, during a representative period as determined by the Secretary, have been engaged in the production of canola or rapeseed to determine whether the producers favor the termination or suspension of the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be1f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines, in a referendum conducted under paragraph (1), that suspension or termination of the order is favored by a majority of the producers voting in the referendum, the Secretary shall suspend or terminate, as appropriate, collection of assessments under the order within 180 days after the determination, and shall suspend or terminate the order, as appropriate, in an orderly manner as soon as practicable after the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be1f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity to request additional referenda","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00be1f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning on the date that is 5 years after the conduct of a referendum under this subchapter, and every 5 years thereafter, the Secretary shall provide canola and rapeseed producers an opportunity to request an additional referendum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be1f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of making request","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf00be1f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In-person requests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out subparagraph (A), the Secretary shall establish a procedure under which a producer may make a request for a reconfirmation referendum in person at a county cooperative extension office or a county Consolidated Farm Service Agency office during a period established by the Secretary, or as provided in clause (ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf00be1f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mail-in requests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In lieu of making a request in person, a producer may make a request by mail. To facilitate the submission of requests by mail, the Secretary may make mail-in request forms available to producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be1fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish a notice in the Federal Register, and the Board shall provide written notification to producers, not later than 60 days prior to the end of the period established under subparagraph (B)(i) for an in-person request, of the opportunity of producers to request an additional referendum. The notification shall explain the right of producers to an additional referendum, the procedure for a referendum, the purpose of a referendum, and the date and method by which producers may act to request an additional referendum under this paragraph. The Secretary shall take such other action as the Secretary determines is necessary to ensure that producers are made aware of the opportunity to request an additional referendum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be1fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable following the submission of a request for an additional referendum, the Secretary shall determine whether a sufficient number of producers have requested the referendum, and take such steps as are necessary to conduct the referendum, as required under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be1fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time limit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An additional referendum requested under the procedures provided in this paragraph shall be conducted not later than 1 year after the Secretary determines that a representative group of producers, as described in paragraph (1)(B), have requested the conduct of the referendum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00be1fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00be1fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall be reimbursed from assessments collected by the Board for any expenses incurred by the Secretary in connection with the conduct of an activity required under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be1ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each referendum shall be conducted for a reasonable period of time not to exceed 3 days, established by the Secretary, under a procedure under which producers intending to vote in the referendum shall certify that the producers were engaged in the production of canola, rapeseed, or canola or rapeseed products during the representative period and, at the same time, shall be provided an opportunity to vote in the referendum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be200-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7446/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Place","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Referenda under this section shall be conducted at locations determined by the Secretary. On request, absentee mail ballots shall be furnished by the Secretary in a manner prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf00be201-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s537"},"text":"Pub. L. 104–127, title V, § 537","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1058"},"text":"110 Stat. 1058","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7511/c/28"},"text":"Pub. L. 110–234, title VII, § 7511(c)(28)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1270"},"text":"122 Stat. 1270","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7511(c)(28), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2031.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf00be202-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf00be203-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf00be204-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf00be205-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsecs. (a)(2), (b)(3)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7511/c/28"},"text":"Pub. L. 110–246, § 7511(c)(28)","children":[],"tail":", substituted “cooperative extension” for “Cooperative State Research, Education, and Extension Service”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf00be206-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idf00be207-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Consolidated Farm Service Agency effectively renamed Farm Service Agency by the amendments made to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6932"},"text":"section 6932 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12404/a"},"text":"Pub. L. 115–334, title XII, § 12404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4974"},"text":"132 Stat. 4974","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf00be208-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7511/c/28"},"text":"section 7511(c)(28) of Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7511/c"},"text":"section 7511(c) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1522"},"text":"section 1522 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
