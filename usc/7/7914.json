{"tag":"section","attrib":{"id":"idf023d7ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914"},"text":null,"children":[{"tag":"num","attrib":{"value":"7914"},"text":"§ 7914.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of counter-cyclical payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf023d7eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of the 2002 through 2007 crop years for each covered commodity, the Secretary shall make counter-cyclical payments to producers on farms for which payment yields and base acres are established with respect to the covered commodity if the Secretary determines that the effective price for the covered commodity is less than the target price for the covered commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf023d7ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective price","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the effective price for a covered commodity is equal to the sum of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf023d7ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The higher of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf023d7ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The national average market price received by producers during the 12-month marketing year for the covered commodity, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf023d7ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The national average loan rate for a marketing assistance loan for the covered commodity in effect for the applicable period under subchapter II.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d7f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The payment rate in effect for the covered commodity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7913"},"text":"section 7913 of this title","children":[],"tail":" for the purpose of making direct payments with respect to the covered commodity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf023d7f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Target price","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf023d7f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2002 and 2003 crop years","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of the 2002 and 2003 crop years, the target prices for covered commodities shall be as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf023d7f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Wheat, $3.86 per bushel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf023d7f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Corn, $2.60 per bushel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf023d7f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grain sorghum, $2.54 per bushel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf023d7f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Barley, $2.21 per bushel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf023d7f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Oats, $1.40 per bushel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf023d7f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upland cotton, $0.7240 per pound.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf023d7f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rice, $10.50 per hundredweight.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf023d7fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Soybeans, $5.80 per bushel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf023d7fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/c/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other oilseeds, $0.0980 per pound.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d7fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent crop years","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of each of the 2004 through 2007 crop years, the target prices for covered commodities shall be as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf023d7fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Wheat, $3.92 per bushel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf023d7fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Corn, $2.63 per bushel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf023d7ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grain sorghum, $2.57 per bushel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf023d800-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Barley, $2.24 per bushel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf023d801-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Oats, $1.44 per bushel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf023d802-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upland cotton, $0.7240 per pound.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf023d803-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rice, $10.50 per hundredweight.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf023d804-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Soybeans, $5.80 per bushel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf023d805-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/c/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other oilseeds, $0.1010 per pound.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf023d806-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The payment rate used to make counter-cyclical payments with respect to a covered commodity for a crop year shall be equal to the difference between—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf023d807-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the target price for the covered commodity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d808-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective price determined under subsection (b) for the covered commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf023d809-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If counter-cyclical payments are required to be paid for any of the 2002 through 2007 crop years of a covered commodity, the amount of the counter-cyclical payment to be paid to the producers on a farm for that crop year shall be equal to the product of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf023d80a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The payment rate specified in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d80b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The payment acres of the covered commodity on the farm.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d80c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The payment yield or updated payment yield for the farm, depending on the election of the owner of the farm under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7912"},"text":"section 7912 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf023d80d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf023d80e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines under subsection (a) that counter-cyclical payments are required to be made under this section for the crop of a covered commodity, the Secretary shall make the counter-cyclical payments for the crop as soon as practicable after the end of the 12-month marketing year for the covered commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d80f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of partial payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, before the end of the 12-month marketing year for a covered commodity, the Secretary estimates that counter-cyclical payments will be required for the crop of the covered commodity, the Secretary shall give producers on a farm the option to receive partial payments of the counter-cyclical payment projected to be made for that crop of the covered commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d810-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for partial payments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf023d811-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2002 through 2006 crop years","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When the Secretary makes partial payments available under paragraph (2) for a covered commodity for any of the 2002 through 2006 crop years—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf023d812-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first partial payment for the crop year shall be made not earlier than October 1, and, to the maximum extent practicable, not later than October 31, of the calendar year in which the crop of the covered commodity is harvested;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf023d813-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the second partial payment shall be made not earlier than February 1 of the next calendar year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf023d814-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the final partial payment shall be made as soon as practicable after the end of the 12-month marketing year for the covered commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf023d815-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2007 crop year","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When the Secretary makes partial payments available for a covered commodity for the 2007 crop year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf023d816-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first partial payment shall be made after completion of the first 6 months of the marketing year for the covered commodity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf023d817-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the final partial payment shall be made as soon as practicable after the end of the 12-month marketing year for the covered commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d818-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of partial payments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf023d819-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2002 through 2006 crop years","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf023d81a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First partial payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of the 2002 through 2006 crop years of a covered commodity, the first partial payment under paragraph (3) to the producers on a farm may not exceed 35 percent of the projected counter-cyclical payment for the covered commodity for the crop year, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf023d81b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second partial payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The second partial payment for a covered commodity for a crop year may not exceed the difference between—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf023d81c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/4/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 70 percent of the projected counter-cyclical payment (including any revision thereof) for the crop of the covered commodity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf023d81d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/4/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the payment made under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf023d81e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The final payment for a covered commodity for a crop year shall be equal to the difference between—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf023d81f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/4/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual counter-cyclical payment to be made to the producers for the covered commodity for that crop year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf023d820-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/4/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the partial payments made to the producers under clauses (i) and (ii) for that crop year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0262011-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2007 crop year","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0262012-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First partial payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the 2007 crop year, the first partial payment under paragraph (3) to the producers on a farm may not exceed 40 percent of the projected counter-cyclical payment for the covered commodity for the crop year, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0262013-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The final payment for the 2007 crop year shall be equal to the difference between—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf0262014-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual counter-cyclical payment to be made to the producers for the covered commodity for that crop year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0262015-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the partial payment made to the producers under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0262016-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7914/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The producers on a farm that receive a partial payment under this subsection for a crop year shall repay to the Secretary the amount, if any, by which the total of the partial payments exceed the actual counter-cyclical payment to be made for the covered commodity for that crop year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0262017-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1104"},"text":"Pub. L. 107–171, title I, § 1104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/150"},"text":"116 Stat. 150","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0262018-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0262019-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf026201a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter II, referred to in subsec. (b)(1)(B), was in the original “subtitle B”, meaning subtitle B (§§ 1201–1209) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/155"},"text":"116 Stat. 155","children":[],"tail":", which is classified principally to subchapter II of this chapter. For complete classification of subtitle B to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
