{"tag":"section","attrib":{"id":"ideff4147d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6941"},"text":null,"children":[{"tag":"num","attrib":{"value":"6941"},"text":"§ 6941.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary of Agriculture for Rural Development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff4147e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6941/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish in the Department the position of Under Secretary of Agriculture for Rural Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff4147f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6941/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confirmation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary of Agriculture for Rural Development shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff41480-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6941/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Under Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff41481-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6941/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon establishment, the Secretary shall delegate to the Under Secretary of Agriculture for Rural Development those functions under the jurisdiction of the Department that are related to rural economic and community development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41482-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6941/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary of Agriculture for Rural Development shall perform such other functions as may be required by law or prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff41483-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6941/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Succession","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any official who is serving as Under Secretary of Agriculture for Small Community and Rural Development on ","children":[{"tag":"date","attrib":{"date":"1994-10-13"},"text":"October 13, 1994","children":[],"tail":", and who was appointed by the President, by and with the advice and consent of the Senate, shall not be required to be reappointed under subsection (b) to the successor position authorized under subsection (a) if the Secretary establishes the position, and the official occupies the new position, within 180 days after "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"October 13, 1994","children":[],"tail":" (or such later date set by the Secretary if litigation delays rapid succession)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff41484-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6941/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan approval authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Approval authority for loans and loan guarantees in connection with the electric and telephone loan and loan guarantee programs authorized by the Rural Electrification Act of 1936 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s901"},"text":"7 U.S.C. 901","children":[],"tail":" et seq.) shall not be transferred to, or conditioned on review of, a State director or other employee whose primary duty is not the review and approval of such loans or the provision of assistance to such borrowers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff41485-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s231"},"text":"Pub. L. 103–354, title II, § 231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3218"},"text":"108 Stat. 3218","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s794/a"},"text":"Pub. L. 104–127, title VII, § 794(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1155"},"text":"110 Stat. 1155","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12407"},"text":"Pub. L. 115–334, title XII, § 12407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4976"},"text":"132 Stat. 4976","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideff41486-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideff41487-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideff41488-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Rural Electrification Act of 1936, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"act May 20, 1936, ch. 432","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1363"},"text":"49 Stat. 1363","children":[],"tail":", which is classified generally to chapter 31 (§ 901 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s901"},"text":"section 901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideff41489-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/s231"},"text":"section 231 of Pub. L. 103–354","children":[],"tail":". Subsec. (f) of "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/s231"},"text":"section 231 of Pub. L. 103–354","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of Title 5","children":[],"tail":", Government Organization and Employees, and repealed sections 2006f and 2211b of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideff4148a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12407/1"},"text":"Pub. L. 115–334, § 12407(1)","children":[],"tail":", substituted “shall” for “is authorized to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12407/2"},"text":"Pub. L. 115–334, § 12407(2)","children":[],"tail":", substituted “The Under Secretary of Agriculture for Rural Development shall” for “If the Secretary establishes the position of Under Secretary of Agriculture for Rural Development authorized under subsection (a), the Under Secretary shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" struck out “Economic and Community” after “Under Secretary of Agriculture for Rural”, wherever appearing in section catchline and subsecs. (a) to (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
