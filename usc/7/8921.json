{"tag":"section","attrib":{"id":"idf0451acc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8921"},"text":null,"children":[{"tag":"num","attrib":{"value":"8921"},"text":"§ 8921.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development of agricultural countermeasures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0451acd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8921/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0451ace-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8921/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grant program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a competitive grant program to encourage basic and applied research and the development of qualified agricultural countermeasures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451acf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8921/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver in emergencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may waive the requirement under paragraph (1) that a grant be provided on a competitive basis if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0451ad0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8921/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary has declared a plant or animal disease emergency under the Plant Protection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7701"},"text":"7 U.S.C. 7701","children":[],"tail":" et seq.) or the Animal Health Protection Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8301"},"text":"7 U.S.C. 8301","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451ad1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8921/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waiving the requirement would lead to the rapid development of a qualified agricultural countermeasure, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0451ad2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8921/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0451ad3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8921/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 for each of fiscal years 2008 through 2013; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451ad4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8921/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","att