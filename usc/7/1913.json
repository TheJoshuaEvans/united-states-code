ren":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/294"},"text":"75 Stat. 294","children":[],"tail":", known as the Agricultural Act of 1961. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1911"},"text":"section 1911 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
