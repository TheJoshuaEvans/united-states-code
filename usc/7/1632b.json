{"tag":"section","attrib":{"id":"ideedab4ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1632b"},"text":"§ 1632b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agriculture Innovation Center Demonstration Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideedab4ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this section is to direct the Secretary of Agriculture to establish a demonstration program under which agricultural producers are provided—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedab4ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance, consisting of engineering services, applied research, scale production, and similar services, to enable the agricultural producers to establish businesses to produce value-added agricultural commodities or products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in marketing, market development, and business planning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizational, outreach, and development assistance to increase the viability, growth, and sustainability of businesses that produce value-added agricultural commodities or products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedab4b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedab4b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Program” means the Agriculture Innovation Center Demonstration Program established under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedab4b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a demonstration program, to be known as the “Agriculture Innovation Center Demonstration Program” under which the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedab4b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make grants to assist eligible entities in establishing Agriculture Innovation Centers to enable agricultural producers to obtain the assistance described in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assistance to eligible entities in establishing Agriculture Innovation Centers through the research and technical services of the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedab4b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedab4b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity shall be eligible for a grant and assistance described in subsection (c) to establish an Agriculture Innovation Center if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedab4b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the entity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideedab4ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has provided services similar to the services described in subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedab4bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates the capability of providing such services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab4bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the application of the entity for the grant and assistance includes a plan, in accordance with regulations promulgated by the Secretary, that outlines—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideedab4bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the support for the entity in the agricultural community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedab4be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the technical and other expertise of the entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedab4bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the goals of the entity for increasing and improving the ability of local agricultural producers to develop markets and processes for value-added agricultural commodities or products;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab4c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entity demonstrates that adequate resources (in cash or in kind) are available, or have been committed to be made available, to the entity, to increase and improve the ability of local agricultural producers to develop markets and processes for value-added agricultural commodities or products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab4c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Agriculture Innovation Center of the entity has a board of directors established in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of directors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Agriculture Innovation Center of an eligible entity shall have a board of directors composed of a diverse group of representatives of public and private entities, including the following:: ","children":[{"tag":"ref","attrib":{"idref":"fn002187"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002187"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedab4c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two general agricultural organizations with the greatest number of members in the State in which the eligible entity is located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab4c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The department of agriculture, or similar State department or agency, or a State legislator, of the State in which the eligible entity is located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab4c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four entities representing commodities produced in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedab4c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants and assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedab4c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (g), under the Program, the Secretary shall make, on a competitive basis, annual grants to eligible entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount of grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant under paragraph (1) shall be in an amount that does not exceed the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedab4c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab4ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" twice the dollar amount of the resources (in cash or in kind) that the eligible entity demonstrates are available, or have been committed to be made available, to the eligible entity in accordance with subsection (d)(1)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum number of grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedab4cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First fiscal year of Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the first fiscal year of the Program, the Secretary shall make grants to not more than 5 eligible entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab4cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second fiscal year of Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the second fiscal year of the Program, the Secretary may make grants to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideedab4ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible entities to which grants were made under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedab4cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 10 additional eligible entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State limitation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedab4d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), in the first 3 fiscal years of the Program, the Secretary shall not make a grant under the Program to more than 1 entity in any 1 State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab4d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in subparagraph (A) precludes a recipient of a grant under the Program from collaborating with any other institution with respect to activities conducted using the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedab4d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity to which a grant is made under the Program may use the grant only for the following purposes (but only to the extent that the use is not described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1627c/d/5/D"},"text":"section 1627c(d)(5)(D) of this title","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002188"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002188"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be followed by a closing parenthesis."}],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedab4d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Applied research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consulting services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hiring of employees, at the discretion of the board of directors of the Agriculture Innovation Center of the eligible entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The making of matching grants, each of which shall be in an amount not to exceed $5,000, to agricultural producers, except that the aggregate amount of all such matching grants made by the eligible entity shall be not more than $50,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Legal services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other related cost, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedab4da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $15,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideedab4db-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6402"},"text":"Pub. L. 107–171, title VI, § 6402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/426"},"text":"116 Stat. 426","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVI/s6203"},"text":"Pub. L. 110–234, title VI, § 6203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1207"},"text":"122 Stat. 1207","children":[],"tail":"; "},{"tag":"ref","attri