{"tag":"section","attrib":{"id":"idef7a77e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2262a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2262a"},"text":"§ 2262a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overseas tort claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef7a77ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2262a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture may pay a tort claim in the manner authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2672"},"text":"section 2672 of title 28","children":[],"tail":", if the claim arises outside the United States in connection with activities of individuals who are performing services for the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7a77eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2262a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period for presentation of claim","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A claim may not be allowed under this section unless the claim is presented in writing to the Secretary of Agriculture within 2 years after the date on which the claim accrues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7a77ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2262a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, an award or denial of a claim by the Secretary of Agriculture under this section is final.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7a77ed-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIX/s920"},"text":"Pub. L. 104–127, title IX, § 920","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1191"},"text":"110 Stat. 1191","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
