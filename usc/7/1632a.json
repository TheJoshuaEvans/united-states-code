{"tag":"section","attrib":{"id":"ideedab49c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1632a"},"text":"§ 1632a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural marketing resource center pilot project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideedab49d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not use more than 2.5 percent of the funds made available to carry out the Local Agriculture Market Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1627c"},"text":"section 1627c of this title","children":[],"tail":" to establish a pilot project (to be known as the “Agricultural Marketing Resource Center”) at an eligible institution described in subsection (b) that will—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedab49e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a resource center with electronic capabilities to coordinate and provide to independent producers and processors (as determined by the Secretary) of value-added agricultural commodities and products of agricultural commodities information regarding research, business, legal, financial, or logistical assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab49f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a strategy to establish a nationwide market information and coordination system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedab4a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive funding to establish the Agricultural Marketing Resource Center, an applicant shall demonstrate to the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedab4a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capacity and technical expertise to provide the services described in subsection (a)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an established plan outlining support of the applicant in the agricultural community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of resources (in cash or in kind) of definite value to sustain the Center following establishment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideedab4a4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/tII/s231"},"text":"Pub. L. 106–224, title II, § 231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/409"},"text":"114 Stat. 409","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6401/a"},"text":"Pub. L. 107–171, title VI, § 6401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/424"},"text":"116 Stat. 424","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVI/s6202"},"text":"Pub. L. 110–234, title VI, § 6202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1206"},"text":"122 Stat. 1206","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VI, § 6202, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1967; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVI/s6203"},"text":"Pub. L. 113–79, title VI, § 6203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/857"},"text":"128 Stat. 857","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tX/s10102/c/1"},"text":"Pub. L. 115–334, title X, § 10102(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4897"},"text":"132 Stat. 4897","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideedab4a5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideedab4a6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideedab4a7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agricultural Risk Protection Act of 2000, and not as part of the Agricultural Marketing Act of 1946 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1621"},"text":"section 1621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideedab4a8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10102/c/1/A"},"text":"Pub. L. 115–334, § 10102(c)(1)(A)","children":[],"tail":", substituted “Agricultural marketing resource center pilot project” for “Value-added agricultural product market development grants” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10102/c/1/D/i"},"text":"Pub. L. 115–334, § 10102(c)(1)(D)(i)","children":[],"tail":", in introductory provisions, substituted “The Secretary shall not use more than 2.5 percent of the funds made available to carry out the Local Agriculture Market Program established under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1627c"},"text":"section 1627c of this title","children":[],"tail":" to establish a pilot project (to be known as the ‘Agricultural Marketing Resource Center’) at an eligible institution described in subsection (b)” for “Notwithstanding the limitation on grants in subsection (b)(2), the Secretary shall not use more than 5 percent of the funds made available under subsection (b) to establish a pilot project (to be known as the ‘Agricultural Marketing Resource Center’) at an eligible institution described in paragraph (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10102/c/1/B"},"text":"Pub. L. 115–334, § 10102(c)(1)(B)","children":[],"tail":", (C)(i), (D)(ii), redesignated subsec. (c)(1) as subsec. (a), redesignated subpars. (A) and (B) of former subsec. (c)(1) as pars. (1) and (2), respectively, of subsec. (a), realigned margins, and struck out former subsec. (a) which defined terms for this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10102/c/1/B"},"text":"Pub. L. 115–334, § 10102(c)(1)(B)","children":[],"tail":", (C)(i), (E)(i), redesignated subsec. (c)(2) as (b), redesignated subpars. (A) to (C) of former subsec. (c)(2) as pars. (1) to (3), respectively, of subsec. (b), realigned margins, and struck out former subsec. (b) which related to grant program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10102/c/1/E/ii"},"text":"Pub. L. 115–334, § 10102(c)(1)(E)(ii)","children":[],"tail":", substituted “subsection (a)(1)” for “paragraph (1)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10102/c/1/C/ii"},"text":"Pub. L. 115–334, § 10102(c)(1)(C)(ii)","children":[],"tail":", struck out subsec. (c) designation and heading “Agricultural Marketing Resource Center pilot project”. Pars. (1) and (2) of former subsec. (c) redesignated subsecs. (a) and (b), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10102/c/1/B"},"text":"Pub. L. 115–334, § 10102(c)(1)(B)","children":[],"tail":", struck out subsecs. (d) and (e) which related to matching funds and limitation, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s6203/1"},"text":"Pub. L. 113–79, § 6203(1)","children":[],"tail":", added par. (6) and struck out former par. (6). Prior to amendment, text read as follows: “In awarding grants under this subsection, the Secretary shall give priority to projects that contribute to increasing opportunities for—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) beginning farmers or ranchers;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) socially disadvantaged farmers or ranchers; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) operators of small- and medium-sized farms and ranches that are structured as a family farm.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s6203/2/A"},"text":"Pub. L. 113–79, § 6203(2)(A)","children":[],"tail":", substituted “On "},{"tag":"date","attrib":{"date":"2014-02-14"},"text":"February 14, 2014","children":[],"tail":",” for “On "},{"tag":"date","attrib":{"date":"2008-10-01"},"text":"October 1, 2008","children":[],"tail":",” and “$63,000,000” for “$15,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s6203/2/B"},"text":"Pub. L. 113–79, § 6203(2)(B)","children":[],"tail":", substituted “2018” for “2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s6202/a"},"text":"Pub. L. 110–246, § 6202(a)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which defined “value-added agricultural product”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s6202/b/1"},"text":"Pub. L. 110–246, § 6202(b)(1)","children":[],"tail":", substituted “paragraph (7)” for “paragraph (4)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s6202/b/2"},"text":"Pub. L. 110–246, § 6202(b)(2)","children":[],"tail":", added pars. (4) to (7) and struck out former par. (4). Prior to amendment, text read as follows: “Not later than 30 days after "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", on "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"October 1, 2002","children":[],"tail":", and on each October 1 thereafter through "},{"tag":"date","attrib":{"date":"2006-10-01"},"text":"October 1, 2006","children":[],"tail":", of the funds of the Commodity Credit Corporation, the Secretary shall make available to carry out this subsection $40,000,000, to remain available until expended.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6401/a/2"},"text":"Pub. L. 107–171, § 6401(a)(2)","children":[],"tail":", added subsecs. (a) and (b) and struck out former subsec. (a) which related to establishment of grant program, maximum amount per grant recipient, and producer strategies. Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6401/a/1"},"text":"Pub. L. 107–171, § 6401(a)(1)","children":[],"tail":", (3), redesignated subsec. (b) as (c) and, in par. (1), substituted “subsection (b)(2)” for “subsection (a)(2)”, “5 percent” for “$5,000,000”, and “subsection (b)” for “subsection (a)” in introductory provisions. Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6401/a/4"},"text":"Pub. L. 107–171, § 6401(a)(4)","children":[],"tail":", which directed amendment of subsec. (d) by substituting “subsections (b) and (c)” for “subsections (a) and (b)”, could not be executed because that phrase does not appear."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6401/a/1"},"text":"Pub. L. 107–171, § 6401(a)(1)","children":[],"tail":", redesignated subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6401/a/1"},"text":"Pub. L. 107–171, § 6401(a)(1)","children":[],"tail":", redesignated subsec. (d) as (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideedab4a9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideedab4aa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideedab4ab-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6401/b"},"text":"Pub. L. 107–171, title VI, § 6401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/426"},"text":"116 Stat. 426","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/171/tVI/s6401/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the amendments made by subsection (a) [amending this section] apply beginning on ","children":[{"tag":"date","attrib":{"date":"2002-10-01"},"text":"October 1, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds made available under section 231(b)(4)(A)(i) [probably should be 231(b)(4)] of the Agricultural Risk Protection Act of 2000 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1632a/b/4"},"text":"7 U.S.C. 1632a(b)(4)","children":[],"tail":"] (as amended by subsection (a)(2)) shall be made available not later than 30 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
