{"tag":"section","attrib":{"id":"idf00be209-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7447"},"text":null,"children":[{"tag":"num","attrib":{"value":"7447"},"text":"§ 7447.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition and review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf00be20a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7447/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00be20b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7447/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person subject to an order issued under this subchapter may file with the Secretary a petition—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00be20c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7447/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stating that the order, a provision of the order, or an obligation imposed in connection with the order is not established in accordance with law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be20d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7447/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requesting a modification of the order or an exemption from the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be20e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7447/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The petitioner shall be given the opportunity for a hearing on a petition filed under paragraph (1), in accordance with regulations issued by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be20f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7447/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ruling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After a hearing under paragraph (2), the Secretary shall issue a ruling on the petition that is the subject of the hearing, which shall be final if the ruling is in accordance with applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be210-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7447/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on petition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any petition filed under this subchapter challenging an order, or any obligation imposed in connection with an order, shall be filed not later than 2 years after the effective date of the order or imposition of the obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00be211-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7447/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00be212-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7447/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The district court of the United States for any district in which the person who is a petitioner under subsection (a) resides or carries on business shall have jurisdiction to review a ruling on the petition, if a complaint is filed by the person not later than 20 days after the date of the entry of a ruling by the Secretary under subsection (a)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be213-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7447/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Service of process in a proceeding under paragraph (1) shall be conducted in accordance with the Federal Rules of Civil Procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be214-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7447/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remands","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the court determines, under paragraph (1), that a ruling issued under subsection (a)(3) is not in accordance with applicable law, the court shall remand the matter to the Secretary with directions either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00be215-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7447/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make such ruling as the court shall determine to be in accordance with law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be216-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7447/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take such further proceedings as, in the opinion of the court, the law requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be217-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7447/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The pendency of proceedings instituted under subsection (a) shall not impede, hinder, or delay the Attorney General or the Secretary from taking any action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7448"},"text":"section 7448 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf00be218-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s538"},"text":"Pub. L. 104–127, title V, § 538","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1060"},"text":"110 Stat. 1060","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf00be219-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf00be21a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf00be21b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Civil Procedure, referred to in subsec. (b)(2), are set out in the Appendix to Title 28, Judiciary and Judicial Procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
