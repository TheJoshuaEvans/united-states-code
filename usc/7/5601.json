{"tag":"section","attrib":{"id":"idefc6c350-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5601"},"text":null,"children":[{"tag":"num","attrib":{"value":"5601"},"text":"§ 5601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this chapter to increase the profitability of farming and to increase opportunities for United States farms and agricultural enterprises by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc6c351-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5601/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the effectiveness of the Department of Agriculture in agricultural export policy formulation and implementation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c352-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5601/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the competitiveness of United States agricultural commodities and products in the world market; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c353-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5601/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for the coordination and efficient implementation of all agricultural export programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefc6c354-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/tI/s101"},"text":"Pub. L. 95–501, title I, § 101","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1