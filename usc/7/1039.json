{"tag":"section","attrib":{"id":"idee6cfede-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1039"},"text":null,"children":[{"tag":"num","attrib":{"value":"1039"},"text":"§ 1039.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for filing purchase applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No application for the purchase of mineral interests under sections 1033 to 1039 of this title shall be filed until ninety days after ","children":[{"tag":"date","attrib":{"date":"1950-09-06"},"text":"September 6, 1950","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee6cfedf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-06/ch897/s7"},"text":"Sept. 6, 1950, ch. 897, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/770"},"text":"64 Stat. 770","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee6cfee0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee6cfee1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee6cfee2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Bankhead-Jones Farm Tenant Act which constitutes a major part of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
