{"tag":"section","attrib":{"id":"idedbc9b03-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"§ 5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idedbc9b04-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The transactions subject to this chapter are entered into regularly in interstate and international commerce and are affected with a national public interest by providing a means for managing and assuming price risks, discovering prices, or disseminating pricing information through trading in liquid, fair and financially secure trading facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedbc9b05-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the purpose of this chapter to serve the public interests described in subsection (a) through a system of effective self-regulation of trading facilities, clearing systems, market participants and market professionals under the oversight of the Commission. To foster these public interests, it is further the purpose of this chapter to deter and prevent price manipulation or any other disruptions to market integrity; to ensure the financial integrity of all transactions subject to this chapter and the avoidance of systemic risk; to protect all market participants from fraudulent or other abusive sales practices and misuses of customer assets; and to promote responsible innovation and fair competition among boards of trade, other markets and market participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idedbc9b06-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369/s3"},"text":"Sept. 21, 1922, ch. 369, § 3","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tI/s108"},"text":"Pub. L. 106–554, § 1(a)(5) [title I, § 108]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–383.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idedbc9b07-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idedbc9b08-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idedbc9b09-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369/s3"},"text":"Sept. 21, 1922, ch. 369, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/999"},"text":"42 Stat. 999","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-15/ch545/s2"},"text":"June 15, 1936, ch. 545, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1491"},"text":"49 Stat. 1491","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/444/tII/s203"},"text":"Pub. L. 97–444, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-11"},"text":"Jan. 11, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2298"},"text":"96 Stat. 2298","children":[],"tail":", stated legislative findings, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tI/s108"},"text":"Pub. L. 106–554, § 1(a)(5) [title I, § 108]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–383."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
