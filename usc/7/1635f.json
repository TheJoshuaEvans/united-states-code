{"tag":"section","attrib":{"id":"ideedd25c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1635f"},"text":"§ 1635f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory packer reporting of boxed beef sales","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideedd25c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Daily reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The corporate officers or officially designated representatives of each packer processing plant shall report to the Secretary at least twice each reporting day (not less than once before, and once after, 12:00 noon Central Time) information on total boxed beef sales, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedd25c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the price for each lot of each negotiated boxed beef sale (determined by seller-buyer interaction and agreement), quoted in dollars per hundredweight (on a F.O.B. plant basis);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd25c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity for each lot of each sale, quoted by number of boxes sold; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd25c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information regarding the characteristics of each lot of each sale, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedd25c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635f/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grade of beef (USDA Choice or better, USDA Select, or ungraded no-roll product);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd25c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635f/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cut of beef; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd25c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635f/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trim specification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedd25c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available to the public the information required to be reported under subsection (a) not less frequently than twice each reporting day.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideedd25c9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 223, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tIX/s911/2"},"text":"Pub. L. 106–78, title IX, § 911(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1193"},"text":"113 Stat. 1193","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
