 of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf02d4cba-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8101, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIX/s9001"},"text":"Pub. L. 107–171, title IX, § 9001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/475"},"text":"116 Stat. 475","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s943/a/1"},"text":"Pub. L. 109–58, title IX, § 943(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/880"},"text":"119 Stat. 880","children":[],"tail":", contained definitions for this chapter, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf02d4cbb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s9001/1"},"text":"Pub. L. 115–334, § 9001(1)","children":[],"tail":", substituted “agricultural materials, renewable chemicals,” for “agricultural materials”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s9001/2"},"text":"Pub. L. 115–334, § 9001(2)","children":[],"tail":", substituted “or an intermediate ingredient or feedstock of renewable biomass into any 1 or more, or a combination, of—” and cls. (i) to (iii) for “into biofuels and biobased products; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (16)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s9001/3/A"},"text":"Pub. L. 115–334, § 9001(3)(A)","children":[],"tail":", substituted “subparagraph (C), the term ‘renewable energy system’ means a system that produces usable energy from a renewable energy source.” for “subparagraph (B), the term ‘renewable energy system’ means a system that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) produces usable energy from a renewable energy source; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) may include distribution components necessary to move energy produced by such system to the initial point of sale.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (16)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s9001/3/B"},"text":"Pub. L. 115–334, § 9001(3)(B)","children":[],"tail":", (C), added subpar. (B) and redesignated former subpar. (B) as (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s9001/2"},"text":"Pub. L. 113–79, § 9001(2)","children":[],"tail":", added par. (9). Former par. (9) redesignated (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (10) to (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s9001/1"},"text":"Pub. L. 113–79, § 9001(1)","children":[],"tail":", redesignated pars. (9) to (12) as (10) to (13), respectively. Former par. (13) redesignated (15)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s9001/3"},"text":"Pub. L. 113–79, § 9001(3)","children":[],"tail":", added par. (14)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s9001/1"},"text":"Pub. L. 113–79, § 9001(1)","children":[],"tail":", redesignated par. (13) as (15)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (16). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s9001/4"},"text":"Pub. L. 113–79, § 9001(4)","children":[],"tail":", added par. (16)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (17). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s9001/1"},"text":"Pub. L. 113–79, § 9001(1)","children":[],"tail":", redesignated par. (14) as (17)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf02d4cbc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf02d4cbd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idf02d4cbe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dA/tVII/s778/a"},"text":"Pub. L. 108–199, div. A, title VII, § 778(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/41"},"text":"118 Stat. 41","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/199/dA/tVII/s778/a"},"text":"“This section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8109"},"text":"section 8109 of this title","children":[],"tail":"] may be cited as the ‘Sun Grant Research Initiative Act of 2003’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf02d4cbf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Biomass Research and Development","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/tIII"},"text":"Pub. L. 106–224, title III","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/428"},"text":"114 Stat. 428","children":[],"tail":"; as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIX/s9008"},"text":"Pub. L. 107–171, title IX, § 9008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/483"},"text":"116 Stat. 483","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/148/tII/s201"},"text":"Pub. L. 108–148, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1901"},"text":"117 Stat. 1901","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s941"},"text":"Pub. L. 109–58, title IX, § 941","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/873"},"text":"119 Stat. 873","children":[],"tail":", known as the Biomass Research and Development Act of 2000, and formerly set out as a note under this section, provided temporary authority for the Secretaries of Agriculture and Energy to promote biomass research and development. As amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", the program became permanent, and title III of "},{"tag":"ref","attrib":{"href":"/us/pl/106/224"},"text":"Pub. L. 106–224","children":[],"tail":" was transferred to chapter 112 (§ 8601 et seq.) of this title. Subsequently, title III of "},{"tag":"ref","attrib":{"href":"/us/pl/106/224"},"text":"Pub. L. 106–224","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIX/s9001/b"},"text":"Pub. L. 110–246, title IX, § 9001(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2095"},"text":"122 Stat. 2095","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idf02d4cc0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf02d4cc1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Biofuels And Rural Economic Development","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2009-05-05"},"text":"May 5, 2009","children":[],"tail":", 74 F.R. 21531, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Secretary of Agriculture, the Secretary of Energy, [and] the Administrator of the Environmental Protection Agency","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the Nation’s ongoing efforts to achieve energy independence, biomass and biofuels promise to play a key role by providing the Nation with homegrown sustainable energy options and energizing our economy with new industries and jobs. While producing clean renewable fuels locally is a powerful engine of economic growth, they must be developed and used in a way that limits environmental impact. Today, the Environmental Protection Agency (EPA) is issuing a Notice of Proposed Rulemaking, as required by the Energy Independence and Security Act of 2007, to set new national renewable fuel standards and implement those standards. The public will have an opportunity to provide input on this proposal through a 60-day comment period, and the EPA is conducting peer reviews on key aspects of the environmental impact assessments within the proposal.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In order to shepherd our Nation’s development of this important industry and to coordinate interagency policy, I hereby establish a Biofuels Interagency Working Group (Working Group), to be co-chaired by the Secretaries of Agriculture and Energy and the Administrator of the EPA. This Working Group will coordinate with the National Science and Technology Council’s Biomass Research and Development Board in undertaking its work. The responsibilities of the Working Group shall include:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(a) Developing the Nation’s first comprehensive biofuel market development program, which shall use existing authorities and identify new policies to support the development of next-generation biofuels, increase flexible fuel vehicle use, and assist in retail marketing efforts;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) Coordinating infrastructure policies affecting the supply, secure transport, and distribution of biofuels; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(c) Identifying new policy options to promote the environmental sustainability of biofuels feedstock production, taking into consideration land use, habitat conservation, crop management practices, water efficiency and water quality, as well as lifecycle assessments of greenhouse gas emissions.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Alongside the Working Group’s efforts, the Secretary of Agriculture may pursue other important biofuel development efforts. The Rural Development Act of 1972 and the Rural Development Policy Act of 1980 direct the Secretary of Agriculture to develop, in coordination with State and local governments, a nationwide rural development program to assure rural America’s health and prosperity. In keeping with that mandate, and recognizing the key role rural America will play in the development of biofuel technology and development, I request that the Secretary of Agriculture take the following steps, to the extent permitted by law:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(a) Immediately begin restructuring existing investments in renewable fuels as needed to preserve industry employment; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) Develop a comprehensive approach to accelerating the investment in and production of American biofuels and reducing our dependence on fossil fuels by providing, within 30 days, under the authorities made available in the Food, Conservation, and Energy Act of 2008:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(i) Loan guarantees for the development, construction, and retrofitting of commercial-scale biorefineries and grants to help pay for the development and construction costs of demonstration-scale biorefineries;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(ii) Expedited funding to encourage biorefineries to replace the use of fossil fuels in plant operations by installing new biomass energy systems or producing new energy from renewable biomass;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(iii) Expedited funding to biofuels producers to encourage production of next-generation biofuels from cellulosic biomass and other feedstocks;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(iv) Expansion of the Renewable Energy Systems and Energy Efficiency Improvements Program, which has been renamed the Rural Energy for America Program, to include hydroelectric source technologies, energy audits, and higher loan guarantee limits; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":" (v) Guidance and support for collection, harvest, storage, and transportation assistance for eligible materials for use in biomass conversion facilities.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This memorandum is not intended to, and does not, create any right or benefit, substantive or procedural, enforceable at law or in equity by any party against the United States, its departments, agencies, or entities, its officers, employees, or agents, or any other person.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Secretary of Agriculture is hereby authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Barack Obama.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
