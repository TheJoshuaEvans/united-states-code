,"attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restore ecosystem health;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02adc9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/13/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would not otherwise be used for higher-value products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02adc9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/13/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" are harvested in accordance with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf02adc9c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/13/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable law and land management plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf02adc9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/13/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the requirements for—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idf02adc9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/13/A/iii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" old-growth maintenance, restoration, and management direction of paragraphs (2), (3), and (4) of subsection (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6512"},"text":"section 6512 of title 16","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idf02adc9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/13/A/iii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" large-tree retention of subsection (f) of that section; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adca0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any organic matter that is available on a renewable or recurring basis from non-Federal land or land belonging to an Indian or Indian tribe that is held in trust by the United States or subject to a restriction against alienation imposed by the United States, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf02adca1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/13/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" renewable plant material, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf02adca2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/13/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" feed grains;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf02adca3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/13/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other agricultural commodities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf02adca4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/13/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other plants and trees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf02adca5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/13/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" algae; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02adca6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/13/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" waste material, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf02adca7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/13/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" crop residue;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf02adca8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/13/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other vegetative waste material (including wood waste and wood residues);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf02adca9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/13/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" animal waste and byproducts (including fats, oils, greases, and manure); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf02adcaa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/13/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food waste and yard waste.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adcab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewable chemical","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “renewable chemical” means a monomer, polymer, plastic, formulated product, or chemical substance produced from renewable biomass.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adcac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewable energy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “renewable energy” means energy derived from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02adcad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a wind, solar, renewable biomass, ocean (including tidal, wave, current, and thermal), geothermal, or hydroelectric source; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adcae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hydrogen derived from renewable biomass or water using an energy source described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adcaf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewable energy system","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02adcb0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/16/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (C), the term “renewable energy system” means a system that produces usable energy from a renewable energy source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adcb1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/16/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “renewable energy system” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf02adcb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/16/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distribution components necessary to move energy produced by a system described in subparagraph (A) to the initial point of sale; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02adcb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/16/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other components and ancillary infrastructure of a system described in subparagraph (A), such as a storage system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adcb4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/16/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A system described in subparagraph (A) may not include a mechanism for dispensing energy at retail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adcb5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf02d4cb6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIX/s9001"},"text":"Pub. L. 107–171, title IX, § 9001","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tIX/s9001/a"},"text":"Pub. L. 110–234, title IX, § 9001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1303"},"text":"122 Stat. 1303","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246