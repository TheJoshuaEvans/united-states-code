A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “advanced biofuel” means fuel derived from renewable biomass other than corn kernel starch.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adc74-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (A), the term “advanced biofuel” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf02adc75-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" biofuel derived from cellulose, hemicellulose, or lignin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02adc76-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" biofuel derived from sugar and starch (other than ethanol derived from corn kernel starch);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02adc77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8101/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" biofuel derived from waste material, including crop residue, other vegetative waste material, animal waste, food waste, and yard waste;","children":[],"tail":"\n"}]