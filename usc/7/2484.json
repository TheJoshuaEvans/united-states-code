{"tag":"section","attrib":{"id":"idef8414ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2484"},"text":null,"children":[{"tag":"num","attrib":{"value":"2484"},"text":"§ 2484.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correction of Plant Variety Protection Office mistake","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever a mistake in a certificate of plant variety protection incurred through the fault of the Plant Variety Protection Office is clearly disclosed by the records of the Office, the Secretary may issue, without charge, a corrected certificate of plant variety protection, stating the fact and nature of such mistake. Such certificate of plant variety protection shall have the same effect and operation in law as if the same had been originally issued in such corrected form.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef8414eb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tII/s84"},"text":"Pub. L. 91–577, title II, § 84","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1552"},"text":"84 Stat. 1552","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/574/s15"},"text":"Pub. L. 96–574, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3350"},"text":"94 Stat. 3350","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8414ec-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef8414ed-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef8414ee-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/574"},"text":"Pub. L. 96–574","children":[],"tail":" substituted provisions relating to correction of Plant Variety Protection Office mistake for provisions relating to certificate of correction of Plant Variety Protection Office mistake."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
