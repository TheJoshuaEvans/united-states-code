{"tag":"section","attrib":{"id":"idf049fcc7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9018"},"text":null,"children":[{"tag":"num","attrib":{"value":"9018"},"text":"§ 9018.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf049fcc8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9018/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with certain requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf049fcc9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9018/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before the producers on a farm may receive payments under this subchapter with respect to the farm, the producers shall agree, during the crop year for which the payments are made and in exchange for the payments—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf049fcca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9018/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to comply with applicable conservation requirements under subtitle B of title XII of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3811"},"text":"16 U.S.C. 3811","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf049fccb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9018/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to comply with applicable wetland protection requirements under subtitle C of title XII of that Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3821"},"text":"16 U.S.C. 3821","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf049fccc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9018/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to effectively control noxious weeds and otherwise maintain the land in accordance with sound agricultural practices, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf049fccd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9018/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use the land on the farm, in a quantity equal to the attributable base acres for the farm and any base acres for an agricultural or conserving use, and not for a nonagricultural commercial, industrial, or residential use, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf049fcce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9018/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may issue such rules as the Secretary considers necessary to ensure producer compliance with the requirements of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf049fccf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9018/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of the transferee or owner, the Secretary may modify the requirements of this subsection if the modifications are consistent with the objectives of this subsection, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf049fcd0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9018/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer or change of interest in farm","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf049fcd1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9018/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf049fcd2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9018/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), a transfer of (or change in) the interest of the producers on a farm for which payments under this subchapter are provided shall result in the termination of the payments, unless the transferee or owner of the acreage agrees to assume all obligations under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf049fcd3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9018/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The termination shall take effect on the date determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf049fcd4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9018/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a producer entitled to a payment under this subchapter dies, becomes incompetent, or is otherwise unable to receive the payment, the Secretary shall make the payment in accordance with rules issued by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf049fcd5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9018/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acreage reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition on the receipt of any benefits under this subchapter or subchapter II, the Secretary shall require producers on a farm to submit to the Secretary annual acreage reports with respect to all cropland on the farm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf049fcd6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9018/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As an additional condition on receiving agriculture risk coverage payments for individual coverage, the Secretary shall require a producer on a farm to submit to the Secretary annual production reports with respect to all covered commodities produced on all farms in the same State—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf049fcd7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9018/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the producer has an interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf049fcd8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9018/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which individual coverage has been selected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf049fcd9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9018/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of inaccurate reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty with respect to benefits under this subchapter or subchapter II shall be assessed against a producer on a farm for an inaccurate acreage or production report unless the Secretary determines that the producer on the farm knowingly and willfully falsified the acreage or production report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf049fcda-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9018/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tenants and sharecroppers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subchapter, the Secretary shall provide adequate safeguards to protect the interests of tenants and sharecroppers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf049fcdb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9018/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sharing of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for the sharing of payments made under this subchapter among the producers on a farm on a fair and equitable basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf049fcdc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1118"},"text":"Pub. L. 113–79, title I, § 1118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/672"},"text":"128 Stat. 672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf049fcdd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf049fcde-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf049fcdf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsecs. (a)(1), (b)(1)(A), (2), (c), and (e) to (g), was in the original “this subtitle”, meaning subtitle A (§§ 1101–1109) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/658"},"text":"128 Stat. 658","children":[],"tail":", which is classified principally to this subchapter. For complete classification of subtitle A to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Food Security Act of 1985, referred to in subsec. (a)(1)(A), (B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1354"},"text":"99 Stat. 1354","children":[],"tail":". Subtitles B and C of title XII of the Act are classified generally to subchapters II (§ 3811 et seq.) and III (§ 3821 et seq.), respectively, of chapter 58 of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title of 1985 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1281"},"text":"section 1281 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
