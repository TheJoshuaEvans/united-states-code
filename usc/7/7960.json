{"tag":"section","attrib":{"id":"idf0289266-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7960"},"text":null,"children":[{"tag":"num","attrib":{"value":"7960"},"text":"§ 7960.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repeal of superseded price support authority and effect of repeal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0289267-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7960/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0289268-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7960/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law or previous declaration made by the Secretary, the Secretary shall ensure that the disposal of all peanuts for which a loan for the 2001 crop of peanuts was made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7271"},"text":"section 7271 of this title","children":[],"tail":" before "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", is carried out in a manner that prevents price disruptions in the domestic and international markets for peanuts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0289269-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7960/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of crop insurance policies for 2002 crop year","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf028926a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7960/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall apply for the 2002 crop year only notwithstanding any other provision of law or crop insurance policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf028926b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7960/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Price election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The nonquota price election for segregation I, II, and III peanuts shall be 17.75 cents per pound and shall be used for all aspects of the policy relating to the calculations of premium, liability, and indemnities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf028926c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7960/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quality adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of quality adjustment only, the average support price per pound of peanuts shall be a price equal to 17.75 cents per pound. Quality under the crop insurance policy for peanuts shall be adjusted under procedures issued by the Federal Crop Insurance Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf02adb5d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1310"},"text":"Pub. L. 107–171, title I, § 1310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/182"},"text":"116 Stat. 182","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf02adb5e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf02adb5f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf02adb60-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s1310"},"text":"section 1310 of Pub. L. 107–171","children":[],"tail":". Subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/s1310"},"text":"section 1310 of Pub. L. 107–171","children":[],"tail":" amended sections 1428 and 1441 of this title and repealed 7271 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
