{"tag":"section","attrib":{"id":"idf004b5e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7312"},"text":null,"children":[{"tag":"num","attrib":{"value":"7312"},"text":"§ 7312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf004b5e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership and appointment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall be composed of 11 members, appointed as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf004b5e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7312/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members shall be appointed by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf004b5e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7312/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four members shall be appointed by the Chairman of the Committee on Agriculture of the House of Representatives in consultation with the ranking minority member of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf004b5e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7312/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four members shall be appointed by the Chairman of the Committee on Agriculture, Nutrition, and Forestry of the Senate in consultation with the ranking minority member of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf004b5e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At least 1 of the members appointed under each of paragraphs (1), (2), and (3) of subsection (a) shall be an individual who is primarily involved in production agriculture. All other members of the Commission shall be appointed from among individuals having knowledge and experience in agricultural production, marketing, finance, or trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf004b5e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7312/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of members; vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Commission shall be appointed for the life of the Commission. A vacancy on the Commission shall not affect its powers, but shall be filled in the same manner as the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf004b5e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7312/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for appointment; first meeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Commission shall be appointed not later than ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"October 1, 1997","children":[],"tail":". The Commission shall convene its first meeting to carry out its duties under this subchapter 30 days after 6 members of the Commission have been appointed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf004b5ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7312/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chairperson of the Commission shall be designated jointly by the Chairman of the Committee on Agriculture of the House of Representatives and the Chairman of the Committee on Agriculture, Nutrition, and Forestry of the Senate from among the members of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf004b5eb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s182"},"text":"Pub. L. 104–127, title I, § 182","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/938"},"text":"110 Stat. 938","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
