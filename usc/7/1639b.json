{"tag":"section","attrib":{"id":"ideee1e0be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1639b"},"text":"§ 1639b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of national bioengineered food disclosure standard","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideee1e0bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of mandatory standard","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2016-07-29"},"text":"July 29, 2016","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee1e0c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a national mandatory bioengineered food disclosure standard with respect to any bioengineered food and any food that may be bioengineered; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e0c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish such requirements and procedures as the Secretary determines necessary to carry out the standard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee1e0c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee1e0c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A food may bear a disclosure that the food is bioengineered only in accordance with regulations promulgated by the Secretary in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e0c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A regulation promulgated by the Secretary in carrying out this subchapter shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee1e0c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit a food derived from an animal to be considered a bioengineered food solely because the animal consumed feed produced from, containing, or consisting of a bioengineered substance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e0c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the amounts of a bioengineered substance that may be present in food, as appropriate, in order for the food to be a bioengineered food;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e0c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a process for requesting and granting a determination by the Secretary regarding other factors and conditions under which a food is considered a bioengineered food;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e0c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with subsection (d), require that the form of a food disclosure under this section be a text, symbol, or electronic or digital link, but excluding Internet website Uniform Resource Locators not embedded in the link, with the disclosure option to be selected by the food manufacturer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e0c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide alternative reasonable disclosure options for food contained in small or very small packages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e0ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of small food manufacturers, provide—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideee1e0cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/b/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an implementation date that is not earlier than 1 year after the implementation date for regulations promulgated in accordance with this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideee1e0cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/b/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on-package disclosure options, in addition to those available under subparagraph (D), to be selected by the small food manufacturer, that consist of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ideee1e0cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/b/2/F/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a telephone number accompanied by appropriate language to indicate that the phone number provides access to additional information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideee1e0ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/b/2/F/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Internet website maintained by the small food manufacturer in a manner consistent with subsection (d), as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e0cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" exclude—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideee1e0d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/b/2/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food served in a restaurant or similar retail food establishment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideee1e0d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/b/2/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" very small food manufacturers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e0d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safety","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of regulations promulgated and food disclosures made pursuant to paragraph (2), a bioengineered food that has successfully completed the pre-market Federal regulatory review process shall not be treated as safer than, or not as safe as, a non-bioengineered counterpart of the food solely because the food is bioengineered or produced or developed with the use of bioengineering.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee1e0d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study of electronic or digital link disclosure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee1e0d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2016-07-29"},"text":"July 29, 2016","children":[],"tail":", the Secretary shall conduct a study to identify potential technological challenges that may impact whether consumers would have access to the bioengineering disclosure through electronic or digital disclosure methods."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e0d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting the study under paragraph (1), the Secretary shall solicit and consider comments from the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e0d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study conducted under paragraph (1) shall consider whether consumer access to the bioengineering disclosure through electronic or digital disclosure methods under this subchapter would be affected by the following factors:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee1e0d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The availability of wireless Internet or cellular networks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e0d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The availability of landline telephones in stores.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e0d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Challenges facing small retailers and rural retailers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e0da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The efforts that retailers and other entities have taken to address potential technology and infrastructure challenges.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e0db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The costs and benefits of installing in retail stores electronic or digital link scanners or other evolving technology that provide bioengineering disclosure information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e0dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional disclosure options","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines in the study conducted under paragraph (1) that consumers, while shopping, would not have sufficient access to the bioengineering disclosure through electronic or digital disclosure methods, the Secretary, after consultation with food retailers and manufacturers, shall provide additional and comparable options to access the bioengineering disclosure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee1e0dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In promulgating regulations under this section, the Secretary shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee1e0de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on-package language accompanies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee1e0df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the electronic or digital link disclosure, indicating that the electronic or digital link will provide access to an Internet website or other landing page by stating only “Scan here for more food information”, or equivalent language that only reflects technological changes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e0e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any telephone number disclosure, indicating that the telephone number will provide access to additional information by stating only “Call for more food information.”;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e0e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the electronic or digital link will provide access to the bioengineering disclosure located, in a consistent and conspicuous manner, on the first product information page that appears for the product on a mobile device, Internet website, or other landing page, which shall exclude marketing and promotional information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e0e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee1e0e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the electronic or digital link disclosure may not collect, analyze, or sell any personally identifiable information about consumers or the devices of consumers; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e0e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if information described in subparagraph (A) must be collected to carry out the purposes of this subchapter, that information shall be deleted immediately and not used for any other purpose;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e0e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the electronic or digital link disclosure also includes a telephone number that provides access to the bioengineering disclosure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e0e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the electronic or digital link disclosure is of sufficient size to be easily and effectively scanned or read by a digital device.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee1e0e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State food labeling standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1639i"},"text":"section 1639i of this title","children":[],"tail":", no State or political subdivision of a State may directly or indirectly establish under any authority or continue in effect as to any food in interstate commerce any requirement relating to the labeling or disclosure of whether a food is bioengineered or was developed or produced using bioengineering for a food that is the subject of the national bioengineered food disclosure standard under this section that is not identical to the mandatory disclosure requirement under that standard."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee1e0e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency with certain laws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall consider establishing consistency between—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee1e0e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national bioengineered food disclosure standard established under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e0ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Organic Foods Production Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6501"},"text":"7 U.S.C. 6501","children":[],"tail":" et seq.) and any rules or regulations implementing that Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee1e0eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee1e0ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be a prohibited act for a person to knowingly fail to make a disclosure as required under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e0ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each person subject to the mandatory disclosure requirement under this section shall maintain, and make available to the Secretary, on request, such records as the Secretary determines to be customary or reasonable in the food industry, by regulation, to establish compliance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e0ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination and audit","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee1e0ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may conduct an examination, audit, or similar activity with respect to any records required under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e0f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person subject to an examination, audit, or similar activity under subparagraph (A) shall be provided notice and opportunity for a hearing on the results of any examination, audit, or similar activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e0f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/g/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit results","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the notice and opportunity for a hearing under subparagraph (B), the Secretary shall make public the summary of any examination, audit, or similar activity under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e0f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639b/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recall authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall have no authority to recall any food subject to this subchapter on the basis of whether the food bears a disclosure that the food is bioengineered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideee1e0f3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 293, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/216/s1"},"text":"Pub. L. 114–216, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-29"},"text":"July 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/835"},"text":"130 Stat. 835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideee1e0f4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideee1e0f5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideee1e0f6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Organic Foods Production Act of 1990, referred to in subsec. (f)(2), is title XXI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3935"},"text":"104 Stat. 3935","children":[],"tail":", which is classified generally to chapter 94 (§ 6501 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6501"},"text":"section 6501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
