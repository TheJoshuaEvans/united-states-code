{"tag":"section","attrib":{"id":"idf03ba4d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506"},"text":null,"children":[{"tag":"num","attrib":{"value":"8506"},"text":"§ 8506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role of brown tree snake Technical Working Group","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf03ba4d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Technical Working Group shall ensure that Federal, State, territorial, and local agency efforts concerning the brown tree snake are coordinated, effective, complementary, and cost-effective.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03ba4d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific duties and activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Technical Working Group shall be responsible for the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03ba4d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The evaluation of Federal, State, and territorial activities, programs and policies that are likely to cause or promote the introduction or spread of the brown tree snake in the United States or the Freely Associated States and the preparation of recommendations for governmental actions to minimize the risk of introduction or further spread of the brown tree snake.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03ba4d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The preparation of recommendations for activities, programs, and policies to reduce and eventually eradicate the brown tree snake in Guam or other areas within the United States where the snake may be established and the monitoring of the implementation of those activities, programs, and policies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03ba4da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any revision of the Brown Tree Snake Control Plan, originally published in June 1996, which was prepared to coordinate Federal, State, territorial, and local government efforts to control, interdict, eradicate or conduct research on the brown tree snake.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03ba4db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03ba4dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations for this purpose, the Technical Working Group shall prepare a report describing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03ba4dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress made toward a large-scale population reduction or eradication of the brown tree snake in Guam or other sites that are infested by the brown tree snake;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03ba4de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interdiction and other activities required to reduce the risk of introduction of the brown tree snake or other nonindigenous snake species in Guam, the Commonwealth of the Northern Mariana Islands, Hawaii, American Samoa, and the Freely Associated States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03ba4df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applied and basic research activities that will lead to improved brown tree snake control, interdiction and eradication efforts conducted by Federal, State, territorial, and local governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03ba4e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the programs and activities for brown tree snake control, interdiction, research and eradication that have been funded, implemented, and planned by Federal, State, territorial, and local governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03ba4e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Technical Working Group shall include in the report a list of priorities, ranked in high, medium, and low categories, of Federal, State, territorial, and local efforts and programs in the following areas:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03ba4e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Control.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03ba4e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03ba4e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03ba4e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Eradication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03ba4e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Technical Working Group shall include in the report the following assessments:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03ba4e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of current funding shortfalls and future funding needs to support Federal, State, territorial, and local government efforts to control, interdict, eradicate, or conduct research on the brown tree snake.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03ba4e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of regulatory limitations that hinder Federal, State, territorial, and local government efforts to control, interdict, eradicate or conduct research on the brown tree snake.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03ba4e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations for this purpose, the Technical Working Group shall submit the report to Congress not later than one year after ","children":[{"tag":"date","attrib":{"date":"2004-10-30"},"text":"October 30, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03ba4ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Technical Working Group shall meet at least annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03ba4eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of Guam","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries shall ensure that adequate representation is afforded to the government of Guam in the Technical Working Group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03ba4ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the Secretaries shall make adequate resources available to the Technical Working Group to ensure its efficient and effective operation. The Secretaries may provide staff to assist the Technical Working Group in carrying out its duties and functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03ba4ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8506/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to each of the Secretaries not more than $450,000 for each of the fiscal years 2006 through 2010 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf03ba4ee-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/384/s7"},"text":"Pub. L. 108–384, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2224"},"text":"118 Stat. 2224","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
