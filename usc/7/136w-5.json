{"tag":"section","attrib":{"id":"idee0b3012-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"136w–5"},"text":"§ 136w–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum requirements for training of maintenance applicators and service technicians","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each State may establish minimum requirements for training of maintenance applicators and service technicians. Such training may include instruction in the safe and effective handling and use of pesticides in accordance with the Environmental Protection Agency approved labeling, and instruction in integrated pest management techniques. The authority of the Administrator with respect to minimum requirements for training of maintenance applicators and service technicians shall be limited to ensuring that each State understands the provisions of this section.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee0b3013-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-25/ch125/s30"},"text":"June 25, 1947, ch. 125, § 30","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/170/tI/s121/2"},"text":"Pub. L. 104–170, title I, § 121(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-03"},"text":"Aug. 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1492"},"text":"110 Stat. 1492","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee0b3014-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee0b3015-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee0b3016-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 30 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-25/ch125"},"text":"act June 25, 1947, ch. 125","children":[],"tail":", was renumbered section 34 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136x"},"text":"section 136x of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
