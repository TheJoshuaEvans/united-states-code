{"tag":"section","attrib":{"id":"idefdc4746-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6105"},"text":null,"children":[{"tag":"num","attrib":{"value":"6105"},"text":"§ 6105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referenda","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefdc4747-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial referendum","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefdc4748-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within the 60-day period immediately preceding the effective date of an order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6103/b"},"text":"section 6103(b) of this title","children":[],"tail":", the Secretary shall conduct a referendum among mushroom producers and importers to ascertain whether the order shall go into effect."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc4749-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall become effective, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6103/b"},"text":"section 6103(b) of this title","children":[],"tail":", if the Secretary determines that the order has been approved by a majority of the producers and importers voting in the referendum, which majority, on average, annually produces and imports into the United States more than 50 percent of the mushrooms annually produced and imported by all those voting in the referendum."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc474a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Succeeding referenda","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefdc474b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination concerning order","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefdc474c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6105/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective 5 years after the date on which an order becomes effective under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6103/b"},"text":"section 6103(b) of this title","children":[],"tail":", the Secretary shall conduct a referendum among mushroom producers and importers to ascertain whether they favor continuation, termination, or suspension of the order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc474d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6105/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for referendum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective beginning 3 years after the date on which an order becomes effective under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6103/b"},"text":"section 6103(b) of this title","children":[],"tail":", the Secretary, on request of a representative group comprising 30 percent or more of the number of mushroom producers and importers, may conduct a referendum to ascertain whether producers and importers favor termination or suspension of the order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc474e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension or termination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, as a result of any referendum conducted under paragraph (1), the Secretary determines that suspension or termination of an order is favored by a majority of the producers and importers voting in the referendum, which majority, on average, annually produces and imports into the United States more than 50 percent of the mushrooms annually produced and imported by all those voting in the referendum, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefdc474f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6105/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 6 months after making such determination, suspend or terminate, as appropriate, collection of assessments under the order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc4750-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6105/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspend or terminate, as appropriate, activities under the order in an orderly manner as soon as practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc4751-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Referenda conducted pursuant to this section shall be conducted in such a manner as is determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefdc4752-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1926"},"text":"Pub. L. 101–624, title XIX, § 1926","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3861"},"text":"104 Stat. 3861","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
