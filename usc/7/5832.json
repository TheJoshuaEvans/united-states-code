{"tag":"section","attrib":{"id":"idefd05f6d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832"},"text":null,"children":[{"tag":"num","attrib":{"value":"5832"},"text":"§ 5832.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Training Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefd05f6e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a National Training Program in Sustainable Agriculture to provide education and training for Cooperative Extension Service agents and other professionals involved in the education and transfer of technical information concerning sustainable agriculture in order to develop their understanding, competence, and ability to teach and communicate the concepts of sustainable agriculture to Cooperative Extension Service agents and to farmers and urban residents who need information on sustainable agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05f6f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Training Program shall be organized and administered by the National Institute of Food and Agriculture, in coordination with other appropriate Federal agencies. The Secretary shall designate an individual from the Cooperative Extension Service in each State to coordinate the National Training Program within that State. The coordinators shall be responsible, in cooperation with appropriate Federal and State agencies, for developing and implementing a statewide training program for appropriate field office personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05f70-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required training","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd05f71-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural agents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that all agricultural agents of the Cooperative Extension Service have completed the National Training Program not later than the end of the five-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":". Such training may occur at a college or university located within each State as designated by the coordinator designated under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05f72-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proof of training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning three years after ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":", the Secretary shall ensure that all new Cooperative Extension Service agents employed by such Service are able to demonstrate, not later than 18 months after the employment of such agents, that such agents have completed the training program established in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05f73-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional training centers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd05f74-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate not less than two regional training centers to coordinate and administer educational activities in sustainable agriculture as provided for in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05f75-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such centers shall offer intensive instructional programs involving classroom and field training work for extension specialists and other individuals who are required to transmit technical information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05f76-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such centers shall be located at existing facilities, and no funds appropriated to carry out this part shall be used for facility construction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05f77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such centers should be administered by entities that have a demonstrated capability relating to sustainable agriculture. The Secretary should consider utilizing existing entities with expertise in sustainable agriculture to assist in the design and implementation of the training program under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05f78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such centers shall make use of information generated by the Department of Agriculture and the State agricultural experiment stations, and the practical experience of farmers, especially those cooperating in on-farm demonstrations and research projects, in carrying out the functions of such centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05f79-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd05f7a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a competitive grants program to award grants to organizations, including land-grant colleges and universities, to carry out sustainable agricultural training for county agents and other individuals that need basic information concerning sustainable agriculture practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05f7b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short courses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the grants made available under paragraph (1) shall be to establish, in various regions in the United States, training programs that consist of workshops and short courses designed to familiarize participants with the concepts and importance of sustainable agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05f7c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional specialists","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To assist county agents and farmers implement production practices developed under this subchapter, chapter 86 of this title,","children":[{"tag":"ref","attrib":{"idref":"fn002311"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002311"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and other appropriate research programs of the Department, regional sustainable agriculture specialists may be designated within each State who shall report to the State coordinator of that State. The specialists shall be responsible for developing and coordinating local dissemination of sustainable agriculture information in a manner that is useful to farmers in the region."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05f7d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Cooperative Extension Service within each State shall transfer information developed under this subchapter, chapter 86 of this title,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and other appropriate research programs of the Department through a program that shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd05f7e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in developing farmer-to-farmer information exchange networks to enable farmers making transitions to more sustainable farming systems to share ideas and draw on the experiences of other farmers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05f7f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" help coordinate and publicize a regular series of sustainable agriculture farm tours and field days within each State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05f80-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plan for extension programming, including extensive farmer input and feedback, in the design of new and ongoing research endeavors related to sustainable agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05f81-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to individual farmers in the design and implementation of farm management plans and strategies for making a transition to more sustainable agricultural systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05f82-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult and work closely with the Soil Conservation Service and the Agricultural Stabilization and Conservation Service in carrying out the information, technical assistance, and related programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05f83-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/g/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, coordinate, and direct special education and outreach programs in areas highly susceptible to groundwater contamination, linking sustainable agriculture information with water quality improvement information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05f84-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/g/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop information sources relating to crop diversification, alternative crops, on-farm food or commodity processing, and on-farm energy generation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05f85-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/g/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a well-water testing program designed to provide those persons dependent upon underground drinking water supplies with an understanding of the need for regular water testing, information on sources of testing, and an understanding of how to interpret test results and provide for the protection of underground water supplies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05f86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/g/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide specific information on water quality practices developed through the research programs in chapter 86 of this title; ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05f87-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/g/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide specific information on nutrient management practices developed through the research programs in chapter 86 of this title; ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05f88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/g/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information concerning whole-farm management systems integrating research results under this subchapter, chapter 86 of this title,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and other appropriate research programs of the Department."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05f89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Appropriate field office personnel” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “appropriate field office personnel” includes employees of the National Institute of Food and Agriculture, Soil Conservation Service, and other appropriate Department of Agriculture personnel, as determined by the Secretary, whose activities involve the provision of agricultural production and conservation information to agricultural producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05f8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5832/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out the National Training Program $20,000,000 for each of fiscal years 2013 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefd05f8b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1629"},"text":"Pub. L. 101–624, title XVI, § 1629","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3741"},"text":"104 Stat. 3741","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIV/s407/4"},"text":"Pub. L. 102–237, title IV, § 407(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1864"},"text":"105 Stat. 1864","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s862/b/4"},"text":"Pub. L. 104–127, title VIII, § 862(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1174"},"text":"110 Stat. 1174","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tVI/s606/f"},"text":"Pub. L. 105–185, title VI, § 606(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/604"},"text":"112 Stat. 604","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7511/c/17"},"text":"Pub. L. 110–234, title VII, § 7511(c)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"