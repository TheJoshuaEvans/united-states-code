{"tag":"section","attrib":{"id":"idef6c1f65-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2134"},"text":null,"children":[{"tag":"num","attrib":{"value":"2134"},"text":"§ 2134.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Valid license for dealers and exhibitors required","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No dealer or exhibitor shall sell or offer to sell or transport or offer for transportation, in commerce, to any research facility or for exhibition or for use as a pet any animal, or buy, sell, offer to buy or sell, transport or offer for transportation, in commerce, to or from another dealer or exhibitor under this chapter any animals, unless and until such dealer or exhibitor shall have obtained a license from the Secretary and such license shall not have been suspended or revoked.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef6c1f66-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/544/s4"},"text":"Pub. L. 89–544, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-08-24"},"text":"Aug. 24, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/351"},"text":"80 Stat. 351","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/579/s5"},"text":"Pub. L. 91–579, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1561"},"text":"84 Stat. 1561","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/279/s5"},"text":"Pub. L. 94–279, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-22"},"text":"Apr. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/418"},"text":"90 Stat. 418","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef6c1f67-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef6c1f68-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef6c1f69-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/279"},"text":"Pub. L. 94–279","children":[],"tail":" substituted “in commerce” for “affecting commerce” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/579"},"text":"Pub. L. 91–579","children":[],"tail":" inserted references to exhibitors, offers to sell, and offers to transport, and substituted references to animals for references to dogs and cats."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef6c1f6a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef6c1f6b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/579"},"text":"Pub. L. 91–579","children":[],"tail":" effective one year after "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/579/s23"},"text":"section 23 of Pub. L. 91–579","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2131"},"text":"section 2131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
