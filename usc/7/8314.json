{"tag":"section","attrib":{"id":"idf036ea10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314"},"text":null,"children":[{"tag":"num","attrib":{"value":"8314"},"text":"§ 8314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf036ea11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf036ea12-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may gather and compile information and conduct any inspection or investigation that the Secretary considers to be necessary for the administration or enforcement of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036ea13-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpoenas","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf036ea14-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall have the power to subpoena the attendance and testimony of any witness, the production of all evidence (including books, papers, documents, electronically stored information, and other tangible things that constitute or contain evidence), or to require the person to whom the subpoena is directed to permit the inspection of premises relating to the administration or enforcement of this chapter ","children":[{"tag":"ref","attrib":{"idref":"fn002364"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002364"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or any matter under investigation in connection with this chapter."},{"tag":"ref","attrib":{"idref":"fn002364"},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036ea15-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location of production","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The attendance of any witness and production of evidence relevant to the inquiry may be required from any place in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036ea16-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf036ea17-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In case of disobedience to a subpoena by any person, the Secretary may request the Attorney General to invoke the aid of any court of the United States within the jurisdiction in which the investigation is conducted, or where the person resides, is found, transacts business, is licensed to do business, or is incorporated, to require the attendance and testimony of any witness, the production of evidence, or the inspection of premises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf036ea18-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In case of a refusal to obey a subpoena issued to any person, a court may order the person to appear before the Secretary and give evidence concerning the matter in question, produce evidence, or permit the inspection of premises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf036ea19-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/a/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contempt","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any failure to obey the order of the court may be punished by the court as contempt of the court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036ea1a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf036ea1b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Witnesses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A witness summoned by the Secretary under this chapter shall be paid the same fees and mileage that are paid to a witness in a court of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf036ea1c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Depositions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A witness whose deposition is taken, and the person taking the deposition, shall be entitled to the same fees that are paid for similar services in a court of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036ea1d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf036ea1e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/a/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish procedures for the issuance of subpoenas under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf036ea1f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/a/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The procedures shall include a requirement that subpoenas be reviewed for legal sufficiency and, to be effective, be signed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf036ea20-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/a/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the authority to sign a subpoena is delegated to an agency other than the Office of Administrative Law Judges, the agency receiving the delegation shall seek review of the subpoena for legal sufficiency outside that agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf036ea21-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Attorney General","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf036ea22-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prosecute, in the name of the United States, all criminal violations of this chapter that are referred to the Attorney General by the Secretary or are brought to the notice of the Attorney General by any person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036ea23-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bring an action to enjoin the violation of or to compel compliance with this chapter, or to enjoin any interference by any person with the Secretary in carrying out this chapter, in any case in which the Secretary has reason to believe that the person has violated, or is about to violate this chapter or has interfered, or is about to interfere, with the actions of the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036ea24-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bring an action for the recovery of any unpaid civil penalty, funds under a reimbursable agreement, late payment penalty, or interest assessed under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf036ea25-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court jurisdiction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf036ea26-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States district courts, the District Court of Guam, the District Court of the Northern Mariana Islands, the District Court of the Virgin Islands, the highest court of American Samoa, and the United States courts of the other territories and possessions are vested with jurisdiction in all cases arising under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036ea27-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any action arising under this chapter may be brought, and process may be served, in the judicial district where a violation or interference occurred or is about to occur, or where the person charged with the violation, interference, impending violation, impending interference, or failure to pay resides, is found, transacts business, is licensed to do business, or is incorporated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036ea28-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8314/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraphs (1) and (2) do not apply to sections 8309(c) and 8313(b) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf036ea29-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10415"},"text":"Pub. L. 107–171, title X, § 10415","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/505"},"text":"116 Stat. 505","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXI/s11012/b"},"text":"Pub. L. 110–234, title XI, § 11012(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1360"},"text":"122 Stat. 1360","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XI, § 11012(b), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2122.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf036ea2a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf036ea2b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf036ea2c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(2)(A), was in the original “this title”, and was translated as reading “this subtitle”, meaning subtitle E (§§ 10401–10418) of title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/494"},"text":"116 Stat. 494","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf036ea2d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf036ea2e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s11012/b/1"},"text":"Pub. L. 110–246, § 11012(b)(1)","children":[],"tail":", added subpar. (A) and struck out former subpar. (A). Prior to amendment, text read as follows: “The Secretary shall have power to issue a subpoena to compel the attendance and testimony of any witness and the production of any documentary evidence relating to the administration or enforcement of this chapter or any matter under investigation in connection with this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s11012/b/2"},"text":"Pub. L. 110–246, § 11012(b)(2)","children":[],"tail":", struck out “documentary” before “evidence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s11012/b/3/A"},"text":"Pub. L. 110–246, § 11012(b)(3)(A)","children":[],"tail":", substituted “testimony of any witness, the production of evidence, or the inspection of premises” for “testimony of any witness and the production of documentary evidence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s11012/b/3/B"},"text":"Pub. L. 110–246, § 11012(b)(3)(B)","children":[],"tail":", substituted “question, produce evidence, or permit the inspection of premises” for “question or to produce documentary evidence”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf036ea2f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf036ea30-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idf036ea31-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of the Secretary of Agriculture relating to agricultural import and entry inspection activities under this chapter to the Secretary of Homeland Security, and for treatment of related references, see sections 231, 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
