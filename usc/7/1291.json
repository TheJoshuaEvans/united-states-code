{"tag":"section","attrib":{"id":"idee6f7042-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1291"},"text":null,"children":[{"tag":"num","attrib":{"value":"1291"},"text":"§ 1291.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments in freight rates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee6f7043-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1291/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complaints by Secretary of Agriculture; notice of hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture is authorized to make complaint to the Surface Transportation Board with respect to rates, charges, tariffs, and practices relating to the transportation of farm products, and to prosecute the same before the Board. Before hearing or disposing of any complaint (filed by any person other than the Secretary) with respect to rates, charges, tariffs, and practices relating to the transportation of farm products, the Board shall cause the Secretary to be notified, and, upon application by the Secretary, shall permit the Secretary to appear and be heard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee6f7044-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1291/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary as party to proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If such rate, charge, tariff, or practice complained of is one affecting the public interest, upon application by the Secretary, the Board shall make the Secretary a party to the proceeding. In such case the Secretary shall have the rights of a party before the Board and the rights of a party to invoke and pursue original and appellate judicial proceedings involving the Board’s determination. The liability of the Secretary in any such case shall extend only to liability for court costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee6f7045-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1291/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of records, services, etc., of Department of Agriculture","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, the Surface Transportation Board is authorized to avail itself of the cooperation, records, services, and facilities of the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee6f7046-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1291/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with complaining farm associations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to cooperate with and assist cooperative associations of farmers making complaint to the Surface Transportation Board with respect to rates, charges, tariffs, and practices relating to the transportation of farm products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee6f7047-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title II, § 201, "},{"tag":"ref","attrib":{"href":"/us/stat/52/36"},"text":"52 Stat. 36","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/tIII/s311"},"text":"Pub. L. 104–88, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/948"},"text":"109 Stat. 948","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee6f7048-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee6f7049-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee6f704a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" substituted “Surface Transportation Board” for “Interstate Commerce Commission” in subsecs. (a), (c), and (d), “Board” for “Commission” wherever appearing in subsecs. (a) and (b), and “Board’s” for “Commission’s” in subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee6f704b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee6f704c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of Title 49","children":[],"tail":", Transportation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
