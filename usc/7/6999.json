{"tag":"section","attrib":{"id":"ideff8cf61-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6999"},"text":null,"children":[{"tag":"num","attrib":{"value":"6999"},"text":"§ 6999.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A final determination of the Division shall be reviewable and enforceable by any United States district court of competent jurisdiction in accordance with chapter 7 of title 5.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideff8cf62-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s279"},"text":"Pub. L. 103–354, title II, § 279","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3233"},"text":"108 Stat. 3233","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
