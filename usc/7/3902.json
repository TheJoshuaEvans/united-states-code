{"tag":"section","attrib":{"id":"idefb13ef3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3902"},"text":null,"children":[{"tag":"num","attrib":{"value":"3902"},"text":"§ 3902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research program on cancer in animals and birds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall conduct a program of basic research on cancer in animals and birds at appropriate facilities within the Department of Agriculture or by grants to other qualified research facilities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefb13ef4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/469/s3"},"text":"Pub. L. 96–469, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2235"},"text":"94 Stat. 2235","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
