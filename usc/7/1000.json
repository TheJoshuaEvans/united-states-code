{"tag":"section","attrib":{"id":"idee68440f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1000"},"text":null,"children":[{"tag":"num","attrib":{"value":"1000"},"text":"§ 1000.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Sections 1001 to 1006, 1006c to 1006e, 1007, 1008 to 1010, 1011, 1012, and 1013 to 1029 of this title may be cited as “The Bankhead-Jones Farm Tenant Act”.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee684410-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-07-22/ch517"},"text":"July 22, 1937, ch. 517","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/522"},"text":"50 Stat. 522","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee684411-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee684412-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"repeals","id":"idee684413-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeals","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s341/a"},"text":"Pub. L. 87–128, title III, § 341(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/318"},"text":"75 Stat. 318","children":[],"tail":", repealed titles I, II, and IV of the Bankhead-Jones Farm Tenant Act, sections 1001 to 1006, 1006c to 1006e, 1007, 1008, 1009, 1014 to 1025, and 1027 to 1029 of this title. "},{"tag":"ref","attrib":{"href":"/us/pl/87/128/s341/a"},"text":"Section 341(a) of Pub. L. 87–128","children":[],"tail":" also provided that reference to any provision of the Bankhead-Jones Farm Tenant Act superseded by any provision of title III of "},{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":" shall be construed as referring to the appropriate provision of such title. See section 1921 et seq. of this title. Section 1013 expired by its own terms and has been omitted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
