{"tag":"section","attrib":{"id":"idefc20845-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4914"},"text":null,"children":[{"tag":"num","attrib":{"value":"4914"},"text":"§ 4914.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment procedure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefc20846-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4914/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before a plan issued by the Secretary under this chapter may be amended, the Secretary shall publish the proposed amendments for public comment and conduct a referendum in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4912"},"text":"section 4912 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc20847-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4914/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate consideration of amendments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc20848-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4914/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amendments described in paragraph (2) that are required to be made by the Secretary to a plan as a result of the amendments made by the Watermelon Research and Promotion Improvement Act of 1993 shall be subject to separate line item voting and approval in a referendum conducted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4912"},"text":"section 4912 of this title","children":[],"tail":" before the Secretary alters the plan as in effect on the day before "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"December 14, 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc20849-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4914/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amendments referred to in paragraph (1) are the amendments to a plan required under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc2084a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4914/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 7 of the Watermelon Research and Promotion Improvement Act of 1993 relating to the elimination of the assessment refund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc2084b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4914/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 8 of such Act relating to subjecting importers to the terms and conditions of the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc2084c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4914/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When conducting the referendum relating to subjecting importers to the terms and conditions of a plan, the Secretary shall include as eligible voters in the referendum producers, handlers, and importers who would be subject to the plan if the amendments to a plan were approved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefc2084d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1655"},"text":"Pub. L. 99–198, title XVI, § 1655","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1630"},"text":"99 Stat. 1630","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/189/s10"},"text":"Pub. L. 103–189, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2264"},"text":"107 Stat. 2264","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefc2084e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefc2084f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefc20850-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Watermelon Research and Promotion Improvement Act of 1993, referred to in subsec. (b)(1), (2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/189"},"text":"Pub. L. 103–189","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2259"},"text":"107 Stat. 2259","children":[],"tail":", which amended this section and sections 4901 to 4904, 4906, 4908, and 4911 to 4913 of this title, and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4901"},"text":"section 4901 of this title","children":[],"tail":". Section 7 of the Act amended "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4906"},"text":"section 4906 of this title","children":[],"tail":". Section 8 of the Act amended sections 4901 to 4904, 4906, 4908, and 4911 to 4913 of this title. For complete classification of this Act to the Code, see Short Title of 1993 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4901"},"text":"section 4901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefc20851-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/189"},"text":"Pub. L. 103–189","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The provisions of this chapter applicable to plans shall be applicable to amendments to plans.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
