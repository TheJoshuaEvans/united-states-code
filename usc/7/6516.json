{"tag":"section","attrib":{"id":"idefe5bcbd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6516"},"text":null,"children":[{"tag":"num","attrib":{"value":"6516"},"text":"§ 6516.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review of certifying agents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe5bcbe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6516/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining whether to approve an application for accreditation submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6514"},"text":"section 6514 of this title","children":[],"tail":", the Secretary shall consider a report concerning such applicant that shall be prepared by a peer review panel established under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bcbf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6516/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review panel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To assist the Secretary in evaluating applications under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6514"},"text":"section 6514 of this title","children":[],"tail":", the Secretary may establish a panel of not less than three persons who have expertise in organic farming and handling methods, to evaluate the State governing official or private person that is seeking accreditation as a certifying agent under such section. Not less than two members of such panel shall be persons who are not employees of the Department of Agriculture or of the applicable State government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe5bcc0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXI/s2117"},"text":"Pub. L. 101–624, title XXI, § 2117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3945"},"text":"104 Stat. 3945","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
