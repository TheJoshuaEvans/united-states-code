{"tag":"section","attrib":{"id":"idee3af2d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s499s"},"text":null,"children":[{"tag":"num","attrib":{"value":"499s"},"text":"§ 499s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Depositing appropriations in fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any unexpended balances of appropriations for the current fiscal year, and any subsequent appropriations, made to carry out the Acts referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s499c/b"},"text":"section 499c(b) of this title","children":[],"tail":", may be deposited in the Perishable Agricultural Commodities Act fund."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee3af2d7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-10/ch436/s19"},"text":"June 10, 1930, ch. 436, § 19","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1950-06-15/ch254/s4"},"text":"June 15, 1950, ch. 254, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/218"},"text":"64 Stat. 218","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee3af2d8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee3af2d9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idee3af2da-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Acts referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s499c/b"},"text":"section 499c(b) of this title","children":[],"tail":", referred to in text, mean the Perishable Agricultural Commodities Act, 1930, which was translated to read “this chapter” and the Act to prevent the destruction or dumping of farm produce, "},{"tag":"ref","attrib":{"href":"/us/act/1927-03-03/ch309"},"text":"act Mar. 3, 1927, ch. 309","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1355"},"text":"44 Stat. 1355","children":[],"tail":", which is classified to chapter 20 (§ 491 et seq.) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
