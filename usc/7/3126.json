{"tag":"section","attrib":{"id":"idef9726b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3126"},"text":null,"children":[{"tag":"num","attrib":{"value":"3126"},"text":"§ 3126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Libraries and information network","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9726b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3126/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is declared to be the policy of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9726b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3126/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperation and coordination among, and the more effective utilization of, dispar­ate agricultural libraries and information units be facilitated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9726b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3126/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information and library needs related to agricultural research and education be effectively planned for, coordinated, and evaluated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9726ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3126/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a structure for the coordination of the agricultural libraries of colleges and universities, Department of Agriculture libraries, and their closely allied information gathering and disseminating units be established in close conjunction with private industry and other research libraries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9726bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3126/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective access by all colleges and universities and Department of Agriculture personnel to literature and information regarding the food and agricultural sciences be provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9726bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3126/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs for training in information utilization with respect to the food and agricultural sciences, including research grants for librarians, information scientists, and agricultural scientists be established or strengthened; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9726bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3126/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Agriculture establish mutually valuable working relationships with international and foreign information and data programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9726be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3126/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food and Nutrition and Education Resources Center","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established within the National Agricultural Library of the Department of Agriculture a Food and Nutrition Information and Education Resources Center. Such Center shall be responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9726bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3126/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assembling and collecting food and nutrition education materials, including the results of nutrition research, training methods, procedures, and other materials related to the purpose of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9726c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3126/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining such information and materials in a library; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9726c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3126/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing notification about these collections on a regular basis to the State cooperative extension services, State educational agencies, and other interested persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9726c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3126/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds are authorized to be appropriated annually in such amounts as Congress may determine necessary to support the purposes of this section. The Secretary is authorized to carry out this section with existing facilities through the use of grants, contracts, or such other means as the Secretary deems appropriate and to require matching of funds. No funds appropriated to support the purposes of this section shall be used to purchase additional equipment unless specifically authorized by law subsequent to ","children":[{"tag":"date","attrib":{"date":"1977-09-29"},"text":"September 29, 1977","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9726c3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1411"},"text":"Pub. L. 95–113, title XIV, § 1411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/990"},"text":"91 Stat. 990","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXIV/s1412"},"text":"Pub. L. 97–98, title XIV, § 1412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1302"},"text":"95 Stat. 1302","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9726c4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef9726c5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef9726c6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of “this chapter”, referred to in subsec. (b)(1), see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3102"},"text":"section 3102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef9726c7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1412/1"},"text":"Pub. L. 97–98, § 1412(1)","children":[],"tail":"–(3), added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1412/4"},"text":"Pub. L. 97–98, § 1412(4)","children":[],"tail":", substituted “notification about these collections on a regular basis to the State cooperative extension services, State educational agencies, and other interested persons” for “for the dissemination of such information and materials on a regular basis to State educational agencies and other interested persons”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef9726c8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef9726c9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98"},"text":"Pub. L. 97–98","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1801"},"text":"section 1801 of Pub. L. 97–98","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idef9726ca-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/s1901"},"text":"section 1901 of Pub. L. 95–113","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1307"},"text":"section 1307 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
