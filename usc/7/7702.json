{"tag":"section","attrib":{"id":"idf01a39c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702"},"text":null,"children":[{"tag":"num","attrib":{"value":"7702"},"text":"§ 7702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01a39c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Article","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “article” means any material or tangible object that could harbor plant pests or noxious weeds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a39c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biological control organism","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “biological control organism” means any enemy, antagonist, or competitor used to control a plant pest or noxious weed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a39c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enter and entry","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “enter” and “entry” mean to move into, or the act of movement into, the commerce of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a39c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export and exportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “export” and “exportation” mean to move from, or the act of movement from, the United States to any place outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a39c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Import and importation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “import” and “importation” mean to move into, or the act of movement into, the territorial limits of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a39c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interstate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “interstate” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01a39c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from one State into or through any other State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a39c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the District of Columbia, Guam, the Virgin Islands of the United States, or any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a39ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interstate commerce","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “interstate commerce” means trade, traffic, or other commerce—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01a39cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between a place in a State and a point in another State, or between points within the same State but through any place outside that State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a39cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the District of Columbia, Guam, the Virgin Islands of the United States, or any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a39cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Means of conveyance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “means of conveyance” means any personal property used for or intended for use for the movement of any other personal property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a39ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Move and related terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The terms “move”, “moving”, and “movement” mean—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01a39cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry, enter, import, mail, ship, or transport;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a39d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to aid, abet, cause, or induce the carrying, entering, importing, mailing, shipping, or transporting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a39d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to offer to carry, enter, import, mail, ship, or transport;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a39d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive to carry, enter, import, mail, ship, or transport;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a39d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/9/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to release into the environment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a39d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/9/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to allow any of the activities described in a preceding subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a39d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noxious weed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “noxious weed” means any plant or plant product that can directly or indirectly injure or cause damage to crops (including nursery stock or plant products), livestock, poultry, or other interests of agriculture, irrigation, navigation, the natural resources of the United States, the public health, or the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a39d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “permit” means a written or oral authorization, including by electronic methods, by the Secretary to move plants, plant products, biological control organisms, plant pests, noxious weeds, or articles under conditions prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a39d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means any individual, partnership, corporation, association, joint venture, or other legal entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a39d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “plant” means any plant (including any plant part) for or capable of propagation, including a tree, a tissue culture, a plantlet culture, pollen, a shrub, a vine, a cutting, a graft, a scion, a bud, a bulb, a root, and a seed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a39d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plant pest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “plant pest” means any living stage of any of the following that can directly or indirectly injure, cause damage to, or cause disease in any plant or plant product:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01a39da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A protozoan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a39db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nonhuman animal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a39dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/14/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A parasitic plant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a39dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/14/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A bacterium.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a39de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/14/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A fungus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a39df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/14/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A virus or viroid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a39e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/14/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An infectious agent or other pathogen.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a39e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/14/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any article similar to or allied with any of the articles specified in the preceding subparagraphs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a39e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plant product","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “plant product” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01a39e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any flower, fruit, vegetable, root, bulb, seed, or other plant part that is not included in the definition of plant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a39e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any manufactured or processed plant or plant part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a39e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a39e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means any of the several States of the United States, the Commonwealth of the Northern Mariana Islands, the Commonwealth of Puerto Rico, the District of Columbia, Guam, the Virgin Islands of the United States, or any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a39e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Systems approach","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7712/e"},"text":"section 7712(e) of this title","children":[],"tail":", the term “systems approach” means a defined set of phytosanitary procedures, at least two of which have an independent effect in mitigating pest risk associated with the movement of commodities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a39e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" This chapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except when used in this section, the term “this chapter” includes any regulation or order issued by the Secretary under the authority of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a39e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7702/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” means all of the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf01a39ea-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/tIV/s403"},"text":"Pub. L. 106–224, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/438"},"text":"114 Stat. 438","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf01a39eb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf01a39ec-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf01a39ed-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224"},"text":"Pub. L. 106–224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/438"},"text":"114 Stat. 438","children":[],"tail":", known as the Plant Protection Act, which is classified principally to this chapter. For complete classification of title IV to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7701"},"text":"section 7701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
