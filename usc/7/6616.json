{"tag":"section","attrib":{"id":"idefea9e1e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6616"},"text":null,"children":[{"tag":"num","attrib":{"value":"6616"},"text":"§ 6616.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans to economically disadvantaged rural communities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefea9e1f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6616/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, under such terms and conditions as the Secretary shall establish, may make loans to economically disadvantaged rural communities for the purposes of securing technical assistance and services to aid in the development and implementation of action plans, including planning for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefea9e20-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6616/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving existing facilities in the community that may generate employment or revenue;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e21-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6616/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanding existing infrastructure, facilities, and services to capitalize on opportunities to diversify economies now dependent on National Forest System land resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e22-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6616/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the development of new industries or commercial ventures unrelated to National Forest System land resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefea9e23-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6616/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest rates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interest rates on a loan made pursuant to this section shall be as determined by the Secretary, but not in excess of the current average market yield on outstanding marketable obligations of the United States with remaining periods to maturity comparable to the maturity of such loan, plus not to exceed 1 percent, as determined by the Secretary, and rounded to the nearest one-eighth of 1 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefea9e24-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2378"},"text":"Pub. L. 101–624, title XXIII, § 2378","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4048"},"text":"104 Stat. 4048","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/3/tIII/s345/f"},"text":"Pub. L. 106–113, div. B, § 1000(a)(3) [title III, § 345(f)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–204.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefea9e25-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefea9e26-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefea9e27-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" substituted “National Forest System land resources” for “national forest resources”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
