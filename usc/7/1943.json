{"tag":"section","attrib":{"id":"idef117c86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943"},"text":null,"children":[{"tag":"num","attrib":{"value":"1943"},"text":"§ 1943.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on amount of operating loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef117c87-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make or insure no loan under this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef117c88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that would cause the total principal indebtedness outstanding at any one time for loans made under this subchapter to any one borrower to exceed, in the case of a loan other than a loan guaranteed by the Secretary, $400,000, or, in the case of a loan guaranteed by the Secretary, $1,750,000 (increased, beginning with fiscal year 2019, by the inflation percentage applicable to the fiscal year in which the loan is guaranteed and reduced by the unpaid indebtedness of the borrower on loans under the sections specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1925"},"text":"section 1925 of this title","children":[],"tail":" that are guaranteed by the Secretary); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef117c89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purchasing or leasing of land other than for cash rent, or for carrying on any land leasing or land purchasing program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef117c8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation percentage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the inflation percentage applicable to a fiscal year is the percentage (if any) by which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef117c8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average of the Prices Paid By Farmers Index (as compiled by the National Agricultural Statistics Service of the Department of Agriculture) for the 12-month period ending on July 31 of the immediately preceding fiscal year; exceeds","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef117c8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average of such index (as so defined) for the 12-month period that immediately precedes the 12-month period described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef117c8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Microloans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef117c8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary may establish a program to make or guarantee microloans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef117c8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not make or guarantee a microloan under this subsection that would cause the total principal indebtedness outstanding at any 1 time for microloans made under this subsection to any 1 borrower to exceed $50,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef117c90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the Secretary shall limit the administrative burdens and streamline the application and approval process for microloans under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef117c91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative lending pilot projects","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef117c92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B), during each of the 2014 through 2023 fiscal years, the Secretary may carry out a pilot project to make loans to community development financial institutions, as the Secretary determines appropriate—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef117c93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make or guarantee microloans consistent with the terms provided under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef117c94-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide business, financial, marketing, and credit management services to microloan borrowers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef117c95-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Prior to making a loan to an institution described in subparagraph (A), the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef117c96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" review and approve—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef117c97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/c/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan loss reserve fund for microloans established by the institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef117c98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/c/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the underwriting standards for microloans of the institution; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef117c99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish such other requirements for making a loan to the institution as the Secretary determines necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef117c9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a loan under subparagraph (A), an institution described in subparagraph (A) shall, as determined by the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef117c9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/c/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the legal authority necessary to carry out the actions described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef117c9c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/c/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a proven track record of successfully assisting agricultural borrowers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef117c9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/c/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the services of a staff with appropriate loan making and servicing expertise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef117c9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less often than annually, on a date determined by the Secretary, an institution that has a loan under this paragraph shall provide to the Secretary such information as the Secretary may require to ensure that the services provided by the institution are serving the purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef117c9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1943/c/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not make more than $10,000,000 in loans under this paragraph in any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef117ca0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s313"},"text":"Pub. L. 87–128, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/310"},"text":"75 Stat. 310","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/488/s9"},"text":"Pub. L. 90–488, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-15"},"text":"Aug. 15, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/771"},"text":"82 Stat. 771","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/419/tI/s122"},"text":"Pub. L. 92–419, title I, § 122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-08-30"},"text":"Aug. 30, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/665"},"text":"86 Stat. 665","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/334/tI/s116"},"text":"Pub. L. 95–334, title I, § 116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-04"},"text":"Aug. 4, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/426"},"text":"92 Stat. 426","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/258/tVI/s604/a"},"text":"Pub. L. 98–258, title VI, § 604(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-04-10"},"text":"Apr. 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/139"},"text":"98 Stat. 139","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/a/tVIII/s806/b"},"text":"Pub. L. 105–277, div. A, § 101(a) [title VIII, § 806(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681"},"text":"112 Stat. 2681","children":[],"tail":", 2681–39; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tV/s5102"},"text":"Pub. L. 110–234, title V, § 5102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1146"},"text":"122 Stat. 1146","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title V, § 5102, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1908; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tV/s5106/a"},"text":"Pub. L. 113–79, title V, § 5106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/837"},"text":"128 Stat. 837","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV"},"text":"Pub. L. 115–334, title V","children":[],"tail":", §§ 5201–5203, "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4671"},"text":"132 Stat. 4671","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef117ca1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef117ca2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef117ca3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The authorities provided by each provision of, and each amendment made by, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"Sept. 30, 2023","children":[],"tail":", to continue, and authorities to be carried out, until the later of "},{"tag":"date","attrib":{"date":"2024-09-30"},"text":"Sept. 30, 2024","children":[],"tail":", or the date specified in the provision of, or amendment made by, "},{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/a"},"text":"section 102(a) of Pub. L. 118–22","children":[],"tail":", set out in an Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef117ca4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5201/1"},"text":"Pub. L. 115–334, § 5201(1)","children":[],"tail":", substituted “$400,000” for “$300,000”, “$1,750,000” for “$700,000”, and “2019” for “2000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5201/2/A"},"text":"Pub. L. 115–334, § 5201(2)(A)","children":[],"tail":", substituted “July” for “August”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5201/2/B"},"text":"Pub. L. 115–334, § 5201(2)(B)","children":[],"tail":", substituted “that immediately precedes the 12-month period described in paragraph (1)” for “ending on "},{"tag":"date","attrib":{"date":"1996-08-31"},"text":"August 31, 1996","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5202"},"text":"Pub. L. 115–334, § 5202","children":[],"tail":", substituted “subsection to any 1 borrower” for “chapter to any 1 borrower”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5203"},"text":"Pub. L. 115–334, § 5203","children":[],"tail":", substituted “2023” for “2018” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s5102"},"text":"Pub. L. 110–246, § 5102","children":[],"tail":", substituted “$300,000” for “$200,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" inserted section catchline, designated existing provisions as subsec. (a), inserted heading, substituted “this subchapter—” for “this subchapter”, in introductory provisions, realigned margin of par. (1) and substituted “$700,000 (increased, beginning with fiscal year 2000, by the inflation percentage applicable to the fiscal year in which the loan is guaranteed and reduced by the unpaid indebtedness of the borrower on loans under the sections specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1925"},"text":"section 1925 of this title","children":[],"tail":" that are guaranteed by the Secretary); or” for “$400,000; or”, realigned margin of par. (2), and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/258"},"text":"Pub. L. 98–258","children":[],"tail":" substituted “$200,000” and “$400,000” for “$100,000” and “$200,000”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/334"},"text":"Pub. L. 95–334","children":[],"tail":" substituted provisions setting forth criteria for Secretary to make or insure loans under this subchapter for provisions setting forth criteria for Secretary to make loans under this subchapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/419"},"text":"Pub. L. 92–419","children":[],"tail":" substituted “$50,000” for “$35,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/488"},"text":"Pub. L. 90–488","children":[],"tail":" struck out from item (1) the proviso which limited the amount to be used for loans which would cause the indebtedness of any borrower to exceed $15,000 to 25 per centum of the sums made available for loans."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef117ca5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef117ca6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
