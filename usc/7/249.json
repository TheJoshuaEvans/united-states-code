{"tag":"section","attrib":{"id":"idee2324cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s249"},"text":null,"children":[{"tag":"num","attrib":{"value":"249"},"text":"§ 249.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of stored agricultural products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee2324cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s249/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with regulations promulgated under this chapter, a warehouse operator may transfer a stored agricultural product from one warehouse to another warehouse for continued storage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee2324cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s249/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued duty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The warehouse operator from which agricultural products have been transferred under subsection (a) shall deliver to the rightful owner of such products, on request at the original warehouse, such products in the quantity and of the kind, quality, and grade called for by the receipt or other evidence of storage of the owner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee2324ce-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, § 10, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/472/tII/s201"},"text":"Pub. L. 106–472, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2065"},"text":"114 Stat. 2065","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee2324cf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee2324d0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee2324d1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 249, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"act Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, § 7, "},{"tag":"ref","attrib":{"href":"/us/stat/39/487"},"text":"39 Stat. 487","children":[],"tail":", entitled injured persons to bring actions on bonds, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/472"},"text":"Pub. L. 106–472","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s245"},"text":"section 245 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 10 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"act Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s251"},"text":"section 251 of this title","children":[],"tail":", prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/472"},"text":"Pub. L. 106–472","children":[],"tail":"."}],"tail":"\n"}],"ta