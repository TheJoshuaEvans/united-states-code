{"tag":"section","attrib":{"id":"ideff414aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6943"},"text":null,"children":[{"tag":"num","attrib":{"value":"6943"},"text":"§ 6943.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural Housing and Community Development Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff414ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6943/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary is authorized to establish and maintain within the Department the Rural Housing and Community Development Service and to assign to the Service such functions as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff414ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6943/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary establishes the Rural Housing and Community Development Service under subsection (a), the Secretary is authorized to assign to the Service jurisdiction over the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff414ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6943/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Programs and activities under title V of the Housing Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1471"},"text":"42 U.S.C. 1471","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff414ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6943/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Programs and activities that relate to rural community lending programs, including programs authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2008d"},"text":"section 2008d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff414af-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s233"},"text":"Pub. L. 103–354, title II, § 233","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3219"},"text":"108 Stat. 3219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII"},"text":"Pub. L. 104–127, title VII","children":[],"tail":", §§ 747(b)(3), 753(b)(2), "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1128"},"text":"110 Stat. 1128","children":[],"tail":", 1131.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideff414b0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideff414b1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideff414b2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Housing Act of 1949, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-07-15/ch338"},"text":"act July 15, 1949, ch. 338","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/413"},"text":"63 Stat. 413","children":[],"tail":". Title V of the Act is classified generally to subchapter III (§ 1471 et seq.) of chapter 8A of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1441"},"text":"section 1441 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideff414b3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" redesignated par. (3) as (2), substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2008d"},"text":"section 2008d of this title","children":[],"tail":"” for “sections 2008 through 2008d of this title”, and struck out former par. (2) which read as follows: “Programs and activities authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1932/i"},"text":"section 1932(i) of this title","children":[],"tail":" and related provisions of law.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
