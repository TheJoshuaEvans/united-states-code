{"tag":"section","attrib":{"id":"idefa5589a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3292b"},"text":"§ 3292b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants for international agricultural science and education programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa5589b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make competitive grants to colleges and universities in order to strengthen United States economic competitiveness and to promote international market development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa5589c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants under this section shall be directed to agricultural research, extension, and teaching activities that will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa5589d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the international content of the curricula in colleges and universities so as to ensure that United States students acquire an understanding of the international dimensions and trade implications of their studies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa5589e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that United States scientists, extension agents, and educators involved in agricultural research and development activities outside of the United States have the opportunity to convey the implications of their activities and findings to their peers and students in the United States and to the users of agricultural research, extension, and teaching;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa5589f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the capabilities of colleges and universities to do collaborative research with other countries, in cooperation with other Federal agencies, on issues relevant to United States agricultural competitiveness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa558a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the capabilities of colleges and universities to provide cooperative extension education to promote the application of new technology developed in foreign countries to United States agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa558a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the capability of United States colleges and universities, in cooperation with other Federal agencies, to provide leadership and educational programs that will assist United States natural resources and food production, processing, and distribution businesses and industries to compete internationally, including product market identification, international policies limiting or enhancing market production, development of new or enhancement of existing markets, and production efficiencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa558a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa558a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for each of fiscal years 1999 through 2013; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa558a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa558a5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1459A"},"text":"Pub. L. 95–113, title XIV, § 1459A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tII/s229"},"text":"Pub. L. 105–185, title II, § 229","children":[],"tail":", "},{"tag":"da