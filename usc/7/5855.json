{"tag":"section","attrib":{"id":"idefd0603d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5855"},"text":null,"children":[{"tag":"num","attrib":{"value":"5855"},"text":"§ 5855.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefd0603e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5855/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd0603f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5855/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative work","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 15 percent and not more than 25 percent of the funds appropriated for a fiscal year to carry out this subchapter shall be used for cooperative work with the National Weather Service entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5852/b/1"},"text":"section 5852(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd06040-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5855/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 15 percent and not more than 25 percent of such funds shall be used by the National Institute of Food and Agriculture for a competitive grants program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5852/c"},"text":"section 5852(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd06041-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5855/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Weather information systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 25 percent and not more than 35 percent of such funds shall be divided equally between the participating States selected for that fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5854"},"text":"section 5854 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd06042-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5855/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The remaining funds shall be allocated for use by the Agricultural Weather Office and the National Institute of Food and Agriculture in carrying out generally the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd06043-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5855/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided under the authority of this subchapter shall not be used for the construction of facilities. Each State or agency receiving funds shall not use more than 30 percent of such funds for equipment purchases. Any use of the funds in facilitating the distribution of agricultural and climate information to producers shall be done with consideration for the role that the private meteorological sector can play in such information delivery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd06044-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5855/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this subchapter $5,000,000 for each of the fiscal years 2008 through 2012 and $1,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefd06045-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1641"},"text":"Pub. L. 101–624, title XVI, § 1641","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3750"},"text":"104 Stat. 3750","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s833"},"text":"Pub. L. 104–127, title VIII, § 833","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1168"},"text":"110 Stat. 1168","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII"},"text":"Pub. L. 110–234, title VII","children":[],"tail":", §§ 7202, 7511(c)(20), "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/u