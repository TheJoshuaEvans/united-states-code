{"tag":"section","attrib":{"id":"idef2bbb33-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009aa–5"},"text":"§ 2009aa–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distressed counties and areas and nondistressed counties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef2bbb34-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2000-12-21"},"text":"December 21, 2000","children":[],"tail":", and annually thereafter, the Authority, in accordance with such criteria as the Authority may establish, shall designate—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2bbb35-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as distressed counties, counties in the region that are the most severely and persistently distressed and underdeveloped and have high rates of poverty or unemployment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2bbb36-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as nondistressed counties, counties in the region that are not designated as distressed counties under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2bbb37-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–5/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as isolated areas of distress, areas located in nondistressed counties (as designated under paragraph (2)) that have high rates of poverty or unemployment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2bbb38-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distressed counties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2bbb39-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority shall allocate at least 75 percent of the appropriations made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009aa–12"},"text":"section 2009aa–12 of this title","children":[],"tail":" for programs and projects designed to serve the needs of distressed counties and isolated areas of distress in the region."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2bbb3a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The funding limitations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009aa–3/b"},"text":"section 2009aa–3(b) of this title","children":[],"tail":" shall not apply to a project providing transportation or basic public services to residents of one or more distressed counties or isolated areas of distress in the region."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2bbb3b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondistressed counties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2bbb3c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–5/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in this subsection, no funds shall be provided under this subchapter for a project located in a county designated as a nondistressed county under subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2bbb3d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–5/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2bbb3e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–5/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The funding prohibition under paragraph (1) shall not apply to grants to fund the administrative expenses of local development districts under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009aa–4/b"},"text":"section 2009aa–4(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2bbb3f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–5/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multicounty projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Authority may waive the application of the funding prohibition under paragraph (1) to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef2bbb40-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–5/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a multicounty project that includes participation by a nondistressed county; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2bbb41-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–5/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other type of project;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"if the Authority determines that the project could bring significant benefits to areas of the region outside a nondistressed county.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2bbb42-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–5/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Isolated areas of distress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For a designation of an isolated area of distress for assistance to be effective, the designation shall be supported—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef2bbb43-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–5/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the most recent Federal data available; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2bbb44-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–5/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if no recent Federal data are available, by the most recent data available through the government of the State in which the isolated area of distress is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2bbb45-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation and basic public infrastructure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority shall allocate at least 50 percent of any funds made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009aa–12"},"text":"section 2009aa–12 of this title","children":[],"tail":" for transportation and basic public infrastructure projects authorized under paragraphs (1) and (3) of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009aa–2/a"},"text":"section 2009aa–2(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef2bbb46-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s382F"},"text":"Pub. L. 87–128, title III, § 382F","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tV/s503"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title V, § 503]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–277.)"}],"tail":"\n"}],"tail":null}
