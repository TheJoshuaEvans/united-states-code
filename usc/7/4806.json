{"tag":"section","attrib":{"id":"idefbf964e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806"},"text":null,"children":[{"tag":"num","attrib":{"value":"4806"},"text":"§ 4806.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Pork Producers Delegate Body","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefbf964f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide for the establishment and appointment by the Secretary, not later than 60 days after the effective date of such order, of a National Pork Producers Delegate Body.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf9650-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership; number of producer members; number of importer members","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf9651-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Delegate Body shall consist of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf9652-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" producers, as appointed by the Secretary in accordance with paragraph (2), from nominees submitted as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefbf9653-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the initial Delegate Body appointed by each State in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4807"},"text":"section 4807 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefbf9654-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of each succeeding Delegate Body, each State association shall submit nominations selected by such association pursuant to a selection process that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idefbf9655-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is approved by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idefbf9656-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires public notice of the process to be given at least one week in advance by publication in a newspaper or newspaper of general circulation in such State and in pork production and agriculture trade publications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idefbf9657-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/1/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that provides complete and equal access to the nominating process to every producer who has paid all assessments due under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4809"},"text":"section 4809 of this title","children":[],"tail":" and not demanded a refund under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4813"},"text":"section 4813 of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"or pursuant to an election of nominees conducted in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4807"},"text":"section 4807 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefbf9658-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a State that has a State association that does not submit nominations or that does not have a State association, such State shall submit nominations in a manner prescribed by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf9659-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" importers, as appointed by the Secretary in accordance with paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf965a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The number of producer members appointed to the Delegate Body from each State shall equal at least two members, and additional members, allocated as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf965b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Shares shall be assigned to each State—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefbf965c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the 1986 calendar year, on the basis of one share for each $400,000 of farm market value of porcine animals marketed from such State (as determined by the Secretary based on the annual average of farm market value in the most recent 3 calendar years preceding such year), rounded to the nearest $400,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefbf965d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each calendar year thereafter, on the basis of one share for each $1,000 of the aggregate amount of assessments collected (minus refunds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4813"},"text":"section 4813 of this title","children":[],"tail":") in such State from persons described in section 4809(a)(1)(A) and (B) of this title, rounded to the nearest $1,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf965e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If during a calendar year the number of such shares of a State is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefbf965f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than 301, the State shall receive a total of two producer members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefbf9660-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 300 but less than 601, the State shall receive a total of three producer members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefbf9661-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 600 but less than 1,001, the State shall receive a total of four producer members; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefbf9662-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 1,000, the State shall receive four producer members, plus one additional member for each 300 additional shares in excess of 1,000 shares, rounded to the nearest 300.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9663-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The number of importer members appointed to the Delegate Body shall be determined as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf9664-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Shares shall be assigned to importers—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefbf9665-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the 1986 calendar year, on the basis of one share for each $575,000 of market value of marketed porcine animals, pork, or pork products (as determined by the Secretary based on the annual average of imports in the most recent 3 calendar years preceding such year), rounded to the nearest $575,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefbf9666-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each calendar year thereafter, on the basis of one share for each $1,000 of the aggregate amount of assessments collected (minus refunds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4813"},"text":"section 4813 of this title","children":[],"tail":") from importers, rounded to the nearest $1,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf9667-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The number of importer members appointed to the Delegate Body shall equal a total of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefbf9668-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three members for the first 1,000 such shares; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefbf9669-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one additional member for each 300 additional shares in excess of 1,000 shares, rounded to the nearest 300.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf966a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting; quorum; votes necessary for decision","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf966b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A producer member of the Delegate Body may, in a vote conducted by the Delegate Body for which the member is present, cast a number of votes equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf966c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of shares attributable to the State of the member; divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf966d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of producer members from such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf966e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An importer member of the Delegate Body may, in a vote conducted by the Delegate Body for which the member is present, cast a number of votes equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf966f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of shares allocated to importers; divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf9670-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of importer members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9671-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members entitled to cast a majority of the votes (including fractions thereof) on the Delegate Body shall constitute a quorum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9672-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A majority of the votes (including fractions thereof) cast at a meeting at which a quorum is present shall be decisive of a motion or election presented to the Delegate Body for a vote.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf9673-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Delegate Body shall serve for a term of 1 year, except that the term of a member of the Delegate Body shall continue until the successor of such member, if any, is appointed in accordance with subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf9674-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf9675-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the first annual meeting, the Delegate Body shall select a Chairman by a majority vote.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9676-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At each annual meeting thereafter, the President of the Board shall serve as the Chairman of the Delegate Body.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf9677-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Delegate Body shall serve without compensation, but may be reimbursed by the Board from assessments collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4809"},"text":"section 4809 of this title","children":[],"tail":" for transportation expenses incurred in performing duties as a member of the Delegate Body."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf9678-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nomination of members to National Pork Board; annual meeting; majority vote in person to nominate","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf9679-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Delegate Body shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf967a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" nominate—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefbf967b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/g/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 23 persons for appointment to the Board, for the first year for which nominations are made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefbf967c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/g/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 1½ persons (rounded up to the nearest person) for each vacancy in the Board that requires nominations thereafter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf967d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit such nominations to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf967e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Delegate Body shall meet annually to make such nominations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf967f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A majority of the Delegate Body shall vote in person in order to nominate members to the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf9680-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Delegate Body shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf9681-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend the rate of assessment prescribed by the initial order and any increase in such rate pursuant to section 4809(5) ","children":[{"tag":"ref","attrib":{"idref":"fn002291"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002291"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be section “4809(b)”."}],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9682-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4806/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the percentage of the aggregate amount of assessments collected in a State that each State association shall receive under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4809/c/1"},"text":"section 4809(c)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefbf9683-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1617"},"text":"Pub. L. 99–198, title XVI, § 1617","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1609"},"text":"99 Stat. 1609","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefbf9684-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefbf9685-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefbf9686-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1986-01-01"},"text":"Jan. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1631"},"text":"section 1631 of Pub. L. 99–198","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4801"},"text":"section 4801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
