{"tag":"section","attrib":{"id":"idef18a896-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1983d"},"text":"§ 1983d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farmer loan pilot projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef18a897-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may conduct pilot projects of limited scope and duration that are consistent with subchapter I through this subchapter to evaluate processes and techniques that may improve the efficiency and effectiveness of the programs carried out under subchapter I through this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef18a898-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef18a899-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 60 days before the date on which the Secretary initiates a pilot project under subsection (a), submit notice of the proposed pilot project to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef18a89a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider any recommendations or feedback provided to the Secretary in response to the notice provided under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef18a89b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s333D"},"text":"Pub. L. 87–128, title III, § 333D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tV/s5302"},"text":"Pub. L. 113–79, title V, § 5302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/839"},"text":"128 Stat. 839","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
