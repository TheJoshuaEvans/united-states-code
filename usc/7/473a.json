{"tag":"section","attrib":{"id":"idee3156a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s473a"},"text":null,"children":[{"tag":"num","attrib":{"value":"473a"},"text":"§ 473a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cotton classification services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee3156a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s473a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture (referred to in this section as the “Secretary”) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee3156a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s473a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make cotton classification services available to producers of cotton; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3156aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s473a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the collection of classification fees from participating producers or agents that voluntarily agree to collect and remit the fees on behalf of producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee3156ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s473a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee3156ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s473a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Classification fees collected under subsection (a)(2) and the proceeds from the sales of samples submitted under this section shall, to the maximum extent practicable, be used to pay the cost of the services provided under this section, including administrative and supervisory costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3156ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s473a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Announcement of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall announce a uniform classification fee and any applicable surcharge for classification services not later than June 1 of the year in which the fee applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee3156ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s473a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee3156af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s473a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing the amount of fees under this section, the Secretary shall consult with representatives of the United States cotton industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3156b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s473a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply to consultations with representatives of the United States cotton industry under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee3156b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s473a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crediting of fees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any fees collected under this section and under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s473d"},"text":"section 473d of this title","children":[],"tail":", late payment penalties, the proceeds from the sales of samples, and interest earned from the investment of such funds shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idee3156b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s473a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be credited to the current appropriation account that incurs the cost of services provided under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s473d"},"text":"section 473d of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3156b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s473a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain available without fiscal year limitation to pay the expenses of the Secretary in providing those services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee3156b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s473a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds described in subsection (d) may be invested—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee3156b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s473a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Secretary in insured or fully collateralized, interest-bearing accounts; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3156b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s473a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the discretion of the Secretary, by the Secretary of the Treasury in United States Government debt instruments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee3156b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s473a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary may enter into long-term lease agreements that exceed 5 years or may take title to property (including through purchase agreements) for the purpose of obtaining offices to be used for the classification of cotton in accordance with this chapter, if the Secretary determines that action would best effectuate the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee3156b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s473a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that financing is not available from fees and the proceeds from the sales of samples, there are authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee3156b9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-03/ch337/s3a"},"text":"Mar. 3, 1927, ch. 337, § 3a","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1937-04-13/ch75"},"text":"Apr. 13, 1937, ch. 75","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/62"},"text":"50 Stat. 62","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tI/s156/b"},"text":"Pub. L. 97–35, title I, § 156(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/373"},"text":"95 Stat. 373","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/403/s1"},"text":"Pub. L. 98–403, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-28"},"text":"Aug. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1479"},"text":"98 Stat. 1479","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/108/s2"},"text":"Pub. L. 100–108, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-20"},"text":"Aug. 20, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/728"},"text":"101 Stat. 728","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tI/s120/a"},"text":"Pub. L. 102–237, title I, § 120(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1842"},"text":"105 Stat. 1842","children":[],"tail":", 1843; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIX/s912/a"},"text":"Pub. L. 104–127, title IX, § 912(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1185"},"text":"110 Stat. 1185","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10801/a"},"text":"Pub. L. 107–171, title X, § 10801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/525"},"text":"116 Stat. 525","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14201"},"text":"Pub. L. 110–234, title XIV, § 14201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1457"},"text":"122 Stat. 1457","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14201, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2219; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/23"},"text":"Pub. L. 117–286, § 4(a)(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4307"},"text":"136 Stat. 4307","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee3156ba-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee3156bb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee3156bc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee3156bd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s14201"},"text":"Pub. L. 110–246, § 14201","children":[],"tail":", inserted section catchline and amended text generally, substituting provisions consisting of subsecs. (a) to (g) for former undesignated provisions which related to cotton classification services in fiscal years 1992 through 2007."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" substituted “2007” for “2002” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" substituted “2002” for “1996” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s120/c"},"text":"Pub. L. 102–237, § 120(c)","children":[],"tail":", amended third sentence generally. Prior to amendment, third sentence read as follows: “Special classification services provided at the request of the producer shall not be subject to the restrictions specified in clauses (1), (2), and (3) of the preceding sentence.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s120/b/2"},"text":"Pub. L. 102–237, § 120(b)(2)","children":[],"tail":", added cl. (7) and struck out former cl. (7). Text read as follows: “the Secretary shall announce the uniform classification fee and any surcharge for the crop not later than June 1 of the year in which the fee applies, except that for fiscal year 1987, such announcement shall be made as soon as practicable following enactment of this proviso.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s120/b/1"},"text":"Pub. L. 102–237, § 120(b)(1)","children":[],"tail":", added cls. (1) and (2) and struck out former cls. (1) and (2). Text read as follows: “(1) the uniform per bale classification fee to be collected from producers, or their agents, for such classification service in any year shall be the uniform fee collected in the previous year, exclusive of adjustments to such fee made in the previous year under clauses (2), (3), and (4) of this proviso, and as may be adjusted by the percentage change in the Implicit Price Deflator for Gross National Product as indexed during the most recent twelve-month period for which statistics are available; (2) the fee calculated in accordance with clause (1) for a crop year may be increased by an amount not to exceed 1 per centum for every 100,000 running bales, or portion thereof, that the Secretary estimates will be produced in such crop year below the level of 12,500,000 running bales, or decreased by an amount not to exceed 1 per centum for every 100,000 running bales, or portion thereof, that the Secretary estimates will be produced in such crop year above the level of 12,500,000 running bales;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s120/a"},"text":"Pub. L. 102–237, § 120(a)","children":[],"tail":", amended first sentence generally. Prior to amendment, first sentence read as follows: “Effective for the fiscal years ending "},{"tag":"date","attrib":{"date":"1987-09-30"},"text":"September 30, 1987","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-30"},"text":"September 30, 1988","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-09-30"},"text":"September 30, 1989","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-09-30"},"text":"September 30, 1991","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"September 30, 1992","children":[],"tail":", the Secretary of Agriculture shall make cotton classification services available to producers of cotton and shall provide for the collection of classification fees from participating producers, or agents who voluntarily agree to collect and remit the fees on behalf of producers.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/108"},"text":"Pub. L. 100–108","children":[],"tail":" amended first sentence generally, substituting “"},{"tag":"date","attrib":{"date":"1987-09-30"},"text":"September 30, 1987","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-30"},"text":"September 30, 1988","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-09-30"},"text":"September 30, 1989","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-09-30"},"text":"September 30, 1991","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"September 30, 1992","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1985-09-30"},"text":"September 30, 1985","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"September 30, 1986","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-09-30"},"text":"September 30, 1987","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1988-09-30"},"text":"September 30, 1988","children":[],"tail":"” and striking out “from” before “agents who voluntarily agree”, in second sentence inserted first proviso and struck out former first proviso which read as follows: “That (1) the uniform per bale classification fee to be collected from producers, or their agents, for such classification service in any year shall not exceed the uniform fee collected in the previous year by more than the percentage increase in the Implicit Price Deflator for Gross National Product as indexed during the most recent twelve-month period for which official statistics are available, and (2) the uniform per bale classification fee shall not be increased for any year if the accumulated reserve exceeds 20 per centum of the cost of the classification program in the previous year”, and in third sentence substituted “clauses (1), (2), and (3)” for “clauses (1) and (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/403"},"text":"Pub. L. 98–403","children":[],"tail":" substituted provisions requiring the Secretary to make classification service available to producers and to set and collect fees for provisions establishing similar requirements effective for fiscal years ending "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"Sept. 30, 1982","children":[],"tail":", 1983, and 1984."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" substituted provisions effective for fiscal years ending "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"Sept. 30, 1982","children":[],"tail":", 1983, and 1984, requiring the Secretary to make classification services available to producers, and to set and collect fees, for provisions authorizing the Secretary to determine and make available classification procedures."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee33c6be-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee33c6bf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L