{"tag":"section","attrib":{"id":"idef7a782a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2268a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2268a"},"text":"§ 2268a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of land; options","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef7a782b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2268a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Agriculture is authorized to acquire land, or interest therein, by purchase, exchange or otherwise, as may be necessary to carry out its authorized work: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That no acquisition shall be made under this authority unless provision is made therefor in the applicable appropriation or other law."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7a782c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2268a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriations for the Department of Agriculture which are available for the purchase of land may be expended for options to purchase land: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That not to exceed $1 may be expended for each option to purchase any particular tract or tracts of land unless otherwise provided in appropriation or other law."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7a782d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-03/ch950/s11"},"text":"Aug. 3, 1956, ch. 950, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1034"},"text":"70 Stat. 1034","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7a782e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef7a782f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef7a7830-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s428a"},"text":"section 428a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
