{"tag":"section","attrib":{"id":"idefdc46d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6102"},"text":null,"children":[{"tag":"num","attrib":{"value":"6102"},"text":"§ 6102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefdc46d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commerce","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “commerce” means interstate, foreign, or intrastate commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “consumer information” means information and programs that will assist consumers and other persons in making evaluations and decisions regarding the purchase, preparation, and use of mushrooms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Council” means the Mushroom Council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6104/b"},"text":"section 6104(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department” means the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6102/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First handler","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “first handler” means any person, as described in an order issued under this chapter, who receives or otherwise acquires mushrooms from a producer and prepares for marketing or markets such mushrooms, or who prepares for marketing or markets mushrooms of that person’s own production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6102/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “importer” means any person who imports, on average, over 500,000 pounds of mushrooms annually from outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6102/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industry information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “industry information” means information and programs that are designed to lead to the development of new markets and marketing strategies, increased efficiency, and activities to enhance the image of the mushroom industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6102/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marketing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “marketing” means the sale or other disposition of mushrooms in any channel of commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6102/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mushrooms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “mushrooms” means all varieties of cultivated mushrooms grown within the United States for the fresh market, or imported into the United States for the fresh market, that are marketed, except that such term shall not include mushrooms that are commercially marinated, canned, frozen, cooked, blanched, dried, packaged in brine, or otherwise processed, as may be determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6102/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means any individual, group of individuals, partnership, corporation, association, cooperative, or any other legal entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6102/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “producer” means any person engaged in the production of mushrooms who owns or who shares the ownership and risk of loss of such mushrooms and who produces, on average, over 500,000 pounds of mushrooms per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6102/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “promotion” means any action determined by the Secretary to enhance the image or desirability of mushrooms, including paid advertising.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6102/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “research” means any type of study to advance the image, desirability, marketability, production, product development, quality, or nutritional value of mushrooms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6102/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6102/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “State” and “United States” include the 50 States of the United States, the District of Columbia, and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefdc46e6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1923"},"text":"Pub. L. 101–624, title XIX, § 1923","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3855"},"text":"104 Stat. 3855","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
