{"tag":"section","attrib":{"id":"idef297175-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009aa"},"text":"§ 2009aa.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef297176-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Authority” means the Delta Regional Authority established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009aa–1"},"text":"section 2009aa–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef297177-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Region","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “region” means the Lower Mississippi (as defined in section 4 of the Delta Development Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"42 U.S.C. 3121","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/100/460"},"text":"Public Law 100–460","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef297178-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal grant program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal grant program” means a Federal grant program to provide assistance in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef297179-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquiring or developing land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef29717a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constructing or equipping a highway, road, bridge, or facility; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef29717b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out other economic development activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef29717c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alabama as participating State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the State of Alabama shall be a full member of the Delta Regional Authority and shall be entitled to all rights and privileges that said membership affords to all other participating States in the Delta Regional Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef29717d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s382A"},"text":"Pub. L. 87–128, title III, § 382A","children":[],"tail":", as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tI/tV/s503"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title I, § 153(b), title V, § 503]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–252, 2763A–269; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6701/f/1"},"text":"Pub. L. 115–334, title VI, § 6701(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4778"},"text":"132 Stat. 4778","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef29717e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef29717f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef297180-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Delta Development Act, referred to in par. (2), is S. 2836 of the 100th Congress, as introduced on ","children":[{"tag":"date","attrib":{"date":"1988-09-27"},"text":"Sept. 27, 1988","children":[],"tail":", and incorporated by reference by, and made a part of, "},{"tag":"ref","attrib":{"href":"/us/pl/100/460/tII"},"text":"Pub. L. 100–460, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2246"},"text":"102 Stat. 2246","children":[],"tail":". Section 4 of the Delta Development Act, which was set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"section 3121 of Title 42","children":[],"tail":", The Public Health and Welfare, was omitted from the Code. See Lower Mississippi Delta Development Commission note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"section 3121 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef297181-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tI/s153/b"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title I, § 153(b)]","children":[],"tail":", which directed amendment of “section 382A of ‘The Delta Regional Authority Act of 2000’ as incorporated in this Act” by adding par. (4), could not be executed as directed because this section is not section 382A of such Act, but rather section 382A of the Consolidated Farm and Rural Development Act, as added by section 503 of the Delta Regional Authority Act of 2000. Corrected amendment was made by "},{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":", effective as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":". See 2018 Amendment note above and 2018 Effective Date of 2018 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef297182-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef297183-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6701/f/2"},"text":"Pub. L. 115–334, title VI, § 6701(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4778"},"text":"132 Stat. 4778","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/334/tVI/s6701/f/2"},"text":"“The amendment made by this subsection [amending this section] shall take effect as if included in the enactment of section 153(b) of division B of H.R. 5666, as introduced in the 106th Congress, and as enacted by section 1(4) of the Consolidated Appropriations Act, 2001 (Appendix D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Public Law 106–554","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":"A–252).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef297184-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings and Purposes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tV/s502"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title V, § 502]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–268, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/554/s1/a/4/dB/tV/s502"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lower Mississippi River region (referred to in this title [enacting this subchapter and amending provisions classified as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"section 3121 of Title 42","children":[],"tail":", The Public Health and Welfare] as the ‘region’), though rich in natural and human resources, lags behind the rest of the United States in economic growth and prosperity;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the region suffers from a greater proportion of measurable poverty and unemployment than any other region of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the greatest hope for economic growth and revitalization in the region lies in the development of transportation infrastructure, creation of jobs, expansion of businesses, and development of entrepreneurial local economies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic progress of the region requires an adequate transportation and physical infrastructure, a skilled and trained workforce, and greater opportunities for enterprise development and entrepreneurship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a concerted and coordinated effort among Federal, State, and local agencies, the private sector, and nonprofit groups is needed if the region is to achieve its full potential for economic development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic development planning on a regional or multicounty basis offers the best prospect for achieving the maximum benefit from public and private investments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the economy of the region requires a special emphasis on areas of the region that are most economically distressed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this title are—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to promote and encourage the economic development of the region—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that the communities and people in the region have the opportunity for economic development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that the economy of the region reaches economic parity with that of the rest of the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish a formal framework for joint Federal-State collaboration in meeting and focusing national attention on the economic development needs of the region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist the region in obtaining the transportation and basic infrastructure, skills training, and opportunities for economic development that are essential for strong local economies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to foster coordination among all levels of government, the private sector, and nonprofit groups in crafting common regional strategies that will lead to broader economic growth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to strengthen efforts that emphasize regional approaches to economic development and planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage the participation of interested citizens, public officials, agencies, and others in developing and implementing local and regional plans for broad-based economic and community development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to focus special attention on areas of the region that suffer from the greatest economic distress.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
