{"tag":"section","attrib":{"id":"idee0b301f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"136w–7"},"text":"§ 136w–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Agriculture minor use program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee0b3020-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture (hereinafter in this section referred to as the “Secretary”) shall assure the coordination of the responsibilities of the Department of Agriculture related to minor uses of pesticides, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee0b3021-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–7/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out the Inter-Regional Project Number 4 (IR–4) as described in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/106/s2"},"text":"section 2 of Public Law 89–106","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s450i/e"},"text":"7 U.S.C. 450i(e)","children":[],"tail":") "},{"tag":"ref","attrib":{"idref":"fn002078"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002078"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and the national pesticide resistance monitoring program established under section 1651 "},{"tag":"ref","attrib":{"idref":"fn002078"},"text":"1","children":[],"tail":" of the Food, Agriculture, Conservation, and Trade Act of 1990 ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s5882"},"text":"7 U.S.C. 5882","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee0b3022-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–7/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting integrated pest management research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee0b3023-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–7/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consulting with growers to develop data for minor uses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee0b3024-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–7/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing assistance for minor use registrations, tolerances, and reregistrations with the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee0b3025-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minor use pesticide data and revolving fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee0b3026-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–7/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minor use pesticide data","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee0b3027-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–7/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Administrator, shall establish a program to make grants for the development of data to support minor use pesticide registrations and reregistrations. The amount of any such grant shall not exceed ½ of the cost of the project for which the grant is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee0b3028-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–7/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who wants to develop data to support minor use pesticide registrations and reregistrations may apply for a grant under subparagraph (A). Priority shall be given to an applicant for such a grant who does not directly receive funds from the sale of pesticides registered for minor uses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee0b3029-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–7/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data ownership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any data that is developed under a grant under subparagraph (A) shall be jointly owned by the Department of Agriculture and the person who received the grant. Such a person shall enter into an agreement with the Secretary under which such person shall share any fee paid to such person under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136a/c/1/F"},"text":"section 136a(c)(1)(F) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee0b302a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–7/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minor Use Pesticide Data Revolving Fund","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee0b302b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–7/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a revolving fund to be known as the Minor Use Pesticide Data Revolving Fund. The Fund shall be available without fiscal year limitation to carry out the authorized purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee0b302c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–7/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of the Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall be deposited in the Fund—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee0b302d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–7/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amounts as may be appropriated to support the purposes of this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee0b302e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–7/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fees collected by the Secretary for any data developed under a grant under paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee0b302f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–7/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizations of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for each fiscal year to carry out the purposes of this subsection $10,000,000 to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee0b3030-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-25/ch125/s32"},"text":"June 25, 1947, ch. 125, § 32","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/170/tII/s210/j"},"text":"Pub. L. 104–170, title II, § 210(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-03"},"text":"Aug. 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1501"},"text":"110 Stat. 1501","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee0b3031-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee0b3032-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idee0b3033-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/106/s2"},"text":"Section 2 of Public Law 89–106","children":[],"tail":", referred to in subsec. (a)(1), was formerly classified to secton 450i of this title prior to editorial reclassification and renumbering as "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3157"},"text":"section 3157 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1651 of the Food, Agriculture, Conservation, and Trade Act of 1990, referred to in subsec. (a)(1), was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5882"},"text":"section 5882 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s862/a"},"text":"Pub. L. 104–127, title VIII, § 862(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1174"},"text":"110 Stat. 1174","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
