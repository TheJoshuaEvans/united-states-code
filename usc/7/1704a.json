{"tag":"section","attrib":{"id":"ideee90c4c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1704a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1704a"},"text":"§ 1704a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements for use of foreign currencies; reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Within sixty days after any agreement is entered into for the use of any foreign currencies, a full report thereon shall be made to the Senate and the House of Representatives of the United States and to the Committees on Agriculture and Appropriations thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideee90c4d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/128/s1/5"},"text":"Pub. L. 85–128, § 1(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-13"},"text":"Aug. 13, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/345"},"text":"71 Stat. 345","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideee90c4e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideee90c4f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideee90c50-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Food for Peace Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ideee90c51-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideee90c52-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transmission of Reports","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions requiring Secretary of Agriculture and Administrator of Agency for International Development to transmit reports required by this section as related to use of foreign currencies accruing under subchapters II and III–A of this chapter, see section 2(b)(3) of Ex. Ord. No. 12752, ","children":[{"tag":"date","attrib":{"date":"1991-02-25"},"text":"Feb. 25, 1991","children":[],"tail":", 56 F.R. 8255, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
