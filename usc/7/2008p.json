{"tag":"section","attrib":{"id":"idef270098-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008p"},"text":null,"children":[{"tag":"num","attrib":{"value":"2008p"},"text":"§ 2008p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for NOAA weather radio transmitters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef270099-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Administrator of the Rural Utilities Service, may make grants to public and nonprofit entities, and borrowers of loans made by the Rural Utilities Service, for the Federal share of the cost of acquiring radio transmitters to increase coverage of rural areas by the all hazards weather radio broadcast system of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef27009a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a grant under this section, an applicant shall provide to the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef27009b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008p/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a binding commitment from a tower owner to place the transmitter on a tower; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef27009c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008p/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the tower placement will increase coverage of a rural area by the all hazards weather radio broadcast system of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef27009d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008p/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant provided under this section shall be not more than 75 percent of the total cost of acquiring a radio transmitter, as described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef27009e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008p/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $1,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef27009f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s379B"},"text":"Pub. L. 87–128, title III, § 379B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6024"},"text":"Pub. L. 107–171, title VI, § 6024","children":[],"tail":", "},{"tag":"dat