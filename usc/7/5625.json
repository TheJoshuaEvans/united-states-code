{"tag":"section","attrib":{"id":"idefcb7d99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5625"},"text":null,"children":[{"tag":"num","attrib":{"value":"5625"},"text":"§ 5625.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Combination of programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commodity Credit Corporation may carry out a program under which commercial export credit guarantees available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5622"},"text":"section 5622 of this title","children":[],"tail":" are combined with direct credits from the Commodity Credit Corporation under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s5621"},"text":"section 5621 of this title","children":[],"tail":" to reduce the effective rate of interest on export sales of agricultural commodities."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefcb7d9a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/tII/s205"},"text":"Pub. L. 95–501, title II, § 205","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1531"},"text":"Pub. L. 101–624, title XV, § 1531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3677"},"text":"104 Stat. 3677","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
