{"tag":"section","attrib":{"id":"idee3fad69-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s583"},"text":null,"children":[{"tag":"num","attrib":{"value":"583"},"text":"§ 583.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign standards; certification of compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Where the government of the country to which the shipment is to be made has standards or requirements as to condition of apples, the Secretary may in addition to inspection and certification for compliance with the standards established or designated hereunder inspect and certify for determination as to compliance with the standards or requirements of such foreign government and may provide for special certificates in such cases.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee3fad6a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-10/ch59/s3"},"text":"June 10, 1933, ch. 59, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/124"},"text":"48 Stat. 124","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/96/s1/c/2"},"text":"Pub. L. 106–96, § 1(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1321"},"text":"113 Stat. 1321","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee3fad6b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee3fad6c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee3fad6d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/96"},"text":"Pub. L. 106–96","children":[],"tail":" struck out “or pears” after “of apples”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
