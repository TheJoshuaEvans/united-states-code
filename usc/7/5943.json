{"tag":"section","attrib":{"id":"idefd9d57e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5943"},"text":null,"children":[{"tag":"num","attrib":{"value":"5943"},"text":"§ 5943.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rice research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefd9d57f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5943/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional and national research programs; rules; purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture may, under rules prescribed by such Secretary, carry out regional and national research programs with regard to rice for the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd9d580-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5943/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce fertilizer and herbicide usage in excess of production needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d581-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5943/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop varieties of rice more susceptible to complete fertilizer utilization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d582-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5943/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the resistance of rice plants to disease and to enhance their conservation and environmental qualities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d583-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5943/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the usage of rice and its processing byproducts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d584-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5943/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop better husbandry practices in production and conservation of rice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d585-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5943/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop more efficient rice storage practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d586-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5943/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve domestic and international marketing of rice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d587-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5943/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to benefit the general welfare.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd9d588-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5943/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of services of Federal, State, local governmental and private agencies; priority consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, in implementing the program authorized in subsection (a), utilize the technical and related services of appropriate Federal, State, local governmental, and private agencies, with priority consideration for land grant universities, State experiment stations, and other agricultural institutions of higher learning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd9d589-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5943/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; use restriction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated not more than $1,000,000 for the period ending ","children":[{"tag":"date","attrib":{"date":"1976-09-30"},"text":"September 30, 1976","children":[],"tail":", to carry out the provisions of this section. No funds authorized by this section shall be used for advertising or promotional activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefd9d58a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/214/tII/s201"},"text":"Pub. L. 94–214, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-02-16"},"text":"Feb. 16, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/187"},"text":"90 Stat. 187","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefd9d58b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefd9d58c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefd9d58d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s428c"},"text":"section 428c of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Rice Production Act of 1975, and not as part of subtitle H of title XVI of the Food, Agriculture, Conservation, and Trade Act of 1990 which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
