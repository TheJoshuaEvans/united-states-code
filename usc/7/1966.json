{"tag":"section","attrib":{"id":"idef13ed32-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1966"},"text":null,"children":[{"tag":"num","attrib":{"value":"1966"},"text":"§ 1966.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency Credit Revolving Fund utilization","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to utilize the revolving fund created by section 1148a ","children":[{"tag":"ref","attrib":{"idref":"fn002217"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002217"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 12 (hereinafter in this subchapter referred to as the “Emergency Credit Revolving Fund”) for carrying out the purposes of this subchapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef13ed33-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s326"},"text":"Pub. L. 87–128, title III, § 326","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/312"},"text":"75 Stat. 312","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef13ed34-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef13ed35-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef13ed36-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":nul