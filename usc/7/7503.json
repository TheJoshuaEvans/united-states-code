{"tag":"section","attrib":{"id":"idf010c400-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7503"},"text":null,"children":[{"tag":"num","attrib":{"value":"7503"},"text":"§ 7503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf010c401-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf010c402-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To receive commodities under this chapter, a State shall submit to the Secretary an operation and administration plan for the provision of benefits under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf010c403-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State shall submit to the Secretary for approval any amendment to a plan submitted under paragraph (1) in any case in which the State proposes to make a change to the operation or administration of a program described in the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf010c404-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each plan shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf010c405-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate the State agency responsible for distributing the commodities received under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf010c406-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth a plan of operation and administration to expeditiously distribute commodities under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf010c407-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7503/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth the standards of eligibility for recipient agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf010c408-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7503/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" set forth the standards of eligibility for individual or household recipients of commodities, which shall require—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf010c409-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7503/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals or households to be comprised of needy persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf010c40a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7503/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individual or household members to be residing in the geographic location served by the distributing agency at the time of applying for assistance;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf010c40b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7503/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the option of the State agency, describe a plan of operation for 1 or more projects in partnership with 1 or more emergency feeding organizations located in the State to harvest, process, package, or transport donated commodities received under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7507/d"},"text":"section 7507(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf010c40c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7503/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe a plan, which may include the use of a State advisory board established under subsection (c), that provides emergency feeding organizations or eligible recipient agencies within the State an opportunity to provide input on the commodity preferences and needs of the emergency feeding organization or eligible recipient agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf010c40d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State advisory board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall encourage each State receiving commodities under this chapter to establish a State advisory board consisting of representatives of all entities in the State, both public and private, interested in the distribution of commodities received under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf010c40e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/8/tII/s202A"},"text":"Pub. L. 98–8, title II, § 202A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/77/tVIII/s812"},"text":"Pub. L. 100–77, title VIII, § 812","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/537"},"text":"101 Stat. 537","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tVIII/s871/b"},"text":"Pub. L. 104–193, title VIII, § 871(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2344"},"text":"110 Stat. 2344","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tIV/s4201/b"},"text":"Pub. L. 110–234, title IV, § 4201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1121"},"text":"122 Stat. 1121","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title IV, § 4201(b), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1882; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIV/s4018/a"},"text":"Pub. L. 115–334, title IV, § 4018(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4648"},"text":"132 Stat. 4648","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf010c40f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf010c410-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf010c411-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf010c412-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" added pars. (5) and (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4201/b"},"text":"Pub. L. 110–246, § 4201(b)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a). Prior to amendment, text read as follows: “To receive commodities under this chapter, a State shall submit a plan of operation and administration every 4 years to the Secretary for approval. The plan may be amended at any time, with the approval of the Secretary.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":" amended section generally, substituting present provisions for provisions relating to availability of flour, cornmeal, and cheese acquired by the Commodity Credit Corporation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf010c413-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf010c414-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4201/b"},"text":"section 4201(b) of Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-10-01"},"text":"Oct. 1, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4407"},"text":"section 4407 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1161"},"text":"section 1161 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
