{"tag":"section","attrib":{"id":"idefcdef40-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5821"},"text":null,"children":[{"tag":"num","attrib":{"value":"5821"},"text":"§ 5821.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated management systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefcdef41-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5821/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a research and education program concerning integrated resource management and integrated crop management in order to enhance research related to farming operations, practices, and systems that optimize crop and livestock production potential and are environmentally sound. The purpose of the program shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcdef42-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5821/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage producers to adopt integrated crop and livestock management practices and systems that minimize or abate adverse environmental impacts, reduce soil erosion and loss of water and nutrients, enhance the efficient use of on-farm and off-farm inputs, and maintain or increase profitability and long-term productivity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef43-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5821/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop knowledge and information on integrated crop and livestock management systems and practices to assist agricultural producers in the adoption of these systems and practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef44-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5821/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accumulate and analyze information on agricultural production practices researched or developed under programs established under this subchapter, chapter 86 of this title,","children":[{"tag":"ref","attrib":{"idref":"fn002309"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002309"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and other appropriate programs of the Department of Agriculture to further the development of integrated crop and livestock management systems;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef45-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5821/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the adoption of whole-farm integrated crop and livestock management systems through demonstration projects on individual farms, including small and limited resource farms, throughout the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef46-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5821/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to evaluate and recommend appropriate integrated crop and livestock management policies and programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdef47-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5821/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development and adoption of integrated crop management practices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall encourage agricultural producers to adopt and develop individual, site-specific integrated crop management practices. On a priority basis, the Secretary shall develop and disseminate information on integrated crop management systems for agricultural producers in specific localities or crop producing regions where the Secretary determines—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcdef48-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5821/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water quality is impaired as a result of local or regional agricultural production practices; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef49-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5821/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adoption of such practices may aid in the recovery of endangered or threatened species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdef4a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5821/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development and adoption of integrated resource management practices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, on a priority basis, develop programs to encourage livestock producers to develop and adopt individual, site-specific integrated resource management practices. These programs shall be designed to benefit producers and consumers through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcdef4b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5821/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" optimum use of available resources and improved production and financial efficiency for producers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef4c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5821/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and prioritizing the research and educational needs of the livestock industry relating to production and financial efficiency, competitiveness, environmental stability, and food safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef4d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5821/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilizing an interdisciplinary approach.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdef4e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5821/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section through the National Institute of Food and Agriculture $20,000,000 for each of fiscal years 2013 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefcdef4f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1627"},"text":"Pub. L. 101–624, title XVI, § 1627","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3739"},"text":"104 Stat. 3739","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s862/b/2"},"text":"Pub. L. 104–127, title VIII, § 862(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1174"},"text":"110 Stat. 1174","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7511/c/16"},"text":"Pub. L. 110–234, title VII, § 7511(c)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1269"},"text":"122 Stat. 1269","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7511(c)(16), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2030; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7202"},"text":"Pub. L. 113–79, title VII, § 7202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/880"},"text":"128 Stat. 880","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7202"},"text":"Pub. L. 115–334, title VII, § 7202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4803"},"text":"132 Stat. 4803","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefcdef50-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefcdef51-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefcdef52-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (a)(3), was in the original “this subtitle”, meaning subtitle B (§§ 1619–1629) of title XVI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3733"},"text":"104 Stat. 3733","children":[],"tail":", which enacted this subchapter, repealed sections 4701 to 4710 of this title, and repealed provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4701"},"text":"section 4701 of this title","children":[],"tail":". For complete classification of subtitle B to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Chapter 86 of this title, referred to in subsec. (a)(3), was in the original “subtitle G of title XIV”, meaning subtitle G (§§ 1481–1485) of title XIV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":", which was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tIII/s302/c"},"text":"Pub. L. 105–185, title III, § 302(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/563"},"text":"112 Stat. 563","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefcdef53-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefcdef54-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" amended subsec. (d) generally. Prior to amendment, text read as follows: “There are authorized to be appropriated for each fiscal year $20,000,000 to carry out this section through the National Institute of Food and Agriculture.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7511/c/16"},"text":"Pub. L. 110–246, § 7511(c)(16)","children":[],"tail":", substituted “National Institute of Food and Agriculture” for “Extension Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" struck out “and "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s5881"},"text":"section 5881 of this title","children":[],"tail":"” before “and other appropriate”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefcdef55-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idefcdef56-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7511/c/16"},"text":"section 7511(c)(16) of Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7511/c"},"text":"section 7511(c) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1522"},"text":"section 1522 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
