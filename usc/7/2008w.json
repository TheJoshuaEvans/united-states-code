{"tag":"section","attrib":{"id":"idef270140-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w"},"text":null,"children":[{"tag":"num","attrib":{"value":"2008w"},"text":"§ 2008w.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural Innovation Stronger Economy Grant Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef270141-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef270142-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means a rural jobs accelerator partnership established after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef270143-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" organizes key community and regional stakeholders into a working group that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef270144-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" focuses on the shared goals and needs of the industry clusters that are objectively identified as existing, emerging, or declining;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef270145-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represents a region defined by the partnership in accordance with subparagraph (B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef270146-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes 1 or more representatives of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef270147-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef270148-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef270149-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/A/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a government entity; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef27014a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has, as a lead applicant—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef27014b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/A/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a District Organization (as defined in section 300.3 of title 13, Code of Federal Regulations (or a successor regulation));","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef27014c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/A/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"), or a consortium of Indian tribes;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef27014d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/A/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or a political subdivision of a State, including a special purpose unit of a State or local government engaged in economic development activities, or a consortium of political subdivisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef27014e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/A/iv/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":") or a consortium of institutions of higher education; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef27014f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/A/iv/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public or private nonprofit organization; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef270150-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to approval by the Secretary, may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef270151-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" serve a region that is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef270152-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a single jurisdiction; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef270153-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the region is a rural area, multijurisdictional; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef270154-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" define the region that the partnership represents, if the region—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef270155-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is large enough to contain critical elements of the industry cluster prioritized by the partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef270156-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is small enough to enable close collaboration among members of the partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef270157-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes a majority of communities that are located in—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idef270158-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/B/ii/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonmetropolitan area that qualifies as a low-income community (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s45D/e"},"text":"section 45D(e) of title 26","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idef270159-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/B/ii/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an area that has access to or has a plan to achieve broadband service (within the meaning of title VI of the Rural Electrification Act of 1936 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s950bb"},"text":"7 U.S.C. 950bb","children":[],"tail":" et seq.)); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef27015a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"item","attrib":{"id":"idef27015b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/B/ii/IV/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a population of 50,000 or fewer inhabitants; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idef27015c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/1/B/ii/IV/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a region with a population of more than 50,000 inhabitants, is the subject of a positive determination by the Secretary with respect to a rural-in-character petition, including such a petition submitted concurrently with the application of the partnership for a grant under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef27015d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industry cluster","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “industry cluster” means a broadly defined network of interconnected firms and supporting institutions in related industries that accelerate innovation, business formation, and job creation by taking advantage of assets and strengths of a region in the business environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef27015e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-wage job","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “high-wage job” means a job that provides a wage that is greater than the median wage for the applicable region, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef27015f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jobs accelerator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “jobs accelerator” means a jobs accelerator center or program located in or serving a low-income rural community that may provide co-working space, in-demand skills training, entrepreneurship support, and any other services described in subsection (d)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef270160-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small and disadvantaged business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “small and disadvantaged business” has the meaning given the term “small business concern owned and controlled by socially and economically disadvantaged individuals” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/d/3/C"},"text":"section 637(d)(3)(C) of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef270161-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef270162-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a grant program under which the Secretary shall award grants, on a competitive basis, to eligible entities to establish jobs accelerators, including related programming, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef270163-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the ability of distressed rural communities to create high-wage jobs, accelerate the formation of new businesses with high-growth potential, and strengthen regional economies, including by helping to build capacity in the applicable region to achieve those goals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef270164-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" help rural communities identify and maximize local assets and connect to regional opportunities, networks, and industry clusters that demonstrate high growth potential.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef270165-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef270166-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of any activity carried out using a grant made under paragraph (1) shall be not greater than 80 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef270167-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In-kind contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of the total cost of any activity carried out using a grant made under paragraph (1) may be in the form of donations or in-kind contributions of goods or services fairly valued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef270168-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting eligible entities to receive grants under paragraph (1), the Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef270169-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the commitment of participating core stakeholders in the jobs accelerator partnership, including a demonstration that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef27016a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investment organizations, including venture development organizations, venture capital firms, revolving loan funders, angel investment groups, community lenders, community development financial institutions, rural business investment companies, small business investment companies (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s662"},"text":"section 662 of title 15","children":[],"tail":"), philanthropic organizations, and other institutions focused on expanding access to capital, are committed partners in the jobs accelerator partnership and willing to potentially invest in projects emerging from the jobs accelerator; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef27016b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education, applied research institutions, workforce development entities, and community-based organizations are willing to partner with the jobs accelerator to provide workers with skills relevant to the industry cluster needs of the region, with an emphasis on the use of on-the-job training, registered apprenticeships, customized training, classroom occupational training, or incumbent worker training;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef27016c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the eligible entity to provide the non-Federal share as required under paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef27016d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of a targeted industry cluster;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef27016e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the partnership to link rural communities to markets, networks, industry clusters, and other regional opportunities and assets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef27016f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other grants or loans of the Secretary and other Federal agencies that the jobs accelerator would be able to leverage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef270170-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prospects for the proposed center and related programming to have sustainability beyond the full maximum length of assistance under this subsection, including the maximum number of renewals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef270171-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant term and renewals","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef270172-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The initial term of a grant under paragraph (1) shall be 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef270173-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may extend the term of a grant under paragraph (1) for an additional period of not longer than 2 years if the Secretary is satisfied, using the evaluation under subsection (e)(2), that the grant recipient has successfully established a jobs accelerator and related programming.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef270174-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the Secretary shall provide grants under paragraph (1) for jobs accelerators and related programming in not fewer than 25 States at any time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef270175-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant awarded under subsection (b) may be in an amount equal to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef270176-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $500,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef270177-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $2,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef270178-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef270179-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), funds from a grant awarded under subsection (b) may be used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef27017a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to construct, purchase, or equip a building to serve as an innovation center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef27017b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to support programs to be carried out at, or in direct partnership with, the jobs accelerator that support the objectives of the jobs accelerator, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef27017c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" linking rural communities and entrepreneurs to markets, networks, industry clusters, and other regional opportunities to support high-wage job creation, new business formation, business expansion, and economic growth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef27017d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrating small businesses into a supply chain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef27017e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating or expanding commercialization activities for new business formation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef27017f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/d/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and building assets in rural communities that are crucial to supporting regional economies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef270180-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/d/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating the repatriation of high-wage jobs to the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef270181-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/d/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the deployment of innovative processes, technologies, and products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef270182-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/d/1/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing the capacity of small businesses in regional industry clusters, including small and disadvantaged businesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef270183-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/d/1/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing United States exports and business interaction with international buyers and suppliers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef270184-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/d/1/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing the skills and expertise of local workforces, entrepreneurs, and institutional partners to meet the needs of employers and prepare workers for high-wage jobs in the identified industry clusters, including the upskilling of incumbent workers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef270185-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/d/1/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring rural communities have the capacity and ability to carry out projects relating to housing, community facilities, infrastructure, or community and economic development to support regional industry cluster growth; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef270186-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/d/1/B/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activities that the Secretary may determine to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef270187-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef270188-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), not more than 10 percent of a grant awarded under subsection (b) shall be used for indirect costs associated with administering the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef270189-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may increase the percentage described in subparagraph (A) on a case-by-case basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef27018a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual activity report and evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after receiving a grant under this section, and annually thereafter for the duration of the grant, an eligible entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef27018b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the Secretary on the activities funded with the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef27018c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef27018d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the progress that the eligible entity has made toward the strategic objectives identified in the application for the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef27018e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" measure that progress using performance measures during the project period, which may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef27018f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high-wage jobs created;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef270190-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high-wage jobs retained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef270191-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private investment leveraged;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef270192-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" businesses improved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef270193-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new business formations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef270194-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new products or services commercialized;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef270195-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improvement of the value of existing products or services under development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef270196-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" regional collaboration, as measured by such metrics as—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef270197-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/B/viii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of organizations actively engaged in the industry cluster;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef270198-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/B/viii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of symposia held by the industry cluster, including organizations that are not located in the immediate region defined by the partnership; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef270199-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/B/viii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of further cooperative agreements;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef27019a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of education and training activities relating to innovation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef27019b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of jobs relocated from outside of the United States to the region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef27019c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/B/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and number of new equity investments in industry cluster firms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef27019d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/B/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and number of new loans to industry cluster firms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef27019e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/B/xiii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiii"},"text":"(xiii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dollar increase in exports resulting from the project activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef27019f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/B/xiv"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiv"},"text":"(xiv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of employees for which training was provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2701a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/B/xv"},"text":null,"children":[{"tag":"num","attrib":{"value":"xv"},"text":"(xv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improvement in sales of participating businesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2701a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/B/xvi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xvi"},"text":"(xvi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improvement in wages paid at participating businesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2701a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/B/xvii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xvii"},"text":"(xvii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improvement in income of participating workers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2701a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/e/2/B/xviii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xviii"},"text":"(xviii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other measure the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2701a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008w/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $10,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef2701a5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s379I"},"text":"Pub. L. 87–128, title III, § 379I","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6424"},"text":"Pub. L. 115–334, title VI, § 6424","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4765"},"text":"132 Stat. 4765","children":[],"tail":".)"}],"tail":"\n"},{"tag":