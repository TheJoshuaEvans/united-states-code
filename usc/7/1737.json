{"tag":"section","attrib":{"id":"ideef764f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737"},"text":null,"children":[{"tag":"num","attrib":{"value":"1737"},"text":"§ 1737.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" John Ogonowski and Doug Bereuter Farmer-to-Farmer Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideef764f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef764f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Caribbean Basin country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Caribbean Basin country” means a country eligible for designation as a beneficiary country under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2702"},"text":"section 2702 of title 19","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef764f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emerging market","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “emerging market” means a country that the Secretary determines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideef764f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is taking steps toward a market-oriented economy through the food, agriculture, or rural business sectors of the economy of the country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef764f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the potential to provide a viable and significant market for United States agricultural commodities or products of United States agricultural commodities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef764f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Middle income country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “middle income country” means a country that has developed economically to the point at which the country does not receive bilateral development assistance from the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef764fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sub-Saharan African country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sub-Saharan African country” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3706"},"text":"section 3706 of title 19","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef764fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":" or any other provision of law, to further assist developing countries, middle-income countries, emerging markets, sub-Saharan African countries, and Caribbean Basin countries to increase farm production and farmer incomes, the President may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef764fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish and administer a program, to be known as the “John Ogonowski and Doug Bereuter Farmer-to-Farmer Program”, of farmer-to-farmer technical assistance between the United States and such countries to assist in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideef764fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing food production and distribution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef764fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the effectiveness of the farming and marketing operations of agricultural producers in those countries;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef764ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" use United States agricultural producers, agriculturalists, colleges and universities (including historically black colleges and universities, land grant colleges or universities, and foundations maintained by colleges or universities), private agribusinesses, private organizations (including grassroots organizations with an established and demonstrated capacity to carry out such a bilateral exchange program), private corporations, employees or staff of a State cooperative institution (as such term is defined in paragraph 18 of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3103"},"text":"section 3103 of this title","children":[],"tail":", except that subparagraphs (E), (F), and (G) of such paragraph shall not apply), and nonprofit farm organizations to work in conjunction with agricultural producers and farm organizations in those countries, on a voluntary basis—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideef76500-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to improve agricultural and agribusiness operations and agricultural systems in those countries, including improving—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideef76501-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" animal care and health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideef76502-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" field crop cultivation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideef76503-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fruit and vegetable growing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideef76504-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" livestock operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideef76505-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food processing and packaging;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideef76506-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" farm credit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideef76507-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marketing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideef76508-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/2/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inputs ","children":[{"tag":"ref","attrib":{"idref":"fn002202"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002202"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideef76509-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/2/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agricultural education and extension;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideef7650a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/2/A/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selection of seed varieties and plant stocks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideef7650b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/2/A/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowledge of insecticide and sanitation procedures to prevent crop destruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideef7650c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/2/A/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use and maintenance of agricultural equipment and irrigation systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideef7650d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/2/A/xiii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiii"},"text":"(xiii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selection of fertilizers and methods of soils treatment; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef7650e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to strengthen cooperatives and other agricultural groups in those countries;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef7650f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer the knowledge and expertise of United States agricultural producers and businesses, on an individual basis, to those countries while enhancing the democratic process by supporting private and public agriculturally related organizations that request and support technical assistance activities through cash and in-kind services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef76510-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, make grants to or enter into contracts or other cooperative agreements with private voluntary organizations, cooperatives, land grant universities, private agribusiness, or nonprofit farm organizations to carry out this section (except that any such contract or other agreement may obligate the United States to make outlays only to the extent that the budget authority for such outlays is available under subsection (d) or has otherwise been provided in advance in appropriation Acts);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef76511-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate programs established under this section with other foreign assistance programs and activities carried out by the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef76512-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent that local currencies can be used to meet the costs of a program established under this section, augment funds of the United States that are available for such a program through the use, within the country in which the program is being conducted, of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideef76513-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign currencies that accrue from the sale of agricultural commodities and products under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef76514-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local currencies generated from other types of foreign assistance activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef76515-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special emphasis on sub-Saharan African and Caribbean Basin countries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef76516-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideef76517-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" agricultural producers in sub-Saharan African and Caribbean Basin countries need training in agricultural techniques that are appropriate for the majority of eligible agricultural producers in those countries, including training in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideef76518-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standard growing practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideef76519-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insecticide and sanitation procedures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideef7651a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other agricultural methods that will produce increased yields of more nutritious and healthful crops;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef7651b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agricultural producers in the United States (including African-American agricultural producers) and banking and insurance professionals have agribusiness expertise that would be invaluable for agricultural producers in sub-Saharan African and Caribbean Basin countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef7651c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a commitment by the United States is appropriate to support the development of a comprehensive agricultural skills training program for those agricultural producers that focuses on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideef7651d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving knowledge of insecticide and sanitation procedures to prevent crop destruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideef7651e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" teaching modern agricultural techniques that would facilitate a continual analysis of crop production, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ideef7651f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification and development of standard growing practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideef76520-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of systems for recordkeeping;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideef76521-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use and maintenance of agricultural equipment that is appropriate for the majority of eligible agricultural producers in sub-Saharan African or Caribbean Basin countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideef76522-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the expansion of small agricultural operations into agribusiness enterprises by increasing access to credit for agricultural producers through—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ideef76523-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/1/C/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and use of village banking systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideef76524-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/1/C/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of agricultural risk insurance pilot products; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideef76525-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/1/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marketing crop yields to prospective purchasers (including businesses and individuals) for local needs and export; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef76526-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs that promote the exchange of agricultural knowledge and expertise through the exchange of American and foreign agricultural producers have been effective in promoting improved agricultural techniques and food security and the extension of additional resources to such farmer-to-farmer exchanges is warranted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef76527-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals for programs carried out in sub-Saharan African and Caribbean Basin countries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goals of programs carried out under this section in sub-Saharan African and Caribbean Basin countries shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideef76528-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to expand small agricultural operations in those countries into agribusiness enterprises by increasing access to credit for agricultural producers through—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideef76529-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and use of village banking systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideef7652a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of agricultural risk insurance pilot products;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef7652b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide training to agricultural producers in those countries that will—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideef7652c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance local food security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideef7652d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" help mitigate and alleviate hunger;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef7652e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide training to agricultural producers in those countries in groups to encourage participants to share and pass on to other agricultural producers in the home communities of the participants, the information and skills obtained from the training, rather than merely retaining the information and skills for the personal enrichment of the participants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef7652f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maximize the number of beneficiaries of the programs in sub-Saharan African and Caribbean Basin countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef76530-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, in addition to any funds that may be specifically appropriated to carry out this section, not less than the greater of $10,000,000 or 0.5 percent of the amounts made available for each of fiscal years 2008 through 2013, and not less than the greater of $15,000,000 or 0.6 percent of the amounts made available for each of fiscal years 2014 through 2023, to carry out this chapter shall be used to carry out programs under this section, with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef76531-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 0.2 percent to be used for programs in developing countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef76532-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 0.1 percent to be used for programs in sub-Saharan African and Caribbean Basin countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef76533-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef76534-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated for each of fiscal years 2008 through 2023 to carry out the programs under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideef76535-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for sub-Saharan African and Caribbean Basin countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef76536-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for other developing or middle-income countries or emerging markets not described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef76537-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 5 percent of the funds made available for a fiscal year under paragraph (1) may be used to pay administrative costs incurred in carrying out programs in sub-Saharan African and Caribbean Basin countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef76538-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program to create new partners and innovation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef76539-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Agency for International Development shall develop a grant program to be carried out in fiscal years 2019 through 2023 to facilitate new and innovative partnerships and activities under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef7653a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant recipient under this subsection shall use funds received under this subsection to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideef7653b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritize new implementing partners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef7653c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop innovative volunteer models;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef7653d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, improve, or maintain strategic partnerships with other United States development programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef7653e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1737/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand the footprint and impact of the programs and activities under this subchapter, and diversity among program participants, including land-grant colleges and universities and cooperative extension services (as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3103"},"text":"section 3103 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideef7653f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title V, § 501, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3656"},"text":"104 Stat. 3656","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIII/s301"},"text":"Pub. L. 102–237, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1855"},"text":"105 Stat. 1855","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII"},"text":"Pub. L. 104–127, title II","children":[],"tail":", §§ 224, 277(c)(1), "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/959"},"text":"110 Stat. 959","children":[],"tail":", 979; "},{"tag":"ref","attrib":{"href":"/us/pl/107/76/tVII/s777"},"text":"Pub. L. 107–76, title VII, § 777","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-28"},"text":"Nov. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/747"},"text":"115 Stat. 747","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIII/s3014"},"text":"Pub. L. 107–171, title III, § 3014","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/285"},"text":"116 Stat. 285","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dA/tVII/s769"},"text":"Pub. L. 108–447, div. A, title VII, § 769","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2848"},"text":"118 Stat. 2848","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3024"},"text":"Pub. L. 110–246, title III, § 3024","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1830"},"text":"122 Stat. 1830","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIII/s3014/a"},"text":"Pub. L. 113–79, title III, § 3014(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/778"},"text":"128 Stat. 778","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIII/s3116"},"text":"Pub. L. 115–334, title III, § 3116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4607"},"text":"132 Stat. 4607","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideef76540-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideef76541-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideef76542-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3116/1/A"},"text":"Pub. L. 115–334, § 3116(1)(A)","children":[],"tail":", inserted “"},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":" or” after “Notwithstanding” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3116/1/B"},"text":"Pub. L. 115–334, § 3116(1)(B)","children":[],"tail":", inserted “technical” before “assistance” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3116/1/C/i"},"text":"Pub. L. 115–334, § 3116(1)(C)(i)","children":[],"tail":", in introductory provisions, inserted “employees or staff of a State cooperative institution (as such term is defined in paragraph 18 of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3103"},"text":"section 3103 of this title","children":[],"tail":", except that subparagraphs (E), (F), and (G) of such paragraph shall not apply),” after “private corporations,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A)(viii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3116/1/C/ii/I"},"text":"Pub. L. 115–334, § 3116(1)(C)(ii)(I)","children":[],"tail":", struck out “; and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A)(ix) to (xiii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3116/1/C/ii/II"},"text":"Pub. L. 115–334, § 3116(1)(C)(ii)(II)","children":[],"tail":", added cls. (ix) to (xiii) and struck out former cl. (ix) which read as follows: “agricultural extension; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3116/2"},"text":"Pub. L. 115–334, § 3116(2)","children":[],"tail":", (3), in introductory provisions, substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3116/4"},"text":"Pub. L. 115–334, § 3116(4)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3014/a/1"},"text":"Pub. L. 113–79, § 3014(a)(1)","children":[],"tail":", substituted “2013, and not less than the greater of $15,000,000 or 0.6 percent of the amounts made available for each of fiscal years 2014 through 2018,” for “2012” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3014/a/2"},"text":"Pub. L. 113–79, § 3014(a)(2)","children":[],"tail":", substituted “2018” for “2012” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3024/a"},"text":"Pub. L. 110–246, § 3024(a)","children":[],"tail":", in introductory provisions, substituted “not less than the greater of $10,000,000 or” for “not less than” and “2008 through 2012” for “2002 through 2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3024/b"},"text":"Pub. L. 110–246, § 3024(b)","children":[],"tail":", added par. (1) and struck out former par. (1). Prior to amendment, text read as follows: “There is authorized to be appropriated to carry out programs under this section in sub-Saharan African and Caribbean Basin countries $10,000,000 for each of fiscal years 2002 through 2007.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/s769/2"},"text":"Pub. L. 108–447, § 769(2)","children":[],"tail":", inserted “and Doug Bereuter” after “John Ogonowski” in section catchline."}],"tail":"\n"},{"t