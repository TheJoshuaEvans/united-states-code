{"tag":"section","attrib":{"id":"idf01ef4e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783"},"text":null,"children":[{"tag":"num","attrib":{"value":"7783"},"text":"§ 7783.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to weed management entities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf01ef4e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and consent","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out a grant under this subchapter, the weed management entity and the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02165e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the activities funded under the grant will take place on Federal land, consult with the heads of the Federal agencies having jurisdiction over the land; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02165e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain the written consent of the non-Federal landowner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02165e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the amount of a grant to a weed management entity, the Secretary shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02165e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the severity or potential severity of the noxious weed problem;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02165ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the Federal funds will be used to leverage non-Federal funds to address the noxious weed problem;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02165eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the weed management entity has made progress in addressing the noxious weeds problem; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02165ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other factors that the Secretary determines to be relevant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02165ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant funds; cost shares","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02165ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A weed management entity that receives a grant under subsection (a) shall use the grant funds to carry out a project authorized by subsection (d) for the control or eradication of a noxious weed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02165ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost shares","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02165f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of carrying out an authorized project under this section exclusively on non-Federal land shall not exceed 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02165f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of non-Federal cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of the cost of carrying out an authorized project under this section may be provided in cash or in kind.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02165f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Projects funded by grants under this section include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02165f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Education, inventories and mapping, management, monitoring, methods development, and other capacity building activities, including the payment of the cost of personnel and equipment that promote control or eradication of noxious weeds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02165f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other activities to control or eradicate noxious weeds or promote control or eradication of noxious weeds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02165f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive assistance under this section, a weed management entity shall prepare and submit to the Secretary an application containing such information as the Secretary shall by regulation require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02165f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Projects funded under this section shall be selected by the Secretary on a competitive basis, taking into consideration the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02165f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The severity of the noxious weed problem or potential problem addressed by the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02165f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The likelihood that the project will prevent or resolve the problem, or increase knowledge about resolving similar problems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02165f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the Federal funds will leverage non-Federal funds to address the noxious weed problem addressed by the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02165fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the program will improve the overall capacity of the United States to address noxious weed control and management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02165fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the weed management entity has made progress in addressing noxious weed problems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02165fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the project will provide a comprehensive approach to the control or eradication of noxious weeds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02165fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the project will reduce the total population of noxious weeds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02165fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/f/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the project promotes cooperation and participation between States that have common interests in controlling and eradicating noxious weeds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02165ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/f/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other factors that the Secretary determines to be relevant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0216600-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional, State, and local involvement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining which projects receive funding under this section, the Secretary shall, to the maximum extent practicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0216601-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rely on technical and merit reviews provided by regional, State, or local weed management experts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0216602-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give priority to projects that maximize the involvement of State, local and, where applicable, Indian Tribe governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0216603-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7783/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall give special consideration to States with approved weed management entities established by Indian Tribes and may provide an additional allocation to a State to meet the particular needs and projects that the weed management entity plans to address.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0216604-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/tIV/s454"},"text":"Pub. L. 106–224, title IV, § 454","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/412/s1"},"text":"Pub. L. 108–412, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2321"},"text":"118 Stat. 2321","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
