{"tag":"section","attrib":{"id":"idef780720-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2242a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2242a"},"text":"§ 2242a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" User fees for reports, publications, and software","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef780721-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2242a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef780722-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2242a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnish, on request, copies of software programs, pamphlets, reports, or other publications, regardless of their form, including electronic publications, prepared in the Department of Agriculture in carrying out any of its missions or programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef780723-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2242a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charge such fees therefor as the Secretary determines are reasonable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef780724-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2242a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency of charges with provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9701"},"text":"section 9701 of title 31","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The imposition of such charges shall be consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9701"},"text":"section 9701 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef780725-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2242a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use and disposition of moneys","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All moneys received in payment for work or services performed, or for software programs, pamphlets, reports, or other publications provided, under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef780726-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2242a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be available until expended to pay directly the costs of such work, services, software programs, pamphlets, reports, or publications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef780727-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2242a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be credited to appropriations or funds that incur such costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef780728-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2242a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any fees collected, late payment penalties, and interest earned shall be credited to the account referred to in this section and may be invested by the Secretary of Agriculture in insured or fully-collateralized interest-bearing accounts or, at the discretion of the Secretary of Agriculture, by the Secretary of the Treasury in United States Government debt instruments. Fees and charges, including late payment penalties and interest earned from the investment of such funds shall be credited to such account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef780729-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXI/s1121"},"text":"Pub. L. 97–98, title XI, § 1121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1273"},"text":"95 Stat. 1273","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVII/s1769"},"text":"Pub. L. 99–198, title XVII, § 1769","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1656"},"text":"99 Stat. 1656","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXV/s2510"},"text":"Pub. L. 101–624, title XXV, § 2510","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4073"},"text":"104 Stat. 4073","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef78072a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef78072b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef78072c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":", in amending section generally, divided existing provisions into subsecs. (a), (b), and (c) and inserted references to software programs and electronic publications."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef78072d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idef78072e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1801"},"text":"section 1801 of Pub. L. 97–98","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
