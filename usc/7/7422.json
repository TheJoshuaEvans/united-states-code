{"tag":"section","attrib":{"id":"idf0099837-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7422"},"text":null,"children":[{"tag":"num","attrib":{"value":"7422"},"text":"§ 7422.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments to orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of this subchapter applicable to an order shall be applicable to any amendment to an order, except that ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7417"},"text":"section 7417 of this title","children":[],"tail":" shall not apply to an amendment."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf0099838-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s523"},"text":"Pub. L. 104–127, title V, § 523","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1047"},"text":"110 Stat. 1047","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
