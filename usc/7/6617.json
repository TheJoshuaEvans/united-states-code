{"tag":"section","attrib":{"id":"idefea9e28-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6617"},"text":null,"children":[{"tag":"num","attrib":{"value":"6617"},"text":"§ 6617.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations and spending authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefea9e29-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6617/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), there are authorized to be appropriated—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefea9e2a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6617/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an amount not to exceed 5 percent of the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefea9e2b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6617/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sums received by the Secretary from sales of timber and other products of the forests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefea9e2c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6617/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" user fees paid in connection with the use of forest lands; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e2d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6617/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional sums as may be necessary to carry out the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefea9e2e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6617/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not in any way affect payments to the States pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s500"},"text":"section 500 of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefea9e2f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6617/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spending authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any spending authority (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s651"},"text":"section 651 of title 2","children":[],"tail":") provided in this subchapter shall be effective for any fiscal year only to such extent or in such amounts as are provided in appropriation Acts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefea9e30-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2379"},"text":"Pub. L. 101–624, title XXIII, § 2379","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4049"},"text":"104 Stat. 4049","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
