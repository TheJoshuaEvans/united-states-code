{"tag":"section","attrib":{"id":"idef080627-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1926e"},"text":"§ 1926e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural decentralized water systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef080628-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible individual","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “eligible individual” means an individual who is a member of a household the members of which have a combined income (for the most recent 12-month period for which the information is available) that is not more than 60 percent of the median nonmetropolitan household income for the State or territory in which the individual resides, according to the most recent decennial census of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef080629-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef08062a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants to private nonprofit organizations for the purpose of providing loans and subgrants to eligible individuals for the construction, refurbishing, and servicing of individual household water well systems and individually owned household decentralized wastewater systems in rural areas that are or will be owned by the eligible individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef08062b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and amounts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef08062c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926e/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of loans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A loan made with grant funds under this section—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef08062d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926e/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have an interest rate of 1 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef08062e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926e/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have a term not to exceed 20 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef08062f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926e/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A loan or subgrant made with grant funds under this section shall not exceed $15,000 for each water well system or decentralized wastewater system described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef080630-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A recipient of a grant made under this section may use grant funds to pay administrative expenses associated with providing the assistance described in paragraph (1), as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef080631-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ground well water contamination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event of ground well water contamination, the Secretary shall allow a loan or subgrant to be made with grant funds under this section for the installation of water treatment where needed beyond the point of entry, with or without the installation of a new water well system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef080632-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority in awarding grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Secretary shall give priority to an applicant that has substantial expertise and experience in promoting the safe and effective use of individually owned household water well systems, individually owned household decentralized wastewater systems, and ground water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef080633-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $20,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef080634-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s306E"},"text":"Pub. L. 87–128, title III, § 306E","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6012/a"},"text":"Pub. L. 107–171, title VI, § 6012(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/357"},"text":"116 Stat. 357","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVI/s6010"},"text":"Pub. L. 110–234, title VI, § 6010","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1163"},"text":"122 Stat. 1163","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VI, § 6010, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1925; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVI/s6009"},"text":"Pub. L. 113–79, title VI, § 6009","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/843"},"text":"128 Stat. 843","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6409"},"text":"Pub. L. 115–334, title VI, § 6409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4761"},"text":"132 Stat. 4761","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef080635-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef080636-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef080637-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef080638-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6409/1"},"text":"Pub. L. 115–334, § 6409(1)","children":[],"tail":", substituted “Rural decentralized water systems” for “Grants to nonprofit organizations to finance the construction, refurbishing, and servicing of individually-owned household water well systems in rural areas for individuals with low or moderate incomes” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6409/2"},"text":"Pub. L. 115–334, § 6409(2)","children":[],"tail":", substituted “60” for “100”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6409/3/A"},"text":"Pub. L. 115–334, § 6409(3)(A)","children":[],"tail":", inserted “and subgrants” after “loans” and “and individually owned household decentralized wastewater systems” after “well systems”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6409/3/B"},"text":"Pub. L. 115–334, § 6409(3)(B)","children":[],"tail":", added par. (2) and struck out former par. (2). Prior to amendment, text read as follows: “A loan made with grant funds under this section—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) shall have an interest rate of 1 percent;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) shall have a term not to exceed 20 years; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) shall not exceed $11,000 for each water well system described in paragraph (1).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6409/3/C"},"text":"Pub. L. 115–334, § 6409(3)(C)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6409/4"},"text":"Pub. L. 115–334, § 6409(4)","children":[],"tail":", substituted “effective use of individually owned household water well systems, individually owned household decentralized wastewater systems,” for “productive use of individually-owned household water well systems”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6409/5"},"text":"Pub. L. 115–334, § 6409(5)","children":[],"tail":", substituted “$20,000,000” for “$5,000,000” and “2019 through 2023” for “2014 through 2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" substituted “$5,000,000 for each of fiscal years 2014 through 2018” for “$10,000,000 for each of fiscal years 2008 through 2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s6010/1"},"text":"Pub. L. 110–246, § 6010(1)","children":[],"tail":", substituted “$11,000” for “$8,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s6010/2"},"text":"Pub. L. 110–246, § 6010(2)","children":[],"tail":", substituted “2008 through 2012” for “2003 through 2007”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef080639-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef08063a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idef08063b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6012/b"},"text":"Pub. L. 107–171, title VI, § 6012(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/358"},"text":"116 Stat. 358","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/171/tVI/s6012/b"},"text":"“The amendment made by subsection (a) [enacting this section] takes effect on ","children":[{"tag":"date","attrib":{"date":"2002-10-01"},"text":"October 1, 2002","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
