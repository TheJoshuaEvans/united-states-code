{"tag":"section","attrib":{"id":"idf04eb7ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057"},"text":null,"children":[{"tag":"num","attrib":{"value":"9057"},"text":"§ 9057.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premiums for dairy margin coverage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf04eb7cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation of premiums","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of participating in dairy margin coverage, a participating dairy operation shall pay an annual premium equal to the product obtained by multiplying—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04eb7d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coverage percentage elected by the participating dairy operation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9056/a/2"},"text":"section 9056(a)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb7d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production history of the participating dairy operation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb7d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the premium per hundredweight of milk imposed by this section for the coverage level selected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04eb7d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tier I: premium per hundredweight for first 6,000,000 pounds of production","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04eb7d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the first 6,000,000 pounds of milk marketings included in the production history of a participating dairy operation, the premium per hundredweight for each coverage level is specified in the table contained in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb7d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer premiums","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (g), the following annual premiums apply:","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf04eb7d6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children"