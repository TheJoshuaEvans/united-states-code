il":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04eb7db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for payment of premium","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide more than 1 method by which a participating dairy operation may pay the premium required under this section in any manner that maximizes participating dairy operation payment flexibility and dairy margin coverage integrity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04eb7dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premium obligations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04eb7dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pro-ration of premium for new participants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a participating dairy operation that first registers to participate in dairy margin coverage for a calendar year after the start of the calendar year, the participating dairy operation shall pay a pro-rated premium for that calendar year based on the portion of the calendar year for which the participating dairy operation purchases the coverage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb7de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal obligation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A participating dairy operation in dairy margin coverage for a calendar year shall be legally obligated to pay the applicable premium for that calendar year, except that the Secretary may waive that obligation, under terms and conditions determined by the Secretary, for any participating dairy operation in the case of death, retirement, permanent dissolution of a participating dairy operation, or other circumstances as the Secretary considers appropriate to ensure the integrity of dairy margin coverage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04eb7df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of premiums","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04eb7e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each dairy operation described in paragraph (2) shall be eligible to receive a repayment from the Secretary in an amount equal to the difference between—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04eb7e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of premiums paid by the participating dairy operation under this section for each applicable calendar year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04eb7e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of payments made to the participating dairy operation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9056"},"text":"section 9056 of this title","children":[],"tail":" for that calendar year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb7e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A dairy operation that is eligible to receive a repayment under paragraph (1) is a dairy operation that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04eb7e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participated in the margin protection program, as in effect for any of calendar years 2014 through 2017; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04eb7e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits to the Secretary an application for the repayment at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb7e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of repayment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A dairy operation that is eligible to receive a repayment under paragraph (1) shall elect to receive the repayment—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04eb7e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an amount equal to 75 percent of the repayment calculated under that paragraph as credit that may be used by the dairy operation for dairy margin coverage premiums; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04eb7e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an amount equal to 50 percent of the repayment calculated under that paragraph as a direct cash repayment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb7e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall only apply to a calendar year during the period of calendar years 2014 through 2017 for which the amount described in subparagraph (A) of that paragraph is greater than the amount described in subparagraph (B) of that paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04eb7ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premium discount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The premium per hundredweight specified in the tables contained in subsections (b) and (c) for each coverage level shall be reduced by 25 percent in accordance with the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04eb7eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of calendar years 2026 through 2031, for a participating dairy operation that makes a 1-time election of coverage level in a tier and of a percentage of coverage under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9056/a"},"text":"section 9056(a) of this title","children":[],"tail":" for the 5-year period beginning in January 2026."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb7ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New dairy operations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each applicable calendar year through 2031, for a participating dairy operation that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04eb7ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes a production history pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9055/b"},"text":"section 9055(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04eb7ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes a 1-time election of coverage level in a tier and of a percentage of coverage under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9056/a"},"text":"section 9056(a) of this title","children":[],"tail":" for the period beginning with the first available calendar year and ending in December 2031."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb7ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full participation required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the annual elections under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9056/a"},"text":"section 9056(a) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04eb7f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 1-time enrollment under this subsection shall remain in effect for the full duration applicable to a participating dairy operation in accordance with paragraph (1) or (2)(B), as applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04eb7f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9057/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a participating dairy operation that makes a 1-time enrollment under this subsection and is noncompliant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9058"},"text":"section 9058 of this title","children":[],"tail":" shall be subject to that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf04eb7f2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1407"},"text":"Pub. L. 113–79, title I, § 1407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/691"},"text":"128 Stat. 691","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dF/s60101/b/4"},"text":"Pub. L. 115–123, div. F, § 60101(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/312"},"text":"132 Stat. 312","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI/s1401/h"},"text":"Pub. L. 115–334, title I, § 1401(h)","children":[],"tail":"–(j), (k)(8), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4514"},"text":"132 Stat. 4514","children":[],"tail":", 4515, 4517; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10313/c"},"text":"Pub. L. 119–21, title I, § 10313(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/100"},"text":"139 Stat. 100","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf04eb7f3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf04eb7f4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf04eb7f5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10313/c/1"},"text":"Pub. L. 119–21, § 10313(c)(1)","children":[],"tail":", substituted “6,000,000” for “5,000,000” in heading and par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10313/c/2"},"text":"Pub. L. 119–21, § 10313(c)(2)","children":[],"tail":", substituted “6,000,000” for “5,000,000” in heading and par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10313/c/3/A"},"text":"Pub. L. 119–21, § 10313(c)(3)(A)","children":[],"tail":", substituted “2026 through 2031” for “2019 through 2023” and “January 2026” for “January 2019”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10313/c/3/B"},"text":"Pub. L. 119–21, § 10313(c)(3)(B)","children":[],"tail":", substituted “2031” for “2023” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/k/8/A"},"text":"Pub. L. 115–334, § 1401(k)(8)(A)","children":[],"tail":", substituted “dairy margin coverage” for “margin protection program” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/k/8/B"},"text":"Pub. L. 115–334, § 1401(k)(8)(B)","children":[],"tail":", substituted “dairy margin coverage” for “the margin protection program” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s60101/b/4/A/i"},"text":"Pub. L. 115–123, § 60101(b)(4)(A)(i)","children":[],"tail":", substituted “Tier I: premium per hundredweight for first 5,000,000 pounds of production” for “Premium per hundredweight for first 4 million pounds of production” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s60101/b/4/A/ii"},"text":"Pub. L. 115–123, § 60101(b)(4)(A)(ii)","children":[],"tail":", substituted “5,000,000” for “4,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/h/1"},"text":"Pub. L. 115–334, § 1401(h)(1)","children":[],"tail":", added par. (2) and struck out former par. (2) which set forth table of annual premiums, applicable except as provided in par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s60101/b/4/A/iii"},"text":"Pub. L. 115–123, § 60101(b)(4)(A)(iii)","children":[],"tail":", in Premium per Cwt. column of table, substituted “None” for “$0.010”, “None” for “$0.025”, “$0.009” for “$0.040”, “$0.016” for “$0.055”, “$0.040” for “$0.090”, “$0.063” for “$0.217”, “$0.087” for “$0.300”, and “$0.142” for “$0.475”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/h/1"},"text":"Pub. L. 115–334, § 1401(h)(1)","children":[],"tail":", struck out par. (3). Text read as follows: “The premium per hundredweight specified in the table contained in paragraph (2) for each coverage level (except the $8.00 coverage level) shall be reduced by 25 percent for each of calendar years 2014 and 2015.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s60101/b/4/B/i"},"text":"Pub. L. 115–123, § 60101(b)(4)(B)(i)","children":[],"tail":", substituted “Tier II: premium per hundredweight for production in excess of 5,000,000 pounds” for “Premium per hundredweight for production in excess of 4 million pounds” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s60101/b/4/B/ii"},"text":"Pub. L. 115–123, § 60101(b)(4)(B)(ii)","children":[],"tail":", substituted “5,000,000” for “4,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/h/2"},"text":"Pub. L. 115–334, § 1401(h)(2)","children":[],"tail":", added par. (2) and struck out former par. (2) which set forth table of annual producer premiums."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/k/8/C"},"text":"Pub. L. 115–334, § 1401(k)(8)(C)","children":[],"tail":", substituted “dairy margin coverage integrity” for “program integrity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/k/8/D/i"},"text":"Pub. L. 115–334, § 1401(k)(8)(D)(i)","children":[],"tail":", substituted “in dairy margin coverage” for “in the margin protection program” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/k/8/D/ii"},"text":"Pub. L. 115–334, § 1401(k)(8)(D)(ii)","children":[],"tail":", substituted “integrity of dairy margin coverage” for “integrity of the program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/i"},"text":"Pub. L. 115–334, § 1401(i)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/j"},"text":"Pub. L. 115–334, § 1401(j)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf04eb7f6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf04eb7f7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/m"},"text":"section 1401(m) of Pub. L. 115–334","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9051"},"text":"section 9051 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123"},"text":"Pub. L. 115–123","children":[],"tail":" applicable beginning with the 2018 calendar year, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/s60101/b/5"},"text":"section 60101(b)(5) of Pub. L. 115–123","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9051"},"text":"section 9051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf04eb7f8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Availability of Premium Discount","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/158/dD/s4101/c/4/A/ii"},"text":"Pub. L. 118–158, div. D, § 4101(c)(4)(A)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-21"},"text":"Dec. 21, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1768"},"text":"138 Stat. 1768","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/158/dD/s4101/c/4/A/ii"},"text":"“With respect to coverage for calendar year 2025, section 1407(g) of the Agricultural Act of 2014 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9057/g"},"text":"7 U.S.C. 9057(g)","children":[],"tail":") shall only apply to a participating dairy operation with respect to which the premium was reduced in accordance with that section (as applied to such participating dairy operation pursuant to section 102(c)(2)(B)(ii) of division B of the Further Continuing Appropriations and Other Extensions Act, 2024 ("},{"tag":"ref","attrib":{"href":"/us/pl/118/22"},"text":"Public Law 118–22","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/stat/137/115"},"text":"137 Stat. 115","children":[],"tail":"]) for calendar year 2024.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/22/dB/tI/s102/c/2/B/ii"},"text":"Pub. L. 118–22, div. B, title I, § 102(c)(2)(B)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-11-17"},"text":"Nov. 17, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/115"},"text":"137 Stat. 115","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/22/dB/tI/s102/c/2/B/ii"},"text":"“With respect to coverage for calendar year 2024, section 1407(g) of the Agricultural Act of 2014 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9057/g"},"text":"7 U.S.C. 9057(g)","children":[],"tail":") shall only apply to a participating dairy operation with respect to which the premium was reduced in accordance with that section for calendar year 2023.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
