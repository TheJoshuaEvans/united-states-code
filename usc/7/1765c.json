{"tag":"section","attrib":{"id":"ideefc1f8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1765c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1765c"},"text":"§ 1765c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance of functions in foreign localities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each United States Agricultural Trade Office shall carry out its functions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1765b"},"text":"section 1765b of this title","children":[],"tail":" in the nation where the United States Agricultural Trade Office is located and in such other nations as the Secretary of Agriculture, in consultation with the Secretary of State, may prescribe in order to carry out the purposes of this subchapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideefc1f8e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-28/ch1041"},"text":"Aug. 28, 1954, ch. 1041","children":[],"tail":", title VI, § 605C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/501/tIV/s401/1"},"text":"Pub. L. 95–501, title IV, § 401(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-21"},"text":"Oct. 21, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1690"},"text":"92 Stat. 1690","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
