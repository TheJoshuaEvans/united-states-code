{"tag":"section","attrib":{"id":"idf02adbff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996"},"text":null,"children":[{"tag":"num","attrib":{"value":"7996"},"text":"§ 7996.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable relief from ineligibility for loans, payments, or other benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf02adc00-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adc01-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural commodity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agricultural commodity” means any agricultural commodity, food, feed, fiber, or livestock that is subject to a covered program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adc02-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02adc03-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered program” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf02adc04-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a program administered by the Secretary under which price or income support, or production or market loss assistance, is provided to producers of agricultural commodities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02adc05-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a conservation program administered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adc06-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered program” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf02adc07-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agricultural credit program carried out under the Consolidated Farm and Rural Development Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"7 U.S.C. 1921","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02adc08-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the crop insurance program carried out under the Federal Crop Insurance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"7 U.S.C. 1501","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adc09-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “participant” means a participant in a covered program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adc0a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State Conservationist","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State Conservationist” means the State Conservationist with respect to a program administered by the Natural Resources Conservation Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adc0b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State Director” means the State Executive Director of the Farm Service Agency with respect to a program administered by the Farm Service Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adc0c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable relief","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide relief to any participant that is determined to be not in compliance with the requirements of a covered program, and therefore ineligible for a loan, payment, or other benefit under the covered program, if the participant—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adc0d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acting in good faith, relied on the action or advice of the Secretary (including any authorized representative of the Secretary) to the detriment of the participant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adc0e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failed to comply fully with the requirements of the covered program, but made a good faith effort to comply with the requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adc0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forms of relief","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may authorize a participant in a covered program to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adc10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain loans, payments, or other benefits received under the covered program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adc11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue to receive loans, payments, and other benefits under the covered program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adc12-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue to participate, in whole or in part, under any contract executed under the covered program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adc13-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a conservation program, reenroll all or part of the land covered by the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adc14-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive such other equitable relief as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adc15-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedial action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of receiving relief under this section, the Secretary may require the participant to take actions designed to remedy any failure to comply with the covered program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adc16-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable relief by State Directors and State Conservationists","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adc17-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State Director, in the case of programs administered by the State Director, and the State Conservationist, in the case of programs administered by the State Conservationist, may grant relief to a participant in accordance with subsections (b) through (d) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02adc18-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of loans, payments, and benefits for which relief will be provided to the participant under this subsection is less than $20,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adc19-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of loans, payments, and benefits for which relief has been previously provided to the participant under this subsection is not more than $5,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adc1a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of loans, payments, and benefits for which relief is provided to similarly situated participants under this subsection is not more than $1,000,000, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adc1b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation, approval, and reversal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The decision by a State Director or State Conservationist to grant relief under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02adc1c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not require prior approval by the Administrator of the Farm Service Agency, the Chief of the Natural Resources Conservation Service, or any other officer or employee of the Agency or Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adc1d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be made only after consultation with, and the approval of, the Office of General Counsel of the Department of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adc1e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to reversal only by the Secretary (who may not delegate the reversal authority).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adc1f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authority of a State Director or State Conservationist under this subsection does not apply to the administration of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02adc20-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" payment limitations under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf02adc21-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 1001 through 1001F of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308"},"text":"7 U.S.C. 1308","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02adc22-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a conservation program administered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adc23-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" highly erodible land and wetland conservation requirements under subtitle B or C of title XII of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3811"},"text":"16 U.S.C. 3811","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adc24-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided to a State Director and State Conservationist under this subsection is in addition to any other applicable authority and does not limit other authority provided by law or the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adc25-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A discretionary decision by the Secretary, the State Director, or the State Conservationist under this section shall be final, and shall not be subject to review under chapter 7 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adc26-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than February 1 of each year, the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that describes for the previous calendar year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adc27-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of requests for equitable relief under subsections (b) and (e) and the disposition of the requests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adc28-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of requests for equitable relief under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6998/d"},"text":"section 6998(d) of this title","children":[],"tail":" and the disposition of the requests."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adc29-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7996/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided in this section is in addition to any other authority provided in this or any other Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf02adc2a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1613"},"text":"Pub. L. 107–171, title I, § 1613","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/219"},"text":"116 Stat. 219","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf02adc2b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf02adc2c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf02adc2d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Consolidated Farm and Rural Development Act, referred to in subsec. (a)(2)(B)(i), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/307"},"text":"75 Stat. 307","children":[],"tail":", which is classified principally to chapter 50 (§ 1921 et seq.) of this title. For complete classification of the Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Crop Insurance Act, referred to in subsec. (a)(2)(B)(ii), is subtitle A of 