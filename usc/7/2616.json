{"tag":"section","attrib":{"id":"idef865eba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2616"},"text":null,"children":[{"tag":"num","attrib":{"value":"2616"},"text":"§ 2616.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make such regulations with the force and effect of law, as may be necessary to carry out the provisions of this chapter and the powers vested in him by this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef865ebb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/670/tIII/s307"},"text":"Pub. L. 91–670, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-11"},"text":"Jan. 11, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2042"},"text":"84 Stat. 2042","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
