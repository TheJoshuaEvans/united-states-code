{"tag":"section","attrib":{"id":"idf02adbba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7991"},"text":null,"children":[{"tag":"num","attrib":{"value":"7991"},"text":"§ 7991.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration generally","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf02adbbb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7991/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Commodity Credit Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use the funds, facilities, and authorities of the Commodity Credit Corporation to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adbbc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7991/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A determination made by the Secretary under this chapter shall be final and conclusive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adbbd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7991/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adbbe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7991/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", the Secretary and the Commodity Credit Corporation, as appropriate, shall promulgate such regulations as are necessary to implement this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adbbf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7991/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The promulgation of the regulations and administration of this chapter shall be made without regard to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02adbc0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7991/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 35 of title 44 (commonly know ","children":[{"tag":"ref","attrib":{"idref":"fn002353"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002353"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “known”."}],"tail":" as the “Paperwork Reduction Act”);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adbc1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7991/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Statement of Policy of the Secretary of Agriculture effective ","children":[{"tag":"date","attrib":{"date":"1971-07-24"},"text":"July 24, 1971","children":[],"tail":" (36 Fed. Reg. 13804), relating to notices of proposed rulemaking and public participation in rulemaking; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adbc2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7991/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the notice and comment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adbc3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7991/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional review of agency rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subsection, the Secretary shall use the authority provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s808"},"text":"section 808 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adbc4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7991/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of advance payment option","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The protection that was afforded producers that had an option to elect to accelerate the receipt of any payment under a production flexibility contract payable under the Federal Agriculture Improvement and Reform Act of 1996, as provided by section 525 of Public ","children":[{"tag":"ref","attrib":{"idref":"fn002354"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002354"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be followed by “Law”."}],"tail":" 106–170 ("},{"tag":"ref","attrib":{"href":"/us/stat/113/1928"},"text":"113 Stat. 1928","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7212"},"text":"7 U.S.C. 7212","children":[],"tail":" note), shall also apply to the option to receive—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adbc5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7991/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the advance payment of direct payments and counter-cyclical payments under subchapter I and subchapter III;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adbc6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7991/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the single payment of compensation for eligible peanut quota holders under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7960"},"text":"section 7960 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adbc7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7991/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the advance payment of direct payments and counter-cyclical payments under title I of the Food, Conservation, and Energy Act of 2008 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"7 U.S.C. 8701","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adbc8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7991/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment authority related to Uruguay Round compliance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adbc9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7991/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required determination; adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that expenditures under subchapters I through V that are subject to the total allowable domestic support levels under the Uruguay Round Agreements (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501"},"text":"section 3501 of title 19","children":[],"tail":"), as in effect on "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", will exceed such allowable levels for any applicable reporting period, the Secretary shall, to the maximum extent practicable, make adjustments in the amount of such expenditures during that period to ensure that such expenditures do not exceed such allowable levels."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adbca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7991/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before making any adjustment under paragraph (1), the Secretary shall submit to the Committee on Agriculture, Nutrition, and Forestry of the Senate and the Committee on Agriculture of the House of Representatives a report describing the determination made under that paragraph and the extent of the adjustment to be made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf02adbcb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1601"},"text":"Pub. L. 107–171, title I, § 1601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/211"},"text":"116 Stat. 211","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1601/e"},"text":"Pub. L. 110–234, title I, § 1601(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1001"},"text":"122 Stat. 1001","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1601(e), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1729.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf02adbcc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf02adbcd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf02adbce-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of “this chapter”, referred to in subsecs. (a) to (c), see References in Text note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7901"},"text":"section 7901 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Agriculture Improvement and Reform Act of 1996, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/888"},"text":"110 Stat. 888","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7201"},"text":"section 7201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subchapter III, referred to in subsec. (d)(1), was in the original “subtitle C”, meaning subtitle C (§§ 1301–1310) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/166"},"text":"116 Stat. 166","children":[],"tail":", which is classified principally to subchapter III of this chapter. For complete classification of subtitle C to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7951"},"text":"section 7951 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Food, Conservation, and Energy Act of 2008, referred to in subsec. (d)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1651"},"text":"122 Stat. 1651","children":[],"tail":". Title I of the Act is classified principally to chapter 113 (§ 8701 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subchapter V, referred to in subsec. (e)(1), was in the original “subtitle E”, meaning subtitle E (§§ 1501–1508) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/205"},"text":"116 Stat. 205","children":[],"tail":", which enacted subchapter V of this chapter and amended sections 1637a, 4501–4504, 4507, 4553, 6402, and 6414 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s713a–4"},"text":"section 713a–4 of Title 15","children":[],"tail":", Commerce and Trade. For complete classification of subtitle E to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf02adbcf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf02adbd0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children"