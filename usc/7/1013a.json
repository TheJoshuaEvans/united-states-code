{"tag":"section","attrib":{"id":"idee6a8e7f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1013a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1013a"},"text":"§ 1013a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits extended to Puerto Rico and Virgin Islands; “county” defined; payments to Governor or fiscal agent of county","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of this subchapter shall extend to Puerto Rico and the Virgin Islands. In the case of Alaska, Puerto Rico, and the Virgin Islands, the term “county” as used in this subchapter may be the entire area, or any subdivision thereof as may be determined by the Secretary, and payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1012"},"text":"section 1012 of this title","children":[],"tail":" shall be made to the Governor or to the fiscal agent of such subdivision."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee6a8e80-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-07-22/ch517"},"text":"July 22, 1937, ch. 517","children":[],"tail":", title III, § 35, as added "},{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s342"},"text":"Pub. L. 87–128, title III, § 342","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/318"},"text":"75 Stat. 318","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee6a8e81-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee6a8e82-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee6a8e83-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/s342"},"text":"section 342 of Pub. L. 87–128","children":[],"tail":" is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1990a"},"text":"section 1990a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee6a8e84-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idee6a8e85-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1961-10-15"},"text":"Oct. 15, 1961","children":[],"tail":", by former section 300.1 of Title 6, Code of Federal Regulations, see Effective Date note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
