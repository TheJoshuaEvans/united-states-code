{"tag":"section","attrib":{"id":"idee33c6f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s493"},"text":null,"children":[{"tag":"num","attrib":{"value":"493"},"text":"§ 493.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of provisions; prosecution of cases","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture is authorized and directed to enforce this chapter. It is made the duty of all United States attorneys to prosecute cases arising under this chapter, subject to the supervision and control of the Department of Justice.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee33c6f4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-03/ch309/s2"},"text":"Mar. 3, 1927, ch. 309, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1355"},"text":"44 Stat. 1355","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
