{"tag":"section","attrib":{"id":"idefde90b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204"},"text":null,"children":[{"tag":"num","attrib":{"value":"6204"},"text":"§ 6204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required terms in orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefde90b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An order issued by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6203/a"},"text":"section 6203(a) of this title","children":[],"tail":" shall contain the terms and conditions described in this section and, except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6205"},"text":"section 6205 of this title","children":[],"tail":", no other terms or conditions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefde90b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lime Board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such order shall provide for the establishment of a Lime Board as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefde90b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall be composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefde90ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 members who are producers and who are not exempt from an assessment under subsection (d)(5)(A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 members who are importers and who are not exempt from an assessment under subsection (d)(5)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member appointed from the general public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde90bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and nomination","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefde90be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint the members of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The 3 members who are producers shall be appointed from individuals nominated by lime producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The 3 members who are importers shall be appointed from individuals nominated by lime importers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The public representative shall be appointed from nominations of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to nominate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If producers and importers fail to nominate individuals for appointment, the Secretary may appoint members on a basis provided for in the order. If the Board fails to nominate a public representative, such member may be appointed by the Secretary without a nomination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an initial Board from among nominations solicited by the Secretary. For the purpose of obtaining nominations for the members of the initial Board described in paragraph (1), the Secretary shall perform the functions of the Board under this subsection as the Secretary determines necessary and appropriate. The Secretary shall terminate the initial Board established under this subsection as soon as practicable after ","children":[{"tag":"date","attrib":{"date":"1993-12-14"},"text":"December 14, 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The producer and importer representation on the Board shall be allocated on the basis of 2 producer members and 1 importer member from the district east of the Mississippi River and 1 producer member and 2 importer members from the district west of the Mississippi River.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde90c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall appoint an alternate for each member of the Board. An alternate shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefde90c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appointed in the same manner as the member for whom such individual is an alternate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve on the Board if such member is absent from a meeting or is disqualified under paragraph (5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde90c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The initial members of the Board appointed under the amended order shall serve a term of 30 months. Subsequent appointments to the Board shall be for a term of 3 years, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefde90c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 members shall be appointed for a term of 1 year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 members shall be appointed for a term of 2 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 members shall be appointed for a term of 3 years;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as designated by the Secretary at the time of appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde90cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replacement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a member or alternate of the Board who was appointed as a producer, importer, or public representative ceases to belong to the group for which such member was appointed, such member or alternate shall be disqualified from serving on the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde90cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members and alternates of the Board shall serve without pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde90ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"While away from their homes or regular places of business in the performance of duties for the Board, members and alternates shall be allowed travel expenses, including a per diem allowance in lieu of subsistence, in the same manner as persons employed intermittently in Government service are allowed travel expenses under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde90cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers and duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefde90d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer orders issued by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6203/a"},"text":"section 6203(a) of this title","children":[],"tail":", and amendments to such orders, in accordance with their terms and provisions and consistent with this chapter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe rules and regulations to effectuate the terms and provisions of such orders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive, investigate, and report to the Secretary accounts of violations of such orders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the Secretary with respect to amendments that should be made to such orders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/b/8/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employ a manager and staff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefde90d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budgets and plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such order shall provide for periodic budgets and plans as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefde90d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budgets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall prepare and submit to the Secretary a budget (on a fiscal period basis determined by the Secretary) of the anticipated expenses and disbursements of the Board in the administration of the order, including probable costs of research, promotion, and consumer information. A budget shall take effect on the approval of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde90d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each budget shall include a plan for research, promotion, and consumer information regarding limes. A plan under this paragraph shall take effect on the approval of the Secretary. The Board may enter into contracts and agreements, with the approval of the Secretary, for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefde90d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and carrying out of such plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment of the cost of such plan with funds collected pursuant to this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefde90da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such order shall provide for the imposition and collection of assessments with regard to the production and importation of limes as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefde90db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The assessment rate shall not exceed $.01 per pound of limes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde90dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection by first handlers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (4), the first handler of limes shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefde90dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for the collection from the producer, and payment to the Board, of assessments under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a separate record of the limes of each producer whose limes are so handled, including the limes owned by the handler.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde90df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer-handlers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (2), a producer-handler shall be considered the first handler of limes produced by such producer-handler.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde90e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The assessment on imported limes shall be paid by the importer at the time of entry into the United States and shall be remitted to the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde90e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" De minimis exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following persons are exempt from an assessment under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefde90e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a producer who produces less than 200,000 pounds of limes per year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a producer-handler who produces and handles less than 200,000 pounds of limes per year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an importer who imports less than 200,000 pounds of limes per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde90e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claiming an exemption","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To claim an exemption under paragraph (5) for a particular year, a person shall submit an application to the Board—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefde90e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stating the basis for such exemption; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certifying that such person will not exceed the limitation required for such exemption in such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefde90e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of assessments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefde90e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such order shall provide that funds paid to the Board as assessments under subsection (d)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefde90ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may be used by the Board to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefde90eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay for research, promotion, and consumer information described in the budget of the Board under subsection (c) and for other expenses incurred by the Board in the administration of an order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefde90ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay such other expenses for the administration, maintenance, and functioning of the Board as may be authorized by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefde90ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/e/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fund a reserve established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6205/4"},"text":"section 6205(4) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be used to pay the expenses incurred by the Secretary, including salaries and expenses of Government employees in implementing and administering the order, except as provided in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde90ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referenda","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such order shall provide that the Board shall reimburse the Secretary, from assessments collected under subsection (d), for any expenses incurred by the Secretary in conducting referenda under this chapter, except for the salaries of Government employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefde90f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False claims","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such order shall provide that any promotion funded with assessments collected under subsection (d) may not make—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefde90f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any false or unwarranted claims on behalf of limes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde90f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any false or unwarranted statements with respect to the attributes or use of any product that competes with limes for sale in commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefde90f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such order shall provide that funds collected by the Board under this chapter through assessments authorized by this chapter may not, in any manner, be used for the purpose of influencing legislation or governmental policy or action, except for making recommendations to the Secretary as provided for in this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefde90f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Books, records, and reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefde90f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By the Board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such order shall require the Board—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefde90f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain books and records with respect to the receipt and disbursement of funds received by the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to submit to the Secretary from time to time such reports as the Secretary may require for appropriate accounting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to submit to the Secretary at the end of each fiscal year a complete audit report regarding the activities of the Board during such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde90f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By others","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"So that information and data will be available to the Board and the Secretary that is appropriate or necessary for the effectuation, administration, or enforcement of this chapter (or any order or regulation issued under this chapter), such order shall require handlers, producer-handlers, and importers who are responsible for the collection, payment, or remittance of assessments under subsection (d)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefde90fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain and make available for inspection by the employees of the Board and the Secretary such books and records as may be required by the order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde90fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to file, at the times, in the manner, and having the content prescribed by the order, reports regarding the collection, payment, or remittance of such assessments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefde90fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefde90fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such order shall require that all information obtained pursuant to subsection (h)(2) shall be kept confidential by all officers and employees of the Department and of the Board. Only such information as the Secretary considers relevant shall be disclosed to the public and only in a suit or administrative hearing, brought at the request of the Secretary or to which the Secretary or any officer of the United States is a party, involving the order with respect to which the information was furnished or acquired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde90fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subsection prohibits—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefde90ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuance of general statements based on the reports of a number of handlers, producer-handlers, and importers subject to an order, if the statements do not identify the information furnished by any person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde9100-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the publication by direction of the Secretary, of the name of any person violating an order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6203/a"},"text":"section 6203(a) of this title","children":[],"tail":", together with a statement of the particular provisions of the order violated by such person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefde9101-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6204/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to authorize the withholding of information from Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefde9102-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1955"},"text":"Pub. L. 101–624, title XIX, § 1955","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3872"},"text":"104 Stat. 3872","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tVIII/s805/1"},"text":"Pub. L. 102–237, title VIII, § 805(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1882"},"text":"105 Stat. 1882","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/194/s4"},"text":"Pub. L. 103–194, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2295"},"text":"107 Stat. 2295","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefde9103-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefde9104-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefde9105-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(1)(A), (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/194/s4/a/1"},"text":"Pub. L. 103–194, § 4(a)(1)","children":[],"tail":", (2), substituted “3” for “7”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/194/s4/a/3"},"text":"Pub. L. 103–194, § 4(a)(3)","children":[],"tail":", inserted at end “The Secretary shall terminate the initial Board established under this subsection as soon as practicable after "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"December 14, 1993","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/194/s4/a/4"},"text":"Pub. L. 103–194, § 4(a)(4)","children":[],"tail":", added subpar. (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/194/s4/b/1"},"text":"Pub. L. 103–194, § 4(b)(1)","children":[],"tail":", substituted “The initial members of the Board appointed under the amended order shall serve a term of 30 months. Subsequent appointments to the Board shall be for a term of 3 years, except that—” for “Members of the Board shall be appointed for a term of 3 years. Of the members first appointed—”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/194/s4/b/2"},"text":"Pub. L. 103–194, § 4(b)(2)","children":[],"tail":", substituted “2” for “3”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/194/s4/b/3"},"text":"Pub. L. 103–194, § 4(b)(3)","children":[],"tail":", substituted “2” for “4” before “members”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/194/s4/b/4"},"text":"Pub. L. 103–194, § 4(b)(4)","children":[],"tail":", substituted “3” for “4” before “members”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/194/s4/c"},"text":"Pub. L. 103–194, § 4(c)","children":[],"tail":", substituted “200,000” for “35,000”, wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (e)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “Government employees” for “government employees”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
