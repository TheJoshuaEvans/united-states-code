{"tag":"section","attrib":{"id":"ideff8cf75-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7001"},"text":null,"children":[{"tag":"num","attrib":{"value":"7001"},"text":"§ 7001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conforming amendments relating to National Appeals Division","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff8cf76-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7001/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decisions of State, county, and area committees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff8cf77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7001/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of subsection","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff8cf78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7001/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), this subsection shall apply only with respect to functions of the Farm Service Agency or the Commodity Credit Corporation that are under the jurisdiction of a State, county, or area committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s590h/b/5"},"text":"section 590h(b)(5) of title 16","children":[],"tail":" or an employee of such a committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff8cf79-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7001/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection does not apply to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff8cf7a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7001/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a function performed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2008k"},"text":"section 2008k of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff8cf7b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7001/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a function performed under a conservation program administered by the Natural Resources Conservation Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cf7c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7001/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finality","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each decision of a State, county, or area committee (or an employee of such a committee) covered by paragraph (1) that is made in good faith in the absence of misrepresentation, false statement, fraud, or willful misconduct shall be final not later than 90 days after the date of filing of the application for benefits, unless the decision, before the end of the 90-day period, is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff8cf7d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7001/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appealed under this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff8cf7e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7001/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modified by the Administrator of the Farm Service Agency or the Executive Vice President of the Commodity Credit Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cf7f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7001/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the decision of the State, county, or area committee has become final under paragraph (2), no action may be taken by the Farm Service Agency, the Commodity Credit Corporation, or a State, county, or area committee to recover amounts found to have been disbursed as a result of a decision in error unless the participant had reason to believe that the decision was erroneous.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cf80-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7001/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, a reference to the “Farm Service Agency” includes any other office, agency, or administrative unit of the Department assigned the functions authorized for the Farm Service Agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6932"},"text":"section 6932 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff8cf81-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7001/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":", (c) Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff8cf82-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s281"},"text":"Pub. L. 103–354, title II, § 281","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3233"},"text":"108 Stat. 3233","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1613/i"},"text":"Pub. L. 107–171, title I, § 1613(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/221"},"text":"116 Stat. 221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideff8cf83-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideff8cf84-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideff8cf85-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/s281"},"text":"section 281 of Pub. L. 103–354","children":[],"tail":". Subsecs. (b) and (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/s281"},"text":"section 281 of Pub. L. 103–354","children":[],"tail":" repealed sections 1433e and 1983b of this title, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideff8cf86-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s1613/i/1"},"text":"Pub. L. 107–171, § 1613(i)(1)","children":[],"tail":", (2), designated existing provisions as subpar. (A), inserted heading, substituted “Except as provided in subparagraph (B), this subsection” for “This subsection” and “Farm Service Agency” for “Consolidated Farm Service Agency”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s1613/i/3"},"text":"Pub. L. 107–171, § 1613(i)(3)","children":[],"tail":", inserted “, before the end of the 90-day period,” after “unless the decision” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B), (3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s1613/i/1"},"text":"Pub. L. 107–171, § 1613(i)(1)","children":[],"tail":", substituted “Farm Service Agency” for “Consolidated Farm Service Agency” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
