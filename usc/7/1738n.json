{"tag":"section","attrib":{"id":"ideef9aec4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738n"},"text":null,"children":[{"tag":"num","attrib":{"value":"1738n"},"text":"§ 1738n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations with Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President shall consult with the appropriate congressional committees on a periodic basis to review the operation of the Facility under this subchapter and the eligibility of countries for benefits from the Facility under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideef9aec5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title VI, § 615, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIII/s331"},"text":"Pub. L. 102–237, title III, § 331","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1858"},"text":"105 Stat. 1858","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
