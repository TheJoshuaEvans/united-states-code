{"tag":"section","attrib":{"id":"idefef5a2a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6912"},"text":null,"children":[{"tag":"num","attrib":{"value":"6912"},"text":"§ 6912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary to delegate transferred functions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefef5a2b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefef5a2c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6912/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary may delegate to any agency, office, officer, or employee of the Department the authority to perform any function transferred to the Secretary under section 6911(a) ","children":[{"tag":"ref","attrib":{"idref":"fn002317"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002317"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title or any other function vested in the Secretary as of "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"October 13, 1994","children":[],"tail":". The authority provided in the preceding sentence includes the authority to establish, consolidate, alter, or discontinue any agency, office, or other administrative unit of the Department."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefef5a2d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6912/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition on authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The delegation authority provided by paragraph (1) shall be subject to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefef5a2e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6912/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 6942, 6971(f), 6993, and 2204e of this title and subsections (a) and (b)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6981"},"text":"section 6981 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefef5a2f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6912/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 5692 and 5693 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefef5a30-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6912/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s590h/b/5"},"text":"section 590h(b)(5) of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefef5a31-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-benefit analysis required for name change","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefef5a32-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6912/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Analysis required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the Secretary shall conduct a cost-benefit analysis before changing the name of any agency, office, division, or other unit of the Department to ensure that the benefits to be derived from changing the name of the agency, office, division, or other unit outweigh the expense of executing the name change.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefef5a33-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6912/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply with respect to any name change required or authorized by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefef5a34-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6912/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comment on proposed reorganization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent that the implementation of the authority provided to the Secretary by this chapter to reorganize the Department involves the creation of new agencies or offices within the Department or the delegation of major functions or major groups of functions to any agency or office of the Department (or the officers or employees of such agency or office), the Secretary shall, to the extent considered practicable by the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefef5a35-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6912/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give appropriate advance public notice of the proposed reorganization action or delegation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefef5a36-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6912/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" afford appropriate opportunity for interested parties to comment on the proposed reorganization action or delegation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefef5a37-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6912/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency transfer of records, property, personnel, and funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefef5a38-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6912/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related transfers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), as part of the transfer or delegation of a function of the Department made or authorized by this chapter, the Secretary may transfer within the Department—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefef5a39-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6912/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any of the records, property, or personnel affected by the transfer or delegation of the function; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefef5a3a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6912/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unexpended balances (available or to be made available for use in connection with the transferred or delegated function) of appropriations, allocations, or other funds of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefef5a3b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6912/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable law relating to funds transfer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1531"},"text":"Section 1531 of title 31","children":[],"tail":" shall apply to any transfer of funds under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefef5a3c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6912/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exhaustion of administrative appeals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, a person shall exhaust all administrative appeal procedures established by the Secretary or required by law before the person may bring an action in a court of competent jurisdiction against—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefef5a3d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6912/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefef5a3e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6912/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefef5a3f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6912/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency, office, officer, or employee of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefef5a40-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s212"},"text":"Pub. L. 103–354, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3210"},"text":"108 Stat. 3210","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7511/c/27"},"text":"Pub. L. 110–234, title VII, § 7511(c)(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1270"},"text":"122 Stat. 1270","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7511(c)(27), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2031.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefef5a41-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefef5a42-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefef5a43-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6911"},"text":"Section 6911 of this title","children":[],"tail":", referred to in subsec. (a)(1), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12414/a/1"},"text":"Pub. L. 115–334, title XII, § 12414(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4981"},"text":"132 Stat. 4981","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (b)(2), (c), and (d)(1), was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3209"},"text":"108 Stat. 3209","children":[],"tail":", known as the Department of Agriculture Reorganization Act of 1994. For complete classification of title II to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6901"},"text":"section 6901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"no