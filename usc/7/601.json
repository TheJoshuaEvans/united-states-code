ch. 296","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/50/246"},"text":"50 Stat. 246","children":[],"tail":", provided as follows: "},{"tag":"quotedContent","attrib":{},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The following provisions of the Agricultural Adjustment Act, as amended, not having been intended for the control of the production of agricultural commodities, and having been intended to be effective irrespective of the validity of any other provision of that Act are expressly affirmed and validated, and are reenacted without change except as provided in section 2:","children":[],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 1 (relating to the declaration of emergency [this section]):","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 2 (relating to declaration of policy [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s602"},"text":"section 602 of this title","children":[],"tail":"]):"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 8a(5), (6), (7), (8), and (9) (relating to violations and enforcement [section 608a(5), (6), (7), (8), and (9) of this title]);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 8b (relating to marketing agreements [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s608b"},"text":"section 608b of this title","children":[],"tail":"]);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 8c (relating to orders [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s608c"},"text":"section 608c of this title","children":[],"tail":"]);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 8d (relating to books and records [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s608d"},"text":"section 608d of this title","children":[],"tail":"]);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 8e (relating to determination of base period [former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s608e"},"text":"section 608e of this title","children":[],"tail":"]);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"“(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 10(a), (b)(2), (c), (f), (g), (h), and (i) (miscellaneous provisions [section 610(a), (b)(2), (c), (f), (g), (h), and (i) of this title]);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12(a) and (c) (relating to appropriation and expenses [section 612(a) and (c) of this title]);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"“(j)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 14 (relating to separability [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s614"},"text":"section 614 of this title","children":[],"tail":"]);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"“(k)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 22 (relating to imports [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s624"},"text":"section 624 of this title","children":[],"tail":"])."}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“Sec. 2.","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The following provisions, reenacted in section I of this act, are amended as follows: * * * [sections 601, 602(1), 608a(6), 608c(5)(B)(d), (6)(B), (6)(B)(18), (19), 610(c), (f), 612(a) of this title].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 2 of act ","children":[{"tag":"date","attrib":{"date":"1937-06-03"},"text":"June 3, 1937","children":[],"tail":", also added subsec. (j) to section 610."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 2 of act ","children":[{"tag":"date","attrib":{"date":"1937-06-03"},"text":"June 3, 1937","children":[],"tail":", was amended by "},{"tag":"ref","attrib":{"href":"/us/act/1937-08-05/ch567"},"text":"act Aug. 5, 1937, ch. 567","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/563"},"text":"50 Stat. 563","children":[],"tail":", which amending act provided for amendments to subsecs. (2) and (6) of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s608c"},"text":"section 608c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
