{"tag":"section","attrib":{"id":"idf004b60e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7317"},"text":null,"children":[{"tag":"num","attrib":{"value":"7317"},"text":"§ 7317.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel matters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf004b60f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7317/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Commission shall serve without compensation, but shall be allowed travel expenses including per diem in lieu of subsistence, as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":", when engaged in the performance of Commission duties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf004b610-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7317/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf004b611-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7317/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall appoint a staff director, who shall be paid at a rate not to exceed the maximum rate of basic pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of title 5","children":[],"tail":", and such professional and clerical personnel as may be reasonable and necessary to enable the Commission to carry out its duties under this subchapter without regard to the provisions of title 5 governing appointments in the competitive service, and without regard to the provisions of chapter 51 and subchapter III of chapter 53 of such title, or any other provision of law, relating to the number, classification, and General Schedule rates."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf004b612-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7317/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No employee appointed under this subsection (other than the staff director) may be compensated at a rate to exceed the maximum rate applicable to level GS–15 of the General Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf004b613-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7317/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detailed personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the request of the chairperson of the Commission, the head of any department or agency of the Federal Government is authorized to detail, without reimbursement, any personnel of the department or agency to the Commission to assist the Commission in carrying out its duties under this section. The detail of any individual may not result in the interruption or loss of civil service status or other privilege of the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf004b614-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s187"},"text":"Pub. L. 104–127, title I, § 187","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/941"},"text":"110 Stat. 941","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf004b615-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf004b616-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf004b617-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in subsec. (b), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf004b618-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf004b619-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Maximum Rate Under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"5 U.S.C. 5376","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"For reference to maximum rate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of Title 5","children":[],"tail":", Government Organization and Employees, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/372/s2/d/3"},"text":"section 2(d)(3) of Pub. L. 110–372","children":[],"tail":", set out as an Effective Date of 2008 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
