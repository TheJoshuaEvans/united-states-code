{"tag":"section","attrib":{"id":"idf02adc4e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002"},"text":null,"children":[{"tag":"num","attrib":{"value":"8002"},"text":"§ 8002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation funding and information management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf02adc4f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funds for administrative costs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adc50-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture, acting through the Farm Service Agency, may use not more than $55,000,000 of funds of the Commodity Credit Corporation to cover administrative costs associated with the implementation of title I and the amendments made by that title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adc51-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The funds referred to in paragraph (1) shall remain available to the Secretary until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adc52-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Set-aside","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount specified in paragraph (1), the Secretary shall use not less than $5,000,000, but not more than $8,000,000, to carry out subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adc53-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information management","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adc54-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall develop a comprehensive information management system, using appropriate technologies, to be used in implementing the programs administered by the Federal Crop Insurance Corporation and the Farm Service Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adc55-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information management system developed under this subsection shall be designed to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02adc56-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve access by agricultural producers to programs described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adc57-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve and protect the integrity of the information collected;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adc58-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the needs of the agencies that require the data in the administration of their programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adc59-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the timeliness of the collection of the information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adc5a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute to the elimination of duplication of information collection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adc5b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lower the overall cost to the Department of Agriculture for information collection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adc5c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieve such other goals as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adc5d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reconciliation of current information management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that all current information of the Federal Crop Insurance Corporation and the Farm Service Agency is combined, reconciled, redefined, and reformatted in such a manner so that the agencies can use the common information management system developed under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adc5e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for development of system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall enter into an agreement or contract with a non-Federal entity to assist the Secretary in the development of the information management system. The Secretary shall give preference in entering into an agreement or contract to entities that have—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02adc5f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior experience with the information and management systems of the Federal Crop Insurance Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adc60-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborated with the Corporation in the development of the identification procedures required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1515/f"},"text":"section 1515(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adc61-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information collected using the information management system developed under this subsection may be made available to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02adc62-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal agency that requires the information to carry out the functions of the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adc63-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any approved insurance provider, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1502/b"},"text":"section 1502(b) of this title","children":[],"tail":", with respect to producers insured by the approved insurance provider."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adc64-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not interfere with, or delay, existing agreements or requests for proposals of the Federal Crop Insurance Corporation or the Farm Service Agency regarding the information management activities known as data mining or data warehousing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adc65-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8002/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts made available under subsection (a)(3), there are authorized to be appropriated such sums as are necessary to carry out subsection (b) for each of fiscal years 2003 through 2008.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf02adc66-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10706"},"text":"Pub. L. 107–171, title X, § 10706","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/519"},"text":"116 Stat. 519","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf02adc67-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf02adc68-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf02adc69-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title I and the amendments made by that title, referred to in subsec. (a)(1), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/143"},"text":"116 Stat. 143","children":[],"tail":", which is classified principally to this chapter. For complete classification of title I to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7901"},"text":"section 7901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
