{"tag":"section","attrib":{"id":"ideff1a44f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924"},"text":null,"children":[{"tag":"num","attrib":{"value":"6924"},"text":"§ 6924.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food Loss and Waste Reduction Liaison","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff1a450-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a Food Loss and Waste Reduction Liaison to coordinate Federal, State, local, and nongovernmental programs, and other efforts, to measure and reduce the incidence of food loss and waste in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a451-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Food Loss and Waste Reduction Liaison shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff1a452-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate food loss and waste reduction efforts within the Department of Agriculture and with other Federal agencies, including the Environmental Protection Agency and the Food and Drug Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a453-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support and promote Federal programs to measure and reduce the incidence of food loss and waste and increase food recovery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a454-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information to, and serve as a resource for, entities engaged in food loss and waste reduction and food recovery, including information about the availability of, and eligibility requirements for, participation in Federal, State, local, and nongovernmental programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a455-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" raise awareness of the liability protections afforded under the Bill Emerson Good Samaritan Food Donation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1791"},"text":"42 U.S.C. 1791","children":[],"tail":") to persons engaged in food loss and waste reduction and food recovery; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a456-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations with respect to expanding innovative food recovery models and reducing the incidence of food loss and waste.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a457-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of carrying out the duties under subsection (b), the Food Loss and Waste Reduction Liaison may enter into contracts or cooperative agreements with the research centers of the Research, Education, and Economics mission area, institutions of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":"), or nonprofit organizations for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff1a458-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of educational materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a459-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of workshops and courses; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a45a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of research on best practices with respect to food loss and waste reduction and food recovery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a45b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study on food waste","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct a study, in consultation with the Food Loss and Waste Reduction Liaison, to evaluate and determine—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff1a45c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods of measuring food waste;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a45d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards for the volume of food waste;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a45e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" factors that contribute to food waste;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a45f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost and volume of food loss;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a460-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of existing liability protections afforded under the Bill Emerson Good Samaritan Food Donation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1791"},"text":"42 U.S.C. 1791","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a461-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures to ensure that programs contemplated, undertaken, or funded by the Department of Agriculture do not disrupt existing food waste recovery and disposal efforts by commercial, marketing, or business relationships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a462-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff1a463-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", the Food Loss and Waste Liaison shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that describes the results of the study conducted under subsection (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a464-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of the submission of the report under paragraph (1), the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that contains, with respect to the preceding year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a465-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the quantity of food waste during such year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a466-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6924/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the food waste reduction and loss prevention activities carried out or led by the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff1a467-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s224"},"text":"Pub. L. 103–354, title II, § 224","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12504"},"text":"Pub. L. 115–334, title XII, § 12504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4987"},"text":"132 Stat. 4987","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
