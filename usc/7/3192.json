{"tag":"section","attrib":{"id":"idef9e2c64-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3192"},"text":null,"children":[{"tag":"num","attrib":{"value":"3192"},"text":"§ 3192.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"When used in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9e2c65-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3192/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “eligible institution” means an accredited school or college of veterinary medicine or a State agricultural experiment station that conducts animal health and disease research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9e2c66-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3192/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “dean” means the dean of an accredited school or college of veterinary medicine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9e2c67-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3192/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “director” means the director of a State agricultural experiment station which qualifies as an eligible institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9e2c68-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3192/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “animal health research capacity” means the capacity of an eligible institution t