{"tag":"section","attrib":{"id":"ideeb48f4e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471j"},"text":null,"children":[{"tag":"num","attrib":{"value":"1471j"},"text":"§ 1471j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A person that disposes of any feed made available to a livestock producer under this subchapter other than as authorized by the Secretary shall be (1) subject to a civil penalty equal to the market value of the feed involved, to be recovered by the Secretary in a civil suit brought for that purpose, and (2) guilty of a misdemeanor and, on conviction thereof, subject to a fine of not more than $1,000, or imprisonment for not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideeb48f4f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-31/ch792"},"text":"Oct. 31, 1949, ch. 792","children":[],"tail":", title VI, § 612, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/387/tI/s101/a"},"text":"Pub. L. 100–387, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-11"},"text":"Aug. 11, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/931"},"text":"102 Stat. 931","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideeb48f50-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideeb48f51-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideeb48f52-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null