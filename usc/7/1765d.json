{"tag":"section","attrib":{"id":"ideefc1f8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1765d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1765d"},"text":"§ 1765d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon the request of the Secretary of Agriculture, the Secretary of State may use the authorities contained in the Foreign Service Buildings Act, 1926 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s292"},"text":"22 U.S.C. 292","children":[],"tail":" et seq.], to acquire sites and buildings, including living quarters, for the purpose of establishing United States Agricultural Trade Offices."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideefc1f90-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-28/ch1041"},"text":"Aug. 28, 1954, ch. 1041","children":[],"tail":", title VI, § 605D, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/501/tIV/s401/1"},"text":"Pub. L. 95–501, title IV, § 401(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-21"},"text":"Oct. 21, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1690"},"text":"92 Stat. 1690","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideefc1f91-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideefc1f92-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideefc1f93-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Service Buildings Act, 1926, as amended, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-07/ch250"},"text":"act May 7, 1926, ch. 250","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/403"},"text":"44 Stat. 403","children":[],"tail":", which is classified generally to chapter 8 (§ 292 et seq.) of Title 22, Foreign Relations and Intercourse. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s299"},"text":"section 299 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
