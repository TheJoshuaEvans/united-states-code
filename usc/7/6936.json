{"tag":"section","attrib":{"id":"ideff4145a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936"},"text":null,"children":[{"tag":"num","attrib":{"value":"6936"},"text":"§ 6936.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Natural Resources Conservation Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff4145b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to establish and maintain within the Department a Natural Resources Conservation Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff4145c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary establishes the Natural Resources Conservation Service under subsection (a), the Secretary is authorized to assign to the Service jurisdiction over the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff4145d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Water Bank Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1301"},"text":"16 U.S.C. 1301","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff4145e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Title XII of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3801"},"text":"16 U.S.C. 3801","children":[],"tail":" et seq.), except subchapter B of chapter 1 of subtitle D of such title ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3831"},"text":"16 U.S.C. 3831","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff4145f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Salinity control measures under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1592/c"},"text":"section 1592(c) of title 43","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41460-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Farms for the Future Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4201"},"text":"7 U.S.C. 4201","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Public Law 101–624","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41461-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other functions as the Secretary considers appropriate, except functions under subchapter B of chapter 1 of subtitle D of title XII of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3831"},"text":"16 U.S.C. 3831","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff41462-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special concurrence requirements for certain functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the programs specified in paragraphs (1) and (3) of subsection (b), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff41463-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acting on the recommendations of the Natural Resources Conservation Service, with the concurrence of the Farm Service Agency, issue regulations to carry out such programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41464-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the Natural Resources Conservation Service, in establishing policies, priorities, and guidelines for each such program, does so with the concurrence of the Farm Service Agency at national, State, and local levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41465-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that, in reaching such concurrence at the local level, the Natural Resources Conservation Service works in cooperation with Soil and Water Conservation Districts or similar organizations established under State law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41466-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that officials of county and area committees established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s590h/b/5"},"text":"section 590h(b)(5) of title 16","children":[],"tail":" meet annually with officials of such Districts or similar organizations to consider local conservation priorities and guidelines; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41467-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take steps to ensure that the concurrence process does not interfere with the effective delivery of such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff41468-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Federal and non-Federal employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff41469-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the implementation of functions assigned to the Natural Resources Conservation Service, the Secretary may use interchangeably in local offices of the Service both Federal employees of the Department and non-Federal employees of county and area committees established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s590h/b/5"},"text":"section 590h(b)(5) of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff4146a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), no personnel action (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2302/a/2/A"},"text":"section 2302(a)(2)(A) of title 5","children":[],"tail":") may be taken with respect to a Federal employee unless such action is taken by another Federal employee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff4146b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsections (c) and (d) of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff4146c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A reference to the “Natural Resources Conservation Service” includes any other office, agency, or administrative unit of the Department assigned the functions authorized for the Natural Resources Conservation Service under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff4146d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A reference to the “Farm Service Agency” includes any other office, agency, or administrative unit of the Department assigned the functions authorized for the Farm Service Agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6932"},"text":"section 6932 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff4146e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff4146f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Field offices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff41470-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not close any field office of the Natural Resources Conservation Service unless, not later than 30 days before the date of the closure, the Secretary submits to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a notification of the closure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41471-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not permanently relocate any field-based employees of the Natural Resources Conservation Service or the rural development mission area if doing so would result in a field office of the Natural Resources Conservation Service or the rural development mission area with 2 or fewer employees, unless, not later than 30 days before the date of the permanent relocation, the Secretary submits to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a notification of the permanent relocation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41472-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6936/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements under paragraphs (1) and (2) shall cease to be effective on ","children":[{"tag":"date","attrib":{"date":"2023-09-30"},"text":"September 30, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff41473-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s228"},"text":"Pub. L. 103–354, title II, § 228","children":[],"tail":", formerly § 246, "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3223"},"text":"108 Stat. 3223","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIII/s336/a/2/D"},"text":"Pub. L. 104–127, title III, § 336(a)(2)(D)","children":[],"tail":", (b)(2)(B), (c)(3), (d)(2), "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1005"},"text":"110 Stat. 1005","children":[],"tail":", 1006; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVIII/s8002/c"},"text":"Pub. L. 107–171, title VIII, § 8002(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/473"},"text":"116 Stat. 473","children":[],"tail":"; renumbered § 228 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII"},"text":"Pub. L. 115–334, title XII","children":[],"tail":", §§ 12404(b)(1), 12410(a)–(c)(1), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4975"},"text":"132 Stat. 4975","children":[],"tail":", 4977, 4978.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideff41474-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideff41475-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideff41476-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Water Bank Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/559"},"text":"Pub. L. 91–559","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-19"},"text":"Dec. 19, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1468"},"text":"84 Stat. 1468","children":[],"tail":", which is classified generally to chapter 29 (§ 1301 et seq.) of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1301"},"text":"section 1301 of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Food Security Act of 1985, referred to in subsec. (b)(2), (5), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1354"},"text":"99 Stat. 1354","children":[],"tail":". Title XII of the Act is classified principally to chapter 58 (§ 3801 et seq.) of Title 16, Conservation. Subchapter B of chapter 1 of subtitle D of title XII of the Act is classified generally to subpart B (§ 3831 et seq.) of part I of subchapter IV of chapter 58 of Title 16. For complete classification of this Act to the Code, see Short Title of 1985 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1281"},"text":"section 1281 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Farms for the Future Act of 1990, referred to in subsec. (b)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIV"},"text":"Pub. L. 101–624, title XIV","children":[],"tail":", ch. 2, §§ 1465–1470B, "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3616-3619"},"text":"104 Stat. 3616–3619","children":[],"tail":", as amended, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4201"},"text":"section 4201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideff41477-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly part of subtitle E of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" and classified as "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6962"},"text":"section 6962 of this title","children":[],"tail":", prior to being moved so as to appear at the end of subtitle B of title II of "},{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12410/c/1/B"},"text":"Pub. L. 115–334, title XII, § 12410(c)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4978"},"text":"132 Stat. 4978","children":[],"tail":", and editorially reclassified as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/s228"},"text":"section 228 of Pub. L. 103–354","children":[],"tail":". Subsec. (f) of "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/s228"},"text":"section 228 of Pub. L. 103–354","children":[],"tail":" amended sections 2001, 2002, 2005, and 3862 of Title 16, Conservation, and repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s590e"},"text":"section 590e of Title 16","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The authorities provided by each provision of, and each amendment made by, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"Sept. 30, 2023","children":[],"tail":", to continue, and authorities to be carried out, until the later of "},{"tag":"date","attrib":{"date":"2024-09-30"},"text":"Sept. 30, 2024","children":[],"tail":", or the date specified in the provision of, or amendment made by, "},{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/a"},"text":"section 102(a) of Pub. L. 118–22","children":[],"tail":", set out in an Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideff41478-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12410/b/1/A"},"text":"Pub. L. 115–334, § 12410(b)(1)(A)","children":[],"tail":", (B), redesignated pars. (3) and (4) as (2) and (3), respectively, and struck out former par. (2) which read as follows: “The forest land enhancement program under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2103"},"text":"section 2103 of title 16","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12410/b/1/B"},"text":"Pub. L. 115–334, § 12410(b)(1)(B)","children":[],"tail":", (C), redesignated par. (5) as (4) and inserted “; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Public Law 101–624","children":[],"tail":"” after “note”. Former par. (4) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12410/b/1/B"},"text":"Pub. L. 115–334, § 12410(b)(1)(B)","children":[],"tail":", (D), redesignated par. (6) as (5) and substituted “3831 et seq.” for “3831–3836”. Former par. (5) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12410/b/2"},"text":"Pub. L. 115–334, § 12410(b)(2)","children":[],"tail":", substituted “paragraphs (1) and (3) of subsection (b)” for “paragraphs (1), (2), and (4) of subsection (b) and the program under subchapter C of chapter 1 of subtitle D of title XII of the Food Security Act of 1985 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3837–383"},"text":"16 U.S.C. 3837–383","children":[],"tail":"7f)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12404/b/1/A"},"text":"Pub. L. 115–334, § 12404(b)(1)(A)","children":[],"tail":", substituted “Farm” for “Consolidated Farm”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12404/b/1/B"},"text":"Pub. L. 115–334, § 12404(b)(1)(B)","children":[],"tail":", substituted “Farm” for “Consolidated Farm” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12410/a"},"text":"Pub. L. 115–334, § 12410(a)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" substituted “forest land enhancement program” for “forestry incentive program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s336/d/2/A"},"text":"Pub. L. 104–127, § 336(d)(2)(A)","children":[],"tail":", redesignated par. (3) as (1) and struck out former par. (1) which read as follows: “The rural environmental conservation program under title X of the Agricultural Act of 1970 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1501"},"text":"16 U.S.C. 1501","children":[],"tail":" et seq.).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s336/b/2/B"},"text":"Pub. L. 104–127, § 336(b)(2)(B)","children":[],"tail":", (d)(2)(A)(ii), redesignated par. (4) as (2) and struck out former par. (2) which read as follows: “The Great Plains Conservation Program under section 16(b) of the Soil Conservation and Domestic Allotment Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s590p/b"},"text":"16 U.S.C. 590p(b)","children":[],"tail":").”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s336/d/2/A/ii"},"text":"Pub. L. 104–127, § 336(d)(2)(A)(ii)","children":[],"tail":", redesignated par. (5) as (3). Former par. (3) redesignated (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s336/c/3"},"text":"Pub. L. 104–127, § 336(c)(3)","children":[],"tail":", (d)(2)(A)(ii), redesignated par. (6) as (4) and substituted “measures” for “program”. Former par. (4) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s336/d/2/A/ii"},"text":"Pub. L. 104–127, § 336(d)(2)(A)(ii)","children":[],"tail":", redesignated par. (7) as (5). Former par. (5) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s336/a/2/D"},"text":"Pub. L. 104–127, § 336(a)(2)(D)","children":[],"tail":", (d)(2)(A)(ii), redesignated par. (8) as (6) and struck out before period at end “and the agricultural conservation program under the Soil Conservation and Domestic Allotment Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s590g"},"text":"16 U.S.C. 590g","children":[],"tail":" et seq.)”. Former par. (6) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s336/d/2/A/ii"},"text":"Pub. L. 104–127, § 336(d)(2)(A)(ii)","children":[],"tail":", redesignated pars. (7) and (8) as (5) and (6), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s336/d/2/B"},"text":"Pub. L. 104–127, § 336(d)(2)(B)","children":[],"tail":", in introductory provisions, substituted “(1), (2), and (4)” for “(2), (3), (4), and (6)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideff41479-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideff4147a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Conservation Technical Assistance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tII/s21002"},"text":"Pub. L. 117–169, title II, § 21002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2018"},"text":"136 Stat. 2018","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/169/tII/s21002"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to amounts otherwise available (and subject to subsection (b)), there are appropriated to the Secretary [of Agriculture] for fiscal year 2022, out of any money in the Treasury not otherwise appropriated, to remain available until ","children":[{"tag":"date","attrib":{"date":"2031-09-30"},"text":"September 30, 2031","children":[],"tail":" (subject to the condition that no such funds may be disbursed after "},{"tag":"date","attrib":{"date":"2031-09-30"},"text":"September 30, 2031","children":[],"tail":")—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000,000 to provide conservation technical assistance through the Natural Resources Conservation Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $300,000,000 to carry out a program to quantify carbon sequestration and carbon dioxide, methane, and nitrous oxide emissions, through which the Natural Resources Conservation Service shall collect field-based data to assess the carbon sequestration and reduction in carbon dioxide, methane, and nitrous oxide emissions outcomes associated with activities carried out pursuant to this section and use the data to monitor and track those carbon sequestration and emissions trends through the Greenhouse Gas Inventory and Assessment Program of the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The funds made available under this section are subject to the conditions that the Secretary shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enter into any agreement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is for a term extending beyond ","children":[{"tag":"date","attrib":{"date":"2031-09-30"},"text":"September 30, 2031","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under which any payment could be outlaid or funds disbursed after ","children":[{"tag":"date","attrib":{"date":"2031-09-30"},"text":"September 30, 2031","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use any other funds available to the Secretary to satisfy obligations initially made under this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interpret this section to authorize funds of the Commodity Credit Corporation for activities under this section if such funds are not expressly authorized or currently expended for such purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated to the Secretary for fiscal year 2022, out of any money in the Treasury not otherwise appropriated, $100,000,000, to remain available until ","children":[{"tag":"date","attrib":{"date":"2028-09-30"},"text":"September 30, 2028","children":[],"tail":", for administrative costs of the agencies and offices of the Department of Agriculture for costs related to implementing this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"ideff4147b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tII/s20001"},"text":"Pub. L. 117–169, title II, § 20001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2015"},"text":"136 Stat. 2015","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/169/tII/s20001"},"text":"“In this title [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8103"},"text":"section 8103 of this title","children":[],"tail":" and sections 3839aa–2, 3839aa–8, 3839aa–22, 3839aa–24, 3841, 3844, and 3871d of Title 16, Conservation, enacting provisions set out as a note above, repealing provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of this title","children":[],"tail":", and amending provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279"},"text":"section 2279 of this title","children":[],"tail":"], the term ‘Secretary’ means the Secretary of Agriculture.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
