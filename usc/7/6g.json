ag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1438"},"text":"122 Stat. 1438","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIII, § 13202(a), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2200.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idedc3c682-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idedc3c683-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idedc3c684-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idedc3c685-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s13202/a"},"text":"Pub. L. 110–246, § 13202(a)","children":[],"tail":", inserted “, and in any significant price discovery contract traded or executed on an electronic trading facility or any agreement, contract, or transaction that is treated by a derivatives clearing organization, whether registered or not registered, as fungible with a significant price discovery contract” after “elsewhere”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tI/s123/a/7/A"},"text":"Pub. L. 106–554, § 1(a)(5) [title I, § 123(a)(7)(A)]","children":[],"tail":", substituted “registered entity” for “clearinghouse and contract market”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tI/s123/a/7/B"},"text":"Pub. L. 106–554, § 1(a)(5) [title I, § 123(a)(7)(B)]","children":[],"tail":", substituted “registered entities” for “clearinghouses, contract markets, and exchanges”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/546"},"text":"Pub. L. 102–546","children":[],"tail":", §§ 207(b)(1), 402(5)(A), redesignated par. (1) as subsec. (a) and substituted “floor broker, or floor trader” for “or floor broker”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/546/s402/5/A"},"text":"Pub. L. 102–546, § 402(5)(A)","children":[],"tail":", redesignated par. (2) as subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/546/s402/5"},"text":"Pub. L. 102–546, § 402(5)","children":[],"tail":", redesignated par. (3) as subsec. (c) and substituted “subsection (b)” for “paragraph (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/546/s402/5/A"},"text":"Pub. L. 102–546, § 402(5)(A)","children":[],"tail":", redesignated pars. (4) to (6) as subsecs. (d) to (f), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/444/s209/1"},"text":"Pub. L. 97–444, § 209(1)","children":[],"tail":", made reporting and recordkeeping requirements applicable to introducing brokers."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/444/s209/2"},"text":"Pub. L. 97–444, § 209(2)","children":[],"tail":", made customer daily trading records requirement applicable to introducing brokers."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/405"},"text":"Pub. L. 95–405","children":[],"tail":" substituted “Floor brokers” for “Brokers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/463"},"text":"Pub. L. 93–463","children":[],"tail":", §§ 103(a), (f), 415, designated existing provisions as par. (1) and substituted “Commission” for “Secretary of Agriculture” and “United States Department of Agriculture”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (2) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/463/s415"},"text":"Pub. L. 93–463, § 415","children":[],"tail":", added pars. (2) to (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/258"},"text":"Pub. L. 90–258","children":[],"tail":" rephrased existing provisions to express reporting and recordkeeping requirements as a positive obligation of futures commission merchants and floor brokers, rather than as a ground for revoking or suspending registration and struck out provisions for revocation or suspension of registration. See "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9"},"text":"section 9 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idedc3c686-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idedc3c687-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s13202/a"},"text":"section 13202(a) of Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s13204/a"},"text":"section 13204(a) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{