{"tag":"section","attrib":{"id":"idedc3c67a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6g"},"text":null,"children":[{"tag":"num","attrib":{"value":"6g"},"text":"§ 6g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting and recordkeeping","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idedc3c67b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every person registered hereunder as futures commission merchant, introducing broker, floor broker, or floor trader shall make such reports as are required by the Commission regarding the transactions and positions of such person, and the transactions and positions of the customer thereof, in commodities for future delivery on any board of trade in the United States or elsewhere, and in any significant price discovery contract traded or executed on an electronic trading facility or any agreement, contract, or transaction that is treated by a derivatives clearing organization, whether registered or not registered, as fungible with a significant price discovery contract; shall keep books and records pertaining to such transactions and positions in such form and manner and for such period as may be required by the Commission; and shall keep such books and records open to inspection by any representative of the Commission or the United States Department of Justice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedc3c67c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Daily trading records: registered entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every registered entity shall maintain daily trading records. The daily trading records shall include such information as the Commission shall prescribe by rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedc3c67d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Daily trading records: floor brokers, introducing brokers, and futures commission merchants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Floor brokers, introducing brokers, and futures commission merchants shall maintain daily trading records for each customer in such manner and form as to be identifiable with the trades referred to in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedc3c67e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Daily trading records: form and reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Daily trading records shall be maintained in a form suitable to the Commission for such period as may be required by the Commission. Reports shall be made from the records maintained at such times and at such places and in such form as the Commission may prescribe by rule, order, or regulation in order to protect the public interest and the interest of persons trading in commodity futures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedc3c67f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6g/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the beginning of trading each day, the exchange shall, insofar as is practicable and under terms and conditions specified by the Commission, make public the volume of trading on each type of contract for the previous day and such other information as the Commission deems necessary in the public interest and prescribes by rule, order, or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedc3c680-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6g/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Commission to make separate determinations unimpaired","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing contained in this section shall be construed to prohibit the Commission from making separate determinations for different registered entities when such determinations are warranted in the judgment of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idedc3c681-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369/s4g"},"text":"Sept. 21, 1922, ch. 369, § 4g","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-15/ch545/s5"},"text":"June 15, 1936, ch. 545, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1496"},"text":"49 Stat. 1496","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/258/s8"},"text":"Pub. L. 90–258, § 8","children":[],"tail":", "},{"tag":"date","attrib"