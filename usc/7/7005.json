{"tag":"section","attrib":{"id":"ideff8cf8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7005"},"text":null,"children":[{"tag":"num","attrib":{"value":"7005"},"text":"§ 7005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary of Agriculture for Marketing and Regulatory Programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff8cf8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7005/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to establish in the Department the position of Under Secretary of Agriculture for Marketing and Regulatory Programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff8cf8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7005/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confirmation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary establishes the position of Under Secretary of Agriculture for Marketing and Regulatory Programs authorized under subsection (a), the Under Secretary shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff8cf8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7005/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Under Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff8cf8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7005/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon establishment, the Secretary shall delegate to the Under Secretary of Agriculture for Marketing and Regulatory Programs those functions and duties under the jurisdiction of the Department that are related to agricultural marketing, animal and plant health inspection, grain inspection, and packers and stockyards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cf8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7005/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary of Agriculture for Marketing and Regulatory Programs shall perform such other functions and duties as may be required by law or prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff8cf90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7005/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Succession","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any official who is serving as Assistant Secretary of Agriculture for Marketing and Regulatory Programs on ","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"October 21, 1998","children":[],"tail":", and who was appointed by the President, by and with the advice and consent of the Senate, shall not be required to be reappointed under subsection (b) to the successor position authorized under subsection (a) if the Secretary establishes the position, and the official occupies the new position, within 180 days after "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"October 21, 1998","children":[],"tail":" (or such later date set by the Secretary if litigation delays rapid succession)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff8cf91-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s285"},"text":"Pub. L. 103–354, title II, § 285","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/a/tX/s1001/3"},"text":"Pub. L. 105–277, div. A, § 101(a) [title X, § 1001(3)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681"},"text":"112 Stat. 2681","children":[],"tail":", 2681–41.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideff8cf92-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideff8cf93-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideff8cf94-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/s285"},"text":"section 285 of Pub. L. 103–354","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":". Subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/s285"},"text":"section 285 of Pub. L. 103–354","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
