{"tag":"section","attrib":{"id":"idf0099850-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442"},"text":null,"children":[{"tag":"num","attrib":{"value":"7442"},"text":"§ 7442.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter (unless the context otherwise requires):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0099851-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the National Canola and Rapeseed Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7444/b"},"text":"section 7444(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099852-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Canola; rapeseed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “canola” and “rapeseed” mean any brassica plant grown in the United States for the production of an oilseed, the oil of which is used for a food or nonfood use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099853-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Canola or rapeseed product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “canola or rapeseed product” means a product produced, in whole or in part, from canola or rapeseed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099854-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commerce","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “commerce” includes interstate, foreign, and intrastate commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099855-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “conflict of interest” means a situation in which a member of the Board has a direct or indirect financial interest in a corporation, partnership, sole proprietorship, joint venture, or other business entity dealing directly or indirectly with the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099856-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “consumer information” means information that will assist consumers and other persons in making evaluations and decisions regarding the purchase, preparation, and use of canola, rapeseed, or canola or rapeseed products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099857-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department” means the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099858-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First purchaser","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “first purchaser” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0099859-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subparagraph (B), a person who buys or otherwise acquires canola, rapeseed, or canola or rapeseed products produced by a producer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf009985a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commodity Credit Corporation, in a case in which canola or rapeseed is forfeited to the Commodity Credit Corporation as collateral for a loan issued under a price support loan program administered by the Commodity Credit Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf009985b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industry information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “industry information” means information or a program that will lead to the development of new markets, new marketing strategies, or increased efficiency for the canola and rapeseed industry, or an activity to enhance the image of the canola or rapeseed industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf009985c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industry member","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “industry member” means a member of the canola and rapeseed industry who represents—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf009985d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufacturers of canola or rapeseed products; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf009985e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons who commercially buy or sell canola or rapeseed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf009985f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marketing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “marketing” means the sale or other disposition of canola, rapeseed, or canola or rapeseed products in a channel of commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099860-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “order” means an order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7443"},"text":"section 7443 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099861-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means an individual, partnership, corporation, association, cooperative, or any other legal entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099862-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “producer” means a person engaged in the growing of canola or rapeseed in the United States who owns, or who shares the ownership and risk of loss of, the canola or rapeseed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099863-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “promotion” means an action, including paid advertising, technical assistance, or a trade servicing activity, to enhance the image or desirability of canola, rapeseed, or canola or rapeseed products in domestic and foreign markets, or an activity designed to communicate to consumers, processors, wholesalers, retailers, government officials, or other persons information relating to the positive attributes of canola, rapeseed, or canola or rapeseed products or the benefits of use or distribution of canola, rapeseed, or canola or rapeseed products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099864-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “research” means any type of test, study, or analysis to advance the image, desirability, marketability, production, product development, quality, or functional or nutritional value of canola, rapeseed, or canola or rapeseed products, including research activity designed to identify and analyze barriers to export sales of canola or rapeseed produced in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099865-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099866-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means any of the 50 States, the District of Columbia and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099867-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7442/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” means collectively the 50 States, the District of Columbia, and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0099868-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s533"},"text":"Pub. L. 104–127, title V, § 533","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1049"},"text":"110 Stat. 1049","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
