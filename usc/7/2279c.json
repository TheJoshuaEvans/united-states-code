{"tag":"section","attrib":{"id":"idef7f32d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279c"},"text":"§ 2279c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student internship programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef7f32d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student intern subsistence program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7f32d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Student intern” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “student intern” means a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7f32d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is employed by the Department of Agriculture (referred to in this section as the “Department”) to assist scientific, professional, administrative, or technical employees of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7f32d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a student in good standing at an institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":") pursuing a course of study related to the field in which the person is employed by the Department."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of certain expenses by the Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture (referred to in this section as the “Secretary”) may, out of user fee funds or funds appropriated to any agency of the Department, pay for lodging expenses, subsistence expenses, and transportation expenses of a student intern at the agency (including expenses of transportation to and from the student intern’s residence at or near the institution of higher education attended by the student intern and the official duty station at which the student intern is employed).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f32d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with associations of colleges and universities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7f32d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to cooperate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding chapter 63 of title 31, the Secretary may enter into cooperative agreements on an annual basis with 1 or more associations of institutions of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":") for the purpose of providing for Department participation in internship programs for graduate and undergraduate students who are selected by the associations from students attending member institutions of the associations and other institutions of higher education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internship program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An internship program supported under this subsection (referred to in this subsection as an “internship program”) shall provide work assignments for students within the Department and such other activities as the association that enters into the cooperative agreement under paragraph (1) with respect to the internship program (referred to in this subsection as the “cooperating association”) and the Secretary shall determine. The nature of Department participation in an internship program shall be developed jointly by the Secretary and the cooperating association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The cooperating association shall coordinate an internship program, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7f32db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recruitment of students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7f32dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrangements for travel of the students to Washington, District of Columbia, and to agency field locations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7f32dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of housing for students, if required; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7f32de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all activities for the students that take place outside the Department work assignments of the students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number and selection of students","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7f32e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A cooperative agreement entered into under paragraph (1) shall specify the number of students that the Department will host each year and a list of work assignments to be provided for the students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7f32e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The cooperating association shall provide the Department with a pool of student candidates meeting the requirements for each work assignment identified by the Secretary. Final selection of the students for Department internship positions shall be made by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From such amounts as the Secretary determines are available each fiscal year for internship programs, and subject to such regulations as the Secretary may issue, the Secretary may reimburse a cooperating association for the Department share of all direct and indirect costs of an internship program, including student stipends, transportation costs to the internship site, and other costs of an internship program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lead agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may designate a lead agency within the Department to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Agencies and offices within the Department other than the lead agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7f32e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enter into interagency agreements with the lead agency to provide work assignments for students participating in an internship program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7f32e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall reimburse the lead agency for the direct and indirect costs of each student assigned to the agency under an internship program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279c/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal employee status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A student who participates in an internship program shall not be considered a Federal employee, except for purposes of chapter 81 of title 5, and chapter 171 of title 28.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7f32e8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIX/s922"},"text":"Pub. L. 104–127, title IX, § 922","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1193"},"text":"110 Stat. 1193","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tI/s102/a/1/A"},"text":"Pub. L. 105–244, title I, § 102(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1617"},"text":"112 Stat. 1617","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7f32e9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef7f32ea-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef7f32eb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsecs. (a)(1)(B), (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":")” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1141"},"text":"section 1141 of title 20","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef7f32ec-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef7f32ed-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
