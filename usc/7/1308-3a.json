pl/119/21/s10308/1"},"text":"Pub. L. 119–21, § 10308(1)","children":[],"tail":", substituted “paragraphs (3) and (4)” for “paragraph (3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10308/2"},"text":"Pub. L. 119–21, § 10308(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10306/e"},"text":"Pub. L. 119–21, § 10306(e)","children":[],"tail":", struck out “, general partnership, or joint venture” after “entity” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1704/b"},"text":"Pub. L. 115–334, § 1704(b)","children":[],"tail":", inserted “subject to paragraph (3),” after “provision of law,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1704/a/1"},"text":"Pub. L. 115–334, § 1704(a)(1)","children":[],"tail":", inserted “title II of the Agriculture Improvement Act of 2018,” after “under”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1704/a/2"},"text":"Pub. L. 115–334, § 1704(a)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s1605/b"},"text":"Pub. L. 113–79, § 1605(b)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) defined “average adjusted gross income”, “average adjusted gross farm income”, and “average adjusted gross nonfarm income”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s1605/d/1"},"text":"Pub. L. 113–79, § 1605(d)(1)","children":[],"tail":", struck out “subparagraph (A) or (B) of” after “average under” and “, the average adjusted gross farm income, and the average adjusted gross nonfarm income” after “average adjusted gross income”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s1605/d/2"},"text":"Pub. L. 113–79, § 1605(d)(2)","children":[],"tail":", struck out “, average adjusted gross farm income, and average adjusted gross nonfarm income” after “average adjusted gross income” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s1605/a"},"text":"Pub. L. 113–79, § 1605(a)","children":[],"tail":", substituted “Limitations on commodity and conservation programs” for “Limitations” in heading, added pars. (1) and (2), and struck out former pars. (1) and (2), which related to commodity programs and conservation programs, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s1605/c"},"text":"Pub. L. 113–79, § 1605(c)","children":[],"tail":", redesignated subsec. (d) as (c) and struck out former subsec. (c) which related to income determination."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s1605/d/3/A"},"text":"Pub. L. 113–79, § 1605(d)(3)(A)","children":[],"tail":", struck out “, average adjusted gross farm income, and average adjusted gross nonfarm income” after “average adjusted gross income” in subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s1605/d/3/B"},"text":"Pub. L. 113–79, § 1605(d)(3)(B)","children":[],"tail":", substituted “subsection (b)(2)” for “paragraphs (1)(C) and (2)(B) of subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s1605/d/4"},"text":"Pub. L. 113–79, § 1605(d)(4)","children":[],"tail":", substituted “subsection (b)(2)” for “paragraphs (1)(C) and (2)(B) of subsection (b)” and struck out “, average adjusted gross farm income, or average adjusted gross nonfarm income” after “average adjusted gross income”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s1605/c/2"},"text":"Pub. L. 113–79, § 1605(c)(2)","children":[],"tail":", redesignated subsec. (e) as (d). Former subsec. (d) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s1605/e"},"text":"Pub. L. 113–79, § 1605(e)","children":[],"tail":", struck out subsec. (e). Text read as follows: “This section shall apply only during the 2009 through 2012 crop, program, or fiscal years, as appropriate.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s1605/c/2"},"text":"Pub. L. 113–79, § 1605(c)(2)","children":[],"tail":", redesignated subsec. (f) as (e). Former subsec. (e) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s1605/c/2"},"text":"Pub. L. 113–79, § 1605(c)(2)","children":[],"tail":", redesignated subsec. (f) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1604/a"},"text":"Pub. L. 110–246, § 1604(a)","children":[],"tail":", amended section generally, substituting subsecs. (a) to (f) for former provisions which related to: in subsec. (a), definition of “average adjusted gross income”; in subsec. (b), limitation on benefits if average adjusted gross income exceeded $2,500,000; in subsec. (c), certification that average adjusted gross income did not exceed limitation; in subsec. (d), reduction of benefits commensurate with ownership interest; and in subsec. (e), applicability of section during 2003 t