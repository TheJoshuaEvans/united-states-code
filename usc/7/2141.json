{"tag":"section","attrib":{"id":"idef6c1f96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2141"},"text":null,"children":[{"tag":"num","attrib":{"value":"2141"},"text":"§ 2141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marking and identification of animals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All animals delivered for transportation, transported, purchased, or sold, in commerce, by a dealer or exhibitor shall be marked or identified at such time and in such humane manner as the Secretary may prescribe: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That only live dogs and cats need be so marked or identified by a research facility."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef6c1f97-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/544/s11"},"text":"Pub. L. 89–544, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-08-24"},"text":"Aug. 24, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/351"},"text":"80 Stat. 351","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/579/s12"},"text":"Pub. L. 91–579, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1562"},"text":"84 Stat. 1562","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/279/s5"},"text":"Pub. L. 94–279, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-22"},"text":"Apr. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/418"},"text":"90 Stat. 418","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef6c1f98-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef6c1f99-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef6c1f9a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/279"},"text":"Pub. L. 94–279","children":[],"tail":" substituted “in commerce” for “affecting commerce”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/579"},"text":"Pub. L. 91–579","children":[],"tail":" applied marking and identification requirements to dealers and exhibitors for animals, as defined, instead of only to dogs and cats when movements are affecting commerce, but limited such requirements for research facilities to only live dogs and cats."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef6c1f9b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef6c1f9c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/579"},"text":"Pub. L. 91–579","children":[],"tail":" effective one year after "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/579/s23"},"text":"section 23 of Pub. L. 91–579","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2131"},"text":"section 2131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
