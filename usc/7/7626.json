{"tag":"section","attrib":{"id":"idf0157fe9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7626"},"text":null,"children":[{"tag":"num","attrib":{"value":"7626"},"text":"§ 7626.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated research, education, and extension competitive grants program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0157fea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7626/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the purpose of this section to authorize the Secretary of Agriculture to establish an integrated research, education, and extension competitive grant program to provide funding for integrated, multifunctional agricultural research, extension, and education activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157feb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7626/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations to carry out this section, the Secretary may award grants to colleges and universities (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3103"},"text":"section 3103 of this title","children":[],"tail":"), 1994 Institutions, and Hispanic-serving agricultural colleges and universities on a competitive basis for integrated agricultural research, education, and extension projects in accordance with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157fec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7626/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under this section shall be awarded to address priorities in United States agriculture, determined by the Secretary in consultation with the Advisory Board, that involve integrated research, extension, and education activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157fed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7626/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0157fee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7626/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (3), with respect to a grant under this section that provides a particular benefit to a specific agricultural commodity, the recipient of the grant shall provide non-Federal matching funds (including funds from an agricultural commodity promotion, research, and information program) equal to not less than the amount of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157fef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7626/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In-kind support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Non-Federal matching funds described in paragraph (1) may include in-kind support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157ff0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7626/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may waive the matching funds requirement under paragraph (1) with respect to a grant if the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0157ff1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7626/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the grant are of a particular benefit to a specific agricultural commodity, but those results are likely to be applicable to agricultural commodities generally; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157ff2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7626/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0157ff3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7626/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the grant—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf0157ff4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7626/d/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves a minor commodity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0157ff5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7626/d/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deals with scientifically important research; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0157ff6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7626/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient is unable to satisfy the matching funds requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157ff7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7626/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this section shall have a term of not more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157ff8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7626/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section for each of fiscal years 1999 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0157ff9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"t