{"tag":"section","attrib":{"id":"ideead63c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1445k"},"text":null,"children":[{"tag":"num","attrib":{"value":"1445k"},"text":"§ 1445k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments in commodities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideead63c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1445k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In-kind payments by Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making in-kind payments under any of the annual programs for wheat, feed grains, upland cotton, or rice (other than negotiable marketing certificates for upland cotton or rice), the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideead63c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1445k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire and use like commodities that have been pledged to the Commodity Credit Corporation as security for price support loans, including loans made to producers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1445e"},"text":"section 1445e of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideead63c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1445k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use other like commodities owned by the Commodity Credit Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideead63c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1445k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methods of payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make in-kind payments—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideead63ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1445k/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by delivery of the commodity to the producer at a warehouse or other similar facility, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideead63cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1445k/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the transfer of negotiable warehouse receipts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideead63cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1445k/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the issuance of negotiable certificates which the Commodity Credit Corporation shall redeem for a commodity in accordance with regulations prescribed by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideead63cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1445k/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by such other methods as the Secretary determines appropriate to enable the producer to receive payments in an efficient, equitable, and expeditious manner so as to ensure that the producer receives the same total return as if the payments had been made in cash.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideead63ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1445k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodity certificates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall pay interest on the cash redemption of a commodity certificate issued by the Secretary to a producer who holds the certificate for at least 150 days. This subsection shall not apply with respect to commodity certificates issued in connection with the export enhancement program or the marketing promotion program established under the Agricultural Trade Act of 1978.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideead63cf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-31/ch792"},"text":"Oct. 31, 1949, ch. 792","children":[],"tail":", title I, § 115, formerly § 107E, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tX/s1005"},"text":"Pub. L. 99–198, title X, § 1005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1448"},"text":"99 Stat. 1448","children":[],"tail":"; renumbered § 115 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXI"},"text":"Pub. L. 101–624, title XI","children":[],"tail":", §§ 1122(a), 1161(a)(1), "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3503"},"text":"104 Stat. 3503","children":[],"tail":", 3520.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideead63d0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideead63d1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideead63d2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Agricultural Trade Act of 1978, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501"},"text":"Pub. L. 95–501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-21"},"text":"Oct. 21, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1685"},"text":"92 Stat. 1685","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1531"},"text":"Pub. L. 101–624, title XV, § 1531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3668"},"text":"104 Stat. 3668","children":[],"tail":", which is classified generally to chapter 87 (§ 5601 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s5601"},"text":"section 5601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideead63d3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1445b–4"},"text":"section 1445b–4 of this title","children":[],"tail":" prior to its renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideead63d4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1122/a"},"text":"Pub. L. 101–624, § 1122(a)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideead63d5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideead63d6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" effective beginning with 1991 crop of an agricultural commodity, with provision for prior crops, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1171"},"text":"section 1171 of Pub. L. 101–624","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideead63d7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inapplicability of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section inapplicable to 2014 through 2018 crops of covered commodities, cotton, and sugar and inapplicable to milk during period beginning ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9092/b/7"},"text":"section 9092(b)(7) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section inapplicable to 2008 through 2012 crops of covered commodities, peanuts, and sugar and inapplicable to milk during period beginning ","children":[{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"2012-12-31"},"text":"Dec. 31, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8782/b/7"},"text":"section 8782(b)(7) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section inapplicable to 2002 through 2007 crops of covered commodities, peanuts, and sugar and inapplicable to milk during period beginning ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"2007-12-31"},"text":"Dec. 31, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7992/b/7"},"text":"section 7992(b)(7) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section inapplicable to 1996 through 2002 crops of loan commodities, peanuts, and sugar and inapplicable to milk during period beginning ","children":[{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"2002-12-31"},"text":"Dec. 31, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7301/b/1/G"},"text":"section 7301(b)(1)(G) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideead63d8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Redemption of Commodity Certificates","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXI/s1122/b"},"text":"Pub. L. 101–624, title XI, § 1122(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3503"},"text":"104 Stat. 3503","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/624/tXI/s1122/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A subsequent holder of a commodity certificate issued by the Commodity Credit Corporation shall be allowed to exchange the expired commodity certificate under the same rules that apply to an original holder of the certificate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application and redemption limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection shall only apply during the 180-day period beginning on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":"]. No person may redeem more than $1,000 worth of certificates under this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Redemption limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In no event shall a person receive a payment from the Commodity Credit Corporation for a certificate that is redeemed under this subsection in an amount greater than the price paid for the certificate by the person. No expired certificate shall be exchanged under this section if the owner purchased the certificate after ","children":[{"tag":"date","attrib":{"date":"1990-01-01"},"text":"January 1, 1990","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
