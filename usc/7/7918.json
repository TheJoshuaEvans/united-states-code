{"tag":"section","attrib":{"id":"idf0262044-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7918"},"text":null,"children":[{"tag":"num","attrib":{"value":"7918"},"text":"§ 7918.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of effectiveness","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This subchapter shall be effective beginning with the 2002 crop year of each covered commodity through the 2007 crop year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf0262045-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1108"},"text":"Pub. L. 107–171, title I, § 1108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/155"},"text":"116 Stat. 155","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
