{"tag":"section","attrib":{"id":"idee59ec9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918"},"text":null,"children":[{"tag":"num","attrib":{"value":"918"},"text":"§ 918.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General prohibitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee59ec9c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No consideration of borrower’s level of general funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not deny or reduce any loan or loan advance under this chapter based on a borrower’s level of general funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee59ec9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan origination fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not charge any fee or charge not expressly provided in this chapter in connection with any loan made or guaranteed under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee59ec9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee59ec9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To facilitate timely action on applications by borrowers for financial assistance under this chapter and for approvals required of the Rural Electrification Administration pursuant to the terms of outstanding loan or security instruments or otherwise, the Secretary may use consultants funded by the borrower, paid for out of the general funds of the borrower, for financial, legal, engineering, and other technical advice and services in connection with the review of the application by the Rural Electrification Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee59eca0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish procedures for the selection and the provision of technical services by consultants to ensure that the consultants have no financial or other conflicts of interest in the outcome of the application of the borrower.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee59eca1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not, without the consent of the borrower, require, as a condition of processing an application for approval, that the borrower agree to pay the costs, fees, and expenses of consultants hired to provide technical or advisory services to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee59eca2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts, grants, and agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into such contracts, grants, or cooperative agreements as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee59eca3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of consultants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall limit the authority of the Secretary to retain the services of consultants from funds made available to the Secretary or otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee59eca4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title I, § 18, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2353"},"text":"Pub. L. 101–624, title XXIII, § 2353","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4039"},"text":"104 Stat. 4039","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/129/s2/c/4"},"text":"Pub. L. 103–129, § 2(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-01"},"text":"Nov. 1, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1364"},"text":"107 Stat. 1364","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s235/a/13"},"text":"Pub. L. 103–354, title II, § 235(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3221"},"text":"108 Stat. 3221","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6602/b/1"},"text":"Pub. L. 115–334, title VI, § 6602(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4776"},"text":"132 Stat. 4776","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee59eca5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee59eca6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee59eca7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" struck out “and the Governor of the telephone bank” after “The Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/129"},"text":"Pub. L. 103–129","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
