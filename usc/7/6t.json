{"tag":"section","attrib":{"id":"idedcaf1f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6t"},"text":null,"children":[{"tag":"num","attrib":{"value":"6t"},"text":"§ 6t.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Large swap trader reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idedcaf1fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6t/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedcaf1fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6t/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), it shall be unlawful for any person to enter into any swap that the Commission determines to perform a significant price discovery function with respect to registered entities if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcaf1fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6t/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person directly or indirectly enters into the swap during any 1 day in an amount equal to or in excess of such amount as shall be established periodically by the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcaf1fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6t/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person directly or indirectly has or obtains a position in the swap equal to or in excess of such amount as shall be established periodically by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf1fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6t/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcaf1ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6t/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person files or causes to be filed with the properly designated officer of the Commission such reports regarding any transactions or positions described in subparagraphs (A) and (B) of paragraph (1) as the Commission may require by rule or regulation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcaf200-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6t/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with the rules and regulations of the Commission, the person keeps books and records of all such swaps and any transactions and positions in any related commodity traded on or subject to the rules of any designated contract market or swap execution facility, and of cash or spot transactions in, inventories of, and purchase and sale commitments of, such a commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedcaf201-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6t/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedcaf202-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6t/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Books and records described in subsection (a)(2)(B) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcaf203-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6t/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" show such complete details concerning all transactions and positions as the Commission may prescribe by rule or regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcaf204-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6t/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be open at all times to inspection and examination by any representative of the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcaf205-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6t/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be open at all times to inspection and examination by the Securities and Exchange Commission, to the extent such books and records relate to transactions in swaps (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1a/47/A/v"},"text":"section 1a(47)(A)(v) of this title","children":[],"tail":"), and consistent with the confidentiality and disclosure requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s12"},"text":"section 12 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcaf206-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6t/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraph (1) shall affect the exclusive jurisdiction of the Commission to prescribe recordkeeping and reporting requirements for large swap traders under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedcaf207-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6t/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the swaps, futures, and cash or spot transactions and positions of any person shall include the swaps, futures, and cash or spot transactions and positions of any persons directly or indirectly controlled by the person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedcaf208-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6t/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Significant price discovery function","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making a determination as to whether a swap performs or affects a significant price discovery function with respect to registered entities, the Commission shall consider the factors described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6a/a/3"},"text":"section 6a(a)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idedcaf209-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369/s4t"},"text":"Sept. 21, 1922, ch. 369, § 4t","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVII/s730"},"text":"Pub. L. 111–203, title VII, § 730","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1702"},"text":"124 Stat. 1702","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idedcaf20a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idedcaf20b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idedcaf20c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the later of 360 days after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", or, to the extent a provision of subtitle A (§§ 711–754) of title VII of "},{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" requires a rulemaking, not less than 60 days after publication of the final rule or regulation implementing such provision of subtitle A, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s754"},"text":"section 754 of Pub. L. 111–203","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1a"},"text":"section 1a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
