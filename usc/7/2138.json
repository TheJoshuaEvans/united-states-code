{"tag":"section","attrib":{"id":"idef6c1f81-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2138"},"text":null,"children":[{"tag":"num","attrib":{"value":"2138"},"text":"§ 2138.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of dogs or cats by United States Government facilities prohibited except from authorized operators of auction sales and licensed dealers or exhibitors","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No department, agency, or instrumentality of the United States which uses animals for research or experimentation or exhibition shall purchase or otherwise acquire any dog or cat for such purposes from any person except an operator of an auction sale subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2142"},"text":"section 2142 of this title","children":[],"tail":" or a person holding a valid license as a dealer or exhibitor issued by the Secretary pursuant to this chapter unless such person is exempted from obtaining such license under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2133"},"text":"section 2133 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef6c1f82-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/544/s8"},"text":"Pub. L. 89–544, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-08-24"},"text":"Aug. 24, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/351"},"text":"80 Stat. 351","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/579/s9"},"text":"Pub. L. 91–579, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1562"},"text":"84 Stat. 1562","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef6c1f83-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef6c1f84-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef6c1f85-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/579"},"text":"Pub. L. 91–579","children":[],"tail":" inserted reference to instrumentalities of the United States which use animals for exhibition and added operators of auction sales subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2142"},"text":"section 2142 of this title","children":[],"tail":" and licensed exhibitors to the enumeration of persons from whom United States Government facilities may acquire dogs or cats."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef6c1f86-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef6c1f87-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/579"},"text":"Pub. L. 91–579","children":[],"tail":" effective one year after "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/579/s23"},"text":"section 23 of Pub. L. 91–579","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2131"},"text":"section 2131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
