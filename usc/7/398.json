{"tag":"section","attrib":{"id":"idee2f0bba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s398"},"text":null,"children":[{"tag":"num","attrib":{"value":"398"},"text":"§ 398.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase and testing of serums or analogous products; dissemination of test results","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture may purchase in the open market from applicable appropriations samples of all tuberculin, serums, antitoxins, or analogous products, of foreign or domestic manufacture, which are sold in the United States, for the detection, prevention, treatment, or cure of diseases of domestic animals, test the same, and disseminate the results of said tests in such manner as he may deem best.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee2f0bbb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-09-21/ch412"},"text":"Sept. 21, 1944, ch. 412","children":[],"tail":", title I, § 101(d), "},{"tag":"ref","attrib":{"href":"/us/stat/58/734"},"text":"58 Stat. 734","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee2f0bbc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee2f0bbd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee2f0bbe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s430"},"text":"section 430 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee2f0bbf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idee2f0bc0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization of Appropriation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Authorization of appropriation of sums necessary for the purposes of this section, see note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s395"},"text":"section 395 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
