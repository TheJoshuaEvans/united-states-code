{"tag":"section","attrib":{"id":"idef8414b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2461"},"text":null,"children":[{"tag":"num","attrib":{"value":"2461"},"text":"§ 2461.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"From the decisions made under sections 2404, 2443, 2501, and 2568 of this title appeal may, within sixty days or such further times as the Secretary allows, be taken under the Federal Rules of Appellate Procedure. The United States Court of Appeals for the Federal Circuit shall have jurisdiction of any such appeal.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef8414b3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tII/s71"},"text":"Pub. L. 91–577, title II, § 71","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1550"},"text":"84 Stat. 1550","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s145"},"text":"Pub. L. 97–164, title I, § 145","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/45"},"text":"96 Stat. 45","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/349/s8/d/1"},"text":"Pub. L. 103–349, § 8(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-06"},"text":"Oct. 6, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3141"},"text":"108 Stat. 3141","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8414b4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef8414b5-3a6e-11f1-