{"tag":"section","attrib":{"id":"ideffdb140-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7111"},"text":null,"children":[{"tag":"num","attrib":{"value":"7111"},"text":"§ 7111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideffdb141-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for each fiscal year such sums as are necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffdb142-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated under subsection (a) shall not be available for payment of the expenses or expenditures of the Board in administering any provision of any order issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideffdb143-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/407/s12"},"text":"Pub. L. 103–407, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4226"},"text":"108 Stat. 4226","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
