{"tag":"section","attrib":{"id":"idefece899-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802"},"text":null,"children":[{"tag":"num","attrib":{"value":"6802"},"text":"§ 6802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefece89a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “consumer information” means any action or program that provides information to consumers and other persons on appropriate uses under varied circumstances, and on the care and handling, of cut flowers or cut greens.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefece89b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cut flowers and cut greens","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefece89c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefece89d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cut flowers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cut flowers” includes all flowers cut from growing plants that are used as fresh-cut flowers and that are produced under cover or in field operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefece89e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cut greens","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cut greens” includes all cultivated or noncultivated decorative foliage cut from growing plants that are used as fresh-cut decorative foliage (except Christmas trees) and that are produced under cover or in field operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefece89f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “cut flowers” and “cut greens” do not include a foliage plant, floral supply, or flowering plant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefece8a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantial portion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which a handler packages cut flowers or cut greens with hard goods in an article (such as a gift basket or similar presentation) for sale to a retailer, the PromoFlor Council may determine, under procedures specified in the order, that the cut flowers or cut greens in the article do not constitute a substantial portion of the value of the article and that, based on the determination, the article shall not be treated as an article of cut flowers or cut greens subject to assessment under the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefece8a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gross sales price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “gross sales price” means the total amount of the transaction in a sale of cut flowers or cut greens from a handler to a retailer or exempt handler.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefece8a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Handler","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefece8a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified handler","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefece8a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified handler” means a person (including a cooperative) operating in the cut flowers or cut greens marketing system—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idefece8a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that sells domestic or imported cut flowers or cut greens to retailers and exempt handlers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idefece8a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose annual sales of cut flowers and cut greens to retailers and exempt handlers are $750,000 or more.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefece8a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions and exclusions","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idefece8a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified handler” includes—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idefece8a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/A/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bouquet manufacturers (subject to paragraph (2)(B));","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idefece8aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/A/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an auction house that clears the sale of cut flowers and cut greens to retailers and exempt handlers through a central clearinghouse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idefece8ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/A/ii/I/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a distribution center that is owned or controlled by a retailer if the predominant retail business activity of the retailer is floral sales.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idefece8ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of determining sales of cut flowers and cut greens to a retailer from a distribution center described in subclause (I)(cc), each non-sale transfer to a retailer shall be treated as a sale in an amount calculated as provided in subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idefece8ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation or delivery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified handler” does not include a person who only physically transports or delivers cut flowers or cut greens.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefece8ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idefece8af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified handler” includes an importer or producer that sells cut flowers or cut greens that the importer or producer has imported into the United States or produced, respectively, directly to consumers and whose sales of the cut flowers and cut greens (as calculated under subparagraph (C)), together with sales of cut flowers and cut greens to retailers or exempt handlers, annually are $750,000 or more.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idefece8b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sales","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each direct sale to a consumer by a qualified handler described in subclause (I) shall be treated as a sale to a retailer or exempt handler in an amount calculated as provided in subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idefece8b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/A/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this paragraph:","children":[],"tail":null},{"tag":"item","attrib":{"id":"idefece8b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/A/iii/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “importer” has the meaning provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6804/b/2/B/i/I"},"text":"section 6804(b)(2)(B)(i)(I) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idefece8b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/A/iii/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “producer” has the meaning provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6804/b/2/B/ii/I"},"text":"section 6804(b)(2)(B)(ii)(I) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefece8b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exempt handler","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “exempt handler” means a person who would otherwise be considered to be a qualified handler, except that the annual sales by the person of cut flowers and cut greens to retailers and other exempt handlers are less than $750,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefece8b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual sales determined","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefece8b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), for the purpose of determining the amount of annual sales of cut flowers and cut greens under subparagraphs (A) and (B), the amount of a sale shall be determined on the basis of the gross sales price of the cut flowers and cut greens sold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefece8b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idefece8b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-sale transfers and direct sales by importers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subclause (III), in the case of a non-sale transfer of cut flowers or cut greens from a distribution center (as described in subparagraph (A)(ii)(II)), or a direct sale to a consumer by an importer (as described in subparagraph (A)(iii)), the amount of the sale shall be equal to the sum of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idefece8b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/C/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the price paid by the distribution center or importer, respectively, to acquire the cut flowers or cut greens; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idefece8ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/C/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount determined by multiplying the acquisition price referred to in item (aa) by a uniform percentage established by an order to represent the mark-up of a wholesale handler on a sale to a retailer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idefece8bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct sales by producers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subclause (III), in the case of a direct sale to a consumer by a producer (as described in subparagraph (A)(iii)), the amount of the sale shall be equal to an amount determined by multiplying the price paid by the consumer by a uniform percentage established by an order to represent the cost of producing the article and the mark-up of a wholesale handler on a sale to a retailer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idefece8bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Changes in uniform percentages","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any change in a uniform percentage referred to in subclause (I) or (II) may become effective after—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idefece8bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/C/ii/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendation by the PromoFlor Council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idefece8be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/4/C/ii/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approval by the Secretary after public notice and opportunity for comment in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":" and without regard to sections 556 and 557 of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefece8bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “order” means an order issued under this chapter (other than sections 6808, 6809, and 6811 of this title).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefece8c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means any individual, group of individuals, firm, partnership, corporation, joint stock company, association, society, cooperative, or other legal entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefece8c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" PromoFlor Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “PromoFlor Council” means the Fresh Cut Flowers and Fresh Cut Greens Promotion Council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6804/b"},"text":"section 6804(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefece8c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “promotion” means any action determined by the Secretary to advance the image, desirability, or marketability of cut flowers or cut greens, including paid advertising.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefece8c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “research” means market research and studies limited to the support of advertising, market development, and other promotion efforts and consumer information efforts relating to cut flowers or cut greens, including educational activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefece8c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retailer","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefece8c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “retailer” means a person (such as a retail florist, supermarket, mass market retail outlet, or other end-use seller), as described in an order, that sells cut flowers or cut greens to consumers, and a distribution center described in subparagraph (B)(i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefece8c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution centers","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefece8c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/10/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “retailer” includes a distribution center that is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idefece8c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/10/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned or controlled by a person described in subparagraph (A), or owned or controlled cooperatively by a group of the persons, if the predominant retail business activity of the person is not floral sales; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idefece8c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/10/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" independently owned but operated primarily to provide food products to retail stores.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefece8ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/10/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importers and producers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An independently owned distribution center described in clause (i)(II) that also is an importer or producer of cut flowers or cut greens shall be subject to the rules of construction specified in paragraph (4)(A)(iii) and, for the purpose of the rules of construction, be considered to be the seller of the articles directly to the consumer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefece8cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefece8cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, the United States Virgin Islands, Guam, American Samoa, the Republic of the Marshall Islands, the Federated States of Micronesia, and the Republic of Palau (until such time as the Compact of Free Association is ratified).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefece8cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6802/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” means the States collectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefece8ce-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/190/s3"},"text":"Pub. L. 103–190, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2268"},"text":"107 Stat. 2268","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefece8cf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefece8d0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefece8d1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For ratification of Compact of Free Association with the Republic of Palau, referred to in par. (12), see Proc. No. 6726, ","children":[{"tag":"date","attrib":{"date":"1994-09-27"},"text":"Sept. 27, 1994","children":[],"tail":", 59 F.R. 49777, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1931"},"text":"section 1931 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
