{"tag":"section","attrib":{"id":"idefde90ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6203"},"text":null,"children":[{"tag":"num","attrib":{"value":"6203"},"text":"§ 6203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefde90ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to this chapter, and to effectuate the declared purposes of this chapter, the Secretary shall issue and, from time to time, amend lime research, promotion, and consumer information orders applicable to handlers, producers, producer-handlers, and importers of limes. Any such order shall be national in scope. Not more than one order shall be in effect under this chapter at any one time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefde90af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefde90b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6203/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposal for issuance of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person that will be affected by this chapter may request the issuance of, and submit a proposal for, an order under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde90b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6203/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposed order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the receipt of a request and proposal by an interested person for an order, the Secretary shall publish a proposed order and give due notice and opportunity for public comment on the proposed order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde90b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6203/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After notice and opportunity for public comment are given, as provided in paragraph (2), the Secretary shall issue an order, taking into consideration the comments received and including in the order provisions necessary to ensure that the order is in conformity with the requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde90b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6203/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such order shall be issued and become effective not later than 150 days following publication of the proposed order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefde90b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6203/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, from time to time, may amend any order issued under this section. The provisions of this chapter applicable to orders shall be applicable to amendments to orders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefde90b5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1954"},"text":"Pub. L. 101–624, title XIX, § 1954","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3872"},"text":"104 Stat. 3872","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
