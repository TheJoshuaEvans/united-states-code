{"tag":"section","attrib":{"id":"idf04eb740-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9040"},"text":null,"children":[{"tag":"num","attrib":{"value":"9040"},"text":"§ 9040.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments of loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf04eb741-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9040/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (e), the Secretary may make appropriate adjustments in the loan rates for any loan commodity (other than cotton) for differences in grade, type, quality, location, and other factors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04eb742-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9040/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The adjustments under subsection (a) shall, to the maximum extent practicable, be made in such a manner that the average loan level for the commodity will, on the basis of the anticipated incidence of the factors, be equal to the level of support determined in accordance with this subchapter and subtitle C.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04eb743-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9040/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment on county basis","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04eb744-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9040/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish loan rates for a crop for producers in individual counties in a manner that results in the lowest loan rate being 95 percent of the national average loan rate, if those loan rates do not result in an increase in outlays.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb745-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9040/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Adjustments under this subsection shall not result in an increase in the national average loan rate for any year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04eb746-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9040/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment in loan rate for cotton","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04eb747-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9040/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make appropriate adjustments in the loan rate for cotton for differences in quality factors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb748-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9040/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of adjustments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Loan rate adjustments under paragraph (1) may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04eb749-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9040/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of non-spot market price data, in addition to spot market price data, that would enhance the accuracy of the price information used in determining quality adjustments under this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04eb74a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9040/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjustments in the premiums or discounts associated with upland cotton with a staple length of 33 or above due to micronaire with the goal of eliminating any unnecessary artificial splits in the calculations of the premiums or discounts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04eb74b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9040/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other adjustments as the Secretary determines appropriate, after consultations conducted in accordance with paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb74c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9040/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with private sector","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04eb74d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9040/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior to revision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making adjustments to the loan rate for cotton (including any review of the adjustments) as provided in this subsection, the Secretary shall consult with representatives of the United States cotton industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04eb74e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9040/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability of chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply to consultations under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb74f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9040/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may review the operation of the upland cotton quality adjustments implemented pursuant to this subsection and may make further adjustments to the administration of the loan program for upland cotton, by revoking or revising any adjustment taken under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04eb750-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9040/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not make adjustments in the loan rates for long grain rice and medium grain rice, except for differences in grade and quality (including milling yields).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf04eb751-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1210"},"text":"Pub. L. 113–79, title I, § 1210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/686"},"text":"128 Stat. 686","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/43"},"text":"Pub. L. 117–286, § 4(a)(43)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4310"},"text":"136 Stat. 4310","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf04eb752-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf04eb753-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf04eb754-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subtitle C, referred to in subsec. (b), means subtitle C of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/687"},"text":"128 Stat. 687","children":[],"tail":", which amended sections 1359bb, 1359ll, and 7272 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf04eb755-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5” for “Federal Advisory Committee Act” in heading and “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)” in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
