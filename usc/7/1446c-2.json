{"tag":"section","attrib":{"id":"ideeb21e69-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1446c–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1446c–2"},"text":"§ 1446c–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic casein industry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideeb21e6a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1446c–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual availability of surplus stocks of nonfat dry milk; bid basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commodity Credit Corporation shall provide surplus stocks of nonfat dry milk of not less than 1,000,000 pounds annually to individuals or entities on a bid basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeb21e6b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1446c–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of bids at lower than resale price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commodity Credit Corporation may accept bids at lower than the resale price otherwise required by law, in order to promote the strengthening of the domestic casein industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeb21e6c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1446c–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonfat dry milk sold to be used only for manufacture of casein","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commodity Credit Corporation shall take appropriate action to ensure that the nonfat dry milk sold by the Corporation under this section is used only for the manufacture of casein.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideeb21e6d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tI/s105"},"text":"Pub. L. 99–198, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1367"},"text":"99 Stat. 1367","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideeb21e6e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideeb21e6f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideeb21e70-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food Security Act of 1985, and not as part of the Agricultural Act of 1949 which is classified principally to this chapter. For complete classification of the 1949 Act to the Code, see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideeb21e71-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideeb21e72-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section not to affect any liability of any person under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1446"},"text":"section 1446 of this title","children":[],"tail":" as in effect before "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/s108"},"text":"section 108 of Pub. L. 99–198","children":[],"tail":", set out as an Application of 1985 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1446"},"text":"section 1446 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
