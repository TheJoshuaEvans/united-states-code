{"tag":"section","attrib":{"id":"idedf118c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s92"},"text":null,"children":[{"tag":"num","attrib":{"value":"92"},"text":"§ 92.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"When used in this chapter—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idedf118c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s92/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Naval stores” means spirits of turpentine and rosin.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf118c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s92/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Spirits of turpentine” includes gum spirits of turpentine and wood turpentine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf118c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s92/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Gum spirits of turpentine” means spirits of turpentine made from gum (oleoresin) from a living tree.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf118c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s92/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Wood turpentine” includes steam distilled wood turpentine and destructively distilled wood turpentine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf118c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s92/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Steam distilled wood turpentine” means wood turpentine distilled with steam from the oleoresin within or extracted from the wood.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf118c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s92/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Destructively distilled wood turpentine” means wood turpentine obtained in the destructive distillation of the wood.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf118c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s92/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Rosin” includes gum rosin and wood rosin.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf118c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s92/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Gum rosin” means rosin remaining after the distillation of gum spirits of turpentine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf118ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s92/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Wood rosin” means rosin remaining after the distillation of steam distilled wood turpentine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf118cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s92/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Package” means any container of naval stores, and includes barrel, tank, tank car, or other receptacle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf118cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s92/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Person” includes partnerships, associations, and corporations, as well as individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf118cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s92/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “commerce” means commerce between any State, Territory, or possession, or the District of Columbia, and any place outside thereof; or between points within the same State, Territory, or possession, or the District of Columbia, but through any place outside thereof; or within any Territory or possession or the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idedf118ce-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1923-03-03/ch217/s2"},"text":"Mar. 3, 1923, ch. 217, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/1435"},"text":"42 Stat. 1435","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
