{"tag":"section","attrib":{"id":"idef865e4c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2545"},"text":null,"children":[{"tag":"num","attrib":{"value":"2545"},"text":"§ 2545.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intermediary exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Transportation or delivery by a carrier in the ordinary course of its business as a carrier, or advertising by a person in the advertising business in the ordinary course of that business, shall not constitute an infringement of the protection provided under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef865e4d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tIII/s115"},"text":"Pub. L. 91–577, title III, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1555"},"text":"84 Stat. 1555","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
