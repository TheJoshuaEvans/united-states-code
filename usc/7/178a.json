{"tag":"section","attrib":{"id":"idee173ea4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s178a"},"text":null,"children":[{"tag":"num","attrib":{"value":"178a"},"text":"§ 178a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee173ea5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s178a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means each of the fifty States, the District of Columbia, and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee173ea6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s178a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretaries” means the Secretary of Agriculture and/or the Secretary of Commerce acting each separately or jointly.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee173ea7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s178a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “commercialization” means the stage in the development or advancement of a technology at which point private enterprise is willing to invest in a full-scale production facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee173ea8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s178a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “native” means hydrocarbon-containing plants and other agricultural crops of strategic and industrial importance which may be cultured in North America, especially plants which are members of the genus Parthenium known as Guayule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee173ea9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/592/s3"},"text":"Pub. L. 95–592, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-04"},"text":"Nov. 4, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2529"},"text":"92 Stat. 2529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/284/s3"},"text":"Pub. L. 98–284, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-05-16"},"text":"May 16, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/181"},"text":"98 Stat. 181","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee173eaa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee173eab-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee173eac-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/284/s3/a"},"text":"Pub. L. 98–284, § 3(a)","children":[],"tail":", inserted “and other agricultural crops of strategic and industrial importance” and “plants which are”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/284/s3/b"},"text":"Pub. L. 98–284, § 3(b)","children":[],"tail":", struck out subsec. (e) which defined “Regional Commissions” as the Regional Action Planning Commissions established pursuant to title V of the Public Works and Economic Development Act of 1965."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
