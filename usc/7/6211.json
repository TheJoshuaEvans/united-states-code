{"tag":"section","attrib":{"id":"idefde9165-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6211"},"text":null,"children":[{"tag":"num","attrib":{"value":"6211"},"text":"§ 6211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefde9166-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6211/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for each fiscal year such funds as are necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefde9167-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6211/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The funds so appropriated shall not be available for payment of the expenses or expenditures of the Board in administering any provisions of an order issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefde9168-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1962"},"text":"Pub. L. 101–624, title XIX, § 1962","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3880"},"text":"104 Stat. 3880","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
