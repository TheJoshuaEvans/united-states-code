{"tag":"section","attrib":{"id":"idee8bf904-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"1359ii"},"text":"§ 1359ii.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee8bf905-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359ii/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An appeal may be taken to the Secretary from any decision under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1359dd"},"text":"section 1359dd of this title","children":[],"tail":" establishing allocations of marketing allotments, or under section 1359ff or 1359gg(d) of this title, by any person adversely affected by reason of any such decision."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee8bf906-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359ii/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee8bf907-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359ii/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of appeal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any such appeal shall be taken by filing with the Secretary, within 20 days after the decision complained of is effective, notice in writing of the appeal and a statement of the reasons therefor. Unless a later date is specified by the Secretary as part of the Secretary’s decision, the decision complained of shall be considered to be effective as of the date on which announcement of the decision is made. The Secretary shall deliver a copy of any notice of appeal to each person shown by the records of the Secretary to be adversely affected by reason of the decision appealed, and shall at all times thereafter permit any such person to inspect and make copies of appellant’s reasons for the appeal and shall on application permit the person to intervene in the appeal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee8bf908-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359ii/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide each appellant an opportunity for a hearing before an administrative law judge in accordance with sections 554 and 556 of title 5. The expenses for conducting the hearing shall be reimbursed by the Commodity Credit Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee8bf909-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title III, § 359i, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1403"},"text":"Pub. L. 107–171, title I, § 1403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/202"},"text":"116 Stat. 202","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1403/h"},"text":"Pub. L. 110–234, title I, § 1403(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date