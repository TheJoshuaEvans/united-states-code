{"tag":"section","attrib":{"id":"idee2c9ada-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s361i"},"text":null,"children":[{"tag":"num","attrib":{"value":"361i"},"text":"§ 361i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Power to amend, repeal, etc., reserved","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Congress may at any time, amend, suspend, or repeal any or all of the provisions of sections 361a to 361i of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee2c9adb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1887-03-02/ch314/s9"},"text":"Mar. 2, 1887, ch. 314, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/442"},"text":"24 Stat. 442","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1955-08-11/ch790/s1"},"text":"Aug. 11, 1955, ch. 790, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/674"},"text":"69 Stat. 674","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee2c9adc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee2c9add-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee2c9ade-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s368b"},"text":"section 368b of this title","children":[],"tail":". The provisions of section 368b were eliminated from "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s361i"},"text":"section 361i of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee2c9adf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1955—Act ","children":[{"tag":"date","attrib":{"date":"1955-08-11"},"text":"Aug. 11, 1955","children":[],"tail":", amended section generally to reserve the right to Congress to amend, suspend, or repeal any or all of the provisions of sections 361a to 361i of this title, and to strike out provisions which subjected grants of moneys to the legislative assent of the several States and Territories."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
