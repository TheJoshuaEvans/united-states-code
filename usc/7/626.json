{"tag":"section","attrib":{"id":"idee55317b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s626"},"text":null,"children":[{"tag":"num","attrib":{"value":"626"},"text":"§ 626.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Import inventory","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee55317c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s626/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compilation and report on imports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture, in consultation with the Secretary of Commerce, the International Trade Commission, the United States Trade Representative, and the heads of all other appropriate Federal agencies, shall compile and report to the public statistics on the total value and quantity of imported raw and processed agricultural products. The report shall be limited to those statistics that such agencies already obtain for other purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee55317d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s626/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compilation and report on consumption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall compile and report to the public data on the total quantity of production and consumption of domestically produced raw and processed agricultural products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee55317e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s626/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuing of data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reports required by this section shall be made in a format that correlates statistics for the quantity and value of imported agricultural products to the production and consumption of domestic agricultural products. The Secretary shall issue such reports on an annual basis, with the first report required not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1988-08-23"},"text":"August 23, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee55317f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tIV/s4502"},"text":"Pub. L. 100–418, title IV, § 4502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1403"},"text":"102 Stat. 1403","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee553180-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee553181-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee553182-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agricultural Competitiveness and Trade Act of 1988 and also as part of the Omnibus Trade and Competitiveness Act of 1988, and not as part of the Agricultural Adjustment Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
