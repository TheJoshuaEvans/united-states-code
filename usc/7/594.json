{"tag":"section","attrib":{"id":"idee3fada6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s594"},"text":null,"children":[{"tag":"num","attrib":{"value":"594"},"text":"§ 594.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption of minimum quantities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may, by regulation, exempt from compliance with the provisions of this chapter (1) any variety or varieties of grapes and plums, and (2) the shipment of such minimum quantities of grapes and plums to any foreign country as he may prescribe.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee3fada7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/687/s4"},"text":"Pub. L. 86–687, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-02"},"text":"Sept. 2, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/734"},"text":"74 Stat. 734","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/105/s2"},"text":"Pub. L. 87–105, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-07-26"},"text":"July 26, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/220"},"text":"75 Stat. 220","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee3fada8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee3fada9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee3fadaa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1961—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/105"},"text":"Pub. L. 87–105","children":[],"tail":" added cl. (1) and designated existing provisions as cl. (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
