{"tag":"section","attrib":{"id":"ideeca1362-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524"},"text":null,"children":[{"tag":"num","attrib":{"value":"1524"},"text":"§ 1524.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education and risk management assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideeca1363-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeca1364-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the amounts made available under paragraph (4), the Secretary, acting through the National Institute of Food and Agriculture, shall carry out the program established under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeca1365-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships for risk management education","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeca1366-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the National Institute of Food and Agriculture, shall establish a program under which competitive grants are made to qualified public and private entities (including land grant colleges, cooperative extension services, and colleges or universities), as determined by the Secretary, for the purpose of educating agricultural producers and providing technical assistance to agricultural producers on a full range of farm viability and risk management activities, including futures, options, agricultural trade options, crop insurance, business planning, enterprise analysis, transfer and succession planning, management coaching, market assessment, cash flow analysis, cash forward contracting, debt reduction, production diversification, farm resources risk reduction, farm financial benchmarking, conservation activities, and other risk management strategies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeca1367-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis for grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this paragraph shall be awarded on the basis of merit and shall be subject to peer or merit review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeca1368-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligation period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds for a grant under this paragraph shall be available to the Secretary for obligation for a 2-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeca1369-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use not more than 4 percent of the funds made available for grants under this paragraph for administrative costs incurred by the Secretary in carrying out this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeca136a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program established under paragraph (2), the Secretary shall place special emphasis on farm viability and risk management strategies (including farm financial benchmarking, business planning and technical assistance, market assessment, transfer and succession planning, and crop insurance participation), education, and outreach specifically targeted at—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeca136b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning farmers or ranchers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeca136c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legal immigrant farmers or ranchers that are attempting to become established producers in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeca136d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" socially disadvantaged farmers or ranchers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeca136e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" farmers or ranchers that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideeca136f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/a/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are preparing to retire;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideeca1370-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/a/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are using transition strategies to help new farmers or ranchers get started; ","children":[{"tag":"ref","attrib":{"idref":"fn002173"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002173"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “and”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideeca1371-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/a/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are converting production and marketing systems to pursue new markets; and ","children":[{"tag":"ref","attrib":{"idref":"fn002174"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002174"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The word “and” probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeca1372-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" producers that are underserved by the Federal crop insurance program established under this subchapter, as determined by the Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeca1373-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veteran farmers or ranchers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeca1374-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the insurance fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1516/c"},"text":"section 1516(c) of this title","children":[],"tail":", there is transferred for the partnerships for risk management education program established under paragraph (2), $10,000,000 for fiscal year 2019 and each subsequent fiscal year, of which not less than $5,000,000 shall be used to carry out paragraph (3)(E)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeca1375-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural management assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeca1376-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide financial assistance to producers in the States of Connecticut, Delaware, Hawaii, Maryland, Massachusetts, Maine, Nevada, New Hampshire, New Jersey, New York, Pennsylvania, Rhode Island, Utah, Vermont, West Virginia, and Wyoming.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeca1377-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A producer may use financial assistance provided under this subsection to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeca1378-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" construct or improve—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideeca1379-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" watershed management structures; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideeca137a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" irrigation structures;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeca137b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plant trees to form windbreaks or to improve water quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeca137c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" mitigate financial risk through production or marketing diversification or resource conservation practices, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideeca137d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" soil erosion control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideeca137e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrated pest management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideeca137f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organic farming; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideeca1380-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and implement a plan to create marketing opportunities for the producer, including through value-added processing;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeca1381-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into futures, hedging, or options contracts in a manner designed to help reduce production, price, or revenue risk;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeca1382-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into agricultural trade options as a hedging transaction to reduce production, price, or revenue risk; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeca1383-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct any other activity relating to an activity described in subparagraphs (A) through (E), as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeca1384-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of payments made to a person (as defined in section 1308(5) ","children":[{"tag":"ref","attrib":{"idref":"fn002175"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002175"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" See References in Text note below."}],"tail":" of this title) (before the amendment made by section 1603(a) "},{"tag":"ref","attrib":{"idref":"fn002175"},"text":"3","children":[],"tail":" of the Food, Conservation, and Energy Act of 2008) under this subsection for any year may not exceed $50,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeca1385-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodity Credit Corporation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeca1386-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out this subsection through the Commodity Credit Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeca1387-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideeca1388-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), the Commodity Credit Corporation shall make available to carry out this subsection not less than $10,000,000 for each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideeca1389-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain fiscal years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of fiscal years 2008 through 2014, the Commodity Credit Corporation shall make available to carry out this subsection $15,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeca138a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts made available to carry out this subsection for a fiscal year, the Commodity Credit Corporation shall use not less than—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideeca138b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent to carry out subparagraphs (A), (B), and (C) of paragraph (2) through the Natural Resources Conservation Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideeca138c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent to provide organic certification cost share assistance through the Agricultural Marketing Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideeca138d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1524/b/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 40 percent to conduct activities to carry out subparagraph (F) of paragraph (2) through the Risk Management Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideeca138e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title V, § 524, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/224/tI/s133"},"text":"Pub. L. 106–224, title I, § 133","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/387"},"text":"114 Stat. 387","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tII/s2501"},"text":"Pub. L. 107–171, title II, § 2501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/263"},"text":"116 Stat. 263","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/199/dA/tVII/s769"},"text":"Pub. L. 108–199, div. A, title VII, § 769","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/40"},"text":"118 Stat. 40","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1603/g/3"},"text":"Pub. L. 110–234, title I, § 1603(g)(3)","children":[],"tail":", title II, § 2801, title VII, § 7511(c)(2), title XII, § 12026, "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1011"},"text":"122 Stat. 1011","children":[],"tail":", 1085, 1267, 1390; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1603(g)(3), title II, § 2801, title VII, § 7511(c)(2), title XII, § 12026, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1739, 1813, 2028, 2152; "},{"tag":"ref","attrib":{"href":"/us/pl/112/55/dA/tVII/s716/a"},"text":"Pub. L. 112–55, div. A, title VII, § 716(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-11-18"},"text":"Nov. 18, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/582"},"text":"125 Stat. 582","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1609/b/1"},"text":"Pub. L. 113–79, title I, § 1609(b)(1)","children":[],"tail":", title XI, § 11027(c), "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/709"},"text":"128 Stat. 709","children":[],"tail":", 977; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXI/s11125/a"},"text":"Pub. L. 115–334, title XI, § 11125(a)","children":[],"tail":", title XII, § 12306(b)(3), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4935"},"text":"132 Stat. 4935","children":[],"tail":", 4969.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideecc5c7f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideecc5c80-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideecc5c81-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308/5"},"text":"Section 1308(5) of this title","children":[],"tail":", which required the Secretary to issue regulations defining “person”, referred to in subsec. (b)(3), was redesignated section 1308(e) and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/s1603/b/1"},"text":"section 1603(b)(1) of Pub. L. 107–171","children":[],"tail":". Section 1603(a) of the Food, Conservation, and Energy Act of 2008, "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", subsequently amended the definition of “covered commodity” in section 1308(a)(1). "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1603/b"},"text":"Section 1603(b) of Pub. L. 110–246","children":[],"tail":" amended section 1308 by, among other things, striking out subsec. (e) and adding subsec. (a)(4) which defined “person”. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1603"},"text":"section 1603 of Pub. L. 110–246","children":[],"tail":" to section 1308 were effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideecc5c82-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideecc5c83-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s11125/a/1"},"text":"Pub. L. 115–334, § 11125(a)(1)","children":[],"tail":", substituted “paragraph (4), the Secretary” for “paragraph (5)—”, struck out subpar. (A) and “(B) the Secretary” before “, acting through”, and substituted “paragraph (2)” for “paragraph (3)”. Prior to amendment, subpar. (A) read as follows: “the Corporation shall carry out the program established under paragraph (2); and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s11125/a/2"},"text":"Pub. L. 115–334, § 11125(a)(2)","children":[],"tail":", (3), redesignated par. (3) as (2) and struck out former par. (2). Prior to amendment, text of par. (2) read as follows: “The Corporation shall establish a program under which crop insurance education and information is provided to producers in States in which (as determined by the Secretary)—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) there is traditionally, and continues to be, a low level of Federal crop insurance participation and availability; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) producers are underserved by the Federal crop insurance program.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s11125/a/4"},"text":"Pub. L. 115–334, § 11125(a)(4)","children":[],"tail":", substituted “and providing technical assistance to agricultural producers on a full range of farm viability and” for “about the full range of” and inserted “business planning, enterprise analysis, transfer and succession planning, management coaching, market assessment, cash flow analysis,” after “insurance,” and “conservation activities,” after “benchmarking,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s11125/a/3"},"text":"Pub. L. 115–334, § 11125(a)(3)","children":[],"tail":", (5)(A), redesignated par. (4) as (3) and, in introductory provisions, substituted “program established under paragraph (2)” for “programs established under paragraphs (2) and (3)” and inserted “farm viability and” after “emphasis on” and “, business planning and technical assistance, market assessment, transfer and succession planning, and crop insurance participation” after “benchmarking”. Former par. (3) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(D)(iii), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s11125/a/5/B"},"text":"Pub. L. 115–334, § 11125(a)(5)(B)","children":[],"tail":", (C), added subpars. (D)(iii) and (E) and struck out former subpar. (E) which read as follows: “new or established farmers or ranchers that are converting production and marketing systems to pursue new markets.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12306/b/3/A"},"text":"Pub. L. 115–334, § 12306(b)(3)(A)","children":[],"tail":"–(C), added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s11125/a/6"},"text":"Pub. L. 115–334, § 11125(a)(6)","children":[],"tail":", substituted “transferred for the partnerships” for “transferred—”, subpar. (A), and “(B) for the partnerships”, substituted “paragraph (2), $10,000,000 for fiscal year 2019” for “paragraph (3), $5,000,000 for fiscal year 2001”, and inserted “, of which not less than $5,000,000 shall be used to carry out paragraph (3)(E)” before period at end. Prior to amendment, subpar. (A) read as follows: “for the education and information program established under paragraph (2), $5,000,000 for fiscal year 2001 and each subsequent fiscal year; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s11027/c/1"},"text":"Pub. L. 113–79, § 11027(c)(1)","children":[],"tail":", inserted “farm financial benchmarking,” after “risk reduction,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s11027/c/2"},"text":"Pub. L. 113–79, § 11027(c)(2)","children":[],"tail":", inserted “(including farm financial benchmarking)” after “management strategies” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s1609/b/1"},"text":"Pub. L. 113–79, § 1609(b)(1)","children":[],"tail":", amended language inserted by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1603/g/3"},"text":"Pub. L. 110–246, § 1603(g)(3)","children":[],"tail":". See 2008 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(4)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/55"},"text":"Pub. L. 112–55","children":[],"tail":" substituted “certain fiscal years” for “fiscal years 2008 through 2012” in heading and “2014” for “2012” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s12026/1"},"text":"Pub. L. 110–246, § 12026(1)","children":[],"tail":", substituted “paragraph (5)” for “paragraph (4)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B), (3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7511/c/2"},"text":"Pub. L. 110–246, § 7511(c)(2)","children":[],"tail":", substituted “the National Institute of Food and Agriculture” for “the Cooperative State Research, Education, and Extension Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s12026/2"},"text":"Pub. L. 110–246, § 12026(2)","children":[],"tail":", (3), added par. (4) and redesignated former par. (4) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s2801/a"},"text":"Pub. L. 110–246, § 2801(a)","children":[],"tail":", inserted “Hawaii,” after “Delaware,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1603/g/3"},"text":"Pub. L. 110–246, § 1603(g)(3)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/s1609/b/1"},"text":"Pub. L. 113–79, § 1609(b)(1)","children":[],"tail":", inserted “(before the amendment made by section 1603(a) of the Food, Conservation, and Energy Act of 2008)” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308/5"},"text":"section 1308(5) of this title","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s2801/b/1"},"text":"Pub. L. 110–246, § 2801(b)(1)","children":[],"tail":", substituted “Except as provided in clause (ii)” for “Except as provided in clauses (ii) and (iii)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(B)(ii), (iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s2801/b/2"},"text":"Pub. L. 110–246, § 2801(b)(2)","children":[],"tail":", added cl. (ii) and struck out former cls. (ii) and (iii) which related to exception for fiscal years 2003 through 2007 and minimum amounts to carry out certain uses."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s2801/c"},"text":"Pub. L. 110–246, § 2801(c)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(4)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/s769/1"},"text":"Pub. L. 108–199, § 769(1)","children":[],"tail":", substituted “clauses (ii) and (iii)” for “clause (ii)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/s769/2"},"text":"Pub. L. 108–199, § 769(2)","children":[],"tail":", added cl. (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" added subsec. (b) and struck out heading and text of former subsec. (b). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—The Secretary shall provide cost share assistance to producers, in a manner determined by the Secretary, in not less than 10, nor more than 15, States in which participation in the Federal crop insurance program is historically low, as determined by the Secretary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Uses","children":[],"tail":".—A producer may use cost share assistance provided under this subsection to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) construct or improve—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) watershed management structures; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) irrigation structures;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) plant trees to form windbreaks or to improve water quality;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) mitigate financial risk through production diversification or resource conservation practices, including—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) soil erosion control;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) integrated pest management; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) transition to organic farming;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) enter into futures, hedging, or options contracts in a manner designed to help reduce production, price, or revenue risk;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) enter into agricultural trade options as a hedging transaction to reduce production, price, or revenue risk; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(F) conduct any other activity related to the activities described in subparagraphs (A) through (E), as determined by the Secretary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Payment limitation","children":[],"tail":".—The total amount of payments made to a person (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308/5"},"text":"section 1308(5) of this title","children":[],"tail":") under this subsection for any year may not exceed $50,000."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) ","children":[{"tag":"inline","attrib":{},"text":"Commodity credit corporation.—","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—The Secretary shall carry out this subsection through the Commodity Credit Corporation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—The Commodity Credit Corporation shall make available to carry out this subsection $10,000,000 for fiscal year 2001 and each subsequent fiscal year.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideecc5c84-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideecc5c85-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" effective as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/s1609/b/2"},"text":"section 1609(b)(2) of Pub. L. 113–79","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1471g"},"text":"section 1471g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideecc5c86-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref