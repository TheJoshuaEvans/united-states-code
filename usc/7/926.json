{"tag":"section","attrib":{"id":"idee5c5d02-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s926"},"text":null,"children":[{"tag":"num","attrib":{"value":"926"},"text":"§ 926.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain rural development investments by qualified telephone borrowers not treated as dividends or distributions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee5c5d03-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s926/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee5c5d04-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s926/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treat any amount invested by any qualified telephone borrower for any purpose described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2204b/c/2"},"text":"section 2204b(c)(2) of this title","children":[],"tail":" (including any investment in, or extension of credit, guarantee, or advance made to, an affiliated company of the borrower, that is used by such company for such a purpose) as a dividend or distribution of capital to the extent that, immediately after such investment, the aggregate of such investments does not exceed ⅓ of the net worth of the borrower; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5c5d05-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s926/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require a qualified telephone borrower to obtain the approval of the Secretary in order to make an investment described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee5c5d06-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s926/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Qualified telephone borrower” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in subsection (a), the term “qualified telephone borrower” means a person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee5c5d07-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s926/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to whom a telephone loan has been made or guaranteed under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5c5d08-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s926/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose net worth is at least 20 percent of the total assets of such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee5c5d09-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title II, § 205, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2356"},"text":"Pub. L. 101–624, title XXIII, § 2356","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4039"},"text":"104 Stat. 4039","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s235/a/13"},"text":"Pub. L. 103–354, title II, § 235(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3221"},"text":"108 Stat. 3221","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6602/b/3"},"text":"Pub. L. 115–334, title VI, § 6602(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4776"},"text":"132 Stat. 4776","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee5c5d0a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee5c5d0b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee5c5d0c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6602/b/3/A"},"text":"Pub. L. 115–334, § 6602(b)(3)(A)","children":[],"tail":", struck out “and the Governor of the telephone bank” after “The Secretary” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6602/b/3/B"},"text":"Pub. L. 115–334, § 6602(b)(3)(B)","children":[],"tail":", struck out “or the Governor of the telephone bank” after “the Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" substituted “Secretary” for “Administrator” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],