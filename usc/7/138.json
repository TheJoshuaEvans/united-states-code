{"tag":"section","attrib":{"id":"idee14cca4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138"},"text":null,"children":[{"tag":"num","attrib":{"value":"138"},"text":"§ 138.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee14cca5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agricultural product” means any fresh fruit or vegetable or any commodity or product derived from livestock or fowl, that is marketed in the United States for human consumption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee14cca6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certificate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “certificate” means a certificate of accreditation issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee14cca7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laboratory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “laboratory” means any facility or vehicle that is owned by an individual or a public or private entity and is equipped and operated for the purpose of carrying out pesticide residue analysis on agricultural products for commercial purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee14cca8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pesticide","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “pesticide” means any substance that alone, in chemical combination, or in any formulation with one or more substances, is defined as a pesticide in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136/u"},"text":"section 136(u) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee14cca9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee14ccaa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIII/s1321"},"text":"Pub. L. 101–624, title XIII, § 1321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3562"},"text":"104 Stat. 3562","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
