{"tag":"section","attrib":{"id":"idee6118f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940i"},"text":null,"children":[{"tag":"num","attrib":{"value":"940i"},"text":"§ 940i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cybersecurity and grid security improvements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee6118f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of cybersecurity and grid security improvements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “cybersecurity and grid security improvements” means investment in the development, expansion, and modernization of rural utility infrastructure that addresses known cybersecurity and grid security risks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee6118f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans and loan guarantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make or guarantee loans under this subchapter and subchapter I for cybersecurity and grid security improvements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee6118f5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title III, § 319, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6507"},"text":"Pub. L. 115–334, title VI, § 6507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4775"},"text":"132 Stat. 4775","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
