{"tag":"section","attrib":{"id":"idef248fd1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2008a"},"text":"§ 2008a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable relief","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef248fd2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), the Secretary may provide a form of relief described in subsection (c) to any farmer or rancher who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef248fd3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received a direct farm ownership, operating, or emergency loan under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248fd4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines is not in compliance with the requirements of this chapter with respect to the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef248fd5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may only provide relief to a farmer or rancher under subsection (a) if the Secretary determines that the farmer or rancher—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef248fd6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acted in good faith; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248fd7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relied on an action of, or the advice of, the Secretary (including any authorized representative of the Secretary) to the detriment of the farming or ranching operation of the farmer or rancher.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef248fd8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forms of relief","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide to a farmer or rancher under subsection (a) any of the following forms of relief:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef248fd9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The farmer or rancher may retain loans or other benefits received in association with the loan with respect to which the farmer or rancher was determined to be noncompliant under subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248fda-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The farmer or rancher may receive such other equitable relief as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef248fdb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of receiving relief under this section, the Secretary may require the farmer or rancher to take actions designed to remedy the noncompliance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef248fdc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative appeal; judicial review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A determination or action of the Secretary under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef248fdd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be final; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248fde-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be subject to administrative appeal or judicial review under chapter 7 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef248fdf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s366"},"text":"Pub. L. 87–128, title III, § 366","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5305"},"text":"Pub. L. 115–334, title V, § 5305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4672"},"text":"132 Stat. 4672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef248fe0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef248fe1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef248fe2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/307"},"text":"75 Stat. 307","children":[],"tail":", known as the Consolidated Farm and Rural Development Act, which is classified principally to this chapter. For complete classification of title III to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idef248fe3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2008a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s366"},"text":"Pub. L. 87–128, title III, § 366","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2316/a"},"text":"Pub. L. 101–624, title XXIII, § 2316(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4004"},"text":"104 Stat. 4004","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tVII/s701/f"},"text":"Pub. L. 102–237, title VII, § 701(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1879"},"text":"105 Stat. 1879","children":[],"tail":", related to State rural economic development review panel, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s754"},"text":"Pub. L. 104–127, title VII, § 754","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1131"},"text":"110 Stat. 1131","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
