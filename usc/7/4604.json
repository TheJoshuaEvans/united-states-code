{"tag":"section","attrib":{"id":"idefbadbb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4604"},"text":null,"children":[{"tag":"num","attrib":{"value":"4604"},"text":"§ 4604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and hearing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefbadbb4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4604/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In issuing an order under this chapter, an amendment to an order, or a regulation to carry out this chapter, the Secretary shall comply with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbadbb5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4604/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formal agency action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sections 556 and 557 of that title shall not apply with respect to the issuance of an order, an amendment to an order, or a regulation under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbadbb6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4604/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposal of an order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A proposal for an order may be submitted to the Secretary by any organization or interested person affected by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefbadbb7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/590/s5"},"text":"Pub. L. 98–590, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3117"},"text":"98 Stat. 3117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tVI/s605/d"},"text":"Pub. L. 105–185, title VI, § 605(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/589"},"text":"112 Stat. 589","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefbadbb8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefbadbb9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefbadbba-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185"},"text":"Pub. L. 105–185","children":[],"tail":" reenacted section catchline without change and amended text generally. Prior to amendment, text read as follows: “Whenever the Secretary has reason to believe that the issuance of an order will assist in carrying out the purpose of this chapter, the Secretary shall provide due notice of and opportunity for a hearing upon a proposed order. Such hearing may be requested and a proposal for an order submitted by any organization or interested person affected by the provisions of this chapter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
