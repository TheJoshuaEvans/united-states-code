{"tag":"section","attrib":{"id":"idef75bcfb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2209i"},"text":null,"children":[{"tag":"num","attrib":{"value":"2209i"},"text":"§ 2209i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for preparation of final agency decisions regarding discrimination complaints","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"2005-11-10"},"text":"November 10, 2005","children":[],"tail":", agencies and offices of the Department of Agriculture may utilize any available discretionary funds to cover the costs of preparing, or contracting for the preparation of, final agency decisions regarding complaints of discrimination in employment or program activities arising within such agencies and offices."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef75bcfc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/97/tVII/s751"},"text":"Pub. L. 109–97, title VII, § 751","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-10"},"text":"Nov. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2156"},"text":"119 Stat. 2156","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef75bcfd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef75bcfe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idef75bcff-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":