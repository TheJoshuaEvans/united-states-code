{"tag":"section","attrib":{"id":"idf01a395f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655d"},"text":null,"children":[{"tag":"num","attrib":{"value":"7655d"},"text":"§ 7655d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wood innovation grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf01a3960-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01a3961-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01a3962-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655d/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a3963-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655d/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public or private entity (including a center of excellence that consists of 1 or more partnerships between forestry, engineering, architecture, or business schools at 1 or more institutions of higher education); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a3964-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655d/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, local, or Tribal government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a3965-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary, acting through the Chief of the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01a3966-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01a3967-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in carrying out the wood innovation grant program of the Secretary described in the notice of the Secretary entitled “Request for Proposals: 2016 Wood Innovations Funding Opportunity” (80 Fed. Reg. 63498 (","children":[{"tag":"date","attrib":{"date":"2015-10-20"},"text":"October 20, 2015","children":[],"tail":")), may make a wood innovation grant to 1 or more eligible entities each year for the purpose of advancing the use of innovative wood products."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a3968-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this subsection, an eligible entity shall submit to the Secretary a proposal at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01a3969-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentivizing use of existing milling capacity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting among proposals of eligible entities under subsection (b)(2), the Secretary shall give priority to proposals that include the use or retrofitting (or both) of existing sawmill facilities located in counties in which the average annual unemployment rate exceeded the national average unemployment rate by more than 1 percent in the previous calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01a396a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of receiving a grant under subsection (b), an eligible entity shall provide funds equal to the amount received by the eligible entity under the grant, to be derived from non-Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf01a396b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVIII/s8643"},"text":"Pub. L. 115–334, title VIII, § 8643","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4872"},"text":"132 Stat. 4872","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf01a396c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf01a396d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf01a396e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agriculture Improvement Act of 2018, and not as part of the Agricultural Research, Extension, and Education Reform Act of 1998, which in part comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf01a396f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idf01a3970-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” as meaning the Secretary of Agriculture, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2"},"text":"section 2 of Pub. L. 115–334","children":[],"tail":", set out as a Definition of “Secretary” note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “innovative wood product”, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8641"},"text":"section 8641 of Pub. L. 115–334","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7655c"},"text":"section 7655c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
