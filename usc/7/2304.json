{"tag":"section","attrib":{"id":"idef81a3ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2304"},"text":null,"children":[{"tag":"num","attrib":{"value":"2304"},"text":"§ 2304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclaimer of intention to prohibit normal dealing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall prevent handlers and producers from selecting their customers and suppliers for any reason other than a producer’s membership in or contract with an association of producers, nor require a handler to deal with an association of producers.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef81a3ac-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/288/s5"},"text":"Pub. L. 90–288, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-04-16"},"text":"Apr. 16, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/95"},"text":"82 Stat. 95","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
