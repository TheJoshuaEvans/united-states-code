{"tag":"section","attrib":{"id":"idefc47892-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5102"},"text":null,"children":[{"tag":"num","attrib":{"value":"5102"},"text":"§ 5102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching grants to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefc47893-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 60 days after the Secretary certifies the State as a qualifying State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5101/b"},"text":"section 5101(b) of this title","children":[],"tail":", the Secretary shall provide financial assistance to the State, in accordance with subsection (b), for the operation and administration of the mediation program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc47894-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grant","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc47895-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary shall pay to a State under subsection (a) not more than 70 percent of the cost of the operation and administration of the mediation program within the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc47896-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not pay more than $500,000 per year to a single State under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc47897-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc47898-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5102/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State that receives an amount paid under subsection (a) shall use that amount only for the operation and administration of the mediation program of the State with respect to which the amount was paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc47899-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5102/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation and administration expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), operation and administration expenses for which a grant may be used include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc4789a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5102/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" salaries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc4789b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5102/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable fees and costs of mediators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc4789c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5102/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" office rent and expenses, such as utilities and equipment rental;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc4789d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5102/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" office supplies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc4789e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5102/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative costs, such as workers’ compensation, liability insurance, the employer’s share of Social Security, and necessary travel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc4789f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5102/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education and training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc478a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5102/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security systems necessary to ensure the confidentiality of mediation sessions and records of mediation sessions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc478a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5102/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs associated with publicity and promotion of the mediation program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc478a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5102/c/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparation of the parties for mediation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc478a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5102/c/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial advisory and counseling services for parties requesting mediation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc478a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that a State has not complied with subsection (c), such State shall not be eligible for additional financial assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefc478a5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233/tV/s502"},"text":"Pub. L. 100–233, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1663"},"text":"101 Stat. 1663","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/554/s22"},"text":"Pub. L. 102–554, § 22","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4161"},"text":"106 Stat. 4161","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s282/f/1/A"},"text":"Pub. L. 103–354, title II, § 282(f)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3235"},"text":"108 Stat. 3235","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/472/tIII/s306/b"},"text":"Pub. L. 106–472, title III, § 306(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2072"},"text":"114 Stat. 2072","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefc478a6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefc478a7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefc478a8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/472"},"text":"Pub. L. 106–472","children":[],"tail":" designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsecs. (a), (b)(1), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" struck out “agricultural loan” before “mediation program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/554/s22/1"},"text":"Pub. L. 102–554, § 22(1)","children":[],"tail":", substituted “70” for “50”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/554/s22/2"},"text":"Pub. L. 102–554, § 22(2)","children":[],"tail":", inserted before period at end “with respect to which the amount was paid”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
