{"tag":"section","attrib":{"id":"idefef5a02-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6811"},"text":null,"children":[{"tag":"num","attrib":{"value":"6811"},"text":"§ 6811.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for Secretary to suspend or terminate order","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If the Secretary finds that an order, or any provision of the order, obstructs or does not tend to effectuate the policy of this chapter specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6801/b"},"text":"section 6801(b) of this title","children":[],"tail":", the Secretary shall terminate or suspend the operation of the order or provision under such terms as the Secretary determines are appropriate."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefef5a03-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/190/s12"},"text":"Pub. L. 103–190, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2289"},"text":"107 Stat. 2289","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
