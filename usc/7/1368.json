{"tag":"section","attrib":{"id":"idee8e6984-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1368"},"text":null,"children":[{"tag":"num","attrib":{"value":"1368"},"text":"§ 1368.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of increase on other quotas","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any increase of any farm marketing quota for any farm as a result of review of the determination thereof under this subpart, the marketing quotas for other farms shall not be affected.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee8e6985-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title III, § 368, "},{"tag":"ref","attrib":{"href":"/us/stat/52/64"},"text":"52 Stat. 64","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
