{"tag":"section","attrib":{"id":"idf0262099-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934"},"text":null,"children":[{"tag":"num","attrib":{"value":"7934"},"text":"§ 7934.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf026209a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall permit the producers on a farm to repay a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7931"},"text":"section 7931 of this title","children":[],"tail":" for a loan commodity (other than upland cotton, rice, extra long staple cotton, and confectionery and each other kind of sunflower seed (other than oil sunflower seed)) at a rate that is the lesser of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf026209b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established for the commodity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7932"},"text":"section 7932 of this title","children":[],"tail":", plus interest (determined in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7283"},"text":"section 7283 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf026209c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a rate that the Secretary determines will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf026209d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize potential loan forfeitures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf026209e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the accumulation of stocks of the commodity by the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf026209f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the cost incurred by the Federal Government in storing the commodity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02620a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow the commodity produced in the United States to be marketed freely and competitively, both domestically and internationally; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02620a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize discrepancies in marketing loan benefits across State boundaries and across county boundaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02620a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment rates for upland cotton and rice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall permit producers to repay a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7931"},"text":"section 7931 of this title","children":[],"tail":" for upland cotton and rice at a rate that is the lesser of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02620a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established for the commodity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7932"},"text":"section 7932 of this title","children":[],"tail":", plus interest (determined in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7283"},"text":"section 7283 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02620a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prevailing world market price for the commodity (adjusted to United States quality and location), as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02620a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment rates for extra long staple cotton","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Repayment of a marketing assistance loan for extra long staple cotton shall be at the loan rate established for the commodity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7932"},"text":"section 7932 of this title","children":[],"tail":", plus interest (determined in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7283"},"text":"section 7283 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02620a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevailing world market price","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7937"},"text":"section 7937 of this title","children":[],"tail":", the Secretary shall prescribe by regulation—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02620a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a formula to determine the prevailing world market price for upland cotton and rice, adjusted to United States quality and location; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02620a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mechanism by which the Secretary shall announce periodically the prevailing world market price for upland cotton and rice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02620a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of prevailing world market price for upland cotton","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02620aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the period beginning on ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"2008-07-31"},"text":"July 31, 2008","children":[],"tail":", the prevailing world market price for upland cotton (adjusted to United States quality and location) established under subsection (d) shall be further adjusted if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02620ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjusted prevailing world market price is less than 115 percent of the loan rate for upland cotton established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7932"},"text":"section 7932 of this title","children":[],"tail":", as determined by the Secretary; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02620ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Friday through Thursday average price quotation for the lowest-priced United States growth as quoted for Middling (M) 1","children":[{"tag":"sup","attrib":{},"text":"3","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"32","children":[],"tail":"-inch cotton delivered C.I.F. Northern Europe is greater than the Friday through Thursday average price of the 5 lowest-priced growths of upland cotton, as quoted for Middling (M) 1"},{"tag":"sup","attrib":{},"text":"3","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"32","children":[],"tail":"-inch cotton, delivered C.I.F. Northern Europe (referred to in this section as the “Northern Europe price”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02620ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Further adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (3), the adjusted prevailing world market price for upland cotton shall be further adjusted on the basis of some or all of the following data, as available:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02620ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States share of world exports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02620af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The current level of cotton export sales and cotton export shipments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02620b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other data determined by the Secretary to be relevant in establishing an accurate prevailing world market price for upland cotton (adjusted to United States quality and location).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02620b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on further adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The adjustment under paragraph (2) may not exceed the difference between—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02620b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Friday through Thursday average price for the lowest-priced United States growth as quoted for Middling 1","children":[{"tag":"sup","attrib":{},"text":"3","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"32","children":[],"tail":"-inch cotton delivered C.I.F. Northern Europe; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02620b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Northern Europe price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02620b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment rates for confectionery and other kinds of sunflower seeds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall permit the producers on a farm to repay a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7931"},"text":"section 7931 of this title","children":[],"tail":" for confectionery and each other kind of sunflower seed (other than oil sunflower seed) at a rate that is the lesser of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02620b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established for the commodity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7932"},"text":"section 7932 of this title","children":[],"tail":", plus interest (determined in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7283"},"text":"section 7283 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02620b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the repayment rate established for oil sunflower seed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02620b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quality grades for dry peas, lentils, and small chickpeas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The loan repayment rate for dry peas, lentils, and small chickpeas shall be based on the quality grades for the applicable commodity specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7932/d"},"text":"section 7932(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02620b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7934/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Good faith exception to beneficial interest requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the 2001 crop year only, in the case of the producers on a farm that marketed or otherwise lost beneficial interest in a loan commodity for which a marketing assistance loan was made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7231"},"text":"section 7231 of this title","children":[],"tail":" before repaying the loan, the Secretary shall permit the producers to repay the loan at the appropriate repayment rate that was in effect for the loan commodity under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7234"},"text":"section 7234 of this title","children":[],"tail":" on the date that the producers lost beneficial interest, as determined by the Secretary, if the Secretary determines the producers acted in good faith."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf02620b9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1204"},"text":"Pub. L. 107–171, title I, § 1204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/156"},"text":"116 Stat. 156","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dA/tVII/s763/c"},"text":"Pub. L. 108–7, div. A, title VII, § 763(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/47"},"text":"117 Stat. 47","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf02620ba-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf02620bb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf02620bc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/s763/c/1"},"text":"Pub. L. 108–7, § 763(c)(1)","children":[],"tail":", substituted “extra long staple cotton, and confectionery and each other kind of sunflower seed (other than oil sunflower seed)” for “and extra long staple cotton”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/s763/c/2"},"text":"Pub. L. 108–7, § 763(c)(2)","children":[],"tail":", (3), added subsecs. (f) and (g) and redesignated former subsec. (f) as (h)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf02620bd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf02620be-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":" applicable beginning with the 2003 crop of other oilseeds, dry peas, lentils, and small chickpeas, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/s763/d"},"text":"section 763(d) of Pub. L. 108–7","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7901"},"text":"section 7901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
