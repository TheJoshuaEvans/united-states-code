{"tag":"section","attrib":{"id":"idee7b5746-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1326"},"text":null,"children":[{"tag":"num","attrib":{"value":"1326"},"text":"§ 1326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of farm marketing quotas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee7b5747-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1326/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever in any county or other area the Secretary finds that the actual production of corn plus the amount of corn stored under seal in such county or other area is less than the normal production of the marketing percentage of the farm acreage allotments in such county or other area, the Secretary shall terminate farm marketing quotas for corn in such county or other area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee7b5748-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1326/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever, upon any farm, the actual production of the acreage of corn is less than the normal production of the marketing percentage of the farm acreage allotment, there may be marketed, without penalty, from such farm an amount of corn from the corn stored under seal pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1324"},"text":"section 1324 of this title","children":[],"tail":" which, together with the actual production of the then current crop, will equal the normal production of the marketing percentage of the farm acreage allotment."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee7b5749-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1326/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever, in any marketing year, marketing quotas are not in effect with respect to the crop of corn produced in the calendar year in which such marketing year begins, all marketing quotas applicable to previous crops of corn shall be terminated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee7b574a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title III, § 326, "},{"tag":"ref","attrib":{"href":"/us/stat/52/51"},"text":"52 Stat. 51","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee7b574b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee7b574c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idee7b574d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1324"},"text":"Section 1324 of this title","children":[],"tail":", referred to in subsec. (b), was repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-28/ch1041/tIII/s304"},"text":"act Aug. 28, 1954, ch. 1041, title III, § 304","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/902"},"text":"68 Stat. 902","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee7b574e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idee7b574f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inapplicability of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section inapplicable to 2014 through 2018 crops of covered commodities, cotton, and sugar and inapplicable to milk during period beginning ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9092/a/1"},"text":"section 9092(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section inapplicable to 2008 through 2012 crops of covered commodities, peanuts, and sugar and inapplicable to milk during period beginning ","children":[{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"2012-12-31"},"text":"Dec. 31, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8782/a/1"},"text":"section 8782(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section inapplicable to 2002 through 2007 crops of covered commodities, peanuts, and sugar and inapplicable to milk during period beginning ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"2007-12-31"},"text":"Dec. 31, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7992/a/1"},"text":"section 7992(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section inapplicable to 1996 through 2001 crops of loan commodities, peanuts, and sugar and inapplicable to milk during period beginning ","children":[{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"2002-12-31"},"text":"Dec. 31, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7301/a/1/A"},"text":"section 7301(a)(1)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"repeals","id":"idee7b5750-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeals","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-28/ch1041/tIII/s304"},"text":"Act Aug. 28, 1954, ch. 1041, title III, § 304","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/902"},"text":"68 Stat. 902","children":[],"tail":", repealed this section insofar as it is applicable to corn. Section has been made applicable to wheat by sections 1330(6) and 1340(6) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
