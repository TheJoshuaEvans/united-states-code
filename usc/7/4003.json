{"tag":"section","attrib":{"id":"idefb13f2f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4003"},"text":null,"children":[{"tag":"num","attrib":{"value":"4003"},"text":"§ 4003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study of potential for expansion of United States agricultural export markets; report to President and Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefb13f30-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture, in consultation with the United States Trade Representative and any other appropriate agency of the United States Government as determined by the Secretary, shall perform a study of the potential for expansion of United States agricultural export markets and the use of agricultural exports in obtaining natural resources or other commodities and products needed by the United States. The Secretary shall complete the study and submit to the President and Congress a report on the study before ","children":[{"tag":"date","attrib":{"date":"1981-06-30"},"text":"June 30, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb13f31-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In performing the study, the Secretary shall determine for the next five years—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefb13f32-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4003/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" world food, feed, and fiber needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb13f33-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4003/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimated United States and world food, feed, and fiber production capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb13f34-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4003/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential new or expanded foreign markets for United States agricultural products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb13f35-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4003/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for the development of international agreements for the exchange of United States agricultural products for natural resources, including energy sources, or other commodities and products needed by the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb13f36-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4003/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the steps that the United States must take to (A) increase agricultural export trade, and (B) obtain needed natural resources or other commodities and products in exchange for agricultural products, to the maximum extent feasible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefb13f37-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/494/tII/s210"},"text":"Pub. L. 96–494, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-03"},"text":"Dec. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2576"},"text":"94 Stat. 2576","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefb13f38-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefb13f39-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefb13f3a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1980-12-03"},"text":"Dec. 3, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/494/s213"},"text":"section 213 of Pub. L. 96–494","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4001"},"text":"section 4001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
