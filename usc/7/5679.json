{"tag":"section","attrib":{"id":"idefcdee58-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5679"},"text":null,"children":[{"tag":"num","attrib":{"value":"5679"},"text":"§ 5679.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biotechnology and agricultural trade program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefcdee59-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5679/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Department the biotechnology and agricultural trade program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdee5a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5679/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the program shall be to remove, resolve, or mitigate significant regulatory nontariff barriers to the export of United States agricultural commodities (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5602"},"text":"section 5602 of this title","children":[],"tail":") into foreign markets through public and private sector projects funded by grants that address—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcdee5b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5679/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" quick response intervention regarding nontariff barriers to United States exports involving—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefcdee5c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5679/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States agricultural commodities produced through biotechnology or new agricultural production technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdee5d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5679/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdee5e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5679/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disease; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdee5f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5679/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other sanitary or phytosanitary concerns; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdee60-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5679/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing protocols as part of bilateral negotiations with other countries on issues such as animal health, grain quality, and genetically modified commodities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdee61-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5679/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Depending on need, as determined by the Secretary, activities authorized under this section may be carried out through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcdee62-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5679/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdee63-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5679/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the emerging markets program under section 1542 ","children":[{"tag":"ref","attrib":{"idref":"fn002308"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002308"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s5623/d"},"text":"section 5623(d) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdee64-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5679/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Cochran Fellowship Program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3293"},"text":"section 3293 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdee65-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5679/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated $2,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefcdee66-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1543A"},"text":"Pub. L. 101–624, title XV, § 1543A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIII/s3204"},"text":"Pub. L. 107–171, title III, § 3204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/300"},"text":"116 Stat. 300","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIII"},"text":"Pub. L. 115–334, title III","children":[],"tail":", §§ 3201(b)(3)(C), 3301, "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4617"},"text":"132 Stat. 4617","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefcdee67-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefcdee68-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefcdee69-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1542, referred to in subsec. (c)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1542"},"text":"section 1542 of title XV of Pub. L. 101–624","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s5622"},"text":"section 5622 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefcdee6a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food, Agriculture, Conservation, and Trade Act of 1990, and not as part of the Agricultural Trade Act of 1978 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefcdee6b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3301/1"},"text":"Pub. L. 115–334, § 3301(1)","children":[],"tail":", inserted “or new agricultural production technologies” after “biotechnology”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3201/b/3/C"},"text":"Pub. L. 115–334, § 3201(b)(3)(C)","children":[],"tail":", inserted “and "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s5623/d"},"text":"section 5623(d) of this title","children":[],"tail":"” after “section 1542”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3301/2"},"text":"Pub. L. 115–334, § 3301(2)","children":[],"tail":", substituted “$2,000,000 for each of fiscal years 2019 through 2023” for “$6,000,000 for each of fiscal years 2002 through 2007”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
