{"tag":"section","attrib":{"id":"idf004b60a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7316"},"text":null,"children":[{"tag":"num","attrib":{"value":"7316"},"text":"§ 7316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf004b60b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7316/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall meet on a regular basis (as determined by the chairperson) and at the call of the chairperson or a majority of its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf004b60c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7316/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members of the Commission shall constitute a quorum for the transaction of business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf004b60d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s186"},"text":"Pub. L. 104–127, title I, § 186","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/941"},"text":"110 Stat. 941","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
