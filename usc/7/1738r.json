{"tag":"section","attrib":{"id":"ideef9aeeb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738r"},"text":null,"children":[{"tag":"num","attrib":{"value":"1738r"},"text":"§ 1738r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Qualified debt” defined","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in sections 1738","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":", 1738p, and 1738q of this title, the term “qualified debt” means any obligation, or portion of such obligation, of an eligible country to pay for purchases of United States agricultural commodities guaranteed by the Commodity Credit Corporation under export credit guarantee programs authorized pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s714c/f"},"text":"section 714c(f) of title 15","children":[],"tail":" or section 1707a(b) "},{"tag":"ref","attrib":{"idref":"fn002204"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002204"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef9aeec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738r/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the Commodity Credit Corporation obtained a legal right or interest, as a result of assignment or subrogation, not later than ","children":[{"tag":"date","attrib":{"date":"1992-09-01"},"text":"September 1, 1992","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9aeed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738r/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment of which obligation has been, not later than ","children":[{"tag":"date","attrib":{"date":"1992-09-01"},"text":"September 1, 1992","children":[],"tail":", rescheduled in accordance with principles set forth in an Agreed Minute of the Paris Club."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such term includes the obligation to pay any interest which was due or accrued not later than ","children":[{"tag":"date","attrib":{"date":"1992-09-01"},"text":"September 1, 1992","children":[],"tail":", and unpaid as of the date of a debt sale pursuant to section 1738"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title or a debt sale, reduction, or cancellation pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738p"},"text":"section 1738p of this title","children":[],"tail":" (as the case may be)."}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideef9aeee-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title VI, § 619, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/532/s2"},"text":"Pub. L. 102–532, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3511"},"text":"106 Stat. 3511","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideef9aeef-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideef9aef0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideef9aef1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1707a"},"text":"Section 1707a of this title","children":[],"tail":", referred to in text, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1574"},"text":"Pub. L. 101–624, title XV, § 1574","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3702"},"text":"104 Stat. 3702","children":[],"tail":". See section 5621 et seq. of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
