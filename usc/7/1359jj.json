{"tag":"section","attrib":{"id":"idee8bf911-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359jj"},"text":null,"children":[{"tag":"num","attrib":{"value":"1359jj"},"text":"§ 1359jj.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee8bf912-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359jj/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of certain agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subpart, the Secretary may use the services of local committees of sugar beet or sugarcane producers, sugarcane processors, or sugar beet processors, State and county committees established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s590h/b"},"text":"section 590h(b) of title 16","children":[],"tail":", and the departments and agencies of the United States Government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee8bf913-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359jj/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Commodity Credit Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use the services, facilities, funds, and authorities of the Commodity Credit Corporation to carry out this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee8bf914-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title III, § 359j, as added "},{"tag":"ref","attrib":