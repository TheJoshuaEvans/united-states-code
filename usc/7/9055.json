{"tag":"section","attrib":{"id":"idf04eb7aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9055"},"text":null,"children":[{"tag":"num","attrib":{"value":"9055"},"text":"§ 9055.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production history of participating dairy operations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf04eb7ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9055/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production history","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), the production history of a dairy operation for dairy margin coverage is equal to the highest annual milk marketings of the participating dairy operation during any 1 of the 2021, 2022, or 2023 calendar years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04eb7ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9055/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election by new dairy operations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a participating dairy operation that has been in operation for less than a year, the participating dairy operation shall elect 1 of the following methods for the Secretary to determine the production history of the participating dairy operation:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04eb7ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9055/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The volume of the actual milk marketings for the months the participating dairy operation has been in operation extrapolated to a yearly amount.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb7ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9055/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An estimate of the actual milk marketings of the participating dairy operation based on the herd size of the participating dairy operation relative to the national rolling herd average data published by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04eb7af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9055/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A participating dairy operation shall provide all information that the Secretary may require in order to establish the production history of the participating dairy operation for purposes of participating in dairy margin coverage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04eb7b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9055/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on changes to business structure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make dairy margin coverage payments to a participating dairy operation if the Secretary determines that the participating dairy operation has reorganized the structure of such operation solely for the purpose of qualifying as a new operation under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf04eb7b1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1405"},"text":"Pub. L. 113–79, title I, § 1405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/690"},"text":"128 Stat. 690","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dF/s60101/b/3"},"text":"Pub. L. 115–123, div. F, § 60101(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/311"},"text":"132 Stat. 311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI/s1401/f"},"text":"Pub. L. 115–334, title I, § 1401(f)","children":[],"tail":", (k)(6), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4513"},"text":"132 Stat. 4513","children":[],"tail":", 4517; "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/dB/tI/s102/c/2/A"},"text":"Pub. L. 118–22, div. B, title I, § 102(c)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-11-17"},"text":"Nov. 17, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/115"},"text":"137 Stat. 115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10313/a/2"},"text":"Pub. L. 119–21, title I, § 10313(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/99"},"text":"139 Stat. 99","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf04eb7b2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf04eb7b3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf04eb7b4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" added subsecs. (a) and (b) and struck out former subsecs. (a) and (b) which related to production history of dairy operations for dairy margin coverage and election of prescribed methods to determine the production history, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/c/2/A/i"},"text":"Pub. L. 118–22, § 102(c)(2)(A)(i)","children":[],"tail":", inserted “paragraph (4) and” before “subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/c/2/A/ii"},"text":"Pub. L. 118–22, § 102(c)(2)(A)(ii)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/k/6"},"text":"Pub. L. 115–334, § 1401(k)(6)","children":[],"tail":", substituted “dairy margin coverage” for “the margin protection program” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/f/1/A/i"},"text":"Pub. L. 115–334, § 1401(f)(1)(A)(i)","children":[],"tail":", substituted “In the subsequent calendar years ending before "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"January 1, 2019","children":[],"tail":"” for “In subsequent years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/f/1/A/ii"},"text":"Pub. L. 115–334, § 1401(f)(1)(A)(ii)","children":[],"tail":", inserted “, as applicable” after “paragraph (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123"},"text":"Pub. L. 115–123","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/f/1/B"},"text":"Pub. L. 115–334, § 1401(f)(1)(B)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, redesignated former pars. (1) and (2) as subpars. (A) and (B), respectively, of par. (1), realigned margins, and added pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/k/6"},"text":"Pub. L. 115–334, § 1401(k)(6)","children":[],"tail":", substituted “dairy margin coverage” for “the margin protection program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/f/2"},"text":"Pub. L. 115–334, § 1401(f)(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf04eb7b5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf04eb7b6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2023 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/22"},"text":"Pub. L. 118–22","children":[],"tail":" to be applied and administered as if enacted on "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"Sept. 30, 2023","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/g"},"text":"section 102(g) of Pub. L. 118–22","children":[],"tail":", set out in an Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf04eb7b7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/m"},"text":"section 1401(m) of Pub. L. 115–334","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9051"},"text":"section 9051 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123"},"text":"Pub. L. 115–123","children":[],"tail":" applicable beginning with the 2018 calendar year, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/s60101/b/5"},"text":"section 60101(b)(5) of Pub. L. 115–123","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9051"},"text":"section 9051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
