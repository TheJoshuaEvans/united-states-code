{"tag":"section","attrib":{"id":"ideddb94cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s17b"},"text":null,"children":[{"tag":"num","attrib":{"value":"17b"},"text":"§ 17b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability of 1968 amendment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this Act or the application thereof to any person or circumstances is held invalid, the validity of the remainder of the Act and the application of such provision to other persons or circumstances shall not be affected thereby, and the provisions of the section of this chapter which is amended by such provision of this Act shall apply to such person or circumstances. Pending proceedings shall not be abated by reason of any provision of this Act but shall be disposed of pursuant to the provisions of this chapter, in effect prior to the effective date of this Act.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideddb94ce-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/258/s27"},"text":"Pub. L. 90–258, § 27","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-02-19"},"text":"Feb. 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/34"},"text":"82 Stat. 34","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideddb94cf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideddb94d0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideddb94d1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/258"},"text":"Pub. L. 90–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-02-19"},"text":"Feb. 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/26"},"text":"82 Stat. 26","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Effective date of this Act, referred to in text, as one hundred and twenty days after ","children":[{"tag":"date","attrib":{"date":"1968-02-19"},"text":"Feb. 19, 1968","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/258/s28"},"text":"section 28 of Pub. L. 90–258","children":[],"tail":", set out as an Effective Date of 1968 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideddb94d2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Commodity Exchange Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
