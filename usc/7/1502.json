{"tag":"section","attrib":{"id":"ideeb48f77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502"},"text":null,"children":[{"tag":"num","attrib":{"value":"1502"},"text":"§ 1502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose; definitions; protection of information; relation to other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideeb48f78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the purpose of this subchapter to promote the national welfare by improving the economic stability of agriculture through a sound system of crop insurance and providing the means for the research and experience helpful in devising and establishing such insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeb48f79-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeb48f7a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “additional coverage” means a plan of crop insurance coverage providing a level of coverage greater than the level available under catastrophic risk protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f7b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approved insurance provider","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “approved insurance provider” means a private insurance provider that has been approved by the Corporation to provide insurance coverage to producers participating in the Federal crop insurance program established under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f7c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beginning farmer or rancher","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “beginning farmer or rancher” means a farmer or rancher who has not actively operated and managed a farm or ranch with a bona fide insurable interest in a crop or livestock as an owner-operator, landlord, tenant, or sharecropper for more than 10 crop years, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f7d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the Board of Directors of the Corporation established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1505/a"},"text":"section 1505(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f7e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Corporation” means the Federal Crop Insurance Corporation established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1503"},"text":"section 1503 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f7f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cover crop termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cover crop termination” means a practice that historically and under reasonable circumstances results in the termination of the growth of a cover crop.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f80-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department” means the United States Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f81-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farm financial benchmarking","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “farm financial benchmarking” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeb48f82-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the process of comparing the performance of an agricultural enterprise against the performance of other similar enterprises, through the use of comparable and reliable data, in order to identify business management strengths, weaknesses, and steps necessary to improve management performance and business profitability; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeb48f83-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benchmarking of the type conducted by farm management and producer associations consistent with the activities described in or funded pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5925f"},"text":"section 5925f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f84-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hemp","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “hemp” has the meaning given the term in section 1639","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f85-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loss ratio","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “loss ratio” means the ratio of all sums paid by the Corporation as indemnities under any eligible crop insurance policy to that portion of the premium designated for anticipated losses and a reasonable reserve, other than that portion of the premium designated for operating and administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organic crop","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “organic crop” means an agricultural commodity that is organically produced consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6502"},"text":"section 6502 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f87-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transitional yield","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “transitional yield” means the maximum average production per acre or equivalent measure that is assigned to acreage for a crop year by the Corporation in accordance with the regulations of the Corporation whenever the producer fails—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeb48f89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to certify that acceptable documentation of production and acreage for the crop year is in the possession of the producer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeb48f8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to present the acceptable documentation on the demand of the Corporation or an insurance company reinsured by the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veteran farmer or rancher","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “veteran farmer or rancher” means a farmer or rancher who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeb48f8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has served in the Armed Forces (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of title 38","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeb48f8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideeb48f8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/14/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not operated a farm or ranch;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideeb48f8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/14/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has operated a farm or ranch for not more than 5 years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideeb48f90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/b/14/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a veteran (as defined in section 101 of that title) who has first obtained status as a veteran (as so defined) during the most recent 5-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeb48f91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of confidential information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeb48f92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General prohibition against disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the Secretary, any other officer or employee of the Department or an agency thereof, an approved insurance provider and its employees and contractors, and any other person may not disclose to the public information furnished by a producer under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized disclosure","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeb48f94-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure in statistical or aggregate form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information described in paragraph (1) may be disclosed to the public if the information has been transformed into a statistical or aggregate form that does not allow the identification of the person who supplied particular information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeb48f95-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent of producer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A producer may consent to the disclosure of information described in paragraph (1). The participation of the producer in, and the receipt of any benefit by the producer under, this subchapter or any other program administered by the Secretary may not be conditioned on the producer providing consent under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations; penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2276/c"},"text":"Section 2276(c) of this title","children":[],"tail":" shall apply with respect to the release of information collected in any manner or for any purpose prohibited by this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeb48f98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the Farm Service Agency shall, in a timely manner, provide to an agent or an approved insurance provider authorized by the producer any information (including Farm Service Agency Form 578s (or any successor form)) or maps (or any corrections to those forms or maps) that may assist the agent or approved insurance provider in insuring the producer under a policy or plan of insurance under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeb70099-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (C), an agent or approved insurance provider that receives the information of a producer pursuant to subparagraph (A) shall treat the information in accordance with paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeb7009a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section prohibits the sharing of the information of a producer pursuant to subparagraph (A) between the agent and the approved insurance provider of the producer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeb7009b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other laws","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeb7009c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions of policies and plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The terms and conditions of any policy or plan of insurance offered under this subchapter that is reinsured by the Corporation shall not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeb7009d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be subject to the jurisdiction of the Commodity Futures Trading Commission or the Securities and Exchange Commission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeb7009e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be considered to be accounts, agreements (including any transaction that is of the character of, or is commonly known to the trade as, an “option”, “privilege”, “indemnity”, “bid”, “offer”, “put”, “call”, “advance guaranty”, or “decline guaranty”), or transactions involving contracts of sale of a commodity for future delivery, traded or executed on a contract market for the purposes of the Commodity Exchange Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"7 U.S.C. 1","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb7009f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1502/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on CFTC and Commodity Exchange Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter affects the jurisdiction of the Commodity Futures Trading Commission or the applicability of the Commodity Exchange Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"7 U.S.C. 1","children":[],"tail":" et seq.) to any transaction conducted on a contract market under that Act by an approved insurance provider to offset the approved insurance provider’s risk under a plan or policy of insurance under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideeb700a0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title V, § 502, "},{"tag":"ref","attrib":{"href":"/us/stat/52/72"},"text":"52 Stat. 72","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1941-06-21/ch214/s1"},"text":"June 21, 1941, ch. 214, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/255"},"text":"55 Stat. 255","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-08-01/ch440/s4"},"text":"Aug. 1, 1947, ch. 440, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/719"},"text":"61 Stat. 719","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tI/s102/a"},"text":"Pub. L. 103–354, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3180"},"text":"108 Stat. 3180","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/224/tI"},"text":"Pub. L. 106–224, title I","children":[],"tail":", §§ 122, 141, "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/377"},"text":"114 Stat. 377","children":[],"tail":", 389; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXII"},"text":"Pub. L. 110–234, title XII","children":[],"tail":", §§ 12001, 12033(c)(2)(B), "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1371"},"text":"122 Stat. 1371","children":[],"tail":", 1405; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XII, §§ 12001, 12033(c)(2)(B), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2133, 2167; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tXI"},"text":"Pub. L. 113–79, title XI","children":[],"tail":", §§ 11001, 11016(a), 11027(a), "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/954"},"text":"128 Stat. 954","children":[],"tail":", 963, 977; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXI/s11101"},"text":"Pub. L. 115–334, title XI, § 11101","children":[],"tail":", title XII, § 12306(b)(1), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4919"},"text":"132 Stat. 4919","children":[],"tail":", 4968; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10501/a/1"},"text":"Pub. L. 119–21, title I, § 10501(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/103"},"text":"139 Stat. 103","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideeb700a1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideeb700a2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideeb700a3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Commodity Exchange Act, referred to in subsec. (d)(1)(B), (2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369"},"text":"act Sept. 21, 1922, ch. 369","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/998"},"text":"42 Stat. 998","children":[],"tail":", which is classified generally to chapter 1 (§ 1 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"section 1 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideeb700a4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideeb700a5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" substituted “10” for “5”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(6) to (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s11101"},"text":"Pub. L. 115–334, § 11101","children":[],"tail":", added pars. (6) and (9) and redesignated former pars. (6) to (11) as (7), (8), and (10) to (13), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12306/b/1"},"text":"Pub. L. 115–334, § 12306(b)(1)","children":[],"tail":", added par. (14)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(3) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s11016/a"},"text":"Pub. L. 113–79, § 11016(a)","children":[],"tail":", added par. (3) and redesignated former pars. (3) to (5) as (4) to (6), respectively. Former par. (6) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s11027/a"},"text":"Pub. L. 113–79, § 11027(a)","children":[],"tail":", added par. (7) and redesignated former pars. (7) to (9) as (8) to (10), respectively. Former par. (10) redesignated (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s11016/a/1"},"text":"Pub. L. 113–79, § 11016(a)(1)","children":[],"tail":", redesignated pars. (6) to (9) as (7) to (10), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s11027/a/1"},"text":"Pub. L. 113–79, § 11027(a)(1)","children":[],"tail":", redesignated par. (10) as (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s11001"},"text":"Pub. L. 113–79, § 11001","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s12033/c/2/B"},"text":"Pub. L. 110–246, § 12033(c)(2)(B)","children":[],"tail":", substituted “this subchapter” for “this chapter” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s12001"},"text":"Pub. L. 110–246, § 12001","children":[],"tail":", added par. (7) and redesignated former pars. (7) and (8) as (8) and (9), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/s122"},"text":"Pub. L. 106–224, § 122","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/s141"},"text":"Pub. L. 106–224, § 141","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" substituted “Purpose and definitions” for “Declaration of purpose” in section catchline, designated existing text as subsec. (a) and added heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1947—Act ","children":[{"tag":"date","attrib":{"date":"1947-08-01"},"text":"Aug. 1, 1947","children":[],"tail":", amended section generally, restating purpose of chapter to improve all agriculture by crop insurance instead of being limited only to wheat."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1941—Act ","children":[{"tag":"date","attrib":{"date":"1941-06-21"},"text":"June 21, 1941","children":[],"tail":", substituted “crop” for “wheat-crop” and “agricultural commodities” for “wheat”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideeb700a6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideeb700a7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideeb700a8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tI/s120"},"text":"Pub. L. 103–354, title I, § 120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3208"},"text":"108 Stat. 3208","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/354/tI/s120"},"text":"“Except as otherwise provided in this title, this title [enacting sections 1433f, 1515, 1521, and 2008f of this title, amending this section and sections 1441–2, 1444–2, 1444f, 1445b–3a, 1503 to 1509, 1511, 1513, 1516, and 1518 to 1520 of this title, sections 901 and 902 of Title 2, The Congress, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1014"},"text":"section 1014 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, repealing sections 1446i and 1508a of this title, enacting provisions set out as notes under sections 1501, 1506, and 1508 of this title and sections 901 and 902 of Title 2, and repealing provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of this title","children":[],"tail":"] and the amendments made by this title shall become effective on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":"] and shall apply to the provision of crop insurance under the Federal Crop Insurance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"7 U.S.C. 1501","children":[],"tail":" et seq.) beginning with the 1995 crop year. With respect to the 1994 crop year, the Federal Crop Insurance Act (as in effect on the day before the date of enactment of this Act) shall continue to apply.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
