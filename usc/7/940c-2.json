{"tag":"section","attrib":{"id":"idee6118a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"940c–2"},"text":"§ 940c–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural development loans and grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee6118a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide grants or zero interest loans to borrowers under this chapter for the purpose of promoting rural economic development and job creation projects, including funding for project feasibility studies, start-up costs, incubator projects, and other reasonable expenses for the purpose of fostering rural development.","children":[{"tag":"ref","attrib":{"idref":"fn002126"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002126"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Additional Funding for Fiscal Year 2024 note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee6118a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of zero interest loans, the Secretary shall establish such reasonable repayment terms as will encourage borrower participation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee6118a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All proceeds from the repayment of such loans made under this section shall be returned to the subaccount that the Secretary shall maintain in accordance with sections 940c(b)(2) and 940c–2(f) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee6118a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Loans and grants required under this section shall be made to the full extent of the amounts made available under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee6118aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee6118ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–2/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to other funds that are available to carry out this section, there is authorized to be appropriated not more than $10,000,000 for each of fiscal years 2019 through 2023 to carry out this section, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee6118ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–2/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds of the Commodity Credit Corporation, the Secretary shall credit to the subaccount to use for the cost of grants and loans under this section $5,000,000 for each of fiscal years 2022 through 2024, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee6118ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–2/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the funds described in paragraphs (1) and (2), the Secretary shall use, without fiscal year limitation, to provide grants and loans under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee6118ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–2/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interest differential sums credited to the subaccount described in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee6118af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–2/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s940c–1/e/2"},"text":"section 940c–1(e)(2) of this title","children":[],"tail":", the fees described in subsection (c)(4) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee6118b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–2/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall maintain the subaccount described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s940c/b/2"},"text":"section 940c(b)(2) of this title","children":[],"tail":", as in effect in fiscal year 2017, for purposes of carrying out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee6118b1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title III, § 313B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6504/c"},"text":"Pub. L. 115–334, title VI, § 6504(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4773"},"text":"132 Stat. 4773","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/dB/tI/s102/d/4"},"text":"Pub. L. 118–22, div. B, title I, § 102(d)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-11-17"},"text":"Nov. 17, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/116"},"text":"137 Stat. 116","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee6118b2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee6118b3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee6118b4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/22"},"text":"Pub. L. 118–22","children":[],"tail":" substituted “through 2024” for “and 2023”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee6118b5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee6118b6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2023 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/22"},"text":"Pub. L. 118–22","children":[],"tail":" to be applied and administered as if enacted on "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"Sept. 30, 2023","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/g"},"text":"section 102(g) of Pub. L. 118–22","children":[],"tail":", set out in an Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idee6118b7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Additional Funding for Fiscal Year 2026","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/37/dB/tVII/s760"},"text":"Pub. L. 119–37, div. B, title VII, § 760","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-11-12"},"text":"Nov. 12, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/554"},"text":"139 Stat. 554","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/37/dB/tVII/s760"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 313B(a) of the Rural Electrification Act of 1936 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s940c–2/a"},"text":"7 U.S.C. 940c–2(a)","children":[],"tail":"), shall be applied for fiscal year 2026 and each fiscal year thereafter until the specified funding has been expended as if the following were inserted after the final period: ‘In addition, the Secretary shall use $9,465,000 of the funds available to carry out this section in fiscal year 2024 for an additional amount for the same purpose and under the same terms and conditions as the Rural Business Development Grants authorized by section 310B of the Consolidated Farm and Rural Development Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1932/c"},"text":"7 U.S.C. 1932(c)","children":[],"tail":") and shall use $9,953,000 of the funds available to carry out this section in fiscal year 2026 for an additional amount for the same purpose and under the same terms and conditions as the Rural Business Development Grants authorized by section 310B of the Consolidated Farm and Rural Development Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1932/c"},"text":"7 U.S.C. 1932(c)","children":[],"tail":").’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) Section 780 of division B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/42"},"text":"Public Law 118–42","children":[],"tail":" [see below] and such section as continued in effect as an authority and condition under "},{"tag":"ref","attrib":{"href":"/us/pl/119/4/s1101/a/1"},"text":"section 1101(a)(1) of Public Law 119–4","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/stat/139/10"},"text":"139 Stat. 10","children":[],"tail":"] shall no longer apply.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation act:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/42/dB/tVII/s780"},"text":"Pub. L. 118–42, div. B, title VII, § 780","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-09"},"text":"Mar. 9, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/118"},"text":"138 Stat. 118","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idee6118b8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation of Loan and Grant Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6504/e"},"text":"Pub. L. 115–334, title VI, § 6504(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4774"},"text":"132 Stat. 4774","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/334/tVI/s6504/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to section 313B(e) of the Rural Electrification Act of 1936 (as added by this section) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s940c–2/e"},"text":"7 U.S.C. 940c–2(e)","children":[],"tail":"], the Secretary of Agriculture shall carry out the loan and grant program required under such section in the same manner as the loan and grant program under section 313(b)(2) of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s940c/b/2"},"text":"7 U.S.C. 940c(b)(2)","children":[],"tail":"] is carried out on the day before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":"], until such time as any regulations necessary to carry out the amendments made by this section [enacting this section and amending sections 912, 940c, and 940c–1 of this title] are fully implemented."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) shall take effect on the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
