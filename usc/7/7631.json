{"tag":"section","attrib":{"id":"idf017c92d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7631"},"text":null,"children":[{"tag":"num","attrib":{"value":"7631"},"text":"§ 7631.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural biotechnology research and development for developing countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf017c92e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7631/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf017c92f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7631/a/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education that offers a curriculum in agriculture or the biosciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf017c930-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7631/a/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf017c931-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7631/a/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium of for-profit institutions and agricultural research institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf017c932-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7631/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf017c933-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7631/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary (acting through the Foreign Agricultural Service) shall establish and administer a program to make competitive grants to eligible entities to develop agricultural biotechnology for developing countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf017c934-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7631/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds provided to an eligible entity under this section may be used for projects that use biotechnology to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf017c935-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7631/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the nutritional content of agricultural products that can be grown in developing countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf017c936-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7631/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the yield and safety of agricultural products that can be grown in developing countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf017c937-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7631/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the yield of agricultural products that are drought- and stress-resistant and that can be grown in developing countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf017c938-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7631/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extend the growing range of crops that can be grown in developing countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf017c939-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7631/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the shelf-life of fruits and vegetables grown in developing countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf017c93a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7631/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop environmentally sustainable agricultural products that can be grown in developing countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf017c93b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7631/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop vaccines to immunize against life-threatening illnesses and other medications that can be administered by consuming genetically-engineered agricultural products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf017c93c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7631/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this section for each of fiscal years 2002 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf017c93d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/tIV/s411"},"text":"Pub. L. 105–185, title IV, § 411","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7505"},"text":"Pub. L. 107–171, title VII, § 7505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/466"},"text":"116 Stat. 466","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7310"},"text":"Pub. L. 110–234, title VII, § 7310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1243"},"text":"122 Stat. 1243","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7310, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2004.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":