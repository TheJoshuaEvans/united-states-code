{"tag":"section","attrib":{"id":"idee27dfd3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s342"},"text":null,"children":[{"tag":"num","attrib":{"value":"342"},"text":"§ 342.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agricultural extension work; cooperation with Secretary of Agriculture","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Cooperative agricultural extension work shall consist of the development of practical applications of research knowledge and giving of instruction and practical demonstrations of existing or improved practices or technologies in agriculture, uses of solar energy with respect to agriculture, home economics, and rural energy and subjects relating thereto to persons not attending or resident in said colleges in the several communities, and imparting information on said subjects through demonstrations, publications, and otherwise and for the necessary printing and distribution of information in connection with the foregoing; and this work shall be carried on in such manner as may be mutually agreed upon by the Secretary of Agriculture and the State agricultural college or colleges or Territory or possession receiving the benefits of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee27dfd4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-05-08/ch79/s2"},"text":"May 8, 1914, ch. 79, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/373"},"text":"38 Stat. 373","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1953-06-26/ch157/s1"},"text":"June 26, 1953, ch. 157, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/84"},"text":"67 Stat. 84","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/749/s1/a"},"text":"Pub. L. 87–749, § 1(a)","children":[],"tail":", "},{"ta