{"tag":"section","attrib":{"id":"idee3d641f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518e"},"text":null,"children":[{"tag":"num","attrib":{"value":"518e"},"text":"§ 518e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tobacco Trust Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee3d6420-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established in the Commodity Credit Corporation a revolving trust fund, to be known as the “Tobacco Trust Fund”, which shall be used in carrying out this subchapter. The Tobacco Trust Fund shall consist of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee3d6421-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assessments collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s518d"},"text":"section 518d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3d6422-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such amounts as are necessary from the Commodity Credit Corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3d6423-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any interest earned on investment of amounts in the Tobacco Trust Fund under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee3d6424-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee3d6425-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized expenditures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), and notwithstanding any other provision of law, the Secretary shall use amounts in the Tobacco Trust Fund, in such amounts as the Secretary determines are necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee3d6426-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518e/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make payments under sections 518a and 518b of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee3d6427-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518e/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide reimbursement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s519/c"},"text":"section 519(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee3d6428-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518e/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reimburse the Commodity Credit Corporation for costs incurred by the Commodity Credit Corporation under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee3d6429-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518e/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make payments to financial institutions to satisfy contractual obligations under section 518a or 518b of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3d642a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures by Commodity Credit Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary shall use the funds, facilities, and authorities of the Commodity Credit Corporation to make payments described in paragraph (1). Not later than ","children":[{"tag":"date","attrib":{"date":"2015-01-01"},"text":"January 1, 2015","children":[],"tail":", the Secretary shall use amounts in the Tobacco Trust Fund to fully reimburse, with interest, the Commodity Credit Corporation for all funds of the Commodity Credit Corporation expended under the authority of this paragraph. Administrative costs incurred by the Secretary or the Commodity Credit Corporation to carry out this title "},{"tag":"ref","attrib":{"idref":"fn002101"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002101"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" may not be paid using amounts in the Tobacco Trust Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee3d642b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee3d642c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commodity Credit Corporation shall invest such portion of the amounts in the Tobacco Trust Fund as are not, in the judgment of the Commodity Credit Corporation, required to meet current expenditures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3d642d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest-bearing obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Investments may be made only in interest-bearing obligations of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3d642e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518e/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of obligations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of investments under paragraph (1), obligations may be acquired—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee3d642f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518e/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on original issue at the issue price; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee3d6430-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518e/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by purchase of outstanding obligations at the market price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3d6431-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518e/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any obligation acquired by the Tobacco Trust Fund may be sold by the Commodity Credit Corporation at the market price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3d6432-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518e/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credits to Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interest on, and the proceeds from the sale or redemption of, any obligations held in the Tobacco Trust Fund shall be credited to and form a part of the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee3d6433-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVI/s626"},"text":"Pub. L. 108–357, title VI, § 626","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1533"},"text":"118 Stat. 1533","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee3d6434-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee3d6435-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idee3d6436-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsec. (b)(2), means title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":", which enacted this chapter, amended sections 609, 1282, 1301, 1303, 1314h, 1361, 1371, 1373, 1375, 1378, 1379, 1428, 1433c–1, and 1441 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s714c"},"text":"section 714c of Title 15","children":[],"tail":", Commerce and Trade, repealed sections 511r, 515 to 515k, 625, 1311 to 1314, 1314–1, 1314b, 1314b–1, 1314b–2, 1314c to 1314j, 1315, 1316, 1445, 1445–1, and 1445–2 of this title, enacted provisions set out as notes under sections 515 and 518 of this title, and repealed provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1314c"},"text":"section 1314c of this title","children":[],"tail":". For complete classification of title VI to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s518"},"text":"section 518 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee3d6437-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idee3d6438-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to the 2005 and subsequent crops of tobacco, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s643"},"text":"section 643 of Pub. L. 108–357","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s518"},"text":"section 518 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
