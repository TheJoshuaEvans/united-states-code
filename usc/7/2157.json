{"tag":"section","attrib":{"id":"idef6e9086-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2157"},"text":null,"children":[{"tag":"num","attrib":{"value":"2157"},"text":"§ 2157.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release of trade secrets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef6e9087-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2157/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release of confidential information prohibited","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for any member of an Institutional Animal Committee to release any confidential information of the research facility including any information that concerns or relates to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef6e9088-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2157/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trade secrets, processes, operations, style of work, or apparatus; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef6e9089-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2157/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity, confidential statistical data, amount or source of any income, profits, losses, or expenditures,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"of the research facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef6e908a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2157/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wrongful use of confidential information prohibited","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for any member of such Committee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef6e908b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2157/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use or attempt to use to his advantages; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef6e908c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2157/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reveal to any other person,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"any information which is entitled to protection as confidential information under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef6e908d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2157/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A violation of subsection (a) or (b) is punishable by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef6e908e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2157/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" removal from such Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef6e908f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2157/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef6e9090-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2157/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fine of not more than $1,000 and imprisonment of not more than one year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef6e9091-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2157/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such violation is willful, a fine of not more than $10,000 and imprisonment of not more than three years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef6e9092-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2157/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of damages by injured person; costs; attorney’s fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person, including any research facility, injured in its business or property by reason of a violation of this section may recover all actual and consequential damages sustained by such person and the cost of the suit including a reasonable attorney’s fee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef6e9093-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2157/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other rights and remedies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to affect any other rights of a person injured in its business or property by reason of a violation of this section. Subsection (d) shall not be construed to limit the exercise of any such rights arising out of or relating to a violation of subsections (a) and (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef6e9094-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/544/s27"},"text":"Pub. L. 89–544, § 27","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVII/s1754"},"text":"Pub. L. 99–198, title XVII, § 1754","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1649"},"text":"99 Stat. 1649","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef6e9095-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef6e9096-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idef6e9097-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective one year after ","children":[{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1759"},"text":"section 1759 of Pub. L. 99–198","children":[],"tail":", set out as an Effective Date of 1985 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2131"},"text":"section 2131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
