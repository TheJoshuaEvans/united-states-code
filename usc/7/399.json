{"tag":"section","attrib":{"id":"idee2f0bc1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s399"},"text":null,"children":[{"tag":"num","attrib":{"value":"399"},"text":"§ 399.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic raising of fur-bearing animals; classification","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of all classification and administration of Acts of Congress, Executive orders, administrative orders, and regulations pertaining to—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee2f0bc2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s399/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fox, rabbit, mink, chinchilla, marten, fisher, muskrat, karakul and all other fur-bearing animals, raised in captivity for breeding or other useful purposes shall be deemed domestic animals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee2f0bc3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s399/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such animals and the products thereof shall be deemed agricultural products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee2f0bc4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s399/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the breeding, raising, producing, or marketing of such animals or their products by the producer shall be deemed an agricultural pursuit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee2f0bc5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-04-30/ch242/s1"},"text":"Apr. 30, 1946, ch. 242, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/127"},"text":"60 Stat. 127","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee2f0bc6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee2f0bc7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee2f0bc8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s433"},"text":"section 433 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee2f0bc9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idee2f0bca-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1946-04-30/ch242/s3"},"text":"Act Apr. 30, 1946, ch. 242, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/128"},"text":"60 Stat. 128","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1946-04-30/ch242/s3"},"text":"“This Act [enacting this section and provisions set out as a note below] shall take effect sixty days after the date of its enactment [","children":[{"tag":"date","attrib":{"date":"1946-04-30"},"text":"Apr. 30, 1946","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idee2f0bcb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1946-04-30/ch242/s2"},"text":"Act Apr. 30, 1946, ch. 242, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/127"},"text":"60 Stat. 127","children":[],"tail":"; 1970 Reorg. Plan No. 2, § 102, eff. "},{"tag":"date","attrib":{"date":"1970-07-01"},"text":"July 1, 1970","children":[],"tail":", 35 F.R. 7959, "},{"tag":"ref","attrib":{"href":"/us/stat/84/2085"},"text":"84 Stat. 2085","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/stat/84/2085"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All the functions of the Secretary of the Interior and the Fish and Wildlife Service of the Department of the Interior, which affect the breeding, raising, producing, marketing, or any other phase of the production or distribution, of domestically raised fur-bearing animals, or products thereof, are hereby transferred to and vested in the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriations and unexpended balances of appropriations, or parts thereof, which the Director of the Office of Management and Budget determines to be available for expenditure for the administration of any function transferred by this Act [enacting this section and provisions set out as a note above], shall be available for expenditure for the continued administration of such function by the officer to whom such function is so transferred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All records and property (including office furniture and equipment) under the jurisdiction of the Secretary of the Interior and the Fish and Wildlife Service of the Department of the Interior used primarily in connection with the administration of functions transferred by this Act are hereby transferred to the jurisdiction of the Secretary of Agriculture.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[Section 2 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-04-30/ch242"},"text":"act Apr. 30, 1946, ch. 242","children":[],"tail":", set out above, was formerly classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s434"},"text":"section 434 of this title","children":[],"tail":" prior to editorial reclassification as this note.]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
