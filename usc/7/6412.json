{"tag":"section","attrib":{"id":"idefe3737c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6412"},"text":null,"children":[{"tag":"num","attrib":{"value":"6412"},"text":"§ 6412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations and power to subpoena","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe3737d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6412/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make such investigations as the Secretary considers necessary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe3737e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6412/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the effective administration of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe3737f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6412/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine whether any person has engaged or is engaging in any act that constitutes a violation of this chapter, or any order, rule, or regulation issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe37380-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6412/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpoenas, oaths, and affirmations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe37381-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6412/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of an investigation under subsection (a), the Secretary may administer oaths and affirmations, and issue a subpoena to require the production of any records that are relevant to the inquiry. The production of any such records may be required from any place in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe37382-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6412/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of an administrative hearing held under section 6410 or 6411 of this title, the presiding officer is authorized to administer oaths and affirmations, subpoena witnesses, compel their attendance, take evidence, and require the production of any records that are relevant to the inquiry. Such attendance of witnesses and the production of any such records may be required from any place in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe37383-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6412/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aid of courts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of contumacy by, or refusal to obey a subpoena issued to, any person, the Secretary may invoke the aid of any court of the United States within the jurisdiction of which such investigation or proceeding is carried on, or where such person resides or carries on business, in order to enforce a subpoena issued by the Secretary under subsection (b). The court may issue an order requiring such person to comply with such a subpoena.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe37384-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6412/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contempt","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any failure to obey such order of the court may be punished by such court as a contempt thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe37385-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6412/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Process in any such case may be served in the judicial district in which such person resides or conducts business or wherever such person may be found.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe37386-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6412/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearing site","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The site of any hearings held under section 6410 or 6411 of this title shall be within the judicial district where such person resides or has a principal place of business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe37387-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1999M"},"text":"Pub. L. 101–624, title XIX, § 1999M","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3924"},"text":"104 Stat. 3924","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
