{"tag":"section","attrib":{"id":"idee59ec8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s917"},"text":null,"children":[{"tag":"num","attrib":{"value":"917"},"text":"§ 917.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on restricting water and waste facility services to electric customers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee59ec8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s917/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance under any rural development program administered by the Secretary or any agency of the Department of Agriculture shall not be conditioned on any requirement that the recipient of the assistance accept or receive electric service from any particular utility, supplier, or cooperative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee59ec8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s917/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ensuring compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish, by regulation, adequate safeguards to ensure that assistance under any rural development program is not subject to such a condition. The safeguards shall include periodic certifications and audits, and appropriate measures and sanctions against any person violating, or attempting to violate subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee59ec8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s917/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Rural development programs” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “rural development program” means the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee59ec8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s917/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 304(b), 306, 306A, 306C, 306D, 310B, and 375 ","children":[{"tag":"ref","attrib":{"idref":"fn002119"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002119"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and subtitle E ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009"},"text":"7 U.S.C. 2009","children":[],"tail":" et seq.] of the Consolidated Farm and Rural Development Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1924/b"},"text":"7 U.S.C. 1924(b)","children":[],"tail":", 1926, 1926a, 1926c, 1926d, and 1932)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee59ec90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s917/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subtitle G ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title XVI and sections 2281 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5177a"},"text":"42 U.S.C. 5177a","children":[],"tail":"], 2333, and 2381 ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s950aaa–2"},"text":"7 U.S.C. 950aaa–2","children":[],"tail":", 3125b] of the Food, Agriculture, Conservation, and Trade Act of 1990."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee59ec91-3a6e-11f1-addd