{"tag":"section","attrib":{"id":"idef7ce892-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2277"},"text":null,"children":[{"tag":"num","attrib":{"value":"2277"},"text":"§ 2277.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts by Animal and Plant Health Inspection Service for services to be performed abroad","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds available to the Animal and Plant Health Inspection Service (APHIS) under this and subsequent appropriations shall be available for contracting with individuals for services to be performed outside of the United States, as determined by APHIS to be necessary or appropriate for carrying out programs and activities abroad. Such individuals shall not be regarded as officers or employees of the United States under any law administered by the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef7ce893-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/142/tVII/s737"},"text":"Pub. L. 102–142, title VII, § 737","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/915"},"text":"105 Stat. 915","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7ce894-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef7ce895-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idef7ce896-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in the following prior appropriation act:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/506/tVI/s641"},"text":"Pub. L. 101–506, title VI, § 641","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1350"},"text":"104 Stat. 1350","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
