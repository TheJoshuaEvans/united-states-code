{"tag":"section","attrib":{"id":"idee9f0b48-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1431d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1431d"},"text":"§ 1431d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donations for school feeding programs abroad; student financing; priorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In any school feeding programs undertaken on and after ","children":[{"tag":"date","attrib":{"date":"1962-09-27"},"text":"September 27, 1962","children":[],"tail":" outside the United States pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1431"},"text":"section 1431 of this title","children":[],"tail":", section 308 of Public Law 480 (83d Congress), as amended, and "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1431b"},"text":"section 1431b of this title","children":[],"tail":", the Secretary shall receive assurances satisfactory to him that, insofar as practicable, there will be student participation in the financing of such programs on the basis of ability to pay, and such programs shall be undertaken with the understanding that commodities will be available for those programs only in accordance with the provisions of such statutes and that commodities made available under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1431"},"text":"section 1431 of this title","children":[],"tail":" will be available only in accordance with the priorities established in such section."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee9f0b49-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/703/tII/s205"},"text":"Pub. L. 87–703, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-27"},"text":"Sept. 27, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/611"},"text":"76 Stat. 611","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee9f0b4a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee9f0b4b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idee9f0b4c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 308 of Public Law 480 (83d Congress), referred to in text, which was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1697"},"text":"section 1697 of this title","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/89/808/s2/D"},"text":"Pub. L. 89–808, § 2(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-11"},"text":"Nov. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1535"},"text":"80 Stat. 1535","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee9f0b4d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food and Agriculture Act of 1962, and not as part of the Agricultural Act of 1949 which is classified principally to this chapter. For complete classification of the 1949 Act to the Code, see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
