{"tag":"section","attrib":{"id":"idefcdee86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5694"},"text":null,"children":[{"tag":"num","attrib":{"value":"5694"},"text":"§ 5694.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff of Foreign Agricultural Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefcdee87-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5694/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel of Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To ensure that the agricultural export programs of the United States are carried out in an effective manner, the authorized number of personnel for the Service shall not be less than 900 staff years each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdee88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5694/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rank of Foreign Agricultural Service officers in foreign missions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary of State shall, on the request of the Secretary of Agriculture, accord the diplomatic title of Minister-Counselor to the senior Service officer assigned to any United States mission abroad. The number of Service officers holding such diplomatic title at any time may not exceed twelve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefcdee89-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/tV/s504"},"text":"Pub. L. 95–501, title V, § 504","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1531"},"text":"Pub. L. 101–624, title XV, § 1531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3686"},"text":"104 Stat. 3686","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefcdee8a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefcdee8b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idefcdee8c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in subsec. (b) of this section appear in the following appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/506/tIV"},"text":"Pub. L. 101–506, title IV","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1343"},"text":"104 Stat. 1343","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/k/tIV/s401"},"text":"Pub. L. 100–202, § 101(k) [title IV, § 401]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-322"},"text":"101 Stat. 1329–322","children":[],"tail":", 1329–350."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefcdee8d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idefcdee8e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Language Proficiency and Evaluation of Foreign Agricultural Service Officers","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1556"},"text":"Pub. L. 101–624, title XV, § 1556","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3698"},"text":"104 Stat. 3698","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s281/b"},"text":"Pub. L. 104–127, title II, § 281(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/980"},"text":"110 Stat. 980","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/127/tII/s281/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment of Foreign Language Competence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Foreign Agricultural Service shall revise its evaluation reports for its Foreign Service officers so as to require in a separate entry an assessment of the officer’s effectiveness in using, in his or her work, a foreign language or foreign languages tested at the General Professional Speaking Proficiency level or above, in cases where the supervisor is capable of making such an assessment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Precedence in Promotion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of Personnel of the Foreign Agricultural Service shall instruct promotion panels to take account of language ability and, all criteria for promotion otherwise being equal, to give precedence in promotions to officers who have achieved at least the General Professional Speaking Proficiency level in 1 or more foreign languages over officers who lack that level of proficiency.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
