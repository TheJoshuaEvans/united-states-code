{"tag":"section","attrib":{"id":"idf010c415-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7504"},"text":null,"children":[{"tag":"num","attrib":{"value":"7504"},"text":"§ 7504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial processing costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may use funds of the Commodity Credit Corporation to pay costs of initial processing and packaging of commodities to be distributed under the program established under this chapter into forms, and in quantities, suitable, as determined by the Secretary, for use in individual households when such commodities are to be consumed by individual households or for institutional use, as applicable. The Secretary may pay such costs in the form of Corporation-owned commodities equal in value to such costs. The Secretary shall ensure that any such payments in kind will not displace commercial sales of such commodities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf010c416-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/8/tII/s203A"},"text":"Pub. L. 98–8, title II, § 203A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/92/s2/5"},"text":"Pub. L. 98–92, § 2(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-02"},"text":"Sept. 2, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/609"},"text":"97 Stat. 609","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXV/s1565/b"},"text":"Pub. L. 99–198, title XV, § 1565(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1591"},"text":"99 Stat. 1591","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf010c417-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf010c418-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf010c419-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":" struck out “, except that wheat from the Food Security Wheat Reserve may not be used to pay such costs” after “equal in value to such costs”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf010c41a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf010c41b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/92/s2"},"text":"Pub. L. 98–92, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-02"},"text":"Sept. 2, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/608"},"text":"97 Stat. 608","children":[],"tail":", provided in part that this section is effective "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"Oct. 1, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
