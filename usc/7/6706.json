{"tag":"section","attrib":{"id":"idefea9e70-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6706"},"text":null,"children":[{"tag":"num","attrib":{"value":"6706"},"text":"§ 6706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutes of Tropical Forestry","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized and directed to establish an Institute of Tropical Forestry in Puerto Rico and an Institute of Pacific Islands Forestry (hereafter in this section referred to as the “Institutes”). The Institutes shall conduct research on forest management and natural resources that shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefea9e71-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6706/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management and development of tropical forests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e72-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6706/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relationship between climate change and tropical forests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e73-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6706/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" threatened and endangered species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e74-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6706/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recreation and tourism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e75-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6706/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of tropical forest resources on a sustained yield basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e76-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6706/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" techniques to monitor the health and productivity of tropical forests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6706/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tropical forest regeneration and restoration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6706/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effects of tropical deforestation on biodiversity, global climate, wildlife, soils, and water.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefea9e79-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIV/s2407"},"text":"Pub. L. 101–624, title XXIV, § 2407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4060"},"text":"104 Stat. 4060","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
