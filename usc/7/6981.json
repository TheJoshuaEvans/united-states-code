{"tag":"section","attrib":{"id":"ideff8cee1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6981"},"text":null,"children":[{"tag":"num","attrib":{"value":"6981"},"text":"§ 6981.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary of Agriculture for Food Safety","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff8cee2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6981/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Department of Agriculture the position of Under Secretary of Agriculture for Food Safety. The Under Secretary shall be appointed by the President, by and with the advice and consent of the Senate, from among individuals with specialized training or significant experience in food safety or public health programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff8cee3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6981/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Under Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff8cee4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6981/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall delegate to the Under Secretary of Agriculture for Food Safety those functions and duties under the jurisdiction of the Department that are primarily related to food safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cee5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6981/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary of Agriculture for Food Safety shall perform such other functions and duties as may be required by law or prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff8cee6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6981/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff8cee7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6981/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical and scientific review groups","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Under Secretary for Research, Education, and Economics, may, without regard to the provisions of title 5 governing appointment in the competitive service, and without regard to the provisions of chapter 51 and subchapter III of chapter 53 of title 5 relating to classification and General Schedule pay rates—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff8cee8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6981/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish such technical and scientific review groups as are needed to carry out the functions of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cee9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6981/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint and pay the members of the groups, except that officers and employees of the United States shall not receive additional compensation for service as a member of a group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff8ceea-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s261"},"text":"Pub. L. 103–354, title II, § 261","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3227"},"text":"108 Stat. 3227","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideff8ceeb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideff8ceec-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideff8ceed-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/s261"},"text":"section 261 of Pub. L. 103–354","children":[],"tail":". Subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/s261"},"text":"section 261 of Pub. L. 103–354","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
