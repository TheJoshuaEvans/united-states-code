{"tag":"section","attrib":{"id":"idef9726d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3128"},"text":null,"children":[{"tag":"num","attrib":{"value":"3128"},"text":"§ 3128.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9726da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3128/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies in Advisory Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy in the Advisory Board shall not affect its duties under this title and shall be filled in the same manner as the original position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9726db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3128/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and expenses of members of Advisory Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Advisory Board shall serve without compensation, if not otherwise officers or employees of the United States, except that they shall, while away from their homes or regular places of business in the performance of services under this chapter, be allowed travel expenses, including per diem in lieu of subsistence, in the same manner as persons employed intermittently in the Government service are allowed expenses under sections 5701 through 5707 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9726dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3128/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated annually such sums as Congress may determine necessary to carry out the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3127"},"text":"section 3127 of this title","children":[],"tail":" and subsection (b) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9726dd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1413"},"text":"Pub. L. 95–113, title XIV, § 1413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/991"},"text":"91 Stat. 991","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXIV/s1414/a"},"text":"Pub. L. 97–98, title XIV, § 1414(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1303"},"text":"95 Stat. 1303","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1605/b/2"},"text":"Pub. L. 101–624, title XVI, § 1605(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3713"},"text":"104 Stat. 3713","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s218/e/7"},"text":"Pub. L. 103–354, title II, § 218(e)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3213"},"text":"108 Stat. 3213","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII"},"text":"Pub. L. 104–127, title VIII","children":[],"tail":", §§ 852(b)(4), 853(b)(5), "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1171"},"text":"110 Stat. 1171","children":[],"tail":", 1172; "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tVI/s606/b"},"text":"Pub. L. 105–185, title VI, § 606(b)","children":[],"tail":", (c)(2), "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/603"},"text":"112 Stat. 603","children":[],"tail":", 604.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9726de-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef9726df-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef9726e0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of “this chapter”, referred to in subsec. (b), see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3102"},"text":"section 3102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef9726e1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s606/c/2"},"text":"Pub. L. 105–185, § 606(c)(2)","children":[],"tail":", substituted “its duties” for “their powers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s606/b"},"text":"Pub. L. 105–185, § 606(b)","children":[],"tail":", substituted “Advisory Board” for “Joint Council, the Advisory Board,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":", §§ 852(b)(4)(A), 853(b)(5)(A), substituted “the Advisory Board” for “the Joint Council, the Advisory Board, or the Technology Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s853/b/5/B"},"text":"Pub. L. 104–127, § 853(b)(5)(B)","children":[],"tail":", struck out “and the Technology Board” before “shall serve without”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s852/b/4/B"},"text":"Pub. L. 104–127, § 852(b)(4)(B)","children":[],"tail":", which directed substitution of “Advisory Board” for “Joint Council, Advisory Board,” could not be executed because those words did not appear in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" struck out subsec. (d) which read as follows: “The President shall appoint, by and with the advice and consent of the Senate, an Assistant Secretary of Agriculture who shall perform such duties as are necessary to carry out this chapter and who shall receive compensation at the rate now or hereafter prescribed by law for Assistant Secretaries of Agriculture.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1605/b/2/A"},"text":"Pub. L. 101–624, § 1605(b)(2)(A)","children":[],"tail":", substituted “, the Advisory Board, or the Technology Board” for “or the Advisory Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1605/b/2/B"},"text":"Pub. L. 101–624, § 1605(b)(2)(B)","children":[],"tail":", substituted “, the Advisory Board, and the Technology Board” for “and Advisory Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1605/b/2/C"},"text":"Pub. L. 101–624, § 1605(b)(2)(C)","children":[],"tail":", redesignated subsec. (e) as (d) and struck out former subsec. (d) which read as follows: “The Subcommittee on Food, Agricultural, and Forestry Research, the Joint Council, and the Advisory Board shall improve communication and interaction among themselves and with others in the agricultural science and education system through such mechanisms as the exchange of reports, joint meetings, and the use of liaison representatives.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98"},"text":"Pub. L. 97–98","children":[],"tail":" added subsecs. (c) to (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef9726e2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef9726e3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98"},"text":"Pub. L. 97–98","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1801"},"text":"section 1801 of Pub. L. 97–98","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idef9726e4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/s1901"},"text":"section 1901 of Pub. L. 95–113","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1307"},"text":"section 1307 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
