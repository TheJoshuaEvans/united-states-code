{"tag":"section","attrib":{"id":"idefcb7ddc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5663"},"text":null,"children":[{"tag":"num","attrib":{"value":"5663"},"text":"§ 5663.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Departmental administration system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefcb7ddd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5663/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to each commercial export promotion program of the Department of Agriculture or the Commodity Credit Corporation, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcb7dde-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5663/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify by regulation the criteria used to evaluate and approve proposals for that program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7ddf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5663/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a centralized system to permit the Foreign Agricultural Service to provide the history and current status of any proposal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7de0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5663/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for regular audits of program transactions to determine compliance with program objectives and requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7de1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5663/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish criteria to evaluate loans eligible for guarantees by the Commodity Credit Corporation, so as to ensure that the Corporation does not assume undue risk in providing such guarantees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcb7de2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5663/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accessibility of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information pertaining to the status of a particular proposal shall be retrievable within the central system by appropriate categories, as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefcb7de3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/tIV/s403"},"text":"Pub. L. 95–501, title IV, § 403","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1531"},"text":"Pub. L. 101–624, title XV, § 1531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3682"},"text":"104 Stat. 3682","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
