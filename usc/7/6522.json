tical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefe82da1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" substituted “, $1,000,000 for fiscal years 2024 and 2025, and $5,000,000 for fiscal year 2026” for “and $1,000,000 for fiscal year 2024” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/22"},"text":"Pub. L. 118–22","children":[],"tail":" inserted “and $1,000,000 for fiscal year 2024” after “2019” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10104/j/1"},"text":"Pub. L. 115–334, § 10104(j)(1)","children":[],"tail":", substituted “Funding” for “Authorization of appropriations” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10104/j/2"},"text":"Pub. L. 115–334, § 10104(j)(2)","children":[],"tail":", added pars. (1) to (6) and struck out former pars. (1) to (7) which related to amounts authorized to be appropriated for fiscal years 2008 to 2018 and additional sums necessary for fiscal year 2009 and each fiscal year thereafter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10104/j/3"},"text":"Pub. L. 115–334, § 10104(j)(3)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c) which related to modernization and technology upgrade for national organic program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s10004/b/1"},"text":"Pub. L. 113–79, § 10004(b)(1)","children":[],"tail":", added par. (6) and redesignated former par. (6) as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s10004/b/2"},"text":"Pub. L. 113–79, § 10004(b)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s10303"},"text":"Pub. L. 110–246, § 10303","children":[],"tail":", designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefe82da2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idefe82da3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2023 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/22"},"text":"Pub. L. 118–22","children":[],"tail":" to be applied and administered as if enacted on "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"Sept. 30, 2023","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/g"},"text":"section 102(g) of Pub. L. 118–22","children":[],"tail":", set out in an Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idefe82da4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
