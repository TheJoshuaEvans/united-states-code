{"tag":"section","attrib":{"id":"idefe82d89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6522"},"text":null,"children":[{"tag":"num","attrib":{"value":"6522"},"text":"§ 6522.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe82d8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6522/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for each fiscal year such sums as may be necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82d8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6522/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National organic program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, in order to carry out activities under the national organic program established under this chapter, there are authorized to be appropriated—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe82d8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6522/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000,000 for fiscal year 2018;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6522/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $16,500,000 for fiscal year 2019;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6522/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $18,000,000 for fiscal year 2020;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6522/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2021;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6522/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $22,000,000 for fiscal year 2022; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6522/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $24,000,000 for fiscal year 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82d92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6522/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modernization and improvement of international trade technology systems and data collection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe82d93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6522/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a new system or modify an existing data collection and organization system to collect and organize in a single system quantitative data on imports of each organically produced agricultural product accepted into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d94-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6522/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1), the Secretary shall modernize trade and transaction certificates to ensure full traceability to the port of entry without unduly hindering trade or commerce, such as through an electronic trade document exchange system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d95-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6522/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The single system established under paragraph (1) shall be accessible by any agency with the direct authority to engage in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe82d96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6522/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspection of imports of agricultural products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6522/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trade data collection and organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6522/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforcement of trade requirements for organically produced agricultural products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6522/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds of the Commodity Credit Corporation, the Secretary shall make available $5,000,000 for fiscal year 2019, $1,000,000 for fiscal years 2024 and 2025, and $5,000,000 for fiscal year 2026 for the purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe82d9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6522/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6522/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining the database and technology upgrades previously carried out under this subsection, as in effect on the day before ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d9c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6522/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts made available under paragraph (4) are in addition to any other funds made available for the purposes described in that paragraph and shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe82d9d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXI/s2123"},"text":"Pub. L. 101–624, title XXI, § 2123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3951"},"text":"104 Stat. 3951","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tX/s10303"},"text":"Pub. L. 110–234, title X, § 10303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1347"},"text":"122 Stat. 1347","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title X, § 10303, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2109; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tX/s10004/b"},"text":"Pub. L. 113–79, title X, § 10004(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","