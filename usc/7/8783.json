{"tag":"section","attrib":{"id":"idf042d168-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783"},"text":null,"children":[{"tag":"num","attrib":{"value":"8783"},"text":"§ 8783.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of quality incentive payments for covered oilseed producers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf042d169-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentive payments required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b) and the availability of appropriations under subsection (h), the Secretary shall use funds made available under subsection (h) to provide quality incentive payments for the production of oilseeds with specialized traits that enhance human health, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf042d16a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered oilseeds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make payments under this section only for the production of an oilseed variety that has, as determined by the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf042d16b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" been demonstrated to improve the health profile of the oilseed for use in human consumption by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf042d16c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing or eliminating the need to partially hydrogenate the oil derived from the oilseed for use in human consumption; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf042d16d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopting new technology traits; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf042d16e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more impediments to commercialization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf042d16f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for proposals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf042d170-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If funds are made available to carry out this section for a crop year, the Secretary shall issue a request for proposals for payments under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf042d171-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiyear proposals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A proponent may submit a multiyear proposal for payments under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf042d172-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of proposals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A proposal for payments under this section shall include a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf042d173-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how use of the oilseed enhances human health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf042d174-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impediments to commercial use of the oilseed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf042d175-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each oilseed variety described in subsection (b) and the value of the oilseed variety as a matter of public policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf042d176-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a range for the base price and premiums per bushel or hundredweight to be paid to producers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf042d177-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a per bushel or hundredweight amount of incentive payments requested for each year under this section that does not exceed ⅓ of the total premium offered for any year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf042d178-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of time, not to exceed 4 years, during which incentive payments are to be provided to producers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf042d179-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/c/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the targeted total quantity of production and estimated acres needed to produce the targeted quantity for each year under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf042d17a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts for production","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf042d17b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall approve successful proposals submitted under subsection (c) on a timely basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf042d17c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make payments to producers under this section after the Secretary receives documentation that the premium required under a contract has been paid to covered producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf042d17d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf042d17e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If funding provided for a crop year is not fully allocated under the initial request for proposals under subsection (c), the Secretary shall issue additional requests for proposals for subsequent crop years under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf042d17f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prorated payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If funding provided for a crop year is less than the amount otherwise approved by the Secretary or for which approval is sought, the Secretary shall prorate the payments or approvals in a manner determined by the Secretary so that the total payments do not exceed the funding level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf042d180-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proprietary information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall protect proprietary information provided to the Secretary for the purpose of administering this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf042d181-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program compliance and penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf042d182-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guarantee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The proponent, if approved, shall be required to guarantee that the oilseed on which a payment is made by the Secretary under this section is used for human consumption as described in the proposal, as approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf042d183-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If oilseeds on which a payment is made by the Secretary under this section are not actually used for the purpose the payment is made, the proponent shall be required to pay to the Secretary an amount equal to, as determined by the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf042d184-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an inadvertent failure, twice the amount of the payment made by the Secretary under this section to the producer of the oilseeds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf042d185-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any other case, up to twice the full value of the oilseeds involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf042d186-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documentation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may require such assurances and documentation as may be needed to enforce the guarantee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf042d187-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional penalties","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf042d188-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/g/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to payments required under paragraph (2), the Secretary may impose penalties on additional persons that use oilseeds the use of which is restricted under this section for a purpose other than the intended use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf042d189-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/g/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a penalty under this paragraph shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf042d18a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/g/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in an amount determined appropriated by the Secretary; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf042d18b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/g/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not to exceed twice the full value of the oilseeds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf042d18c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8783/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section for each of fiscal years 2009 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf042d18d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1605"},"text":"Pub. L. 110–234, title I, § 1605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1016"},"text":"122 Stat. 1016","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1605, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1744.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf042d18e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf042d18f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf042d190-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf042d191-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf042d192-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
