ib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/s383D"},"text":"section 383D of Pub. L. 87–128","children":[],"tail":", title III, was renumbered section 383E and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009bb–3"},"text":"section 2009bb–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef2e2c48-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s6026/c/2/B"},"text":"Pub. L. 110–246, § 6026(c)(2)(B)","children":[],"tail":", made technical amendment to reference in original act which appears in introductory provisions as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009bb–8"},"text":"section 2009bb–8 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s6026/d/1"},"text":"Pub. L. 110–246, § 6026(d)(1)","children":[],"tail":", redesignated pars. (2) and (1) as (1) and (2), respectively, and, in par. (2), substituted “transportation, renewable energy transmission, and telecommunication” for “transportation and telecommunication”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s6026/d/2"},"text":"Pub. L. 110–246, § 6026(d)(2)","children":[],"tail":", substituted “the following activities” for “the activities in the following order or priority” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef2e2c49-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"ch