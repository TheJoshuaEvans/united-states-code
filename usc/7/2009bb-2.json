{"tag":"section","attrib":{"id":"idef2e2c32-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009bb–2"},"text":"§ 2009bb–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic and community development grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef2e2c33-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Authority may approve grants to States, Indian tribes, local governments, and public and nonprofit organizations for projects, approved in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009bb–8"},"text":"section 2009bb–8 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2e2c34-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist the region in obtaining the job training, employment-related education, and business development (with an emphasis on entrepreneurship) that are needed to build and maintain strong local economies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2c35-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop the transportation, renewable energy transmission, and telecommunication infrastructure of the region for the purpose of facilitating economic development in the region (except that grants for this purpose may be made only to States, Indian tribes, local governments, and nonprofit organizations);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2c36-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide assistance to severely distressed and underdeveloped areas that lack financial resources for improving basic public services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2c37-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–2/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide assistance to severely distressed and underdeveloped areas that lack financial resources for equipping industrial parks and related facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2c38-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–2/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to otherwise achieve the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2e2c39-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2e2c3a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds for grants under subsection (a) may be provided—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2e2c3b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–2/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entirely from appropriations to carry out this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2e2c3c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–2/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in combination with funds available under another Federal grant program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2e2c3d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–2/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from any other source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2c3e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority of funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To best build the foundations for long-term economic development and to complement other Federal, State, and tribal resources in the region, Federal funds available under this subchapter shall be focused on the following activities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2e2c3f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–2/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Basic public infrastructure in distressed counties and isolated areas of distress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2e2c40-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–2/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation and telecommunication infrastructure for the purpose of facilitating economic development in the region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2e2c41-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–2/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Business development, with emphasis on entrepreneurship.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2e2c42-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–2/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Job training or employment-related education, with emphasis on use of existing public educational institutions located in the region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef2e2c43-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s383D"},"text":"Pub. L. 87–128, title III, § 383D","children":[],"tail":", formerly § 383C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6028"},"text":"Pub. L. 107–171, title VI, § 6028","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/380"},"text":"116 Stat. 380","children":[],"tail":"; renumbered § 383D and amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVI/s6026/c/1/A"