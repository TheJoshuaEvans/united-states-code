{"tag":"section","attrib":{"id":"idf00726c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401"},"text":null,"children":[{"tag":"num","attrib":{"value":"7401"},"text":"§ 7401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodity promotion and evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf00726ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Commodity promotion law” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “commodity promotion law” means a Federal law that provides for the establishment and operation of a promotion program regarding an agricultural commodity that includes a combination of promotion, research, industry information, or consumer information activities, is funded by mandatory assessments on producers or processors, and is designed to maintain or expand markets and uses for the commodity (as determined by the Secretary). The term includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00726cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the marketing promotion provisions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s608c/6/I"},"text":"section 608c(6)(I) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/502"},"text":"Public Law 89–502","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2101"},"text":"7 U.S.C. 2101","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/670"},"text":"Public Law 91–670","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2611"},"text":"7 U.S.C. 2611","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/428"},"text":"Public Law 93–428","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2701"},"text":"7 U.S.C. 2701","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/294"},"text":"Public Law 94–294","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2901"},"text":"7 U.S.C. 2901","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subtitle B of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/180"},"text":"Public Law 98–180","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4501"},"text":"7 U.S.C. 4501","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/590"},"text":"Public Law 98–590","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4601"},"text":"7 U.S.C. 4601","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subtitle B of title XVI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Public Law 99–198","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4801"},"text":"7 U.S.C. 4801","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subtitle C of title XVI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Public Law 99–198","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4901"},"text":"7 U.S.C. 4901","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subtitle B of title XIX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Public Law 101–624","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6101"},"text":"7 U.S.C. 6101","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subtitle E of title XIX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Public Law 101–624","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6301"},"text":"7 U.S.C. 6301","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subtitle H of title XIX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Public Law 101–624","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6401"},"text":"7 U.S.C. 6401","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/190"},"text":"Public Law 103–190","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6801"},"text":"7 U.S.C. 6801","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/407"},"text":"Public Law 103–407","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7101"},"text":"7 U.S.C. 7101","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subchapter II;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/a/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subchapter III;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/a/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subchapter IV;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/a/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subchapter V; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/a/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other provision of law enacted after ","children":[{"tag":"date","attrib":{"date":"1996-04-04"},"text":"April 4, 1996","children":[],"tail":", that provides for the establishment and operation of a promotion program described in the first sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00726de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00726df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is in the national public interest and vital to the welfare of the agricultural economy of the United States to maintain and expand existing markets and develop new markets and uses for agricultural commodities through industry-funded, Government-supervised, generic commodity promotion programs established under commodity promotion laws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" These generic commodity promotion programs, funded by the agricultural producers or processors who most directly reap the benefits of the programs and supervised by the Secretary of Agriculture, provide a unique opportunity for producers and processors to inform consumers about their products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The central congressional purpose underlying each commodity promotion law has always been to maintain and expand markets for the agricultural commodity covered by the law, rather than to maintain or expand the share of those markets held by any individual producer or processor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The commodity promotion laws were neither designed nor intended to prohibit or restrict, and the promotion programs established and funded pursuant to these laws do not prohibit or restrict, individual advertising or promotion of the covered commodities by any producer, processor, or group of producers or processors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It has never been the intent of Congress for the generic commodity promotion programs established and funded by the commodity promotion laws to replace the individual advertising and promotion efforts of producers or processors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual producer’s or processor’s own advertising initiatives are typically designed to increase the share of the market held by that producer or processor rather than to increase or expand the overall size of the market.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In contrast, a generic commodity promotion program is intended and designed to maintain or increase the overall demand for the agricultural commodity covered by the program and increase the size of the market for that commodity, often by utilizing promotion methods and techniques that individual producers and processors typically are unable, or have no incentive, to employ.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The commodity promotion laws establish promotion programs that operate as “self-help” mechanisms for producers and processors to fund generic promotions for covered commodities which, under the required supervision and oversight of the Secretary of Agriculture—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00726e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" further specific national governmental goals, as established by Congress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00726e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produce nonideological and commercial communication the purpose of which is to further the governmental policy and objective of maintaining and expanding the markets for the covered commodities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" While some commodity promotion laws grant a producer or processor the option of crediting individual advertising conducted by the producer or processor for all or a portion of the producer’s or processor’s marketing promotion assessments, all promotion programs established under the commodity promotion laws, both those programs that permit credit for individual advertising and those programs that do not contain such provisions, are very narrowly tailored to fulfill the congressional purposes of the commodity promotion laws without impairing or infringing the legal or constitutional rights of any individual producer or processor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" These generic commodity promotion programs are of particular benefit to small producers who often lack the resources or market power to advertise on their own and who are otherwise often unable to benefit from the economies of scale available in promotion and advertising.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Periodic independent evaluation of the effectiveness of these generic commodity promotion programs will assist Congress and the Secretary of Agriculture in ensuring that the objectives of the programs are met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00726ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent evaluation of promotion program effectiveness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided by law, each commodity board established under the supervision and oversight of the Secretary of Agriculture pursuant to a commodity promotion law shall, not less often than every 5 years, authorize and fund, from funds otherwise available to the board, an independent evaluation of the effectiveness of the generic commodity promotion programs and other programs conducted by the board pursuant to a commodity promotion law. The board shall submit to the Secretary, and make available to the public, the results of each periodic independent evaluation conducted under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00726ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall annually provide to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate information on administrative expenses on programs established under commodity promotion laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00726ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption of certified organic products from promotion order assessments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00726ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any provision of a commodity promotion law, a person that produces, handles, markets, or imports organic products may be exempt from the payment of an assessment under a commodity promotion law with respect to any agricultural commodity that is certified as “organic” or “100 percent organic” (as defined in part 205 of title 7, Code of Federal Regulations (or a successor regulation)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Split operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The exemption described in paragraph (1) shall apply to the certified “organic” or “100 percent organic” (as defined in part 205 of title 7 of the Code of Federal Regulations (or a successor regulation)) products of a producer, handler, or marketer regardless of whether the agricultural commodity subject to the exemption is produced, handled, or marketed by a person that also produces, handles, or markets conventional or nonorganic agricultural products, including conventional or nonorganic agricultural products of the same agricultural commodity as that for which the exemption is claimed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall approve the exemption of a person under this subsection if the person maintains a valid organic certificate issued under the Organic Foods Production Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6501"},"text":"7 U.S.C. 6501","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of effectiveness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall be effective until the date on which the Secretary issues an organic commodity promotion order in accordance with subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations concerning eligibility and compliance for an exemption under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00726f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organic commodity promotion order","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00726f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00726f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certified organic farm","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “certified organic farm” has the meaning given the term in section 2103 of the Organic Foods Production Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6502"},"text":"7 U.S.C. 6502","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00726f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered person” means a producer, handler, marketer, or importer of an organic agricultural commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00726f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dual-covered agricultural commodity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “dual-covered agricultural commodity” means an agricultural commodity that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf00726f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/f/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is produced on a certified organic farm; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf00726fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/f/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is covered under both—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf00726fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/f/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organic commodity promotion order issued pursuant to paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf00726fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/f/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other agricultural commodity promotion order issued under a commodity promotion law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00726fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may issue an organic commodity promotion order under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7413"},"text":"section 7413 of this title","children":[],"tail":" that includes any agricultural commodity that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00726fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is produced or handled (as defined in section 2103 of the Organic Foods Production Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6502"},"text":"7 U.S.C. 6502","children":[],"tail":")) and that is certified to be sold or labeled as “organic” or “100 percent organic” (as defined in part 205 of title 7, Code of Federal Regulations (or a successor regulation)); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00726ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is imported with a valid organic certificate (as defined in that part).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072700-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary issues an organic commodity promotion order described in paragraph (2), a covered person may elect, for applicable dual-covered agricultural commodities and in the sole discretion of the covered person, whether to be assessed under the organic commodity promotion order or another applicable agricultural commodity promotion order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072701-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7401/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations concerning eligibility and compliance for an exemption under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0072702-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s501"},"text":"Pub. L. 104–127, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1029"},"text":"110 Stat. 1029","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10607"},"text":"Pub. L. 107–171, title X, § 10607","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/514"},"text":"116 Stat. 514","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tX/s10004/d"},"text":"Pub. L. 113–79, title X, § 10004(d)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/942"},"text":"128 Stat. 942","children":[],"tail":", 943; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dA/tVII/s747"},"text":"Pub. L. 113–235, div. A, title VII, § 747","children":[],"tail":", "},{"tag":"date","attrib":{"da