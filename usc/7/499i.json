{"tag":"section","attrib":{"id":"idee388194-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s499i"},"text":null,"children":[{"tag":"num","attrib":{"value":"499i"},"text":"§ 499i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounts, records, and memoranda; duty of licensees to keep; contents; suspension of license for violation of duty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every commission merchant, dealer, and broker shall keep such accounts, records, and memoranda as fully and correctly disclose all transactions involved in his business, including the true ownership of such business by stockholding or otherwise. If such accounts, records, and memoranda are not so kept, the Secretary may publish the facts and circumstances and/or, by order, suspend the license of the offender for a period not to exceed ninety days.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee388195-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-10/ch436/s9"},"text":"June 10, 1930, ch. 436, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/535"},"text":"46 Stat. 535","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee388196-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee388197-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee388198-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s559"},"text":"section 559 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
