{"tag":"section","attrib":{"id":"idef24903a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008l"},"text":null,"children":[{"tag":"num","attrib":{"value":"2008l"},"text":"§ 2008l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility of employees of State, county, or area committee for loans and loan guarantees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef24903b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not prohibit an employee of a State, county or area committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s590h/b/5"},"text":"section 590h(b)(5) of title 16","children":[],"tail":" or an employee of the Department of Agriculture from obtaining a loan or loan guarantee under subchapter I, II or III of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef24903c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approvals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef24903d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008l/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" County or area office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a loan application from an employee in a county or area office, the Farm Service Agency State office shall be responsible for reviewing and approving the application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef24903e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008l/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a loan application from an employee of a State office, the Farm Service Agency national office shall be responsible for reviewing and approving the application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef24903f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s377"},"text":"Pub. L. 87–128, title III, § 377","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tV/s5321"},"text":"Pub. L. 107–171, title V, § 5321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/349"},"text":"116 Stat. 349","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
