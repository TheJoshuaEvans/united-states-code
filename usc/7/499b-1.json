{"tag":"section","attrib":{"id":"idee363734-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s499b–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"499b–1"},"text":"§ 499b–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Products produced in distinct geographic areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee363735-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s499b–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a perishable agricultural commodity (as defined under the Perishable Agricultural Commodity Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s499a/4"},"text":"7 U.S.C. 499a(4)","children":[],"tail":")— "},{"tag":"ref","attrib":{"idref":"fn002091"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002091"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idee363736-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s499b–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to a Federal marketing order under the Agricultural Marketing Agreement Act of 1937 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s601"},"text":"7 U.S.C. 601","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee363737-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s499b–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" traditionally identified as being produced in a distinct geographic area, State, or region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee363738-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s499b–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unique identity, based on such distinct geographic area, of which has been promoted with funds collected through producer contributions pursuant to such marketing order,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"no person may use the unique name or geographical designation of such commodity to promote the sale of a similar commodity produced outside such area, State, or region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee363739-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s499b–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A violation of this section shall be considered a violation of paragraphs (4) and (5) of section 2 of the Perishable Agricultural Commodities Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s499b/4"},"text":"7 U.S.C. 499b(4)","children":[],"tail":" and (5))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee36373a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s499b–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person bringing a complaint under this section shall reimburse the Secretary of Agriculture for any and all costs associated with the enforcement of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee36373b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s499b–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall not increase any fees charged under the Perishable Agricultural Commodities Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s499a"},"text":"7 U.S.C. 499a","children":[],"tail":" et seq.] to offset costs associated with the operation of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee36373c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s499b–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee36373d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIII/s1309"},"text":"Pub. L. 101–624, title XIII, § 1309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3562"},"text":"104 Stat. 3562","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee36373e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee36373f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idee363740-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Perishable Agricultural Commodity Act, and the Perishable Agricultural Commodities Act, referred to in subsecs. (a), (b), and (d), probably mean the Perishable Agricultural Commodities Act, 1930, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-10/ch436"},"text":"act June 10, 1930, ch. 436","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/531"},"text":"46 Stat. 531","children":[],"tail":", which is classified generally to this chapter (§ 499a et seq.). For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s499a/a"},"text":"section 499a(a) of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s499a/4"},"text":"7 U.S.C. 499a(4)","children":[],"tail":", referred to in subsec. (a), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s499a/b/4"},"text":"7 U.S.C. 499a(b)(4)","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tX/s1011/1/A"},"text":"Pub. L. 102–237, title X, § 1011(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1898"},"text":"105 Stat. 1898","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Agricultural Marketing Agreement Act of 1937 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s601"},"text":"7 U.S.C. 601","children":[],"tail":" et seq.), referred to in subsec. (a)(1), is "},{"tag":"ref","attrib":{"href":"/us/act/1937-06-03/ch296"},"text":"act June 3, 1937, ch. 296","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/246"},"text":"50 Stat. 246","children":[],"tail":", which is classified principally to chapter 26A (§ 671 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s674"},"text":"section 674 of this title","children":[],"tail":" and Tables. The Agricultural Marketing Agreement Act of 1937 reenacted and amended the Agricultural Adjustment Act, title I of "},{"tag":"ref","attrib":{"href":"/us/act/1933-05-12/ch25"},"text":"act May 12, 1933, ch. 25","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/31"},"text":"48 Stat. 31","children":[],"tail":", as amended, which is classified generally to chapter 26 (§ 601 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s601"},"text":"section 601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee363741-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food, Agriculture, Conservation, and Trade Act of 1990, and not as part of the Perishable Agricultural Commodities Act, 1930 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
