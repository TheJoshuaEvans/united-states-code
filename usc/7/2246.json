{"tag":"section","attrib":{"id":"idef780745-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2246"},"text":null,"children":[{"tag":"num","attrib":{"value":"2246"},"text":"§ 2246.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan, rental, or sale of films","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture is authorized, under such rules and regulations and subject to such conditions as he may prescribe, to loan, rent, or sell copies of films. In the sale or rental of films educational institutions or associations for agricultural education not organized for profit shall have preference; all moneys received from such rentals or sales to be covered into the Treasury of the United States as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef780746-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-03-04/ch179"},"text":"Mar. 4, 1917, ch. 179","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/1157"},"text":"39 Stat. 1157","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1920-05-31/ch217"},"text":"May 31, 1920, ch. 217","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/718"},"text":"41 Stat. 718","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef780747-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef780748-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef780749-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s554"},"text":"section 554 of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
