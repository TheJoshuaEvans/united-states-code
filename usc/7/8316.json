{"tag":"section","attrib":{"id":"idf036ea39-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8316"},"text":null,"children":[{"tag":"num","attrib":{"value":"8316"},"text":"§ 8316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf036ea3a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8316/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf036ea3b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8316/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf036ea3c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8316/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In connection with an emergency under which a pest or disease of livestock threatens any segment of agricultural production in the United States, the Secretary may transfer from other appropriations or funds available to the agencies or corporations of the Department of Agriculture such funds as the Secretary determines are necessary for the arrest, control, eradication, or prevention of the spread of the pest or disease of livestock and for related expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036ea3d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8316/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds transferred under this subsection shall remain available until expended, without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036ea3e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8316/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviewability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The action of any officer, employee, or agent of the Secretary in carrying out this section (including determining the amount of and making any payment authorized to be made under this chapter) shall not be subject to review by any officer or employee of the Federal Government other than the Secretary or the designee of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf036ea3f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8316/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this chapter, the Secretary may use funds made available to carry out this chapter for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf036ea40-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8316/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employment of civilian nationals in foreign countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036ea41-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8316/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction and operation of research laboratories, quarantine stations, and other buildings and facilities for special purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf036ea42-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10417"},"text":"Pub. L. 107–171, title X, § 10417","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/507"},"text":"116 Stat. 507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXI/s11011/3"},"text":"Pub. L. 110–234, title XI, § 11011(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1360"},"text":"122 Stat. 1360","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XI, § 11011(3), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2122.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf036ea43-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf036ea44-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"tex