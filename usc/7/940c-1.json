{"tag":"section","attrib":{"id":"idee611876-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"940c–1"},"text":"§ 940c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guarantees for bonds and notes issued for electrification or telephone purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee611877-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee611878-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guarantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), the Secretary shall guarantee payments on bonds or notes issued by cooperative or other lenders organized on a not-for-profit basis, if the proceeds of the bonds or notes are used to make utility infrastructure loans, or refinance bonds or notes issued for those purposes, to a borrower that has at any time received, or is eligible to receive, a loan under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee611879-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A bond or note guaranteed under this section shall, by agreement between the Secretary and the borrower—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee61187a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be for a term of 30 years (or another term of years that the Secretary determines is appropriate); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee61187b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be repaid by the borrower—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee61187c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in periodic installments of principal and interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee61187d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in periodic installments of interest and, at the end of the term of the bond or note, as applicable, by the repayment of the outstanding principal; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee61187e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through a combination of the methods described in clauses (i) and (ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee61187f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee611880-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outstanding loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A lender shall not receive a guarantee under this section for a bond or note if, at the time of the guarantee, the total principal amount of such guaranteed bonds or notes outstanding of the lender would exceed the principal amount of outstanding loans of the lender for eligible purposes described in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee611881-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may deny the request of a lender for the guarantee of a bond or note under this section if the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee611882-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lender does not have appropriate expertise or experience or is otherwise not qualified to make loans for eligible purposes described in subsection (a)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee611883-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the bond or note issued by the lender would not be investment grade quality without a guarantee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee611884-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lender has not provided to the Secretary a list of loan amounts approved by the lender that the lender certifies are for eligible purposes described in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee611885-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of guarantees provided by the Secretary under this section during a fiscal year shall not exceed $1,000,000,000, subject to the availability of funds under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee611886-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee611887-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A lender that receives a guarantee issued under this section on a bond or note shall pay a fee to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee611888-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee611889-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the annual fee paid for the guarantee of a bond or note under this section shall be equal to 30 basis points of the amount of the unpaid principal of the bond or note guaranteed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee61188a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subsection and subsection (e)(2), no other fees shall be assessed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee61188b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee61188c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A lender shall pay the fees required under this subsection on a semiannual basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee61188d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Structured schedule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, with the consent of the lender, structure the schedule for payment of the fee to ensure that sufficient funds are available to pay the subsidy costs for note or bond guarantees as provided for in subsection (e)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee61188e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural economic development subaccount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (e)(2), fees collected under this subsection shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee61188f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposited into the rural economic development subaccount that shall be maintained as required by sections 940c(b)(2) and 940c–2(f) of this title, to remain available until expended; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee611890-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used for the purposes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s940c/b/2"},"text":"section 940c(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee611891-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guarantees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee611892-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A guarantee issued under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee611893-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be for the full amount of a bond or note, including the amount of principal, interest, and call premiums;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee611894-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be fully assignable and transferable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee611895-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent the full faith and credit of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee611896-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To ensure that the Secretary has the resources necessary to properly examine the proposed guarantees, the Secretary may limit the number of guarantees issued under this section to 5 per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee611897-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department opinion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the timely request of a lender, the General Counsel of the Department of Agriculture shall provide the Secretary with an opinion regarding the validity and authority of a guarantee issued to the lender under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee611898-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee611899-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee61189a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that the amount of funds appropriated for a fiscal year under paragraph (1) are not sufficient to carry out this section, the Secretary may use up to ⅓ of the fees collected under subsection (c) for the cost of providing guarantees of bonds and notes under this section before depositing the remainder of the fees into the rural economic development subaccount required to be maintained by sections 940c(b)(2) and 940c–2(f) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee61189b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided under this section shall terminate on ","children":[{"tag":"date","attrib":{"date":"2023-09-30"},"text":"September 30, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee61189c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title III, § 313A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6101/a"},"text":"Pub. L. 107–171, title VI, § 6101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/413"},"text":"116 Stat. 413","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVI/s6106/a"},"text":"Pub. L. 110–234, title VI, § 6106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1197"},"text":"122 Stat. 1197","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VI, § 6106(a), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1958; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVI/s6102"},"text":"Pub. L. 113–79, title VI, § 6102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/851"},"text":"128 Stat. 851","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI"},"text":"Pub. L. 115–334, title VI","children":[],"tail":", §§ 6504(d), 6505(a), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4774"},"text":"132 Stat. 4774","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee61189d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee61189e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee61189f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The authorities provided by each provision of, and each amendment made by, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"Sept. 30, 2023","children":[],"tail":", to continue, and authorities to be carried out, until the later of "},{"tag":"date","attrib":{"date":"2024-09-30"},"text":"Sept. 30, 2024","children":[],"tail":", or the date specified in the provision of, or amendment made by, "},{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/a"},"text":"section 102(a) of Pub. L. 118–22","children":[],"tail":", set out in an Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The authorities provided by each provision of, and each amendment made by, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"2012-09-30"},"text":"Sept. 30, 2012","children":[],"tail":", to continue, and the Secretary of Agriculture to carry out the authorities, until the later of "},{"tag":"date","attrib":{"date":"2013-09-30"},"text":"Sept. 30, 2013","children":[],"tail":", or the date specified in the provision of, or amendment made by, "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/240/s701/a"},"text":"section 701(a) of Pub. L. 112–240","children":[],"tail":", set out in a 1-Year Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee6118a0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6505/a/1"},"text":"Pub. L. 115–334, § 6505(a)(1)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, substituted “basis, if the proceeds of the bonds or notes are used to make utility infrastructure loans, or refinance bonds or notes issued for those purposes, to a borrower that has at any time received, or is eligible to receive, a loan under this chapter.” for “basis if the proceeds of the bonds or notes are used to make loans for any electrification or telephone purpose eligible for assistance under this chapter, including section 904 or 922 of this title or to refinance bonds or notes issued for such purposes.”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6505/a/2/A"},"text":"Pub. L. 115–334, § 6505(a)(2)(A)","children":[],"tail":", substituted “purposes described in subsection (a)(1).” for “electrification or telephone purposes consistent with this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6505/a/2/B"},"text":"Pub. L. 115–334, § 6505(a)(2)(B)","children":[],"tail":", (C), redesignated par. (3) as (2) and struck out former par. (2). Prior to amendment, text of par. (2) read as follows: “The Secretary shall not guarantee payment on a bond or note issued by a lender, the proceeds of which are used for the generation of electricity.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6505/a/2/D/i"},"text":"Pub. L. 115–334, § 6505(a)(2)(D)(i)","children":[],"tail":", substituted “for eligible purposes described in subsection (a)(1)” for “for electrification or telephone purposes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6505/a/2/D/ii"},"text":"Pub. L. 115–334, § 6505(a)(2)(D)(ii)","children":[],"tail":", substituted “subsection (a)(1)” for “subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6505/a/2/C"},"text":"Pub. L. 115–334, § 6505(a)(2)(C)","children":[],"tail":", redesignated par. (4) as (3). Former par. (3) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6504/d/1/A"},"text":"Pub. L. 115–334, § 6504(d)(1)(A)","children":[],"tail":", substituted “that shall be maintained as required by sections 940c(b)(2) and 940c–2(f) of this title” for “maintained under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s940c/b/2/A"},"text":"section 940c(b)(2)(A) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6504/d/1/B"},"text":"Pub. L. 115–334, § 6504(d)(1)(B)","children":[],"tail":", substituted “940c(b)(2) of this title” for “940c(b)(2)(B) of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6504/d/2"},"text":"Pub. L. 115–334, § 6504(d)(2)","children":[],"tail":", substituted “required to be maintained by sections 940c(b)(2) and 940c–2(f) of this title” for “maintained under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s940c/b/2/A"},"text":"section 940c(b)(2)(A) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6505/a/3"},"text":"Pub. L. 115–334, § 6505(a)(3)","children":[],"tail":", substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" substituted “2018” for “2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s6106/a/1/A"},"text":"Pub. L. 110–246, § 6106(a)(1)(A)","children":[],"tail":", substituted “for eligible electrification or telephone purposes consistent with this chapter” for “for electrification or telephone purposes that have been made concurrently with loans approved for such purposes under this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s6106/a/1/B"},"text":"Pub. L. 110–246, § 6106(a)(1)(B)","children":[],"tail":", added par. (4) and struck out former par. (4) which related to prohibition on use of amounts from reduced funding costs for interest rate reduction except for certain concurrent loans."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s6106/a/2"},"text":"Pub. L. 110–246, § 6106(a)(2)","children":[],"tail":", added pars. (2) and (3) and struck out former pars. (2) and (3) which provided that the amount of an annual fee paid for the guarantee would be equal to 30 basis points of the amount of the unpaid principal and directed payment of fees required under subsec. (c) on a semiannual basis."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s6106/a/3"},"text":"Pub. L. 110–246, § 6106(a)(3)","children":[],"tail":", substituted “2012” for “2007”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee6118a1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee6118a2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idee6118a3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations and Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVI/s6106/b"},"text":"Pub. L. 110–234, title VI, § 6106(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1197"},"text":"122 Stat. 1197","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VI, § 6106(b), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1959, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/246/s4/a"},"text":"“The Secretary [of Agriculture] shall continue to carry out section 313A of the Rural Electrification Act of 1936 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s940c–1"},"text":"7 U.S.C. 940c–1","children":[],"tail":") in the same manner as on the day before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":"], except without regard to the limitations prescribed in subsection (b)(1) of that section, until such time as any regulations necessary to carry out the amendments made by this section [amending this section] are fully implemented.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical provisions. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":".]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dA/tVII/s750/b"},"text":"Pub. L. 108–199, div. A, title VII, § 750(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/38"},"text":"118 Stat. 38","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/199/dA/tVII/s750/b"},"text":"“The Secretary shall publish a proposed rule to carry out section 313A of the Rural Electrification Act of 1936 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s940c–1"},"text":"7 U.S.C. 940c–1","children":[],"tail":"] within 60 days of enactment of this Act ["},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6101/b"},"text":"Pub. L. 107–171, title VI, § 6101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/415"},"text":"116 Stat. 415","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/171/tVI/s6101/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":"], the Secretary of Agriculture shall promulgate regulations to carry out the amendments made by this section [enacting this section]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 240 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":"], the Secretary shall implement the amendment made by this section [enacting this section].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idee6118a4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Administration of Guarantees Prior to Implementation of Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6505/b"},"text":"Pub. L. 115–334, title VI, § 6505(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4775"},"text":"132 Stat. 4775","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/334/tVI/s6505/b"},"text":"“Beginning on the date of enactment of the Agriculture Improvement Act of 2018 [","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":"], the Secretary [of Agriculture] shall continue to carry out section 313A of the Rural Electrification Act of 1936 ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s940c–1"},"text":"7 U.S.C. 940c–1","children":[],"tail":") (as amended by subsection (a)) under a Notice of Solicitation of Applications until the date on which any regulations necessary to carry out the amendments made by subsection (a) [amending this section] are fully implemented.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
