{"tag":"section","attrib":{"id":"ideeedc80c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1731"},"text":null,"children":[{"tag":"num","attrib":{"value":"1731"},"text":"§ 1731.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodity determinations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideeedc80d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1731/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligible commodities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeedc80e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1731/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alcoholic beverages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Alcoholic beverages shall not be made available for disposition under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc80f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1731/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tobacco","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Tobacco or the products thereof shall not be made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1727b"},"text":"section 1727b of this title","children":[],"tail":" or subchapter III of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeedc810-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1731/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Market development activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a)(1) shall not be construed to prohibit representatives of the United States wine, beer, distilled spirits, or other alcoholic beverage industry from participating in agricultural market development activities carried out by the Secretary with foreign currencies made available under subchapter II of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideeedc811-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title IV, § 401, as added "},{"tag":"ref","attrib":{"href":"/us/pl/86/341/tI/s14"},"text":"Pub. L. 86–341, title I, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-21"},"text":"Sept. 21, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/610"},"text":"73 Stat. 610","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/87/703/tII/s201/1"},"text":"Pub. L. 87–703, title II, § 201(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-27"},"text":"Sept. 27, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/610"},"text":"76 Stat. 610","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/808/s2/E"},"text":"Pub. L. 89–808, § 2(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-11"},"text":"Nov. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1535"},"text":"80 Stat. 1535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/88/tII/s212"},"text":"Pub. L. 95–88, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/551"},"text":"91 Stat. 551","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXII/s1204"},"text":"Pub. L. 95–113, title XII, § 1204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/956"},"text":"91 Stat. 956","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/53/tII/s208"},"text":"Pub. L. 96–53, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/370"},"text":"93 Stat. 370","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3645"},"text":"104 Stat. 3645","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s212"},"text":"Pub. L. 104–127, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/955"},"text":"110 Stat. 955","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3014/a"},"text":"Pub. L. 110–246, title III, § 3014(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1826"},"text":"122 Stat. 1826","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideeedc812-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideeedc813-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideeedc814-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" redesignated subsecs. (b) and (c) as (a) and (b), respectively, in subsec. (b), substituted “(a)(1)” for “(b)(1)”, and struck out former subsec. (a). Prior to amendment, text read as follows: “No agricultural commodity shall be available for disposition under this chapter if the Secretary determines that the disposition would reduce the domestic supply of the commodity below the supply needed to meet domestic requirements and provide adequate carryover (as determined by the Secretary), unless the Secretary determines that some part of the supply should be used to carry out urgent humanitarian purposes under this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" added subsec. (a) and struck out former subsec. (a) which authorized Secretary, after consultation with other affected Federal agencies, to determine agricultural commodities and quantities thereof available for disposition, redesignated subsec. (e) as (b) and struck out former subsec. (b) which provided for modification of determination by Secretary, redesignated subsec. (f) as (c) and substituted “(b)(1)” for “(e)(1)”, struck out former subsec. (c) which provided for nonavailability of commodities if domestic supply of such commodities was adversely affected, and struck out subsec. (d) which outlined policies for distribution of commodities to developing countries."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" amended section generally, substituting present provisions for provisions authorizing Secretary to determine types and quantities of commodities available for distribution, limiting distribution where domestic supply is threatened, and requiring available storage facilities in recipient country prior to making commodities available to such country as well as finding that distribution will not result in interference with production or marketing in that country."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/53"},"text":"Pub. L. 96–53","children":[],"tail":" substituted “to or interference with domestic production or marketing in” for “to domestic production in”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113"},"text":"Pub. L. 95–113","children":[],"tail":" inserted provisions under which commodities may be made available for disposition if the Secretary of Agriculture determines that some part of the supply of commodities should be used to carry out urgent humanitarian purposes, even though such disposition would reduce the domestic supply of those commodities below that needed to meet domestic requirements, provide adequate carryover, and allow for anticipated exports."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/88"},"text":"Pub. L. 95–88","children":[],"tail":" designated existing provisions as subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/88"},"text":"Pub. L. 95–88","children":[],"tail":" added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/808"},"text":"Pub. L. 89–808","children":[],"tail":" substituted provisions relating to determination and criteria for such determination by the Secretary of Agriculture of agricultural commodities available for disposition for former statement of purpose of provisions relating to long-term supply contracts, now covered by subchapter II of this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/703"},"text":"Pub. L. 87–703","children":[],"tail":" included in the statement of purpose the stimulation and increase of sales of surplus agricultural commodities for dollars through long-term supply contracts and through the extension of credit for the purchase of such commodities, by agreements with friendly nations or with private trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideeedc815-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideeedc816-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/b"},"text":"section 4(b) of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideeedc817-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1991-01-01"},"text":"Jan. 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1513"},"text":"section 1513 of Pub. L. 101–624","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideeedc818-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/53"},"text":"Pub. L. 96–53","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/53/s512/a"},"text":"section 512(a) of Pub. L. 96–53","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideeedc819-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113"},"text":"Pub. L. 95–113","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/s1901"},"text":"section 1901 of Pub. L. 95–113","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1307"},"text":"section 1307 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/88"},"text":"Pub. L. 95–88","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/88/s215"},"text":"section 215 of Pub. L. 95–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1702"},"text":"section 1702 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideeedc81a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1966 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/808"},"text":"Pub. L. 89–808","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1967-01-01"},"text":"Jan. 1, 1967","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/89/808/s5"},"text":"section 5 of Pub. L. 89–808","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideeedc81b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Export Sales of Dairy Products","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXI/s1163"},"text":"Pub. L. 99–198, title XI, § 1163","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1499"},"text":"99 Stat. 1499","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/435/tI/s107"},"text":"Pub. L. 100–435, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-19"},"text":"Sept. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1651"},"text":"102 Stat. 1651","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tI/s111"},"text":"Pub. L. 101–624, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3380"},"text":"104 Stat. 3380","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tIV/s411/c"},"text":"Pub. L. 103–465, title IV, § 411(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4963"},"text":"108 Stat. 4963","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/465/tIV/s411/c"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In each fiscal year, the Secretary of Agriculture may sell dairy products for export, at such prices as the Secretary determines appropriate, in a quantity and allocated as determined by the Secretary, consistent with the obligations undertaken by the United States set forth in the Uruguay Round Agreements, if the disposition of the commodities will not interfere with the usual marketings of the United States nor disrupt world prices of agricultural commodities and patterns of commercial trade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such sales shall be made through the Commodity Credit Corporation under existing authority available to the Secretary or the Commodity Credit Corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Through ","children":[{"tag":"date","attrib":{"date":"1995-09-30"},"text":"September 30, 1995","children":[],"tail":", the Secretary shall report semiannually to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate on the volume of sales made under this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[Amendment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1163"},"text":"section 1163 of Pub. L. 99–198","children":[],"tail":", set out above, by "},{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" effective on the date of entry into force of the WTO Agreement with respect to the United States ("},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s451"},"text":"section 451 of Pub. L. 103–465","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3601"},"text":"section 3601 of Title 19","children":[],"tail":", Customs Duties.]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[Amendment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1163"},"text":"section 1163 of Pub. L. 99–198","children":[],"tail":", set out above, by "},{"tag":"ref","attrib":{"href":"/us/pl/100/435"},"text":"Pub. L. 100–435","children":[],"tail":" effective and implemented on "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/435/s701"},"text":"section 701 of Pub. L. 100–435","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2012"},"text":"section 2012 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
