{"tag":"section","attrib":{"id":"idf0130e64-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518"},"text":null,"children":[{"tag":"num","attrib":{"value":"7518"},"text":"§ 7518.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Micro-grants for food security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0130e65-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to increase the quantity and quality of locally grown food through small-scale gardening, herding, and livestock operations in food insecure communities in areas of the United States that have significant levels of food insecurity and import a significant quantity of food.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0130e66-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0130e67-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means an entity that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0130e68-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0130e69-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0130e6a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe or tribal organization, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0130e6b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a nonprofit organization engaged in increasing food security, as determined by the Secretary, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf0130e6c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/1/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a religious organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0130e6d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/1/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a food bank; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0130e6e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/1/A/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a food pantry;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0130e6f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a federally funded educational facility, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf0130e70-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/1/A/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Head Start program or an Early Head Start program carried out under the Head Start Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9831"},"text":"42 U.S.C. 9831","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0130e71-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/1/A/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public elementary school or public secondary school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0130e72-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/1/A/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0130e73-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/1/A/iv/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Tribal College or University (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c/b"},"text":"section 1059c(b) of title 20","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0130e74-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/1/A/iv/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a job training program; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0130e75-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local or Tribal government that may not levy local taxes under State or Federal law; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e76-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located in an eligible State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0130e77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible State” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0130e78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State of Alaska;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e79-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State of Hawaii;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e7a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" American Samoa;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e7b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commonwealth of the Northern Mariana Islands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e7c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commonwealth of Puerto Rico;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e7d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federated States of Micronesia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e7e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Guam;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e7f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Republic of the Marshall Islands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e80-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Republic of Palau; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e81-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0130e82-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall distribute funds to the agricultural department or agency of each eligible State for the competitive distribution of subgrants to eligible entities to increase the quantity and quality of locally grown food in food insecure communities, including through small-scale gardening, herding, and livestock operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0130e83-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0130e84-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amount made available under subsection (g), the Secretary shall distribute—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0130e85-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 40 percent to the State of Alaska;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 40 percent to the State of Hawaii; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e87-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2.5 percent to each eligible State described in any of subparagraphs (C) through (J) of subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0130e88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryover of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds distributed under paragraph (1) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0130e89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible State that receives funds under paragraph (1) may use not more than 3 percent of those funds—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0130e8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to administer the competition for providing subgrants to eligible entities in that eligible State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide oversight of the subgrant recipients in that eligible State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to collect data and submit a report to the Secretary under subsection (f)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0130e8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subgrants to eligible entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0130e8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of subgrants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0130e8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a subgrant to an eligible entity under this section shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0130e90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an eligible entity that is an individual, not greater than $5,000 per year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0130e91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an eligible entity described in any of clauses (ii) through (v) of subsection (b)(1)(A), not greater than $10,000 per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of receiving a subgrant under this section, an eligible entity shall provide funds equal to 10 percent of the amount received by the eligible entity under the subgrant, to be derived from non-Federal sources. A State may waive the matching requirement for an individual who otherwise meets the requirements to receive a subgrant by the eligible State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds received by an eligible entity that is awarded a subgrant under this section shall remain available for expenditure not later than 3 years after the date the funds are received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0130e94-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the competitive distribution of subgrants under subsection (c), an eligible State may give priority to an eligible entity that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0130e95-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not previously received a subgrant under this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located in a community or region in that eligible State with the highest degree of food insecurity, as determined by the agricultural department or agency of the eligible State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0130e97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible State may provide subgrants to 2 or more eligible entities to carry out the same project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0130e98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of subgrant funds by eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a subgrant under this section shall use the funds to engage in activities that will increase the quantity and quality of locally grown food for food insecure individuals, families, neighborhoods, and communities, including by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0130e99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchasing gardening tools or equipment, soil, soil amendments, seeds, plants, animals, canning equipment, refrigeration, or other items necessary to grow and store food;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchasing or building composting units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchasing or building towers designed to grow leafy green vegetables;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e9c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanding an area under cultivation or engaging in other activities necessary to be eligible to receive funding under the environmental quality incentives program established under chapter 4 of subtitle D of title XII of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa"},"text":"16 U.S.C. 3839aa","children":[],"tail":" et seq.) for a high tunnel;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaging in an activity that extends the growing season;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" starting or expanding hydroponic and aeroponic farming of any scale;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130e9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building, buying, erecting, or repairing fencing for livestock, poultry, or reindeer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130ea0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/4/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchasing and equipping a slaughter and processing facility approved by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130ea1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/4/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" traveling to participate in agricultural education provided by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0130ea2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/4/I/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State cooperative extension service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0130ea3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/4/I/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a land-grant college or university (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3103"},"text":"section 3103 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0130ea4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/4/I/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Tribal College or University (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c/b"},"text":"section 1059c(b) of title 20","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0130ea5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/4/I/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Alaska Native-serving institution or a Native Hawaiian-serving institution (as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059d/b"},"text":"section 1059d(b) of title 20","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0130ea6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/4/I/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal or State agency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130ea7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/4/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paying for shipping of purchased items relating to growing or raising food for local consumption or purchase;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130ea8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/4/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" creating or expanding avenues for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0130ea9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/4/K/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale of food commodities, specialty crops, and meats that are grown by the eligible entity for sale in the local community; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0130eaa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/4/K/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the availability of fresh, locally grown, and nutritious food; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130eab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/4/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaging in other activities relating to increasing food security (including subsistence), as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0130eac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for other financial assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity shall not be ineligible to receive financial assistance under another program administered by the Secretary as a result of receiving a subgrant under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0130ead-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0130eae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subgrant recipients","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As a condition of receiving a subgrant under this section, an eligible entity shall agree to submit to the eligible State in which the eligible entity is located a report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0130eaf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 60 days after the end of the project funded by the subgrant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130eb0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that describes the use of the subgrants by eligible entities, the quantity of food grown through small-scale gardening, herding, and livestock operations, and the number of food insecure individuals fed as a result of the subgrant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0130eb1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to the Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after the date on which an eligible State receives a report from each eligible entity in that State under paragraph (1), the eligible State shall submit to the Secretary a report that describes, in the aggregate, the information and data contained in the reports received from those eligible entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0130eb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0130eb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $10,000,000 for fiscal year 2019 and each fiscal year thereafter, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0130eb4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7518/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations in advance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Only funds appropriated under paragraph (1) in advance specifically to carry out this section shall be available to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0130eb5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIV/s4206"},"text":"Pub. L. 115–334, title IV, § 4206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4663"},"text":"132 Stat. 4663","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0130eb6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0130eb7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf0130eb8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Head Start Act, referred to in subsec. (b)(1)(A)(iv)(I), is subchapter B (§ 635 et seq.) of chapter 8 of subtitle A of title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/499"},"text":"95 Stat. 499","children":[],"tail":", which is classified generally to subchapter II (§ 9831 et seq.) of chapter 105 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9801"},"text":"section 9801 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Food Security Act of 1985, referred to in subsec. (e)(4)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1354"},"text":"99 Stat. 1354","children":[],"tail":". Chapter 4 of subtitle D of title XII of the Act is classified generally to part IV (§ 3839aa et seq.) of subchapter IV of chapter 58 of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title of 1985 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1281"},"text":"section 1281 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf0130eb9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agriculture Improvement Act of 2018, and not as part of the Emergency Food Assistance Act of 1983 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf0130eba-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idf0130ebb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” as meaning the Secretary of Agriculture, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2"},"text":"section 2 of Pub. L. 115–334","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
