{"tag":"section","attrib":{"id":"idf010c4ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7513"},"text":null,"children":[{"tag":"num","attrib":{"value":"7513"},"text":"§ 7513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finality of determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Determinations made by the Secretary of Agriculture under this chapter and the facts constituting the basis for any donation of commodities under this chapter, or the amount thereof, when officially determined in conformity with the applicable regulations prescribed by the Secretary, shall be final and conclusive and shall not be reviewable by any other officer or agency of the Government.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf010c4ac-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/8/tII/s211"},"text":"Pub. L. 98–8, title II, § 211","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/92/s2/10"},"text":"Pub. L. 98–92, § 2(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-02"},"text":"Sept. 2, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/612"},"text":"97 Stat. 612","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf010c4ad-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf010c4ae-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf010c4af-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/92/s2"},"text":"Pub. L. 98–92, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-02"},"text":"Sept. 2, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/608"},"text":"97 Stat. 608","children":[],"tail":", provided in part that this section is effective "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"Oct. 1, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
