{"tag":"section","attrib":{"id":"idedcd3d77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"7b–3"},"text":"§ 7b–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Swap execution facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idedcd3d78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedcd3d79-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person may operate a facility for the trading or processing of swaps unless the facility is registered as a swap execution facility or as a designated contract market under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcd3d7a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dual registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person that is registered as a swap execution facility under this section shall register with the Commission regardless of whether the person also is registered with the Securities and Exchange Commission as a swap execution facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedcd3d7b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trading and trade processing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedcd3d7c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as specified in paragraph (2), a swap execution facility that is registered under subsection (a) may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcd3d7d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available for trading any swap; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcd3d7e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate trade processing of any swap.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcd3d7f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural swaps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A swap execution facility may not list for trading or confirm the execution of any swap in an agricultural commodity (as defined by the Commission) except pursuant to a rule or regulation of the Commission allowing the swap under such terms and conditions as the Commission shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedcd3d80-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of facility used to trade swaps by contract markets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A board of trade that operates a contract market shall, to the extent that the board of trade also operates a swap execution facility and uses the same electronic trade execution system for listing and executing trades of swaps on or through the contract market and the swap execution facility, identify whether the electronic trading of such swaps is taking place on or through the contract market or the swap execution facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedcd3d81-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule-writing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedcd3d82-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Securities and Exchange Commission and Commodity Futures Trading Commission may promulgate rules defining the universe of swaps that can be executed on a swap execution facility. These rules shall take into account the price and nonprice requirements of the counterparties to a swap and the goal of this section as set forth in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcd3d83-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For all swaps that are not required to be executed through a swap execution facility as defined in paragraph (1), such trades may be executed through any other available means of interstate commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcd3d84-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Securities and Exchange Commission and Commodity Futures Trading Commission shall update these rules as necessary to account for technological and other innovation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedcd3d85-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The goal of this section is to promote the trading of swaps on swap execution facilities and to promote pre-trade price transparency in the swaps market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedcd3d86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Core principles for swap execution facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedcd3d87-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with core principles","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcd3d88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be registered, and maintain registration, as a swap execution facility, the swap execution facility shall comply with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idedcfad89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the core principles described in this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcfad8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any requirement that the Commission may impose by rule or regulation pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s12a/5"},"text":"section 12a(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcfad8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable discretion of swap execution facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless otherwise determined by the Commission by rule or regulation, a swap execution facility described in subparagraph (A) shall have reasonable discretion in establishing the manner in which the swap execution facility complies with the core principles described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcfad8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A swap execution facility shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcfad8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish and enforce compliance with any rule of the swap execution facility, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idedcfad8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms and conditions of the swaps traded or processed on or through the swap execution facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcfad8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any limitation on access to the swap execution facility;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcfad90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish and enforce trading, trade processing, and participation rules that will deter abuses and have the capacity to detect, investigate, and enforce those rules, including means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idedcfad91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide market participants with impartial access to the market; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcfad92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to capture information that may be used in establishing whether rule violations have occurred;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcfad93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish rules governing the operation of the facility, including rules specifying trading procedures to be used in entering and executing orders traded or posted on the facility, including block trades; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcfad94-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide by its rules that when a swap dealer or major swap participant enters into or facilitates a swap that is subject to the mandatory clearing requirement of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2/h"},"text":"section 2(h) of this title","children":[],"tail":", the swap dealer or major swap participant shall be responsible for compliance with the mandatory trading requirement under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2/h/8"},"text":"section 2(h)(8) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcfad95-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Swaps not readily susceptible to manipulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The swap execution facility shall permit trading only in swaps that are not readily susceptible to manipulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcfad96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring of trading and trade processing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The swap execution facility shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcfad97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish and enforce rules or terms and conditions defining, or specifications detailing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idedcfad98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trading procedures to be used in entering and executing orders traded on or through the facilities of the swap execution facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcfad99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for trade processing of swaps on or through the facilities of the swap execution facility; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcfad9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor trading in swaps to prevent manipulation, price distortion, and disruptions of the delivery or cash settlement process through surveillance, compliance, and disciplinary practices and procedures, including methods for conducting real-time monitoring of trading and comprehensive and accurate trade reconstructions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcfad9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ability to obtain information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The swap execution facility shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcfad9c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and enforce rules that will allow the facility to obtain any necessary information to perform any of the functions described in this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcfad9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the information to the Commission on request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcfad9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the capacity to carry out such international information-sharing agreements as the Commission may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcfad9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Position limits or accountability","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcfada0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To reduce the potential threat of market manipulation or congestion, especially during trading in the delivery month, a swap execution facility that is a trading facility shall adopt for each of the contracts of the facility, as is necessary and appropriate, position limitations or position accountability for speculators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcfada1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Position limits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any contract that is subject to a position limitation established by the Commission pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6a/a"},"text":"section 6a(a) of this title","children":[],"tail":", the swap execution facility shall—"}],"tail":null},{"tag":"clause","attrib":{"id":"idedcfada2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set its position limitation at a level no higher than the Commission limitation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcfada3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor positions established on or through the swap execution facility for compliance with the limit set by the Commission and the limit, if any, set by the swap execution facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcfada4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial integrity of transactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The swap execution facility shall establish and enforce rules and procedures for ensuring the financial integrity of swaps entered on or through the facilities of the swap execution facility, including the clearance and settlement of the swaps pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2/h/1"},"text":"section 2(h)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcfada5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The swap execution facility shall adopt rules to provide for the exercise of emergency authority, in consultation or cooperation with the Commission, as is necessary and appropriate, including the authority to liquidate or transfer open positions in any swap or to suspend or curtail trading in a swap.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcfada6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timely publication of trading information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcfada7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The swap execution facility shall make public timely information on price, trading volume, and other trading data on swaps to the extent prescribed by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcfada8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capacity of swap execution facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The swap execution facility shall be required to have the capacity to electronically capture and transmit trade information with respect to transactions executed on the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcfada9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping and reporting","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcfadaa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A swap execution facility shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idedcfadab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/10/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain records of all activities relating to the business of the facility, including a complete audit trail, in a form and manner acceptable to the Commission for a period of 5 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcfadac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/10/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the Commission, in a form and manner acceptable to the Commission, such information as the Commission determines to be necessary or appropriate for the Commission to perform the duties of the Commission under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcfadad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/10/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall keep any such records relating to swaps defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1a/47/A/v"},"text":"section 1a(47)(A)(v) of this title","children":[],"tail":" open to inspection and examination by the Securities and Exchange Commission.” "},{"tag":"ref","attrib":{"idref":"fn002036"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002036"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The closing quotation marks probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcfadae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall adopt data collection and reporting requirements for swap execution facilities that are comparable to corresponding requirements for derivatives clearing organizations and swap data repositories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcfadaf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antitrust considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless necessary or appropriate to achieve the purposes of this chapter, the swap execution facility shall not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcfadb0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt any rules or taking ","children":[{"tag":"ref","attrib":{"idref":"fn002037"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002037"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “take”."}],"tail":" any actions that result in any unreasonable restraint of trade; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcfadb1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impose any material anticompetitive burden on trading or clearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcfadb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts of interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The swap execution facility shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcfadb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and enforce rules to minimize conflicts of interest in its decision-making process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcfadb4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a process for resolving the conflicts of interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcfadb5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial resources","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcfadb6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The swap execution facility shall have adequate financial, operational, and managerial resources to discharge each responsibility of the swap execution facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcfadb7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of resource adequacy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The financial resources of a swap execution facility shall be considered to be adequate if the value of the financial resources exceeds the total amount that would enable the swap execution facility to cover the operating costs of the swap execution facility for a 1-year period, as calculated on a rolling basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcfadb8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" System safeguards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The swap execution facility shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcfadb9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish and maintain a program of risk analysis and oversight to identify and minimize sources of operational risk, through the development of appropriate controls and procedures, and automated systems, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idedcfadba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/14/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are reliable and secure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcfadbb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/14/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have adequate scalable capacity;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcfadbc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish and maintain emergency procedures, backup facilities, and a plan for disaster recovery that allow for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idedcfadbd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/14/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the timely recovery and resumption of operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcfadbe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/14/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fulfillment of the responsibilities and obligations of the swap execution facility; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcfadbf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/14/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" periodically conduct tests to verify that the backup resources of the swap execution facility are sufficient to ensure continued—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idedcfadc0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/14/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" order processing and trade matching;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcfadc1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/14/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" price reporting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcfadc2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/14/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" market surveillance and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcfadc3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/14/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintenance of a comprehensive and accurate audit trail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedcfadc4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of chief compliance officer","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedcfadc5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each swap execution facility shall designate an individual to serve as a chief compliance officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcfadc6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The chief compliance officer shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idedcfadc7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/15/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report directly to the board or to the senior officer of the facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcfadc8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/15/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review compliance with the core principles in this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcfadc9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/15/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the board of the facility, a body performing a function similar to that of a board, or the senior officer of the facility, resolve any conflicts of interest that may arise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcfadca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/15/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for establishing and administering the policies and procedures required to be established pursuant to this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcfadcb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/15/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure compliance with this chapter and the rules and regulations issued under this chapter, including rules prescribed by the Commission pursuant to this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcfadcc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/15/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish procedures for the remediation of noncompliance issues found during compliance office reviews, look backs, internal or external audit findings, self-reported errors, or through validated complaints.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcfadcd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/15/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing procedures under subparagraph (B)(vi), the chief compliance officer shall design the procedures to establish the handling, management response, remediation, retesting, and closing of noncompliance issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedcfadce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/15/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idedcfadcf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/15/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with rules prescribed by the Commission, the chief compliance officer shall annually prepare and sign a report that contains a description of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idedcfadd0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/15/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the compliance of the swap execution facility with this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idedcfadd1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/15/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the policies and procedures, including the code of ethics and conflict of interest policies, of the swap execution facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedcfadd2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/15/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The chief compliance officer shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idedcfadd3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/15/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit each report described in clause (i) with the appropriate financial report of the swap execution facility that is required to be submitted to the Commission pursuant to this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idedcfadd4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/f/15/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in the report a certification that, under penalty of law, the report is accurate and complete.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedcfadd5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may exempt, conditionally or unconditionally, a swap execution facility from registration under this section if the Commission finds that the facility is subject to comparable, comprehensive supervision and regulation on a consolidated basis by the Securities and Exchange Commission, a prudential regulator, or the appropriate governmental authorities in the home country of the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedcfadd6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–3/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall prescribe rules governing the regulation of alternative swap execution facilities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idedcfadd7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369/s5h"},"text":"Sept. 21, 1922, ch. 369, § 5h","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVII/s733"},"text":"Pub. L. 111–203, title VII, § 733","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1712"},"text":"124 Stat. 1712","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idedcfadd8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idedcfadd9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idedcfadda-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the later of 360 days after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", or, to the extent a provision of subtitle A (§§ 711–754) of title VII of "},{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" requires a rulemaking, not less than 60 days after publication of the final rule or regulation implementing such provision of subtitle A, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s754"},"text":"section 754 of Pub. L. 111–203","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1a"},"text":"section 1a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
