{"tag":"section","attrib":{"id":"idefc933a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5605"},"text":null,"children":[{"tag":"num","attrib":{"value":"5605"},"text":"§ 5605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independence of authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each authority granted under this chapter shall be in addition to, and not in lieu of, any authority granted to the Secretary or the Commodity Credit Corporation under any other provision of law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefc933a6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/tI/s105"},"text":"Pub. L. 95–501, title I, § 105","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1531"},"text":"Pub. L. 101–624, title XV, § 1531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3672"},"text":"104 Stat. 3672","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
