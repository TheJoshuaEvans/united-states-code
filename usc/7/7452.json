{"tag":"section","attrib":{"id":"idf00be244-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7452"},"text":null,"children":[{"tag":"num","attrib":{"value":"7452"},"text":"§ 7452.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf00be245-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7452/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for each fiscal year such sums as are necessary to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00be246-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7452/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated under subsection (a) shall not be available for payment of the expenses or expenditures of the Board in administering a provision of an order issued under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf00be247-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s543"},"text":"Pub. L. 104–127, title V, § 543","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1063"},"text":"110 Stat. 1063","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
