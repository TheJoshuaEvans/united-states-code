{"tag":"section","attrib":{"id":"idef7a779c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2254c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2254c"},"text":"§ 2254c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is appropriated, out of any funds in the Treasury not otherwise appropriated, $20,000,000 for each of fiscal years 2021 and 2022 for the Agricultural Research Service to address gaps in nutrition research at the critical intersections of responsive agriculture, quality food production, and human nutrition and health.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef7a779d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tVII/s756"},"text":"Pub. L. 116–260, div. N, title VII, § 756","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2109"},"text":"134 Stat. 2109","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/158/s4/c"},"text":"Pub. L. 117–158, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-06-25"},"text":"June 25, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1312"},"text":"136 Stat. 1312","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7a779e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef7a779f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef7a77a0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/158"},"text":"Pub. L. 117–158","children":[],"tail":" substituted “for each of fiscal years 2021 and 2022” for “for fiscal year 2021 and each fiscal year thereafter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
