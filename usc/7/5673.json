{"tag":"section","attrib":{"id":"idefcb7e06-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5673"},"text":null,"children":[{"tag":"num","attrib":{"value":"5673"},"text":"§ 5673.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting authority to expand agricultural export markets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefcb7e07-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5673/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may contract with individuals for services to be performed outside the United States as the Secretary determines necessary or appropriate for carrying out programs and activities to maintain, develop, or enhance export markets for United States agricultural commodities and products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcb7e08-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5673/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Not employees of United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Individuals referred to in subsection (a) shall not be regarded as officers or employees of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefcb7e09-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/tIV/s413"},"text":"Pub. L. 95–501, title IV, § 413","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1531"},"text":"Pub. L. 101–624, title XV, § 1531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3685"},"text":"104 Stat. 3685","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
