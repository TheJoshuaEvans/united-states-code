{"tag":"section","attrib":{"id":"idf00be291-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465"},"text":null,"children":[{"tag":"num","attrib":{"value":"7465"},"text":"§ 7465.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required terms in order","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf00be292-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budgets and plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00be293-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7463"},"text":"section 7463 of this title","children":[],"tail":" shall provide for periodic budgets and plans in accordance with this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be294-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budgets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall prepare and submit to the Secretary a budget prior to the beginning of the fiscal year of the anticipated expenses and disbursements of the Board in the administration of the order, including probable costs of research, promotion, and consumer information. A budget shall become effective on a ⅔-vote of a quorum of the Board and approval by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be295-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each budget shall include a plan for research, promotion, and consumer information regarding kiwifruit. A plan under this paragraph shall become effective on approval by the Secretary. The Board may enter into contracts and agreements, on approval by the Secretary, for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00be296-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and carrying out of the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be297-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment of the cost of the plan, with funds collected pursuant to this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00be298-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00be299-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide for the imposition and collection of assessments with regard to the production and importation of kiwifruit in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be29a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The assessment rate shall be the rate that is recommended by a ⅔-vote of a quorum of the Board and approved by the Secretary, except that the rate shall not exceed $0.10 per 7-pound tray of kiwifruit or an equivalent rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be29b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection by first handlers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (5), the first handler of kiwifruit shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00be29c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for the collection from the producer, and payment to the Board, of assessments required under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be29d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a separate record of the kiwifruit of each producer whose kiwifruit are so handled, including the kiwifruit owned by the handler.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be29e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The assessment on imported kiwifruit shall be paid by the importer to the United States Customs Service at the time of entry into the United States and shall be remitted to the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be29f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following persons or activities are exempt from an assessment under this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00be2a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A producer who produces less than 500 pounds of kiwifruit per year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be2a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An importer who imports less than 10,000 pounds of kiwifruit per year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be2a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A sale of kiwifruit made directly from the producer to a consumer for a purpose other than resale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be2a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The production or importation of kiwifruit for processing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be2a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claim of exemption","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To claim an exemption under paragraph (5) for a particular year, a person shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00be2a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit an application to the Board stating the basis for the exemption and certifying that the quantity of kiwifruit produced, imported, or sold by the person will not exceed any poundage limitation required for the exemption in the year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be2a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be on a list of approved processors developed by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00be2a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of assessments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00be2a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The order shall provide that funds paid to the Board as assessments under subsection (b) may be used by the Board—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00be2a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay for research, promotion, and consumer information described in the budget of the Board under subsection (a) and for other expenses incurred by the Board in the administration of an order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be2aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay such other expenses for the administration, maintenance, and functioning of the Board (including any enforcement efforts for the collection of assessments) as may be authorized by the Secretary, including interest and penalties for late payments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be2ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fund a reserve established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7466/d"},"text":"section 7466(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be2ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The order shall provide that funds paid to the Board as assessments under subsection (b) shall be used by the Board—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00be2ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay the expenses incurred by the Secretary, including salaries and expenses of Federal Government employees, in implementing and administering the order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be2ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reimburse the Secretary for any expenses incurred by the Secretary in conducting referenda under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be2af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except for the first year of operation of the Board, expenses for the administration, maintenance, and functioning of the Board may not exceed 30 percent of the budget for a year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00be2b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False claims","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The order shall provide that any promotion funded with assessments collected under subsection (b) may not make—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00be2b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any false claims on behalf of kiwifruit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be2b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any false statements with respect to the attributes or use of any product that competes with kiwifruit for sale in commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00be2b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide that funds collected by the Board under this subchapter through assessments may not, in any manner, be used for the purpose of influencing legislation or governmental policy or action, except for making recommendations to the Secretary as provided for under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00be2b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Books, records, and reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00be2b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The order shall require the Board—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00be2b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain books and records with respect to the receipt and disbursement of funds received by the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be2b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to submit to the Secretary from time to time such reports as the Secretary may require for appropriate accounting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be2b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to submit to the Secretary at the end of each fiscal year a complete audit report by an independent auditor regarding the activities of the Board during the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be2b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Others","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To make information and data available to the Board and the Secretary that is appropriate or necessary for the effectuation, administration, or enforcement of this subchapter (or any order or regulation issued under this subchapter), the order shall require handlers and importers who are responsible for the collection, payment, or remittance of assessments under subsection (b)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00be2ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain and make available for inspection by the employees and agents of the Board and the Secretary such books and records as may be required by the order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be2bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to file, at the times and in the manner and content prescribed by the order, reports regarding the collection, payment, or remittance of the assessments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00be2bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00be2bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall require that all information obtained pursuant to subsection (f)(2) be kept confidential by all officers, employees, and agents of the Department of Agriculture and of the Board. Only such information as the Secretary considers relevant shall be disclosed to the public and only in a suit or administrative hearing, brought at the request of the Secretary or to which the Secretary or any officer of the United States is a party, involving the order with respect to which the information was furnished or acquired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be2be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subsection prohibits—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00be2bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuance of general statements based on the reports of a number of handlers and importers subject to an order, if the statements do not identify the information furnished by any person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00be2c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the publication, by direction of the Secretary, of the name of any person violating an order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7463/a"},"text":"section 7463(a) of this title","children":[],"tail":", together with a statement of the particular provisions of the order violated by the person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be2c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who willfully violates this subsection, on conviction, shall be subject to a fine of not more than $1,000 or to imprisonment for not more than 1 year, or both, and, if the person is a member, officer, or agent of the Board or an employee of the Department of Agriculture, shall be removed from office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00be2c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7465/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter authorizes the withholding of information from Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf00be2c3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s556"},"text":"Pub. L. 104–127, title V, § 556","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1067"},"text":"110 Stat. 1067","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf00be2c4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf00be2c5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idf00be2c6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the United States Customs Service of the Department of the Treasury, including functions of the Secretary of the Treasury relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see sections 203(1), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":". For establishment of U.S. Customs and Border Protection in the Department of Homeland Security, treated as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/114/125"},"text":"Pub. L. 114–125","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/s802/b"},"text":"section 802(b) of Pub. L. 114–125","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
