{"tag":"section","attrib":{"id":"idee1e4354-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s215"},"text":null,"children":[{"tag":"num","attrib":{"value":"215"},"text":"§ 215.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to obey orders; punishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee1e4355-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s215/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any stockyard owner, market agency, or dealer who knowingly fails to obey any order made under the provisions of sections 211, 212, or 213 of this title shall forfeit to the United States the sum of $500 for each offense. Each distinct violation shall be a separate offense, and in case of a continuing violation each day shall be deemed a separate offense. Such forfeiture shall be recoverable in a civil suit in the name of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1e4356-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s215/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It shall be the duty of the various United States attorneys, under the direction of the Attorney General, to prosecute for the recovery of forfeitures. The costs and expense of such prosecution shall be paid out of the appropriation for the expenses of the courts of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee1e4357-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-08-15/ch64"},"text":"Aug. 15, 1921, ch. 64","children":[],"tail":", title III, § 314, "},{"tag":"ref","attrib":{"href":"/us/stat/42/167"},"text":"42 Stat. 167","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s1"},"text":"June 25, 1948, ch. 646, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/909"},"text":"62 Stat. 909","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee1e4358-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee1e4359-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idee1e435a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":", substituted “United States attorneys” for “district attorneys” in subsec. (a). See "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s541"},"text":"section 541 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, and Historical and Revision Notes thereunder."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
