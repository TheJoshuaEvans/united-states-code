{"tag":"section","attrib":{"id":"idefa5580a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243"},"text":null,"children":[{"tag":"num","attrib":{"value":"3243"},"text":"§ 3243.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hispanic-serving agricultural colleges and universities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa5580b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of endowment fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “endowment fund” means the Hispanic-Serving Agricultural Colleges and Universities Fund established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa5580c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Endowment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa5580d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall establish in accordance with this subsection a Hispanic-Serving Agricultural Colleges and Universities Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa5580e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury may enter into such agreements as are necessary to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa5580f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit to the endowment fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall deposit in the endowment fund any—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa55810-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts made available through Acts of appropriations, which shall be the endowment fund corpus; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa55811-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest earned on the endowment fund corpus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa55812-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall invest the endowment fund corpus and income in interest-bearing obligations of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa55813-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawals and expenditures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa55814-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corpus","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury may not make a withdrawal or expenditure from the endowment fund corpus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa55815-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On ","children":[{"tag":"date","attrib":{"date":"2008-09-30"},"text":"September 30, 2008","children":[],"tail":", and each September 30 thereafter, the Secretary of the Treasury shall withdraw the amount of the income from the endowment fund for the fiscal year and warrant the funds to the Secretary of Agriculture who, after making adjustments for the cost of administering the endowment fund, shall distribute the adjusted income as follows:"}],"tail":null},{"tag":"clause","attrib":{"id":"idefa55816-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 60 percent shall be distributed among the Hispanic-serving agricultural colleges and universities on a pro rata basis based on the Hispanic enrollment count of each institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefa55817-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 40 percent shall be distributed in equal shares to the Hispanic-serving agricultural colleges and universities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa55818-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Endowments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available under this subsection shall be held and considered to be granted to Hispanic-serving agricultural colleges and universities to establish an endowment in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa55819-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary such sums as are necessary to carry out this subsection for fiscal year 2008 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa5581a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for annual payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa5581b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For fiscal year 2008 and each fiscal year thereafter, there are authorized to be appropriated to the Department of Agriculture to carry out this subsection an amount equal to the product obtained by multiplying—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa5581c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $80,000; by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa5581d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of Hispanic-serving agricultural colleges and universities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa5581e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For fiscal year 2008 and each fiscal year thereafter, the Secretary of the Treasury shall pay to the treasurer of each Hispanic-serving agricultural college and university an amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa5581f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount made available by appropriations under paragraph (1); divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa55820-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of Hispanic-serving agricultural colleges and universities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa55821-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa55822-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts authorized to be appropriated under this subsection shall be used in the same manner as is prescribed for colleges under the Act of ","children":[{"tag":"date","attrib":{"date":"1890-08-30"},"text":"August 30, 1890","children":[],"tail":" (commonly known as the “Second Morrill Act”) ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s321"},"text":"7 U.S.C. 321","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa55823-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subsection, the requirements of that Act shall apply to Hispanic-serving agricultural colleges and universities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa55824-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutional capacity-building grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa55825-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For fiscal year 2008 and each fiscal year thereafter, the Secretary shall make grants to assist Hispanic-serving agricultural colleges and universities in institutional capacity building (not including alteration, repair, renovation, or construction of buildings).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa55826-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for institutional capacity-building grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa55827-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make grants under this subsection on the basis of a competitive application process under which Hispanic-serving agricultural colleges and universities may submit applications to the Secretary at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa55828-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration of need","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefa55829-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of an application for a grant under this subsection, the Secretary shall require the applicant to demonstrate need for the grant, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefa5582a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other sources of funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award a grant under this subsection only to an applicant that demonstrates a failure to obtain funding for a project after making a reasonable effort to otherwise obtain the funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa5582b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under this subsection shall be made only if the recipient of the grant pays a non-Federal share in an amount that is specified by the Secretary and based on assessed institutional needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa5582c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary such sums as are necessary to carry out this subsection for fiscal year 2008 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa5582d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa5582e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a competitive grants program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa5582f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fund fundamental and applied research and extension at Hispanic-serving agricultural colleges and universities in agriculture, human nutrition, food science, bioenergy, and environmental science; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa55830-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to award competitive grants to Hispanic-serving agricultural colleges and universities to provide for training in the food and agricultural sciences of Hispanic agricultural workers and Hispanic youth working in the food and agricultural sciences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa55831-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3243/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary such sums as are necessary to carry out this subsection for fiscal year 2008 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa55832-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[