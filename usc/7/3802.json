{"tag":"section","attrib":{"id":"idefb13e9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3802"},"text":null,"children":[{"tag":"num","attrib":{"value":"3802"},"text":"§ 3802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefb13e9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3802/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb13e9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3802/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “garbage” means all waste material derived in whole or in part from the meat of any animal (including fish and poultry) or other animal material, and other refuse of any character whatsoever that has been associated with any such material, resulting from the handling, preparation, cooking, or consumption of food, except that such term shall not include waste from ordinary household operations which is fed directly to swine on the same premises where such household is located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb13ea0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3802/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “person” means any individual, corporation, company, association, firm, partnership, society, or joint stock company or other legal entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb13ea1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3802/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means the fifty States, the District of Columbia, Guam, Puerto Rico, the Virgin Islands of the United States, American Samoa, the Commonwealth of the Northern Mariana Islands, and the territories and possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefb13ea2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/468/s3"},"text":"Pub. L. 96–468, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2229"},"text":"94 Stat. 2229","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/592/tV/s511"},"text":"Pub. L. 96–592, title V, § 511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3451"},"text":"94 Stat. 3451","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefb13ea3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefb13ea4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefb13ea5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/592"},"text":"Pub. L. 96–592","children":[],"tail":" added par. (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
