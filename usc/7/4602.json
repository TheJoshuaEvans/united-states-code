{"tag":"section","attrib":{"id":"idefbadb81-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602"},"text":null,"children":[{"tag":"num","attrib":{"value":"4602"},"text":"§ 4602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbadb82-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Committee” means the National Honey Nominations Committee provided for under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4606/b"},"text":"section 4606(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadb83-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “consumer education” means any action to provide information on the usage and care of honey or honey products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadb84-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Department","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Department” means the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadb85-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “exporter” means any person who exports honey or honey products from the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadb86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Handle.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbadb87-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “handle” means to process, package, sell, transport, purchase, or in any other way place or cause to be placed in commerce, honey or a honey product.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbadb88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “handle” includes selling unprocessed honey that will be consumed or used without further processing or packaging.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbadb89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “handle” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefbadb8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transportation of unprocessed honey by a producer to a handler;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefbadb8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transportation by a commercial carrier of honey, whether processed or unprocessed, for a handler or producer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefbadb8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/5/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase of honey or a honey product by a consumer or other end-user of the honey or honey product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadb8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “handler” means any person who handles honey.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadb8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “honey” means the nectar and saccharine exudations of plants which are gathered, modified, and stored in the comb by honey bees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadb8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Honey Board” means the board provided for under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4606/c"},"text":"section 4606(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadb90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Honey production","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “honey production” means all beekeeping operations related to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbadb91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" managing honey bee colonies to produce honey;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbadb92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" harvesting honey from the colonies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbadb93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extracting honey from the honeycombs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbadb94-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparing honey for sale for further processing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadb95-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “honey products” means products produced, in whole or part, from honey.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadb96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “importer” means any person who imports honey or honey products into the United States or acts as an agent, broker, or consignee for any person or nation that produces honey outside of the United States for sale in the United States and who is listed in the import records as the importer of record for such honey or honey products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadb97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Industry information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “industry information” means information or a program that will lead to the development of new markets, new marketing strategies, or increased efficiency for the honey industry, or an activity to enhance the image of honey and honey products and of the honey industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadb98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “marketing” means the sale or other disposition in commerce of honey or honey products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadb99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National honey marketing cooperative","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “national honey marketing cooperative” means a cooperative that markets its products in at least 2 of the following 4 regions of the United States, as determined by the Secretary:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbadb9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Atlantic Coast, including the District of Columbia and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbadb9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Mideast.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbadb9c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/14/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Midwest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbadb9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/14/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Pacific, including the States of Alaska and Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadb9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” means any individual, group of individuals, partnership, corporation, association, cooperative, or any other entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadb9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “producer” means any person who produces honey in the United States for sale in commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadba0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “producer-packer” means any person who is both a producer and handler of honey.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadba1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “promotion” means any action, including paid advertising, pursuant to this chapter, to present a favorable image for honey or honey products to the public with the express intent of improving the competitive position and stimulating sales of honey or honey products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadba2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified national organization representing handler interests","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “qualified national organization representing handler interests” means an organization that the Secretary certifies as being eligible to recommend nominations for the Committee handler, handler-importer, alternate handler, and alternate handler-importer members of the Honey Board under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4606/b"},"text":"section 4606(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadba3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified national organization representing importer interests","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “qualified national organization representing importer interests” means an organization that the Secretary certifies as being eligible to recommend nominations for the Committee importer, handler-importer, alternate importer, and alternate handler-importer members of the Honey Board under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4606/b"},"text":"section 4606(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadba4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “research” means any type of research designed to advance the image, desirability, usage, marketability, production, or quality of honey or honey products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadba5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadba6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"(23)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means any of the several States, the District of Columbia and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbadba7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4602/24"},"text":null,"children":[{"tag":"num","attrib":{"value":"24"},"text":"(24)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State association” means that organization of beekeepers in a State which is generally recognized as representing the beekeepers of that State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefbadba8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/590/s3"},"text":"Pub. L. 98–590, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3116"},"text":"98 Stat. 3116","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1982"},"text":"Pub. L. 101–624, title XIX, § 1982","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3904"},"text":"104 Stat. 3904","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tVI/s605/b"},"text":"Pub. L. 105–185, title VI, § 605(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/588"},"text":"112 Stat. 588","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefbadba9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefbadbaa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefbadbab-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Pars. (1) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s605/b/3"},"text":"Pub. L. 105–185, § 605(b)(3)","children":[],"tail":", redesignated pars. (14), (12), (19), (18), and (7) as (1) to (5), respectively. Former pars. (1) to (5) redesignated (7), (10), (22), (15), and (16), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s605/b/3"},"text":"Pub. L. 105–185, § 605(b)(3)","children":[],"tail":", redesignated par. (1) as (7). Former par. (7) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s605/b/1"},"text":"Pub. L. 105–185, § 605(b)(1)","children":[],"tail":", added par. (7) and struck out former par. (7) which read as follows: “The term ‘handle’ means to sell, package, or process honey.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (8) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s605/b/3"},"text":"Pub. L. 105–185, § 605(b)(3)","children":[],"tail":", redesignated pars. (15), (20), (2), (8), and (21) as (8) to (12), respectively. Former pars. (8) to (12) redesignated (11), (17), (18), (21), and (2), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (14) to (18). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s605/b/3"},"text":"Pub. L. 105–185, § 605(b)(3)","children":[],"tail":", redesignated pars. (22), (4), (5), (9), and (10) as (14) to (18), respectively. Former pars. (14) to (18) redesignated (1), (8), (24), (23), and (4), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (19) to (24). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s605/b/3"},"text":"Pub. L. 105–185, § 605(b)(3)","children":[],"tail":", redesignated pars. (23), (24), (11), (3), (17), and (16) as (19) to (24), respectively. Former pars. (19) to (24) redesignated (3), (9), (12), (14), (19), and (20), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s605/b/2"},"text":"Pub. L. 105–185, § 605(b)(2)","children":[],"tail":", added pars. (19) to (24)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1982/1"},"text":"Pub. L. 101–624, § 1982(1)","children":[],"tail":", substituted “or acts” for “or who acts”, and inserted before period at end “and who is listed in the import records as the importer of record for such honey or honey products”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (18). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1982/2"},"text":"Pub. L. 101–624, § 1982(2)","children":[],"tail":", added par. (18)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
