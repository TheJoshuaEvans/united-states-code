{"tag":"section","attrib":{"id":"ideee90c77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1721"},"text":null,"children":[{"tag":"num","attrib":{"value":"1721"},"text":"§ 1721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President shall establish a program under this subchapter (to be implemented by the Administrator) to provide agricultural commodities to foreign countries on behalf of the people of the United States to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee90c78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1721/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address famine and food crises, and respond to emergency food needs, arising from man-made and natural disasters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee90c79-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1721/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" combat malnutrition, especially in children and mothers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee90c7a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1721/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out activities that attempt to alleviate the causes of hunger, mortality and morbidity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee90c7b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1721/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote economic and community development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee90c7c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1721/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote food security and support sound environmental practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee90c7d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1721/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out feeding programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee90c7e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1721/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" build resilience to mitigate and prevent food crises and reduce the future need for emergency aid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideee90c7f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title II, § 201, "},{"tag":"ref","attrib":{"href":"/us/stat/68/457"},"text":"68 Stat. 457","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-05-28/ch327"},"text":"May 28, 1956, ch. 327","children":[],"tail":", title II, § 208(b), "},{"tag":"ref","attrib":{"href":"/us/stat/70/201"},"text":"70 Stat. 201","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-03/ch933/s4"},"text":"Aug. 3, 1956, ch. 933, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/988"},"text":"70 Stat. 988","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/808/s2/C"},"text":"Pub. L. 89–808, § 2(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-11"},"text":"Nov. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1534"},"text":"80 Stat. 1534","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/161/tII/s208"},"text":"Pub. L. 94–161, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-20"},"text":"Dec. 20, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/853"},"text":"89 Stat. 853","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/88/tII/s206"},"text":"Pub. L. 95–88, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/547"},"text":"91 Stat. 547","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/113/tIV/s404"},"text":"Pub. L. 97–113, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1538"},"text":"95 Stat. 1538","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/tX/s1002"},"text":"Pub. L. 99–83, title X, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-08"},"text":"Aug. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/270"},"text":"99 Stat. 270","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXI"},"text":"Pub. L. 99–198, title XI","children":[],"tail":", §§ 1102, 1103, "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1465"},"text":"99 Stat. 1465","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3636"},"text":"104 Stat. 3636","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3007"},"text":"Pub. L. 110–246, title III, § 3007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1823"},"text":"122 Stat. 1823","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIII/s3001"},"text":"Pub. L. 113–79, title III, § 3001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/772"},"text":"128 Stat. 772","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideee90c80-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideee90c81-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideee90c82-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" inserted “(to be implemented by the Administrator)” after “under this subchapter” in introductory provisions and struck out concluding provisions which read as follows: “Such program shall be implemented by the Administrator.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3001/2"},"text":"Pub. L. 113–79, § 3001(2)","children":[],"tail":", added par. (7) and struck out former par. (7). Prior to amendment, par. (7) read as follows: “promote economic and nutritional security by increasing educational, training, and other productive activities.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3007/1"},"text":"Pub. L. 110–246, § 3007(1)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “address famine or other urgent or extraordinary relief requirements;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3007/2/A"},"text":"Pub. L. 110–246, § 3007(2)(A)","children":[],"tail":", inserted “food security and support” after “promote”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3007/2/B"},"text":"Pub. L. 110–246, § 3007(2)(B)","children":[],"tail":"–(4), added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" amended section generally, substituting present provisions for provisions requiring President to furnish commodities to meet famine, combat malnutrition, promote economic development in friendly countries, and for needy persons and school lunch and preschool feeding programs, setting minimum quantity for distribution, requiring use of certain distribution networks, requiring President to consider benefits of distributing processed and protein-fortified foods, nutritional needs of recipients, cost effectiveness of particular commodities, and purposes of this subchapter, requiring that 75 percent of commodities distributed be in form of processed or fortified products or bagged commodities, and authorizing waiver of such 75 percent requirement."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1102"},"text":"Pub. L. 99–198, § 1102","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “The minimum quantity of agricultural commodities distributed under this subchapter—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) for fiscal years 1978 through 1980 shall be 1,600,000 metric tons, of which not less than 1,300,000 metric tons shall be distributed through nonprofit voluntary agencies and the World Food Program;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) for fiscal year 1981 shall be 1,650,000 metric tons, of which not less than 1,350,000 metric tons shall be distributed through nonprofit voluntary agencies and the World Food Program; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) for fiscal year 1982 and each fiscal year thereafter shall be 1,700,000 metric tons, of which not less than 1,200,000 metric tons for nonemergency programs shall be distributed through nonprofit voluntary agencies and the World Food Program, except that for fiscal year 1986 the minimum quantity distributed shall be 1,800,000 metric tons, of which not less than 1,300,000 metric tons for nonemergency programs shall be distributed through nonprofit voluntary agencies and the World Food Program, and for fiscal year 1987 the minimum quantity distributed shall be 1,900,000 metric tons, of which not less than 1,425,000 metric tons for nonemergency programs shall be distributed through nonprofit voluntary agencies and the World Food Program;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"unless the President determines and reports to the Congress, together with his reasons, that such quantity cannot be used effectively to carry out the purposes of this subchapter: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That such minimum quantity shall not exceed the total quantity of commodities determined to be available for disposition under this chapter pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1731"},"text":"section 1731 of this title","children":[],"tail":", less the quantity of commodities required to meet famine or other urgent or extraordinary relief requirements.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83"},"text":"Pub. L. 99–83","children":[],"tail":" inserted provisions relating to minimum quantities for fiscal years 1986 and 1987."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1103"},"text":"Pub. L. 99–198, § 1103","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/113"},"text":"Pub. L. 97–113","children":[],"tail":" substituted “1,200,000 metric tons for nonemergency programs” for “1,400,000 metric tons”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/88"},"text":"Pub. L. 95–88","children":[],"tail":" substituted provisions increasing and setting specific minimums for commodities to be distributed for fiscal years 1978 through 1980, for 1981, and for fiscal year 1982 and each fiscal year thereafter, for provisions which had set a fixed minimum of 1,300,000 tons of agricultural commodities each fiscal year, of which the minimum to be distributed through nonprofit voluntary agencies and the World Food Program was 1,000,000 tons each fiscal year."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/161"},"text":"Pub. L. 94–161","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/808"},"text":"Pub. L. 89–808","children":[],"tail":" expanded scope of assistance to include emergency relief without regard to recipient being a friendly people, combating malnutrition in children, promotion of economic and community development in friendly developing areas, and for nonprofit school lunch and preschool feeding programs outside the United States and to be furnished from available commodities rather than surplus agricultural commodities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Act ","children":[{"tag":"date","attrib":{"date":"1956-08-03"},"text":"Aug. 3, 1956","children":[],"tail":", inserted “or extraordinary” after “urgent” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1956-05-28"},"text":"May 28, 1956","children":[],"tail":", struck out “f.o.b. vessels in United States ports,” before “as he may request”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideee90c83-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideee90c84-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/b"},"text":"section 4(b) of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideee90c85-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1991-01-01"},"text":"Jan. 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1513"},"text":"section 1513 of Pub. L. 101–624","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideee90c86-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83"},"text":"Pub. L. 99–83","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/s1301"},"text":"section 1301 of Pub. L. 99–83","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151–1"},"text":"section 2151–1 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideee90c87-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/88"},"text":"Pub. L. 95–88","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/88/s215"},"text":"section 215 of Pub. L. 95–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1702"},"text":"section 1702 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideee90c88-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1966 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/808"},"text":"Pub. L. 89–808","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1967-01-01"},"text":"Jan. 1, 1967","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/89/808/s5"},"text":"section 5 of Pub. L. 89–808","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideee90c89-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Nonemergency Food Assistance Programs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/385/tII/s201"},"text":"Pub. L. 105–385, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3465"},"text":"112 Stat. 3465","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3001/b/1/A"},"text":"Pub. L. 110–246, title III, § 3001(b)(1)(A)","children":[],"tail":", (2)(D), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1820"},"text":"122 Stat. 1820","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/246/tIII/s3001/b/1/A"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing nonemergency assistance under title II of the Food for Peace Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1721"},"text":"7 U.S.C. 1721","children":[],"tail":" et seq.), the Administrator of the United States Agency for International Development shall ensure that—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in planning, decisionmaking, and implementation in providing such assistance, the Administrator takes into consideration local input and participation directly and through United States and indigenous private and voluntary organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of the nonemergency activities described in paragraphs (2) through (6) of section 201 of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1721"},"text":"7 U.S.C. 1721","children":[],"tail":"), including programs that provide assistance to people of any age group who are otherwise unable to meet their basic food needs (including feeding programs for the disabled, orphaned, elderly, sick and dying), are carried out; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" greater flexibility is provided for program and evaluation plans so that such assistance may be developed to meet local needs, as provided for in section 202(f) of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1722/f"},"text":"7 U.S.C. 1722(f)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In providing assistance under the Food for Peace Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"7 U.S.C. 1691","children":[],"tail":" et seq.], the Secretary of Agriculture and the Administrator of United States Agency for International Development shall ensure that commodities are provided in a manner that is consistent with sections 403(a) and (b) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1733/a"},"text":"7 U.S.C. 1733(a)","children":[],"tail":" and (b)).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[Section 3001(b)(1)(A), (2)(D) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", which directed amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/105/385/s201"},"text":"section 201 of Pub. L. 105–385","children":[],"tail":", set out above, by substituting “Food for Peace Act” for “Agricultural Trade Development and Assistance Act of 1954”, was executed in subsec. (b) by making the substitution for “Agriculture Trade Development and Assistance Act of 1954”, to reflect the probable intent of Congress.]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideee90c8a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization for Commodity Credit Corporation To Purchase and Donate Flour and Cornmeal","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/683"},"text":"Pub. L. 85–683","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-19"},"text":"Aug. 19, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/635"},"text":"72 Stat. 635","children":[],"tail":", as authorizing Commodity Credit Corporation to purchase and donate flour and cornmeal when it has wheat or corn available for donation pursuant to this subchapter, see note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1431"},"text":"section 1431 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ideee90c8b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideee90c8c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation of Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Program under this subchapter to provide for donation of agricultural commodities to foreign countries to be implemented by Administrator of the Agency for International Development, see Ex. Ord. No. 12752, § 1(b), ","children":[{"tag":"date","attrib":{"date":"1991-02-25"},"text":"Feb. 25, 1991","children":[],"tail":", 56 F.R. 8255, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
