{"tag":"section","attrib":{"id":"ideed388fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1605"},"text":null,"children":[{"tag":"num","attrib":{"value":"1605"},"text":"§ 1605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideed388fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is authorized to be appropriated, out of any money in the Treasury not otherwise appropriated, such sums as may be necessary for administering this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideed388fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds appropriated for carrying into effect the purpose of this chapter shall be available for allotment by the Secretary of Agriculture to the bureaus and offices of the Department of Agriculture and for transfer to other departments and agencies of the Government which the Secretary of Agriculture may call upon to assist or cooperate in carrying out such purposes or for services rendered or to be rendered in connection therewith.","children":[{"tag":"p","attrib":{},"text":"Appropriations made under this authorization, within the limit prescribed in such appropriations, may be expended for the share of the United States in the expense of the International Seed Testing Congress in carrying out plans for correlating the work of the various adhering governments on problems relating to seed analyses or other subjects which the Congress may determine to be necessary in the interest of international seed trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideed388ff-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-09/ch615"},"text":"Aug. 9, 1939, ch. 615","children":[],"tail":", title IV, § 415, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1289"},"text":"53 Stat. 1289","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1944-09-21/ch412"},"text":"Sept. 21, 1944, ch. 412","children":[],"tail":", title VII, § 701(b), "},{"tag":"ref","attrib":{"href":"/us/stat/58/741"},"text":"58 Stat. 741","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideed38900-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideed38901-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideed38902-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1944—Act ","children":[{"tag":"date","attrib":{"date":"1944-09-21"},"text":"Sept. 21, 1944","children":[],"tail":", added last par."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideed38903-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideed38904-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1610"},"text":"section 1610 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
