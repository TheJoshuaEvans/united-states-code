{"tag":"section","attrib":{"id":"idf0026c97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7286"},"text":null,"children":[{"tag":"num","attrib":{"value":"7286"},"text":"§ 7286.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodity certificates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0026c98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7286/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making in-kind payments under subchapter III of this chapter, title I of the Farm Security and Rural Investment Act of 2002 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7901"},"text":"7 U.S.C. 7901","children":[],"tail":" et seq.], title I of the Food, Conservation, and Energy Act of 2008 ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"7 U.S.C. 8701","children":[],"tail":" et seq.], and Subtitle "},{"tag":"ref","attrib":{"idref":"fn002335"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002335"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" B of title I of the Agricultural Act of 2014 ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9031"},"text":"7 U.S.C. 9031","children":[],"tail":" et seq.], the Commodity Credit Corporation may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0026c99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7286/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire and use commodities that have been pledged to the Commodity Credit Corporation as collateral for loans made by the Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0026c9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7286/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use other commodities owned by the Commodity Credit Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0026c9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7286/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" redeem negotiable marketing certificates for cash under terms and conditions established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0026c9c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7286/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methods of payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commodity Credit Corporation may make in-kind payments—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0026c9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7286/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by delivery of the commodity at a warehouse or other similar facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0026c9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7286/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the transfer of negotiable warehouse receipts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0026c9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7286/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the issuance of negotiable certificates, which the Commodity Credit Corporation shall exchange for a commodity owned or controlled by the Corporation in accordance with regulations promulgated by the Corporation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0026ca0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7286/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by such other methods as the Commodity Credit Corporation determines appropriate to promote the efficient, equitable, and expeditious receipt of the in-kind payments so that a person receiving the payments receives the same total return as if the payments had been made in cash.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0026ca1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7286/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0026ca2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7286/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the option of a producer, the Commodity Credit Corporation shall make negotiable certificates authorized under subsection (b)(3) available to the producer, in the form of program payments or by sale, in a manner that the Corporation determines will encourage the orderly marketing of commodities pledged as collateral for loans made to producers under subchapter III of this chapter, title I of the Farm Security and Rural Investment Act of 2002 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7901"},"text":"7 U.S.C. 7901","children":[],"tail":" et seq.], title I of the Food, Conservation, and Energy Act of 2008 ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"7 U.S.C. 8701","children":[],"tail":" et seq.], and Subtitle "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" B of title I of the Agricultural Act of 2014 ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9031"},"text":"7 U.S.C. 9031","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0026ca3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7286/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A negotiable certificate issued in accordance with this subsection may be transferred to another person in accordance with regulations promulgated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0026ca4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7286/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning with the 2015 crop marketing year, the Secretary shall carry out paragraph (1) under the same terms and conditions as were in effect for the 2008 crop year for loans made to producers under subtitle B [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8731"},"text":"7 U.S.C. 8731","children":[],"tail":" et seq.] of title I of the Food, Conservation, and Energy Act of 2008 ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"7 U.S.C. 8701","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0026ca5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s166"},"text":"Pub. L. 104–127, title I, § 166","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tVIII/s812"},"text":"Pub. L. 106–78, title VIII, § 812","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1181"},"text":"113 Stat. 1181","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1608"},"text":"Pub. L. 107–171, title I, § 1608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/218"},"text":"116 Stat. 218","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1607"},"text":"Pub. L. 110–234, title I, § 1607","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1018"},"text":"122 Stat. 1018","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1607, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1746, "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dA/tVII/s740"},"text":"Pub. L. 114–113, div. A, title VII, § 740","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2281"},"text":"129 Stat. 2281","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0026ca6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0026ca7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf0026ca8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Farm Security and Rural Investment Act of 2002, referred to in subsecs. (a) and (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/134"},"text":"116 Stat. 134","children":[],"tail":". Title I of the Act is classified principally to chapter 106 (§ 7901 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7901"},"text":"section 7901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Food, Conservation, and Energy Act of 2008, referred to in subsecs. (a) and (c)(1), (3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1651"},"text":"122 Stat. 1651","children":[],"tail":". Title I of the Act is classified principally to chapter 113 (§ 8701 et seq.) of this title. Subtitle B of title I of the Act is classified generally to subchapter II (§ 8731 et seq.) of chapter 113 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Agricultural Act of 2014, referred to in subsecs. (a) and (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/649"},"text":"128 Stat. 649","children":[],"tail":". Title I of the Act is classified principally to chapter 115 (§ 9001 et seq.) of this title. Subtitle B of title I of the Act is classified generally to subchapter II (§ 9031 et seq.) of chapter 115 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf0026ca9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf0026caa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsecs. (a), (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s740/1"},"text":"Pub. L. 114–113, § 740(1)","children":[],"tail":", substituted “title I of the Food, Conservation, and Energy Act of 2008, and Subtitle B of title I of the Agricultural Act of 2014” for “and title I of the Food, Conservation, and Energy Act of 2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s740/2"},"text":"Pub. L. 114–113, § 740(2)","children":[],"tail":", amended par. (3) generally. Prior to amendment, text read as follows: “The authority to carry out paragraph (1) terminates effective ending with the 2009 crop year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsecs. (a), (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1607/1"},"text":"Pub. L. 110–246, § 1607(1)","children":[],"tail":", substituted “, title I of the Farm Security and Rural Investment Act of 2002, and title I of the Food, Conservation, and Energy Act of 2008” for “and subtitle B and C of title I of the Farm Security and Rural Investment Act of 2002”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1607/2"},"text":"Pub. L. 110–246, § 1607(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsecs. (a), (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" substituted “subchapter III of this chapter and subtitle B and C of title I of the Farm Security and Rural Investment Act of 2002” for “subchapter III of this chapter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf0026cab-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf0026cac-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
