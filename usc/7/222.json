{"tag":"section","attrib":{"id":"idee1e4398-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s222"},"text":null,"children":[{"tag":"num","attrib":{"value":"222"},"text":"§ 222.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Trade Commission powers adopted for enforcement of chapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the efficient execution of the provisions of this chapter, and in order to provide information for the use of Congress, the provisions (including penalties) of sections 46 and 48 to 50 of title 15, are made applicable to the jurisdiction, powers, and duties of the Secretary in enforcing the provisions of this chapter and to any person subject to the provisions of this chapter, whether or not a corporation. The Secretary, in person or by such agents as he may designate, may prosecute any inquiry necessary to his duties under this chapter in any part of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee1e4399-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-08-15/ch64"},"text":"Aug. 15, 1921, ch. 64","children":[],"tail":", title IV, § 402, "},{"tag":"ref","attrib":{"href":"/us/stat/42/168"},"text":"42 Stat. 168","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1921-08-15/ch64"},"text":"Aug. 15, 1921, ch. 64","children":[],"tail":", title V, § 503, as added "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch532"},"text":"Aug. 14, 1935, ch. 532","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/649"},"text":"49 Stat. 649","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee1e439a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee1e439b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee1e439c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1935—Act ","children":[{"tag":"date","attrib":{"date":"1921-08-15"},"text":"Aug. 15, 1921","children":[],"tail":", § 503, as added "},{"tag":"date","attrib":{"date":"1935-08-14"},"text":"Aug. 14, 1935","children":[],"tail":", purported to insert “or any live poultry dealer or handler” after “packer” but word “packer” does not appear in this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idee1e439d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idee1e439e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Executive and administrative functions of Federal Trade Commission, with certain reservations, transferred to Chairman of such Commission by 1950 Reorg. Plan No. 8, § 1, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3175, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1264"},"text":"64 Stat. 1264","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
