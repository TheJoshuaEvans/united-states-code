{"tag":"section","attrib":{"id":"ideeb48f54-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1472"},"text":null,"children":[{"tag":"num","attrib":{"value":"1472"},"text":"§ 1472.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for livestock producers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideeb48f55-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1472/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of livestock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “livestock” includes elk, reindeer, bison, horses, and deer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeb48f56-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1472/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In such amounts as are provided in advance in appropriation Acts, the Secretary of Agriculture may provide assistance to dairy and other livestock producers to cover economic losses incurred by such producers in connection with the production of livestock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeb48f57-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1472/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The assistance provided to livestock producers may be in the following forms:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeb48f58-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1472/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indemnity payments to livestock producers who incur livestock mortality losses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f59-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1472/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Livestock feed assistance to livestock producers affected by shortages of feed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f5a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1472/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compensation for sudden increases in production costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f5b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1472/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other assistance, and for such other economic losses, as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeb48f5c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1472/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not use the funds of the Commodity Credit Corporation to provide assistance under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeb48f5d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1472/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideeb48f5e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10104"},"text":"Pub. L. 107–171, title X, § 10104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/488"},"text":"116 Stat. 488","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dA/tVII/s785/b/2"},"text":"Pub. L. 108–447, div. A, title VII, § 785(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2850"},"text":"118 Stat. 2850","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/97/tVII/s784/b/3"},"text":"Pub. L. 109–97, title VII, § 784(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-10"},"text":"Nov. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2162"},"text":"119 Stat. 2162","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideeb48f5f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideeb48f60-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideeb48f61-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Farm Security and Rural Investment Act of 2002, and not as part of the Emergency Livestock Feed Assistance Act of 1988 which comprises this subchapter or as part of the Agricultural Act of 1949 which is classified principally to this chapter. For complete classification of the 1949 Act to the Code, see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideeb48f62-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/97"},"text":"Pub. L. 109–97","children":[],"tail":" substituted “bison, horses, and deer” for “and bison”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":" added subsec. (a) and redesignated former subsecs. (a) to (d) as (b) to (e), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideeb48f63-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideeb48f64-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/97"},"text":"Pub. L. 109–97","children":[],"tail":" applicable to losses resulting from a disaster that occurs on or after "},{"tag":"date","attrib":{"date":"2005-07-28"},"text":"July 28, 2005","children":[],"tail":", and inapplicable to losses resulting from a disaster that occurs before such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/97/s784/c"},"text":"section 784(c) of Pub. L. 109–97","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1471"},"text":"section 1471 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
