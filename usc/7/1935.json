{"tag":"section","attrib":{"id":"idef0f329b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935"},"text":null,"children":[{"tag":"num","attrib":{"value":"1935"},"text":"§ 1935.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Down payment loan program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef0f329c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef0f329d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other section of this subchapter, the Secretary shall establish, within the farm ownership loan program established under this subchapter, a program under which loans shall be made under this section to eligible farmers or ranchers for down payments on farm ownership loans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f329e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall be the primary coordinator of credit supervision for the down payment loan program established under this section, in consultation with the commercial or cooperative lender and, if applicable, the contracting credit counseling service selected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2006b/c"},"text":"section 2006b(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0f329f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan terms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef0f32a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each loan made under this section shall be in an amount that does not exceed 45 percent of the least of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef0f32a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase price of the farm or ranch to be acquired;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0f32a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appraised value of the farm or ranch to be acquired; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0f32a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $667,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f32a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The interest rate on any loan made by the Secretary under this section shall be a rate equal to the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef0f32a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the difference obtained by subtracting 4 percent from the interest rate for farm ownership loans under this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0f32a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1.5 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f32a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each loan under this section shall be made for a period of 20 years or less, at the option of the borrower.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f32a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each borrower of a loan under this section shall repay the loan to the Secretary in equal annual installments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f32a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nature of retained security interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall retain an interest in each farm or ranch acquired with a loan made under this section that shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef0f32aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be secured by the farm or ranch;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0f32ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be junior only to such interests in the farm or ranch as may be conveyed at the time of acquisition to the person (including a lender) from whom the borrower obtained a loan used to acquire the farm or ranch; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0f32ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the borrower to obtain the permission of the Secretary before the borrower may grant an additional security interest in the farm or ranch.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0f32ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef0f32ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Borrowers required to make minimum down payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not make a loan under this section to any borrower with respect to a farm or ranch if the contribution of the borrower to the down payment on the farm or ranch will be less than 5 percent of the purchase price of the farm or ranch.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f32af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited types of financing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not make a loan under this section with respect to a farm or ranch if the farm or ranch is to be acquired with other financing that contains any of the following conditions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef0f32b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The financing is to be amortized over a period of less than 30 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0f32b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A balloon payment will be due on the financing during the 20-year period beginning on the date the loan is to be made by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0f32b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall, to the maximum extent practicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef0f32b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the transfer of farms and ranches from retiring farmers and ranchers to persons eligible for insured loans under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f32b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make efforts to widely publicize the availability of loans under this section among—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef0f32b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potentially eligible farmers or ranchers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0f32b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retiring farmers and ranchers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0f32b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicants for farm ownership loans under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f32b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage retiring farmers and ranchers to assist in the sale of their farms and ranches to eligible farmers or ranchers by providing seller financing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f32b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordinate the loan program established by this section with State programs that provide farm ownership or operating loans for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef0f32ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning farmers or ranchers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0f32bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" socially disadvantaged farmers or ranchers, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2003/e"},"text":"section 2003(e) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0f32bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veteran farmers or ranchers, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279/a"},"text":"section 2279(a) of this title","children":[],"tail":"; and; and "},{"tag":"ref","attrib":{"idref":"fn002213"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002213"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f32bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish annual performance goals to promote the use of the down payment loan program and other joint financing arrangements as the preferred choice for direct real estate loans made by any lender to an eligible farmer or rancher.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0f32be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible farmer or rancher","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible farmer or rancher” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef0f32bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a qualified beginning farmer or rancher;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f32c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a socially disadvantaged farmer or rancher, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2003/e"},"text":"section 2003(e) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f32c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1935/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a veteran farmer or rancher, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279/a"},"text":"section 2279(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef0f32c2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s310E"},"text":"Pub. L. 87–128, title III, § 310E","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/554/s7/a"},"text":"Pub. L. 102–554, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4144"},"text":"106 Stat. 4144","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tV/s5005"},"text":"Pub. L. 107–171, title V, § 5005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/342"},"text":"116 Stat. 342","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tV/s5004"},"text":"Pub. L. 110–234, title V, § 5004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1144"},"text":"122 Stat. 1144","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title V, § 5004, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1905; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tV/s5005"},"text":"Pub. L. 113–79, title V, § 5005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/834"},"text":"128 Stat. 834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12306/c"},"text":"Pub. L. 115–334, title XII, § 12306(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4969"},"text":"132 Stat. 4969","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef0f32c3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef0f32c4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef0f32c5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef0f32c6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12306/c/1"},"text":"Pub. L. 115–334, § 12306(c)(1)","children":[],"tail":", substituted “eligible farmers or ranchers” for “qualified beginning farmers or ranchers and socially disadvantaged farmers or ranchers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12306/c/2/A"},"text":"Pub. L. 115–334, § 12306(c)(2)(A)","children":[],"tail":", substituted “farmers or ranchers” for “recipients of the loans”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12306/c/2/B"},"text":"Pub. L. 115–334, § 12306(c)(2)(B)","children":[],"tail":", added par. (3) and struck out former par. (3) which read as follows: “encourage retiring farmers and ranchers to assist in the sale of their farms and ranches to qualified beginning farmers and ranchers and socially disadvantaged farmers or ranchers by providing seller financing;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12306/c/2/C"},"text":"Pub. L. 115–334, § 12306(c)(2)(C)","children":[],"tail":", substituted “for—” for “for beginning farmers or ranchers or socially disadvantaged farmers or ranchers”, added subpars. (A) and (B) and subpar. (C) designation, and inserted “veteran farmers or ranchers, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279/a"},"text":"section 2279(a) of this title","children":[],"tail":"; and” before “; and” in subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12306/c/2/D"},"text":"Pub. L. 115–334, § 12306(c)(2)(D)","children":[],"tail":", substituted “an eligible farmer or rancher” for “a qualified beginning farmer or rancher or socially disadvantaged farmer or rancher”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12306/c/3"},"text":"Pub. L. 115–334, § 12306(c)(3)","children":[],"tail":", added subsec. (e) and struck out former subsec. (e). Prior to amendment, text read as follows: “In this section, the term ‘socially disadvantaged farmer or rancher’ has the meaning given that term in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2003/e/2"},"text":"section 2003(e)(2) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s5005/a"},"text":"Pub. L. 113–79, § 5005(a)","children":[],"tail":", substituted “$667,000” for “$500,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s5005/b"},"text":"Pub. L. 113–79, § 5005(b)","children":[],"tail":", struck out second par. (2) which read as follows: “The interest rate on any loan made by the Secretary under this section shall be 4 percent.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s5004/1"},"text":"Pub. L. 110–246, § 5004(1)","children":[],"tail":", substituted “or ranchers and socially disadvantaged farmers or ranchers” for “and ranchers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s5004/2/A"},"text":"Pub. L. 110–246, § 5004(2)(A)","children":[],"tail":", added par. (1) and par. (2) consisting of subpars. (A) and (B) and struck out former par. (1). Prior to amendment, text of par. (1) read as follows: “Each loan made under this section shall be in an amount equal to 40 percent of the purchase price or appraisal value, whichever is lower, of the farm or ranch to be acquired, unless the borrower requests a lesser amount.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s5004/2/B"},"text":"Pub. L. 110–246, § 5004(2)(B)","children":[],"tail":", substituted “20” for “15”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s5004/3/A"},"text":"Pub. L. 110–246, § 5004(3)(A)","children":[],"tail":", substituted “5” for “10”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s5004/3/B"},"text":"Pub. L. 110–246, § 5004(3)(B)","children":[],"tail":", (C), redesignated par. (3) as (2), in subpar. (B), substituted “20-year” for “15-year”, and struck out former par. (2). Prior to amendment, text read as follows: “The Secretary shall not make a loan under this section with respect to a farm or ranch for which the purchase price or appraisal value, whichever is lower, exceeds $250,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s5004/4/A/ii"},"text":"Pub. L. 110–246, § 5004(4)(A)(ii)","children":[],"tail":", struck out “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s5004/4/A/i"},"text":"Pub. L. 110–246, § 5004(4)(A)(i)","children":[],"tail":", which directed the insertion of “and socially disadvantaged farmers or ranchers” after “ranchers”, was executed by making the insertion after “ranchers” the second place it appeared to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s5004/4/B"},"text":"Pub. L. 110–246, § 5004(4)(B)","children":[],"tail":", substituted “or ranchers or socially disadvantaged farmers or ranchers; and” for “and ranchers.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s5004/4/C"},"text":"Pub. L. 110–246, § 5004(4)(C)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s5004/5"},"text":"Pub. L. 110–246, § 5004(5)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s5005/1/A"},"text":"Pub. L. 107–171, § 5005(1)(A)","children":[],"tail":", substituted “40 percent” for “30 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s5005/1/B"},"text":"Pub. L. 107–171, § 5005(1)(B)","children":[],"tail":", substituted “15 years” for “10 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s5005/2"},"text":"Pub. L. 107–171, § 5005(2)","children":[],"tail":", substituted “15-year” for “10-year”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef0f32c7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef0f32c8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
