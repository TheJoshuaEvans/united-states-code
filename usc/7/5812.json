{"tag":"section","attrib":{"id":"idefcdef02-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812"},"text":null,"children":[{"tag":"num","attrib":{"value":"5812"},"text":"§ 5812.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefcdef03-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcdef04-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer the programs and projects conducted under sections 5811 and 5813 of this title through the National Institute of Food and Agriculture, Agricultural Research Service, and other appropriate agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef05-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a minimum of four Regional Administrative Councils in accordance with subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef06-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in conjunction with such Regional Administrative Councils, identify regional host institutions required to carry out such programs or projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdef07-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional Administrative Councils","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcdef08-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The membership of the Regional Administrative Councils shall include representatives of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefcdef09-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Agricultural Research Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdef0a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Institute of Food and Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdef0b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State cooperative extension services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdef0c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State agricultural experiment stations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdef0d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Soil Conservation Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdef0e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State departments engaged in sustainable agriculture programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdef0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit organizations with demonstrable expertise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdef10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" farmers utilizing systems and practices of sustainable agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdef11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agribusiness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdef12-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State or United States Geological Survey; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdef13-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/b/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other persons knowledgeable about sustainable agriculture and its impact on the environment and rural communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef14-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Regional Administrative Councils shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefcdef15-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the programs established under this subchapter at the regional level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdef16-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish goals and criteria for the selection of projects authorized under this subchapter within the applicable region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdef17-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint a technical committee to evaluate the proposals for projects to be considered under this subchapter by such council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdef18-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and act on the recommendations of the technical committee, and coordinate its activities with the regional host institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcdef19-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and make available an annual report concerning projects funded under sections 5811 and 5813 of this title, together with an evaluation of the project activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef1a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5812/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Regional Administrative Council or a technical committee may not participate in the discussion or recommendation of proposed projects if the member has or had a professional or business interest in, including the provision of consultancy services, the organization whose grant application is under review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefcdef1b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1622"},"text":"Pub. L. 101–624, title XVI, § 1622","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3736"},"text":"104 Stat. 3736","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s860/a"},"text":"Pub. L. 104–127, title VIII, § 860(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1173"},"text":"110 Stat. 1173","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7511/c/15"},"text":"Pub. L. 110–234, title VII, § 7511(c)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1268"},"text":"122 Stat. 1268","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7511(c)(15), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2030.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefcdef1c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefcdef1d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefcdef1e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefcdef1f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7511/c/15/A"},"text":"Pub. L. 110–246, § 7511(c)(15)(A)","children":[],"tail":", substituted “the National Institute of Food and Agriculture” for “the Cooperative State Research Service in close cooperation with the Extension Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B) to (L). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7511/c/15/B"},"text":"Pub. L. 110–246, § 7511(c)(15)(B)","children":[],"tail":", added subpar. (B), redesignated former subpars. (D) to (L) as (C) to (K), respectively, and struck out former subpars. (B) and (C) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the Cooperative State Research Service;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) the Extension Service;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s860/b/1"},"text":"Pub. L. 104–127, § 860(b)(1)","children":[],"tail":", redesignated pars. (3) and (4) as (2) and (3), respectively, substituted “subsection (b)” for “subsection (e)” in par. (2), and struck out former par. (2) which read as follows: “establish the Advisory Council in accordance with subsection (c) of this section;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s860/a"},"text":"Pub. L. 104–127, § 860(a)","children":[],"tail":", (b)(3), redesignated subsec. (e) as (b) and struck out former subsec. (b) which required Secretary, not later than "},{"tag":"date","attrib":{"date":"1991-04-01"},"text":"Apr. 1, 1991","children":[],"tail":", and each April 1 thereafter, to prepare and submit to congressional committees and to Advisory Council report describing results of programs carried out under sections 5811, 5813, and 5821 of this title and report describing progress of projects conducted under this subchapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s860/b/4"},"text":"Pub. L. 104–127, § 860(b)(4)","children":[],"tail":", redesignated subpars. (B) to (F) as (A) to (E), respectively, and struck out former subpar. (A) which read as follows: “make recommendations to the Advisory Council concerning research and extension projects that merit funding under sections 5811 and 5813 of this title;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s860/b/2"},"text":"Pub. L. 104–127, § 860(b)(2)","children":[],"tail":", (3), redesignated subsec. (e) as (b) and struck out subsec. (c) which provided for membership of the National Sustainable Agriculture Advisory Council and subsec. (d) which set forth responsibilities of Advisory Council."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefcdef20-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idefcdef21-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7511/c/15"},"text":"section 7511(c)(15) of Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7511/c"},"text":"section 7511(c) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1522"},"text":"section 1522 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
