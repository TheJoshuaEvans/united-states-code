{"tag":"section","attrib":{"id":"idf0512944-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9091"},"text":null,"children":[{"tag":"num","attrib":{"value":"9091"},"text":"§ 9091.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration generally","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0512945-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9091/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Commodity Credit Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use the funds, facilities, and authorities of the Commodity Credit Corporation to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0512946-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9091/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A determination made by the Secretary under this chapter shall be final and conclusive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0512947-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9091/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0512948-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9091/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subsection, not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":", the Secretary and the Commodity Credit Corporation, as appropriate, shall promulgate such regulations as are necessary to implement this chapter and the amendments made by this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0512949-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9091/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The promulgation of the regulations and administration of this chapter and the amendments made by this chapter, sections 11003 and 11017, title I of the Agriculture Improvement Act of 2018 and the amendments made by that title, and section 10109 of that Act shall be made without regard to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf051294a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9091/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the notice and comment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf051294b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9091/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 35 of title 44 (commonly known as the “Paperwork Reduction Act”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf051294c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9091/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional review of agency rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subsection, the Secretary shall use the authority provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s808"},"text":"section 808 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf051294d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9091/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment authority related to trade agreements compliance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf051294e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9091/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required determination; adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that expenditures under this chapter that are subject to the total allowable domestic support levels under the Uruguay Round Agreements (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501"},"text":"section 3501 of title 19","children":[],"tail":") will exceed such allowable levels for any applicable reporting period, the Secretary shall, to the maximum extent practicable, make adjustments in the amount of such expenditures during that period to ensure that such expenditures do not exceed the allowable levels."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf051294f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9091/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before making any adjustment under paragraph (1), the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report describing the determination made under that paragraph and the extent of the adjustment to be made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0512950-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1601"},"text":"Pub. L. 113–79, title I, § 1601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/704"},"text":"128 Stat. 704","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI/s1701"},"text":"Pub. L. 115–334, title I, § 1701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4525"},"text":"132 Stat. 4525","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0512951-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0512952-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf0512953-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/658"},"text":"128 Stat. 658","children":[],"tail":", which is classified principally to this chapter. For complete classification of title I to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 11003 and 11017, referred to in subsec. (c)(2), mean sections 11003 and 11017 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1508b"},"text":"section 1508b of this title","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1508"},"text":"section 1508 of this title","children":[],"tail":" and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1508"},"text":"section 1508 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Agriculture Improvement Act of 2018, referred to in subsec. (c)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4490"},"text":"132 Stat. 4490","children":[],"tail":". Title I of the Act enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9071"},"text":"section 9071 of this title","children":[],"tail":", amended sections 608c, 1308, 1308–3a, 1359bb, 1359"},{"tag":"i","attrib":{},"text":"ll","children":[],"tail":", 4504, 4553, 7272, 7333, 8737, 8772, 9011 to 9017, 9031, 9032, 9034 to 9039, 9051 to 9060, 9081, 9091, 9092, and 9097 of this title, repealed sections 9019 and 9071 of this title, and enacted provisions set out as notes under sections 608c, 1308, 1308–3a, 6932, 9051, 9052, and 9081 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s6101"},"text":"section 6101 of Title 31","children":[],"tail":", Money and Finance. For complete classification of this Act to the Code, see Short Title of 2018 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 10109 of that Act, referred to in subsec. (c)(2), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10109"},"text":"section 10109 of Pub. L. 115–334","children":[],"tail":", title X, "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4906"},"text":"132 Stat. 4906","children":[],"tail":". Subsecs. (a) to (c) of section 10109 are not classified to the Code. Subsec. (d) of section 10109 amended "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2276"},"text":"section 2276 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf0512954-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1701/1"},"text":"Pub. L. 115–334, § 1701(1)","children":[],"tail":", substituted “this chapter, sections 11003 and 11017, title I of the Agriculture Improvement Act of 2018 and the amendments made by that title, and section 10109 of that Act” for “this chapter and sections 11003 and 11017” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1701/2"},"text":"Pub. L. 115–334, § 1701(2)","children":[],"tail":"–(4), struck out subpar. (C) which read as follows: “the Statement of Policy of the Secretary of Agriculture effective "},{"tag":"date","attrib":{"date":"1971-07-24"},"text":"July 24, 1971","children":[],"tail":" (36 Fed. Reg. 13804), relating to notices of proposed rulemaking and public participation in rulemaking.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
