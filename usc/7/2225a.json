{"tag":"section","attrib":{"id":"idef78068e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2225a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2225a"},"text":"§ 2225a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts for consulting services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1991-10-28"},"text":"October 28, 1991","children":[],"tail":", the expenditure of any appropriation for the Department of Agriculture for any consulting service through procurement contract, pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"5 U.S.C. 3109","children":[],"tail":", shall be limited to those contracts where such expenditures are a matter of public record and available for public inspection, except where otherwise provided under existing law, or under existing Executive order issued pursuant to existing law."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef78068f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/142/tVII/s701"},"text":"Pub. L. 102–142, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/911"},"text":"105 Stat. 911","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
