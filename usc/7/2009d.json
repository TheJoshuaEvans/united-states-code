1932(a)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6026/a/1"},"text":"Pub. L. 107–171, § 6026(a)(1)","children":[],"tail":", redesignated par. (5) as (4) and struck out former par. (4) which read as follows: “The national reserve account.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6026/a/2"},"text":"Pub. L. 107–171, § 6026(a)(2)","children":[],"tail":", (3), redesignated subsec. (f) as (e) and struck out heading and text of former subsec. (e) which related to national reserve account."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6026/a/3"},"text":"Pub. L. 107–171, § 6026(a)(3)","children":[],"tail":", redesignated subsec. (g) as (f). Former subsec. (f) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6026/a/3"},"text":"Pub. L. 107–171, § 6026(a)(3)","children":[],"tail":", (4), redesignated subsec. (h) as (g) and substituted “subsection (f)” for “subsection (g) of this section”. Former subsec. (g) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/472/s305/b"},"text":"Pub. L. 106–472, § 305(b)","children":[],"tail":", substituted “paragraph (19), (20), or (21)” for “paragraph (19) or (20)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/472/s304/b"},"text":"Pub. L. 106–472, § 304(b)","children":[],"tail":", substituted “paragraph (19) or (20) of section 1926(a)” for “section 1926(a)(19)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (d)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/86"},"text":"Pub. L. 105–86","children":[],"tail":" inserted “direct and” after “business and industry”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef29711e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef29711f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6701/e/2"},"text":"Pub. L. 115–334, title VI, § 6701(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4778"},"text":"132 Stat. 4778","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/334/tVI/s6701/e/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall take effect as if included in the enactment of section 6012(b) of the Agricultural Act of 2014 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Public Law 113–79","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef297120-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef297121-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Account Balances","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/55/dA/tVII/s747"},"text":"Pub. L. 112–55, div. A, title VII, § 747","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-11-18"},"text":"Nov. 18, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/590"},"text":"125 Stat. 590","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/55/dA/tVII/s747"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“For 2012 and subsequent fiscal years—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any balances to carry out a housing demonstration program to provide revolving loans for the preservation of low-income multi-family housing projects as authorized in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Public Law 108–447","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/109/97"},"text":"Public Law 109–97","children":[],"tail":" and a demonstration program for the preservation and revitalization of the section 515 multi-family rental housing properties as authorized by "},{"tag":"ref","attrib":{"href":"/us/pl/109/97"},"text":"Public Law 109–97","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/5"},"text":"Public Law 110–5","children":[],"tail":" shall be transferred to and merged with the ‘Rural Housing Service, Multi-family Housing Revitalization Program Account’;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any prior balances in the Rural Development, Rural Community Advancement Program account for programs authorized by section 306 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1926"},"text":"7 U.S.C. 1926","children":[],"tail":"] and described in section 381E(d)(1) ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009d/d/1"},"text":"7 U.S.C. 2009d(d)(1)","children":[],"tail":"] of such Act [probably means title III of "},{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", known as the Consolidated Farm and Rural Development Act, which is classified principally to this chapter] be transferred and merged with the ‘Rural Community Facilities Program Account’ and any other prior balances from the Rural Development, Rural Community Advancement Program account that the Secretary determines are appropriate to transfer;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any prior balances in the Rural Development, Rural Community Advancement Program account for programs authorized by sections 306 and 310B [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1926"},"text":"7 U.S.C. 1926","children":[],"tail":", 1932] and described in sections 310B(f) and 381E(d)(3) of such Act be transferred and merged with the ‘Rural Business Program Account’ and any other prior balances from the Rural Development, Rural Community Advancement Program account that the Secretary determines are appropriate to transfer; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any prior balances in the Rural Development, Rural Community Advancement Program account programs authorized by sections 306, 306A, 306C, 306D, 306E, and 310B [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1926"},"text":"7 U.S.C. 1926","children":[],"tail":", 1926a, 1926c, 1926d, 1926e, 1932] and described in sections 306C(a)(2), 306D, 306E, and 381E(d)(2) of such Act be transferred to and merged with the ‘Rural Water and Waste Disposal Program Account’ and any other prior balances from the Rural Development, Rural Community Advancement Program account that the Secretary determines are appropriate to transfer.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
