{"tag":"section","attrib":{"id":"idef2970fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009d"},"text":"§ 2009d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural Development Trust Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef2970fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a trust fund which shall be known as the Rural Development Trust Fund (in this subchapter referred to as the “Trust Fund”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2970ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are established in the Trust Fund the following accounts:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef297100-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rural community facilities account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef297101-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rural utilities account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef297102-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rural business and cooperative development account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef297103-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The federally recognized Indian tribe account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef297104-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits into accounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, each fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef297105-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all amounts made available to carry out the authorities described in subsection (d)(1) for the fiscal year shall be deposited into the rural community facilities account of the Trust Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef297106-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all amounts made available to carry out the authorities described in subsection (d)(2) for the fiscal year shall be deposited into the rural utilities account of the Trust Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef297107-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all amounts made available to carry out the authorities described in subsection (d)(3) for the fiscal year shall be deposited into the rural business and cooperative development account of the Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef297108-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Function categories","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The function categories described in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef297109-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural community facilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rural community development category consists of all amounts made available for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef29710a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community facility direct and guaranteed loans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1926/a/1"},"text":"section 1926(a)(1) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef29710b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community facility grants under paragraph (19), (20), or (21) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1926/a"},"text":"section 1926(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef29710c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural utilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rural utilities category consists of all amounts made available for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef29710d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water or waste disposal grants or direct or guaranteed loans under paragraph (1) or (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1926/a"},"text":"section 1926(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef29710e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rural water or wastewater technical assistance and training grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1926/a/14"},"text":"section 1926(a)(14) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef29710f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency community water assistance grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1926a"},"text":"section 1926a of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef297110-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solid waste management grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1932/b"},"text":"section 1932(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef297111-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural business and cooperative development","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rural business and cooperative development category consists of all amounts made available for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef297112-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" business and industry direct and guaranteed loans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1932/a/2/A"},"text":"section 1932(a)(2)(A) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef297113-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rural business enterprise grants or rural educational network grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1932/c"},"text":"section 1932(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef297114-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federally recognized Indian tribe account","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef297115-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers into account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each fiscal year, the Secretary shall transfer to the federally recognized Indian tribe account of the Trust Fund 3 percent of the amount deposited into the Trust Fund for the fiscal year under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef297116-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available to federally recognized Indian tribes the amounts in the federally recognized Indian tribe account for use pursuant to any authority described in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef297117-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation among States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall allocate the amounts in each account specified in subsection (c) among the States in a fair, reasonable, and appropriate manner that takes into consideration rural population, levels of income, unemployment, and other relevant factors, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef297118-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009d/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds allocated for States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available to each State the total amount allocated for the State under subsection (f) that remains after applying ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009f"},"text":"section 2009f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef297119-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s381E"},"text":"Pub. L. 87–128, title III, § 381E","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s761"},"text":"Pub. L. 104–127, title VII, § 761","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1140"},"text":"110 Stat. 1140","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/86/tIII"},"text":"