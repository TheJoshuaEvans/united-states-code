{"tag":"section","attrib":{"id":"idef7f329a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279b"},"text":"§ 2279b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Agriculture educational, training, and professional development activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef7f329b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7f329c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Graduate School","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Graduate School” means the Graduate School of the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f329d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the General Administration Board of the Graduate School.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f329e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the Graduate School.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f329f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f32a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation as nonappropriated fund instrumentality","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7f32a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cease operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2009-10-01"},"text":"October 1, 2009","children":[],"tail":", the Secretary of Agriculture shall cease to maintain or operate a nonappropriated fund instrumentality of the United States to develop, administer, or provide educational training and professional development activities, including educational activities for Federal agencies, Federal employees, non-profit organizations, other entities, and members of the general public."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7f32a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture is authorized to use funds available to the Department of Agriculture and such resources of the Department as the Secretary considers appropriate (including the assignment of such employees of the Department as the Secretary considers appropriate) to assist the General Administrative Board of the Graduate School in the conversion of the Graduate School to an entity that is non-governmental and not a nonappropriated fund instrumentality of the United States, including such privatization activities not otherwise inconsistent with law or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7f32a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authority under paragraph (1) shall terminate on the earlier of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef7f32a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the completion of the transition of the Graduate School to an entity that is non-governmental and not a nonappropriated fund instrumentality of the United States, as determined by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef7f32a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2009-09-30"},"text":"September 30, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f32a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities of Graduate School","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under the general supervision of the Secretary, the Graduate School shall develop, administer, and provide educational, training, and professional development activities, including educational activities for Federal agencies, Federal employees, nonprofit organizations, other entities, and members of the general public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f32a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees and donations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7f32a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Graduate School may charge and retain fair and reasonable fees for the activities provided by the Graduate School. The amount of the fees shall be based on the cost of the activities to the Graduate School.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of donations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7f32ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance and use authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Graduate School may accept, use, hold, dispose, and administer gifts, bequests, and devises of money, securities, and other real or personal property made for the benefit of, or in connection with, the Graduate School.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7f32ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Graduate School shall not accept a donation from a person that is actively engaged in a procurement activity with the Graduate School or has an interest that may be substantially affected by the performance or nonperformance of an official duty of a member of the Board or an employee of the Graduate School.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Not Federal funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees collected under paragraph (1) and amounts received under paragraph (2) shall not be considered to be Federal funds and shall not be required to be deposited in the Treasury of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f32ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General Administration Board and Director","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7f32af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment as governing board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint a General Administration Board to serve as a governing board for the Graduate School and to supervise and direct the activities of the Graduate School. The Board shall be subject to regulation by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7f32b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formulate broad policies in accordance with which the Graduate School shall be administered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7f32b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take all steps necessary to ensure that the highest possible educational standards are maintained by the Graduate School;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7f32b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise general supervision over the administration of the Graduate School; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7f32b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish such bylaws, rules, and procedures as may be necessary for the fulfillment of the duties described in subparagraphs (A), (B), and (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of Director and other officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall select a Director and such other officers as the Board considers necessary to administer the Graduate School. The Director and other officers shall serve on such terms and perform such duties as the Board may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall be responsible, subject to the supervision and direction of the Board, for carrying out the functions of the Graduate School.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Borrowing and investment authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board may authorize the Director—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7f32b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to borrow money on the credit of the Graduate School; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7f32b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to invest funds held in excess of the current operating requirements of the Graduate School for purposes of maintaining a reasonable reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director and the members of the Board shall not be held personally liable for any loss or damage that may accrue to the funds of the Graduate School as the result of any act or exercise of discretion performed in carrying out their duties under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f32bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Employees of the Graduate School are employees of a nonappropriated fund instrumentality and shall not be considered to be Federal employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f32bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Not a Federal agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Graduate School shall not be considered to be a Federal agency for purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7f32bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 10 of title 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 552 or 552a of title 5; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 171 of title 28.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f32c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition and disposal of property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to carry out the activities of the Graduate School, the Graduate School may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7f32c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire real property in the District of Columbia and in other places by lease, purchase, or otherwise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain, enlarge, or remodel any such property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have sole control of any such property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dispose of real and personal property without regard to chapters 1 to 11 of title 40 and division C (except sections 3302, 3307(e), 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f32c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Graduate School may enter into contracts without regard to chapters 1 to 11 of title 40 and division C (except sections 3302, 3307(e), 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41 or any other law that prescribes procedures for the procurement of property or services by an executive agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f32c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Department facilities and resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Graduate School may use the facilities and resources of the Department of Agriculture, on the condition that any costs incurred by the Department that are attributable solely to Graduate School operations and all costs incurred by the Graduate School arising out of such operations shall be paid using funds of the Graduate School. Federal funds may not be used to pay the costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f32c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279b/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits of records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The financial records of the Graduate School (including records relating to contracts or agreements entered into under subsection (c)) shall be made available to the Comptroller General for purposes of conducting an audit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7f32c8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIX/s921"},"text":"Pub. L. 104–127, title IX, § 921","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1191"},"text":"110 Stat. 1191","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10705/a"},"text":"Pub. L. 107–171, title X, § 10705(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/518"},"text":"116 Stat. 518","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14213/a"},"text":"Pub. L. 110–234, title XIV, § 14213(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1465"},"text":"122 Stat. 1465","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14213(a), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2227; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/29"},"text":"Pub. L. 117–286, § 4(a)(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4308"},"text":"136 Stat. 4308","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7f32c9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef7f32ca-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef7f32cb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsecs. (h)(4) and (i), “chapters 1 to 11 of title 40 and division C (except sections 3302, 3307(e), 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41” substituted for “the Federal Property and Administrative Services Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s471"},"text":"40 U.S.C. 471","children":[],"tail":" et seq.)” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", which Act enacted Title 40, Public Buildings, Property, and Works, and "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef7f32cc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5;” for “the Federal Advisory Committee Act (5 U.S.C. App.);”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s14213/a/1"},"text":"Pub. L. 110–246, § 14213(a)(1)","children":[],"tail":", substituted “Department of Agriculture educational, training, and professional development activities” for “Operation of Graduate School of Department of Agriculture as nonappropriated fund instrumentality” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s14213/a/2"},"text":"Pub. L. 110–246, § 14213(a)(2)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows: “On and after "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"April 4, 1996","children":[],"tail":", the Graduate School of the Department of Agriculture shall continue to operate as a nonappropriated fund instrumentality of the United States under the jurisdiction of the Department of Agriculture.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" added subsec. (k)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef7f32cd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef7f32ce-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef7f32cf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10705/c"},"text":"Pub. L. 107–171, title X, § 10705(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/519"},"text":"116 Stat. 519","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/171/tX/s10705/c"},"text":"“The amendments made by this section [amending this section and repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5922"},"text":"section 5922 of this title","children":[],"tail":"] take effect on "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"October 1, 2002","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef7f32d0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Procurement Procedures","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14213/b"},"text":"Pub. L. 110–234, title XIV, § 14213(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1466"},"text":"122 Stat. 1466","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14213(b), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2228, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/246/s4/a"},"text":"“Notwithstanding the amendments made by subsection (a) [amending this section], effective on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":"], the Graduate School of the Department of Agriculture shall be subject to Federal procurement laws and regulations in the same manner and subject to the same requirements as a private entity providing services to the Federal Government.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical provisions. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
