{"tag":"section","attrib":{"id":"idf00997bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416"},"text":null,"children":[{"tag":"num","attrib":{"value":"7416"},"text":"§ 7416.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf00997bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"While an order issued under this subchapter is in effect with respect to an agricultural commodity, assessments shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00997bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paid by first handlers with respect to the agricultural commodity produced and marketed in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00997be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paid by importers with respect to the agricultural commodity imported into the United States, if the imported agricultural commodity is covered by the order pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7415/f"},"text":"section 7415(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00997bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assessments required under an order shall be remitted to the board established under the order at the time and in the manner prescribed by the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00997c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 1 assessment may be levied on a first handler or importer under subsection (a) with respect to any agricultural commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00997c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment rates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The board shall recommend to the Secretary 1 or more rates of assessment to be levied under subsection (a). If approved by the Secretary, the rates shall take effect. An order may provide that an assessment rate may not be increased unless approved by a referendum conducted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7417"},"text":"section 7417 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00997c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Late-payment and interest charges","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00997c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Late-payment and interest charges may be levied on each person subject to an order who fails to remit an assessment in accordance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00997c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rate for the charges shall be specified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00997c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of assessments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pending disbursement of assessments under a budget approved by the Secretary, a board may invest assessments collected under this section in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00997c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obligations of the United States or any agency of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00997c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" general obligations of any State or any political subdivision of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00997c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest-bearing accounts or certificates of deposit of financial institutions that are members of the Federal Reserve System; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00997c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obligations fully guaranteed as to principal and interest by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00997ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refund of assessments from escrow account","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00997cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Escrow account","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the period beginning on the effective date of an order and ending on the date the Secretary announces the results of a referendum that is conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7417/b/1"},"text":"section 7417(b)(1) of this title","children":[],"tail":" with respect to the order, the board established under the order shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00997cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and maintain an escrow account of the kind described in subsection (f)(3) to be used to refund assessments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00997cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposit funds in the account in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00997ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount to be deposited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The board shall deposit in the account an amount equal to 10 percent of the assessments collected during the period referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00997cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to receive refund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraphs (4), (5), and (6), persons subject to an order shall be eligible to demand a refund of assessments collected during the period referred to in paragraph (1) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00997d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assessments were remitted on behalf of the person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00997d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the order is not approved in the referendum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00997d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of demand","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The demand for a refund shall be made at such time and in such form as specified by the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00997d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of refund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person entitled to a refund shall be paid promptly after the board receives satisfactory proof that the assessment for which the refund is demanded was paid on behalf of the person who makes the demand.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00997d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/g/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the funds in the escrow account required by paragraph (1) are insufficient to pay the amount of all refunds that persons subject to an order otherwise would have a right to receive under this subsection, the board shall prorate the amount of the funds among all the persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00997d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/g/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closing of escrow account","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the order is approved in a referendum conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7417/b/1"},"text":"section 7417(b)(1) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00997d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/g/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the escrow account shall be closed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00997d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7416/g/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funds shall be available to the board for disbursement as authorized in the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf00997d8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s517"},"text":"Pub. L. 104–127, title V, § 517","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1042"},"text":"110 Stat. 1042","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
