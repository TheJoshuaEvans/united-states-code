{"tag":"section","attrib":{"id":"idefc6c321-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5405"},"text":null,"children":[{"tag":"num","attrib":{"value":"5405"},"text":"§ 5405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural air quality research oversight","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefc6c322-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5405/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc6c323-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5405/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" various studies have alleged that agriculture is a source of PM–10 emissions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c324-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5405/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" many of these studies have often been based on erroneous data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c325-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5405/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal research activities are currently being conducted by the Department of Agriculture to determine the true extent to which agricultural activities contribute to air pollution and to determine cost-effective ways in which the agricultural industry can reduce any pollution that exists; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c326-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5405/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal policy recommendations that may be issued by any Federal agency to address air pollution problems related to agriculture or any other industrial activity should be based on sound scientific findings that are subject to adequate peer review and should take into account economic feasibility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc6c327-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5405/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to encourage the Secretary of Agriculture to continue to strengthen vital research efforts related to agricultural air quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc6c328-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5405/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc6c329-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5405/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intergovernmental cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, to the maximum extent practicable with respect to the Department of Agriculture and other Federal departments and agencies, ensure intergovernmental cooperation in research activities related to agricultural air quality and avoid duplication of the activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c32a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5405/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correct data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, to the maximum extent practicable, ensure that the results of any research related to agricultural air quality conducted by Federal agencies not report erroneous data with respect to agricultural air quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc6c32b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5405/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task force","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc6c32c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5405/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief of the National Resources Conservation Service shall establish a task force to address agricultural air quality issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c32d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5405/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The task force shall be comprised of employees of the Department of Agriculture, industry representatives, and other experts in the fields of agriculture and air quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c32e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5405/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The task force shall advise the Secretary with respect to the role of the Secretary for providing oversight and coordination related to agricultural air quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefc6c32f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIII/s391"},"text":"Pub. L. 104–127, title III, § 391","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1025"},"text":"110 Stat. 1025","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefc6c330-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefc6c331-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefc6c332-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Federal Agriculture Improvement and Reform Act of 1996, and not as part of subtitle F (§ 1471 et seq.) of title XIV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" which comprises this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
