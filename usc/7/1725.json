{"tag":"section","attrib":{"id":"ideeeb56dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1725"},"text":null,"children":[{"tag":"num","attrib":{"value":"1725"},"text":"§ 1725.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food Aid Consultative Group","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideeeb56de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1725/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a Food Aid Consultative Group (hereinafter referred to in this section as the “Group”) that shall meet regularly to review and address issues concerning the effectiveness of the regulations and procedures that govern food assistance programs established and implemented under this subchapter, and the implementation of other provisions of this subchapter that may involve eligible organizations described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1722/d/1"},"text":"section 1722(d)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeeb56df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1725/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Group shall be composed of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeeb56e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1725/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb56e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1725/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary of Agriculture for Trade and Foreign Agricultural Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb56e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1725/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Inspector General of the Agency for International Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb56e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1725/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative of each private voluntary organization and cooperative participating in a program under this subchapter, or receiving planning assistance funds from the Agency to establish programs under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb56e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1725/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives from African, Asian and Latin American indigenous non-governmental organizations determined appropriate by the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb56e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1725/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives from agricultural producer groups in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb56e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1725/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives from the United States agricultural processing sector involved in providing agricultural commodities for programs under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb56e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1725/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives from the maritime transportation sector involved in transporting agricultural commodities overseas for programs under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeeb56e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1725/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall be the chairperson of the Group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeeb56e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1725/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeeb56ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1725/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation in advance of issuance of implementation regulations, handbooks, and guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days before a proposed regulation, handbook, or guideline implementing this subchapter, or a proposed significant revision to a regulation, handbook, or guideline implementing this subchapter, becomes final, the Administrator shall provide the proposal to the Group for review and comment. The Administrator shall consult and, when appropriate (but at least twice per year), meet with the Group regarding such proposed regulations, handbooks, guidelines, or revisions thereto prior to the issuance of such.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb56eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1725/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation regarding food aid quality efforts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall seek input from and consult with the Group on the implementation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1722/h"},"text":"section 1722(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeeb56ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1725/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply to the Group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeeb56ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1725/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Group shall terminate on ","children":[{"tag":"date","attrib":{"date":"2023-12-31"},"text":"December 31, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideeeb56ee-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title II, § 205, as added "},{"tag":"ref","attrib":{"href":"/us/pl/89/808/s2/C"},"text":"Pub. L. 89–808, § 2(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-11"},"text":"Nov. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1535"},"text":"80 Stat. 1535","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3639"},"text":"104 Stat. 3639","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s210"},"text":"Pub. L. 104–127, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/955"},"text":"110 Stat. 955","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIII/s3005"},"text":"Pub. L. 107–171, title III, § 3005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/282"},"text":"116 Stat. 282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3011"},"text":"Pub. L. 110–246, title III, § 3011","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1824"},"text":"122 Stat. 1824","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIII/s3005"},"text":"Pub. L. 113–79, title III, § 3005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/774"},"text":"128 Stat. 774","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIII/s3105"},"text":"Pub. L. 115–334, title III, § 3105","children":[],"tail":", title XII, § 12405(c), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4604"},"text":"132 Stat. 4604","children":[],"tail":", 4975; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/26"},"text":"Pub. L. 117–286, § 4(a)(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4308"},"text":"136 Stat. 4308","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideeeb56ef-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideeeb56f0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideeeb56f1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", which directed amendment of “Section 205(e) of the Agricultural Trade Development and Assistance Act of 1954” by substituting “Chapter 10 of title 5” for “Advisory Committee Act” in heading and “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)” in text, was executed to this section, which is section 205(e) of the Food for Peace Act, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12405/c"},"text":"Pub. L. 115–334, § 12405(c)","children":[],"tail":", substituted “Under Secretary of Agriculture for Trade and Foreign Agricultural Affairs” for “Under Secretary of Agriculture for Farm and Foreign Agricultural Services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3105/1"},"text":"Pub. L. 115–334, § 3105(1)","children":[],"tail":", substituted “30 days” for “45 days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3105/2"},"text":"Pub. L. 115–334, § 3105(2)","children":[],"tail":", substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3005/a"},"text":"Pub. L. 113–79, § 3005(a)","children":[],"tail":", added par. (7) and redesignated former par. (7) as (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3005/b"},"text":"Pub. L. 113–79, § 3005(b)","children":[],"tail":", designated existing provisions as par. (1), substituted “Not later than 45 days before a proposed regulation, handbook, or guideline implementing this subchapter, or a proposed significant revision to a regulation, handbook, or guideline implementing this subchapter, becomes final, the Administrator shall provide the proposal to the Group for review and comment.” for “In preparing regulations, handbooks, or guidelines implementing this subchapter, or significant revisions thereto, the Administrator shall provide such proposals to the Group for review and comment.”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3005/c"},"text":"Pub. L. 113–79, § 3005(c)","children":[],"tail":", substituted “2018” for “2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3011/1"},"text":"Pub. L. 110–246, § 3011(1)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3011/2"},"text":"Pub. L. 110–246, § 3011(2)","children":[],"tail":", substituted “2012” for “2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" substituted “2007” for “2002”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s210/1"},"text":"Pub. L. 104–127, § 210(1)","children":[],"tail":", substituted “eligible organizations described in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1722/d/1"},"text":"section 1722(d)(1) of this title","children":[],"tail":"” for “private voluntary organizations, cooperatives and indigenous non-governmental organizations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s210/2/A"},"text":"Pub. L. 104–127, § 210(2)(A)","children":[],"tail":", substituted “of Agriculture for Farm and Foreign Agricultural Services” for “for International Affairs and Commodity Programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s210/2/B"},"text":"Pub. L. 104–127, § 210(2)(B)","children":[],"tail":"–(D), added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s210/3"},"text":"Pub. L. 104–127, § 210(3)","children":[],"tail":", inserted “(but at least twice per year)” after “when appropriate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s210/4"},"text":"Pub. L. 104–127, § 210(4)","children":[],"tail":", substituted “2002” for “1995”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" amended section generally, substituting present provisions for provisions declaring sense of Congress that President should encourage advanced nations to increase contributions for combating hunger, particularly through expansion of international food and agricultural assistance programs, and that United States should work for expansion of United Nations World food program."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideeeb56f2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideeeb56f3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag"