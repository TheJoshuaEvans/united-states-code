tXIV/s1473E"},"text":"Pub. L. 95–113, title XIV, § 1473E","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/220/s5"},"text":"Pub. L. 101–220, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-12"},"text":"Dec. 12, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1878"},"text":"103 Stat. 1878","children":[],"tail":", related to research into new commercial products from natural plant materials, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIV/s402/14"},"text":"Pub. L. 102–237, title IV, § 402(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1863"},"text":"105 Stat. 1863","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefaa39cc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1)(B)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7130/1"},"text":"Pub. L. 115–334, § 7130(1)","children":[],"tail":", added cl. (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7130/2"},"text":"Pub. L. 115–334, § 7130(2)","children":[],"tail":", substituted “2019 through 2023” for “2008 through 2012”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefaa39cd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefaa39ce-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"