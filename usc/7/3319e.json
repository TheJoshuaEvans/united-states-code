{"tag":"section","attrib":{"id":"idefa7c9ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e"},"text":null,"children":[{"tag":"num","attrib":{"value":"3319e"},"text":"§ 3319e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New Era Rural Technology Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa7c9ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of community college","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “community college” means an institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":")—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa7c9af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that admits as regular students individuals who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa7c9b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are beyond the age of compulsory school attendance in the State in which the institution is located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa7c9b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the ability to benefit from the training offered by the institution;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa7c9b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that does not provide an educational program for which the institution awards a bachelor’s degree or an equivalent degree; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa7c9b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa7c9b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides an educational program of not less than 2 years that is acceptable for full credit toward such a degree; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefaa39b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offers a 2-year program in engineering, technology, mathematics, or the physical, chemical, or biological sciences, designed to prepare a student to work as a technician or at the semiprofessional level in engineering, scientific, or other technological fields requiring the understanding and application of basic engineering, scientific, or mathematical principles of knowledge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefaa39b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefaa39b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefaa39b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program to be known as the “New Era Rural Technology Program”, to make grants available for technology development, applied research, and training to aid in the development of an agriculture-based renewable energy workforce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefaa39b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The initiative under this section shall support the fields of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefaa39ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bioenergy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefaa39bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pulp and paper manufacturing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefaa39bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agriculture-based renewable energy resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefaa39bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" precision agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefaa39be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To receive funding under this section, an entity shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefaa39bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a community college or advanced technological center, located in a rural area and in existence on the date of the enactment of this section, that participates in agricultural or bioenergy research and applied research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefaa39c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a proven record of development and implementation of programs to meet the needs of students, educators, and business and industry to supply the agriculture-based, renewable energy or pulp and paper manufacturing fields with certified technicians, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefaa39c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the ability to leverage existing partnerships and occupational outreach and training programs for secondary schools, 4-year institutions, and relevant nonprofit organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefaa39c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing grants under this section, the Secretary shall give preference to eligible entities working in partnership—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefaa39c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve information-sharing capacity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefaa39c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maximize the ability to meet the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefaa39c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as are necessary for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefaa39c6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1473E"},"text":"Pub. L. 95–113, title XIV, § 1473E","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7137"},"text":"Pub. L. 110–234, title VII, § 7137","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1229"},"text":"122 Stat. 1229","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7137, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1990; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7130"},"text":"Pub. L. 115–334, title VII, § 7130","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4795"},"text":"132 Stat. 4795","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefaa39c7-3