{"tag":"section","attrib":{"id":"idee0b2ffd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"136w–3"},"text":"§ 136w–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of pests; cooperation with Department of Agriculture’s program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee0b2ffe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, in coordination with the Secretary of Agriculture, shall identify those pests that must be brought under control. The Administrator shall also coordinate and cooperate with the Secretary of Agriculture’s research and implementation programs to develop and improve the safe use and effectiveness of chemical, biological, and alternative methods to combat and control pests that reduce the quality and economical production and distribution of agricultural products to domestic and foreign consumers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee0b2fff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pest control availability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee0b3000-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, in cooperation with the Secretary of Agriculture, shall identify—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee0b3001-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–3/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available methods of pest control by crop or animal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee0b3002-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–3/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minor pest control problems, both in minor crops and minor or localized problems in major crops; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee0b3003-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–3/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" factors limiting the availability of specific pest control methods, such as resistance to control methods and regulatory actions limiting the availability of control methods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee0b3004-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture shall, not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":", and annually thereafter, prepare a report and send the report to the Administrator. The report shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee0b3005-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–3/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain the information described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee0b3006-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–3/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the crucial pest control needs where a shortage of control methods is indicated by the information described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee0b3007-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–3/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe in detail research and extension efforts designed to address the needs identified in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee0b3008-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated pest management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, in cooperation with the Secretary of Agriculture, shall develop approaches to the control of pests based on integrated pest management that respond to the needs of producers, with a special emphasis on minor pests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee0b3009-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public health pests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, in coordination with the Secretary of Agriculture and the Secretary of Health and Human Services, shall identify pests of significant public health importance and, in coordination with the Public Health Service, develop and implement programs to improve and facilitate the safe and necessary use of chemical, biological, and other methods to combat and control such pests of public health importance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee0b300a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-25/ch125/s28"},"text":"June 25, 1947, ch. 125, § 28","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/396/s24/2"},"text":"Pub. L. 95–396, § 24(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/838"},"text":"92 Stat. 838","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIV/s1495"},"text":"Pub. L. 101–624, title XIV, § 1495","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3629"},"text":"104 Stat. 3629","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s862/b/1"},"text":"Pub. L. 104–127, title VIII, § 862(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1174"},"text":"110 Stat. 1174","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/170/tII/s236"},"text":"Pub. L. 104–170, title II, § 236","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-03"},"text":"Aug. 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1509"},"text":"110 Stat. 1509","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee0b300b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee0b300c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee0b300d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" struck out “and the information required by "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s5882"},"text":"section 5882 of this title","children":[],"tail":"” after “paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/170"},"text":"Pub. L. 104–170","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" designated existing provisions as subsec. (a) and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
