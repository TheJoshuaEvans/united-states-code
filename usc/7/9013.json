{"tag":"section","attrib":{"id":"idf0478bc0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013"},"text":null,"children":[{"tag":"num","attrib":{"value":"9013"},"text":"§ 9013.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment yields","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0478bc1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of making price loss coverage payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9016"},"text":"section 9016 of this title","children":[],"tail":", the Secretary shall provide for the establishment of a yield for each farm for any designated oilseed for which a payment yield was not established under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8712"},"text":"section 8712 of this title","children":[],"tail":" in accordance with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0478bc2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment yields for designated oilseeds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0478bc3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of average yield","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of oilseeds designated before ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", the Secretary shall determine the average yield per planted acre for the designated oilseed on a farm for the 1998 through 2001 crop years, excluding any crop year in which the acreage planted to the designated oilseed was zero."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0478bc4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment for payment yield","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0478bc5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The payment yield for a farm for an oilseed designated before ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", shall be equal to the product of the following:"}],"tail":null},{"tag":"clause","attrib":{"id":"idf0478bc6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average yield for the designated oilseed determined under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0478bc7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The ratio resulting from dividing the national average yield for the designated oilseed for the 1981 through 1985 crops by the national average yield for the designated oilseed for the 1998 through 2001 crops.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0478bc8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No national average yield information available","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that national average yield information for an oilseed designated before ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", is not available, the Secretary shall use such information as the Secretary determines to be fair and equitable to establish a national average yield under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0478bc9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of county average yield","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the yield per planted acre for a crop of an oilseed designated before ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", for a farm for any of the 1998 through 2001 crop years was less than 75 percent of the county yield for that designated oilseed, the Secretary shall assign a yield for that crop year equal to 75 percent of the county yield for the purpose of determining the average under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0478bca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of oilseeds designated after certain date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of oilseeds designated on or after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", the payment yield shall be equal to 90 percent of the average of the yield per planted acre for the most recent 5 crop years, as determined by the Secretary, excluding any crop year in which the acreage planted to the covered commodity was zero."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0478bcb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of lack of payment yield","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0478bcc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a covered commodity on a farm for which base acres have been established or that is planted on generic base acres, if no payment yield is otherwise established for the covered commodity on the farm, the Secretary shall establish an appropriate payment yield for the covered commodity on the farm under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0478bcd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of similarly situated farms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To establish an appropriate payment yield for a covered commodity on a farm as required by paragraph (1), the Secretary shall take into consideration the farm program payment yields applicable to that covered commodity for similarly situated farms. The use of such data in an appeal, by the Secretary or by the producer, shall not be subject to any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0478bce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single opportunity to update yields","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0478bcf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to update","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the sole discretion of the owner of a farm, the owner of a farm shall have a 1-time opportunity to update, on a covered-commodity-by-covered-commodity basis, the payment yield that would otherwise be used in calculating any price loss coverage payment for each covered commodity on the farm for which the election is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0478bd0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of updating yields for covered commodities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the owner of a farm elects to update yields under paragraph (1), the payment yield for a covered commodity on the farm, for the purpose of calculating price loss coverage payments only, shall be equal to the product obtained by multiplying—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0478bd1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 percent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0478bd2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average of the yield per planted acre for the crop of covered commodities on the farm for the 2013 through 2017 crop years, as determined by the Secretary, excluding any crop year in which the acreage planted to the covered commodity was zero; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0478bd3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to paragraph (3), the ratio obtained by dividing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0478bd4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average of the 2008 through 2012 national average yield per planted acre for the covered commodity, as determined by the Secretary; by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0478bd5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average of the 2013 through 2017 national average yield per planted acre for the covered commodity, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0478bd6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In no case shall the ratio obtained under paragraph (2)(C) be less than 90 percent or greater than 100 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0478bd7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of county average yield","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of determining the average yield per planted acre under paragraph (2)(B), if the yield per planted acre for a crop of a covered commodity for a farm for any of the crop years described in that subparagraph was less than 75 percent of the average of county yields for those crop years for that commodity, the Secretary shall assign a yield for that crop year equal to 75 percent of the average of the 2013 through 2017 county yield for the covered commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0478bd8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Upland cotton conversion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of seed cotton, for purposes of determining the average of the yield per planted acre under this subsection, the average yield for seed cotton per planted acre shall be equal to 2.4 times the average yield for upland cotton per planted acre.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0478bd9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under this subsection shall be made at a time and manner so as to be in effect beginning with the 2020 crop year, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0478bda-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment yield for seed cotton","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0478bdb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment yield","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the payment yield for seed cotton for a farm shall be equal to 2.4 times the payment yield for upland cotton for the farm established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8714/e/3"},"text":"section 8714(e)(3) of this title","children":[],"tail":" (as in effect on "},{"tag":"date","attrib":{"date":"2013-09-30"},"text":"September 30, 2013","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0478bdc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9013/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Update","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the sole discretion of the owner of a farm with a yield for upland cotton described in paragraph (1), the owner of the farm shall have a 1-time opportunity to update the payment yield for upland cotton for the farm, as provided in subsection (d), for the purpose of calculating the payment yield for seed cotton under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0478bdd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1113"},"text":"Pub. L. 113–79, title I, § 1113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/664"},"text":"128 Stat. 664","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dF/s60101/a/4"},"text":"Pub. L. 115–123, div. F, § 60101(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/308"},"text":"132 Stat. 308","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI/s1103"},"text":"Pub. L. 115–334, title I, § 1103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4501"},"text":"132 Stat. 4501","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0478bde-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0478bdf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf0478be0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1103/a/1"},"text":"Pub. L. 115–334, § 1103(a)(1)","children":[],"tail":", substituted “oilseeds designated before "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":"” for “designated oilseeds”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1103/a/2"},"text":"Pub. L. 115–334, § 1103(a)(2)","children":[],"tail":", substituted “an oilseed designated before "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":",” for “a designated oilseed” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1103/a/3"},"text":"Pub. L. 115–334, § 1103(a)(3)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1103/b"},"text":"Pub. L. 115–334, § 1103(b)","children":[],"tail":", added subsec. (d) and struck out former subsec. (d) which consisted of pars. (1) to (4) relating to election to update payment yield, time for election, method of updating yields, and use of county average yield, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123"},"text":"Pub. L. 115–123","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf0478be1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf0478be2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123"},"text":"Pub. L. 115–123","children":[],"tail":" applicable beginning with the 2018 crop year, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/s60101/a/13"},"text":"section 60101(a)(13) of Pub. L. 115–123","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9011"},"text":"section 9011 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
