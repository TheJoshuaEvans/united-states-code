{"tag":"section","attrib":{"id":"ideedf6fbb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1636c"},"text":"§ 1636c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall not charge or assess a user fee, transaction fee, service charge, assessment, reimbursement, or any other fee for the submission or reporting of information, for the receipt or availability of, or access to, published reports or information, or for any other activity required under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideedf6fbc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 254, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tIX/s911/2"},"text":"Pub. L. 106–78, title IX, § 911(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1203"},"text":"113 Stat. 1203","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
