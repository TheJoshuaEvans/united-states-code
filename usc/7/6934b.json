{"tag":"section","attrib":{"id":"ideff41440-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934b"},"text":null,"children":[{"tag":"num","attrib":{"value":"6934b"},"text":"§ 6934b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural Youth Organization Coordinator","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff41441-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish in the Department the position of Agricultural Youth Organization Coordinator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff41442-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Agricultural Youth Organization Coordinator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff41443-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the role of youth-serving organizations and school-based agricultural education in motivating and preparing young people to pursue careers in the agriculture, food, and natural resources systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41444-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work to help build youth awareness of the reach and importance of agriculture, across a diversity of fields and disciplines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41445-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify short-term and long-term interests of the Department and provide opportunities, resources, input, and coordination with programs and agencies of the Department to youth-serving organizations and school-based agricultural education, including the development of internship opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41446-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" share, internally and externally, the extent to which active steps are being taken to encourage collaboration with, and support of, youth-serving organizations and school-based agricultural education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41447-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information to youth involved in food and agriculture organizations concerning the availability of, and eligibility requirements for, participation in agricultural programs, with particular emphasis on beginning farmer and rancher programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41448-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934b/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a resource for assisting youth involved in food and agriculture organizations in applying for participation in agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41449-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934b/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advocate on behalf of youth involved in food and agriculture organizations in interactions with employees of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff4144a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts and cooperative agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of carrying out the duties under subsection (b), the Agricultural Youth Organization Coordinator shall consult with the cooperative extension and the land-grant university systems, and may enter into contracts or cooperative agreements with the research centers of the Agricultural Research Service, cooperative extension and the land-grant university systems, non-land-grant colleges of agriculture, or nonprofit organizations for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff4144b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of regional research on the profitability of small farms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff4144c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of educational materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff4144d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of workshops, courses, and certified vocational training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff4144e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of mentoring activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff4144f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934b/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of internship opportunities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff41450-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7405"},"text":"Pub. L. 107–171, title VII, § 7405","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12305"},"text":"Pub. L. 115–334, title XII, § 12305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4967"},"text":"132 Stat. 4967","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideff41451-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideff41452-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ideff41453-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7405"},"text":"section 7405 of Pub. L. 107–171","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3319f"},"text":"section 3319f of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12301/a/1"},"text":"Pub. L. 115–334, title XII, § 12301(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4950"},"text":"132 Stat. 4950","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideff41454-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Farm Security and Rural Investment Act of 2002, and not as part of the Department of Agriculture Reorganization Act of 1994, which in part comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideff41455-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"ideff41456-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Department” means the Department of Agriculture and “Secretary” means the Secretary of Agriculture, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7401"},"text":"section 7401 of Pub. L. 107–171","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3319b"},"text":"section 3319b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
