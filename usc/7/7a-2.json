,"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idedcd3d40-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s749/c/1"},"text":"Pub. L. 111–203, § 749(c)(1)","children":[],"tail":", struck out “, 7a(d),” after “7(d)” and “and "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2/h/7"},"text":"section 2(h)(7) of this title","children":[],"tail":" with respect to significant price discovery contracts,” before “to describe”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s745/a"},"text":"Pub. L. 111–203, § 745(a)","children":[],"tail":", added par. (2) and struck out former par. (2). Prior to amendment, text read as follows: “An interpretation issued under paragraph (1) shall not provide the exclusive means for complying with such sections.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s745/b"},"text":"Pub. L. 111–203, § 745(b)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c) which related to new contracts, new rules, and rule amendments and Commission approval upon certification of compliance with this chapter."}],"tail":"\n"},{"t