{"tag":"section","attrib":{"id":"ideedd2556-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1635a"},"text":"§ 1635a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedd2557-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Base price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “base price” means the price paid for livestock, delivered at the packing plant, before application of any premiums or discounts, expressed in dollars per hundred pounds of carcass weight.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd2558-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis level","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “basis level” means the agreed-on adjustment to a future price to establish the final price paid for livestock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd2559-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current slaughter week","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “current slaughter week” means the period beginning Monday, and ending Sunday, of the week in which a reporting day occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd255a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" F.O.B.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “F.O.B.” means free on board, regardless of the mode of transportation, at the point of direct shipment by the seller to the buyer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd255b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Livestock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “livestock” means cattle, swine, and lambs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd255c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lot","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “lot” means a group of one or more livestock that is identified for the purpose of a single transaction between a buyer and a seller.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd255d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marketing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “marketing” means the sale or other disposition of livestock, livestock products, or meat or meat food products in commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd255e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiated purchase","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “negotiated purchase” means a cash or spot market purchase by a packer of livestock from a producer under which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedd255f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the base price for the livestock is determined by seller-buyer interaction and agreement on a day; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd2560-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the livestock are scheduled for delivery to the packer not later than 14 days after the date on which the livestock are committed to the packer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd2561-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiated sale","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “negotiated sale” means a cash or spot market sale by a producer of livestock to a packer under which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedd2562-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the base price for the livestock is determined by seller-buyer interaction and agreement on a day; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd2563-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the livestock are scheduled for delivery to the packer not later than 14 days after the date on which the livestock are committed to the packer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd2564-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior slaughter week","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “prior slaughter week” means the Monday through Sunday prior to a reporting day.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd2565-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “producer” means any person engaged in the business of selling livestock to a packer for slaughter (including the sale of livestock from a packer to another packer).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd2566-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting day","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “reporting day” means a day on which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedd2567-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635a/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a packer conducts business regarding livestock committed to the packer, or livestock purchased, sold, or slaughtered by the packer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd2568-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635a/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary is required to make information concerning the business described in subparagraph (A) available to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd2569-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635a/12/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Agriculture is open to conduct business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd256a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd256b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the 50 States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideedd256c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 212, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tIX/s911/2"},"text":"Pub. L. 106–78, title IX, § 911(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1188"},"text":"113 Stat. 1188","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
