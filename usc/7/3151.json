{"tag":"section","attrib":{"id":"idef9726f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151"},"text":null,"children":[{"tag":"num","attrib":{"value":"3151"},"text":"§ 3151.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to enhance research capacity in schools of veterinary medicine","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9726fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9726fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a program of competitive grants to States for the purpose of meeting the costs of renovation, improving compliance with Federal regulations, employing faculty, acquiring equipment, and taking other action related to the improvement of schools of veterinary medicine to ensure agricultural competitiveness on a worldwide basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9726fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State receiving a grant under paragraph (1) shall provide State matching funds equal to not less than the amount of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9726fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except with respect to the States of Alaska and Hawaii, the Secretary shall give preference in awarding grants to States which file, with their application for funds under this section, assurances satisfactory to the Secretary that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9726fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State has established a veterinary medical training program with one or more States without colleges of veterinary medicine which consists of appropriate cooperative agreements providing for a sharing of curriculum and costs by the individual States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9726ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the clinical training of the school to be improved shall emphasize care and preventive medical programs for food animals and companion animals (including horses) which support industries of major economic importance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef972700-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may set aside a portion of funds appropriated for the award of grants under this section and make such amounts available only for grants to eligible colleges and universities that the Secretary determines have unique capabilities for achieving the objective of full participation of minority groups in research in the Nation’s schools of veterinary medicine.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Notwithstanding clause (1) of this subsection, no State which the Secretary determines has made a reasonable effort to establish appropriate cooperative agreements shall be denied a grant or otherwise prejudiced because of its failure to establish such cooperative agreements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef972701-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apportionment and distribution of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds appropriated to carry out this section for any fiscal year shall be apportioned and distributed as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef972702-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Five per centum shall be retained by the Department of Agriculture for administration, program assistance to eligible States, and program coordination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef972703-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The remainder shall be apportioned and distributed by the Secretary to those States which have applied for funds under this section on such basis as the Secretary may deem appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef972704-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1415"},"text":"Pub. L. 95–113, title XIV, § 1415","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/993"},"text":"91 Stat. 993","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXIV/s1417"},"text":"Pub. L. 97–98, title XIV, § 1417","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1305"},"text":"95 Stat. 1305","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXIV/s1410"},"text":"Pub. L. 99–198, title XIV, § 1410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1547"},"text":"99 Stat. 1547","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1607/a"},"text":"Pub. L. 101–624, title XVI, § 1607(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3716"},"text":"104 Stat. 3716","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7128/b/1/A"},"text":"Pub. L. 113–79, title VII, § 7128(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/878"},"text":"128 Stat. 878","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7614/b/1/A"},"text":"Pub. L. 115–334, title VII, § 7614(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4833"},"text":"132 Stat. 4833","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef972705-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef972706-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef972707-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" struck out “This grant program shall be based on a matching formula of 50 per centum Federal and 50 per centum State funding.” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1607/b/1"},"text":"Pub. L. 101–624, § 1607(b)(1)","children":[],"tail":", amended section catchline generally."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1607/b/1"},"text":"Pub. L. 101–624, § 1607(b)(1)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1607/a/1"},"text":"Pub. L. 101–624, § 1607(a)(1)","children":[],"tail":", amended first sentence generally. Prior to amendment, first sentence read as follows: “The Secretary shall conduct a program of grants to States for the purpose of meeting the costs of construction, employing faculty, acquiring equipment, and taking other action relating to the initial establishment and initial operation of schools of veterinary medicine, or the expansion of existing schools of veterinary medicine, as determned [sic] by the Secretary by regulations.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1607/b/2"},"text":"Pub. L. 101–624, § 1607(b)(2)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1607/a/2"},"text":"Pub. L. 101–624, § 1607(a)(2)","children":[],"tail":", struck out “, or has made a reasonable effort to establish,” after “established”, and “and” after “States;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1607/a/3"},"text":"Pub. L. 101–624, § 1607(a)(3)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “the clinical training of the school to be established or expanded shall emphasize care and preventive medical programs for food-producing animals.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1607/a/3"},"text":"Pub. L. 101–624, § 1607(a)(3)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1607/b/3"},"text":"Pub. L. 101–624, § 1607(b)(3)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":" substituted “Five” for “Four”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98"},"text":"Pub. L. 97–98","children":[],"tail":" struck out proviso that not less than 50 per centum of such funds shall be made available to States which have accredited schools of veterinary medicine."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef972708-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef972709-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7614/c"},"text":"Pub. L. 115–334, title VII, § 7614(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4837"},"text":"132 Stat. 4837","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/334/tVII/s7614/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Awards made after date of enactment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsections (a) [repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3371"},"text":"section 3371 of this title","children":[],"tail":"] and (b) [amending this section and sections 3157, 3322, 3333, 5813, 5924, 5925, 5925b, 7626, 7632, and 8114 of this title] shall apply with respect to grants, cooperative agreements, or other awards described in subsection (b) that are made after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Awards made on or before date of enactment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding the amendments made by subsections (a) and (b), a matching funds requirement in effect on the day before the date of enactment of this Act under a provision of law amended by subsection (a) or (b) shall continue to apply to a grant, cooperative agreement, or other award described in subsection (b) that is made on or before the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef97270a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7128/c/2"},"text":"Pub. L. 113–79, title VII, § 7128(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/879"},"text":"128 Stat. 879","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/79/tVII/s7128/c/2"},"text":"“Notwithstanding the amendments made by subsection (b) [amending this section and sections 3157, 3322, 3333, 5813, 5924, 5925, 5925b, 7626, 7632, and 8114 of this title], a matching funds requirement in effect on or before the date of the enactment of this section [","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":"] under a provision of a covered law shall continue to apply to a grant awarded under such provision on or before "},{"tag":"date","attrib":{"date":"2014-10-01"},"text":"October 1, 2014","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef97270b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98"},"text":"Pub. L. 97–98","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1801"},"text":"section 1801 of Pub. L. 97–98","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idef97270c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/s1901"},"text":"section 1901 of Pub. L. 95–113","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1307"},"text":"section 1307 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
