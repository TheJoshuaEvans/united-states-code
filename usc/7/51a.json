{"tag":"section","attrib":{"id":"idede509ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s51a"},"text":null,"children":[{"tag":"num","attrib":{"value":"51a"},"text":"§ 51a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of classification facilities to cotton growers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture is requested to extend to cotton growers facilities for the classification of cotton authorized in this chapter, with such supervision of licensed classifiers as he shall deem necessary under authority of the United States Cotton Futures Act.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idede509f0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-03-04/ch284/s1"},"text":"Mar. 4, 1933, ch. 284, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/1621"},"text":"47 Stat. 1621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idede509f1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idede509f2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idede509f3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The United States Cotton Futures Act, referred to in text, is part A of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"act Aug. 11, 1916, ch. 313","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/476"},"text":"39 Stat. 476","children":[],"tail":", which was repealed by section 4 of "},{"tag":"ref","attrib":{"href":"/us/act/1939-02-10/ch2"},"text":"act Feb. 10, 1939, ch. 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1"},"text":"53 Stat. 1","children":[],"tail":". For complete classification of this Act to the Code prior to its repeal, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idede509f4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section was not enacted as part of the United States Cotton Standards Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
