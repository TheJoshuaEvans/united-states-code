{"tag":"section","attrib":{"id":"idefe5bc76-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6513"},"text":null,"children":[{"tag":"num","attrib":{"value":"6513"},"text":"§ 6513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organic plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe5bc77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A producer or handler seeking certification under this chapter shall submit an organic plan to the certifying agent and the State organic certification program (if applicable), and such plan shall be reviewed by the certifying agent who shall determine if such plan meets the requirements of the programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crop production farm plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bc79-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6513/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Soil fertility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An organic plan shall contain provisions designed to foster soil fertility, primarily through the management of the organic content of the soil through proper tillage, crop rotation, and manuring.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc7a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6513/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manuring","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe5bc7b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6513/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion in organic plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An organic plan shall contain terms and conditions that regulate the application of manure to crops.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bc7c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6513/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of manure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such organic plan may provide for the application of raw manure only to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefe5bc7d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6513/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any green manure crop;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe5bc7e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6513/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any perennial crop;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe5bc7f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6513/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any crop not for human consumption; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe5bc80-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6513/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any crop for human consumption, if such crop is harvested after a reasonable period of time determined by the certifying agent to ensure the safety of such crop, after the most recent application of raw manure, but in no event shall such period be less than 60 days after such application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bc81-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6513/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contamination by manure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such organic plan shall prohibit raw manure from being applied to any crop in a way that significantly contributes to water contamination by nitrates or bacteria.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc82-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6513/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Livestock plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An organic livestock plan shall contain provisions designed to foster the organic production of livestock consistent with the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc83-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6513/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mixed crop livestock production","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An organic plan may encompass both the crop production and livestock production requirements in subsections (b) and (c) if both activities are conducted by the same producer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc84-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6513/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Handling plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An organic handling plan shall contain provisions designed to ensure that agricultural products that are sold or labeled as organically produced are produced and handled in a manner that is consistent with the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc85-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6513/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of wild crops","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An organic plan for the harvesting of wild crops shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bc86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6513/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate the area from which the wild crop will be gathered or harvested;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc87-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6513/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a 3 year history of the management of the area showing that no prohibited substances have been applied;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6513/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a plan for the harvesting or gathering of the wild crops assuring that such harvesting or gathering will not be destructive to the environment and will sustain the growth and production of the wild crop; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6513/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include provisions that no prohibited substances will be applied by the producer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6513/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on content of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An organic plan shall not include any production or handling practices that are inconsistent with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe5bc8b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXI/s2114"},"text":"Pub. L. 101–624, title XXI, § 2114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3943"},"text":"104 Stat. 3943","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
