{"tag":"section","attrib":{"id":"idef18a88f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1983c"},"text":"§ 1983c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of information to borrowers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef18a890-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On request of a farm borrower of a farmer program loan, the Secretary shall make available to the borrower the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef18a891-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One copy of each document signed by the borrower.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef18a892-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One copy of each appraisal performed with respect to the loan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef18a893-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All documents that the Secretary otherwise is required to provide to the borrower under any law or rule of law in effect on the date of such request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef18a894-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1983c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not be construed to supersede any duty imposed on the Secretary by any law or rule of law in effect immediately before ","children":[{"tag":"date","attrib":{"date":"1988-01-06"},"text":"January 6, 1988","children":[],"tail":", unless such duty is in direct conflict with any duty imposed by subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef18a895-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s333C"},"text":"Pub. L. 87–128, title III, § 333C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVI/s609"},"text":"Pub. L. 100–233, title VI, § 609","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1668"},"text":"101 Stat. 1668","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
