{"tag":"section","attrib":{"id":"ideff41411-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6934a"},"text":"§ 6934a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beginning farmer and rancher coordination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff41412-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff41413-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beginning farmer or rancher","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “beginning farmer or rancher” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279/a"},"text":"section 2279(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41414-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Coordinator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Coordinator” means the National Beginning Farmer and Rancher Coordinator established under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41415-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State coordinator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State coordinator” means a State beginning farmer and rancher coordinator designated under subsection (c)(1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41416-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State office","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State office” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff41417-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a State office of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff41418-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Farm Service Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff41419-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Natural Resources Conservation Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff4141a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/a/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Rural Business-Cooperative Service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff4141b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/a/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Rural Utilities Service; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff4141c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regional office of the Risk Management Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff4141d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Beginning Farmer and Rancher Coordinator","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff4141e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish in the Department the position of National Beginning Farmer and Rancher Coordinator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff4141f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff41420-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Coordinator shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff41421-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary and coordinate activities of the Department on programs, policies, and issues relating to beginning farmers and ranchers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff41422-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the applicable State food and agriculture council, determine whether to approve a plan submitted by a State coordinator under subsection (c)(3)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff41423-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Additional duties of the National Coordinator may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff41424-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" developing and implementing new strategies—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ideff41425-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/b/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for outreach to beginning farmers and ranchers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideff41426-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/b/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist beginning farmers and ranchers with connecting to owners or operators that have ended, or expect to end within 5 years, actively owning or operating a farm or ranch; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff41427-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating interagency and interdepartmental collaboration on issues relating to beginning farmers and ranchers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41428-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less frequently than once each year, the National Coordinator shall distribute within the Department and make publicly available a report describing the status of steps taken to carry out the duties described in subparagraphs (A) and (B) of paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41429-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts and cooperative agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the duties under paragraph (2), the National Coordinator may enter into a contract or cooperative agreement with an institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":"), cooperative extension services (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3103"},"text":"section 3103 of this title","children":[],"tail":"), or a nonprofit organization—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff4142a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct research on the profitability of new farms in operation for not less than 5 years in a region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff4142b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop educational materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff4142c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct workshops, courses, training, or certified vocational training; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff4142d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct mentoring activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff4142e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State beginning farmer and rancher coordinators","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff4142f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff41430-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Coordinator, in consultation with State food and agriculture councils and directors of State offices, shall designate in each State a State beginning farmer and rancher coordinator from among employees of State offices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff41431-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be designated as a State coordinator, an employee shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff41432-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be familiar with issues relating to beginning farmers and ranchers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff41433-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the ability to coordinate with other Federal departments and agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41434-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop a training plan to provide to each State coordinator knowledge of programs and services available from the Department for beginning farmers and ranchers, taking into consideration the needs of all production types and sizes of agricultural operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41435-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State coordinator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff41436-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate technical assistance at the State level to assist beginning farmers and ranchers in accessing programs of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff41437-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and submit to the National Coordinator for approval under subsection (b)(2)(A)(ii) a State plan to improve the coordination, delivery, and efficacy of programs of the Department to beginning farmers and ranchers, taking into consideration the needs of all types of production methods and sizes of agricultural operation, at each county and area office in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff41438-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee implementation of an approved State plan described in subparagraph (B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff41439-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with outreach coordinators in the State offices to ensure appropriate information about technical assistance is available at outreach events and activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff4143a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934a/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate partnerships and joint outreach efforts with other organizations and government agencies serving beginning farmers and ranchers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff4143b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7404"},"text":"Pub. L. 107–171, title VII, § 7404","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12304"},"text":"Pub. L. 115–334, title XII, § 12304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4965"},"text":"132 Stat. 4965","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideff4143c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideff4143d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ideff4143e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7404"},"text":"section 7404 of Pub. L. 107–171","children":[],"tail":" was classified as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3101"},"text":"section 3101 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7506"},"text":"Pub. L. 115–334, title VII, § 7506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4823"},"text":"132 Stat. 4823","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideff4143f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Farm Security and Rural Investment Act of 2002, and not as part of the Department of Agriculture Reorganization Act of 1994, which in part comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
