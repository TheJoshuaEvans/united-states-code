{"tag":"section","attrib":{"id":"ideffdb1bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7214"},"text":null,"children":[{"tag":"num","attrib":{"value":"7214"},"text":"§ 7214.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of contract payments under contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideffdb1bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7214/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual payment quantity of contract commodities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each contract, the payment quantity of a contract commodity for each fiscal year shall be equal to the product of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffdb1be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7214/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 85 percent of the contract acreage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb1bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7214/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the farm program payment yield.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffdb1c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7214/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual payment quantity of contract commodities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The payment quantity of each contract commodity covered by all contracts for each fiscal year shall be equal to the sum of the amounts calculated under subsection (a) for each individual contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffdb1c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7214/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual payment rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The payment rate for a contract commodity for each fiscal year shall be equal to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffdb1c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7214/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7213"},"text":"section 7213 of this title","children":[],"tail":" for the contract commodity for the fiscal year; divided by"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb1c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7214/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under subsection (b) for the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffdb1c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7214/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual payment amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount to be paid under a contract in effect for each fiscal year with respect to all contract commodities covered by the contract shall be equal to the sum of the products of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffdb1c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7214/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment quantity determined under subsection (a) for each of the contract commodities covered by the contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb1c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7214/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the corresponding payment rate for the contract commodity in effect under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffdb1c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7214/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction in payment amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The contract payment determined under subsection (d) for an owner or producer for a fiscal year shall be immediately reduced by the amount of any repayment of deficiency payments that is required under section 114(a)(2) of the Agricultural Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1445j/a/2"},"text":"7 U.S.C. 1445j(a)(2)","children":[],"tail":") and is not repaid as of the date the contract payment is determined. The Secretary shall be required to collect the required repayment, or any claim based on the required repayment, as soon as the contract payment is determined."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffdb1c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7214/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment of contract payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s590h/g"},"text":"section 590h(g) of title 16","children":[],"tail":" (relating to assignment of payments) shall apply to contract payments under this section. The owner or producer making the assignment, or the assignee, shall provide the Secretary with notice, in such manner as the Secretary may require in the contract, of any assignment made under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffdb1c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7214/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sharing of contract payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for the sharing of contract payments among the owners and producers subject to the contract on a fair and equitable basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideffdb1ca-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s114"},"text":"Pub. L. 104–127, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/901"},"text":"110 Stat. 901","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
