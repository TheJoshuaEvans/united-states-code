{"tag":"section","attrib":{"id":"idef676468-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2036d"},"text":"§ 2036d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot projects to encourage the use of public-private partnerships committed to addressing food insecurity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef676469-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, on application of eligible entities, approve not more than 10 pilot projects to support public-private partnerships that address food insecurity and poverty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef67646a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef67646b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef67646c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036d/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef67646d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036d/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a community-based organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef67646e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036d/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef67646f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036d/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private entity, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef676470-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “public agency” means a department, agency, other unit, or instrumentality of Federal, State, or local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef676471-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Projects approved under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef676472-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be limited to 2 years in length; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef676473-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include a collaboration between one or more public agencies and one or more eligible entities that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef676474-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036d/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improves the effectiveness and impact of the supplemental nutrition assistance program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef676475-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036d/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develops food security solutions that are specific to the needs of a community or region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef676476-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036d/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthens the capacity of communities to address food insecurity and poverty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef676477-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide for an independent evaluation of pilot projects approved under this section that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef676478-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the activities conducted under the pilot projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef676479-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the effectiveness of the pilot projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef67647a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036d/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" best practices regarding the use of public-private partnerships to improve the effectiveness of public benefit programs to address food insecurity and poverty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef67647b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef67647c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $5,000,000 to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef67647d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation in advance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Only funds appropriated under paragraph (1) in advance specifically to carry out this section shall be available to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef67647e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/525/s30"},"text":"Pub. L. 88–525, § 30","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIV/s4021"},"text":"Pub. L. 115–334, title IV, § 4021","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4652"},"text":"132 Stat. 4652","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
