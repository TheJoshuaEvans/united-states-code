{"tag":"section","attrib":{"id":"idef9e2c70-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3193"},"text":null,"children":[{"tag":"num","attrib":{"value":"3193"},"text":"§ 3193.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization to Secretary of Agriculture","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9e2c71-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3193/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to cooperate with, encourage, and assist States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to carry out the purpose of this subchapter, the Secretary is authorized to cooperate with, encourage, and assist the States in carrying out programs of animal health and disease research at eligible institutions under sections 3195(a) and 3196 of this title in the manner hereinafter described in this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9e2c72-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3193/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study of animal care delivery system","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9e2c73-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3193/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall commission the National Academy of Sciences, working through the Board on Agriculture of the National Research Council, to conduct a study of the delivery system utilized to provide farmers, including small and limited resource farmers, and ranchers with animal care and veterinary medical services, including animal drugs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9e2c74-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3193/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The study required by this subsection shall assess opportunities to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9e2c75-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3193/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the flow of information to producers regarding animal husbandry practices, and diagnostic and treatment methods, including the costs and conditions necessary for the effective use of such practices and methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9e2c76-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3193/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster achievement of food safety goals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9e2c77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3193/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance the well-being and treatment of farm animals, with particular emphasis on disease prevention strategies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9e2c78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3193/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The study required by this subsection shall include recommendations for changes in research and extension policies or priorities, food safety programs and policies, and policies and procedures governing the approval, use, and monitoring of animal drugs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9e2c79-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1431"},"text":"Pub. L. 95–113, title XIV, § 1431","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1002"},"text":"91 Stat. 1002","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1611/a"},"text":"Pub. L. 101–624, title XVI, § 1611(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3720"},"text":"104 Stat. 3720","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7111/b/3/A"},"text":"Pub. L. 113–79, title VII, § 7111(b)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/874"},"text":"128 Stat. 874","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9e2c7a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef9e2c7b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef9e2c7c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" inserted “under sections 3195(a) and 3196 of this title” after “eligible institutions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" amended section catchline generally, designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef9e2c7d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idef9e2c7e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/s1901"},"text":"section 1901 of Pub. L. 95–113","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1307"},"text":"section 1307 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
