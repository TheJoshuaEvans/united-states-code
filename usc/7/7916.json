{"tag":"section","attrib":{"id":"idf026202f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7916"},"text":null,"children":[{"tag":"num","attrib":{"value":"7916"},"text":"§ 7916.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planting flexibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0262030-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7916/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitted crops","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), any commodity or crop may be planted on base acres on a farm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0262031-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7916/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations regarding certain commodities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0262032-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7916/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The planting of an agricultural commodity specified in paragraph (3) shall be prohibited on base acres unless the commodity, if planted, is destroyed before harvest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0262033-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7916/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of trees and other perennials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The planting of an agricultural commodity specified in paragraph (3) that is produced on a tree or other perennial plant shall be prohibited on base acres.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0262034-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7916/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered agricultural commodities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraphs (1) and (2) apply to the following agricultural commodities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0262035-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7916/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fruits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0262036-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7916/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Vegetables (other than lentils, mung beans, and dry peas).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0262037-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7916/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Wild rice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0262038-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7916/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraphs (1) and (2) of subsection (b) shall not limit the planting of an agricultural commodity specified in paragraph (3) of that subsection—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0262039-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7916/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any region in which there is a history of double-cropping of covered commodities with agricultural commodities specified in subsection (b)(3), as determined by the Secretary, in which case the double-cropping shall be permitted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf026203a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7916/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a farm that the Secretary determines has a history of planting agricultural commodities specified in subsection (b)(3) on base acres, except that direct payments and counter-cyclical payments shall be reduced by an acre for each acre planted to such an agricultural commodity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf026203b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7916/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" by the producers on a farm that the Secretary determines has an established planting history of a specific agricultural commodity specified in subsection (b)(3), except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf026203c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7916/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity planted may not exceed the average annual planting history of such agricultural commodity by the producers on the farm in the 1991 through 1995 or 1998 through 2001 crop years (excluding any crop year in which no plantings were made), as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf026203d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7916/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct payments and counter-cyclical payments shall be reduced by an acre for each acre planted to such agricultural commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf026203e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7916/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for 2002 crop year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the 2002 crop year only, if the calculation of base acres under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7911/a"},"text":"section 7911(a) of this title","children":[],"tail":" results in total base acres for a farm in excess of the contract acreage (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7202"},"text":"section 7202 of this title","children":[],"tail":") for the farm used to calculate the fiscal year 2002 payment authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7214"},"text":"section 7214 of this title","children":[],"tail":", paragraphs (1) and (2) of subsection (b) shall not limit the harvesting of an agricultural commodity specified in paragraph (3) of that subsection on the excess base acres, except that direct payments and counter-cyclical payments for the 2002 crop year shall be reduced by an acre for each acre of the excess base acres planted to such an agricultural commodity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf026203f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1106"},"text":"Pub. L. 107–171, title I, § 1106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/153"},"text":"116 Stat. 153","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
