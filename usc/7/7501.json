{"tag":"section","attrib":{"id":"idf00e53cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7501"},"text":null,"children":[{"tag":"num","attrib":{"value":"7501"},"text":"§ 7501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00e53cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional commodities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “additional commodities” means commodities made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7515"},"text":"section 7515 of this title","children":[],"tail":" in addition to the commodities made available under sections 7502 and 7507 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Average monthly number of unemployed persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “average monthly number of unemployed persons” means the average monthly number of unemployed persons in each State during the most recent fiscal year for which information concerning the number of unemployed persons is available, as determined by the Bureau of Labor Statistics of the Department of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible recipient agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible recipient agency” means a public or nonprofit organization that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00e53cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7501/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" administers—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf00e53d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7501/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an emergency feeding organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf00e53d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7501/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a charitable institution (including a hospital and a retirement home, but excluding a penal institution) to the extent that the institution serves needy persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf00e53d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7501/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summer camp for children, or a child nutrition program providing food service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf00e53d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7501/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nutrition project operating under the Older Americans Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"42 U.S.C. 3001","children":[],"tail":" et seq.), including a project that operates a congregate nutrition site and a project that provides home-delivered meals; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf00e53d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7501/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a disaster relief program;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00e53d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7501/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been designated by the appropriate State agency, or by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00e53d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7501/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been approved by the Secretary for participation in the program established under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7501/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency feeding organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “emergency feeding organization” means a public or nonprofit organization that administers activities and projects (including the activities and projects of a charitable institution, a food bank, a food pantry, a hunger relief center, a soup kitchen, or a similar public or private nonprofit eligible recipient agency) providing nutrition assistance to relieve situations of emergency and distress through the provision of food to needy persons, including low-income and unemployed persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7501/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “food bank” means a public or charitable institution that maintains an established operation involving the provision of food or edible commodities, or the products of food or edible commodities, to food pantries, soup kitchens, hunger relief centers, or other food or feeding centers that, as an integral part of their normal activities, provide meals or food to feed needy persons on a regular basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7501/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food pantry","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “food pantry” means a public or private nonprofit organization that distributes food to low-income and unemployed households, including food from sources other than the Department of Agriculture, to relieve situations of emergency and distress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7501/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Poverty line","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “poverty line” has the meaning provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9902/2"},"text":"section 9902(2) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7501/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Soup kitchen","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “soup kitchen” means a public or charitable institution that, as an integral part of the normal activities of the institution, maintains an established feeding operation to provide food to needy homeless persons on a regular basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7501/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Total value of additional commodities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “total value of additional commodities” means the actual cost of all additional commodities that are paid by the Secretary (including the distribution and processing costs incurred by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7501/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Value of additional commodities allocated to each State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “value of additional commodities allocated to each State” means the actual cost of additional commodities allocated to each State that are paid by the Secretary (including the distribution and processing costs incurred by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf00e53de-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/8/tII/s201A"},"text":"Pub. L. 98–8, title II, § 201A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/92/s2/2"},"text":"Pub. L. 98–92, § 2(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-02"},"text":"Sept. 2, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/608"},"text":"97 Stat. 608","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXV/s1563"},"text":"Pub. L. 99–198, title XV, § 1563","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1590"},"text":"99 Stat. 1590","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tVIII/s871/a"},"text":"Pub. L. 104–193, title VIII, § 871(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2343"},"text":"110 Stat. 2343","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf00e53df-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf00e53e0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf00e53e1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning the Emergency Food Assistance Act of 1983, title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/8"},"text":"Pub. L. 98–8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-03-24"},"text":"Mar. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/35"},"text":"97 Stat. 35","children":[],"tail":", which enacted this chapter and amended provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s612c"},"text":"section 612c of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out below and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Older Americans Act of 1965, referred to in par. (3)(A)(iv), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73"},"text":"Pub. L. 89–73","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-14"},"text":"July 14, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/218"},"text":"79 Stat. 218","children":[],"tail":", which is classified generally to chapter 35 (§ 3001 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf00e53e2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":" amended section generally, substituting provisions containing an opening provision and pars. (1) to (10) defining “additional commodities”, “average monthly number of unemployed persons”, “eligible recipient agency”, “emergency feeding organization”, “food bank”, “food pantry”, “poverty line”, “soup kitchen”, “total value of additional commodities”, and “value of additional commodities allocated to each state” for an opening provision and pars. (1) to (6) defining “eligible recipient agencies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":" inserted before semicolon at end “(including the activities and projects of charitable institutions, food banks, hunger centers, soup kitchens, and similar public or private nonprofit eligible recipient agencies) hereinafter in this chapter referred to as ‘emergency feeding organizations’ ”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf00e53e3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf00e53e4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/92/s2"},"text":"Pub. L. 98–92, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-02"},"text":"Sept. 2, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/608"},"text":"97 Stat. 608","children":[],"tail":", provided in part that the amendments made by section 2 are effective "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"Oct. 1, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idf00e53e5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/8/tII/s201"},"text":"Pub. L. 98–8, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-03-24"},"text":"Mar. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/35"},"text":"97 Stat. 35","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/98/92/s2/1"},"text":"Pub. L. 98–92, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-02"},"text":"Sept. 2, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/608"},"text":"97 Stat. 608","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVII/s1772/a/2"},"text":"Pub. L. 101–624, title XVII, § 1772(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3808"},"text":"104 Stat. 3808","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/624/tXVII/s1772/a/2"},"text":"“This title [enacting this chapter and amending provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s612c"},"text":"section 612c of this title","children":[],"tail":"] may be cited as the ‘Emergency Food Assistance Act of 1983’, and is hereinafter in this title referred to as ‘this Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf00e53e6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Food Supply Chain and Agriculture Pandemic Response","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/tI/s1001"},"text":"Pub. L. 117–2, title I, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/10"},"text":"135 Stat. 10","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/2/tI/s1001"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated to the Secretary of Agriculture for fiscal year 2021, out of any money in the Treasury not otherwise appropriated, $4,000,000,000, to remain available until expended, to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture shall use the amounts made available pursuant to subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to purchase food and agricultural commodities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to purchase and distribute agricultural commodities (including fresh produce, dairy, seafood, eggs, and meat) to individuals in need, including through delivery to nonprofit organizations and through restaurants and other food related entities, as determined by the Secretary, that may receive, store, process, and distribute food items;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make grants and loans for small or midsized food processors or distributors, seafood processing facilities and processing vessels, farmers markets, producers, or other organizations to respond to COVID–19, including for measures to protect workers against COVID–19; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make loans and grants and provide other assistance to maintain and improve food and agricultural supply chain resiliency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Animal Health.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"COVID–","children":[],"tail":"19"},{"tag":"inline","attrib":{},"text":" animal surveillance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Agriculture shall conduct monitoring and surveillance of susceptible animals for incidence of SARS–CoV–2.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Out of the amounts made available under subsection (a), the Secretary shall use $300,000,000 to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Overtime Fees.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Small establishment; very small establishment definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms ‘small establishment’ and ‘very small establishment’ have the meaning given those terms in the final rule entitled ‘Pathogen Reduction; Hazard Analysis and Critical Control Point (HACCP) Systems’ published in the Federal Register on ","children":[{"tag":"date","attrib":{"date":"1996-07-25"},"text":"July 25, 1996","children":[],"tail":" (61 Fed. Reg. 38806)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Overtime inspection cost reduction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 10703 of the Farm Security and Rural Investment Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2219a"},"text":"7 U.S.C. 2219a","children":[],"tail":"), the Act of "},{"tag":"date","attrib":{"date":"1948-06-05"},"text":"June 5, 1948","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s695"},"text":"21 U.S.C. 695","children":[],"tail":"), section 25 of the Poultry Products Inspection Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s468"},"text":"21 U.S.C. 468","children":[],"tail":"), and section 24 of the Egg Products Inspection Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1053"},"text":"21 U.S.C. 1053","children":[],"tail":"), and any regulations promulgated by the Department of Agriculture implementing such provisions of law and subject to the availability of funds under paragraph (3), the Secretary of Agriculture shall reduce the amount of overtime inspection costs borne by federally-inspected small establishments and very small establishments engaged in meat, poultry, or egg products processing and subject to the requirements of the Federal Meat Inspection Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s601"},"text":"21 U.S.C. 601","children":[],"tail":" et seq.), the Poultry Products Inspection Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s451"},"text":"21 U.S.C. 451","children":[],"tail":" et seq.), or the Egg Products Inspection Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1031"},"text":"21 U.S.C. 1031","children":[],"tail":" et seq.), for inspection activities carried out during the period of fiscal years 2021 through 2030."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Out of the amounts made available under subsection (a), the Secretary shall use $100,000,000 to carry out this subsection.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
