{"tag":"section","attrib":{"id":"idee78e5b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1308–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"1308–4"},"text":"§ 1308–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee78e5b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1308–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a payment provisions education program for appropriate personnel of the Department of Agriculture and members and other personnel of county and State committees established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s590h/b"},"text":"section 590h(b) of title 16","children":[],"tail":", for the purpose of fostering more effective and uniform application of the payment limitations and restrictions established under sections 1308 through 1308–3 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee78e5b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1308–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The education program shall provide training to the personnel in the fair, accurate, and uniform application to individual farming operations of the provisions of law and regulation relating to the payment provisions of sections 1308 through 1308–3 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee78e5b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1308–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State office of the Agricultural Stabilization and Conservation Service shall make the initial determination concerning the application of payment limitations and restrictions established under sections 1308 through 1308–3 of this title to farm operations consisting of more than 5 persons, subject to review by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee78e5b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1308–4/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodity Credit Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out the program provided under this section through the Commodity Credit Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee78e5b8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tX/s1001E"},"text":"Pub. L. 99–198, title X, § 1001E","children":[],"tail":", formerly § 1001D, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXI/s1111/g"},"text":"Pub. L. 101–624, title XI, § 1111(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3499"},"text":"104 Stat. 3499","children":[],"tail":"; renumbered § 1001E, "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1604/1"},"text":"Pub. L. 107–171, title I, § 1604(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/215"},"text":"116 Stat. 215","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee78e5b9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee78e5ba-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee78e5bb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food Security Act of 1985, and not as part of the Agricultural Adjustment Act of 1938 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee78e5bc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1001E"},"text":"section 1001E of Pub. L. 99–198","children":[],"tail":" was renumbered section 1001F and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308–5"},"text":"section 1308–5 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee78e5bd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idee78e5be-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective beginning with 1991 crop of an agricultural commodity, with provision for prior crops, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1171"},"text":"section 1171 of Pub. L. 101–624","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
