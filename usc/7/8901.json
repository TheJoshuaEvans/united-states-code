{"tag":"section","attrib":{"id":"idf0451a25-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901"},"text":null,"children":[{"tag":"num","attrib":{"value":"8901"},"text":"§ 8901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0451a26-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agent” means a nuclear, biological, chemical, or radiological substance that causes agricultural disease or the adulteration of products regulated by the Secretary of Agriculture under any provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a27-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural biosecurity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “agricultural biosecurity” means protection from an agent that poses a threat to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0451a28-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plant or animal health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451a29-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public health as it relates to the adulteration of products regulated by the Secretary of Agriculture under any provision of law that is caused by exposure to an agent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451a2a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the environment as it relates to agriculture facilities, farmland, and air and water within the immediate vicinity of an area associated with an agricultural disease or outbreak.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a2b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural countermeasure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “agricultural countermeasure”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0451a2c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a product, practice, or technology that is intended to enhance or maintain the agricultural biosecurity of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451a2d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include a product, practice, or technology used solely in response to a human medical incident or public health emergency not related to agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a2e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural disease","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agricultural disease” has the meaning given the term by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a2f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural disease emergency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agricultural disease emergency” means an incident of agricultural disease that requires prompt action to prevent significant damage to people, plants, or animals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a30-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agroterrorist act","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “agroterrorist act” means an act that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0451a31-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" causes or attempts to cause—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0451a32-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" damage to agriculture; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0451a33-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" injury to a person associated with agriculture; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451a34-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is committed or appears to be committed with the intent to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0451a35-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intimidate or coerce a civilian population; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0451a36-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disrupt the agricultural industry in order to influence the policy of a government by intimidation or coercion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a37-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Animal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “animal” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8302"},"text":"section 8302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a38-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department” means the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a39-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “development” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0451a3a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research leading to the identification of products or technologies intended for use as agricultural countermeasures to protect animal health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451a3b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the formulation, production, and subsequent modification of those products or technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451a3c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of in vitro and in vivo studies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451a3d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of field, efficacy, and safety studies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451a3e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/9/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preparation of an application for marketing approval for submission to an applicable agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451a3f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/9/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other actions taken by an applicable agency in a case in which an agricultural countermeasure is procured or used prior to issuance of a license or other form of Federal Government approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a40-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “plant” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7702"},"text":"section 7702 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a41-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8901/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified agricultural countermeasure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified agricultural countermeasure” means an agricultural countermeasure that the Secretary, in consultation with the Secretary of Homeland Security, determines to be a priority in order to address an agricultural biosecurity threat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0451a42-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14102"},"text":"Pub. L. 110–234, title XIV, § 14102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1453"},"text":"122 Stat. 1453","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14102, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2215.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0451a43-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0451a44-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],