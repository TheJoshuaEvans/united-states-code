{"tag":"section","attrib":{"id":"ideff1a357-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919"},"text":null,"children":[{"tag":"num","attrib":{"value":"6919"},"text":"§ 6919.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military Veterans Agricultural Liaison","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff1a358-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish in the Department the position of Military Veterans Agricultural Liaison.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a359-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Military Veterans Agricultural Liaison shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff1a35a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information to returning veterans about, and connect returning veterans with, beginning farmer training and agricultural vocational and rehabilitation programs appropriate to the needs and interests of returning veterans, including assisting veterans in using Federal veterans educational benefits for purposes relating to beginning a farming or ranching career;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a35b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information to veterans concerning the availability of, and eligibility requirements for, participation in agricultural programs, with particular emphasis on beginning farmer and rancher programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a35c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a resource for assisting veteran farmers and ranchers, and potential farmers and ranchers, in applying for participation in agricultural programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a35d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advocate on behalf of veterans in interactions with employees of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a35e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and periodically update the website described in subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a35f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in carrying out the duties described in paragraphs (1) through (5), consult with and provide technical assistance to any Federal agency, including the Department of Defense, the Department of Veterans Affairs, the Small Business Administration, and the Department of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a360-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts and cooperative agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of carrying out the duties under subsection (b), the Military Veterans Agricultural Liaison may enter into contracts or cooperative agreements with the research centers of the Agricultural Research Service, institutions of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":"), or nonprofit organizations for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff1a361-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of regional research on the profitability of small farms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a362-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of educational materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a363-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of workshops, courses, and certified vocational training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a364-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of mentoring activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a365-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of internship opportunities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a366-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Website required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff1a367-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The website required under subsection (b)(5) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a368-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Positions identified within the Department of Agriculture that are available to veterans for apprenticeships.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a369-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Apprenticeships, programs of training on the job, and programs of education that are approved for purposes of chapter 36 of title 38.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a36a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Employment skills training programs for members of the Armed Forces carried out pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1143/e"},"text":"section 1143(e) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a36b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Information designed to assist businesses, nonprofit entities, educational institutions, and farmers interested in developing apprenticeships, on-the-job training, educational, or entrepreneurial programs for veterans in navigating the process of having a program approved by a State approving agency for purposes of chapter 36 of title 38, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff1a36c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/d/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contact information for relevant offices in the Department of Defense, Department of Veterans Affairs, Department of Labor, and Small Business Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a36d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/d/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic requirements for approval by each State approving agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a36e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/d/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations with respect to training and coursework to be used during apprenticeships or on-the-job training that will enable a veteran to be eligible for agricultural programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a36f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/d/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examples of successful programs and curriculums that have been approved for purposes of chapter 36 of title 38 (with consent of the organization and without any personally identifiable information).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a370-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of website","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a371-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", and once every 5 years thereafter, the Secretary shall conduct a study to determine if the website required under subsection (b)(5) is effective in providing veterans the information required under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a372-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineffective website","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines that the website is not effective under subparagraph (A), the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff1a373-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the agriculture and veterans committees described in subparagraph (C) of that determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a374-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not earlier than 180 days after the date on which the Secretary provides notice under clause (i), terminate the website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a375-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agriculture and veterans committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The agriculture and veterans committees referred to in subparagraph (B)(i) are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff1a376-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a377-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture, Nutrition, and Forestry of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a378-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/d/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Veterans’ Affairs of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a379-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/d/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Veterans’ Affairs of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a37a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall consult with organizations that serve veterans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a37b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff1a37c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", and annually thereafter, the Military Veterans Agricultural Liaison shall submit a report on beginning farmer training for veterans and agricultural vocational and rehabilitation programs for veterans to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a37d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a37e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Veterans’ Affairs of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a37f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture, Nutrition, and Forestry of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a380-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Veterans’ Affairs of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a381-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report submitted under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a382-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the measures taken to carry out subsections (b) and (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a383-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the information provided to veterans under paragraphs (1) and (2) of subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a384-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for best informing veterans of the programs described in paragraphs (1) and (2) of subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a385-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the contracts or cooperative agreements entered into under subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a386-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the programs implemented under subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a387-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/f/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the employment outreach activities directed to veterans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a388-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/f/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for how opportunities for veterans in agriculture should be developed or expanded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a389-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/f/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of veteran farm lending data and a summary of shortfalls, if any, identified by the Military Veterans Agricultural Liaison in collecting data with respect to veterans engaged in agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a38a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/f/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations, if any, on how to improve activities under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a38b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public dissemination of information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff1a38c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", and annually thereafter, the Military Veterans Agricultural Liaison shall make publicly available and share broadly, including by posting on the website of the Department—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a38d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the report of the Military Veterans Agricultural Liaison on beginning farmer training for veterans and agricultural vocational and rehabilitation programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a38e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information disseminated under paragraphs (1) and (2) of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a38f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6919/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Further dissemination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the day before the date on which the Military Veterans Agricultural Liaison makes publicly available the information under paragraph (1), the Military Veterans Agricultural Liaison shall provide that information to the Department of Defense, the Department of Veterans Affairs, the Small Business Administration, and the Department of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff1a390-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s219"},"text":"Pub. L. 103–354, title II, § 219","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tXII/s12304"},"text":"Pub. L. 113–79, title XII, § 12304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/985"},"text":"128 Stat. 985","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12402"},"text":"Pub. L. 115–334, title XII, § 12402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4971"},"text":"132 S