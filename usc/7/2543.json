{"tag":"section","attrib":{"id":"idef841552-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2543"},"text":null,"children":[{"tag":"num","attrib":{"value":"2543"},"text":"§ 2543.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to save seed; crop exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except to the extent that such action may constitute an infringement under subsections (3) and (4) of section 2541 ","children":[{"tag":"ref","attrib":{"idref":"fn002262"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002262"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, it shall not infringe any right hereunder for a person to save seed produced by the person from seed obtained, or descended from seed obtained, by authority of the owner of the variety for seeding purposes and use such saved seed in the production of a crop for use on the farm of the person, or for sale as provided in this section. A bona fide sale for other than reproductive purposes, made in channels usual for such other purposes, of seed produced on a farm either from seed obtained by authority of the owner for seeding purposes or from seed produced by descent on such farm from seed obtained by authority of the owner for seeding purposes shall not constitute an infringement. A purchaser who diverts seed from such channels to seeding purposes shall be deemed to have notice under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2567"},"text":"section 2567 of this title","children":[],"tail":" that the actions of the purchaser constitute an infringement."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef865e43-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tIII/s113"},"text":"Pub. L. 91–577, title III, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1555"},"text":"84 Stat. 1555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/349"},"text":"Pub. L. 103–349","children":[],"tail":", §§ 10, 13(s), "},{"tag":"date","attrib":{"date":"1994-10-06"},"text":"Oct. 6, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3142"},"text":"108 Stat. 3142","children":[],"tail":", 3144.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef865e44-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef865e45-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef865e46-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsections (3) and (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2541"},"text":"section 2541 of this title","children":[],"tail":", referred to in text, probably means paragraphs (3) and (4) of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2541"},"text":"section 2541 of this title","children":[],"tail":", which were redesignated subsection (a)(3) and (4) of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2541"},"text":"section 2541 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/102/560/s3/a"},"text":"Pub. L. 102–560, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4231"},"text":"106 Stat. 4231","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef865e47-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/349"},"text":"Pub. L. 103–349","children":[],"tail":", §§ 10, 13(s)(1), in first sentence substituted “produced by the person” for “produced by him”, “the farm of the person” for “his farm”, and “section.” for “section: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That without regard to the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2541/3"},"text":"section 2541(3) of this title","children":[],"tail":" it shall not infringe any right hereunder for a person, whose primary farming occupation is the growing of crops for sale for other than reproductive purposes, to sell such saved seed to other persons so engaged, for reproductive purposes, provided such sale is in compliance with such State laws governing the sale of seed as may be applicable.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/349/s13/s/2"},"text":"Pub. L. 103–349, § 13(s)(2)","children":[],"tail":", substituted “the actions of the purchaser” for “his actions” in third sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef865e48-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef865e49-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/349"},"text":"Pub. L. 103–349","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"1994-10-06"},"text":"Oct. 6, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/349/s15"},"text":"section 15 of Pub. L. 103–349","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2401"},"text":"section 2401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
