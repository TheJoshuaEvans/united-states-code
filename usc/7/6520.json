{"tag":"section","attrib":{"id":"idefe82d42-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6520"},"text":null,"children":[{"tag":"num","attrib":{"value":"6520"},"text":"§ 6520.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative appeal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe82d43-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6520/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited appeals procedure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish an expedited administrative appeals procedure under which persons may appeal an action of the Secretary, the applicable governing State official, or a certifying agent under this chapter that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe82d44-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6520/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adversely affects such person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d45-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6520/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is inconsistent with the organic certification program established under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82d46-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6520/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeal of final decision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A final decision of the Secretary under subsection (a) may be appealed to the United States district court for the district in which such person is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe82d47-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXI/s2121"},"text":"Pub. L. 101–624, title XXI, § 2121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3950"},"text":"104 Stat. 3950","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tX/s1001/9"},"text":"Pub. L. 102–237, title X, § 1001(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1894"},"text":"105 Stat. 1894","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefe82d48-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefe82d49-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefe82d4a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “district court for the district” for “District Court for the District”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
