{"tag":"section","attrib":{"id":"idefa7c98d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d"},"text":null,"children":[{"tag":"num","attrib":{"value":"3319d"},"text":"§ 3319d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental and alternative crops","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa7c98e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and pilot project program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, during the period beginning ","children":[{"tag":"date","attrib":{"date":"1986-10-01"},"text":"October 1, 1986","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"September 30, 2023","children":[],"tail":", the Secretary shall develop and implement a research project program for the development of supplemental and alternative crops (including canola), using such funds as are appropriated to the Secretary each fiscal year under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa7c98f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importance to producers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The development of supplemental and alternative crops for agronomic rotational purposes and as a habitat for honey bees and other pollinators is of critical importance to producers of agricultural commodities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa7c990-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research funding, special or competitive grants, etc.; program requirements; agreements, grants and other arrangements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa7c991-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall make competitive grants to further the purposes of this section in the implementation of a comprehensive and integrated program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa7c992-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The program developed and implemented by the Secretary shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa7c993-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an examination of the adaptation of supplemental and alternative crops;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa7c994-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment and extension of various methods of planting, cultivating, harvesting, and processing supplemental and alternative crops;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa7c995-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer of such applied research to on-farm practice as soon as practicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa7c996-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment through grants, cooperative agreements, or other means of such processing, storage, and transportation facilities for supplemental and alternative crops as the Secretary determines will facilitate the achievement of a successful program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa7c997-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application of such other resources and expertise as the Secretary considers appropriate to support the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa7c998-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The program may include, but shall not be limited to, agreements, grants, and other arrangements—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa7c999-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct comprehensive resource and infrastructure assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa7c99a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and introduce supplemental and alternative income-producing crops;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa7c99b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and expand domestic and export markets for such crops;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa7c99c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical assistance to farm owners and operators, marketing cooperatives, and others;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa7c99d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct fundamental and applied research related to the development of new commercial products derived from natural plant material (including hemp (as defined in section 1639","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title)) for industrial, medical, and agricultural applications; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa7c99e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to participate with colleges and universities, other Federal agencies, and private sector entities in conducting research described in subparagraph (E).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa7c99f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of expertise and resources of other Federal agencies and land-grant colleges and universities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use the expertise and resources of the Agricultural Research Service, the National Institute of Food and Agriculture, and the land-grant colleges and universities for the purpose of carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa7c9a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa7c9a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for fiscal year 2013;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa7c9a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 for each of fiscal years 2014 through 2018; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa7c9a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319d/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa7c9a4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1473D"},"text":"Pub. L. 95–113, title XIV, § 1473D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXIV/s1428"},"text":"Pub. L. 99–198, title XIV, § 1428","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1554"},"text":"99 Stat. 1554","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1601/b/5"},"text":"Pub. L. 101–624, title XVI, § 1601(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3703"},"text":"104 Stat. 3703","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s819"},"text":"Pub. L. 104–127, title VIII, § 819","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1167"},"text":"110 Stat. 1167","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tIII/s301/a/14"},"text":"Pub. L. 105–185, title III, § 301(a)(14)","children":[],"tail":", title VI, § 606(a), "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/562"},"text":"112 Stat. 562","children":[],"tail":", 603; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7115"},"text":"Pub. L. 107–171, title VII, § 7115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/433"},"text":"116 Stat. 433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII"},"text":"Pub. L. 110–234, title VII","children":[],"tail":", §§ 7136, 7511(c)(13), "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1228"},"text":"122 Stat. 1228","children":[],"tail":", 1268; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, §§ 7136, 7511(c)(13), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1990, 2030; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7122"},"text":"Pub. L. 113–79, title VII, § 7122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/876"},"text":"128 Stat. 876","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7129"},"text":"Pub. L. 115–334, title VII, § 7129","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4795"},"text":"132 Stat. 4795","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa7c9a5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefa7c9a6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefa7c9a7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of “this chapter”, referred to in subsec. (a), see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3102"},"text":"section 3102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefa7c9a8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The authorities provided by each provision of, and each amendment made by, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"Sept. 30, 2023","children":[],"tail":", to continue, and authorities to be carried out, until the later of "},{"tag":"date","attrib":{"date":"2024-09-30"},"text":"Sept. 30, 2024","children":[],"tail":", or the date specified in the provision of, or amendment made by, "},{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/a"},"text":"section 102(a) of Pub. L. 118–22","children":[],"tail":", set out in an Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The authorities provided by each provision of, and each amendment made by, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"2012-09-30"},"text":"Sept. 30, 2012","children":[],"tail":", to continue, and the Secretary of Agriculture to carry out the authorities, until the later of "},{"tag":"date","attrib":{"date":"2013-09-30"},"text":"Sept. 30, 2013","children":[],"tail":", or the date specified in the provision of, or amendment made by, "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/240/s701/a"},"text":"section 701(a) of Pub. L. 112–240","children":[],"tail":", set out in a 1-Year Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefa7c9a9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7129/1"},"text":"Pub. L. 115–334, § 7129(1)","children":[],"tail":", substituted “2023” for “2018” and “crops (including canola),” for “crops,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7129/2"},"text":"Pub. L. 115–334, § 7129(2)","children":[],"tail":", inserted “for agronomic rotational purposes and as a habitat for honey bees and other pollinators” after “alternative crops” and substituted “commodities.” for “commodities whose livelihood is threatened by the decline in demand experienced with respect to certain of their crops due to changes in consumption patterns or other related causes.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7129/3"},"text":"Pub. L. 115–334, § 7129(3)","children":[],"tail":", inserted “(including hemp (as defined in section 1639"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title))” after “material”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7129/4"},"text":"Pub. L. 115–334, § 7129(4)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7122/a/1"},"text":"Pub. L. 113–79, § 7122(a)(1)","children":[],"tail":", substituted “2018” for “2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7122/b"},"text":"Pub. L. 113–79, § 7122(b)","children":[],"tail":", substituted “make competitive grants” for “use such research funding, special or competitive grants, or other means, as the Secretary determines,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7122/a/2"},"text":"Pub. L. 113–79, § 7122(a)(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7136"},"text":"Pub. L. 110–246, § 7136","children":[],"tail":", substituted “2012” for “2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7511/c/13"},"text":"Pub. L. 110–246, § 7511(c)(13)","children":[],"tail":", substituted “the National Institute of Food and Agriculture” for “the Cooperative State Research Service, the Extension Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" substituted “2007” for “2002”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s301/a/14"},"text":"Pub. L. 105–185, § 301(a)(14)","children":[],"tail":", substituted “2002” for “1997”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s606/a"},"text":"Pub. L. 105–185, § 606(a)","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/s819/b/5"},"text":"Pub. L. 104–127, § 819(b)(5)","children":[],"tail":". See 1996 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s819/a"},"text":"Pub. L. 104–127, § 819(a)","children":[],"tail":", (b)(1), substituted “1997” for “1995” and struck out “and pilot” after “research”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s819/b/2"},"text":"Pub. L. 104–127, § 819(b)(2)","children":[],"tail":", struck out “at pilot sites in areas adversely affected by declining demand for crops grown in the area” after “alternative crops”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s819/b/3"},"text":"Pub. L. 104–127, § 819(b)(3)","children":[],"tail":", struck out “from pilot sites” after “research”."}],"tail":"\n"},{"tag":"p"