{"tag":"section","attrib":{"id":"idee232498-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s243"},"text":null,"children":[{"tag":"num","attrib":{"value":"243"},"text":"§ 243.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition and collection of fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee232499-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s243/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall assess persons covered by this chapter fees to cover the costs of administering this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee23249a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s243/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fees under this section shall be set at a rate determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee23249b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s243/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All fees collected under this section shall be credited to the account that incurs the costs of administering this chapter and shall be available to the Secretary without further appropriation and without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee23249c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s243/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds collected under this section may be deposited in an interest-bearing account with a financial institution, and any interest earned on the account shall be credited under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee23249d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s243/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Efficiencies and cost effectiveness","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee23249e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s243/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall seek to minimize the fees established under this section by improving efficiencies and reducing costs, including the efficient use of personnel to the extent practicable and consistent with the effective implementation of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee23249f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s243/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish an annual report on the actions taken by the Secretary to comply with paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee2324a0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, § 4, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/472/tII/s201"},"text":"Pub. L. 106–472, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2064"},"text":"114 Stat. 2064","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee2324a1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee2324a2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee2324a3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 243, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"act Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, § 3, "},{"tag":"ref","attrib":{"href":"/us/stat/39/486"},"text":"39 Stat. 486","children":[],"tail":", authorized investigation of warehousing, weighing, classifying, and certification of agricultural products, inspection of warehouses, and prescription of duties of warehousemen by Secretary of Agriculture, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/472"},"text":"Pub. L. 106–472","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s242"},"text":"section 242 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 4 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"act Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s244"},"text":"section 244 of this title","children":[],"tail":", prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/472"},"text":"Pub. L. 106–472","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
