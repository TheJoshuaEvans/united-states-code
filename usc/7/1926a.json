{"tag":"section","attrib":{"id":"idef0595c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1926a"},"text":"§ 1926a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency and imminent community water assistance grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef0595c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide grants in accordance with this section to assist the residents of rural areas and small communities to secure adequate quantities of safe water—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef0595c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after a significant decline in the quantity or quality of water available from the water supplies of such rural areas and small communities, or when such a decline is imminent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0595c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" when repairs, partial replacement, or significant maintenance efforts on established water systems would remedy—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef0595c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an acute, or imminent, shortage of quality water; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0595c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a significant decline, or imminent decline, in the quantity or quality of water that is available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0595c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef0595c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" give priority to projects described in subsection (a)(1), particularly to projects to address contamination that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef0595c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" poses a threat to human health or the environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0595c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was caused by circumstances beyond the control of the applicant for a grant, including circumstances that occurred over a period of time; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0595ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide at least 70 percent of all such grants to such projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0595cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to obtain a grant under this section, an applicant shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef0595cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a public or private nonprofit entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0595cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a grant made under subsection (a)(1), demonstrate to the Secretary that the decline referred to in such subsection occurred, or will occur, within 2 years of the date the application was filed for such grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0595ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef0595cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants made under this section may be used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef0595d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for waterline extensions from existing systems, laying of new waterlines, repairs, significant maintenance, digging of new wells, equipment replacement, and hook and tap fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0595d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any other appropriate purpose associated with developing sources of, treating, storing, or distributing water;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0595d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist communities in complying with the requirements of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"33 U.S.C. 1251","children":[],"tail":" et seq.) or the Safe Drinking Water Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300f"},"text":"42 U.S.C. 300f","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0595d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide potable water to communities through other means, other than those covered above for not to exceed 120 days when a more permanent solution is not feasible in a shorter time frame. Where drinking water supplies are inadequate due to an event, as determined by the Secretary, including drought, severe weather, or contamination, the Secretary may provide potable water for an additional period of time not to exceed an additional 120 days in order to protect public health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0595d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint proposals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall preclude rural communities from submitting joint proposals for emergency water assistance, subject to the restrictions contained in subsection (e). Such restrictions should be considered in the aggregate, depending on the number of communities involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0595d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef0595d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum population and income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No grant provided under this section shall be used to assist any rural area or community that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef0595d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any area in any city or town with a population in excess of 10,000 inhabitants according to the most recent decennial census of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0595d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a median household income in excess of the State nonmetropolitan median household income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0595d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Set-aside for smaller communities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 50 percent of the funds allocated under this section shall be allocated to rural communities with populations that do not exceed 3,000 inhabitants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0595da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants made under this section may not exceed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef0595db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of each grant made under subsection (a)(1), $1,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0595dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of each grant made under subsection (a)(2), $150,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0595dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (e), grants under this section shall be made in an amount equal to 100 percent of the costs of the projects conducted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0595de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef0595df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nationally competitive application process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop a nationally competitive application process to award grants under this section. The process shall include criteria for evaluating applications, including population, median household income, and the severity of the decline, or imminent decline, in quantity or quality of water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0595e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of review of applications","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef0595e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Simplified application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The application process developed by the Secretary under paragraph (1) shall include a simplified application form that will permit expedited consideration of an application for a grant filed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0805e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In processing applications for any water or waste grant or loan authorized under this chapter, the Secretary shall afford priority processing to an application for a grant under this section to the extent funds will be available for an award on the application at the conclusion of priority processing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0805e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, to the maximum extent practicable, review and act on an application under this section within 60 days after the date on which the application is submitted to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0805e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef0805e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef0805e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year, not less than 5 percent and not more than 7 percent of the total amount made available to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1926/a/2"},"text":"section 1926(a)(2) of this title","children":[],"tail":" for the fiscal year shall be reserved for grants under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0805e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef0805e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/i/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds reserved under subparagraph (A) for a fiscal year shall be reserved only until July 1 of the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef0805e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/i/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding clause (i), in response to an eligible community where the drinking water supplies are inadequate, as determined by the Secretary, due to an event, including drought, severe weather, or contamination, the Secretary may use funds described in subparagraph (A) from July 1 through September 30 each fiscal year to provide potable water under this section in order to protect public health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0805ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926a/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to funds made available under paragraph (1), there is authorized to be appropriated to carry out this section $50,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef0805eb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s306A"},"text":"Pub. L. 87–128, title III, § 306A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/82/tV/s501/a"},"text":"Pub. L. 101–82, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-14"},"text":"Aug. 14, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/584"},"text":"103 Stat. 584","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s742"},"text":"Pub. L. 104–127, title VII, § 742","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1124"},"text":"110 Stat. 1124","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6009"},"text":"Pub. L. 107–171, title VI, § 6009","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/356"},"text":"116 Stat. 356","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVI/s6008"},"text":"Pub. L. 110–234, title VI, § 6008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1163"},"text":"122 Stat. 1163","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VI, § 6008, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1924; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVI/s6007"},"text":"Pub. L. 113–79, title VI, § 6007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/843"},"text":"128 Stat. 843","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6407/a"},"text":"Pub. L. 115–334, title VI, § 6407(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4759"},"text":"132 Stat. 4759","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef0805ec-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef0805ed-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef0805ee-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Water Pollution Control Act, referred to in subsec. (d)(1)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"act June 30, 1948, ch. 758","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/92/500/s2"},"text":"Pub. L. 92–500, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-18"},"text":"Oct. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/816"},"text":"86 Stat. 816","children":[],"tail":", which is classified generally to chapter 26 (§ 1251 et seq.) of Title 33, Navigation and Navigable Waters. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"section 1251 of Title 33","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Safe Drinking Water Act, referred to in subsec. (d)(1)(C), is title XIV of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1974-12-16"},"text":"Dec. 16, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/523/s2/a"},"text":"Pub. L. 93–523, § 2(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1660"},"text":"88 Stat. 1660","children":[],"tail":", which is classified generally to subchapter XII (§ 300f et seq.) of chapter 6A of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (h)(2)(B), was in the original “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/307"},"text":"75 Stat. 307","children":[],"tail":", known as the Consolidated Farm and Rural Development Act, which is classified principally to this chapter. For complete classification of title III to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef0805ef-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef0805f0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6407/a/1"},"text":"Pub. L. 115–334, § 6407(a)(1)","children":[],"tail":", substituted “, particularly to projects to address contamination that—” for “; and” and added subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6407/a/2"},"text":"Pub. L. 115–334, § 6407(a)(2)","children":[],"tail":", inserted before period at end “, other than those covered above for not to exceed 120 days when a more permanent solution is not feasible in a shorter time frame. Where drinking water supplies are inadequate due to an event, as determined by the Secretary, including drought, severe weather, or contamination, the Secretary may provide potable water for an additional period of time not to exceed an additional 120 days in order to protect public health”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6407/a/3"},"text":"Pub. L. 115–334, § 6407(a)(3)","children":[],"tail":", struck out “according to the most recent decennial census of the United States” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6407/a/4"},"text":"Pub. L. 115–334, § 6407(a)(4)","children":[],"tail":", substituted “$1,000,000” for “$500,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6407/a/5/A/i"},"text":"Pub. L. 115–334, § 6407(a)(5)(A)(i)","children":[],"tail":", substituted “5 percent and not more than 7” for “3 nor more than 5”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6407/a/5/A/ii"},"text":"Pub. L. 115–334, § 6407(a)(5)(A)(ii)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B). Prior to amendment, text read as follows: “Funds reserved under subparagraph (A) for a fiscal year shall be reserved only until July 1 of the fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6407/a/5/B"},"text":"Pub. L. 115–334, § 6407(a)(5)(B)","children":[],"tail":", substituted “$50,000,000 for each of fiscal years 2019 through 2023” for “$35,000,000 for each of fiscal years 2008 through 2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (i)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" substituted “2018” for “2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (i)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s6008"},"text":"Pub. L. 110–246, § 6008","children":[],"tail":", substituted “2008 through 2012” for “2003 through 2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6009/1"},"text":"Pub. L. 107–171, § 6009(1)","children":[],"tail":", inserted “and imminent” before “community water assistance” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6009/2/A"},"text":"Pub. L. 107–171, § 6009(2)(A)","children":[],"tail":", inserted “, or when such a decline is imminent” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6009/2/B/i"},"text":"Pub. L. 107–171, § 6009(2)(B)(i)","children":[],"tail":", substituted “acute, or imminent,” for “acute”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6009/2/B/ii"},"text":"Pub. L. 107–171, § 6009(2)(B)(ii)","children":[],"tail":", substituted “decline, or imminent decline,” for “decline”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6009/3"},"text":"Pub. L. 107–171, § 6009(3)","children":[],"tail":", substituted “occurred, or will occur,” for “occurred”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6009/4"},"text":"Pub. L. 107–171, § 6009(4)","children":[],"tail":", added par. (1) and struck out heading and text of former par. (1). Text read as follows: “Grants made under this section may be used for waterline extensions from existing systems, laying of new waterlines, repairs, significant maintenance, digging of new wells, equipment replacement, hook and tap fees, and any other appropriate purpose associated with developing sources of, or treating, storing, or distributing water, and to assist communities in complying with the requirements of the Federal Water Pollution Control Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"33 U.S.C. 1251","children":[],"tail":" et seq.) or the Safe Drinking Water Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300f"},"text":"42 U.S.C. 300f","children":[],"tail":" et seq.).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6009/5"},"text":"Pub. L. 107–171, § 6009(5)","children":[],"tail":", substituted “$150,000” for “$75,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6009/6/A"},"text":"Pub. L. 107–171, § 6009(6)(A)","children":[],"tail":", substituted “decline, or imminent decline,” for “decline” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6009/6/B"},"text":"Pub. L. 107–171, § 6009(6)(B)","children":[],"tail":", added par. (2) and struck out heading and text of former par. (2). Text read as follows: “The Secretary shall make every effort to review and act on applications within 60 days of the date that such applications are submitted.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6009/7"},"text":"Pub. L. 107–171, § 6009(7)","children":[],"tail":", added subsec. (i) and struck out heading and text of former subsec. (i). Text read as follows: “There are authorized to be appropriated to carry out this section $35,000,000 for each of fiscal years 1996 through 2002.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s742/1/A"},"text":"Pub. L. 104–127, § 742(1)(A)","children":[],"tail":", substituted “10,000” for “15,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s742/1/B"},"text":"Pub. L. 104–127, § 742(1)(B)","children":[],"tail":", substituted “3,000” for “5,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s742/2"},"text":"Pub. L. 104–127, § 742(2)","children":[],"tail":", added subsec. (i) and struck out heading and text of former subsec. (i). Text read as follows: “There are authorized to be appropriated to carry out this section, $35,000,000 for each of the fiscal years 1990 and 1991, such sums to remain authorized until fully appropriated.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef0805f1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef0805f2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef0805f3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/82/tV/s501/b"},"text":"Pub. L. 101–82, title V, § 501(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-14"},"text":"Aug. 14, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/585"},"text":"103 Stat. 585","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/82/tV/s501/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture shall publish—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interim final regulations to carry out section 306A of the Consolidated Farm and Rural Development Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1926a"},"text":"7 U.S.C. 1926a","children":[],"tail":"] (as added by subsection (a) of this section) not later than 45 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1989-08-14"},"text":"Aug. 14, 1989","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" final regulations to carry out section 306A of such Act not later than 90 days after the date of enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funds.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obligation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall designate 70 percent of the funds made available for the first fiscal year for which appropriations are made under section 306A(i) of the Consolidated Farm and Rural Development Act not later than 5 months after the date such funds are appropriated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Release","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may release funds prior to the issuance of final regulations under paragraph (1)(B) for grants under section 306A(a)(1) of the Consolidated Farm and Rural Development Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
