{"tag":"section","attrib":{"id":"idefbd4d0b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4801"},"text":null,"children":[{"tag":"num","attrib":{"value":"4801"},"text":"§ 4801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings and declaration of purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefbd4d0c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4801/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbd4d0d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4801/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pork and pork products are basic foods that are a valuable and healthy part of the human diet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbd4d0e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4801/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the production of pork and pork products plays a significant role in the economy of the United States because pork and pork products are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbd4d0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4801/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produced by thousands of producers, including many small- and medium-sized producers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbd4d10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4801/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consumed by millions of people throughout the United States on a daily basis;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbd4d11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4801/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pork and pork products must be available readily and marketed efficiently to ensure that the people of the United States receive adequate nourishment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbd4d12-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4801/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the maintenance and expansion of existing markets, and development of new markets, for pork and pork products are vital to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbd4d13-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4801/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the welfare of pork producers and persons concerned with producing and marketing pork and pork products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbd4d14-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4801/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the general economy of the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbd4d15-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4801/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pork and pork products move in interstate and foreign commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbd4d16-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4801/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pork and pork products that do not move in such channels of commerce directly burden or affect interstate commerce in pork and pork products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbd4d17-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4801/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in recent years, increasing quantities of low-cost, imported pork and pork products have been brought into the United States and replaced domestic pork and pork products in normal channels of trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbd4d18-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4801/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbd4d19-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4801/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It is the purpose of this chapter to authorize the establishment of an orderly procedure for financing, through adequate assessments, and carrying out an effective and coordinated program of promotion, research, and consumer information designed to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbd4d1a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4801/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen the position of the pork industry in the marketplace; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbd4d1b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4801/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain, develop, and expand markets for pork and pork products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbd4d1c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4801/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such procedure shall be implemented, and such program shall be conducted, at no cost to the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbd4d1d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4801/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in this chapter may be construed to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbd4d1e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4801/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit or require the imposition of quality standards for pork or pork products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbd4d1f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4801/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for control of the production of pork or pork products; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbd4d20-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4801/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise limit the right of an individual pork producer to produce pork and pork products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefbd4d21-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1612"},"text":"Pub. L. 99–198, title XVI, § 1612","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1607"},"text":"99 Stat. 1607","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefbd4d22-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefbd4d23-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefbd4d24-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1631"},"text":"Pub. L. 99–198, title XVI, § 1631","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1622"},"text":"99 Stat. 1622","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/198/tXVI/s1631"},"text":"“This subtitle [subtitle B (§§ 1611–1631) of title XVI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":", enacting this chapter] shall become effective on "},{"tag":"date","attrib":{"date":"1986-01-01"},"text":"January 1, 1986","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idefbd4d25-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1611"},"text":"Pub. L. 99–198, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1606"},"text":"99 Stat. 1606","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/198/tXVI/s1611"},"text":"“This subtitle [subtitle B (§§ 1611–1631) of title XVI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":", enacting this chapter] may be cited as the ‘Pork Promotion, Research, and Consumer Information Act of 1985’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
