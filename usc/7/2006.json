{"tag":"section","attrib":{"id":"idef248f6d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006"},"text":null,"children":[{"tag":"num","attrib":{"value":"2006"},"text":"§ 2006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of mediation rights by borrowers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may not make, insure, or guarantee any farmer program loan to a farm borrower on the condition that the borrower waive any right under the mediation program of any State.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef248f6e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s358"},"text":"Pub. L. 87–128, title III, § 358","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tV/s512"},"text":"Pub. L. 100–233, title V, § 512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1664"},"text":"101 Stat. 1664","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s282/f/3"},"text":"Pub. L. 103–354, title II, § 282(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3235"},"text":"108 Stat. 3235","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef248f6f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef248f70-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef248f71-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" struck out “agricultural loan” before “mediation program”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
