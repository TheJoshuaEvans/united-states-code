{"tag":"section","attrib":{"id":"idefc478d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201"},"text":null,"children":[{"tag":"num","attrib":{"value":"5201"},"text":"§ 5201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc478d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States agricultural exports have declined by more than 36 percent since 1981, from $43,800,000,000 in 1981 to $27,900,000,000 in 1987;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc478d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States share of the world market for agricultural commodities and products has dropped by 20 percent during the last 6 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc478d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the first time in 15 years, the United States incurred monthly agricultural trade deficits in 1986;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc478d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loss of $1,000,000,000 in United States agricultural exports causes the loss of 35,000 agricultural jobs and the loss of 60,000 nonagricultural jobs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc478d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loss of agricultural exports threatens family farms and the economic well-being of rural communities in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc478d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" factors contributing to the loss of United States agricultural exports include changes in world agricultural markets such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc478d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the addition of new exporting nations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc478d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innovations in agricultural technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc478da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increased use of export subsidies designed to lower the price of commodities on the world market;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc478db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the existence of barriers to agricultural trade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc478dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the slowdown in the growth of world food demand in the 1980’s due to cyclical economic factors, including currency fluctuations and a debt-related slowdown in the economic growth of agricultural markets in certain developing countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc478dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rapid buildup of surplus stocks as a consequence of favorable weather for agricultural production during the 1980’s;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc478de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the volume and value of exports is important to the financial well-being of the farm sector in the United States and to increasing farm income in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc478df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in order to increase agricultural exports and improve prices for farmers and ranchers in the United States, it is necessary that all agricultural export programs of the United States be used in an expeditious manner, including programs established under the Food for Peace Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"7 U.S.C. 1691","children":[],"tail":" et seq.), the Commodity Credit Corporation Charter Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s714"},"text":"15 U.S.C. 714","children":[],"tail":" et seq.), and section 416 of the Agricultural Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1431"},"text":"7 U.S.C. 1431","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc478e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" greater use should be made by the Secretary of Agriculture of the authorities established under section 4 ","children":[{"tag":"ref","attrib":{"idref":"fn002303"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002303"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Food for Peace Act of 1966 ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1707a"},"text":"7 U.S.C. 1707a","children":[],"tail":"), the Food for Peace Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"7 U.S.C. 1691","children":[],"tail":" et seq.), section 416 of the Agricultural Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1431"},"text":"7 U.S.C. 1431","children":[],"tail":"), and the Commodity Credit Corporation Charter Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s714"},"text":"15 U.S.C. 714","children":[],"tail":" et seq.) to provide intermediate credit financing and other assistance for the establishment of facilities in importing countries to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc478e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the handling, marketing, processing, storage, and distribution of imported agricultural commodities and products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc478e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase livestock production to enhance the demand for United States feed grains;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc478e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food aid and export assistance programs in developing countries stimulate economic activity which causes incomes to rise, and, as incomes rise, diets improve and the demand for and ability to purchase food increases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc478e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private voluntary organizations and cooperatives are important and successful partners in our food aid and development programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc478e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in addition to meeting humanitarian needs, food aid used in sales and barter programs by private voluntary organizations and cooperatives—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc478e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides communities with health care, credit systems, and tools for development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc478e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5201/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes the infrastructure that is essential to the expansion of markets for United States agricultural commodities and products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefc478e8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tIV/s4101"},"text":"Pub. L. 100–418, title IV, § 4101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1388"},"text":"102 Stat. 1388","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3001/b/1/A"},"text":"Pub. L. 110–246, title III, § 3001(b)(1)(A)","children":[],"tail":", (2)(J), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1820"},"text":"122 Stat. 1820","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefc478e9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefc478ea-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefc478eb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Food for Peace Act, referred to in pars. (8) and (9), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"act July 10, 1954, ch. 469","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/454"},"text":"68 Stat. 454","children":[],"tail":", which is classified generally to chapter 41 (§ 1691 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Commodity Credit Corporation Charter Act, referred to in pars. (8) and (9), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-29/ch704"},"text":"act June 29, 1948, ch. 704","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/1070"},"text":"62 Stat. 1070","children":[],"tail":", which is classified generally to subchapter II (§ 714 et seq.) of chapter 15 of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s714"},"text":"section 714 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4 of the Food for Peace Act of 1966 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1707a"},"text":"7 U.S.C. 1707a","children":[],"tail":"), referred to in par. (9), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1574"},"text":"Pub. L. 101–624, title XV, § 1574","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3702"},"text":"104 Stat. 3702","children":[],"tail":". See subchapter II (§ 5621 et seq.) of chapter 87 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefc478ec-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Pars. (8), (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" substituted “Food for Peace Act” for “Agricultural Trade Development and Assistance Act of 1954”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefc478ed-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idefc478ee-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/b"},"text":"section 4(b) of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idefc478ef-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tIV/s4001"},"text":"Pub. L. 100–418, title IV, § 4001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1388"},"text":"102 Stat. 1388","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/418/tIV/s4001"},"text":"“This title [enacting this chapter, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2112"},"text":"section 2112 of Title 16","children":[],"tail":", Conservation, and sections 1401, 1402, and 1403 of Title 21, Food and Drugs, amending sections 608c, 608e–1, 626, 1704, 1707a, 1726, 1736"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":", 1736s, 1736t, 1736v, 1736x, 1736bb, and 1736bb–3 to 1736bb–6 of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s713a–14"},"text":"section 713a–14 of Title 15","children":[],"tail":", Commerce and Trade, and "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s620"},"text":"section 620 of Title 21","children":[],"tail":", and enacting provisions set out as notes under sections 624, 1431, 1446, 1691, and 1736t of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1401"},"text":"section 1401 of Title 21","children":[],"tail":"] may be cited as the ‘Agricultural Competitiveness and Trade Act of 1988’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
