{"tag":"section","attrib":{"id":"idef248f9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2006d"},"text":"§ 2006d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Market placement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a market placement program for qualified beginning farmers and ranchers and other borrowers of farmer program loans that the Secretary believes have a reasonable chance of qualifying for commercial credit with a guarantee provided under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef248f9c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s362"},"text":"Pub. L. 87–128, title III, § 362","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVIII/s1821"},"text":"Pub. L. 101–624, title XVIII, § 1821","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3831"},"text":"104 Stat. 3831","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef248f9d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef248f9e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef248f9f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/307"},"text":"75 Stat. 307","children":[],"tail":", known as the Consolidated Farm and Rural Development Act, which is classified principally to this chapter. For complete classification of title III to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
