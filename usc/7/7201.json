{"tag":"section","attrib":{"id":"ideffdb147-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7201"},"text":null,"children":[{"tag":"num","attrib":{"value":"7201"},"text":"§ 7201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title and purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideffdb148-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter may be cited as the “Agricultural Market Transition Act”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffdb149-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffdb14a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7201/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to authorize the use of binding production flexibility contracts between the United States and agricultural producers to support farming certainty and flexibility while ensuring continued compliance with farm conservation and wetland protection requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb14b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7201/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make nonrecourse marketing assistance loans and loan deficiency payments available for certain crops;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb14c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7201/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the operation of farm programs for milk, peanuts, and sugar; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb14d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7201/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish a commission to undertake a comprehensive review of past and future production agriculture in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideffdb14e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s101"},"text":"Pub. L. 104–127, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/896"},"text":"110 Stat. 896","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideffdb14f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideffdb150-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideffdb151-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","a