"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1516"},"text":"112 Stat. 1516","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/228/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7212"},"text":"section 7212 of this title","children":[],"tail":"] may be cited as the ‘Emergency Farm Financial Relief Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"ideffdb154-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s1/a"},"text":"Pub. L. 104–127, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/888"},"text":"110 Stat. 888","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/127/s1/a"},"text":"“This Act [see Tables for classification] may be cited as the ‘Federal Agriculture Improvement and Reform Act of 1996’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"ideffdb155-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Severability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIX/s928"},"text":"Pub. L. 104–127, title IX, § 928","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1197"},"text":"110 Stat. 1197","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/127/tIX/s928"},"text":"“If any provision of this Act [see Short Title note above] or the application thereof to any person or circumstance is held invalid, the invalidity shall not affect other provisions or applications of this Act that can be given effect without regard to the invalid provision or application, and to this end the provisions of this Act are severable.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
