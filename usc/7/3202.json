{"tag":"section","attrib":{"id":"idefa09cf1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3202"},"text":null,"children":[{"tag":"num","attrib":{"value":"3202"},"text":"§ 3202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and education grants for the study of antibiotic-resistant bacteria","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa09cf2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide research and education grants, on a competitive basis—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa09cf3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3202/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to study the development of antibiotic-resistant bacteria, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa09cf4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3202/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" movement of antibiotic-resistant bacteria into groundwater and surface water; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa09cf5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3202/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect on antibiotic resistance from various drug use regimens; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa09cf6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3202/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to study and ensure the judicious use of antibiotics in veterinary and human medicine, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa09cf7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3202/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods and practices of animal husbandry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa09cf8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3202/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safe and effective alternatives to antibiotics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa09cf9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3202/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of better veterinary diagnostics to improve decisionmaking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa09cfa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3202/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of conditions or factors that affect antibiotic use on farms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa09cfb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraphs (4), (7), (8), and (11)(B) of subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3157"},"text":"section 3157 of this title","children":[],"tail":" shall apply with respect to the making of grants under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa09cfc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section for each of fiscal years 2008 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa09cfd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7521"},"text":"Pub. L. 110–234, title VII, § 7521","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1271"},"text":"122 Stat. 1271","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7521, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2033.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa09cfe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefa09cff-3a6e-11f1-addd-bbaf