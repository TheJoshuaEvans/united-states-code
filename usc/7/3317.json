{"tag":"section","attrib":{"id":"idefa7c94c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3317"},"text":null,"children":[{"tag":"num","attrib":{"value":"3317"},"text":"§ 3317.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program evaluation studies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa7c94d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3317/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall regularly conduct program evaluations to meet the purposes of this chapter and the responsibilities assigned to the Secretary and the Department of Agriculture in this chapter. Such evaluations shall be designed to provide information that may be used to improve the administration and effectiveness of agricultural research, extension, and teaching programs in achieving their stated objectives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa7c94e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3317/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary is authorized to encourage and foster the regular evaluation of agricultural research, extension, and teaching programs within the State agricultural experiment stations, cooperative extension services, and colleges and universities, through the development and support of cooperative evaluation programs and program evaluation centers and institutes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa7c94f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1471"},"text":"Pub. L. 95–113, title XIV, § 1471","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXIV/s1439/a"},"text":"Pub. L. 97–98, title XIV, § 1439(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1314"},"text":"95 Stat. 1314","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa7c950-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefa7c951-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefa7c952-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of “this chapter”, referred to in subsec. (a), see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3102"},"text":"section 3102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefa7c953-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefa7c954-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1801"},"text":"section 1801 of Pub. L. 97–98","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/us