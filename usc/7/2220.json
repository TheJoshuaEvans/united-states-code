{"tag":"section","attrib":{"id":"idef780665-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2220"},"text":null,"children":[{"tag":"num","attrib":{"value":"2220"},"text":"§ 2220.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain officials and employees of Department and others not subject to restriction on payment of compensation to Government officials and employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The officials and the employees of the Department of Agriculture engaged in the activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279i"},"text":"section 2279i of this title","children":[],"tail":" and paid in whole or in part out of funds contributed as provided therein, and the persons, corporations, or associations making contributions as therein provided, shall not be subject to the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s209"},"text":"section 209 of title 18","children":[],"tail":"; nor shall any official or employee engaged in the cooperative activities of the Forest Service, or the persons, corporations, or associations contributing to such activities be subject to such section."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef780666-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1919-07-24/ch26"},"text":"July 24, 1919, ch. 26","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/270"},"text":"41 Stat. 270","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-03/ch1263/s5"},"text":"Sept. 3, 1954, ch. 1263, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1227"},"text":"68 Stat. 1227","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef780667-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeadi