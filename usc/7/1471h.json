{"tag":"section","attrib":{"id":"ideeb48f3b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1471h"},"text":"§ 1471h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideeb48f3c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person that has qualifying gross revenues in excess of $2,500,000 annually, as determined by the Secretary, shall not be eligible to receive any livestock emergency benefits under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeb48f3d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section, the term “qualifying gross revenue” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeb48f3e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a majority of the person’s annual income is received from farming and ranching operations, the gross revenue from the person’s farming and ranching operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f3f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if less than a majority of the person’s annual income is received from farming and ranching operations, the person’s gross revenue from all sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideeb48f40-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-31/ch792"},"text":"Oct. 31, 1949, ch. 792","children":[],"tail":", title VI, § 610, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/387/tI/s101/a"},"text":"Pub. L. 100–387, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-11"},"text":"Aug. 11, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/931"},"text":"102 Stat. 931","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideeb48f41-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideeb48f42-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideeb48f43-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 15 days after ","children":[{"tag":"date","attrib":{"date":"1988-08-11"},"text":"Aug. 11, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/387/s101/c/1"},"text":"section 101(c)(1) of Pub. L. 100–387","children":[],"tail":", set out as an Effective and Termination Dates of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1427"},"text":"section 1427 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideeb48f44-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inapplicability of Section","children":[],"tail":