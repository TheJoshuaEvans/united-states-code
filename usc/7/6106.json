{"tag":"section","attrib":{"id":"idefdc4753-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6106"},"text":null,"children":[{"tag":"num","attrib":{"value":"6106"},"text":"§ 6106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition and review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefdc4754-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefdc4755-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person subject to an order issued under this chapter may file with the Secretary a petition—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefdc4756-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6106/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stating that the order, any provision of the order, or any obligation imposed in connection with the order, is not in accordance with law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc4757-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6106/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requesting a modification of the order or an exemption from the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc4758-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The petitioner shall be given the opportunity for a hearing on the petition, in accordance with regulations issued by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc4759-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6106/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ruling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After such hearing, the Secretary shall make a ruling on the petition, which shall be final if in accordance with law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc475a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefdc475b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The district courts of the United States in any district in which a person who is a petitioner under subsection (a) resides or carries on business are hereby vested with jurisdiction to review the ruling on such person’s petition, if a complaint for that purpose is filed within 20 days after the date of the entry of such ruling of the Secretary under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc475c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Service of process in such proceedings shall be conducted in accordance with the Federal Rules of Civil Procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc475d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6106/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remands","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the court determines that such ruling is not in accordance with law, the court shall remand the matter to the Secretary with directions either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefdc475e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6106/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make such ruling as the court shall determine to be in accordance with law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc475f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6106/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take such further action as, in the opinion of the court, the law requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc4760-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6106/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The pendency of proceedings instituted under subsection (a) shall not impede, hinder, or delay the Attorney General or the Secretary from obtaining relief pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6107"},"text":"section 6107 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefdc4761-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1927"},"text":"Pub. L. 101–624, title XIX, § 1927","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3862"},"text":"104 Stat. 3862","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefdc4762-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefdc4763-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefdc4764-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Civil Procedure, referred to in subsec. (b)(2), are set out in the Appendix to Title 28, Judiciary and Judicial Procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
