{"tag":"section","attrib":{"id":"idefe82da5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6523"},"text":null,"children":[{"tag":"num","attrib":{"value":"6523"},"text":"§ 6523.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National organic certification cost-share program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe82da6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6523/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall establish a national organic certification cost-share program to assist producers and handlers of agricultural products in obtaining certification under the national organic production program established under the Organic Foods Production Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6501"},"text":"7 U.S.C. 6501","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82da7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6523/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe82da8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6523/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary shall pay under this section not more than 75 percent of the costs incurred by a producer or handler in obtaining certification under the national organic production program, as certified to and approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82da9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6523/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maximum amount of a payment made to a producer or handler under this section shall be $750.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82daa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6523/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than March 1 of each year, the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that describes the requests by, disbursements to, and expenditures for each State under the program during the current and previous fiscal year, including the number of producers and handlers served by the program in the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82dab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6523/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe82dac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6523/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds of the Commodity Credit Corporation, the Secretary shall make available to carry out this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe82dad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6523/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000 for each of fiscal years 2019 and 2020;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82dae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6523/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,000,000 for fiscal year 2021; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82daf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6523/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $8,000,000 for each of fiscal years 2022 through 2031.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82db0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6523/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available under paragraph (1) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe82db1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10606"},"text":"Pub. L. 107–171, title X, § 10606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/514"},"text":"116 Stat. 514","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tX/s10301"},"text":"Pub. L. 110–234, title X, § 10301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1346"},"text":"122 Stat. 1346","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title X, § 10301, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2108; "},{"tag":"ref","attrib":{"href":"/us/pl/112/240/tVII/s701/g/3"},"text":"Pub. L. 112–240, title VII, § 701(g)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2366"},"text":"126 Stat. 2366","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tX/s10004/c"},"text":"Pub. L. 113–79, title X, § 10004(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/942"},"text":"128 Stat. 942","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tX/s10105"},"text":"Pub. L. 115–334, title X, § 10105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4905"},"text":"132 Stat. 4905","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/dB/tI/s102/d/7/C"},"text":"Pub. L. 118–22, div. B, title I, § 102(d)(7)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-11-17"},"text":"Nov. 17, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/118"},"text":"137 Stat. 118","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10606/e"},"text":"Pub. L. 119–21, title I, § 10606(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/110"},"text":"139 Stat. 110","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefe82db2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefe82db3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefe82db4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Organic Foods Production Act of 1990, referred to in subsec. (a), is title XXI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3935"},"text":"104 Stat. 3935","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6501"},"text":"section 6501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefe82db5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Farm Security and Rural Investment Act of 2002, and not as part of the Organic Foods Production Act of 1990 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefe82db6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" substituted “2031” for “2024”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (d)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/22"},"text":"Pub. L. 118–22","children":[],"tail":" substituted “through 2024” for “and 2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10105/a"},"text":"Pub. L. 115–334, § 10105(a)","children":[],"tail":", struck out “(acting through the Agricultural Marketing Service)” after “Secretary of Agriculture”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10105/b"},"text":"Pub. L. 115–334, § 10105(b)","children":[],"tail":", added subsec. (d) and struck out former subsec. (d) which related to funding to carry out this section for fiscal years 2013 to 2018."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" added par. (1) and struck out former par. (1). Prior to amendment, text read as follows: “Of the funds of the Commodity Credit Corporation, the Secretary shall make available to carry out this section $22,000,000 for the period of fiscal years 2008 through 2012.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/240/s701/g/3/A"},"text":"Pub. L. 112–240, § 701(g)(3)(A)","children":[],"tail":", substituted “The Secretary of Agriculture (acting through the Agricultural Marketing Service) shall” for “Of funds of the Commodity Credit Corporation, the Secretary of Agriculture (acting through the Agricultural Marketing Service) shall use $22,000,000 for fiscal year 2008, to remain available until expended, to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/240/s701/g/3/B"},"text":"Pub. L. 112–240, § 701(g)(3)(B)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s10301/1"},"text":"Pub. L. 110–246, § 10301(1)","children":[],"tail":", substituted “$22,000,000 for fiscal year 2008” for “$5,000,000 for fiscal year 2002”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s10301/2"},"text":"Pub. L. 110–246, § 10301(2)","children":[],"tail":", substituted “$750” for “$500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s10301/3"},"text":"Pub. L. 110–246, § 10301(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefe82db7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idefe82db8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2023 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/22"},"text":"Pub. L. 118–22","children":[],"tail":" to be applied and administered as if enacted on "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"Sept. 30, 2023","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/g"},"text":"section 102(g) of Pub. L. 118–22","children":[],"tail":", set out in an Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idefe82db9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/240"},"text":"Pub. L. 112–240","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-09-30"},"text":"Sept. 30, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/240/s701/j"},"text":"section 701(j) of Pub. L. 112–240","children":[],"tail":", set out in a 1-Year Extension of Agricultural Programs note under "},{"tag