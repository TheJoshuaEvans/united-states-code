{"tag":"section","attrib":{"id":"idf04519b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8788"},"text":null,"children":[{"tag":"num","attrib":{"value":"8788"},"text":"§ 8788.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Durum wheat quality program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf04519ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8788/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of funds under subsection (c), the Secretary shall provide compensation to producers of durum wheat in an amount not to exceed 50 percent of the actual cost of fungicides applied to a crop of durum wheat of the producers to control Fusarium head blight (wheat scab) on acres certified to have been planted to Durum wheat in a crop year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04519bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8788/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insufficient funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the total amount of funds appropriated for a fiscal year under subsection (c) are insufficient to fulfill all eligible requests for compensation under this section, the Secretary shall prorate the compensation payments in a manner determined by the Secretary to be equitable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04519bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8788/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $10,000,000 for each of fiscal years 2009 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf04519bd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1613"},"text":"Pub. L. 110–234, title I, § 1613","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1019"},"text":"122 Stat. 1019","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1613, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1748.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf04519be-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf04519bf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf04519c0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],