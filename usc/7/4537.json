{"tag":"section","attrib":{"id":"idefb86b35-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4537"},"text":null,"children":[{"tag":"num","attrib":{"value":"4537"},"text":"§ 4537.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of order, Institute, and Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefb86b36-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4537/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination or suspension of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, whenever the Secretary finds that the order issued under this subchapter or any provision of such order obstructs or does not tend to facilitate the expansion of markets for milk and dairy products marketed in the United States, shall terminate or suspend the operation of the order or such provision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb86b37-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4537/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissolution of Institute","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary terminates the order, the Institute shall be dissolved 180 days after the termination of the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb86b38-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4537/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal of moneys in Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Institute is dissolved for any reason, the moneys remaining in the Fund shall be disposed of as shall be agreed to by the board and the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefb86b39-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/180/tI/s136"},"text":"Pub. L. 98–180, title I, § 136","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tI/s121"},"text":"Pub. L. 99–198, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1371"},"text":"99 Stat. 1371","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
