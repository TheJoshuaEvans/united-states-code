{"tag":"section","attrib":{"id":"idef6e9059-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2153"},"text":null,"children":[{"tag":"num","attrib":{"value":"2153"},"text":"§ 2153.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees and authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall charge, assess, and cause to be collected reasonable fees for licenses issued. Such fees shall be adjusted on an equitable basis taking into consideration the type and nature of the operations to be licensed and shall be deposited and covered into the Treasury as miscellaneous receipts. There are hereby authorized to be appropriated such funds as Congress may from time to time provide: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That there is authorized to be appropriated to the Secretary of Agriculture for enforcement by the Department of Agriculture of the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2156"},"text":"section 2156 of this title","children":[],"tail":" an amount not to exceed $100,000 for the transition quarter ending "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"September 30, 1976","children":[],"tail":", and not to exceed $400,000 for each fiscal year thereafter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef6e905a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/544/s23"},"text":"Pub. L. 89–544, § 23","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-08-24"},"text":"Aug. 24, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/353"},"text":"80 Stat. 353","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/279/s18"},"text":"Pub. L. 94–279, § 18","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-22"},"text":"Apr. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/423"},"text":"90 Stat. 423","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef6e905b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef6e905c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef6e905d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/279"},"text":"Pub. L. 94–279","children":[],"tail":" authorized appropriations for the enforcement of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2156"},"text":"section 2156 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
