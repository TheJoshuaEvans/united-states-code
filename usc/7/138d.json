{"tag":"section","attrib":{"id":"idee14cccd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138d"},"text":null,"children":[{"tag":"num","attrib":{"value":"138d"},"text":"§ 138d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee14ccce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application for accreditation under this chapter shall be prepared and submitted to the Secretary and shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee14cccf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of the laboratory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee14ccd0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of the owners and managers of such laboratory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee14ccd1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement concerning the type of analysis the laboratory intends to conduct;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee14ccd2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138d/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a brief history of the laboratory and its previous operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee14ccd3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138d/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as may be required by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee14ccd4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on submission of application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A laboratory that has been denied, or has lost, accreditation under this chapter shall not reapply for accreditation until the expiration of at least 6 months after such denial or loss of accreditation. Corrective actions taken by the laboratory to address deficiencies upon which the denial or loss of accreditation was based must accompany the reapplication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee14ccd5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIII/s1325"},"text":"Pub. L. 101–624, title XIII, § 1325","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3564"},"text":"104 Stat. 3564","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
