{"tag":"section","attrib":{"id":"idef734c1f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h"},"text":null,"children":[{"tag":"num","attrib":{"value":"2204h"},"text":"§ 2204h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local food production and program evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef734c20-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef734c21-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" collect data on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef734c22-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production and marketing of locally or regionally produced agricultural food products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef734c23-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct and indirect regulatory compliance costs affecting the production and marketing of locally or regionally produced agricultural food products;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734c24-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate interagency collaboration and data sharing on programs relating to local and regional food systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734c25-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" monitor—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef734c26-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of programs designed to expand or facilitate local food systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef734c27-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" barriers to local and regional market access due to Federal regulation of small-scale production; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734c28-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" evaluate the manner in which local food systems—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef734c29-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute to improving community food security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef734c2a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist populations with limited access to healthy food.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef734c2b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef734c2c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and distribute comprehensive reporting of prices and volume of locally or regionally produced agricultural food products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734c2d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct surveys and analysis and publish reports relating to the production, handling, distribution, retail sales, and trend studies (including consumer purchasing patterns) of or on locally or regionally produced agricultural food products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734c2e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" evaluate the effectiveness of existing programs in growing local and regional food systems, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef734c2f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of local food systems on job creation and economic development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef734c30-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of participation in the Local Agriculture Market Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1627c"},"text":"section 1627c of this title","children":[],"tail":", including the percentage of projects funded in comparison to applicants and the types of eligible entities receiving funds;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef734c31-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of participants to leverage private capital and a synopsis of the places from which non-Federal funds are derived; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef734c32-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional resources required to aid in the development or expansion of local and regional food systems;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734c33-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" evaluate the impact that Federal regulation of small commercial producers of agricultural food products intended for local and regional consumption may have on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef734c34-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local job creation and economic development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef734c35-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to local and regional fruit and vegetable markets, including for new and beginning small commercial producers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef734c36-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" participation in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef734c37-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/b/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supplier networks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef734c38-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/b/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high volume distribution systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef734c39-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/b/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retail sales outlets;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734c3a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand the Agricultural Resource Management Survey of the Department to include questions on locally or regionally produced agricultural food products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734c3b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to establish or expand private-public partnerships to facilitate, to the maximum extent practicable, the collection of data on locally or regionally produced agricultural food products, including the development of a nationally coordinated and regionally balanced evaluation of the redevelopment of locally or regionally produced food systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef734c3c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":", and annually thereafter, the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report describing the progress that has been made in implementing this section and identifying any additional needs and barriers related to developing local and regional food systems."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef734c3d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tX/s10016"},"text":"Pub. L. 113–79, title X, § 10016","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/952"},"text":"128 Stat. 952","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tX/s10102/c/3"},"text":"Pub. L. 115–334, title X, § 10102(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4898"},"text":"132 Stat. 4898","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef734c3e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef734c3f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef734c40-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “Local Agriculture Market Program established under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1627c"},"text":"section 1627c of this title","children":[],"tail":"” for “Farmers’ Market and Local Food Promotion Program established under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3005"},"text":"section 3005 of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef734c41-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idef734c42-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” as meaning the Secretary of Agriculture, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
