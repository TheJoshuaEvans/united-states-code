{"tag":"section","attrib":{"id":"idefe372f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6405"},"text":null,"children":[{"tag":"num","attrib":{"value":"6405"},"text":"§ 6405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and issuance of orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe372f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6405/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After notice and opportunity for public comment are given, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6404"},"text":"section 6404 of this title","children":[],"tail":", the Secretary shall issue an order, taking into consideration the comments received and including in the order provisions necessary to ensure that the order is in conformity with the requirements and the declared policy of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe372f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6405/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such order shall be issued and, if approved by fluid milk processors as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6413"},"text":"section 6413 of this title","children":[],"tail":", shall become effective not later than 180 days following publication of the proposed order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe372f4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","at