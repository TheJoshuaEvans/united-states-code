{"tag":"section","attrib":{"id":"idee1987ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s178h"},"text":null,"children":[{"tag":"num","attrib":{"value":"178h"},"text":"§ 178h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of Secretary of Commerce","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In carrying out the provisions of this subchapter, the Secretary of Commerce is authorized to—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee1987eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s178h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make grants to States, education institutions, scientific organizations, and Indian tribes as defined in the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Public Law 93–638","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":"),"},{"tag":"ref","attrib":{"idref":"fn002086"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002086"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and enter into contracts with such institutions and organizations and with industrial or engineering firms;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1987ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s178h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire the services of biologists, agronomists, foresters, geneticists, engineers, economists, and other personnel having expertise in native agricultural crops which could supply critical agricultural materials by contract or otherwise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1987ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s178h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize the facilities of Federal and State institutions and other scientific laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1987ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s178h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and operate necessary facilities and pilot plants to carry out the continuous research, testing, development, and programing necessary to effectuate the purposes of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1987ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s178h/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire secret processes, technical data, invention, patent applications, patents, licenses, land and interests in land (including water rights), plants and facilities, and other property or rights by purchase, license, lease, or donation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1987f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s178h/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster and participate in regional, national, and international conferences relating to the activities authorized by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee1987f1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/592/s10"},"text":"Pub. L. 95–592, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-04"},"text":"Nov. 4, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2533"},"text":"92 Stat. 2533","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/284/s10"},"text":"Pub. L. 98–284, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-05-16"},"text":"May 16, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/184"},"text":"98 Stat. 184","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee1987f2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee1987f3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idee1987f4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Public Law 93–638","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":"), referred to in cl. (a), is "},{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which was classified principally to subchapter II (§ 450 et seq.) of chapter 14 of Title 25, Indians, prior to editorial reclassification as chapter 46 (§ 5301 et seq.) of Title 25. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee1987f5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/284/s10/1"},"text":"Pub. L. 98–284, § 10(1)","children":[],"tail":", (2), in provisions preceding cl. (a) substituted “this subchapter” for “this section” and struck out “, acting through the Regional Commissions or otherwise,” after “the Secretary of Commerce”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Cl. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/284/s10/3"},"text":"Pub. L. 98–284, § 10(3)","children":[],"tail":", inserted “having expertise in native agricultural crops which could supply critical agricultural materials”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Cl. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/284/s10/4"},"text":"Pub. L. 98–284, § 10(4)","children":[],"tail":", substituted “the activities authorized by this subchapter” for “natural rubber manufacture”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
