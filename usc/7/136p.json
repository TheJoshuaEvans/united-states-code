{"tag":"section","attrib":{"id":"idee067534-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136p"},"text":null,"children":[{"tag":"num","attrib":{"value":"136p"},"text":"§ 136p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption of Federal and State agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator may, at the Administrator’s discretion, exempt any Federal or State agency from any provision of this subchapter if the Administrator determines that emergency conditions exist which require such exemption. The Administrator, in determining whether or not such emergency conditions exist, shall consult with the Secretary of Agriculture and the Governor of any State concerned if they request such determination.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee067535-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-25/ch125/s18"},"text":"June 25, 1947, ch. 125, § 18","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/516/s2"},"text":"Pub. L. 92–516, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/995"},"text":"86 Stat. 995","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/140/s8"},"text":"Pub. L. 94–140, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-28"},"text":"Nov. 28, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/754"},"text":"89 Stat. 754","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/532/tVIII/s801/k"},"text":"Pub. L. 100–532, title VIII, § 801(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-25"},"text":"Oct. 25, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2682"},"text":"102 Stat. 2682","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tX/s1006/b/1"},"text":"Pub. L. 102–237, title X, § 1006(b)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1895"},"text":"105 Stat. 1895","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee067536-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee067537-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee067538-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “the Administrator” for “he” before “determines” and “the Administrator’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/532"},"text":"Pub. L. 100–532","children":[],"tail":" substituted “and” for “or“ in section catchline, and directed that sentence beginning “The Administrator, in” be run in after first sentence beginning “The Administrator may”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/140"},"text":"Pub. L. 94–140","children":[],"tail":" inserted provision requiring Administrator to consult with Secretary of Agriculture and Governor of State concerned in determining whether an emergency situation exists."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAme