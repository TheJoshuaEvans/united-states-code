{"tag":"section","attrib":{"id":"idef780717-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2241b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2241b"},"text":"§ 2241b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of seeds and plants for distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Purchase and distribution of vegetable, field, and flower seeds, plants, shrubs, vines, bulbs, and cuttings shall be of the freshest and best obtainable varieties and adapted to general cultivation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef780718-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(R.S. § 527; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1896-04-25/ch140"},"text":"Apr. 25, 1896, ch. 140","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/29/106"},"text":"29 Stat. 106","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef780719-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef78071a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef78071b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s415"},"text":"section 415 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef78071c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1896—Act ","children":[{"tag":"date","attrib":{"date":"1896-04-25"},"text":"Apr. 25, 1896","children":[],"tail":", struck out “by the Department of Agriculture” and “trees”, and inserted “vegetable, field, and flower seeds” and “bulbs”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
