{"tag":"section","attrib":{"id":"idefa30e06-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3241"},"text":null,"children":[{"tag":"num","attrib":{"value":"3241"},"text":"§ 3241.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education grants programs for Hispanic-serving institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa30e07-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3241/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make competitive grants to Hispanic-serving institutions for the purpose of promoting and strengthening the ability of Hispanic-serving institutions to carry out education, applied research, and related community development programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa30e08-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3241/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants made under this section shall be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa30e09-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3241/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the activities of Hispanic-serving institutions to enhance educational equity for underrepresented students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa30e0a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3241/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to strengthen institutional educational capacities, including libraries, curriculum, faculty, scientific instrumentation, instruction delivery systems, and student recruitment and retention, in order to respond to identified State, regional, national, or international educational needs in the food and agricultural sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa30e0b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3241/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to attract and support undergraduate and graduate students from underrepresented groups in order to prepare them for careers related to the food, agricultural, and natural resource systems of the United States, beginning with the mentoring of students at the high school level and continuing with the provision of financial support for students through their attainment of a doctoral degree; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa30e0c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3241/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate cooperative initiatives between 2 or more Hispanic-serving institutions, or between Hispanic-serving institutions and units of State government or the private sector, to maximize the development and use of resources, such as faculty, facilities, and equipment, to improve food and agricultural sciences teaching programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa30e0d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3241/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to make grants under this section $40,000,000 for each of fiscal years 1997 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa30e0e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1455"},"text":"Pub. L. 95–113, title XIV, § 1455","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s815/a"},"text":"Pub. L. 104–127, title VIII, § 815(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1166"},"text":"110 Stat. 1166","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tIII/s301/a/11"},"text":"Pub. L. 105–185, title III, § 301(a)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/562"},"text":"112 Stat. 562","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7111"},"text":"Pub. L. 107–171, title VII, § 7111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/433"},"text":"116 Stat. 433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7128"},"text":"Pub. L. 110–234, title VII, § 7128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1223"},"text":"122 Stat. 1223","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. 