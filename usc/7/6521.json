{"tag":"section","attrib":{"id":"idefe82d4b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521"},"text":null,"children":[{"tag":"num","attrib":{"value":"6521"},"text":"§ 6521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe82d4c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 540 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":", the Secretary shall issue proposed regulations to carry out this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82d4d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to State","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe82d4e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical and other assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide technical, administrative, and National Institute of Food and Agriculture assistance to assist States in the implementation of an organic certification program under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d4f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide financial assistance to any State that implements an organic certification program under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82d50-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to data documentation systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall have access to available data from cross-border documentation systems administered by other Federal agencies, including the Automated Commercial Environment system of U.S. Customs and Border Protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82d51-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe82d52-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2020-03-01"},"text":"March 1, 2020","children":[],"tail":", and annually thereafter through "},{"tag":"date","attrib":{"date":"2023-03-01"},"text":"March 1, 2023","children":[],"tail":", the Secretary shall submit to Congress, and make publicly available on the website of the Department of Agriculture, a report describing national organic program activities with respect to all domestic and overseas investigations and compliance actions taken pursuant to this chapter during the preceding year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d53-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The data described in paragraph (1) shall be broken down by agricultural product, quantity, value, and month.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d54-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any data determined by the Secretary to be confidential business information shall not be provided in the report under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe82d55-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXI/s2122"},"text":"Pub. L. 101–624, title XXI, § 2122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3951"},"text":"104 Stat. 3951","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s751