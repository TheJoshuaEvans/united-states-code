{"tag":"section","attrib":{"id":"idef6e90be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2160"},"text":null,"children":[{"tag":"num","attrib":{"value":"2160"},"text":"§ 2160.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on slaughter of dogs and cats for human consumption","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef6e90bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2160/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c), no person may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef6e90c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2160/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly slaughter a dog or cat for human consumption; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef6e90c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2160/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" knowingly ship, transport, move, deliver, receive, possess, purchase, sell, or donate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef6e90c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2160/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dog or cat to be slaughtered for human consumption; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef6e90c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2160/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dog or cat part for human consumption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef6e90c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2160/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall apply only with respect to conduct—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef6e90c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2160/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in or affecting interstate commerce or foreign commerce; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef6e90c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2160/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the special maritime and territorial jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef6e90c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2160/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for Indian tribes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prohibition in subsection (a) shall not apply to an Indian (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":") carrying out any activity described in subsection (a) for the purpose of a religious ceremony."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef6e90c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2160/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who violates subsection (a) shall be subject to a fine in an amount not greater than $5,000 for each violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef6e90c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2160/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on State law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7101ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2160/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limits any State or local law or regulation protecting the welfare of animals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7101cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2160/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevents a State or unit of local government from adopting and enforcing an animal welfare law or regulation that is more stringent than this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7101cc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12515"},"text":"Pub. L. 115–334, title XII, § 12515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5000"},"text":"132 Stat. 5000","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7101cd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef7101ce-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef7101cf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agriculture Improvement Act of 2018, and not as part of the Animal Welfare Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
