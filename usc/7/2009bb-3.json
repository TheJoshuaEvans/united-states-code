{"tag":"section","attrib":{"id":"idef2e2c4b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009bb–3"},"text":"§ 2009bb–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplements to Federal grant programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef2e2c4c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that certain States and local communities of the region may be unable to take maximum advantage of Federal grant programs for which the States and communities are eligible because—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2e2c4d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" they lack the economic resources to provide the required matching share; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2c4e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are insufficient funds available under the applicable Federal law authorizing the Federal grant program to meet pressing needs of the region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2e2c4f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal grant program funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any provision of law limiting the Federal share, the areas eligible for assistance, or the authorizations of appropriations, under any Federal grant program, and in accordance with subsection (c), the Authority, with the approval of the Federal cochairperson and with respect to a project to be carried out in the region—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2e2c50-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may increase the Federal share of the costs of a project under any Federal grant program to not more than 90 percent (except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009bb–5/b"},"text":"section 2009bb–5(b) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2c51-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall use amounts made available to carry out this subchapter to pay the increased Federal share.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2e2c52-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certifications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2e2c53-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any project for which all or any portion of the basic Federal share of the costs of the project is proposed to be paid under this section, no Federal contribution shall be made until the Federal official administering the Federal law that authorizes the Federal grant program certifies that the project—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2e2c54-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–3/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets (except as provided in subsection (b)) the applicable requirements of the applicable Federal grant program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2e2c55-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–3/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could be approved for Federal contribution under the Federal grant program if funds were available under the law for the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2c56-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification by Authority","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2e2c57-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–3/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The certifications and determinations required to be made by the Authority for approval of projects under this Act in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009bb–8"},"text":"section 2009bb–8 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"idef2e2c58-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–3/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be controlling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2e2c59-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–3/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be accepted by the Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2e2c5a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–3/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance by Federal cochairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any project described in paragraph (1), any finding, report, certification, or documentation required to be submitted with respect to the project to the head of the department, agency, or instrumentality of the Federal Government responsible for the administration of the Federal grant program under which the project is carried out shall be accepted by the Federal cochairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef2e2c5b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s383E"},"text":"Pub. L. 87–128, title III, § 383E","children":[],"tail":", formerly § 383D, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6028"},"text":"Pub. L. 107–171, title VI, § 6028","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/381"},"text":"116 Stat. 381","children":[],"tail":"; renumbered § 383E and amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVI/s6026/c/1/A"},"text":"Pub. L. 110–234, title VI, § 6026(c)(1)(A)","children":[],"tail":", (2)(C), (e), "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1178-1180"},"text":"122 Stat. 1178–1180","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VI, § 6026(c)(1)(A), (2)(C), (e), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1940, 1941.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef2e2c5c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef2e2c5d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef2e2c5e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (c)(2)(A), refers to the Agricultural Act of 1961, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/294"},"text":"75 Stat. 294","children":[],"tail":". For classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1911"},"text":"section 1911 of this title","children":[],"tail":" and Tables. However, the reference was probably intended to be “this title” meaning the Consolidated Farm and Rural Development Act, title III of "},{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", as amended, which is classified principally to this chapter. For classification of this title to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef2e2c5f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idef2e2c60-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/s383E"},"text":"section 383E of Pub. L. 87–128","children":[],"tail":", title III, was renumbered section 383F and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009bb–4"},"text":"section 2009bb–4 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef2e2c61-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s6026/e"},"text":"Pub. L. 110–246, § 6026(e)","children":[],"tail":", struck out “, including local development districts,” after “region” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s6026/c/2/C/i"},"text":"Pub. L. 110–246, § 6026(c)(2)(C)(i)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009bb–5/b"},"text":"section 2009bb–5(b) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s6026/c/2/C/ii"},"text":"Pub. L. 110–246, § 6026(c)(2)(C)(ii)","children":[],"tail":", made technical amendment to reference in original act which appears in introductory provisions as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009bb–8"},"text":"section 2009bb–8 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef2e2c62-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef2e2c63-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
