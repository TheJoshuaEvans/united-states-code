{"tag":"section","attrib":{"id":"idef75bc59-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204j"},"text":null,"children":[{"tag":"num","attrib":{"value":"2204j"},"text":"§ 2204j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National agriculture imagery program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef75bc5a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture, acting through the Administrator of the Farm Service Agency, shall carry out a national agriculture imagery program to annually acquire aerial imagery during agricultural growing seasons from the continental United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef75bc5b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The aerial imagery acquired under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef75bc5c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consist of high resolution processed digital imagery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef75bc5d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be made available in a format that can be provided to Federal, State, and private sector entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef75bc5e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204j/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be technologically compatible with geospatial information technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef75bc5f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204j/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be consistent with the standards established by the Federal Geographic Data Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef75bc60-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental satellite imagery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture may supplement the aerial imagery collected under this section with satellite imagery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef75bc61-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204j/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $23,000,000 for fiscal year 2019 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef75bc62-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12612"},"text":"Pub. L. 115–334, title XII, § 12612","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5013"},"text":"132 Stat. 5013","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
