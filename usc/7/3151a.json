{"tag":"section","attrib":{"id":"idef97270d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3151a"},"text":"§ 3151a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veterinary medicine loan repayment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef97270e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef97270f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service in shortage situations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a program of entering into agreements with veterinarians under which the veterinarians agree to provide, for a period of time as determined by the Secretary and specified in the agreement, veterinary services in veterinarian shortage situations. For each year of such service under an agreement under this paragraph, the Secretary shall pay an amount, as determined by the Secretary and specified in the agreement, of the principal and interest of qualifying educational loans of the veterinarians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef972710-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service to Federal Government in emergency situations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef972711-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into agreements of 1 year duration with veterinarians who have agreements pursuant to paragraph (1) for such veterinarians to provide services to the Federal Government in emergency situations, as determined by the Secretary, under terms and conditions specified in the agreement. Pursuant to an agreement under this paragraph, the Secretary shall pay an amount, in addition to the amount paid pursuant to the agreement in paragraph (1), as determined by the Secretary and specified in the agreement, of the principal and interest of qualifying educational loans of the veterinarians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef972712-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Agreements entered into under this paragraph shall include the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef972713-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A veterinarian shall not be required to serve more than 60 working days per year of the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef972714-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A veterinarian who provides service pursuant to the agreement shall receive a salary commensurate with the duties and shall be reimbursed for travel and per diem expenses as appropriate for the duration of the service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef972715-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of veterinarian shortage situations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining “veterinarian shortage situations”, the Secretary may consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef972716-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geographical areas that the Secretary determines have a shortage of veterinarians; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef972717-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" areas of veterinary practice that the Secretary determines have a shortage of veterinarians, such as food animal medicine, public health, epidemiology, and food safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef972718-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef972719-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may carry out this program directly or enter into agreements with another Federal agency or other service provider to assist in the administration of this program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef97271a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Breach remedies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef97271b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Agreements with program participants shall provide remedies for any breach of an agreement by a participant, including repayment or partial repayment of financial assistance received, with interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef97271c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts recovered","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds recovered under this subsection shall be credited to the account available to carry out this section and shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef97271d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may grant a waiver of the repayment obligation for breach of contract in the event of extreme hardship or extreme need, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef97271e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall develop regulations to determine the amount of loan repayment for a year of service by a veterinarian. In making the determination, the Secretary shall consider the extent to which such determination—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef97271f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affects the ability of the Secretary to maximize the number of agreements that can be provided under the Veterinary Medicine Loan Repayment Program from the amounts appropriated for such agreements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef972720-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides an incentive to serve in veterinary service shortage areas with the greatest need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef972721-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying educational loans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Loan repayments provided under this section may consist of payments on behalf of participating individuals of the principal and interest on government and commercial loans received by the individual for attendance of the individual at an accredited college of veterinary medicine resulting in a degree of Doctor of Veterinary Medicine or the equivalent, which loans were made for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef972722-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tuition expenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef972723-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all other reasonable educational expenses, including fees, books, and laboratory expenses, incurred by the individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef972724-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable living expenses as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef972725-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment schedule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into an agreement with the holder of any loan for which payments are made under this section to establish a schedule for the making of such payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef972726-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to educational loan repayments, the Secretary shall make such additional payments to participants as the Secretary determines to be appropriate for the purpose of providing reimbursements to participants for individual tax liability resulting from participation in this program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef972727-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In administering the program, the Secretary shall give priority to agreements with veterinarians for the practice of food animal medicine in veterinarian shortage situations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef972728-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the funds appropriated to the Secretary under subsection (f) may be used to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5379"},"text":"section 5379 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef972729-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subchapter II of chapter 5 of title 5, not later than 270 days after the date of enactment of this subsection, the Secretary shall promulgate regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef97272a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for carrying out this section such sums as may be necessary and such sums shall remain available to the Secretary for the purposes of this section until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef97272b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1415A"},"text":"Pub. L. 95–113, title XIV, § 1415A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/161/s2"},"text":"Pub. L. 108–161, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2014"},"text":"117 Stat. 2014","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7105/a"},"text":"Pub. L. 110–234, title VII, § 7105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1216"},"text":"122 Stat. 1216","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7105(a), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1977.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef97272c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef97272d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef97272e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this subsection, referred to in subsec. (e), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef97272f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef972730-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7105/a/1"},"text":"Pub. L. 110–246, § 7105(a)(1)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which authorized the Secretary to consider certain factors in determining “veterinarian shortage situations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7105/a/2"},"text":"Pub. L. 110–246, § 7105(a)(2)","children":[],"tail":", added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7105/a/3"},"text":"Pub. L. 110–246, § 7105(a)(3)","children":[],"tail":", (4), added subsecs. (d) and (e) and redesignated former subsec. (d) as (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef972731-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef972732-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
