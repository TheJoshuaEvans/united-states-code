{"tag":"section","attrib":{"id":"idef780706-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2241a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2241a"},"text":"§ 2241a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange or sale authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef780707-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2241a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of qualified item of personal property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “qualified item of personal property” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef780708-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2241a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an animal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef780709-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2241a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an animal product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef78070a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2241a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef78070b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2241a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plant product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef78070c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2241a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c), notwithstanding chapter 5 of subtitle I of title 40, the Secretary, acting through the Under Secretary for Research, Education, and Economics, in managing personal property for the purpose of carrying out the research functions of the Department, may exchange, sell, or otherwise dispose of any qualified item of personal property, including by way of public auction, and may retain and apply the sale or other proceeds, without further appropriation and without fiscal year limitation, in whole or in partial payment—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef78070d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2241a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire any qualified item of personal property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef78070e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2241a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to offset costs related to the maintenance, care, or feeding of any qualified item of personal property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef78070f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2241a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (b) does not apply to the free dissemination of new varieties of seeds and germplasm in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef780710-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tIII/s307"},"text":"Pub. L. 103–354, title III, § 307","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7408"},"text":"Pub. L. 110–234, title VII, § 7408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1252"},"text":"122 Stat. 1252","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7408, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2013; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7605"},"text":"Pub. L. 113–79, title VII, § 7605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/912"},"text":"128 Stat. 912","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef780711-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef780712-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"ta