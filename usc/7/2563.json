{"tag":"section","attrib":{"id":"idef865e5a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2563"},"text":null,"children":[{"tag":"num","attrib":{"value":"2563"},"text":"§ 2563.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The several courts having jurisdiction of cases under this subchapter may grant injunctions in accordance with the principles of equity to prevent the violation of any right hereunder on such terms as the court deems reasonable.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef865e5b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tIII/s123"},"text":"Pub. L. 91–577, title III, § 123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1556"},"text":"84 Stat. 1556","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
