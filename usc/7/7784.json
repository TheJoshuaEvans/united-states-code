{"tag":"section","attrib":{"id":"idf0216605-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784"},"text":null,"children":[{"tag":"num","attrib":{"value":"7784"},"text":"§ 7784.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0216606-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and consent","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out an agreement under this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0216607-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the activities funded under the agreement will take place on Federal land, consult with the heads of the Federal agencies having jurisdiction over the land; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0216608-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain the written consent of the non-Federal landowner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0216609-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into agreements under this section with weed management entities notwithstanding sections 6301 through 6309 of title 31 and other laws relating to the procurement of goods and services for the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf021660a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities carried out under an agreement under this section may include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf021660b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Education, inventories and mapping, management, monitoring, methods development, and other capacity building activities, including the payment of the cost of personnel and equipment that promote control or eradication of noxious weeds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf021660c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other activities to control or eradicate noxious weeds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf021660d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities funded under this section shall be selected by the Secretary taking into consideration the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf021660e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The severity of the noxious weeds problem or potential problem addressed by the activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf021660f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The likelihood that the activity will prevent or resolve the problem, or increase knowledge about resolving similar problems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0216610-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the activity will provide a comprehensive approach to the control or eradication of noxious weeds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0216611-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the program will improve the overall capacity of the United States to address noxious weed control and management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0216612-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the project promotes cooperation and participation between States that have common interests in controlling and eradicating noxious weeds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0216613-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other factors that the Secretary determines to be relevant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0216614-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional, State, and local involvement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining which activities receive funding under this section, the Secretary shall, to the maximum extent practicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0216615-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rely on technical and merit reviews provided by regional, State, or local weed management experts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0216616-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give priority to activities that maximize the involvement of State, local, and, where applicable, representatives of Indian Tribe governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0216617-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rapid response program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the request of the Governor of a State, the Secretary may enter into a cooperative agreement with a weed management entity in that State to enable rapid response to outbreaks of noxious weeds at a stage which rapid eradication and control is possible and to ensure eradication or immediate control of the noxious weeds if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0216618-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a demonstrated need for the assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0216619-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the noxious weed is considered to be a significant threat to native fish, wildlife, or their habitats, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf021661a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic impact of delaying action is considered by the Secretary to be substantial; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf021661b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the proposed response to such threat—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf021661c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is technically feasible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf021661d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economically responsible; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf021661e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7784/f/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimizes adverse impacts to the structure and function of an ecosystem and adverse effects on nontarget species and ecosystems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf021661f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/tIV/s455"},"text":"Pub. L. 106–224, title IV, § 455","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/412/s1"},"text":"Pub. L. 108–412, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2322"},"text":"118 Stat. 2322","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
