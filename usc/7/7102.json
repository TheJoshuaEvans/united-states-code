{"tag":"section","attrib":{"id":"ideffb402c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102"},"text":null,"children":[{"tag":"num","attrib":{"value":"7102"},"text":"§ 7102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter (unless the context clearly requires otherwise):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffb402d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the National Sheep Promotion, Research, and Information Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7104/b"},"text":"section 7104(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb402e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carbonized wool","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “carbonized wool” means wool that has been immersed in a bath, usually of mineral acids or acid salts, that destroys vegetable matter in the wool, but does not affect the wool fibres.","children":[{"tag":"ref","attrib":{"idref":"fn002327"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002327"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “fibers.”"}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb402f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “consumer information” means nutritional data and other information that will assist consumers and other persons in making evaluations and decisions regarding the purchase, preparation, or use of sheep products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb4030-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Customs Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Customs Service” means United States Customs Service of the Department of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb4031-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Degreased wool","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “degreased wool” means wool from which the bulk of impurities has been removed by processing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb4032-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department” means the United States Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb4033-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “education” means activities providing information relating to the sheep industry or sheep products to producers, feeders, importers, consumers, and other persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb4034-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Executive Committee” means the Executive Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7104/g"},"text":"section 7104(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb4035-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exporter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “exporter” means any person who exports domestic live sheep or greasy wool from the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb4036-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feeder","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “feeder” means a person who feeds lambs until the lambs reach slaughter weight.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb4037-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Greasy wool","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “greasy wool” means wool that has not been washed or otherwise cleaned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb4038-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Handler","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “handler” means any person who purchases and markets greasy wool.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb4039-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “importer” means any person who imports sheep or sheep products into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb403a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industry information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “industry information” means information and programs that will lead to increased efficiency in processing and the development of new markets, marketing strategies, increased marketing efficiency, and activities to enhance the image of sheep or sheep products on a national or international basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb403b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “order” means a sheep and wool promotion, research, education, and information order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7103"},"text":"section 7103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb403c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means any individual, group of individuals, partnership, corporation, association, cooperative, or any other legal entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb403d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Processor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “processor” means any person who slaughters sheep or processes greasy wool into degreased wool.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb403e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “producer” means any person, other than a feeder, who owns or acquires ownership of sheep.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb403f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “producer information” means activities designed to provide producers, feeders, and importers with information relating to production or marketing efficiencies or developments, program activities, or other information that would facilitate an increase in the consumption of sheep or sheep products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb4040-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “promotion” means any action (including paid advertising) to advance the image and desirability of sheep or sheep products to improve the competitive position, and stimulate sales, of sheep products in the domestic and international marketplace.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb4041-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pulled wool","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “pulled wool” means wool that is pulled from the skin of a slaughtered sheep.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb4042-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified State sheep board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified State sheep board” means a sheep and wool promotion entity that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideffb4043-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/22/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is authorized by State statute or is otherwise organized and operating within a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffb4044-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/22/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receives voluntary contributions or dues and conducts promotion, research, or consumer information programs with respect to sheep or wool, or both; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffb4045-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/22/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is recognized by the Board as the sheep and wool promotion entity within the State;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that not more than 1 qualified State sheep board shall exist in any State at any 1 time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb4046-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"(23)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Raw wool","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “raw wool” means greasy wool, pulled wool, degreased wool, or carbonized wool.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb4047-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/24"},"text":null,"children":[{"tag":"num","attrib":{"value":"24"},"text":"(24)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “research” means development projects and studies relating to the production (including the feeding of sheep), processing, distribution, or use of sheep or sheep products to encourage, expand, improve, or make more efficient the marketing of sheep or sheep products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb4048-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/25"},"text":null,"children":[{"tag":"num","attrib":{"value":"25"},"text":"(25)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb4049-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/26"},"text":null,"children":[{"tag":"num","attrib":{"value":"26"},"text":"(26)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sheep","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sheep” means ovine animals of any age, including lambs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb404a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/27"},"text":null,"children":[{"tag":"num","attrib":{"value":"27"},"text":"(27)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sheep products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sheep products” means products produced, in whole or in part, from sheep, including wool and products containing wool fiber.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb404b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/28"},"text":null,"children":[{"tag":"num","attrib":{"value":"28"},"text":"(28)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the 50 States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb404c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/29"},"text":null,"children":[{"tag":"num","attrib":{"value":"29"},"text":"(29)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “unit” means each State, group of States, or class designation that is represented on the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb404d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/30"},"text":null,"children":[{"tag":"num","attrib":{"value":"30"},"text":"(30)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” means the 50 States and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb404e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/31"},"text":null,"children":[{"tag":"num","attrib":{"value":"31"},"text":"(31)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wool","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “wool” means the fiber from the fleece of a sheep.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb404f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7102/32"},"text":null,"children":[{"tag":"num","attrib":{"value":"32"},"text":"(32)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wool products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “wool products” means products produced, in whole or in part, from wool and products containing wool fiber.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideffb4050-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/407/s3"},"text":"Pub. L. 103–407, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4211"},"text":"108 Stat. 4211","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideffb4051-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideffb4052-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"ideffb4053-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the United States Customs Service of the Department of the Treasury, including functions of the Secretary of the Treasury relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see sections 203(1), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":". For establishment of U.S. Customs and Border Protection in the Department of Homeland Security, treated as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/114/125"},"text":"Pub. L. 114–125","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/s802/b"},"text":"section 802(b) of Pub. L. 114–125","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
