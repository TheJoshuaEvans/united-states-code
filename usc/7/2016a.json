{"tag":"section","attrib":{"id":"idef486b31-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2016a"},"text":"§ 2016a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" EBT benefit fraud prevention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef486b32-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance; rulemaking","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef486b33-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" issue guidance to State agencies, on an ongoing basis, as informed by the process outlined in paragraph (4), that describes security measures that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef486b34-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are effective, as determined by the Secretary, in detecting and preventing theft of benefits, including through card skimming, card cloning, and other similar fraudulent methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef486b35-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with industry standards for detecting, identifying, and preventing debit and credit card skimming, card cloning, and other similar fraudulent methods; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef486b36-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the feasibility of cost, availability, and implementation for States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef486b37-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promulgate regulations through notice-and-comment rulemaking to require State agencies to take the security measures described in the guidance issued under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef486b38-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than ","children":[{"tag":"date","attrib":{"date":"2023-12-01"},"text":"December 1, 2023","children":[],"tail":", promulgate regulations (including an interim final rule) to require State agencies to implement procedures for the replacement of benefits consistent with subsection (b);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef486b39-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordinate with the Administrator of the Administration for Children and Families of the Department of Health and Human Services, the Attorney General of the United States, State agencies, retail food stores, and EBT contractors—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef486b3a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to determine—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef486b3b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how benefits are being stolen through card skimming, card cloning, and other similar fraudulent methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef486b3c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how those stolen benefits are used; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef486b3d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/a/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the locations where card skimming, card cloning, and other similar fraudulent methods are taking place;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef486b3e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish measures, including equipment enhancements for retail food stores, to prevent benefits from being stolen through card skimming, card cloning, and other similar fraudulent methods; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef486b3f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish standard reporting methods for States to collect and share data with the Secretary on the scope of benefits being stolen through card skimming, card cloning, and other similar fraudulent methods; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef486b40-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than ","children":[{"tag":"date","attrib":{"date":"2024-12-01"},"text":"December 1, 2024","children":[],"tail":", submit to the Committee on Agriculture, Nutrition, and Forestry of the Senate and the Committee on Agriculture of the House of Representatives a report that includes—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef486b41-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the frequency of theft of benefits and the location of those thefts, including benefits stolen through card skimming, card cloning, and other similar fraudulent methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef486b42-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the determinations made under paragraph (4)(A), the measures established under paragraph (4)(B), and methods established in paragraph (4)(C);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef486b43-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the industry standards described in paragraph (1)(B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef486b44-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comparison of State plans related to reimbursement, prevention, and other relevant procedures approved in accordance with subsection (b)(1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef486b45-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/a/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations on how to consistently and proactively detect, track, report, and prevent theft of benefits, including benefits stolen through card skimming, card cloning, and other similar fraudulent methods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef486b46-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replacement of benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall use funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2027"},"text":"section 2027 of this title","children":[],"tail":" to require States to replace benefits that are determined by the State agency to have been stolen through card skimming, card cloning, or similar fraudulent methods, subject to the conditions that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef486b47-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the State agency shall submit to the Secretary not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", for prior approval a plan for the replacement of stolen benefits that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef486b48-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes appropriate procedures, as determined by the Secretary, for the timely submission of claims to, timely validation of claims by, and replacement issuance by the State agency that includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef486b49-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a signed statement by the affected household on the benefit theft, consistent with the signature requirements and options provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2020/e/2/C"},"text":"section 2020(e)(2)(C) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef486b4a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criteria to determine if a submitted claim is valid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef486b4b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for the documentation of replacement issuances, including the submitted claims and findings from the validation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef486b4c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the submission of data reports on benefit theft and replacement activity to the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef486b4d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/b/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures to inform households of their right to a fair hearing, consistent with those already established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2020/e"},"text":"section 2020(e) of this title","children":[],"tail":" and corresponding regulations concerning replacement issuances; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef486b4e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/b/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State agency’s use and planned use of benefit theft prevention measures, including any additional guidance that may be issued under subsection (a)(1);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef486b4f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes appropriate procedures, as determined by the Secretary, for reporting the scope and frequency of card skimming affecting households within the State to the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef486b50-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon approval shall be incorporated into the State plan of operation required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2020/e"},"text":"section 2020(e) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef486b51-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may approve after the date on which guidance is issued under subsection (a)(1);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef486b52-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the replacement of stolen benefits for a household—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef486b53-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall not exceed the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef486b54-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of benefits stolen from the household; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef486b55-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount equal to 2 months of the monthly allotment of the household immediately prior to the date on which the benefits were stolen;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef486b56-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not occur more than 2 times per Federal fiscal year per household by a single State agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef486b57-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall only apply to benefits stolen during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2022-10-01"},"text":"October 1, 2022","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2024-12-20"},"text":"December 20, 2024","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef486b58-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans approved under paragraph (1) will remain in effect until the effective date of the rule promulgated pursuant to subsection (a)(3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef486b59-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" replacements of benefits under this section shall not be regarded as losses for the purpose of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2016/e"},"text":"section 2016(e) of this title","children":[],"tail":" to the extent such replacements are made in accordance with an approved plan that complies with this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef486b5a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the terms “allotment”, “benefit”, “household”, “retail food store”, and “State agency” have the meaning given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2012"},"text":"section 2012 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef486b5b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rescission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the unobligated balances made available for the Supplemental Nutrition Assistance Program as authorized by section 1101(b)(1) of the American Rescue Plan Act of 2021 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2"},"text":"Public Law 117–2","children":[],"tail":"), $8,000,000 is hereby rescinded."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef486b5c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comptroller General","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef486b5d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2024-09-26"},"text":"September 26, 2024","children":[],"tail":", the Comptroller General of the United States shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that examines risks related to supplemental nutrition assistance program electronic benefit transfer payment system security, including the risk of stolen benefits through card skimming, card cloning, and other similar methods."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef486b5e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under paragraph (1) shall include an assessment of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef486b5f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the Department of Agriculture manages payment system security, including risks related to stolen benefits, compared to leading industry practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef486b60-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which States, retailers, and other relevant entities manage risks related to stolen benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef486b61-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the oversight of and guidance provided by the Secretary to States regarding stolen benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef486b62-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommendations and policy options for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef486b63-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/e/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving how the Department of Agriculture and other relevant entities manage payment system security risks, including those related to stolen benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef486b64-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2016a/e/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Department of Agriculture may best share those improvements with States, retailers, and other relevant entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef486b65-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dHH/tIV/s501"},"text":"Pub. L. 117–328, div. HH, title IV, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5985"},"text":"136 Stat. 5985","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/83/dB/tI/s105"},"text":"Pub. L. 118–83, div. B, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-09-26"},"text":"Sept. 26, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1534"},"text":"138 Stat. 1534","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef486b66-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef486b67-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef486b68-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1101(b)(1) of the American Rescue Plan Act of 2021, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/s1101/b/1"},"text":"section 1101(b)(1) of Pub. L. 117–2","children":[],"tail":", title I, "}