{"tag":"section","attrib":{"id":"idef841468-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2421"},"text":null,"children":[{"tag":"num","attrib":{"value":"2421"},"text":"§ 2421.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for recognition of plant variety rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef841469-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2421/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An application for a certificate of Plant Variety Protection may be filed by the owner of the variety sought to be protected. The application shall be made in writing to the Secretary, shall be signed by or on behalf of the applicant, and shall be accompanied by the prescribed fee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef84146a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2421/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An error as to the naming of the breeder, without deceptive intent, may be corrected at any time, in accordance with regulations established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef84146b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tII/s51"},"text":"Pub. L. 91–577, title II, § 51","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1548"},"text":"84 Stat. 1548","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
