{"tag":"section","attrib":{"id":"idf010c47d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7510"},"text":null,"children":[{"tag":"num","attrib":{"value":"7510"},"text":"§ 7510.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodities not income","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, commodities distributed under this chapter shall not be considered income or resources for any purposes under any Federal, State, or local law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf010c47e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/8/tII/s206"},"text":"Pub. L. 98–8, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-03-24"},"text":"Mar. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/36"},"text":"97 Stat. 36","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
