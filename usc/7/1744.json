{"tag":"section","attrib":{"id":"ideef9af0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1744"},"text":null,"children":[{"tag":"num","attrib":{"value":"1744"},"text":"§ 1744.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of commodities in set-aside; exemption from pricing limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideef9af10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1744/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Corporation shall have authority to sell, without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1743/a/7"},"text":"section 1743(a)(7) of this title","children":[],"tail":", any commodity covered by the commodity set-aside for the purpose of rotating stocks or consolidating inventories, any such sale to be offset by purchase of the same commodity in a substantially equivalent quantity or of a substantially equivalent value."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideefc1f11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1744/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Dispositions pursuant to this chapter shall not be subject to the pricing limitations of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1427"},"text":"section 1427 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideefc1f12-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-28/ch1041"},"text":"Aug. 28, 1954, ch. 1041","children":[],"tail":", title I, § 104, "},{"tag":"ref","attrib":{"href":"/us/stat/68/898"},"text":"68 Stat. 898","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
