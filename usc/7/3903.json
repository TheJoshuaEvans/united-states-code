{"tag":"section","attrib":{"id":"idefb13ef5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3903"},"text":null,"children":[{"tag":"num","attrib":{"value":"3903"},"text":"§ 3903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual program review to achieve coordination with National Cancer Institute program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture and the Director of the National Institutes of Health shall annually review the research program conducted under this chapter in order to coordinate the program with the National Cancer Institute research program.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefb13ef6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/469/s4"},"text":"Pub. L. 96–469, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2235"},"text":"94 Stat. 2235","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
