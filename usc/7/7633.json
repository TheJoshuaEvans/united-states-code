{"tag":"section","attrib":{"id":"idf017c9ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633"},"text":null,"children":[{"tag":"num","attrib":{"value":"7633"},"text":"§ 7633.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food and agriculture service learning program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf017c9ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations under subsection (e), the Secretary, acting through the Director of the National Institute of Food and Agriculture, and working in consultation with other appropriate Federal agencies that oversee national service programs, shall administer a competitively awarded food and agriculture service learning grant program (referred to in this section as the “Program”) to increase knowledge of agriculture and improve the nutritional health of children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf017c9af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Program are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf017c9b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase capacity for food, garden, and nutrition education within host organizations or entities and school cafeterias and in the classroom;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf017c9b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to complement and build on the efforts of the farm to school programs implemented under section 18(g) of the Richard B. Russell National School Lunch Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1769/g"},"text":"42 U.S.C. 1769(g)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf017c9b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to complement efforts by the Department and school food authorities to implement the school lunch program established under the Richard B. Russell National School Lunch Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"42 U.S.C. 1751","children":[],"tail":" et seq.) and the school breakfast program established by "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1773"},"text":"section 1773 of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf017c9b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out activities that advance the nutritional health of children and nutrition education in elementary schools and secondary schools (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf017c9b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to foster higher levels of community engagement and support the expansion of national service and volunteer opportunities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf017c9b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf017c9b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the Program, the Director of the National Institute of Food and Agriculture shall make competitive grants to eligible entities that carry out the purposes described in paragraphs (1) through (5) of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf017c9b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants under this section, the Secretary may consider projects that are carried out by entities that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf017c9b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a proven track record in carrying out the purposes described in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf017c9b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work in underserved rural and urban communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf017c9ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" teach and engage children in experiential learning about agriculture, gardening, nutrition, cooking, and where food comes from; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf017c9bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate a connection between elementary schools and secondary schools and agricultural producers in the local and regional area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf017c9bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf017c9bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may require a partner organization or other qualified entity to collect and report any data on the activities carried out under the Program, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf017c9be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf017c9bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct regular evaluations of the activities carried out under the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf017c9c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that includes a description of the results of each evaluation conducted under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf017c9c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf017c9c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out the Program $25,000,000, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf017c9c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraphs (4), (7), (8), and (11)(B) of subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3157"},"text":"section 3157 of this title","children":[],"tail":" shall apply with respect to the making of a competitive grant under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf017c9c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7633/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of effort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under paragraph (1) shall be used only to supplement, not to supplant, the amount of Federal funding otherwise expended for nutrition, research, and extension programs of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf017c9c5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/tIV/s413"},"text":"Pub. L. 105–185, title IV, § 413","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIV/s4209"},"text":"Pub. L. 113–79, title IV, § 4209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/829"},"text":"128 Stat. 829","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/g"},"text":"Pub. L. 114–95, title IX, § 9215(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2166"},"text":"129 Stat. 2166","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf017c9c6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf017c9c7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf017c9c8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Richard B. Russell National School Lunch Act, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281"},"text":"act June 4, 1946, ch. 281","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/230"},"text":"60 Stat. 230","children":[],"tail":", which is classified generally to chapter 13 (§ 1751 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"section 1751 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf017c9c9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf017c9ca-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf017c9cb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
