{"tag":"section","attrib":{"id":"idee3d637d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518"},"text":null,"children":[{"tag":"num","attrib":{"value":"518"},"text":"§ 518.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter and subchapter II:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee3d637e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural Act of 1949","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Agricultural Act of 1949” means the Agricultural Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"7 U.S.C. 1421","children":[],"tail":" et seq.), as in effect on the day before "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"October 22, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3d637f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural Adjustment Act of 1938","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Agricultural Adjustment Act of 1938” means the Agricultural Adjustment Act of 1938 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1281"},"text":"7 U.S.C. 1281","children":[],"tail":" et seq.), as in effect on the day before "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"October 22, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3d6380-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considered planted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “considered planted” means tobacco that was planted, but failed to be produced as a result of a natural disaster, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3d6381-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “contract” means a contract entered into under section 518a or 518b of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3d6382-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “contract payment” means a payment made under section 518a or 518b of this title pursuant to a contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3d6383-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer of quota tobacco","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “producer of quota tobacco” means an owner, operator, landlord, tenant, or sharecropper that shared in the risk of producing tobacco on a farm where tobacco was produced or considered planted pursuant to a tobacco farm poundage quota or farm acreage allotment established under part I of subtitle B of title III of the Agricultural Adjustment Act of 1938 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1311"},"text":"7 U.S.C. 1311","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3d6384-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quota tobacco","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term ‘quota tobacco’ ","children":[{"tag":"ref","attrib":{"idref":"fn002093"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002093"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" means a kind of tobacco that is subject to a farm marketing quota or farm acreage allotment for the 2004 tobacco marketing year under a marketing quota or allotment program established under part I of subtitle B of title III of the Agricultural Adjustment Act of 1938 ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1311"},"text":"7 U.S.C. 1311","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3d6385-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tobacco","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “tobacco” means each of the following kinds of tobacco:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee3d6386-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Flue-cured tobacco, comprising types 11, 12, 13, and 14.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee3d6387-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fire-cured tobacco, comprising types 22 and 23.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee3d6388-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Dark air-cured tobacco, comprising types 35 and 36.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee3d6389-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Virginia sun-cured tobacco, comprising type 37.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee3d638a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518/8/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Virginia fire-cured tobacco, comprising type 21.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee3d638b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518/8/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Burley tobacco, comprising type 31.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee3d638c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518/8/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cigar-filler and cigar-binder tobacco, comprising types 42, 43, 44, 53, 54, and 55.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3d638d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tobacco quota holder","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tobacco quota holder” means a person that was an owner of a farm, as of ","children":[{"tag":"date","attrib":{"date":"2004-10-22"},"text":"October 22, 2004","children":[],"tail":", for which a basic tobacco farm marketing quota or farm acreage allotment for quota tobacco was established for the 2004 tobacco marketing year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3d638e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tobacco Trust Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Tobacco Trust Fund” means the Tobacco Trust Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s518e"},"text":"section 518e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3d638f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s518/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee3d6390-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVI/s621"},"text":"Pub. L. 108–357, title VI, § 621","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1524"},"text":"118 Stat. 1524","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee3d6391-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee3d6392-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idee3d6393-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Agricultural Act of 1949, referred to in par. (1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-31/ch792"},"text":"act Oct. 31, 1949, ch. 792","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/1051"},"text":"63 Stat. 1051","children":[],"tail":", which is classified principally to chapter 35A (§ 1421 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Agricultural Adjustment Act of 1938, referred to in pars. (2), (6), and (7), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"act Feb. 16, 1938, ch. 30","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/31"},"text":"52 Stat. 31","children":[],"tail":", which is classified principally to chapter 35 (§ 1281 et seq.) of this title. Part I of subtitle B of title III of the Act was classified to subpart I (§ 1311 et seq.) of part B of subchapter II of chapter 35 of this title prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVI/s611/a"},"text":"Pub. L. 108–357, title VI, § 611(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1522"},"text":"118 Stat. 1522","children":[],"tail":". For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1281"},"text":"section 1281 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee3d6394-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idee3d6395-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVI/s643"},"text":"Pub. L. 108–357, title VI, § 643","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1536"},"text":"118 Stat. 1536","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tVI/s643"},"text":"“This title [see Short Title note below] and the amendments made by this title shall apply to the 2005 and subsequent crops of each kind of tobacco.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idee3d6396-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVI/s601"},"text":"Pub. L. 108–357, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1521"},"text":"118 Stat. 1521","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tVI/s601"},"text":"“This title [enacting this chapter, amending sections 609, 1282, 1301, 1303, 1314h, 1361, 1371, 1373, 1375, 1378, 1379, 1428, 1433c–1, and 1441 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s714c"},"text":"section 714c of Title 15","children":[],"tail":", Commerce and Trade, repealing sections 511r, 515 to 515k, 625, 1311 to 1314, 1314–1, 1314b, 1314b–1, 1314b–2, 1314c to 1314j, 1315, 1316, 1445, 1445–1, and 1445–2 of this title, enacting provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s515"},"text":"section 515 of this title","children":[],"tail":", and repealing provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1314c"},"text":"section 1314c of this title","children":[],"tail":"] may be cited as the ‘Fair and Equitable Tobacco Reform Act of 2004’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
