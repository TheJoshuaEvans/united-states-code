{"tag":"section","attrib":{"id":"idf0347861-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8301"},"text":null,"children":[{"tag":"num","attrib":{"value":"8301"},"text":"§ 8301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0347862-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the prevention, detection, control, and eradication of diseases and pests of animals are essential to protect—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0347863-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8301/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" animal health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0347864-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8301/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the health and welfare of the people of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0347865-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8301/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic interests of the livestock and related industries of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0347866-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8301/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the environment of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0347867-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8301/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interstate commerce and foreign commerce of the United States in animals and other articles;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0347868-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" animal diseases and pests are primarily transmitted by animals and articles regulated under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0347869-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the health of animals is affected by the methods by which animals and articles are transported in interstate commerce and foreign commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf034786a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8301/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary must continue to conduct research on animal diseases and pests that constitute a threat to the livestock of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf034786b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8301/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf034786c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8301/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all animals and articles regulated under this chapter are in or affect interstate commerce or foreign commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf034786d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8301/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" regulation by the Secretary and cooperation by the Secretary with foreign countries, States or other jurisdictions, or persons are necessary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf034786e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8301/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent and eliminate burdens on interstate commerce and foreign commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf034786f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8301/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to regulate effectively interstate commerce and foreign commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0347870-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8301/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect the agriculture, environment, economy, and health and welfare of the people of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0347871-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10402"},"text":"Pub. L. 107–171, title X, § 10402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/494"},"text":"116 Stat. 494","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0347872-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0347873-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf0347874-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in pars. (2) and (5)(A), was in the original “this subtitle”, meaning subtitle E (§§ 10401–10418) of title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/494"},"text":"116 Stat. 494","children":[],"tail":", which is classified principally to this chapter. For complete classification of subtitle E to the Code, see Short Title note set out below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf0347875-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idf0347876-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10401"},"text":"Pub. L. 107–171, title X, § 10401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/494"},"text":"116 Stat. 494","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/171/tX/s10401"},"text":"“This subtitle [subtitle E (§§ 10401–10418) of title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":", enacting this chapter, amending sections 7714 and 7733 of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1540"},"text":"section 1540 of Title 16","children":[],"tail":", Conservation, and sections 136a and 618 of Title 21, Food and Drugs, and repealing sections 429, 2260, 2260a of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1306"},"text":"section 1306 of Title 19","children":[],"tail":", Customs Duties, sections 102 to 105, 111, 112, 113, 114 to 114d–1, 114e to 114h, 115 to 131, 134 to 135b, 612 to 614 of Title 21, sections 3901 and 3902 of Title 46, Shipping, and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s129a"},"text":"section 129a of Title 21","children":[],"tail":"] may be cited as the ‘Animal Health Protection Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idf0347877-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of the Secretary of Agriculture relating to agricultural import and entry inspection activities under this chapter to the Secretary of Homeland Security, and for treatment of related references, see sections 231, 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
