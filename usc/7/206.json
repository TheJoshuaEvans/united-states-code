{"tag":"section","attrib":{"id":"idee1e4312-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s206"},"text":null,"children":[{"tag":"num","attrib":{"value":"206"},"text":"§ 206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rates and charges generally; discrimination","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All rates or charges made for any stockyard services furnished at a stockyard by a stockyard owner or market agency shall be just, reasonable, and nondiscriminatory, and any unjust, unreasonable, or discriminatory rate or charge is prohibited and declared to be unlawful: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That rates and charges based upon percentages of the gross sales prices of livestock shall not be prohibited merely because they are based upon such percentages rather than on a per head basis."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee1e4313-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-08-15/ch64"},"text":"Aug. 15, 1921, ch. 64","children":[],"tail":", title III, § 305, "},{"tag":"ref","attrib":{"href":"/us/stat/42/164"},"text":"42 Stat. 164","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/409/s1/a"},"text":"Pub. L. 95–409, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-02"},"text":"Oct. 2, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/886"},"text":"92 Stat. 886","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee1e4314-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee1e4315-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee1e4316-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/409"},"text":"Pub. L. 95–409","children":[],"tail":" inserted proviso that rates and charges based upon percentages of gross sales of livestock shall not be prohibited merely because based on such percentages rather than on a per head basis."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
