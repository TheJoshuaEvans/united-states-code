{"tag":"section","attrib":{"id":"ideef9ae43-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1738b"},"text":"§ 1738b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for benefits under Facility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideef9ae44-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for benefits from the Facility under this subchapter, a country shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef9ae45-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a Latin American or Caribbean country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9ae46-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" have in effect or have received approval for, or, as appropriate in exceptional circumstances, be making significant progress towards the establishment of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideef9ae47-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an International Monetary Fund (hereafter referred to in this subchapter as the “IMF”) standby arrangement, extended IMF arrangement, or an arrangement under the structural adjustment facility or enhanced structural adjustment facility, or in exceptional circumstances, an IMF-monitored program or its equivalent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef9ae48-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, structural or sectoral adjustment loans from the International Bank for Reconstruction and Development (hereafter referred to in this subchapter as the “World Bank”) or the International Development Association (hereafter referred to in this subchapter as the “IDA”);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9ae49-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have placed into effect major investment reforms in conjunction with an Inter-American Development Bank (hereafter referred to as the “IDB”) loan or otherwise be implementing, or making significant progress towards an open investment regime; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9ae4a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if appropriate, have agreed with its commercial bank lenders on a satisfactory financing program, including, as appropriate, debt or debt service reduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9ae4b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall determine whether a country is an eligible country for purposes of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideef9ae4c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title VI, § 603, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3658"},"text":"104 Stat. 3658","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIII/s302"},"text":"Pub. L. 102–237, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1855"},"text":"105 Stat. 1855","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideef9ae4d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideef9ae4e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideef9ae4f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" inserted hyphen between “Inter” and “American”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ideef9ae50-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"ideef9ae51-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under subsec. (b) of this section, see section 1 of Ex. Ord. No. 13345, ","children":[{"tag":"date","attrib":{"date":"2004-07-08"},"text":"July 8, 2004","children":[],"tail":", 69 F.R. 41901, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738"},"text":"section 1738 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
