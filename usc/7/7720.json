{"tag":"section","attrib":{"id":"idf01caaa0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7720"},"text":null,"children":[{"tag":"num","attrib":{"value":"7720"},"text":"§ 7720.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National plan for control and management of Sudden Oak Death","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf01caaa1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7720/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of national plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriated funds for this purpose, the Secretary of Agriculture, acting through the Animal Plant and Health Inspection Service, shall develop a national plan for the control and management of Sudden Oak Death, a forest disease caused by the fungus-like pathogen Phytophthora ramorum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01caaa2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7720/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the plan, the Secretary shall specifically address the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01caaa3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7720/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information derived by the Department of Agriculture from ongoing efforts to identify hosts of Phytophthora ramorum and survey the extent to which Sudden Oak Death exists in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caaa4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7720/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Past and current efforts to understand the risk posed by Phytophthora ramorum and the results of control and management efforts regarding Sudden Oak Death, including efforts related to research, control, quarantine, and hazardous fuel reduction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caaa5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7720/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such future efforts as the Secretary considers necessary to control and manage Sudden Oak Death, including cost estimates for the implementation of such efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01caaa6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7720/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop the plan in consultation with other Federal agencies that have appropriate expertise regarding the control and management of Sudden Oak Death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01caaa7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7720/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall complete the plan and commence implementation as soon as practicable after the date on which funds are first appropriated pursuant to the authorization of appropriations in subsection (e) to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01caaa8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7720/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf01caaa9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/488/s1"},"text":"Pub. L. 108–488, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3964"},"text":"118 Stat. 3964","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf01caaaa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf01caaab-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf01caaac-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Plant Protection Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
