{"tag":"section","attrib":{"id":"ideed388e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1602"},"text":null,"children":[{"tag":"num","attrib":{"value":"1602"},"text":"§ 1602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The institution of any one of the proceedings provided for in sections 1595, 1596, 1599 to 1601 of this title shall not bar institution of any of the others, except that action shall not be instituted under both subsections 1596(a) and (b) of this title for the same cause of action. Nothing in this chapter shall be construed as requiring the Secretary of Agriculture to recommend prosecution, or institution of civil penalty proceedings, libel proceedings, cease-and-desist proceedings, or proceedings for the enforcement of a cease-and-desist order, for minor violations of this chapter or the rules and regulations made and promulgated thereunder whenever he believes that the public interest will be adequately served by suitable written notice or warning.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideed388e9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-09/ch615"},"text":"Aug. 9, 1939, ch. 615","children":[],"tail":", title IV, § 412, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1288"},"text":"53 Stat. 1288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-09/ch520/s3"},"text":"July 9, 1956, ch. 520, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/508"},"text":"70 Stat. 508","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideed388ea-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideed388eb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideed388ec-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1956—Act ","children":[{"tag":"date","attrib":{"date":"1956-07-09"},"text":"July 9, 1956","children":[],"tail":", inserted references to civil penalties as well as criminal penalties under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1596"},"text":"section 1596 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideed388ed-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideed388ee-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1956 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendments made by act ","children":[{"tag":"date","attrib":{"date":"1956-07-09"},"text":"July 9, 1956","children":[],"tail":", applicable only with respect to violations occurring after "},{"tag":"date","attrib":{"date":"1956-07-09"},"text":"July 9, 1956","children":[],"tail":", see section 4 of act "},{"tag":"date","attrib":{"date":"1956-07-09"},"text":"July 9, 1956","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1596"},"text":"section 1596 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideed388ef-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","a