{"tag":"section","attrib":{"id":"idf0406028-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740"},"text":null,"children":[{"tag":"num","attrib":{"value":"8740"},"text":"§ 8740.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments of loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0406029-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (e), the Secretary may make appropriate adjustments in the loan rates for any loan commodity (other than cotton) for differences in grade, type, quality, location, and other factors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf040602a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The adjustments under subsection (a) shall, to the maximum extent practicable, be made in such a manner that the average loan level for the commodity will, on the basis of the anticipated incidence of the factors, be equal to the level of support determined in accordance with this subtitle and subtitles B through E.","children":[{"tag":"ref","attrib":{"idref":"fn002378"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002378"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf040602b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment on county basis","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf040602c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish loan rates for a crop for producers in individual counties in a manner that results in the lowest loan rate being 95 percent of the national average loan rate, if those loan rates do not result in an increase in outlays.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf040602d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Adjustments under this subsection shall not result in an increase in the national average loan rate for any year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf040602e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment in loan rate for cotton","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf040602f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make appropriate adjustments in the loan rate for cotton for differences in quality factors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0406030-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revisions to quality adjustments for upland cotton","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0406031-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the date of enactment of this Act, the Secretary shall implement revisions in the administration of the marketing assistance loan program for upland cotton to more accurately and efficiently reflect market values for upland cotton.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0406032-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory revisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Revisions under subparagraph (A) shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0406033-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the elimination of warehouse location differentials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0406034-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of differentials for the various quality factors and staple lengths of cotton based on a 3-year, weighted moving average of the weighted designated spot market regions, as determined by regional production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0406035-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the elimination of any artificial split in the premium or discount between upland cotton with a 32 or 33 staple length due to micronaire; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0406036-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/d/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mechanism to ensure that no premium or discount is established that exceeds the premium or discount associated with a leaf grade that is 1 better than the applicable color grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0406037-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary revisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Revisions under subparagraph (A) may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0406038-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of non-spot market price data, in addition to spot market price data, that would enhance the accuracy of the price information used in determining quality adjustments under this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0406039-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjustments in the premiums or discounts associated with upland cotton with a staple length of 33 or above due to micronaire with the goal of eliminating any unnecessary artificial splits in the calculations of the premiums or discounts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf040603a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/d/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other adjustments as the Secretary determines appropriate, after consultations conducted in accordance with paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf040603b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with private sector","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf040603c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior to revision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making adjustments to the loan rate for cotton (including any review of the adjustments) as provided in this subsection, the Secretary shall consult with representatives of the United States cotton industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf040603d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability of chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply to consultations under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf040603e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of adjustments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may review the operation of the upland cotton quality adjustments implemented pursuant to this subsection and may make further revisions to the administration of the loan program for upland cotton, by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf040603f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revoking or revising any actions taken under paragraph (2)(B); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0406040-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revoking or revising any actions taken or authorized to be taken under paragraph (2)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0406041-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8740/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not make adjustments in the loan rates for long grain rice and medium grain rice, except for differences in grade and quality (including milling yields).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0406042-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1210"},"text":"Pub. L. 110–234, title I, § 1210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/965"},"text":"122 Stat. 965","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1210, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1693; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/42"},"text":"Pub. L. 117–286, § 4(a)(42)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4310"},"text":"136 Stat. 4310","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0406043-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0406044-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf0406045-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subtitle and subtitles B through E, referred to in subsec. (b), probably means subtitle B (§ 1201 et seq.) and subtitles C (§ 1301 et seq.), D (§ 1401 et seq.), and E (§ 1501 et seq.) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1681"},"text":"122 Stat. 1681","children":[],"tail":". Subtitles B and C are classified generally to this subchapter and subchapter III (§ 8751 et seq.), respectively, of this chapter. Subtitle D enacted sections 1359kk, 1359"},{"tag":"i","attrib":{},"text":"ll","children":[],"tail":", and 7287 of this title, amended sections 1359aa to 1359gg, 1359ii, 7272, and 7971 of this title, repealed former "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1359kk"},"text":"section 1359kk of this title","children":[],"tail":", and enacted provisions set out as notes under sections 3602 and 7272 of this title. Subtitle E enacted subchapter IV (§ 8771 et seq.) of this chapter and amended sections 608c, 1637b, 4502, 4504, 4531, and 4553 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s713a–14"},"text":"section 713a–14 of Title 15","children":[],"tail":", Commerce and Trade. For complete classification of subtitles B to E to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this Act, referred to in subsec. (d)(2)(A), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf0406046-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf0406047-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5” for “Federal Advisory Committee Act” in heading and “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)” in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf0406048-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf0406049-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
