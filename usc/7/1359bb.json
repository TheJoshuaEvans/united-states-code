{"tag":"section","attrib":{"id":"idee89aefd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"1359bb"},"text":"§ 1359bb.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flexible marketing allotments for sugar","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee89aefe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sugar estimates","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee89aeff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than August 1 before the beginning of each of the 2008 through 2031 crop years for sugarcane and sugar beets, the Secretary shall estimate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee89af00-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of sugar that will be subject to human consumption in the United States during the crop year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee89af01-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of sugar that would provide for reasonable carryover stocks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee89af02-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of sugar that will be available from carry-in stocks for human consumption in the United States during the crop year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee89af03-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of sugar that will be available from the domestic processing of sugarcane, sugar beets, and in-process beet sugar; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee89af04-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of sugars, syrups, and molasses that will be imported for human consumption or to be used for the extraction of sugar for human consumption in the United States during the crop year, whether the articles are under a tariff-rate quota or are in excess or outside of a tariff-rate quota.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee89af05-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The estimates under this subsection shall not apply to sugar imported for the production of polyhydric alcohol or to any sugar refined and reexported in refined form or in products containing sugar.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee89af06-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reestimates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make reestimates of sugar consumption, stocks, production, and imports for a crop year as necessary, but not later than the beginning of each of the second through fourth quarters of the crop year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee89af07-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sugar allotments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee89af08-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"By the beginning of each crop year, the Secretary shall establish for that crop year appropriate allotments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1359cc"},"text":"section 1359cc of this title","children":[],"tail":" for the marketing by processors of sugar processed from sugar cane or sugar beets or in-process beet sugar (whether the sugar beets or in-process beet sugar was produced domestically or imported) at a level that is—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee89af09-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sufficient to maintain raw and refined sugar prices above forfeiture levels so that there will be no forfeitures of sugar to the Commodity Credit Corporation under the loan program for sugar established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7272"},"text":"section 7272 of this title","children":[],"tail":"; but"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee89af0a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 85 percent of the estimated quantity of sugar for domestic human consumption for the crop year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee89af0b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may include sugar products, the majority content of which is sucrose for human consumption, derived from sugar cane, sugar beets, molasses, or sugar in the allotments established under paragraph (1) if the Secretary determines it to be appropriate for purposes of this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee89af0c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage of allotments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee89af0d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The marketing allotments under this subpart shall apply to the marketing by processors of sugar intended for domestic human consumption that has been processed from sugar cane, sugar beets, or in-process beet sugar, whether such sugar beets or in-process beet sugar was produced domestically or imported.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee89af0e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with the administration of marketing allotments for each of the 2002 through 2007 crop years, the marketing allotments shall not apply to sugar sold—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee89af0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the exportation of the sugar to a foreign country, except that the exports of sugar shall not be eligible to receive credits under reexport programs for refined sugar or sugar containing products administered by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee89af10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enable another processor to fulfill an allocation established for that processor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee89af11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for uses other than domestic human consumption, except for the sale of sugar for the production of ethanol or other bioenergy if the disposition of the sugar is administered by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8110"},"text":"section 8110 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee89af12-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The sale of sugar described in paragraph (2)(B) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee89af13-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made prior to May 1; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee89af14-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reported to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee89af15-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee89af16-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During all or part of any crop year for which marketing allotments have been established, no processor of sugar beets or sugarcane shall market for domestic human consumption a quantity of sugar in excess of the allocation established for the processor, except—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee89af17-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enable another processor to fulfill an allocation established for that other processor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee89af18-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the exportation of the sugar.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee89af19-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359bb/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any processor who knowingly violates paragraph (1) shall be liable to the Commodity Credit Corporation for a civil penalty in an amount equal to 3 times the United States market value, at the time of the commission of the violation, of that quantity of sugar involved in the violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee89af1a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title III, § 359b, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1403"},"text":"Pub. L. 107–171, title I, § 1403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/188"},"text":"116 Stat. 188","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1403/b"},"text":"Pub. L. 110–234, title I, § 1403(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/982"},"text":"122 Stat. 982","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1403(b), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1710; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1301/b/1"},"text":"Pub. L. 113–79, title I, § 1301(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/688"},"text":"128 Stat. 688","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI/s1301/b/1"},"text":"Pub. L. 115–334, title I, § 1301(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4511"},"text":"132 Stat. 4511","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10312/c/1"},"text":"Pub. L. 119–21, title I, § 10312(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/97"},"text":"139 Stat. 97","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee89af1b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee89af1c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee89af1d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of law applicable to sugarcane or sugar beets for the 2023 crop year pursuant to title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" and amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1301"},"text":"section 1301 of Pub. L. 115–334","children":[],"tail":" applicable to the 2024 crop year for sugarcane or sugar beets, see "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/c/1"},"text":"section 102(c)(1) of Pub. L. 118–22","children":[],"tail":", set out in an Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee89af1e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1359bb, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30/tIII/s359b"},"text":"act Feb. 16, 1938, ch. 30, title III, § 359b","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tIX/s902"},"text":"Pub. L. 101–624, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3480"},"text":"104 Stat. 3480","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tI/s111/d"},"text":"Pub. L. 102–237, title I, § 111(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1831"},"text":"105 Stat. 1831","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tI/s1107/b"},"text":"Pub. L. 103–66, title I, § 1107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/324"},"text":"107 Stat. 324","children":[],"tail":", related to marketing allotments for sugar and crystalline fructose, prior to the general amendment of this subpart by "},{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee89af1f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" substituted “2031” for “2023” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “2023” for “2018” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" substituted “2018” for “2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1403/b"},"text":"Pub. L. 110–246, § 1403(b)","children":[],"tail":", amended section generally, substituting provisions relating to sugar estimates for 2008 through 2012 crop years, establishment of allotments, coverage of allotments, and prohibition against marketing in excess of allotments, for provisions relating to sugar estimates for 2002 through 2007 crop years, establishment of allotments, and prohibition against marketing in excess of allotments."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee89af20-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee89af21-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
