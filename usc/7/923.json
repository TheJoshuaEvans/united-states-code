{"tag":"section","attrib":{"id":"idee5c5cec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s923"},"text":null,"children":[{"tag":"num","attrib":{"value":"923"},"text":"§ 923.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State regulation of telephone service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing contained in this chapter shall be construed to deprive any State commission, board, or other agency of jurisdiction, under any State law, now or hereafter effective, to regulate telephone service which is not subject to regulation by the Federal Communications Commission, under the Communications Act of 1934 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s151"},"text":"47 U.S.C. 151","children":[],"tail":" et seq.], including the rates for such service."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee5c5ced-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title II, § 202, as added "},{"tag":"ref","attrib":{"href":"/us/act/1949-10-28/ch776/s5"},"text":"Oct. 28, 1949, ch. 776, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/948"},"text":"63 Stat. 948","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee5c5cee-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee5c5cef-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idee5c5cf0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Communications Act of 1934, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"act June 19, 1934, ch. 652","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1064"},"text":"48 Stat. 1064","children":[],"tail":", which is classified principally to chapter 5 (§ 151 et seq.) of Title 47, Telecommunications. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s609"},"text":"section 609 of Title 47","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
