{"tag":"section","attrib":{"id":"idf039339e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355"},"text":null,"children":[{"tag":"num","attrib":{"value":"8355"},"text":"§ 8355.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Losses of livestock due to depredation by federally protected species","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf039339f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03933a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Depredation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03933a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “depredation” means actual death, injury, or destruction of livestock that is caused by a federally protected species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03933a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “depredation” does not include damage to real or personal property other than livestock, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf03933a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" damage to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf03933a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other animals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf03933a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vegetation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf03933a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/1/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" motor vehicles; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf03933a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/1/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" structures;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf03933a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf03933a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lost profits; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf03933aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consequential damages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03933ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federally protected species","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “federally protected species” means a species that is or previously was protected under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03933ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1940-06-08"},"text":"June 8, 1940","children":[],"tail":" (commonly known as the “Bald and Golden Eagle Protection Act”) ("},{"tag":"ref","attrib":{"href":"/us/stat/54/250"},"text":"54 Stat. 250","children":[],"tail":", chapter 278; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s668"},"text":"16 U.S.C. 668","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03933ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03933ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Migratory Bird Treaty Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s703"},"text":"16 U.S.C. 703","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03933af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian Tribe” has the meaning given to the term “Indian tribe” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03933b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Livestock","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03933b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “livestock” means horses, mules and asses, rabbits, llamas, cattle, bison, swine, sheep, goats, poultry, bees, honey and beehives, or any other animal generally used for food or in the production of food or fiber.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03933b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “livestock” includes guard animals actively engaged in the protection of livestock described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03933b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the grant program established under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03933b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretaries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Secretaries” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03933b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior, acting through the Director of the United States Fish and Wildlife Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03933b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, acting through the Administrator of the Animal and Plant Health Inspection Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03933b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program for losses of livestock due to depredation by federally protected species","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03933b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretaries shall establish a program to provide grants to States and Indian Tribes to supplement amounts provided by States, Indian Tribes, or State agencies under 1 or more programs established by the States and Indian Tribes (including programs established after ","children":[{"tag":"date","attrib":{"date":"2020-10-30"},"text":"October 30, 2020","children":[],"tail":")—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03933b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to assist livestock producers in carrying out—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf03933ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" proactive and nonlethal activities to reduce the risk of livestock loss due to depredation by federally protected species occurring on—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf03933bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, State, or private land within the applicable State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf03933bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land owned by, or held in trust for the benefit of, the applicable Indian Tribe; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf03933bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research relating to the activities described in clause (i); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03933be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to compensate livestock producers for livestock losses due to depredation by federally protected species occurring on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf03933bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, State, or private land within the applicable State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf03933c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land owned by, or held in trust for the benefit of, the applicable Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03933c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03933c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to the secretaries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than September 30 of each year, a State or Indian Tribe desiring to receive a grant under the program shall submit to the Secretaries a report describing, for the 1-year period ending on that September 30, the losses of livestock due to depredation by federally protected species occurring on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf03933c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, State, or private land within the applicable State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf03933c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land owned by, or held in trust for the benefit of, the applicable Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03933c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries shall allocate available funding to carry out this Act among States and Indian Tribes for a 1-year period ending on September 30 based on the losses described in the reports submitted for the previous 1-year period ending on September 30 under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03933c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under paragraph (1), a State or Indian Tribe shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03933c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate an appropriate agency of the State or Indian Tribe to administer the 1 or more programs supplemented by the grant funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03933c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish 1 or more accounts to receive grant funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03933c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain files of all claims received and paid under grant-funded programs, including supporting documentation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03933ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Secretaries—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf03933cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" annual reports that include—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf03933cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/3/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of claims and expenditures under the program during the year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf03933cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/3/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any action taken on the claims; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf03933ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/b/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other reports as the Secretaries may require to assist the Secretaries in determining the effectiveness of assisted activities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03933cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03933d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no State or Indian Tribe is required to participate in the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03933d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program supplements, and does not replace or supplant, any State compensation programs for depredation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03933d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated to carry out this section $15,000,000 for each of fiscal years 2021 through 2030, of which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03933d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 shall be used to provide grants for the purposes described in subsection (b)(1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03933d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8355/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 shall be used to provide grants for the purpose described in subsection (b)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf03933d5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/188/tI/s102"},"text":"Pub. L. 116–188, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/908"},"text":"134 Stat. 908","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/198/tI/s101"},"text":"Pub. L. 118–198, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2678"},"text":"138 Stat. 2678","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf03933d6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf03933d7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf03933d8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Act of ","children":[{"tag":"date","attrib":{"date":"1940-06-08"},"text":"June 8, 1940","children":[],"tail":" (commonly known as the “Bald and Golden Eagle Protection Act”), referred to in subsec. (a)(2)(A), is "},{"tag":"ref","attrib":{"href":"/us/act/1940-06-08/ch278"},"text":"act June 8, 1940, ch. 278","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/250"},"text":"54 Stat. 250","children":[],"tail":", which is classified generally to subchapter II of chapter 5A (§668 et seq.) of Title 16, Conservation. The Act is also commonly known as the Bald Eagle Protection Act. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.), referred to in subsec. (a)(2)(B), is "},{"tag":"ref","attrib":{"href":"/us/pl/93/205"},"text":"Pub. L. 93–205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-28"},"text":"Dec. 28, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/884"},"text":"87 Stat. 884","children":[],"tail":", which is classified principally to chapter 35 (§ 1531 et seq.) of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"section 1531 of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Migratory Bird Treaty Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s703"},"text":"16 U.S.C. 703","children":[],"tail":" et seq.), referred to in subsec. (a)(2)(C), is "},{"tag":"ref","attrib":{"href":"/us/act/1918-07-03/ch128"},"text":"act July 3, 1918, ch. 128","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/755"},"text":"40 Stat. 755","children":[],"tail":", which is classified generally to subchapter II (§ 703 et seq.) of chapter 7 of Title 16, Conservation. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s710"},"text":"section 710 of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/188"},"text":"Pub. L. 116–188","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/905"},"text":"134 Stat. 905","children":[],"tail":", known as the America’s Conservation Enhancement Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s8201"},"text":"section 8201 of Title 16","children":[],"tail":", Conservation, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf03933d9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198"},"text":"Pub. L. 118–198","children":[],"tail":" substituted “2030” for “2025” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
