{"tag":"section","attrib":{"id":"idefdc46f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104"},"text":null,"children":[{"tag":"num","attrib":{"value":"6104"},"text":"§ 6104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required terms in orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefdc46f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each order issued under this chapter shall contain the terms and conditions prescribed in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc46f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mushroom Council","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefdc46f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and membership of Council","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefdc46f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide for the establishment of, and selection of members to, a Mushroom Council that shall consist of at least 4 members and not more than 9 members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc46f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided for in paragraph (2), the members of the Council shall be mushroom producers and importers appointed by the Secretary from nominations submitted by producers and importers in the manner authorized by the Secretary, except that no more than one member may be appointed to the Council from nominations submitted by any one producer or importer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefdc46f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making appointments, the Secretary shall take into account, to the extent practicable, the geographical distribution of mushroom production throughout the United States, and the comparative volume of mushrooms imported into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc46f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Units","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing such geographical distribution of mushroom production, a whole State shall be considered as a unit and such units shall be organized into 3 regions that shall fairly represent the geographic distribution of mushroom production within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc46fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Importers shall be represented as one region, which shall be separate from the regions established for mushrooms produced in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc46fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members per region","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint one member from each region if such region produces or imports, on average, at least 50,000,000 pounds of mushrooms annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc46fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the members appointed pursuant to paragraph (1), and subject to the 9-member limit of members on the Council provided in that paragraph, the Secretary shall appoint additional members to the council from a region that attains additional pounds of production as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefdc46fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/b/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the annual production of a region is greater than 110,000,000 pounds, but less than or equal to 180,000,000 pounds, the region shall be represented by 1 additional member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefdc46fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/b/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the annual production of a region is greater than 180,000,000 pounds, but less than or equal to 260,000,000 pounds, the region shall be represented by 2 additional members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefdc46ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/b/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the annual production of a region is greater than 260,000,000 pounds, the region shall be represented by 3 additional members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc4700-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Average annual production","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, in determining average annual mushroom production in each of the 4 regions of the United States established under this paragraph, the Secretary shall only consider mushrooms produced by producers covered by this chapter, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6102/11"},"text":"section 6102(11) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc4701-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to nominate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If producers and importers fail to nominate individuals for appointment, the Secretary may appoint members on a basis provided for in the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc4702-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms; compensation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefdc4703-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of appointment to the Council shall be for 3 years, except that the initial appointments shall to the extent practicable be proportionately for 1-year, 2-year, and 3-year terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc4704-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Council members shall serve without compensation but shall be reimbursed for their expenses incurred in performing their duties as members of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc4705-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers and duties of Council","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The order shall define the powers and duties of the Council, which shall include the following powers and duties—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefdc4706-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to administer the order in accordance with its terms and provisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc4707-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make rules and regulations to effectuate the terms and provisions of the order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc4708-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to appoint members of the Council to serve on an executive committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc4709-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to propose, receive, evaluate, approve and submit to the Secretary for approval under subsection (d) budgets, plans, and projects of mushroom promotion, research, consumer information, and industry information, as well as to contract and enter into agreements with appropriate persons to implement such plans or projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc470a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and propose to the Secretary voluntary quality and grade standards for mushrooms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc470b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and propose to the Secretary programs for good agricultural and good handling practices and related activities for mushrooms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc470c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive, investigate, and report to the Secretary complaints of violations of the order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc470d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recommend to the Secretary amendments to the order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc470e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to invest, pending disbursement under a plan or project, funds collected through assessments authorized under this chapter only in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefdc470f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/c/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obligations of the United States or any agency thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc4710-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/c/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" general obligations of any State or any political subdivision thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc4711-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/c/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any interest-bearing account or certificate of deposit of a bank that is a member of the Federal Reserve System; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc4712-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/c/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obligations fully guaranteed as to principal and interest by the United States,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that income from any such invested funds may only be used for any purpose for which the invested funds may be used.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc4713-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans and budgets","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefdc4714-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide that the Council shall submit to the Secretary for approval any plan or project of promotion, research, consumer information, or industry information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc4715-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budgets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall require the Council to submit to the Secretary for approval budgets on a fiscal year basis of its anticipated expenses and disbursements in the implementation of the order, including projected costs of promotion, research, consumer information, and industry information plans and projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc4716-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No plan or project of promotion, research, consumer information, or industry information, or budget, shall be implemented prior to its approval by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc4717-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts and agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefdc4718-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To ensure efficient use of funds, the order shall provide that the Council may enter into contracts or agreements for the implementation and carrying out of plans or projects of mushroom promotion, research, consumer information, or industry information, including contracts with producer organizations, and for the payment of the cost thereof with funds received by the Council under the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc4719-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any such contract or agreement shall provide that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefdc471a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contracting party shall develop and submit to the Council a plan or project together with a budget or budgets that shall show estimated costs to be incurred for such plan or project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc471b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan or project shall become effective on the approval of the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc471c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contracting party shall keep accurate records of all of its transactions, account for funds received and expended, make periodic reports to the Council of activities conducted, and make such other reports as the Council or the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc471d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide that the Council may contract with producer organizations for any other services. Any such contract shall include provisions comparable to those provided in subparagraphs (A), (B), and (C) of paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc471e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Books and records of Council","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefdc471f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The order shall require the Council to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefdc4720-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain such books and records (which shall be available to the Secretary for inspection and audit) as the Secretary may prescribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc4721-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit to the Secretary, from time to time, such reports as the Secretary may prescribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc4722-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" account for the receipt and disbursement of all funds entrusted to the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc4723-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall cause its books and records to be audited by an independent auditor at the end of each fiscal year, and a report of such audit to be submitted to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc4724-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefdc4725-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection and payment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefdc4726-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide that each first handler of mushrooms for the domestic fresh market produced in the United States shall collect, in the manner prescribed by the order, assessments from producers and remit the assessments to the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc4727-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order also shall provide that each importer of mushrooms for the domestic fresh market shall pay assessments to the Council in the manner prescribed by the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc4728-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct marketing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person marketing mushrooms of that person’s own production directly to consumers shall remit the assessments on such mushrooms directly to the Council in the manner prescribed in the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc4729-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate of assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rate of assessment shall be determined and announced by the Council and may be changed by the Council at any time. The order shall provide that the rate of assessment—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefdc472a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the first year of the order, may not exceed one-quarter cent per pound of mushrooms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc472b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the second year of the order, may not exceed one-third cent per pound of mushrooms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc472c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the third year of the order, may not exceed one-half cent per pound of mushrooms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc472d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the following years of the order, may not exceed one cent per pound of mushrooms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc472e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide that the assessments shall be used for payment of the expenses in implementing and administering this chapter, with provision for a reasonable reserve, and to cover those administrative costs incurred by the Secretary in implementing and administering this chapter, except for the salaries of Government employees incurred in conducting referenda.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc472f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No assessment may be collected on mushrooms that a first handler certifies will be exported as mushrooms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc4730-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall prohibit any funds received by the Council under the order from being used in any manner for the purpose of influencing legislation or governmental action or policy, except that such funds may be used by the Council for the development and recommendation to the Secretary of amendments to the order as prescribed in this chapter and for the submission to the Secretary of recommended voluntary grade and quality standards for mushrooms under the Agricultural Marketing Act of 1946 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1621"},"text":"7 U.S.C. 1621","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc4731-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Books and records","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefdc4732-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall require that each first handler and importer of mushrooms maintain, and make available for inspection, such books and records as may be required by the order and file reports at the time, in the manner, and having the content prescribed by the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc4733-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such information shall be made available to the Secretary as is appropriate for the administration or enforcement of this chapter, the order, or any regulation issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc4734-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefdc4735-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this chapter, all information obtained under paragraph (1) shall be kept confidential by all officers and employees of the Department and the Council, and agents of the Council, and only such information so obtained as the Secretary considers relevant may be disclosed to the public by them and then only in a suit or administrative hearing brought at the request of the Secretary, or to which the Secretary or any officer of the United States is a party, and involving the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc4736-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this paragraph may be construed to prohibit—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefdc4737-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/i/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuance of general statements, based on the reports, of the number of persons subject to the order or statistical data collected therefrom, which statements do not identify the information furnished by any person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefdc4738-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/i/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the publication, by direction of the Secretary, of the name of any person violating the order, together with a statement of the particular provisions of the order violated by such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc4739-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefdc473a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/i/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this chapter, information obtained under this chapter may be made available to another agency of the Federal Government for a civil or criminal law enforcement activity if the activity is authorized by law and if the head of the agency has made a written request to the Secretary specifying the particular information desired and the law enforcement activity for which the information is sought.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefdc473b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/i/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person knowingly violating this subsection, on conviction, shall be subject to a fine of not more than $1,000 or to imprisonment for not more than 1 year, or both, and if an officer or employee of the Council or the Department, shall be removed from office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc473c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/i/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to authorize the withholding of information from Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc473d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6104/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order also shall contain such terms and conditions, not inconsistent with this chapter, as are necessary to effectuate this chapter, including provisions for the assessment of a penalty for each late payment of assessments under subsection (g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefdc473e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1925"},"text":"Pub. L. 101–624, title XIX, § 1925","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3857"},"text":"104 Stat. 3857","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tVIII/s803/1"},"text":"Pub. L. 10