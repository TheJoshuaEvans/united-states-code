{"tag":"section","attrib":{"id":"idf010c4b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7514"},"text":null,"children":[{"tag":"num","attrib":{"value":"7514"},"text":"§ 7514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incorporation of additional commodities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf010c4b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7514/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall administer the program authorized under this chapter in a manner that incorporates into the program additional commodities purchased by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7515"},"text":"section 7515 of this title","children":[],"tail":" to be distributed to States for use in such States by emergency feeding organizations, as defined in section 7501(1) "},{"tag":"ref","attrib":{"idref":"fn002344"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002344"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title. Such additional commodities, to the extent practicable and appropriate, shall include commodities purchased within a given State for distribution within such State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf010c4b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7514/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement commodities available","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall supplement the commodities made available to emergency feeding organizations under sections 7502 and 7507(a) of this title with nutritious and useful commodities purchased by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7515"},"text":"section 7515 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf010c4b3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/8/tII/s213"},"text":"Pub. L. 98–8, title II, § 213","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/435/tI/s104"},"text":"Pub. L. 100–435, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-19"},"text":"Sept. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1648"},"text":"102 Stat. 1648","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf010c4b4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf010c4b5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf010c4b6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7501"},"text":"Section 7501 of this title","children":[],"tail":", referred to in subsec. (a), was subsequently amended, and section 7501(1) no longer defines the term “emergency feeding organization”. However, such term is defined elsewhere in that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf010c4b7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf010c4b8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section to be effective and implemented on ","children":[{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/435/s701/a"},"text":"section 701(a) of Pub. L. 100–435","children":[],"tail":", set out as an Effective Date of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2012"},"text":"section 2012 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
