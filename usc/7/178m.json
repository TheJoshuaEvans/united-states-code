{"tag":"section","attrib":{"id":"idee198809-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s178m"},"text":null,"children":[{"tag":"num","attrib":{"value":"178m"},"text":"§ 178m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to President and Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretaries shall submit to the President and the Congress, no later than ","children":[{"tag":"date","attrib":{"date":"1980-12-31"},"text":"December 31, 1980","children":[],"tail":", and each year thereafter through 1987, a report on the status of the research, development, and other work underway under this subchapter. Such report shall (1) recommend specific directions for further research, development and other work, and (2) recommend funding levels for various elements of the overall project."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee19880a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/592/s15"},"text":"Pub. L. 95–592, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-04"},"text":"Nov. 4, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2533"},"text":"92 Stat. 2533","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/284/s14"},"text":"Pub. L. 98–284, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-05-16"},"text":"May 16, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/184"},"text":"98 Stat. 184","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee19880b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee19880c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee19880d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/284"},"text":"Pub. L. 98–284","children":[],"tail":" substituted “The Secretaries” for “The Secretary of Agriculture and the Secretary of Commerce” and “1987” for “1982”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
