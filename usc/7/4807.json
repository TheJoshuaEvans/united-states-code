{"tag":"section","attrib":{"id":"idefbf9687-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807"},"text":null,"children":[{"tag":"num","attrib":{"value":"4807"},"text":"§ 4807.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of Delegate Body","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefbf9688-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nominations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf9689-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 30 days after the effective date of the order, the Secretary shall call for the nomination within each State of candidates for appointment as producer members of the initial Delegate Body.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf968a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each State association may nominate producers who are residents of such State to serve as such candidates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf968b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf968c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002292"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002292"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subpar. (B) has been enacted."}],"tail":" Additional producers who are residents of a State may be nominated as candidates of such State by written petition signed by 100 producers or 5 percent of the pork producers in such State, whichever is less. The Secretary shall establish and publicize the procedures governing the time and place for filing petitions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf968d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election; eligibility to vote; notice of election; number of members nominated","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf968e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After the Secretary has received the nominations required under subsection (a) and not later than 45 days after the effective date of the order, the Secretary shall call for an election within each State of persons for appointment as producer members of the initial Delegate Body.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf968f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be eligible to vote in an election held in a State, a person must be a producer who is a resident of such State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9690-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf9691-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notice of each such election shall be given by the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefbf9692-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by publication in a newspaper or newspapers of general circulation in each State, and in pork production and agriculture trade publications, at least 1 week prior to the election; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefbf9693-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any other reasonable manner determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf9694-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The notice shall set forth the period of time and places for voting and such other information as the Secretary considers necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9695-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each State shall nominate to the Delegate Body the number of producer members required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4806/b/2/B"},"text":"section 4806(b)(2)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9696-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The producers who receive the highest number of votes in each State shall be nominated for appointment as members of the Delegate Body from such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf9697-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent nominations and elections to be administered by Board; time of election; voting eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf9698-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (3), after the election of the producer members of the initial Delegate Body, the Board shall administer all subsequent nominations and elections of the producer members to be nominated for appointment as members of the Delegate Body, with the assistance of the Secretary and in accordance with subsections (a)(3) and (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9699-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board shall determine the timing of an election referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf969a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To be eligible to vote in such an election in a State, a person must—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf969b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a producer who is a resident of such State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf969c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have paid all assessments due under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4809"},"text":"section 4809 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf969d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not demanded a refund of an assessment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4813"},"text":"section 4813 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf969e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nominating committee; appointment; nomination to fill position for pending election","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf969f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prior to the expiration of the term of any producer member of the Delegate Body, the Board shall appoint a nominating committee of producers who are residents of the State represented by such member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf96a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such committee shall nominate producers of such State as candidates to fill the position for which an election is to be held.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf96a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4807/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Additional producers who are residents of a State may be nominated to fill such positions in accordance with subsection (a)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefbf96a2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1618"},"text":"Pub. L. 99–198, title XVI, § 1618","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1611"},"text":"99 Stat. 1611","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefbf96a3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefbf96a4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefbf96a5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1986-01-01"},"text":"Jan. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1631"},"text":"section 1631 of Pub. L. 99–198","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4801"},"text":"section 4801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
