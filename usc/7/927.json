{"tag":"section","attrib":{"id":"idee5c5d0d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s927"},"text":null,"children":[{"tag":"num","attrib":{"value":"927"},"text":"§ 927.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General duties and prohibitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee5c5d0e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s927/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee5c5d0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s927/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in evaluating the feasibility of a telephone loan to be made to a borrower for telephone services, use—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee5c5d10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s927/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to items for which the regulatory authority with jurisdiction over the provision of such services has approved the depreciation rates used by the borrower, such approved rates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee5c5d11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s927/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to other items, the average of the depreciation rates used by borrowers of telephone loans made under this chapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5c5d12-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s927/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annually determine and publish the average described in paragraph (2)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5c5d13-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s927/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make loans for all purposes for which telephone loans are authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s922"},"text":"section 922 of this title","children":[],"tail":", to the extent of qualifying applications therefor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee5c5d14-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s927/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee5c5d15-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s927/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rescind an insured telephone loan made under this chapter without the consent of the borrower, unless all of the purposes for which telephone loans have been made to the borrower under this chapter have been accomplished with funds provided under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5c5d16-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s927/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulate the order or sequence of advances of funds under telephone loans made under this chapter to any borrower who has received any combination of telephone loans from the Secretary or the Federal Financing Bank; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5c5d17-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s927/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deny a loan or advance to, or take any other adverse action against, an applicant for, or a borrower of, a telephone loan under this chapter for any reason that is not based on a rule, regulation, bulletin, or other written policy standard that has not been published pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee5c5d18-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title II, § 206, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2357"},"text":"Pub. L. 101–624, title XXIII, § 2357","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4040"},"text":"104 Stat. 4040","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s235/a/7"},"text":"Pub. L. 103–354, title II, § 235(a)(7)","children":[],"tail":", (13), "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3221"},"text":"108 Stat. 3221","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6602/b/4"},"text":"Pub. L. 115–334, title VI, § 6602(b)(4)","children":[],"tail":", (5), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4776"},"text":"132 Stat. 4776","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee5c5d19-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee5c5d1a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee5c5d1b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6602/b/4/A"},"text":"Pub. L. 115–334, § 6602(b)(4)(A)","children":[],"tail":", struck out “and the Governor of the telephone bank” after “The Secretary” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s602/b/4/B"},"text":"Pub. L. 115–334, § 602(b)(4)(B)","children":[],"tail":", (D), redesignated pars. (2) and (3) as (1) and (2), respectively, and struck out par. (1) which read as follows: “notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553/a/2"},"text":"section 553(a)(2) of title 5","children":[],"tail":", cause to be published in the Federal Register, in accordance with subsections (b) through (e) of section 553 of such title, all rules, regulations, bulletins, and other written policy standards governing the operations of the telephone loan and loan guarantee programs administered under this chapter other than those relating to agency management and personnel;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6602/b/4/C"},"text":"Pub. L. 115–334, § 6602(b)(4)(C)","children":[],"tail":", (D), redesignated par. (4) as (3) and struck out “or 948” after “section 922”. Former par. (3) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6602/b/5/A"},"text":"Pub. L. 115–334, § 6602(b)(5)(A)","children":[],"tail":", struck out “and the Governor of the telephone bank” after “The Secretary” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6602/b/5/B"},"text":"Pub. L. 115–334, § 6602(b)(5)(B)","children":[],"tail":", struck out “, or a Rural Telephone Bank loan,” after “an insured telephone loan”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6602/b/5/C"},"text":"Pub. L. 115–334, § 6602(b)(5)(C)","children":[],"tail":", struck out “, the Rural Telephone Bank,” after “from the Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" substituted “Secretary” for “Administrator” in subsecs. (a) and (b) and “Secretary” for “Rural Electrification Administration” in subsec. (b)(2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
