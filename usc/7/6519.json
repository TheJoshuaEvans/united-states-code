{"tag":"section","attrib":{"id":"idefe82d0c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519"},"text":null,"children":[{"tag":"num","attrib":{"value":"6519"},"text":"§ 6519.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping, investigations, and enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe82d0d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe82d0e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this chapter, each person who sells, labels, or represents any agricultural product as having been produced or handled using organic methods shall make available to the Secretary or the applicable governing State official, on request by the Secretary or official, all records associated with the agricultural product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certified operations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each producer that operates a certified organic farm or certified organic handling operation under this chapter shall maintain, for a period of not less than 5 years, all records concerning the production or handling of any agricultural product sold or labeled as organically produced under this chapter, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe82d10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed history of substances applied to fields or agricultural products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of each person who applied such a substance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d12-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date, rate, and method of application of each such substance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d13-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certifying agents","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe82d14-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A certifying agent shall maintain all records concerning the activities of the certifying agent under this chapter for a period of not less than 10 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d15-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access for Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A certifying agent shall provide to the Secretary and the applicable governing State official (or a representative) access to all records concerning the activities of the certifying agent under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d16-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transference of records","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a private person that was certified under this chapter is dissolved or loses accreditation, all records and copies of records concerning the activities of the person under this chapter shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefe82d17-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transferred to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe82d18-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made available to the applicable governing State official.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d19-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful and a violation of this chapter for any person covered by this chapter to fail or refuse to provide accurate information (including a delay in the timely delivery of such information) required by the Secretary under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d1a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6506/a/9"},"text":"section 6506(a)(9) of this title","children":[],"tail":", or as otherwise directed by the Secretary or the Attorney General for enforcement purposes, no officer, employee, or agent of the United States shall make available to the public any information, statistic, or document obtained from, or made available by, any person under this chapter, other than in a manner that ensures that confidentiality is preserved regarding—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe82d1b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of all relevant persons (including parties to a contract); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d1c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proprietary business information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82d1d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe82d1e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may take such investigative actions as the Secretary considers to be necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe82d1f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to verify the accuracy of any information reported or made available under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d20-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine whether a person covered by this chapter has committed a violation of any provision of this chapter, including an order or regulation promulgated by the Secretary pursuant to this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d21-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific investigative powers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this chapter, the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe82d22-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer oaths and affirmations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d23-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subpoena witnesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d24-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compel attendance of witnesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d25-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take evidence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d26-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the production of any records required to be maintained under this chapter that are relevant to an investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d27-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information sharing during active investigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this chapter, all parties to an active investigation (including certifying agents, State organic certification programs, and the national organic program) shall share confidential business information with Federal Government officers and employees involved in the investigation as necessary to fully investigate and enforce potential violations of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82d28-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations of chapter","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe82d29-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Misuse of label","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who knowingly sells or labels a product as organic, except in accordance with this chapter, shall be subject to a civil penalty of not more than $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d2a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False statement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who makes a false statement under this chapter to the Secretary, a governing State official, or a certifying agent shall be punished in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1001"},"text":"section 1001 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d2b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligibility","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe82d2c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (C), any person that carries out an activity described in subparagraph (B), after notice and an opportunity to be heard, shall not be eligible, for the 5-year period beginning on the date of the occurrence, to receive a certification under this chapter with respect to any farm or handling operation in which the person has an interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d2d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An activity referred to in subparagraph (A) is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefe82d2e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making a false statement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe82d2f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attempting to have a label indicating that an agricultural product is organically produced affixed to an agricultural product that a person knows, or should have reason to know, to have been produced or handled in a manner that is not in accordance with this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe82d30-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise violating the purposes of the applicable organic certification program, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d31-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (A), the Secretary may modify or waive a period of ineligibility under this paragraph if the Secretary determines that the modification or waiver is in the best interests of the applicable organic certification program established under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d32-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting of violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A certifying agent shall immediately report any violation of this chapter to the Secretary or the applicable governing State official.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d33-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations by certifying agent","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A certifying agent that is a private person that violates the provisions of this chapter or falsely or negligently certifies any farming or handling operation that does not meet the terms and conditions of the applicable organic certification program as an organic operation, as determined by the Secretary or the applicable governing State official shall, after notice and an opportunity to be heard—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe82d34-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lose accreditation as a certifying agent under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d35-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be ineligible to be accredited as a certifying agent under this chapter for a period of not less than 3 years, beginning on the date of the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d36-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter alters—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe82d37-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the authority of the Secretary concerning meat, poultry and egg products under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefe82d38-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/c/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Meat Inspection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s601"},"text":"21 U.S.C. 601","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe82d39-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/c/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Poultry Products Inspection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s451"},"text":"21 U.S.C. 451","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe82d3a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/c/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Egg Products Inspection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1031"},"text":"21 U.S.C. 1031","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d3b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority of the Secretary of Health and Human Services under the Federal Food, Drug, and Cosmetic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d3c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6519/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority of the Administrator of the Environmental Protection Agency under the Federal Insecticide, Fungicide, and Rodenticide Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136"},"text":"7 U.S.C. 136","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe82d3d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXI/s2120"},"text":"Pub. L. 101–624, title XXI, § 2120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3949"},"text":"104 Stat. 3949","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tX/s1001/8"},"text":"Pub. L. 102–237, title X, 