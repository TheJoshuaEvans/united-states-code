{"tag":"section","attrib":{"id":"idefde9106-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6205"},"text":null,"children":[{"tag":"num","attrib":{"value":"6205"},"text":"§ 6205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissive terms in orders","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"On the recommendation of the Board and with the approval of the Secretary, an order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6203/a"},"text":"section 6203(a) of this title","children":[],"tail":" may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefde9107-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6205/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide authority to the Board to exempt from such order limes exported from the United States, subject to such safeguards as the Board may establish to ensure proper use of the exemption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde9108-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6205/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide authority to the Board to designate different handler payment and reporting schedules to recognize differences in marketing practices and procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde9109-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6205/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that the Board may convene from time to time working groups drawn from producers, handlers, producer-handlers, importers, exporters, or the general public to assist in the development of research and marketing programs for limes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde910a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6205/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide authority to the Board to accumulate reserve funds from assessments collected pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6204/d"},"text":"section 6204(d) of this title","children":[],"tail":" to permit an effective and continuous coordinated program of research, promotion, and consumer information, in years in which production and assessment income may be reduced, except that any reserve fund so established may not exceed the amount budgeted for operation of this chapter for 1 year;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde910b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6205/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide authority to the Board to use, with the approval of the Secretary, funds collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6204/d"},"text":"section 6204(d) of this title","children":[],"tail":" for the development and expansion of lime sales in foreign markets; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde910c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6205/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide for terms and conditions—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefde910d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6205/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incidental to, and not inconsistent with, the terms and conditions specified in this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde910e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6205/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary to effectuate the other provisions of such order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefde910f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1956"},"text":"Pub. L. 101–624, title XIX, § 1956","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3876"},"text":"104 Stat. 3876","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
