{"tag":"section","attrib":{"id":"idf0026cad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7287"},"text":null,"children":[{"tag":"num","attrib":{"value":"7287"},"text":"§ 7287.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodity Credit Corporation storage payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0026cae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7287/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the 2025 crop year and each subsequent crop year, the Commodity Credit Corporation shall establish rates for the storage of forfeited sugar in an amount that is not less than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0026caf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7287/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of refined sugar, 34 cents per hundredweight per month; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0026cb0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7287/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of raw cane sugar, 27 cents per hundredweight per month.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0026cb1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7287/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior crop years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of the 2012 through 2024 crop years, the Commodity Credit Corporation shall establish rates for the storage of forfeited sugar in the same manner as was used on the day before the date of enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0026cb2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s167"},"text":"Pub. L. 104–127, title I, § 167","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1405"},"text":"Pub. L. 110–234, title I, § 1405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/990"},"text":"122 Stat. 990","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1405, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1718; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10312/b"},"text":"Pub. L. 119–21, title I, § 10312(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/96"},"text":"139 Stat. 96","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0026cb3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0026cb4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf0026cb5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":