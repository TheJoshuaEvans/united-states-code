{"tag":"section","attrib":{"id":"idf01a3928-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b"},"text":null,"children":[{"tag":"num","attrib":{"value":"7655b"},"text":"§ 7655b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forestry products advanced utilization research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf01a3929-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a forestry and forestry products research and extension initiative to develop and disseminate science-based tools that address the needs of the forestry sector and their respective regions, forest and timberland owners and managers, and forestry products engineering, manufacturing, and related interests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01a392a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The initiative described in subsection (a) shall include the following activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01a392b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Research conducted for purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01a392c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wood quality improvement with respect to lumber strength and grade yield;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a392d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of novel engineered lumber products and renewable energy from wood; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a392e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing the longevity, sustainability, and profitability of timberland through sound management and utilization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a392f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Demonstration activities and technology transfer to demonstrate the beneficial characteristics of wood as a green building material, including investments in life cycle assessment for wood products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a3930-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Projects designed to improve—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01a3931-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forestry products, lumber, and evaluation standards and valuation techniques;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a3932-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lumber quality and value-based, on-forest management techniques; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a3933-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forestry products conversion and manufacturing efficiency, productivity, and profitability over the long term (including forestry product marketing).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01a3934-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01a3935-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make competitive grants to carry out the activities described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a3936-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants under this section, the Secretary shall give higher priority to activities that are carried out by entities that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01a3937-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are multistate, multiinstitutional, or multidisciplinary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a3938-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have explicit mechanisms to communicate results to producers, forestry industry stakeholders, policymakers, and the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a3939-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" have—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf01a393a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extensive history and demonstrated experience in forestry and forestry products research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf01a393b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing capacity in forestry products research and dissemination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf01a393c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a demonstrated means of evaluating and responding to the needs of the related commercial sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a393d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making grants under this section, the Secretary shall follow the requirements of paragraphs (4), (7), (8), and (11)(B) of subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3157"},"text":"section 3157 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a393e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of a grant made under this section may not exceed 10 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01a393f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that any activities carried out under this section are carried out in coordination with the Forest Service, including the Forest Products Laboratory, and other appropriate agencies of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01a3940-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit an annual report to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate describing, for the period covered by the report—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01a3941-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the research that has been conducted under paragraph (2) of subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a3942-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of buildings the Forest Service has built with wood as the primary structural material; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a3943-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the investments made by the Forest Service in green building and wood promotion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01a3944-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01a3945-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $7,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a3946-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, the Secretary shall match any funds made available under paragraph (1) with funds made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1646"},"text":"section 1646 of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf01a3947-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/tVI/s617"},"text":"Pub. L. 105–185, title VI, § 617","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7310"},"text":"Pub. L. 113–79, title VII, § 7310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/892"},"text":"128 Stat. 892","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7308"},"text":"Pub. L. 115–334, title VII, § 7308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4816"},"text":"132 Stat. 4816","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf01a3948-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf01a3949-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf01a394a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s617"},"text":"section 617 of Pub. L. 105–185","children":[],"tail":", title VI, "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/607"},"text":"112 Stat. 607","children":[],"tail":", which was not classified to the Code, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7302"},"text":"Pub. L. 107–171, title VII, § 7302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/455"},"text":"116 Stat. 455","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf01a394b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “2023” for “2018”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
