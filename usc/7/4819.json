{"tag":"section","attrib":{"id":"idefbf97a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4819"},"text":null,"children":[{"tag":"num","attrib":{"value":"4819"},"text":"§ 4819.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefbf97a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4819/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated such sums as may be necessary for the Secretary to carry out this chapter, subject to reimbursement from the Board under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4809/c/3/B/iv"},"text":"section 4809(c)(3)(B)(iv) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf97a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4819/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sums appropriated to carry out this chapter shall not be available for payment of an expense or expenditure incurred by the Board in administering an order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefbf97a9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1630"},"text":"Pub. L. 99–198, title XVI, § 1630","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1621"},"text":"99 Stat. 1621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefc207aa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefc207ab-3a6e-11f1-addd-