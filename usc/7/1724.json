. 1281","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXI/s1101"},"text":"Pub. L. 99–198, title XI, § 1101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1465"},"text":"99 Stat. 1465","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3639"},"text":"104 Stat. 3639","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s209"},"text":"Pub. L. 104–127, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/954"},"text":"110 Stat. 954","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIII/s3004"},"text":"Pub. L. 107–171, title III, § 3004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/282"},"text":"116 Stat. 282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/199/dA/tVII/s758"},"text":"Pub. L. 108–199, div. A, title VII, § 758","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/38"},"text":"118 Stat. 38","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3010"},"text":"Pub. L. 110–246, title III, § 3010","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1824"},"text":"122 Stat. 1824","children":[],"tail":"; "},{"tag":"ref","at