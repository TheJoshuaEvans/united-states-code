{"tag":"section","attrib":{"id":"ideeeb56c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1724"},"text":null,"children":[{"tag":"num","attrib":{"value":"1724"},"text":"§ 1724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Levels of assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideeeb56ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1724/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum levels","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeeb56cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1724/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (3), the Administrator shall make agricultural commodities available for food distribution under this subchapter in an amount that for each of fiscal years 2008 through 2023 is not less than 2,500,000 metric tons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb56cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1724/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum non-emergency assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts specified in paragraph (1), and except as provided in paragraph (3), the Administrator shall make agricultural commodities available for non-emergency food distribution through eligible organizations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1722"},"text":"section 1722 of this title","children":[],"tail":" in an amount that for each of fiscal years 2008 through 2023 is not less than 1,875,000 metric tons."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb56cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1724/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may waive the requirements of paragraphs (1) and (2) for any fiscal year if the Administrator determines that such quantities of commodities cannot be used effectively to carry out this subchapter or in order to meet an emergency. In making a waiver under this paragraph, the Administrator shall prepare and submit to the Committees on International Relations, Agriculture and Appropriations of the House of Representatives, and the Committees on Appropriations and Agriculture, Nutrition, and Forestry of the Senate a report containing the reasons for the waiver. No waiver shall be made before the beginning of the applicable fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeeb56ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1724/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of value-added commodities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeeb56cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1724/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum levels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), in making agricultural commodities available under this subchapter, the Administrator shall ensure that not less than 75 percent of the quantity of such commodities required to be distributed during each fiscal year under subsection (a)(2) be in the form of processed, fortified, or bagged commodities and that not less than 50 percent of the quantity of the bagged commodities that are whole grain commodities be bagged in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb56d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1724/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of minimum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may waive the requirement of paragraph (1) for any fiscal year in which the Administrator determines that the requirements of the programs established under this subchapter will not be best served by the enforcement of such requirement under such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideeeb56d1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title II, § 204, "},{"tag":"ref","attrib":{"href":"/us/stat/68/458"},"text":"68 Stat. 458","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/128/s1/1"},"text":"Pub. L. 85–128, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-13"},"text":"Aug. 13, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/345"},"text":"71 Stat. 345","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/931/s5"},"text":"Pub. L. 85–931, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-06"},"tex