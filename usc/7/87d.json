{"tag":"section","attrib":{"id":"idedeea6fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87d"},"text":null,"children":[{"tag":"num","attrib":{"value":"87d"},"text":"§ 87d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility for acts of others","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When construing and enforcing the provisions of this chapter, the act, omission, or failure of any official, agent, or other person acting for or employed by any association, partnership, or corporation within the scope of the employment or office of the official, agent, or other person shall, in every case, also be deemed the act, omission, or failure of such association, partnership, or corporation as well as that of the person.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idedeea6fe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. B, § 15, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/487/s1"},"text":"Pub. L. 90–487, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-15"},"text":"Aug. 15, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/768"},"text":"82 Stat. 768","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/156/s12/n"},"text":"Pub. L. 103–156, § 12(n)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-24"},"text":"Nov. 24, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1529"},"text":"107 Stat. 1529","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idedeea6ff-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idedeea700-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idedeea701-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/156"},"text":"Pub. L. 103–156","children":[],"tail":", which directed amendment of “Section 15” by substituting “the employment or office of the official, agent, or other person” for “his employment or office”, without specifying the name of the Act being amended, was executed to this section, which is section 15 of the United States Grain Standards Act, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idedeea702-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idedeea703-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/487/s2"},"text":"section 2 of Pub. L. 90–487","children":[],"tail":", set out as an Effective Date of 1968 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s78"},"text":"section 78 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
