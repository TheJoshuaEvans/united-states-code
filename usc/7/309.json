{"tag":"section","attrib":{"id":"idee256e65-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s309"},"text":null,"children":[{"tag":"num","attrib":{"value":"309"},"text":"§ 309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land grants in the State of North Dakota","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee256e66-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s309/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s303"},"text":"section 303 of this title","children":[],"tail":", the State of North Dakota shall manage the land granted to the State under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s301"},"text":"section 301 of this title","children":[],"tail":", including any proceeds from the land, in accordance with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee256e67-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s309/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of proceeds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s304"},"text":"section 304 of this title","children":[],"tail":", the State of North Dakota shall, with respect to any trust fund in which proceeds from the sale of land under this subchapter are deposited (referred to in this section as the “trust fund”)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idee256e68-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s309/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposit all revenues earned by a trust fund into the trust fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee256e69-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s309/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deduct the costs of administering a trust fund from each trust fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee256e6a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s309/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" manage each trust fund to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee256e6b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s309/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserve the purchasing power of the trust fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee256e6c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s309/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain stable distributions to trust fund beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee256e6d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s309/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s304"},"text":"section 304 of this title","children":[],"tail":", any distributions from trust funds in the State of North Dakota shall be made in accordance with section 2 of article IX of the Constitution of the State of North Dakota."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee256e6e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s309/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s305"},"text":"section 305 of this title","children":[],"tail":", the State of North Dakota shall manage the land granted under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s301"},"text":"section 301 of this title","children":[],"tail":", including any proceeds from the land, in accordance with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee256e6f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1862-07-02/ch130/s9"},"text":"July 2, 1862, ch. 130, § 9","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXIII/s13001/b"},"text":"Pub. L. 111–11, title XIII, § 13001(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1446"},"text":"123 Stat. 1446","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
