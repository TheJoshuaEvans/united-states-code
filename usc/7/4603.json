{"tag":"section","attrib":{"id":"idefbadbac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4603"},"text":null,"children":[{"tag":"num","attrib":{"value":"4603"},"text":"§ 4603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Honey research, promotion, and consumer information order","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To effectuate the declared policy of this chapter, the Secretary shall, subject to the provisions of this chapter, issue and, from time to time, amend orders and regulations applicable to persons engaged in the production, sale, or handling of honey and honey products in the United States and the importation of honey and honey products into the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefbadbad-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/590/s4"},"text":"Pub. L. 98–590, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3116"},"text":"98 Stat. 3116","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tVI/s605/c"},"text":"Pub. L. 105–185, title VI, § 605(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/589"},"text":"112 Stat. 589","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefbadbae-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefbadbaf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefbadbb0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185"},"text":"Pub. L. 105–185","children":[],"tail":" inserted “and regulations” after “orders”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefbadbb1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idefbadbb2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Conforming Amendment to Order","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1987"},"text":"Pub. L. 101–624, title XIX, § 1987","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3908"},"text":"104 Stat. 3908","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/624/tXIX/s1987"},"text":"“Notwithstanding any provision of the Honey Research, Promotion, and Consumer Information Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4601"},"text":"7 U.S.C. 4601","children":[],"tail":" et seq.), the Secretary of Agriculture, after notice and opportunity for public comment, shall issue an amendment to the order in effect under such Act on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":"] to conform such order to the amendments made by this subtitle [subtitle F (§§ 1981–1989) of title XIX of "},{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":", enacting "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4610a"},"text":"section 4610a of this title","children":[],"tail":" and amending sections 1787, 4602, 4606, 4608, and 4612 of this title], which shall become effective on the date of the publication of such amendment to the order in the Federal Register without a referendum thereon (except for the referendum specifically provided for under section 1985 [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4612"},"text":"section 4612 of this title","children":[],"tail":"]). The Secretary shall issue such amendment to the order in final form not later than 150 days after the date of the enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
