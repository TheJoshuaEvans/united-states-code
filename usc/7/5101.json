{"tag":"section","attrib":{"id":"idefc2085f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101"},"text":null,"children":[{"tag":"num","attrib":{"value":"5101"},"text":"§ 5101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefc20860-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State is a qualifying State if the Secretary of Agriculture (hereinafter in this chapter referred to as the “Secretary”) determines that the State has in effect a mediation program that meets the requirements of subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc20861-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 15 days after the Secretary receives from the Governor of a State a description of the mediation program of the State and a statement certifying that the State has met all of the requirements of subsection (c), the Secretary shall determine whether the State is a qualifying State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc20862-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements of State mediation programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc20863-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issues covered","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc20864-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be certified as a qualifying State, the mediation program of the State must provide mediation services to persons described in paragraph (2) that are involved in agricultural loans (regardless of whether the loans are made or guaranteed by the Secretary or made by a third party).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc20865-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other issues","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The mediation program of a qualifying State may provide mediation services to persons described in paragraph (2) that are involved in one or more of the following issues:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefc20866-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Wetlands determinations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc20867-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compliance with farm programs, including conservation programs and the national organic program established under the Organic Foods Production Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6501"},"text":"7 U.S.C. 6501","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc20868-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Agricultural credit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc20869-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rural water loan programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc2086a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grazing on National Forest System land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc2086b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pesticides.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc2086c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/1/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lease issues, including land leases and equipment leases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc2086d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/1/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Family farm transition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc2086e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/1/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Farmer-neighbor disputes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc2086f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/1/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other issues as the Secretary or the head of the department of agriculture of each participating State considers appropriate for better serving the agricultural community and persons eligible for mediation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc20870-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mediation services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funding provided for the mediation program of a qualifying State may also be used to provide credit counseling to persons described in paragraph (2)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefc20871-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to the initiation of any mediation involving the Department of Agriculture; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc20872-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unrelated to any ongoing dispute or mediation in which the Department of Agriculture is a party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc20873-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons eligible for mediation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc20874-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B), the persons referred to in paragraph (1) include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefc20875-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agricultural producers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc20876-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creditors of producers (as applicable);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc20877-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons directly affected by actions of the Department of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc20878-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other persons involved in an issue for which mediation services are provided by a mediation program described in paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc20879-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary participation","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefc2087a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to clause (ii) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5103"},"text":"section 5103 of this title","children":[],"tail":", a person may not be compelled to participate in mediation services provided under this Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc2087b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Clause (i) shall not affect a State law requiring mediation before foreclosure on agricultural land or property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc2087c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall certify a State as a qualifying State with respect to the issues proposed to be covered by the mediation program of the State if the mediation program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc2087d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for mediation services that, if decisions are reached, result in mediated, mutually agreeable decisions between the parties to the mediation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc2087e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is authorized or administered by an agency of the State government or by the Governor of the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc2087f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for the training of mediators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc20880-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides that the mediation sessions shall be confidential;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc20881-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures, in the case of agricultural loans, that all lenders and borrowers of agricultural loans receive adequate notification of the mediation program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc20882-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensures, in the case of other issues covered by the mediation program, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefc20883-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/3/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Agriculture receives adequate notification of those issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc20884-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/c/3/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons directly affected by actions of the Department of Agriculture receive adequate notification of the mediation program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc47885-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of mediation services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “mediation services”, with respect to mediation or a request for mediation, may include all activities related to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc47886-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the intake and scheduling of cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc47887-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of background and selected information regarding the mediation process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc47888-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial advisory and counseling services (as appropriate) performed by a person other than a State mediation program mediator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc47889-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5101/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mediation session.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefc4788a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233/tV/s501"},"text":"Pub. L. 100–233, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1662"},"text":"101 Stat. 1662","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tV/s501"},"text":"Pub. L. 100–399, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1005"},"text":"102 Stat. 1005","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s282/a"},"text":"Pub. L. 103–354, title II, § 282(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3233"},"text":"108 Stat. 3233","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/472/tIII/s306/a"},"text":"Pub. L. 106–472, title III, § 306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2072"},"text":"114 Stat. 2072","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5402/a"},"text":"Pub. L. 115–334, title V, § 5402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4674"},"text":"132 Stat. 4674","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefc4788b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefc4788c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefc4788d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Organic Foods Production Act of 1990, referred to in subsec. (c)(1)(B)(ii), is title XXI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3935"},"text":"104 Stat. 3935","children":[],"tail":", which is classified generally to chapter 94 (§ 6501 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6501"},"text":"section 6501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (c)(2)(B)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Pub. L. 100–233","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1568"},"text":"101 Stat. 1568","children":[],"tail":", known as the Agricultural Credit Act of 1987. Provisions relating to mediation services are contained in title V of the Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefc4788e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5402/a/1/A/i"},"text":"Pub. L. 115–334, § 5402(a)(1)(A)(i)","children":[],"tail":", struck out “under the jurisdiction of the Department of Agriculture” after “the following issues” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5402/a/1/A/ii"},"text":"Pub. L. 115–334, § 5402(a)(1)(A)(ii)","children":[],"tail":", inserted “and the national organic program established under the Organic Foods Production Act of 1990 ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6501"},"text":"7 U.S.C. 6501","children":[],"tail":" et seq.)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B)(vii) to (x). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5402/a/1/A/iii"},"text":"Pub. L. 115–334, § 5402(a)(1)(A)(iii)","children":[],"tail":", added cls. (vii) to (x) and struck out former cl. (vii) which read as follows: “Such other issues as the Secretary considers appropriate.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5402/a/1/B"},"text":"Pub. L. 115–334, § 5402(a)(1)(B)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5402/a/2"},"text":"Pub. L. 115–334, § 5402(a)(2)","children":[],"tail":", added cl. (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5402/a/3"},"text":"Pub. L. 115–334, § 5402(a)(3)","children":[],"tail":", inserted dash after “program, that” and cl. (ii) designation before “persons” and added cl. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/472/s306/a/1"},"text":"Pub. L. 106–472, § 306(a)(1)","children":[],"tail":", added pars. (1) and (2) and struck out former pars. (1) and (2), which required State mediation program to provide services for producers, their creditors, and other persons involved in agricultural loans, or involved in agricultural loans and such issues as wetlands determinations, compliance with farm programs, agricultural credit, rural water loan programs, grazing on National Forest System lands, pesticides, or such other issues considered appropriate."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/472/s306/a/2"},"text":"Pub. L. 106–472, § 306(a)(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/s282/a/1"},"text":"Pub. L. 103–354, § 282(a)(1)","children":[],"tail":", substituted “a mediation program” for “an agricultural loan mediation program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/s282/a/2"},"text":"Pub. L. 103–354, § 282(a)(2)","children":[],"tail":", struck out “agricultural loan” before “mediation program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/s282/a/3"},"text":"Pub. L. 103–354, § 282(a)(3)","children":[],"tail":", added subsec. (c) and struck out heading and text of former subsec. (c). Text read as follows: “Within 15 days after the Secretary receives a description of a State agricultural loan mediation program, the Secretary shall certify the State as a qualifying State if the State program—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) provides for mediation services to be provided to producers, and their creditors, that, if decisions are reached, result in mediated, mutually agreeable decisions between parties under an agricultural loan mediation program;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) is authorized or administered by an agency of the State government or by the Governor of the State;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) provides for the training of mediators;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) provides that the mediation sessions shall be confidential; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) ensures that all lenders and borrowers of agricultural loans receive adequate notification of the mediation program.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" struck out comma after “Governor of a State”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefc4788f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idefc47890-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective as if enacted immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Pub. L. 100–233","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/a"},"text":"section 1001(a) of Pub. L. 100–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2002"},"text":"section 2002 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idefc47891-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/233/s1"},"text":"Pub. L. 111–233, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-08-16"},"text":"Aug. 16, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2493"},"text":"124 Stat. 2493","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/233/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5106"},"text":"section 5106 of this title","children":[],"tail":"] may be cited as the ‘Agricultural Credit Act of 2010’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
