{"tag":"section","attrib":{"id":"idefe82dc4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6601"},"text":null,"children":[{"tag":"num","attrib":{"value":"6601"},"text":"§ 6601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forestry rural revitalization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe82dc5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6601/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of economic development and global marketing program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture, acting through the National Institute of Food and Agriculture and the Cooperative Extension System, and in consultation with the Forest Service, shall establish and implement educational programs and provide technical assistance to assist businesses, industries, and policymakers to create jobs, raise incomes, and increase public revenues in manners consistent with environmental concerns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82dc6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6601/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each program established under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe82dc7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6601/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer technologies to natural resource-based industries in the United States to make such industries more efficient, productive, and competitive;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82dc8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6601/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist businesses to identify global marketing opportunities, conduct business on an international basis, and market themselves more effectively; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82dc9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6601/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" train local leaders in strategic community economic development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82dca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6601/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture shall establish specific programs under subsection (a) to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe82dcb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6601/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deliver educational services focused on community economic analysis, economic diversification, economic impact analysis, retention and expansion of existing commodity and noncommodity industries, amenity resource and tourism development, and entrepreneurship focusing on forest lands and rural communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82dcc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6601/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use Cooperative Extension System databases and analytical tools to help communities diversify their economic bases, add value locally to raw forest product materials, and retain revenues by helping to develop local businesses and industries to supply forest products locally; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82dcd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6601/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the full resources of the Cooperative Extension System, including land-grant universities and county offices, to promote economic development that is sustainable and environmentally sound.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82dce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6601/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural revitalization technologies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe82dcf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6601/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture, acting through the Chief of the Forest Service, in consultation with the State and Private Forestry Technology Marketing Unit at the Forest Products Laboratory, and in collaboration with eligible institutions, may carry out a program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe82dd0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6601/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accelerate adoption of technologies using biomass and small-diameter materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82dd1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6601/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to create community-based enterprises through marketing activities and demonstration projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82dd2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6601/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish small-scale business enterprises to make use of biomass and small-diameter materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82dd3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6601/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this subsection $5,000,000 for each of fiscal years 2008 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe82dd4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2371"},"text":"Pub. L. 101–624, title XXIII, § 2371","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","