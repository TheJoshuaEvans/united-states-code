{"tag":"section","attrib":{"id":"idee684400-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s954"},"text":null,"children":[{"tag":"num","attrib":{"value":"954"},"text":"§ 954.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grades and standards for classification","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to establish and promulgate grades and standards for the classification of peanuts, whenever in his discretion he may see fit.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee684401-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-24/ch745/s4"},"text":"June 24, 1936, ch. 745, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1899"},"text":"49 Stat. 1899","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
