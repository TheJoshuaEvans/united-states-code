{"tag":"section","attrib":{"id":"idef29715e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009j"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009j"},"text":"§ 2009j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef29715f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in collaboration with State, local, public, and private entities, State rural development councils, and community-based organizations, shall prepare an annual report that contains evaluations, assessments, and performance outcomes concerning the rural community advancement programs carried out under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef297160-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than March 1 of each year, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef297161-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit the report required by subsection (a) to Congress and the chief executives of the States participating in the program established under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef297162-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the report available to State and local participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef297163-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s381K"},"text":"Pub. L. 87–128, title III, § 381K","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s761"},"text":"Pub. L. 104–127, title VII, § 761","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1146"},"text":"110 Stat. 1146","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
