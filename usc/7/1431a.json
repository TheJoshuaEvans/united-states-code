{"tag":"section","attrib":{"id":"idee9f0b32-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1431a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1431a"},"text":"§ 1431a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cotton donations to educational institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Commodity Credit Corporation is authorized, on such terms as the Secretary of Agriculture may approve, to donate cotton acquired through its price support operations to educational institutions for use in the training of students in the processing and manufacture of cotton into textiles.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee9f0b33-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/835/tV/s505"},"text":"Pub. L. 85–835, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-28"},"text":"Aug. 28, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/996"},"text":"72 Stat. 996","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee9f0b34-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee9f0b35-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee9f0b36-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agricultural Act of 1958, and not as part of the Agricultural Act of 1949 which is classified principally to this chapter. For complete classification of the 1949 Act to the Code, see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
