{"tag":"section","attrib":{"id":"idefc933e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622"},"text":null,"children":[{"tag":"num","attrib":{"value":"5622"},"text":"§ 5622.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export credit guarantee program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefc933e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short-term credit guarantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commodity Credit Corporation may guarantee the repayment of credit made available to finance commercial export sales of agricultural commodities, including processed agricultural products and high-value agricultural products, from privately owned stocks on credit terms that do not exceed a 24-month period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc933e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commodity Credit Corporation may use export credit guarantees authorized under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc933e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase exports of agricultural commodities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc933e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to compete against foreign agricultural exports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc933e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to assist countries in meeting their food and fiber needs, particularly—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc933e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc933ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" countries that are emerging markets that have committed to carry out, or are carrying out, policies that promote economic freedom, private domestic production of food commodities for domestic consumption, and the creation and expansion of efficient domestic markets for the purchase and sale of agricultural commodities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc933eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for such other purposes as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc933ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on use of credit guarantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Export credit guarantees authorized by this section shall not be used for foreign aid, foreign policy, or debt rescheduling purposes. The provisions of the cargo preference laws shall not apply to export sales with respect to which credit is guaranteed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc933ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commodity Credit Corporation shall not make credit guarantees available in connection with sales of agricultural commodities to any obligor that the Secretary determines cannot adequately service the debt associated with such sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc933ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Export credit guarantees issued pursuant to this section shall contain such terms and conditions as the Commodity Credit Corporation determines to be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc933ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States agricultural commodities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commodity Credit Corporation shall finance or guarantee under this section only United States agricultural commodities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc933f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligibility of financial institutions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc933f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A financial institution shall be ineligible to receive an assignment of a credit guarantee issued by the Commodity Credit Corporation under this section if it is determined by the Corporation, at the time of the assignment, that such financial institution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc933f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the financial institution issuing the letter of credit or a subsidiary of such institution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc933f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is owned or controlled by an entity that owns or controls that financial institution issuing the letter of credit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc933f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third country banks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commodity Credit Corporation may guarantee under subsection (a) the repayment of credit made available to finance an export sale irrespective of whether the obligor is located in the country to which the export sale is destined.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc933f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for fish and processed fish products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making available any guarantees of credit under this section in connection with sales of fish and processed fish products, the Secretary shall make such guarantees available under terms and conditions that are comparable to the terms and conditions that apply to guarantees provided with respect to sales of other agricultural commodities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc933f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation on agricultural export credit programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the United States Trade Representative shall consult on a regular basis with the Committee on Agriculture, and the Committee on International Relations, of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate on the status of multilateral negotiations regarding agricultural export credit programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc933f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc933f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of long term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “long term” means a period of 10 or more years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc933f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guarantees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In administering the export credit guarantees authorized under this section, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc933fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop an approach to risk evaluation that facilitates accurate country risk designations and timely adjustments to the designations (on an ongoing basis) in response to material changes in country risk conditions, with ongoing opportunity for input and evaluation from the private sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc933fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjust risk-based guarantees as necessary to ensure program effectiveness and United States competitiveness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc933fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/j/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with industry to ensure, to the maximum extent practicable, that risk-based fees associated with the guarantees cover the operating costs and losses over the long term; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc933fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5622/j/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding any other provision of this section, administer and carry out (only after consulting with the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition and Forestry of the Senate) the program pursuant to such terms as may be agreed between the parties to address the World Trade Organization dispute WTO/DS267 to the extent not superseded by any applicable international undertakings on officially supported export credits to which the United States is a party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefc933fe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/tII/s202"},"text":"Pub. L. 95–501, title II, § 202","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1531"},"text":"Pub. L. 101–624, title XV, § 1531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3673"},"text":"104 Stat. 3673","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIII/s334"},"text":"Pub. L. 102–237, title III, § 334","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1859"},"text":"105 Stat. 1859","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/511/tVII"},"text":"Pub. L. 102–511, title VII","children":[],"tail":", §§ 708, 709(a), "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3351"},"text":"106 Stat. 3351","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII"},"text":"Pub. L. 104–127, title II","children":[],"tail":", §§ 243(a), 277(c)(3), "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/965"},"text":"110 Stat. 965","children":[],"tail":", 979; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIII/s3102/a"},"text":"Pub. L. 107–171, title III, § 3102(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/289"},"text":"116 Stat. 289","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3101/a"},"text":"Pub. L. 110–246, title III, § 3101(a)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1831"},"text":"122 Stat. 1831","children":[],"tail":", 1832; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIII/s3101/a"},"text":"Pub. L. 113–79, title III, § 3101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/778"},"text":"128 Stat. 778","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefc933ff-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefc93400-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idefc93401-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/s202"},"text":"section 202 of Pub. L. 95–501","children":[],"tail":" enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1707c"},"text":"section 1707c of this title","children":[],"tail":" prior to the complete revision of "},{"tag":"ref","attrib":{"href":"/us/pl/95/501"},"text":"Pub. L. 95–501","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefc93402-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3101/a/1"},"text":"Pub. L. 113–79, § 3101(a)(1)","children":[],"tail":", substituted “24-month” for “3-year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3101/a/2"},"text":"Pub. L. 113–79, § 3101(a)(2)","children":[],"tail":", substituted “obligor” for “country”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (i), (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3101/a/3"},"text":"Pub. L. 113–79, § 3101(a)(3)","children":[],"tail":", (4), redesignated subsecs. (j) and (k) as (i) and (j), respectively, and struck out former subsec. (i) which related to percentages of export credit guarantees issued to promote export of processed or high-value agricultural products in fiscal years 1996 through 2007."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(2)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3101/a/5/A"},"text":"Pub. L. 113–79, § 3101(a)(5)(A)","children":[],"tail":", (B), redesignated subpars. (C) and (D) as (A) and (B), respectively, and struck out former subpars. (A) and (B) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) maximize the export sales of agricultural commodities;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) maximize the export credit guarantees that are made available and used during the course of a fiscal year;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3101/a/5/B"},"text":"Pub. L. 113–79, § 3101(a)(5)(B)","children":[],"tail":", (D)(i), redesignated subpar. (E) as (C) and struck out “, but do not exceed,” after “cover”. Former subpar. (C) redesignated (A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3101/a/5/C"},"text":"Pub. L. 113–79, § 3101(a)(5)(C)","children":[],"tail":", (D)(ii), (E), added subpar. (D). Former subpar. (D) redesignated (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3101/a/5/B"},"text":"Pub. L. 113–79, § 3101(a)(5)(B)","children":[],"tail":", redesignated subpar. (E) as (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3101/a/4"},"text":"Pub. L. 113–79, § 3101(a)(4)","children":[],"tail":", redesignated subsec. (k) as (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3101/a/1"},"text":"Pub. L. 110–246, § 3101(a)(1)","children":[],"tail":", struck out par. (1) designation and heading before “The Commodity” and struck out pars. (2) and (3) which related to supplier credits and extended supplier credits, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3101/a/2"},"text":"Pub. L. 110–246, § 3101(a)(2)","children":[],"tail":", (3), redesignated subsec. (d) as (b) and struck out former subsec. (b). Prior to amendment, text read as follows: “Subject to the provisions of subsection (c) of this section, the Commodity Credit Corporation may guarantee the repayment of credit made available by financial institutions in the United States to finance commercial export sales of agricultural commodities, including processed agricultural products and high-value agricultural products, from privately owned stocks on credit terms that are for not less than a 3-year period nor for more than a 10-year period in a manner that will directly benefit United States agricultural producers.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3101/c/1"},"text":"Pub. L. 110–246, § 3101(c)(1)","children":[],"tail":", struck out “, consistent with the provisions of subsection (c) of this section” after “appropriate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3101/a/2"},"text":"Pub. L. 110–246, § 3101(a)(2)","children":[],"tail":", (3), redesignated subsec. (e) as (c) and struck out former subsec. (c) which related to requirements for guarantees under former subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3101/c/2"},"text":"Pub. L. 110–246, § 3101(c)(2)","children":[],"tail":", struck out par. (1) designation and heading before “The Commodity” and struck out par. (2) which related to criteria for the determination required under this subsec. with respect to credit guarantees under former subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3101/a/3"},"text":"Pub. L. 110–246, § 3101(a)(3)","children":[],"tail":", redesignated subsec. (f) as (d). Former subsec. (d) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3101/a/3"},"text":"Pub. L. 110–246, § 3101(a)(3)","children":[],"tail":", redesignated subsecs. (g) to (i) as (e) to (g), respectively. Former subsecs. (e) and (f) redesignated (c) and (d), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3101/c/3"},"text":"Pub. L. 110–246, § 3101(c)(3)","children":[],"tail":", substituted “subsection (a)” for “subsections (a) and (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (h) to (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3101/a/3"},"text":"Pub. L. 110–246, § 3101(a)(3)","children":[],"tail":", (4), redesignated subsecs. (j) to ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") as (h) to (j), respectively, and added subsec. (k). Former subsecs. (h) and (i) redesignated (f) and (g), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s3102/a"},"text":"Pub. L. 107–171, § 3102(a)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s3102/b"},"text":"Pub. L. 107–171, § 3102(b)","children":[],"tail":", substituted “through 2007” for “, 2001, and 2002”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/s3102/c"},"text":"Pub. L. 107–171, § 3102(c)","children":[],"tail":", added subsec. ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s243/a/1"},"text":"Pub. L. 104–127, § 243(a)(1)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s277/c/3"},"text":"Pub. L. 104–127, § 277(c)(3)","children":[],"tail":", substituted “emerging markets” for “emerging democracies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s243/a/2"},"text":"Pub. L. 104–127, § 243(a)(2)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s243/a/3"},"text":"Pub. L. 104–127, § 243(a)(3)","children":[],"tail":", added subsec. (h) and struck out heading and text of former subsec. (h). Text read as follows: “The Commodity Credit Corporation shall finance or guarantee under this section only United States agricultural commodities. The Commodity Credit Corporation shall not finance or guarantee under this section the value of any foreign agricultural component.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s243/a/4"},"text":"Pub. L. 104–127, § 243(a)(4)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, struck out former par. (1) which read as follows: “is not in a sound financial condition;”, redesignated pars. (2) and (3) as subpars. (A) and (B), respectively, of par. (1), and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s243/a/5"},"text":"Pub. L. 104–127, § 243(a)(5)","children":[],"tail":", added subsec. (k) and struck out heading and text of former subsec. (k). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—In issuing export credit guarantees under this section in connection with sales to the independent states of the former Soviet Union, the Commodity Credit Corporation shall, to the extent practicable and subject to paragraph (2), ensure that no less than 35 percent of the total amount of credit guarantees issued for a fiscal year are issued to promote the export of processed and high-value agricultural products and that the balance are issued to promote the export of bulk or raw agricultural commodities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—The 35 percent requirement of paragraph (1) shall apply for a fiscal year only to the extent that the percentage of the total amount of credit guarantees issued for that fiscal year under this section to promote the export to all countries of processed and high-value agricultural products is less than 25 percent.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511/s709/a/1"},"text":"Pub. L. 102–511, § 709(a)(1)","children":[],"tail":", inserted “, including processed agricultural products and high-value agricultural products,” after “agricultural commodities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511/s708/a"},"text":"Pub. L. 102–511, § 708(a)","children":[],"tail":", inserted sentence at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511/s708/b"},"text":"Pub. L. 102–511, § 708(b)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows: “to assist countries, particularly developing countries, in meeting their food and fiber needs; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511/s709/a/2"},"text":"Pub. L. 102–511, § 709(a)(2)","children":[],"tail":", added subsec. (k)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “issued by the Commodity Credit Corporation under this section if it is determined by the Corporation, at the time of the assignment, that” for “or proceeds payable under a credit guarantee issued by the Commodity Credit Corporation under this section if it is determined by the Corporation that”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefc93403-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idefc93404-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on International Relations of House of Representatives changed to Committee on Foreign Affairs of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idefc93405-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/b"},"text":"section 4(b) of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idefc93406-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s243/d"},"text":"Pub. L. 104–127, title II, § 243(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/967"},"text":"110 Stat. 967","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/127/tII/s243/d"},"text":"“Not later than 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":"], the Secretary of Agriculture shall issue regulations to carry out the amendments made by this section [amending this section and sections 5602 and 5641 of this title].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idefc93407-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Promotion of Agricultural Exports to Emerging Markets","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1542"},"text":"Pub. L. 101–624, title XV, § 1542","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3691"},"text":"104 Stat. 3691","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIII/s338"},"text":"Pub. L. 102–237, title III, § 338","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1859"},"text":"105 Stat. 1859","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/511/tVII/s706"},"text":"Pub. L. 102–511, title VII, § 706","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3350"},"text":"106 Stat. 3350","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tIII/s321/g"},"text":"Pub. L. 103–182, title III, § 321(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2112"},"text":"107 Stat. 2112","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII"},"text":"Pub. L. 104–127, title II","children":[],"tail":", §§ 277(a), 278, "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/977"},"text":"110 Stat. 977","children":[],"tail":", 979; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIII/s3203"},"text":"Pub. L. 107–171, title III, § 3203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/300"},"text":"116 Stat. 300","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3204"},"text":"Pub. L. 110–246, title III, § 3204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1837"},"text":"122 Stat. 1837","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIII/s3203"},"text":"Pub. L. 113–79, title III, § 3203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/779"},"text":"128 Stat. 779","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/188/tI/s101/b"},"text":"Pub. L. 113–188, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2017"},"text":"128 Stat. 2017","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIII"},"text":"Pub. L. 115–334, title III","children":[],"tail":", §§ 3201(b)(3)(A), 3304, "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4616"},"text":"132 Stat. 4616","children":[],"tail":", 4619, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/334/tIII"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commodity Credit Corporation shall make available for fiscal years 1996 through 2023 not less than $1,000,000,000 of direct credits or export credit guarantees for exports to emerging markets under section 201 or 202 of the Agricultural Trade Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5621"},"text":"7 U.S.C. 5621","children":[],"tail":" and 5622), in addition to the amounts acquired or authorized under section 211 of the Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s5641"},"text":"7 U.S.C. 5641","children":[],"tail":") for the program."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Facilities and Services","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A portion of such export credit guarantees shall be made available for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment or improvement of facilities, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of services or United States produced goods,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in emerging markets by United States persons to improve handling, marketing, processing, storage, or distribution of imported agricultural commodities and products thereof if the Secretary of Agriculture determines that such guarantees will primarily promote the export of United States agricultural commodities (as defined in section 102(7) of the Agricultural Trade Act of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5602/7"},"text":"7 U.S.C. 5602(7)","children":[],"tail":"])."}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commodity Credit Corporation shall give priority under this subsection to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects that encourage the privatization of the agricultural sector or that benefit private farms or cooperatives in emerging markets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects for which nongovernmental persons agree to assume a relatively larger share of the costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction waiver","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may waive any applicable requirements relating to the use of United States goods in the construction of a proposed facility, if the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" goods from the United States are not available; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of goods from the United States is not practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term of guarantee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A facility payment guarantee under this subsection shall be for a term that is not more than the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term of the depreciation schedule of the facility assisted; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 20 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before the authority under this section is exercised, the Secretary of Agriculture shall consult with exporters of United States agricultural commodities (as defined in section 102(7) of the Agricultural Trade Act of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5602/7"},"text":"7 U.S.C. 5602(7)","children":[],"tail":"]), nongovernmental experts, and other Federal Government agencies in order to ensure that facilities in an emerging market for which financing is guaranteed under paragraph (1)(B) do not primarily benefit countries which are in close geographic proximity to that emerging market."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign Debt Burdens","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the program described in subsection (a), the Secretary of Agriculture shall ensure that the credits for which repayment is guaranteed under subsection (a) do not negatively affect the political and economic situation in emerging markets by excessively adding to the foreign debt burdens of such countries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Emerging Market","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section and section 1543 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3293"},"text":"7 U.S.C. 3293","children":[],"tail":"], the term ‘emerging market’ means any country, foreign territory, customs union, or other economic market that the Secretary determines—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is taking steps toward a market-oriented economy through the food, agriculture, or rural business sectors of its economy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the potential to provide a viable and significant market for United States agricultural commodities or products of United States agricultural commodities.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idefc93408-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idefc93409-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Presidential Determination of Emerging Democracies","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Determination of President of the United States, No. 95–35, ","children":[{"tag":"date","attrib":{"date":"1995-08-10"},"text":"Aug. 10, 1995","children":[],"tail":", 60 F.R. 44723, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pursuant to the authority vested in me by section 1542(f) of the Food, Agriculture, Conservation and Trade Act of 1990, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5622"},"text":"7 U.S.C. 5622","children":[],"tail":" note) (hereinafter “the Act”), I hereby determine that the following countries are taking the steps set forth in section 1542(f) of the Act to qualify as emerging democracies for purposes of that section:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Albania, Bangladesh, Belarus, Bosnia and Herzegovina, Bulgaria, Cambodia, Croatia, Czech Republic, Egypt, El Salvador, Estonia, the Former Yugoslav Republic of Macedonia, Ghana, Guatemala, Hungary, Jordan, Kazakhstan, Latvia, Lithuania, Morocco, Namibia, Nicaragua, Pakistan, Panama, the Philippines, Poland, Romania, Russia, Slovak Republic, Slovenia, South Africa, Tanzania, Tunisia, Ukraine, Yemen, and Zimbabwe.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In making this determination, I have considered the eligibility only of those countries for which programs are underway or currently contemplated by the Department of Agriculture.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Secretary of State is authorized and directed to publish this determination in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"William J. Clinton.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
