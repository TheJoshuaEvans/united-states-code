{"tag":"section","attrib":{"id":"ideef0388b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736"},"text":null,"children":[{"tag":"num","attrib":{"value":"1736"},"text":"§ 1736.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Commodity Credit Corporation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideef0388c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commodity Credit Corporation may acquire and make available such agricultural commodities as necessary to carry out agreements under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef0388d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Included expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to commodities made available under subchapters III and III–A, the Commodity Credit Corporation may pay—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef0388e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of acquiring such commodities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef0388f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs associated with packaging, enrichment, preservation, and fortification of such commodities, including the costs of carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1736g–2"},"text":"section 1736g–2 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef03890-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the processing, transportation, handling, and other incidental costs up to the time of the delivery of such commodities free on board vessels in United States ports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef03891-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel freight charges from United States ports or designated Canadian transshipment ports, as determined by the Secretary, to designated ports of entry abroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef03892-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the costs associated with transporting such commodities from United States ports to designated points of entry abroad in the case—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideef03893-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of landlocked countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef03894-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of ports that cannot be used effectively because of natural or other disturbances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef03895-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the unavailability of carriers to a specific country; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef03896-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of substantial savings in costs or time that may be effected by the utilization of points of entry other than ports;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef03897-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of commodities for urgent and extraordinary relief requirements (including pre-positioned commodities) the transportation costs incurred in moving the commodities from designated points of entry or ports of entry abroad to storage and distribution sites and associated storage, distribution, and program implementation costs to use the commodities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef03898-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the charges for general average contributions arising out of the ocean transport of commodities transferred pursuant thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef03899-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodity Credit Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The funds, facilities, and authorities of the Commodity Credit Corporation may be used to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef0389a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds shall be available under this chapter only to the extent provided in advance in appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideef0389b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title IV, § 406, as added "},{"tag":"ref","attrib":{"href":"/us/pl/86/341/tI/s14"},"text":"Pub. L. 86–341, title I, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-21"},"text":"Sept. 21, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/610"},"text":"73 Stat. 610","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/87/703/tII/s201/5"},"text":"Pub. L. 87–703, title II, § 201(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-27"},"text":"Sept. 27, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/611"},"text":"76 Stat. 611","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/808/s2/E"},"text":"Pub. L. 89–808, § 2(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-11"},"text":"Nov. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1536"},"text":"80 Stat. 1536","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/161/tII/s214"},"text":"Pub. L. 94–161, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-20"},"text":"Dec. 20, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/855"},"text":"89 Stat. 855","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tI/s1204/b/2"},"text":"Pub. L. 101–508, title I, § 1204(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-11"},"text":"104 Stat. 1388–11","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3650"},"text":"104 Stat. 3650","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIII/s323"},"text":"Pub. L. 102–237, title III, § 323","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1857"},"text":"105 Stat. 1857","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s215"},"text":"Pub. L. 104–127, title II, § 215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/956"},"text":"110 Stat. 956","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII"},"text":"Pub. L. 110–246, title III","children":[],"tail":", §§ 3014(b)(1), 3016, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1826"},"text":"122 Stat. 1826","children":[],"tail":", 1827; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIII/s3110"},"text":"Pub. L. 115–334, title III, § 3110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4605"},"text":"132 Stat. 4605","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideef0389c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideef0389d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideef0389e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “storage, distribution, and program implementation costs to use the commodities” for “storage and distribution costs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3014/b/1"},"text":"Pub. L. 110–246, § 3014(b)(1)","children":[],"tail":", struck out “(that have been determined to be available under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1731/a"},"text":"section 1731(a) of this title","children":[],"tail":")” after “commodities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3016"},"text":"Pub. L. 110–246, § 3016","children":[],"tail":", inserted “, including the costs of carrying out "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1736g–2"},"text":"section 1736g–2 of this title","children":[],"tail":"” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s215/1"},"text":"Pub. L. 104–127, § 215(1)","children":[],"tail":", substituted “may” for “shall” after “Corporation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s215/2/A"},"text":"Pub. L. 104–127, § 215(2)(A)","children":[],"tail":", in introductory provisions, substituted “subchapters III and III–A” for “this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s215/2/B"},"text":"Pub. L. 104–127, § 215(2)(B)","children":[],"tail":", added par. (4) and struck out former par. (4) which read as follows: “the ocean freight charges from United States ports to designated ports of entry abroad;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b)(5)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “time” for “items”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" amended section generally, substituting present provisions for provisions authorizing appropriations and authorizing the President to administer a program of farmer-to-farmer assistance, enter into agreements or make grants to train farmers in recipient countries, seek exchange of farm youth and farm leaders with developing countries, conduct research in tropical and subtropical agriculture, coordinate program with other foreign assistance programs, establish conditions for eligibility in farmer-to-farmer program, and pay costs of program through use of foreign currencies accruing from sale of commodities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/161/s214/1"},"text":"Pub. L. 94–161, § 214(1)","children":[],"tail":", substituted “the President” for “the Secretary of Agriculture”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/161/s214/2"},"text":"Pub. L. 94–161, § 214(2)","children":[],"tail":", struck out “through existing agencies of the Department of Agriculture” after “establish and administer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/161/s214/3"},"text":"Pub. L. 94–161, § 214(3)","children":[],"tail":", substituted “with other foreign assistance activities of the United States” for “with the activities of the Peace Corps, the Agency for International Development, and other agencies of the United States and to assign, upon agreement with such agencies, such persons to work with and under the administration of such agencies: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That nothing in this section shall be construed to infringe upon the powers or functions of the Secretary of State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/808"},"text":"Pub. L. 89–808","children":[],"tail":" substituted food production assistance provisions for provision respecting applicability of other laws, now provided for by "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1707/d"},"text":"section 1707(d) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/703"},"text":"Pub. L. 87–703","children":[],"tail":" made section 1701(b) and (c) applicable to this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideef0389f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideef038a0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/b"},"text":"section 4(b) of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideef038a1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1991-01-01"},"text":"Jan. 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1513"},"text":"section 1513 of Pub. L. 101–624","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s1301"},"text":"section 1301 of Pub. L. 101–508","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1994"},"text":"section 1994 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideef038a2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1966 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/808"},"text":"Pub. L. 89–808","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1967-01-01"},"text":"Jan. 1, 1967","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/89/808/s5"},"text":"section 5 of Pub. L. 89–808","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideef038a3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Farmer-to-Farmer Programs for Fiscal Years 1986 Through 1990","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXI/s1107"},"text":"Pub. L. 99–198, title XI, § 1107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1467"},"text":"99 Stat. 1467","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/277/s6"},"text":"Pub. L. 100–277, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-04"},"text":"Apr. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/69"},"text":"102 Stat. 69","children":[],"tail":", directed that not less than one-tenth of 1 percent of the funds available for each of the fiscal years ending "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"Sept. 30, 1986","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"1990-09-30"},"text":"Sept. 30, 1990","children":[],"tail":", to carry out this chapter be used to carry out section 1736(a)(1), (2) of this title, and directed the Administrator of the Agency for International Development, in conjunction with the Secretary of Agriculture, to submit to Congress a report, not later than 120 days after "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", indicating the manner in which the Agency intended to implement such provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
