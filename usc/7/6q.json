{"tag":"section","attrib":{"id":"idedc88112-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6q"},"text":null,"children":[{"tag":"num","attrib":{"value":"6q"},"text":"§ 6q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special procedures to encourage and facilitate bona fide hedging by agricultural producers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idedc88113-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall consider issuing rules or orders which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedc88114-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6q/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe procedures under which each contract market is to provide for orderly delivery, including temporary storage costs, of any agricultural commodity enumerated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1a/9"},"text":"section 1a(9) of this title","children":[],"tail":" which is the subject of a contract for purchase or sale for future delivery;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedc88115-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6q/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the ease with which domestic agricultural producers may participate in contract markets, including by addressing cost and margin requirements, so as to better enable the producers to hedge price risk associated with their production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedc88116-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6q/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide flexibility in the minimum quantities of such agricultural commodities that may be the subject of a contract for purchase or sale for future delivery that is traded on a contract market, to better allow domestic agricultural producers to hedge such price risk; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedc88117-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6q/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage contract markets to provide information and otherwise facilitate the participation of domestic agricultural producers in contract markets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedc88118-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 1 year after ","children":[{"tag":"date","attrib":{"date":"2000-12-21"},"text":"December 21, 2000","children":[],"tail":", the Commission shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report on the steps it has taken to implement this section and on the activities of contract markets pursuant to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idedc88119-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369/s4q"},"text":"Sept. 21, 1922, ch. 369, § 4q","children":[],"tail":", formerly § 4p, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tI/s121"},"text":"Pub. L. 106–554, § 1(a)(5) [title I, § 121]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–404; renumbered § 4q, "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIII/s13105/d"},"text":"Pub. L. 110–234, title XIII, § 13105(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1434"},"text":"122 Stat. 1434","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIII, § 13105(d), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2196; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVII/s721/e/3"},"text":"Pub. L. 111–203, title VII, § 721(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1671"},"text":"124 Stat. 1671","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idedc8811a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idedc8811b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idedc8811c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading"