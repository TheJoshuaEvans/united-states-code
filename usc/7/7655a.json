{"tag":"section","attrib":{"id":"idf017ca1a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655a"},"text":null,"children":[{"tag":"num","attrib":{"value":"7655a"},"text":"§ 7655a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food safety education initiatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf017ca1b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiative authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may carry out a food safety education program to educate the public and persons in the fresh produce industry about—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf017ca1c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientifically proven practices for reducing microbial pathogens on fresh produce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf017ca1d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods of reducing the threat of cross-contamination of fresh produce through sanitary handling practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf017ca1e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may carry out the education program in cooperation with public and private partners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf017ca1f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $1,000,000 for each of fiscal years 2008 through 2023, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf017ca20-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tX/s10105"},"text":"Pub. L. 110–234, title X, § 10105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1336"},"text":"122 Stat. 1336","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title X, § 10105, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2098; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tX/s10006"},"text":"Pub. L. 113–79, title X, § 10006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/947"},"text":"128 Stat. 947","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tX/s10106"},"text":"Pub. L. 115–334, title X, § 10106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2