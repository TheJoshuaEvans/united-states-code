{"tag":"section","attrib":{"id":"idf023d769-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7901"},"text":null,"children":[{"tag":"num","attrib":{"value":"7901"},"text":"§ 7901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter (other than subchapter III):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf023d76a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7901/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural Act of 1949","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Agricultural Act of 1949” means the Agricultural Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"7 U.S.C. 1421","children":[],"tail":" et seq.), as in effect prior to the suspensions under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7301"},"text":"section 7301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d76b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7901/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Base acres","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “base acres”, with respect to a covered commodity on a farm, means the number of acres established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7911"},"text":"section 7911 of this title","children":[],"tail":" with respect to the covered commodity on the election made by the owner of the farm under subsection (a) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d76c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7901/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counter-cyclical payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “counter-cyclical payment” means a payment made to producers on a farm under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7914"},"text":"section 7914 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d76d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7901/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered commodity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered commodity” means wheat, corn, grain sorghum, barley, oats, upland cotton, rice, soybeans, and other oilseeds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d76e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7901/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “direct payment” means a payment made to producers on a farm under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7913"},"text":"section 7913 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d76f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7901/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “effective price”, with respect to a covered commodity for a crop year, means the price calculated by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7914"},"text":"section 7914 of this title","children":[],"tail":" to determine whether counter-cyclical payments are required to be made for that crop year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d770-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7901/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extra long staple cotton","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “extra long staple cotton” means cotton that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf023d771-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7901/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is produced from pure strain varieties of the Barbadense species or any hybrid thereof, or other similar types of extra long staple cotton, designated by the Secretary, having characteristics needed for various end uses for which United States upland cotton is not suitable and grown in irrigated cotton-growing regions of the United States designated by the Secretary or other areas designated by the Secretary as suitable for the production of the varieties or types; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf023d772-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7901/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is ginned on a roller-type gin or, if authorized by the Secretary, ginned on another type gin for experimental purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d773-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7901/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan commodity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “loan commodity” means wheat, corn, grain sorghum, barley, oats, upland cotton, extra long staple cotton, rice, soybeans, other oilseeds, wool, mohair, honey, dry peas, lentils, and small chickpeas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d774-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7901/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other oilseed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “other oilseed” means a crop of sunflower seed, rapeseed, canola, safflower, flaxseed, mustard seed, crambe, sesame seed, or, if designated by the Secretary, another oilseed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d775-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7901/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment acres","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “payment acres” means 85 percent of the base acres of a covered commodity on a farm, as established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7911"},"text":"section 7911 of this title","children":[],"tail":", on which direct payments and counter-cyclical payments are made."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d776-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7901/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment yield","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf023d777-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7901/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “payment yield” means the yield established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7912"},"text":"section 7912 of this title","children":[],"tail":" for a farm for a covered commodity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf023d778-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7901/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updated payment yield","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “updated payment yield” means the payment yield elected by the owner of a farm under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7912/e"},"text":"section 7912(e) of this title","children":[],"tail":" to be used in calculating the counter-cyclical payments for the farm."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d779-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7901/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “producer” means an owner, operator, landlord, tenant, or sharecropper that shares in the risk of producing a crop and is entitled to share in the crop available for marketing from the farm, or would have shared had the crop been produced. In determining whether a grower of hybrid seed is a producer, the Secretary shall not take into consideration the existence of a hybrid seed contract and shall ensure that program requirements do not adversely affect the ability of the grower to receive a payment under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d77a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7901/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d77b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7901/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, and any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d77c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7901/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Target price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “target price” means the price per bushel (or other appropriate unit in the case of upland cotton, rice, and other oilseeds) of a covered commodity used to determine the payment rate for counter-cyclical payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf023d77d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7901/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States”, when used in a geographical sense, means all of the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf023d77e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1001"},"text":"Pub. L. 107–171, title I, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/143"},"text":"116 Stat. 143","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dA/tVII/s763/a"},"text":"Pub. L. 108–7, div. A, title VII, § 763(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/46"},"text":"117 Stat. 46","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf023d77f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf023d780-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf023d781-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/143"},"text":"116 Stat. 143","children":[],"tail":", which enacted this chapter and "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308–3a"},"text":"section 1308–3a of this title","children":[],"tail":", amended sections 1301, 1308 to 1308–3, 1308–4, 1308–5, 1314b, 1359aa to 1359kk, 1361, 1371, 1373, 1378, 1428, 1441, 1637a, 4501 to 4504, 4507, 4553, 6402, 6414, 6998, 7001, 7235, 7272, 7282 to 7284, 7286, and 7301 of this title, and sections 713a–4 and 714c of Title 15, Commerce and Trade, repealed sections 1339a, 1357 to 1359a, and 7271 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3830a"},"text":"section 3830a of Title 16","children":[],"tail":", Conservation, and enacted provisions set out as notes under sections 1308 and 7272 of this title. For complete classification of title I to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subchapter III, referred to in text, was in the original “subtitle C”, meaning subtitle C (§§ 1301–1310) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/166"},"text":"116 Stat. 166","children":[],"tail":", which is classified principally to subchapter III of this chapter. For complete classification of subtitle C to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7951"},"text":"section 7951 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Agricultural Act of 1949, referred to in par. (1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-31/ch792"},"text":"act Oct. 31, 1949, ch. 792","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/1051"},"text":"63 Stat. 1051","children":[],"tail":", which is classified principally to chapter 35A (§ 1421 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf023d782-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":" inserted “crambe, sesame seed,” after “mustard seed,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf023d783-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf023d784-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dA/tVII/s763/d"},"text":"Pub. L. 108–7, div. A, title VII, § 763(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/47"},"text":"117 Stat. 47","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/7/dA/tVII/s763/d"},"text":"“This section [amending this section and sections 7932 and 7934 of this title] and the amendments made by this section apply beginning with the 2003 crop of other oilseeds (as defined in section 1001 of the Farm Security and Rural Investment Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7901"},"text":"7 U.S.C. 7901","children":[],"tail":")), dry peas, lentils, and small chickpeas.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idf023d785-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/tI/s1001"},"text":"Pub. L. 109–171, title I, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/4"},"text":"120 Stat. 4","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/171/tI/s1001"},"text":"“This title [amending sections 2009cc–18, 2655, 7621, 7913, 7937, 7953, 7982, and 8106 of this title and sections 3838a, 3839aa–2, 3839aa–7, and 3841 of Title 16, Conservation, and enacting provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7937"},"text":"section 7937 of this title","children":[],"tail":"] may be cited as the ‘Agricultural Reconciliation Act of 2005’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idf023d786-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s1/a"},"text":"Pub. L. 107–171, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/134"},"text":"116 Stat. 134","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/171/s1/a"},"text":"“This Act [see Tables for classification] may be cited as the ‘Farm Security and Rural Investment Act of 2002’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
