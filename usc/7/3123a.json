{"tag":"section","attrib":{"id":"idef94b612-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3123a"},"text":"§ 3123a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specialty crop committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef94b613-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef94b614-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2004-12-21"},"text":"December 21, 2004","children":[],"tail":", the executive committee of the Advisory Board shall establish, and appoint the initial members of, a permanent specialty crops committee that will be responsible for studying the scope and effectiveness of research, extension, and economics programs affecting the specialty crop industry."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef94b615-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citrus disease subcommittee","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef94b616-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 45 days after ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":", the Secretary shall establish within the specialty crops committee, and appoint the initial members of, a citrus disease subcommittee to carry out the responsibilities of the subcommittee described in subsection (g) in accordance with subsection (j)(3) of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7632"},"text":"section 7632 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef94b617-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The citrus disease subcommittee shall be composed of 11 members, each of whom is a domestic producer of citrus in a State, represented as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef94b618-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Five of such members shall represent Arizona or California.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef94b619-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Five of such members shall represent Florida.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef94b61a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One of such members shall represent Texas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef94b61b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may appoint individuals who are not members of the specialty crops committee or the Advisory Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3123"},"text":"section 3123 of this title","children":[],"tail":" as members of the citrus disease subcommittee "},{"tag":"ref","attrib":{"idref":"fn002274"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002274"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef94b61c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The subcommittee established under subparagraph (A) shall terminate on ","children":[{"tag":"date","attrib":{"date":"2023-09-30"},"text":"September 30, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef94b61d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The subcommittee established under subparagraph (A) shall be covered by the exemption to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1008/c"},"text":"section 1008(c) of title 5","children":[],"tail":" applicable to the Advisory Board under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3123/f"},"text":"section 3123(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef94b61e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef94b61f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Individuals who are not members of the Advisory Board may be appointed as members of the specialty crops committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef94b620-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the specialty crops committee shall serve at the discretion of the executive committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef94b621-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diversity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Membership of the specialty crops committee shall reflect diversity in the specialty crops represented.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef94b622-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual committee report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the establishment of the specialty crops committee, and annually thereafter, the specialty crops committee shall submit to the Advisory Board a report containing the findings of its study under subsection (a). The specialty crops committee shall include in each report recommendations regarding the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef94b623-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Programs designed to improve the efficiency, productivity, and profitability of specialty crop production in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef94b624-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Research, extension, and teaching programs designed to improve competitiveness in the specialty crop industry, including programs that would—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef94b625-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the quality and shelf-life of fresh fruits and vegetables, including their taste and appearance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef94b626-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop new crop protection tools and expand the applicability and cost-effectiveness of integrated pest management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef94b627-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent the introduction of foreign invasive pests and diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef94b628-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop new products and new uses of specialty crops, including improving the quality and taste of processed specialty crops;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef94b629-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop new and improved marketing tools for specialty crops;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef94b62a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance food safety regarding specialty crops;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef94b62b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the remote sensing and the mechanization of production practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef94b62c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance irrigation techniques used in specialty crop production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef94b62d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Analyses of changes in macroeconomic conditions, technologies, and policies on specialty crop production and consumption, with particular focus on the effect of those changes on the financial stability of producers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef94b62e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development of data that provide applied information useful to specialty crop growers, their associations, and other interested beneficiaries in evaluating that industry from a regional and national perspective.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef94b62f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Analysis of the alignment of specialty crops committee recommendations with grants awarded through the specialty crop research initiative established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7632"},"text":"section 7632 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef94b630-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with specialty crop industry","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In studying the scope and effectiveness of programs under subsection (a), the specialty crops committee shall consult on an ongoing basis with diverse sectors of the specialty crop industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef94b631-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In preparing the annual budget recommendations for the Department of Agriculture, the Secretary shall take into consideration those findings and recommendations contained in the most-recent report of the specialty crops committee that are adopted by the Advisory Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef94b632-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the budget material submitted to Congress by the Secretary in connection with the budget submitted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":" for a fiscal year, the Secretary shall include a report describing how the Secretary addressed each recommendation of the specialty crops committee described in subsection (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef94b633-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citrus disease subcommittee duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of subsection (j) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7632"},"text":"section 7632 of this title","children":[],"tail":", the citrus disease subcommittee shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef94b634-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary on citrus research, extension, and development needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef94b635-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" propose, by a favorable vote of two-thirds of the members of the subcommittee, a research and extension agenda and annual budgets for the funds made available to carry out such subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef94b636-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate and review ongoing research and extension funded under the emergency citrus disease research and extension program (as defined in such subsection);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef94b637-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish, by a favorable vote of two-thirds of the members of the subcommittee, annual priorities for the award of grants under such subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef94b638-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the Secretary any comments on grants awarded under such subsection during the previous fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef94b639-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/g/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" engage in regular consultation and collaboration with the Department and other institutional, governmental, and private persons conducting scientific research on, and extension activities related to, the causes or treatments of citrus diseases and pests, both domestic and invasive, for purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef94b63a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/g/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximizing the effectiveness of research and extension projects funded under the citrus disease research and extension program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef94b63b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/g/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hastening the development of useful treatments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef94b63c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/g/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" avoiding duplicative and wasteful expenditures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef94b63d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3123a/g/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing the Secretary with such information and advice as the Secretary may request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef94b63e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s