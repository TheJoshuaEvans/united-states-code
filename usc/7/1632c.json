{"tag":"section","attrib":{"id":"ideedab4e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1632c"},"text":"§ 1632c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acer access and development program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideedab4e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture may make competitive grants to States, tribal governments, and research institutions to support the efforts of such States, tribal governments, and research institutions to promote the domestic maple syrup industry through the following activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedab4e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promotion of research and education related to maple syrup production.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promotion of natural resource sustainability in the maple syrup industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Market promotion for maple syrup and maple-sap products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Encouragement of owners and operators of privately held land containing species of trees in the genus Acer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedab4e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632c/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to initiate or expand maple-sugaring activities on the land; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab4e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632c/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to voluntarily make the land available, including by lease or other means, for access by the public for maple-sugaring activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedab4ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In submitting an application for a competitive grant under this section, a State, tribal government, or research institution shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedab4eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the activities to be supported using the grant funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the benefits that the State, tribal government, or research institution intends to achieve as a result of engaging in such activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the increase in maple-sugaring activities or maple syrup production that the State, tribal government, or research institution anticipates will occur as a result of engaging in such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedab4ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed so as to preempt a State or tribal government law, including a State or tribal government liability law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedab4ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of maple-sugaring","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “maple-sugaring” means the collection of sap from any species of tree in the genus Acer for the purpose of boiling to produce food.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedab4f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall promulgate such regulations as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedab4f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $20,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideedab4f2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tXII/s12306"},"text":"Pub. L. 113–79, title XII, § 12306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/988"},"text":"128 Stat. 988","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12501"},"text":"Pub. L. 115–334, title XII, § 12501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4982"},"text":"132 Stat. 4982","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideedab4f3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideedab4f4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideedab4f5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agricultural Act of 2014, and not as part of the Agricultural Marketing Act of 1946 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideedab4f6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “2023” for “2018”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
