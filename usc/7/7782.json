{"tag":"section","attrib":{"id":"idf01ef4df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7782"},"text":null,"children":[{"tag":"num","attrib":{"value":"7782"},"text":"§ 7782.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf01ef4e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7782/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program to provide financial and technical assistance to control or eradicate noxious weeds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01ef4e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7782/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7786/a"},"text":"section 7786(a) of this title","children":[],"tail":", the Secretary shall make grants under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7783"},"text":"section 7783 of this title","children":[],"tail":" to weed management entities for the control or eradication of noxious weeds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01ef4e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7782/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7786/b"},"text":"section 7786(b) of this title","children":[],"tail":", the Secretary shall enter into agreements under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7784"},"text":"section 7784 of this title","children":[],"tail":" with weed management entities to provide financial and technical assistance for the control or eradication of noxious weeds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf01ef4e3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/tIV/s453"},"text":"Pub. L. 106–224, title IV, § 453","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/412/s1"},"text":"Pub. L. 108–412, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2321"},"text":"118 Stat. 2321","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
