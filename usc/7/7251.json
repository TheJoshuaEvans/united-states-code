{"tag":"section","attrib":{"id":"ideffffb9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7251"},"text":null,"children":[{"tag":"num","attrib":{"value":"7251"},"text":"§ 7251.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Milk price support program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideffffb9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7251/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall support the price of milk produced in the 48 contiguous States through the purchase of cheese, butter, and nonfat dry milk produced from the milk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffb9c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7251/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The price of milk shall be supported at the following rates per hundredweight for milk containing 3.67 percent butterfat:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffffb9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7251/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During calendar year 1996, $10.35.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffb9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7251/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During calendar year 1997, $10.20.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffb9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7251/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During calendar year 1998, $10.05.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffba0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7251/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During each of calendar years 1999 through 2001, $9.90.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffba1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7251/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During the period beginning on ","children":[{"tag":"date","attrib":{"date":"2002-01-01"},"text":"January 1, 2002","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2002-05-31"},"text":"May 31, 2002","children":[],"tail":", $9.90."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffba2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7251/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase prices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The support purchase prices under this section for each of the products of milk (butter, cheese, and nonfat dry milk) announced by the Secretary shall be the same for all of that product sold by persons offering to sell the product to the Secretary. The purchase prices shall be sufficient to enable plants of average efficiency to pay producers, on average, a price that is not less than the rate of price support for milk in effect under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffba3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7251/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for butter and nonfat dry milk purchase prices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffffba4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7251/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of purchase prices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may allocate the rate of price support between the purchase prices for nonfat dry milk and butter in a manner that will result in the lowest level of expenditures by the Commodity Credit Corporation or achieve such other objectives as the Secretary considers appropriate. Not later than 10 days after making or changing an allocation, the Secretary shall notify the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate of the allocation. ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"Section 553 of title 5","children":[],"tail":" shall not apply with respect to the implementation of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffba5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7251/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of purchase price adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make any such adjustments in the purchase prices for nonfat dry milk and butter the Secretary considers to be necessary not more than twice in each calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffba6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7251/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refunds of 1995 and 1996 assessments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffffba7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7251/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refund required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for a refund of the entire reduction required under section 204(h)(2) of the Agricultural Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1446e/h/2"},"text":"7 U.S.C. 1446e(h)(2)","children":[],"tail":"), as in effect on the day before the amendment made by subsection (g), in the price of milk received by a producer during calendar year 1995 or 1996, if the producer provides evidence that the producer did not increase marketings in calendar year 1995 or 1996 when compared to calendar year 1994 or 1995, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffba8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7251/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not apply with respect to a producer for a particular calendar year if the producer has already received a refund under section 204(h) of the Agricultural Act of 1949 for the same fiscal year before the effective date of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffba9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7251/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of refund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A refund under this subsection shall not be considered as any type of price support or payment for purposes of sections 3811 and 3821 of title 16.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffbaa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7251/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodity Credit Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out the program authorized by this section through the Commodity Credit Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffbab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7251/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffbac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7251/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of effectiveness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section (other than subsection (g)) shall be effective only during the period beginning on the first day of the first month beginning after ","children":[{"tag":"date","attrib":{"date":"1996-04-04"},"text":"April 4, 1996","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2002-05-31"},"text":"May 31, 2002","children":[],"tail":". The program authorized by this section shall terminate on "},{"tag":"date","attrib":{"date":"2002-05-31"},"text":"May 31, 2002","children":[],"tail":", and shall be considered to have expired notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s907"},"text":"section 907 of title 2","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideffffbad-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s141"},"text":"Pub. L. 104–127, title I, § 141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/914"},"text":"110 Stat. 914","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tVIII/s807/a"},"text":"Pub. L. 106–78, title VIII, § 807(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1181"},"text":"113 Stat. 1181","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/387/s1/a/tVII/s742/a"},"text":"Pub. L. 106–387, § 1(a) [title VII, § 742(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1549"},"text":"114 Stat. 1549","children":[],"tail":", 1549A–35; "},{"tag":"ref","attrib":{"href":"/us/pl/107/76/tVII/s772/a"},"text":"Pub. L. 107–76, title VII, § 772(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-28"},"text":"Nov. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/745"},"text":"115 Stat. 745","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideffffbae-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideffffbaf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideffffbb0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 204 of the Agricultural Act of 1949, referred to in subsec. (e)(1), (2), was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1446e"},"text":"section 1446e of this title","children":[],"tail":" prior to repeal by subsec. (g) of this section. See Codification note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideffffbb1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s141"},"text":"section 141 of Pub. L. 104–127","children":[],"tail":". Subsec. (g) of "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/s141"},"text":"section 141 of Pub. L. 104–127","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1446e"},"text":"section 1446e of this title","children":[],"tail":" and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1446e"},"text":"section 1446e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideffffbb2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/76/s772/a/1"},"text":"Pub. L. 107–76, § 772(a)(1)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/76/s772/a/2"},"text":"Pub. L. 107–76, § 772(a)(2)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2002-05-31"},"text":"May 31, 2002","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2001-12-31"},"text":"December 31, 2001","children":[],"tail":"” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387/s1/a/tVII/s742/a/1"},"text":"Pub. L. 106–387, § 1(a) [title VII, § 742(a)(1)]","children":[],"tail":", substituted “through 2001” for “and 2000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387/s1/a/tVII/s742/a/2"},"text":"Pub. L. 106–387, § 1(a) [title VII, § 742(a)(2)]","children":[],"tail":", substituted “2001” for “2000” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/78/s807/a/1"},"text":"Pub. L. 106–78, § 807(a)(1)","children":[],"tail":", substituted “each of calendar years 1999 and 2000” for “calendar year 1999”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/78/s807/a/2"},"text":"Pub. L. 106–78, § 807(a)(2)","children":[],"tail":", substituted “2000” for “1999” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
