{"tag":"section","attrib":{"id":"ideed13f4a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1574"},"text":null,"children":[{"tag":"num","attrib":{"value":"1574"},"text":"§ 1574.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclaimers, limited warranties and nonwarranties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The use of a disclaimer, limited warranty, or nonwarranty clause in any invoice, advertising, labeling, or written, printed, or graphic matter, pertaining to any seed shall not constitute a defense, or be used as a defense in any way, in any prosecution or other proceeding brought under the provisions of this chapter, or the rules and regulations made and promulgated thereunder. Nothing in this section is intended to preclude the use of a disclaimer, limited warranty, or nonwarranty clause as a defense in any proceeding not brought under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideed13f4b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-09/ch615"},"text":"Aug. 9, 1939, ch. 615","children":[],"tail":", title II, § 204, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1282"},"text":"53 Stat. 1282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-09/ch520/s2"},"text":"July 9, 1956, ch. 520, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/508"},"text":"70 Stat. 508","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/581/s11"},"text":"Pub. L. 85–581, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-01"},"text":"Aug. 1, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/478"},"text":"72 Stat. 478","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideed13f4c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideed13f4d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideed13f4e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/581"},"text":"Pub. L. 85–581","children":[],"tail":" precluded use of limited warranty clause as defense in prosecution or other proceeding brought under provisions of this chapter and stated that use of enumerated clauses as defenses in proceedings not brought under this chapter is not barred."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Act ","children":[{"tag":"date","attrib":{"date":"1956-07-09"},"text":"July 9, 1956","children":[],"tail":", substituted “or other proceeding” for “, or in any proceeding for confiscation of seeds,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideed13f4f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideed13f50-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1956 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendments made by act ","children":[{"tag":"date","attrib":{"date":"1956-07-09"},"text":"July 9, 1956","children":[],"tail":", applicable only with respect to violations occurring after "},{"tag":"date","attrib":{"date":"1956-07-09"},"text":"July 9, 1956","children":[],"tail":", see note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1596"},"text":"section 1596 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideed13f51-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1610"},"text":"section 1610 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
