{"tag":"section","attrib":{"id":"idefb6214a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4404"},"text":null,"children":[{"tag":"num","attrib":{"value":"4404"},"text":"§ 4404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Secretary of State","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of State, with the concurrence of the Secretary of Agriculture, may take such action as may be considered appropriate to assert and protect the rights of the United States under the agreement.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefb6214b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/325/s5"},"text":"Pub. L. 97–325, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1605"},"text":"96 Stat. 1605","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
