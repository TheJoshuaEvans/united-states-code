{"tag":"section","attrib":{"id":"idf00be257-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7462"},"text":null,"children":[{"tag":"num","attrib":{"value":"7462"},"text":"§ 7462.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter (unless the context otherwise requires):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00be258-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7462/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the National Kiwifruit Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7464"},"text":"section 7464 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be259-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7462/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “consumer information” means any action taken to provide information to, and broaden the understanding of, the general public regarding the consumption, use, nutritional attributes, and care of kiwifruit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be25a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7462/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exporter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “exporter” means any person from outside the United States who exports kiwifruit into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be25b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7462/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Handler","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “handler” means any person, excluding a common carrier, engaged in the business of buying and selling, packing, marketing, or distributing kiwifruit as specified in the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be25c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7462/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “importer” means any person who imports kiwifruit into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be25d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7462/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Kiwifruit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “kiwifruit” means all varieties of fresh kiwifruit grown in or imported into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be25e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7462/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marketing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “marketing” means the sale or other disposition of kiwifruit into interstate, foreign, or intrastate commerce by buying, marketing, distribution, or otherwise placing kiwifruit into commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be25f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7462/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “order” means a kiwifruit research, promotion, and consumer information order issued by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7463"},"text":"section 7463 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be260-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7462/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means any individual, group of individuals, partnership, corporation, association, cooperative, or other legal entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be261-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7462/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Processing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “processing” means canning, fermenting, distilling, extracting, preserving, grinding, crushing, or in any manner changing the form of kiwifruit for the purpose of preparing the kiwifruit for market or marketing the kiwifruit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be262-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7462/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “producer” means any person who grows kiwifruit in the United States for sale in commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be263-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7462/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “promotion” means any action taken under this subchapter (including paid advertising) to present a favorable image of kiwifruit to the general public for the purpose of improving the competitive position of kiwifruit and stimulating the sale of kiwifruit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be264-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7462/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “research” means any type of research relating to the use, nutritional value, and marketing of kiwifruit conducted for the purpose of advancing the image, desirability, marketability, or quality of kiwifruit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be265-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7462/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be266-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7462/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” means the 50 States of the United States, the District of Columbia, and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf00be267-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s553"},"text":"Pub. L. 104–127, title V, § 553","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1064"},"text":"110 Stat. 1064","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
