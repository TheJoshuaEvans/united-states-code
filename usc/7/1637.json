{"tag":"section","attrib":{"id":"ideedf6ff1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637"},"text":null,"children":[{"tag":"num","attrib":{"value":"1637"},"text":"§ 1637.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this subchapter is to establish a program of information regarding the marketing of dairy products that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf6ff2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides information that can be readily understood by producers and other market participants, including information with respect to prices, quantities sold, and inventories of dairy products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6ff3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improves the price and supply reporting services of the Department of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6ff4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourages competition in the marketplace for dairy products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideedf6ff5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 271, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/532/s2"},"text":"Pub. L. 106–532, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2541"},"text":"114 Stat. 2541","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
