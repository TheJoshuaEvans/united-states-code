{"tag":"section","attrib":{"id":"idefac8478-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3403"},"text":null,"children":[{"tag":"num","attrib":{"value":"3403"},"text":"§ 3403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefac8479-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Secretary has reason to believe that the issuance of an order will tend to effectuate the declared policy of this chapter, the Secretary shall give due notice and opportunity for hearing upon a proposed order. Such hearing may be requested and proposal for an order submitted by an organization certified pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3413"},"text":"section 3413 of this title","children":[],"tail":", or by any interested person affected by the provisions of this chapter, including the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac847a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effectuation of Congressional policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After notice and opportunity for hearing as provided in subsection (a) of this section, the Secretary shall issue an order if the Secretary finds, and sets forth in such order, upon the evidence introduced at such hearing that the issuance of such order and all the terms and conditions thereof will tend to effectuate the declared policy of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefac847b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXVII/s1704"},"text":"Pub. L. 95–113, title XVII, § 1704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1033"},"text":"91 Stat. 1033","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefac847c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefac847d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefac847e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/s1901"},"text":"section 1901 of Pub. L. 95–113","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1307"},"text":"section 1307 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
