{"tag":"section","attrib":{"id":"idefbf974c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4813"},"text":null,"children":[{"tag":"num","attrib":{"value":"4813"},"text":"§ 4813.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refunds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefbf974d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4813/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demand for refund; persons eligible","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this chapter, prior to the approval of the continuation of an order pursuant to the referendum required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4811/a"},"text":"section 4811(a) of this title","children":[],"tail":", any person shall have the right to demand and receive from the Board a refund of an assessment collected under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4809"},"text":"section 4809 of this title","children":[],"tail":" if such person—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf974e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4813/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is responsible for paying such assessment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf974f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4813/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not support the program established under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf9750-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4813/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and time within which demand to be made","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such demand shall be made in accordance with regulations, on a form, and within a time period prescribed by the Board and approved by the Secretary, but not later than 30 days after the end of the month in which the assessment was paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf9751-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4813/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of refund on submission of satisfactory proof","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such refund shall be made not later than 30 days after demand is received therefore ","children":[{"tag":"ref","attrib":{"idref":"fn002299"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002299"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “therefor”."}],"tail":" on submission of proof satisfactory to the Board that the producer, person, or importer—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf9752-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4813/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paid the assessment for which refund is sought; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9753-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4813/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" did not collect such assessment from another producer, person, or importer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefbf9754-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1624"},"text":"Pub. L. 99–198, title XVI, § 1624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1619"},"text":"99 Stat. 1619","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefbf9755-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefbf9756-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefbf9757-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1986-01-01"},"text":"Jan. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1631"},"text":"section 1631 of Pub. L. 99–198","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4801"},"text":"section 4801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
