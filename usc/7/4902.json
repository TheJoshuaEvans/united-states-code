{"tag":"section","attrib":{"id":"idefc207bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4902"},"text":null,"children":[{"tag":"num","attrib":{"value":"4902"},"text":"§ 4902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc207c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4902/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc207c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4902/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” means any individual, group of individuals, partnership, corporation, association, cooperative, or other entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc207c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4902/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “watermelon” means all varieties of watermelon grown by producers in the United States or imported into the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc207c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4902/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “handler” means any person (except a common or contract carrier of watermelons owned by another person) who handles watermelons in a manner specified in a plan issued under this chapter or in regulations promulgated thereunder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc207c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4902/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “producer” means any person engaged in the growing of 10 or more acres of watermelons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc207c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4902/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “importer” means any person who imports watermelons into the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc207c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4902/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “plan” means an order issued by the Secretary under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc207c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4902/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “promotion” means any action taken by the Board, under this chapter, to present a favorable image for watermelons to the public with the express intent of improving the competitive position of watermelons in the marketplace and stimulating sales of watermelons, and shall include, but not be limited to, paid advertising.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc207c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4902/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Board” means the National Watermelon Promotion Board provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4906"},"text":"section 4906 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc207c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4902/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “United States” means each of the several States and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefc207ca-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1643"},"text":"Pub. L. 99–198, title XVI, § 1643","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1623"},"text":"99 Stat. 1623","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/189"},"text":"Pub. L. 103–189","children":[],"tail":", §§ 3(a), 8(a), (k)(3), 9(a), "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2259"},"text":"107 Stat. 2259","children":[],"tail":", 2261, 2263, 2264.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefc207cb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefc207cc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefc207cd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/189/s8/k/3/A"},"text":"Pub. L. 103–189, § 8(k)(3)(A)","children":[],"tail":", substituted “chapter:” for “chapter—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/189/s8/k/3/B"},"text":"Pub. L. 103–189, § 8(k)(3)(B)","children":[],"tail":", (C), substituted “The term” for “the term” and a period for semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/189/s8/a/1"},"text":"Pub. L. 103–189, § 8(a)(1)","children":[],"tail":", (k)(3)(B), substituted “The term” for “the term” and “or imported into the United States.” for the semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/189/s3/a/1"},"text":"Pub. L. 103–189, § 3(a)(1)","children":[],"tail":", struck out “the forty-eight contiguous States of” after “by producers in”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/189/s8/k/3/B"},"text":"Pub. L. 103–189, § 8(k)(3)(B)","children":[],"tail":", (C), substituted “The term” for “the term” and a period for semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/189/s9/a"},"text":"Pub. L. 103–189, § 9(a)","children":[],"tail":", substituted “10” for “five”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/189/s8/k/3/B"},"text":"Pub. L. 103–189, § 8(k)(3)(B)","children":[],"tail":", (C), substituted “The term” for “the term” and a period for semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/189/s8/a/2"},"text":"Pub. L. 103–189, § 8(a)(2)","children":[],"tail":", (3), added pars. (6) and (7) and redesignated former pars. (6) and (7) as (8) and (9), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/189/s8/a/2"},"text":"Pub. L. 103–189, § 8(a)(2)","children":[],"tail":", (k)(3)(D), redesignated par. (6) as (8) and substituted “The term” for “the term” and a period for “; and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/189/s8/a/2"},"text":"Pub. L. 103–189, § 8(a)(2)","children":[],"tail":", (k)(3)(E), redesignated par. (7) as (9) and substituted “The term” for “the term” and “4906” for “4903”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/189/s3/a/2"},"text":"Pub. L. 103–189, § 3(a)(2)","children":[],"tail":", added par. (10)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
