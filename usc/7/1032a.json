{"tag":"section","attrib":{"id":"idee6cfeba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1032a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1032a"},"text":"§ 1032a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disbursing and certifying officers; exemption from liability for advances to defense relocation corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Comptroller General of the United States is authorized and directed to allow credit in the accounts of disbursing and certifying officers for advances made in good faith on behalf of the Department of Agriculture to defense relocation corporations and land purchasing associations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee6cfebb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch964/s6"},"text":"Aug. 14, 1946, ch. 964, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/1079"},"text":"60 Stat. 1079","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee6cfebc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee6cfebd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee6cfebe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s82h"},"text":"section 82h of Title 31","children":[],"tail":" prior to the general revision and enactment of Title 31, Money and Finance, by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/877"},"text":"96 Stat. 877","children":[],"tail":". Section was not enacted as a part of the Bankhead-Jones Farm Tenant Act, which constitutes a major part of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
