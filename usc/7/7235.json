{"tag":"section","attrib":{"id":"ideffffb2a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7235"},"text":null,"children":[{"tag":"num","attrib":{"value":"7235"},"text":"§ 7235.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan deficiency payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideffffb2b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7235/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of loan deficiency payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (d), the Secretary may make loan deficiency payments available to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffffb2c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7235/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" producers who, although eligible to obtain a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7231"},"text":"section 7231 of this title","children":[],"tail":" with respect to a loan commodity, agree to forgo obtaining the loan for the commodity in return for payments under this section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffb2d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7235/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective only for the 2000 and 2001 crop years, producers that, although not eligible to obtain such a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7231"},"text":"section 7231 of this title","children":[],"tail":", produce a contract commodity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffb2e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7235/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A loan deficiency payment under this section shall be computed by multiplying—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffffb2f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7235/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan payment rate determined under subsection (c) for the loan commodity; by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffb30-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7235/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of the loan commodity produced by the eligible producers, excluding any quantity for which the producers obtain a loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7231"},"text":"section 7231 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffb31-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7235/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan payment rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the loan payment rate shall be the amount by which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffffb32-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7235/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7232"},"text":"section 7232 of this title","children":[],"tail":" for the loan commodity; exceeds"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffb33-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7235/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate at which a loan for the commodity may be repaid under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7234"},"text":"section 7234 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffb34-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7235/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for extra long staple cotton","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply with respect to extra long staple cotton.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffb35-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7235/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A payment to a producer eligible for a payment under subsection (a)(2) that harvested a commodity on or before the date that is 30 days after the promulgation of the regulations implementing subsection (a)(2) shall be determined as the date the producer lost beneficial interest in the commodity, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffb36-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7235/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beneficial interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (e), a producer shall be eligible for a payment under this section only if the producer has a beneficial interest in the commodity, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffb37-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7235/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date for payment rate determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the 2001 crop year, the Secretary shall determine the amount of the loan deficiency payment to be made under this section to the producers on a farm with respect to a quantity of a loan commodity using the payment rate in effect under subsection (c) as of the earlier of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffffb38-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7235/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The date on which the producers marketed or otherwise lost beneficial interest in the crop of the loan commodity, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffb39-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7235/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The date the producers requested the payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideffffb3a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s135"},"text":"Pub. L. 104–127, title I, § 135","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/909"},"text":"110 Stat. 909","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/224/tII/s206"},"text":"Pub. L. 106–224, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/405"},"text":"114 Stat. 405","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1205/f/2"},"text":"Pub. L. 107–171, title I, § 1205(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/159"},"text":"116 Stat. 159","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideffffb3b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideffffb3c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideffffb3d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s1205/f/2/A"},"text":"Pub. L. 107–171, § 1205(f)(2)(A)","children":[],"tail":", substituted “2000 and 2001 crop years” for “2000 crop year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s1205/f/2/B"},"text":"Pub. L. 107–171, § 1205(f)(2)(B)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/s206/a"},"text":"Pub. L. 106–224, § 206(a)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/s206/b"},"text":"Pub. L. 106–224, § 206(b)","children":[],"tail":", substituted “produced by the eligible producers, excluding any quantity for which the producers obtain a loan under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7231"},"text":"section 7231 of this title","children":[],"tail":".” for “that the producers on a farm are eligible to place under loan but for which the producers forgo obtaining the loan in return for payments under this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/s206/c"},"text":"Pub. L. 106–224, § 206(c)","children":[],"tail":", added subsecs. (e) and (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
