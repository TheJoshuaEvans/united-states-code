{"tag":"section","attrib":{"id":"idefe5bc38-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509"},"text":null,"children":[{"tag":"num","attrib":{"value":"6509"},"text":"§ 6509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Animal production practices and materials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe5bc39-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any livestock that is to be slaughtered and sold or labeled as organically produced shall be raised in accordance with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc3a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Breeder stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Breeder stock may be purchased from any source if such stock is not in the last third of gestation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc3b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Practices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For a farm to be certified under this chapter as an organic farm with respect to the livestock produced by such farm, producers on such farm—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bc3c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall feed such livestock organically produced feed that meets the requirements of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc3d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall not use the following feed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe5bc3e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plastic pellets for roughage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bc3f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manure refeeding; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bc40-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" feed formulas containing urea; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc41-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not use growth promoters and hormones on such livestock, whether implanted, ingested, or injected, including antibiotics and synthetic trace elements used to stimulate growth or production of such livestock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc42-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bc43-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited practices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For a farm to be certified under this chapter as an organic farm with respect to the livestock produced by such farm, producers on such farm shall not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe5bc44-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use subtherapeutic doses of antibiotics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bc45-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use synthetic internal parasiticides on a routine basis; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bc46-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer medication, other than vaccinations, in the absence of illness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc47-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Organic Standards Board shall recommend to the Secretary standards in addition to those in paragraph (1) for the care of livestock to ensure that such livestock is organically produced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc48-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional guidelines","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bc49-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Poultry","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With the exception of day old poultry, all poultry from which meat or eggs will be sold or labeled as organically produced shall be raised and handled in accordance with this chapter prior to and during the period in which such meat or eggs are sold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc4a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dairy livestock","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe5bc4b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), a dairy animal from which milk or milk products will be sold or labeled as organically produced shall be raised and handled in accordance with this chapter for not less than the 12-month period immediately prior to the sale of such milk and milk products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bc4c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition guideline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Crops and forage from land included in the organic system plan of a dairy farm that is in the third year of organic management may be consumed by the dairy animals of the farm during the 12-month period immediately prior to the sale of organic milk and milk products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc4d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Livestock identification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bc4e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For a farm to be certified under this chapter as an organic farm with respect to the livestock produced by such farm, producers on such farm shall keep adequate records and maintain a detailed, verifiable audit trail so that each animal (or in the case of poultry, each flock) can be traced back to such farm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc4f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to carry out paragraph (1), each producer shall keep accurate records on each animal (or in the case of poultry, each flock) including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe5bc50-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts and sources of all medications administered; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bc51-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all feeds and feed supplements bought and fed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc52-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6509/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and public comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall hold public hearings and shall develop detailed regulations, with notice and public comment, to guide the implementation of the standards for livestock products provided under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe5bc53-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXI/s2110"},"text":"Pub. L. 101–624, title XXI, § 2110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3940"},"text":"104 Stat. 3940","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tX/s1001/2"},"text":"Pub. L. 102–237, title X, § 1001(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1893"},"text":"105 Stat. 1893","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/97/tVII/s797/c"},"text":"Pub. L. 109–97, title VII, § 797(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-10"},"text":"Nov. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2165"},"text":"119 Stat. 2165","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefe5bc54-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefe5bc55-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefe5bc56-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/97"},"text":"Pub. L. 109–97","children":[],"tail":" designated existing provisions as subpar. (A), inserted heading, substituted “Except as provided in subparagraph (B), a dairy” for “A dairy”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s1001/2/A"},"text":"Pub. L. 102–237, § 1001(2)(A)","children":[],"tail":", substituted “parasiticides” for “paraciticides”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s1001/2/B"},"text":"Pub. L. 102–237, § 1001(2)(B)","children":[],"tail":", redesignated subsec. (h) as (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefe5bc57-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idefe5bc58-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dB/tVII/s756"},"text":"Pub. L. 116–94, div. B, title VII, § 756","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2654"},"text":"133 Stat. 2654","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/94/dB/tVII/s756"},"text":"“Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"], the Secretary of Agriculture shall issue a final rule based on the proposed rule entitled ‘National Organic Program; Origin of Livestock,’ published in the "},{"tag":"i","attrib":{},"text":"Federal Register","children":[],"tail":" on "},{"tag":"date","attrib":{"date":"2015-04-28"},"text":"April 28, 2015","children":[],"tail":" (80 Fed. Reg. 23455): "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the final rule shall incorporate public comments submitted in response to the proposed rule.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
