{"tag":"section","attrib":{"id":"idf021665a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7803"},"text":null,"children":[{"tag":"num","attrib":{"value":"7803"},"text":"§ 7803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf021665b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf021665c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7803/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To effectuate the policy of this chapter specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7801/b"},"text":"section 7801(b) of this title","children":[],"tail":", the Secretary, subject to the procedures provided in subsection (b), shall issue orders under this chapter applicable to producers, importers, and first handlers of Hass avocados."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf021665d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7803/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any order shall be national in scope.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf021665e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7803/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" One order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than one order shall be in effect at any one time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf021665f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0216660-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7803/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposal for an order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An existing organization of avocado producers established pursuant to a State statute, or any other person who will be affected by this chapter, may request the issuance of, and submit a proposal for an order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0216661-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7803/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of proposal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish a proposed order and give notice and opportunity for public comment on the proposed order not later than 60 days after receipt by the Secretary of a proposal for an order from an existing organization of avocado producers established pursuant to a State statute, as provided in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0216662-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7803/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of order","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0216663-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7803/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After notice and opportunity for public comment are provided in accordance with paragraph (2), the Secretary shall issue the order, taking into consideration the comments received and including in the order such provisions as are necessary to ensure that the order is in conformity with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0216664-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7803/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall be issued and become effective only after an affirmative vote in a referendum as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7805"},"text":"section 7805 of this title","children":[],"tail":", but not later than 180 days after publication of the proposed order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0216665-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7803/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, from time to time, may amend an order. The provisions of this chapter applicable to an order shall be applicable to any amendment to an order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0216666-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387/s1/a/tXII/s1204"},"text":"Pub. L. 106–387, § 1(a) [title XII, § 1204]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1549"},"text":"114 Stat. 1549","children":[],"tail":", 1549A–81.)"}],"tail":"\n"}],"tail":null}
