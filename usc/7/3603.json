{"tag":"section","attrib":{"id":"idefaef556-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3603"},"text":null,"children":[{"tag":"num","attrib":{"value":"3603"},"text":"§ 3603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of powers and duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President may exercise any power or duty conferred on him by this chapter through such agencies or offices of the United States as he shall designate. Such agencies or offices shall issue such regulations as they determine are necessary to implement this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefaef557-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/236/s3"},"text":"Pub. L. 96–236, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-22"},"text":"Apr. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/336"},"text":"94 Stat. 336","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
