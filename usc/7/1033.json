{"tag":"section","attrib":{"id":"idee6cfebf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1033"},"text":null,"children":[{"tag":"num","attrib":{"value":"1033"},"text":"§ 1033.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of reserved mineral interests","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provisions of law, the Secretary of Agriculture (referred to in sections 1033 to 1035 and 1037 to 1039 of this title as the “Secretary”) is authorized and directed to sell, as provided in said sections, all mineral interests now owned by the United States, which have been reserved or acquired by it under any program heretofore administered by the Resettlement Administration, or the Farm Security Administration, or now administered by the Farmers Home Administration, except the program administered pursuant to sections 1010 to 1012 of this title and the program for the liquidation of labor camps pursuant to Public Law 298, Eightieth Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee6cfec0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-06/ch897/s1"},"text":"Sept. 6, 1950, ch. 897, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/769"},"text":"64 Stat. 769","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee6cfec1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee6cfec2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idee6cfec3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Public Law 298, Eightieth Congress, referred to in text, means ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-31/ch413"},"text":"act July 31, 1947, ch. 413","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/694"},"text":"61 Stat. 694","children":[],"tail":", which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1017"},"text":"section 1017 of this title","children":[],"tail":" and was repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1950-04-20/ch94/tII/s205/a"},"text":"act Apr. 20, 1950, ch. 94, title II, § 205(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/73"},"text":"64 Stat. 73","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee6cfec4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Bankhead-Jones Farm Tenant Act which constitutes a major part of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee6cfec5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idee6cfec6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-06/ch897/s8"},"text":"Act Sept. 6, 1950, ch. 897, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/770"},"text":"64 Stat. 770","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1950-09-06/ch897/s8"},"text":"“There is authorized to be appropriated to the Secretary such sums as Congress may from time to time determine to be necessary to enable the Secretary to carry out the provisions of this Act [enacting this section and sections 1034 to 1039 of this title].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
