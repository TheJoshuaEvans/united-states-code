{"tag":"section","attrib":{"id":"idf0072755-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414"},"text":null,"children":[{"tag":"num","attrib":{"value":"7414"},"text":"§ 7414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required terms in orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0072756-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each order shall contain the terms and conditions specified in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0072757-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0072758-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each order shall establish a board to carry out a program of generic promotion, research, and information regarding the agricultural commodity covered by the order and intended to effectuate the purpose of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072759-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board membership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf007275a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each board shall consist of the number of members considered by the Secretary, in consultation with the agricultural commodity industry involved, to be appropriate to administer the order. In addition to members, the Secretary may also provide for alternates on the board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf007275b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint the members and any alternates of a board from among producers of the agricultural commodity and first handlers and others in the marketing chain as appropriate. If imports of the agricultural commodity covered by an order are subject to assessment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7415/f"},"text":"section 7415(f) of this title","children":[],"tail":", the Secretary shall also appoint importers as members of the board and as alternates if alternates are included on the board. The Secretary may appoint 1 or more members of the general public to each board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf007275c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nominations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make appointments from nominations made pursuant to the method set forth in the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf007275d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographical representation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To ensure fair and equitable representation of the agricultural commodity industry covered by an order, the composition of each board shall reflect the geographical distribution of the production of the agricultural commodity involved in the United States and the quantity or value of the agricultural commodity imported into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf007275e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reapportionment of board membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with rules issued by the Secretary, at least once in each 5-year period, but not more frequently than once in each 3-year period, each board shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf007275f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the geographical distribution in the United States of the production of the agricultural commodity covered by the order involved and the quantity or value of the agricultural commodity imported into the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0072760-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if warranted, recommend to the Secretary the reapportionment of the board membership to reflect changes in the geographical distribution of the production of the agricultural commodity and the quantity or value of the imported agricultural commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072761-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0072762-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each order shall provide for notice of board vacancies to the agricultural commodity industry involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0072763-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each board shall provide the Secretary with prior notice of meetings of the board to permit the Secretary, or a designated representative of the Secretary, to attend the meetings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072764-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of office","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0072765-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members and any alternates of a board shall each serve for a term of 3 years, except that the members and any alternates initially appointed to a board shall serve for terms of not more than 2, 3, and 4 years, as specified by the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0072766-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on consecutive terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member or alternate may serve not more than 2 consecutive terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0072767-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (B), each member or alternate shall continue to serve until a successor is appointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0072768-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy arising before the expiration of a term of office of an incumbent member or alternate of a board shall be filled in a manner provided for in the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072769-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf007276a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members and any alternates of a board shall serve without compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf007276b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If approved by a board, members or alternates shall be reimbursed for reasonable travel expenses, which may include a per diem allowance or actual subsistence incurred while away from their homes or regular places of business in the performance of services for the board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf007276c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers and duties of board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each order shall specify the powers and duties of the board established under the order, which shall include the power and duty—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf007276d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to administer the order in accordance with its terms and conditions and to collect assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf007276e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and recommend to the Secretary for approval such bylaws as may be necessary for the functioning of the board and such rules as may be necessary to administer the order, including activities authorized to be carried out under the order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf007276f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet, organize, and select from among the members of the board a chairperson, other officers, and committees and subcommittees, as the board determines to be appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072770-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to employ persons, other than the members, as the board considers necessary to assist the board in carrying out its duties, and to determine the compensation and specify the duties of the persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072771-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (e), to develop and carry out generic promotion, research, and information activities relating to the agricultural commodity covered by the order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072772-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prepare and submit for the approval of the Secretary, before the beginning of each fiscal year, rates of assessment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7416"},"text":"section 7416 of this title","children":[],"tail":" and an annual budget of the anticipated expenses to be incurred in the administration of the order, including the probable cost of each promotion, research, and information activity proposed to be developed or carried out by the board;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072773-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to borrow funds necessary for the startup expenses of the order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072774-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (f), to enter into contracts or agreements to develop and carry out generic promotion, research, and information activities relating to the agricultural commodity covered by the order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072775-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay the cost of the activities with assessments collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7416"},"text":"section 7416 of this title","children":[],"tail":", earnings from invested assessments, and other funds;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072776-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to keep records that accurately reflect the actions and transactions of the board, to keep and report minutes of each meeting of the board to the Secretary, and to furnish the Secretary with any information or records the Secretary requests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072777-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive, investigate, and report to the Secretary complaints of violations of the order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072778-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recommend to the Secretary such amendments to the order as the board considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0072779-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A board may not engage in, and shall prohibit the employees and agents of the board from engaging in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf007277a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any action that would be a conflict of interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf007277b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using funds collected by the board under the order, any action undertaken for the purpose of influencing any legislation or governmental action or policy other than recommending to the Secretary amendments to the order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf007277c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any advertising, including promotion, research, and information activities authorized to be carried out under the order, that may be false or misleading or disparaging to another agricultural commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf007277d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities and budgets","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf007277e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each order shall require the board established under the order to submit to the Secretary for approval plans and projects for promotion, research, or information relating to the agricultural commodity covered by the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf007277f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budgets","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0072780-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each order shall require the board established under the order to submit to the Secretary for approval a budget of its anticipated annual expenses and disbursements to be paid to administer the order. The budget shall be submitted before the beginning of a fiscal year and as frequently as may be necessary after the beginning of the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0072781-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each order shall require that the Secretary be reimbursed for all expenses incurred by the Secretary in the implementation, administration, and supervision of the order, including all referenda costs incurred in connection with the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072782-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incurring expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A board may incur the expenses described in paragraph (2) and other expenses for the administration, maintenance, and functioning of the board as authorized by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072783-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Expenses incurred under paragraph (3) shall be paid by a board using assessments collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7416"},"text":"section 7416 of this title","children":[],"tail":", earnings obtained from assessments, and other income of the board. Any funds borrowed by the board shall be expended only for startup costs and capital outlays."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072784-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on spending","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For fiscal years beginning 3 or more years after the date of the establishment of a board, the board may not expend for administration (except for reimbursements to the Secretary required under paragraph (2)(B)), maintenance, and functioning of the board in a fiscal year an amount that exceeds 15 percent of the assessment and other income received by the board for the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0072785-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts and agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0072786-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each order shall provide that, with the approval of the Secretary, the board established under the order may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0072787-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into contracts and agreements to carry out generic promotion, research, and information activities relating to the agricultural commodity covered by the order, including contracts and agreements with producer associations or other entities as considered appropriate by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0072788-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay the cost of approved generic promotion, research, and information activities using assessments collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7416"},"text":"section 7416 of this title","children":[],"tail":", earnings obtained from assessments, and other income of the board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072789-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each contract or agreement shall provide that any person who enters into the contract or agreement with the board shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf007278a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and submit to the board a proposed activity together with a budget that specifies the cost to be incurred to carry out the activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf007278b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" keep accurate records of all of its transactions relating to the contract or agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf007278c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" account for funds received and expended in connection with the contract or agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf007278d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make periodic reports to the board of activities conducted under the contract or agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf007278e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such other reports as the board or the Secretary considers relevant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf007278f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records of board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0072790-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each order shall require the board established under the order—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0072791-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain such records as the Secretary may require and to make the records available to the Secretary for inspection and audit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0072792-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to collect and submit to the Secretary, at any time the Secretary may specify, any information the Secretary may request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0072793-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to account for the receipt and disbursement of all funds in the possession, or under the control, of the board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072794-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each order shall require the board established under the order to have—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0072795-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its records audited by an independent auditor at the end of each fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0072796-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report of the audit submitted directly to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0072797-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7401/c"},"text":"section 7401(c) of this title","children":[],"tail":", each order shall require the board established under the order to provide for the independent evaluation of all generic promotion, research, and information activities undertaken under the order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0072798-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Books and records of persons covered by order","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0072799-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each order shall require that producers, first handlers and other persons in the marketing chain as appropriate, and importers covered by the order shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf007279a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain records sufficient to ensure compliance with the order and regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf007279b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the board established under the order any information required by the board to carry out its responsibilities under the order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf007279c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/i/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the records described in subparagraph (A) available, during normal business hours, for inspection by employees or agents of the board or the Department, including any records necessary to verify information required under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf007279d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any record required to be maintained under paragraph (1) shall be maintained for such time period as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf007279e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use, and may authorize the board to use under this subchapter, information regarding persons subject to an order that is collected by the Department under any other law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf007279f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality of information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00727a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/i/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subchapter, all information obtained under paragraph (1) or as part of a referendum under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7417"},"text":"section 7417 of this title","children":[],"tail":" shall be kept confidential by all officers, employees, and agents of the Department and of the board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00727a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/i/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Information referred to in subparagraph (A) may be disclosed only if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf00727a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/i/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary considers the information relevant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf00727a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/i/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information is revealed in a judicial proceeding or administrative hearing brought at the direction or on the request of the Secretary or to which the Secretary or any officer of the Department is a party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00727a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/i/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This paragraph shall not prohibit—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf00727a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/i/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuance of general statements based on reports or on information relating to a number of persons subject to an order if the statements do not identify the information furnished by any person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf00727a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/i/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the publication, by direction of the Secretary, of the name of any person violating any order and a statement of the particular provisions of the order violated by the person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00727a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/i/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who willfully violates this subsection shall be subject, on conviction, to a fine of not more than $1,000 or to imprisonment for not more than 1 year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00727a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7414/i/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not authorize the withholding of information from Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf00727a9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s515"},"text":"Pub. L. 104–127, title V, § 515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1036"},"text":"110 Stat. 1036","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
