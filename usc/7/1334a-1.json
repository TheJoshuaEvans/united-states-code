{"tag":"section","attrib":{"id":"idee80119f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1334a–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1334a–1"},"text":"§ 1334a–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summer fallow farms; upper limit on required set aside acreage for 1971 through 1977 wheat, feed grain, and cotton crops","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, for the 1971 through 1977 crops of wheat, feed grains and cotton, if in any year at least 55 per centum of the cropland acreage on an established summer fallow farm is devoted to a summer fallow use, no further acreage shall be required to be set aside under the wheat, feed grain and cotton programs for such year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee8011a0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/524/tIV/s410"},"text":"Pub. L. 91–524, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-11-30"},"text":"Nov. 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1367"},"text":"84 Stat. 1367","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/86/s1/17"},"text":"Pub. L. 93–86, § 1(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-08-10"},"text":"Aug. 10, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/230"},"text":"87 Stat. 230","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee8011a1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee8011a2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee8011a3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agricultural Act of 1970, and not as part of the Agricultural Adjustment Act of 1938 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee8011a4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1973—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/86"},"text":"Pub. L. 93–86","children":[],"tail":" substituted “1971 through 1977” for “1971, 1972, and 1973”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
