{"tag":"section","attrib":{"id":"idf007271c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412"},"text":null,"children":[{"tag":"num","attrib":{"value":"7412"},"text":"§ 7412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter (unless the context otherwise requires):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf007271d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural commodity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “agricultural commodity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf007271e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agricultural, horticultural, viticultural, and dairy products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf007271f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" livestock and the products of livestock;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0072720-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the products of poultry and bee raising;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0072721-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the products of forestry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0072722-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" products, as a class, that are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0072723-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produced on a certified organic farm (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6502"},"text":"section 6502 of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0072724-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certified to be sold or labeled as “organic” or “100 percent organic” (as defined in part 205 of title 7, Code of Federal Regulations (or a successor regulation));","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0072725-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other commodities raised or produced on farms, as determined appropriate by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0072726-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" products processed or manufactured from products specified in the preceding subparagraphs, as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072727-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “board” means a board established under an order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7413"},"text":"section 7413 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072728-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “conflict of interest” means a situation in which a member or employee of a board has a direct or indirect financial interest in a person that performs a service for, or enters into a contract with, a board for anything of economic value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072729-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department” means the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf007272a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First handler","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “first handler” means the first person who buys or takes possession of an agricultural commodity from a producer for marketing. If a producer markets the agricultural commodity directly to consumers, the producer shall be considered to be the first handler with respect to the agricultural commodity produced by the producer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf007272b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “importer” means any person who imports an agricultural commodity from outside the United States for sale in the United States as a principal or as an agent, broker, or consignee of any person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf007272c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “information” means information and programs that are designed to increase—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf007272d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efficiency in processing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf007272e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of new markets, marketing strategies, increased marketing efficiency, and activities to enhance the image of agricultural commodities on a national or international basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf007272f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Market","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “market” means to sell or to otherwise dispose of an agricultural commodity in interstate, foreign, or intrastate commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072730-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “order” means an order issued by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7413"},"text":"section 7413 of this title","children":[],"tail":" that provides for a program of generic promotion, research, and information regarding agricultural commodities designed to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0072731-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen the position of agricultural commodity industries in the marketplace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0072732-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain and expand existing domestic and foreign markets and uses for agricultural commodities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0072733-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop new markets and uses for agricultural commodities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0072734-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist producers in meeting their conservation objectives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072735-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means any individual, group of individuals, partnership, corporation, association, cooperative, or any other legal entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072736-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “producer” means any person who is engaged in the production and sale of an agricultural commodity in the United States and who owns, or shares the ownership and risk of loss of, the agricultural commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072737-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “promotion” means any action taken by a board under an order, including paid advertising, to present a favorable image of an agricultural commodity to the public to improve the competitive position of the agricultural commodity in the marketplace and to stimulate sales of the agricultural commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072738-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “research” means any type of test, study, or analysis designed to advance the image, desirability, use, marketability, production, product development, or quality of an agricultural commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072739-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf007273a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means any of the States, the District of Columbia, the Commonwealth of Puerto Rico, or any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf007273b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspend","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “suspend” means to issue a rule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":" to temporarily prevent the operation of an order during a particular period of time specified in the rule."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf007273c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terminate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “terminate” means to issue a rule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":" to cancel permanently the operation of an order beginning on a date certain specified in the rule."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf007273d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7412/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” means collectively the 50 States, the District of Columbia, the Commonwealth of Puerto Rico and the territories and possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf007273e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s513"},"text":"Pub. L. 104–127, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1033"},"text":"110 Stat. 1033","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tX/s10004/f"},"text":"Pub. L. 113–79, title X, § 10004(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/944"},"text":"128 Stat. 944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf007273f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0072740-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf0072741-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Par. (1)(E) to (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" added subpar. (E) and redesignated former subpars. (E) and (F) as (F) and (G), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
