{"tag":"section","attrib":{"id":"idefb62169-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4502"},"text":null,"children":[{"tag":"num","attrib":{"value":"4502"},"text":"§ 4502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefb6216a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Board” means the National Dairy Promotion and Research Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4504"},"text":"section 4504 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb6216b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Department” means the Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb6216c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb6216d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “milk” means any class of cow’s milk;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb6216e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4502/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “dairy products” means products manufactured for human consumption which are derived from the processing of milk, and includes fluid milk products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb6216f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4502/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “fluid milk products” means those milk products normally consumed in liquid form as a beverage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb62170-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4502/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “person” means any individual, group of individuals, partnership, corporation, association, cooperative, or any other entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb62171-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4502/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “producer” means any person engaged in the production of milk for commercial use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb62172-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4502/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “promotion” means actions such as paid advertising, sales promotion, and publicity to advance the image and sales of and demand for dairy products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb62173-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4502/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “research” means studies testing the effectiveness of market development and promotion efforts, studies relating to the nutritional value of milk and dairy products, and other related efforts to expand demand for milk and dairy products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb62174-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4502/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “nutrition education” means those activities intended to broaden the understanding of sound nutritional principles including the role of milk and dairy products in a balanced diet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb62175-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4502/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “United States”, when used in a geographical sense, means all of the States, the District of Columbia, and the Commonwealth of Puerto Rico;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb62176-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4502/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “imported dairy product” means any dairy product that is imported into the United States, including dairy products imported into the United States in the form of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefb62177-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4502/m/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" milk, cream, and fresh and dried dairy products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb62178-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4502/m/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" butter and butterfat mixtures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb62179-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4502/m/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cheese; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb6217a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4502/m/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" casein and mixtures;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb6217b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4502/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “importer” means a person that imports an imported dairy product into the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb6217c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4502/o"},"text":null,"children":[{"tag":"num","attrib":{"value":"o"},"text":"(o)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Customs” means the United States Customs Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ide