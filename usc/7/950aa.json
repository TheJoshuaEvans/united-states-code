{"tag":"section","attrib":{"id":"idee63890a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"950aa"},"text":"§ 950aa.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional powers and duties","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee63890b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aa/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advice and guidance to electric borrowers under this chapter concerning the effective and prudent use by such borrowers of the investment authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s940b"},"text":"section 940b of this title","children":[],"tail":" to promote rural development;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee63890c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aa/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical advice, troubleshooting, and guidance concerning the operation of programs or systems that receive assistance under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee63890d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aa/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and administer various pilot projects through electric and telephone borrowers that the Secretary determines are useful or necessary, and recommend specific rural development projects for rural areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee63890e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aa/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" act as an information clearinghouse and conduit to provide information to electric and telephone borrowers under this chapter concerning useful and effective rural development efforts that such borrowers may wish to apply in their areas of operation and concerning State, regional, or local plans for long-term rural economic development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee63890f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aa/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information to electric and telephone borrowers under this chapter concerning the eligibility of such borrowers to apply for financial assistance, loans, or grants from other Federal agencies and non-Federal sources to enable such borrowers to expand their rural development efforts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee638910-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aa/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote local partnerships and other coordination between borrowers under this chapter and community organizations, States, counties, or other entities, to improve rural development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee638911-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title V, § 501, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2345"},"text":"Pub. L. 101–624, title XXIII, § 2345","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4029"},"text":"104 Stat. 4029","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tVII/s703/c"},"text":"Pub. L. 102–237, title VII, § 703(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1881"},"text":"105 Stat. 1881","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s235/a/12"},"text":"Pub. L. 103–354, title II, § 235(a)(12)","children":[],"tail":", (13), "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3221"},"text":"108 Stat. 3221","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s781/b"},"text":"Pub. L. 104–127, title VII, § 781(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1151"},"text":"110 Stat. 1151","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee638912-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee638913-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee638914-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" struck out par. (7) which read as follows: “administer a Rural Business Incubator Fund (as established under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s950aa–1"},"text":"section 950aa–1 of this title","children":[],"tail":") that shall provide technical assistance, advice, loans, or capital to business incubator programs or for the creation or operation of small business incubators in rural areas.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" struck out “of REA Administrator” at end of section catchline and substituted “Secretary” for “Administrator” in introductory provisions and par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Pars. (6) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" inserted “and” at end of par. (6), redesignated par. (8) as (7), and struck out former par. (7) which read as follows: “review the advice and recommendations of the Rural Educational Opportunities Board as established under section 601(f); and”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee638915-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee638916-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" effective as if included in the provision of the Food, Agriculture, Conservation, and Trade Act of 1990, "},{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":", to which the amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/s1101/b/8"},"text":"section 1101(b)(8) of Pub. L. 102–237","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
