{"tag":"section","attrib":{"id":"idef309dfd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009cc–11"},"text":"§ 2009cc–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examinations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef309dfe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–11/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each rural business investment company that participates in the program established under this subchapter shall be subject to examinations made at the direction of the Secretary in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef309dff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–11/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance of private sector entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An examination under this section may be conducted with the assistance of a private sector entity that has the qualifications and the expertise necessary to conduct such an examination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef309e00-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–11/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef309e01-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–11/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may assess the cost of an examination under this section, including compensation of the examiners, against the rural business investment company examined.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef309e02-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–11/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any rural business investment company against which the Secretary assesses costs under this paragraph shall pay the costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef309e03-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–11/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds collected under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef309e04-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–11/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be deposited in the account that incurred the costs for carrying out this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef309e05-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–11/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be made available to the Secretary to carry out this section, without further appropriation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef309e06-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–11/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef309e07-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s384L"},"text":"Pub. L. 87–128, title III, § 384L","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6029"},"text":"Pub. L. 107–171, title VI, § 6029","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/399"},"text":"116 Stat. 399","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
