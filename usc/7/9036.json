{"tag":"section","attrib":{"id":"idf04c46c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036"},"text":null,"children":[{"tag":"num","attrib":{"value":"9036"},"text":"§ 9036.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments in lieu of loan deficiency payments for grazed acreage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf04c46c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible producers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04c46c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective for each of the 2014 through 2031 crop years, in the case of a producer that would be eligible for a loan deficiency payment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9035"},"text":"section 9035 of this title","children":[],"tail":" for wheat, barley, or oats, but that elects to use acreage planted to the wheat, barley, or oats for the grazing of livestock, the Secretary shall make a payment to the producer under this section if the producer enters into an agreement with the Secretary to forgo any other harvesting of the wheat, barley, or oats on that acreage."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c46c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing of triticale acreage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective for each of the 2014 through 2031 crop years, with respect to a producer on a farm that uses acreage planted to triticale for the grazing of livestock, the Secretary shall make a payment to the producer under this section if the producer enters into an agreement with the Secretary to forgo any other harvesting of triticale on that acreage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c46c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment amount","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04c46c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a payment made under this section to a producer on a farm described in subsection (a)(1) shall be equal to the amount determined by multiplying—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c46ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan deficiency payment rate determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9035/c"},"text":"section 9035(c) of this title","children":[],"tail":" in effect, as of the date of the agreement, for the county in which the farm is located; by"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c46cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the payment quantity determined by multiplying—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf04c46cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of the grazed acreage on the farm with respect to which the producer elects to forgo harvesting of wheat, barley, or oats; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04c46cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf04c46ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/b/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment yield in effect for the calculation of price loss coverage under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9015"},"text":"section 9015 of this title","children":[],"tail":" with respect to that loan commodity on the farm;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf04c46cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/b/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a farm for which agriculture risk coverage is elected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9016/a"},"text":"section 9016(a) of this title","children":[],"tail":", the payment yield that would otherwise be in effect with respect to that loan commodity on the farm in the absence of such election; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf04c46d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/b/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a farm for which no payment yield is otherwise established for that loan commodity on the farm, an appropriate yield established by the Secretary in a manner consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9013/c"},"text":"section 9013(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c46d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing of triticale acreage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a payment made under this section to a producer on a farm described in subsection (a)(2) shall be equal to the amount determined by multiplying—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c46d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan deficiency payment rate determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9035/c"},"text":"section 9035(c) of this title","children":[],"tail":" in effect for wheat, as of the date of the agreement, for the county in which the farm is located; by"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c46d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the payment quantity determined by multiplying—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf04c46d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of the grazed acreage on the farm with respect to which the producer elects to forgo harvesting of triticale; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04c46d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf04c46d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment yield in effect for the calculation of price loss coverage under subchapter I with respect to wheat on the farm;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf04c46d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a farm for which agriculture risk coverage is elected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9016/a"},"text":"section 9016(a) of this title","children":[],"tail":", the payment yield that would otherwise be in effect for wheat on the farm in the absence of such election; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf04c46d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/b/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a farm for which no payment yield is otherwise established for wheat on the farm, an appropriate yield established by the Secretary in a manner consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9013/c"},"text":"section 9013(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c46d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time, manner, and availability of payment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04c46da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time and manner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A payment under this section shall be made at the same time and in the same manner as loan deficiency payments are made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9035"},"text":"section 9035 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c46db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c46dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an availability period for the payments authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c46dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain commodities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of wheat, barley, and oats, the availability period shall be consistent with the availability period for the commodity established by the Secretary for marketing assistance loans authorized by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c46de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9036/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on crop insurance indemnity or noninsured crop assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A 2014 through 2031 crop of wheat, barley, oats, or triticale planted on acreage that a producer elects, in the agreement required by subsection (a), to use for the grazing of livestock in lieu of any other harvesting of the crop shall not be eligible for an indemnity under a policy or plan of insurance authorized under the Federal Crop Insurance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"7 U.S.C. 1501","children":[],"tail":" et seq.) or noninsured crop assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7333"},"text":"section 7333 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf04c46df-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1206"},"text":"Pub. L. 113–79, title I, § 1206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/680"},"text":"128 Stat. 680","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI/s1201/c/2"},"text":"Pub. L. 115–334, title I, § 1201(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4509"},"text":"132 Stat. 4509","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10309/d/2"},"text":"Pub. L. 119–21, title I, § 10309(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/94"},"text":"139 Stat. 94","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf04c46e0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf04c46e1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf04c46e2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter I, referred to in subsec. (b)(2)(B)(ii)(I), was in the original “subtitle A”, meaning subtitle A of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/658"},"text":"128 Stat. 658","children":[],"tail":", which is classified principally to subchapter I of this chapter. For complete classification of subtitle A to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Crop Insurance Act, referred to in subsec. (d), is subtitle A of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"act Feb. 16, 1938, ch. 30","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/72"},"text":"52 Stat. 72","children":[],"tail":", which is classified generally to subchapter I (§ 1501 et seq.) of chapter 36 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"section 1501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf04c46e3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of law applicable to a loan commodity for the 2023 crop year pursuant to title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" applicable to the 2024 crop year for that loan commodity, see "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/c/1"},"text":"section 102(c)(1) of Pub. L. 118–22","children":[],"tail":", set out in an Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf04c46e4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsecs. (a), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" substituted “2031” for “2023” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsecs. (a), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “2023” for “2018” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
