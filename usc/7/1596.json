{"tag":"section","attrib":{"id":"ideed13fc6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1596"},"text":null,"children":[{"tag":"num","attrib":{"value":"1596"},"text":"§ 1596.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideed13fc7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1596/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who knowingly, or as a result either of gross negligence or of a failure to make a reasonable effort to inform himself of the pertinent facts, violates any provision of this chapter or the rules and regulations made and promulgated thereunder shall be deemed guilty of a misdemeanor and, upon conviction thereof, shall pay a fine of not more than $1,000, for the first offense, and upon conviction for each subsequent offense not more than $2,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideed13fc8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1596/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who violates any provision of this chapter or the rules and regulations made and promulgated thereunder shall forfeit to the United States a sum, not less than $25 or more than $500, for each such violation, which forfeiture shall be recoverable in a civil suit brought in the name of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideed13fc9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-09/ch615"},"text":"Aug. 9, 1939, ch. 615","children":[],"tail":", title IV, § 406, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1286"},"text":"53 Stat. 1286","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-09/ch520/s1"},"text":"July 9, 1956, ch. 520, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/508"},"text":"70 Stat. 508","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideed13fca-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideed13fcb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideed13fcc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1956—Act ","children":[{"tag":"date","attrib":{"date":"1956-07-09"},"text":"July 9, 1956","children":[],"tail":", designated existing provisions as subsec. (a), inserted “knowingly or as a result either of gross negligence or of a failure to make a reasonable effort to inform himself of the pertinent facts,” and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideed13fcd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideed13fce-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1956 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1956-07-09/ch520/s4"},"text":"Act July 9, 1956, ch. 520, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/508"},"text":"70 Stat. 508","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1956-07-09/ch520/s4"},"text":"“The amendments made by this Act [amending sections 1574, 1596, and 1602 of this title] shall be applicable only with respect to violations occurring after the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1956-07-09"},"text":"July 9, 1956","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideed13fcf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1610"},"text":"section 1610 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
