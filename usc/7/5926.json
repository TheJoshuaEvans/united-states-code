{"tag":"section","attrib":{"id":"idefd51b0e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926"},"text":null,"children":[{"tag":"num","attrib":{"value":"5926"},"text":"§ 5926.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Centers of excellence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefd51b0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding priorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prioritize centers of excellence established for purposes of carrying out research, extension, and education activities relating to the food and agricultural sciences (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3103"},"text":"section 3103 of this title","children":[],"tail":") for the receipt of funding for any competitive research or extension program administered by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd51b10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A center of excellence is composed of 1 or more of the eligible entities specified in subsection (b)(7) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3157"},"text":"section 3157 of this title","children":[],"tail":" that provide financial or in-kind support to the center of excellence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd51b11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for centers of excellence","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd51b12-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required efforts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The criteria for recognition as a center of excellence shall include efforts—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd51b13-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure coordination and cost effectiveness by reducing unnecessarily duplicative efforts regarding research, teaching, and extension;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd51b14-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to leverage available resources by using public-private partnerships among agricultural industry groups, institutions of higher education, and the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd51b15-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to implement teaching initiatives to increase awareness and effectively disseminate solutions to target audiences through extension activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd51b16-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the economic returns to rural communities by identifying, attracting, and directing funds to high-priority agricultural issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51b17-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional efforts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where practicable, the criteria for recognition as a center of excellence shall include efforts to improve teaching capacity and infrastructure at colleges and universities (including land-grant colleges and universities, cooperating forestry schools, NLGCA Institutions (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3103"},"text":"section 3103 of this title","children":[],"tail":"), and schools of veterinary medicine)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd51b18-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Centers of excellence at 1890s Institutions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd51b19-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall recognize not less than 3 centers of excellence, each led by an 1890 Institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7601"},"text":"section 7601 of this title","children":[],"tail":"), to focus on 1 or more of the areas described in paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51b1a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Areas of focus","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd51b1b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student success and workforce development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A center of excellence established under paragraph (1) may engage in activities to ensure that students have the skills and education needed to work in agriculture and food industries, agriculture science, technology, engineering, mathematics, and related fields of study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd51b1c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nutrition, health, wellness, and quality of life","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A center of excellence established under paragraph (1) may carry out research, education, and extension programs that increase access to healthy food, improve nutrition, mitigate preventive disease, and develop strategies to assist limited resource individuals in accessing health and nutrition resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd51b1d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farming systems, rural prosperity, and economic sustainability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A center of excellence established under paragraph (1) may share best practices with farmers to improve agricultural production, processing, and marketing, reduce urban food deserts, examine new uses for traditional and nontraditional crops, animals, and natural resources, and continue activities carried out by the Center for Innovative and Sustainable Small Farms, Ranches, and Forest Lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd51b1e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Global food security and defense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A center of excellence established under paragraph (1) may engage in international partnerships that strengthen agricultural development in developing countries, partner with international researchers regarding new and emerging animal and plant pests and diseases, engage in agricultural disaster recovery, and continue activities carried out by the Center for International Engagement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd51b1f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Natural resources, energy, and environment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A center of excellence established under paragraph (1) may focus on protecting and managing domestic natural resources for current and future production of food and agricultural products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd51b20-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emerging technologies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A center of excellence established under paragraph (1) may focus on the development of emerging technologies to increase agricultural productivity, enhance small farm economic viability, and improve rural communities by developing genetic and sensor technologies for food and agriculture and providing technology training to farmers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51b21-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this subsection $10,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51b22-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", and every year thereafter, the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report describing—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd51b23-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resources invested in the centers of excellence established under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd51b24-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5926/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the work being done by those centers of excellence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefd51b25-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1673"},"text":"Pub. L. 101–624, title XVI, § 1673","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7214/a"},"text":"Pub. L. 113–79, title VII, § 7214(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/886"},"text":"128 Stat. 886","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7213"},"text":"Pub. L. 115–334, title VII, § 7213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4813"},"text":"132 Stat. 4813","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefd51b26-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefd51b27-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idefd51b28-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5926, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1673"},"text":"Pub. L. 101–624, title XVI, § 1673","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3773"},"text":"104 Stat. 3773","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIV/s407/12"},"text":"Pub. L. 102–237, title IV, § 407(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1865"},"text":"105 Stat. 1865","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s837"},"text":"Pub. L. 104–127, title VIII, § 837","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1169"},"text":"110 Stat. 1169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tII/s245"},"text":"Pub. L. 105–185, title II, § 245","children":[],"tail":", title III, § 301(b)(2), "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/556"},"text":"112 Stat. 556","children":[],"tail":", 563; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7121"},"text":"Pub. L. 107–171, title VII, § 7121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/434"},"text":"116 Stat. 434","children":[],"tail":", established an agricultural telecommunications program, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7209"},"text":"Pub. L. 110–234, title VII, § 7209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1241"},"text":"122 Stat. 1241","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7209, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2003, effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefd51b29-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefd51b2a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefd51b2b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7214/b"},"text":"Pub. L. 113–79, title VII, § 7214(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/887"},"text":"128 Stat. 887","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/79/tVII/s7214/b"},"text":"“The amendments made by subsection (a) [enacting this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2014-10-01"},"text":"October 1, 2014","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
