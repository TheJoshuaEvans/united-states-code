{"tag":"section","attrib":{"id":"idef81a423-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2372"},"text":null,"children":[{"tag":"num","attrib":{"value":"2372"},"text":"§ 2372.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of plant variety protection fees; return of excess amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All fees shall be paid to the Secretary, and the Secretary may refund any sum paid by mistake or in excess of the fee required.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef81a424-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tI/s32"},"text":"Pub. L. 91–577, title I, § 32","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1545"},"text":"84 Stat. 1545","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
