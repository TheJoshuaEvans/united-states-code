{"tag":"section","attrib":{"id":"idef8ffbb7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3001"},"text":null,"children":[{"tag":"num","attrib":{"value":"3001"},"text":"§ 3001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional statement of purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the purpose of this chapter to promote, through appropriate means and on an economically sustainable basis, the development and expansion of direct marketing of agricultural commodities from farmers to consumers. To accomplish this objective, the Secretary of Agriculture (hereinafter referred to as the “Secretary”) shall initiate and coordinate a program designed to facilitate direct marketing from farmers to consumers for the mutual benefit of consumers and farmers.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef8ffbb8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/463/s2"},"text":"Pub. L. 94–463, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-08"},"text":"Oct. 8, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1982"},"text":"90 Stat. 1982","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8ffbb9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef8ffbba-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idef8ffbbb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/463/s1"},"text":"Pub. L. 94–463, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-08"},"text":"Oct. 8, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1982"},"text":"90 Stat. 1982","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/463/s1"},"text":"“That this Act [enacting this chapter and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5145"},"text":"section 5145 of Title 42","children":[],"tail":", The Public Health and Welfare] may be cited as the ‘Farmer-to-Consumer Direct Marketing Act of 1976’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
