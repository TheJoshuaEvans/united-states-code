{"tag":"section","attrib":{"id":"idef780675-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2223"},"text":null,"children":[{"tag":"num","attrib":{"value":"2223"},"text":"§ 2223.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Details of employees from and to library and bureaus and offices","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Employees of the library may be temporarily detailed by the Secretary of Agriculture for library service in the bureaus and offices of the department, and employees of the bureaus and offices of the department engaged in library work may also be temporarily detailed to the library.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef780676-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-04/ch238"},"text":"Mar. 4, 1911, ch. 238","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1261"},"text":"36 Stat. 1261","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef780677-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef780678-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef780679-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The library, referred to in text, is the library of the Department of Agriculture, known as the National Agricultural Library.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef78067a-3a6e-11f1-addd-bbaf0b3f68e9"},"tex