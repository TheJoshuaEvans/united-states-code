{"tag":"section","attrib":{"id":"idefaef510-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3502"},"text":null,"children":[{"tag":"num","attrib":{"value":"3502"},"text":"§ 3502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefaef511-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary determines that a person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefaef512-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has failed to submit a report in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3501"},"text":"section 3501 of this title","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefaef513-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has knowingly submitted a report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3501"},"text":"section 3501 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefaef514-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3502/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which does not contain all the information required to be in such report, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefaef515-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3502/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which contains information that is misleading or false,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such person shall be subject to a civil penalty imposed by the Secretary. The amount of any such civil penalty shall be determined in accordance with the provisions of subsection (b) of this section. Any such civil penalty shall be recoverable in a civil action brought by the Attorney General of the United States in an appropriate district court of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefaef516-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of any civil penalty imposed by the Secretary under subsection (a) of this section shall be such amount as the Secretary determines to be appropriate to carry out the purposes of this chapter, except that such amount shall not exceed 25 percent of the fair market value, on the date of the assessment of such penalty, of the interest in agricultural land with respect to which such violation occurred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefaef517-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/460/s3"},"text":"Pub. L. 95–460, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-14"},"text":"Oct. 14, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1265"},"text":"92 Stat. 1265","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
