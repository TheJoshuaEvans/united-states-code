{"tag":"section","attrib":{"id":"idf0026c71-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7284"},"text":null,"children":[{"tag":"num","attrib":{"value":"7284"},"text":"§ 7284.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal liability of producers for deficiencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0026c72-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7284/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), no producer shall be personally liable for any deficiency arising from the sale of the collateral securing any nonrecourse loan made under this chapter ","children":[{"tag":"ref","attrib":{"idref":"fn002334"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002334"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" title I of the Farm Security and Rural Investment Act of 2002 ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7901"},"text":"7 U.S.C. 7901","children":[],"tail":" et seq.], title I of the Food, Conservation, and Energy Act of 2008 ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"7 U.S.C. 8701","children":[],"tail":" et seq.], and title I of the Agricultural Act of 2014 ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"7 U.S.C. 9001","children":[],"tail":" et seq.] unless the loan was obtained through a fraudulent representation by the producer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0026c73-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7284/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not prevent the Commodity Credit Corporation or the Secretary from requiring a producer to assume liability for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0026c74-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7284/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a deficiency in the grade, quality, or quantity of a commodity stored on a farm or delivered by the producer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0026c75-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7284/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a failure to properly care for and preserve a commodity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0026c76-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7284/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a failure or refusal to deliver a commodity in accordance with a program established under this chapter ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" title I of the Farm Security and Rural Investment Act of 2002 ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7901"},"text":"7 U.S.C. 7901","children":[],"tail":" et seq.], title I of the Food, Conservation, and Energy Act of 2008 ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"7 U.S.C. 8701","children":[],"tail":" et seq.], and title I of the Agricultural Act of 2014 ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"7 U.S.C. 9001","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0026c77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7284/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of collateral","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a nonrecourse loan made under this chapter ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" title I of the Farm Security and Rural Investment Act of 2002 ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7901"},"text":"7 U.S.C. 7901","children":[],"tail":" et seq.], title I of the Food, Conservation, and Energy Act of 2008 ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"7 U.S.C. 8701","children":[],"tail":" et seq.], and title I of the Agricultural Act of 2014 ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"7 U.S.C. 9001","children":[],"tail":" et seq.] or the Commodity Credit Corporation Charter Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s714"},"text":"15 U.S.C. 714","children":[],"tail":" et seq.), if the Commodity Credit Corporation acquires title to the unredeemed collateral, the Corporation shall be under no obligation to pay for any market value that the collateral may have in excess of the loan indebtedness."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0026c78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7284/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sugarcane and sugar beets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A security interest obtained by the Commodity Credit Corporation as a result of the execution of a security agreement by the processor of sugarcane or sugar beets shall be superior to all statutory and common law liens on raw cane sugar and refined beet sugar in favor of the producers of sugarcane and sugar beets and all prior recorded and unrecorded liens on the crops of sugarcane and sugar beets from which the sugar was derived.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0026c79-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s164"},"text":"Pub. L. 104–127, title I, § 164","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/935"},"text":"110 Stat. 935","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1607"},"text":"Pub. L. 107–171, title I, § 1607","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/218"},"text":"116 Stat. 218","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1606"},"text":"Pub. L. 110–234, title I, § 1606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1017"},"text":"122 Stat. 1017","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1606, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1746; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1607"},"text":"Pub. L. 113–79, title I, § 1607","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/708"},"text":"128 Stat. 708","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0026c7a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0026c7b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf0026c7c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of “this chapter”, referred to in text, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7201"},"text":"section 7201 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Farm Security and Rural Investment Act of 2002, referred to in subsecs. (a), (b)(3), and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/134"},"text":"116 Stat. 134","children":[],"tail":". Title I of the Act is classified principally to chapter 106 (§ 7901 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7901"},"text":"section 7901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Food, Conservation, and Energy Act of 2008, referred to in subsecs. (a), (b)(3), and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1651"},"text":"122 Stat. 1651","children":[],"tail":". Title I of the Act is classified principally to chapter 113 (§ 8701 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Agricultural Act of 2014, referred to in subsecs. (a), (b)(3), and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/649"},"text":"128 Stat. 649","children":[],"tail":". Title I of the Act is classified principally to chapter 115 (§ 9001 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Commodity Credit Corporation Charter Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-29/ch704"},"text":"act June 29, 1948, ch. 704","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/1070"},"text":"62 Stat. 1070","children":[],"tail":", which is classified generally to subchapter II (§ 714 et seq.) of chapter 15 of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s714"},"text":"section 714 of title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf0026c7d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf0026c7e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsecs. (a), (b)(3), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" substituted “title I of the Food, Conservation, and Energy Act of 2008, and title I of the Agricultural Act of 2014” for “and title I of the Food, Conservation, and Energy Act of 2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsecs. (a), (b)(3), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1606"},"text":"Pub. L. 110–246, § 1606","children":[],"tail":", substituted “title I of the Farm Security and Rural Investment Act of 2002, and title I of the Food, Conservation, and Energy Act of 2008” for “and title I of the Farm Security and Rural Investment Act of 2002”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsecs. (a), (b)(3), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" substituted “this chapter and title I of the Farm Security and Rural Investment Act of 2002” for “this chapter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf00