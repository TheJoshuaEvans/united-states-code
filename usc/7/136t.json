{"tag":"section","attrib":{"id":"idee08e5ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136t"},"text":null,"children":[{"tag":"num","attrib":{"value":"136t"},"text":"§ 136t.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation and cooperation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee08e5ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136t/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All authority vested in the Administrator by virtue of the provisions of this subchapter may with like force and effect be executed by such employees of the Environmental Protection Agency as the Administrator may designate for the purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee08e5ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136t/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall cooperate with Department of Agriculture, any other Federal agency, and any appropriate agency of any State or any political subdivision thereof, in carrying out the provisions of this subchapter, and in securing uniformity of regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee08e5af-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-25/ch125/s22"},"text":"June 25, 1947, ch. 125, § 22","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/516/s2"},"text":"Pub. L. 92–516, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/996"},"text":"86 Stat. 996","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee08e5b0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee08e5b1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idee08e5b2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/516/s4"},"text":"section 4 of Pub. L. 92–516","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136"},"text":"section 136 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
