{"tag":"section","attrib":{"id":"idf036e938-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8308a"},"text":"§ 8308a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Animal disease prevention and management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf036e939-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Animal Health Laboratory Network","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf036e93a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible laboratory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “eligible laboratory” means a diagnostic laboratory that meets specific criteria developed by the Secretary, in consultation with State animal health officials, State veterinary diagnostic laboratories, and veterinary diagnostic laboratories at institutions of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e93b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with State veterinarians, shall offer to enter into contracts, grants, cooperative agreements, or other legal instruments with eligible laboratories for any of the following purposes:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf036e93c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To enhance the capability of the Secretary to respond in a timely manner to emerging or existing bioterrorist threats to animal health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e93d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To provide the capacity and capability for standardized—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf036e93e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" test procedures, reference materials, and equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf036e93f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" laboratory biosafety and biosecurity levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf036e940-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quality management system requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf036e941-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interconnected electronic reporting and transmission of data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf036e942-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/a/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluation for emergency preparedness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e943-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To coordinate the development, implementation, and enhancement of national veterinary diagnostic laboratory capabilities, with special emphasis on surveillance planning and vulnerability analysis, technology development and validation, training, and outreach.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e944-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable and to the extent capacity and specialized expertise may be necessary, the Secretary shall give priority to existing Federal facilities, State facilities, and facilities at institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf036e945-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Animal Disease Preparedness and Response Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf036e946-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program, to be known as the National Animal Disease Preparedness and Response Program (referred to in this section as “the Program”), to address the increasing risk of the introduction and spread within the United States of animal pests and diseases affecting the economic interests of the livestock and related industries of the United States, including the maintenance and expansion of export markets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e947-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities under the Program shall include, to the extent practicable, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf036e948-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enhancing animal pest and disease analysis and surveillance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e949-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expanding outreach and education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e94a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Targeting domestic inspection activities at vulnerable points in the safeguarding continuum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e94b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enhancing and strengthening threat identification technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e94c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improving biosecurity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e94d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enhancing emergency preparedness and response capabilities, including training additional emergency response personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e94e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conducting technology development to enhance electronic sharing of animal health data for risk analysis between State and Federal animal health officials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e94f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Enhancing the development and effectiveness of animal health technologies to treat and prevent animal disease, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf036e950-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/2/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterinary biologics and diagnostics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf036e951-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/2/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" animal drugs for minor uses and minor species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf036e952-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/2/H/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" animal medical devices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf036e953-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/2/H/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emerging veterinary countermeasures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e954-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other activities as determined appropriate by the Secretary, in consultation with eligible entities specified in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e955-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out the Program, the Secretary shall offer to enter into cooperative agreements or other legal instruments, as authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8312"},"text":"section 8312 of this title","children":[],"tail":" (referred to in this section as “agreements”) with eligible entities, to be selected by the Secretary, which may include any of the following entities, either individually or in combination:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf036e956-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State department of agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e957-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The office of the chief animal health official of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e958-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An entity eligible to receive funds under a capacity and infrastructure program (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6971/f/1/C"},"text":"section 6971(f)(1)(C) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e959-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A college of veterinary medicine, including a veterinary emergency team at such college.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e95a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State or national livestock producer organization with direct and significant economic interest in livestock production.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e95b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State emergency agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e95c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State, national, allied, or regional veterinary organization or specialty board recognized by the American Veterinary Medical Association.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e95d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e95e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e95f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special funding considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In entering into agreements under this subsection, the Secretary shall give priority to applications submitted by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf036e960-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State department of agriculture or an office of the chief animal health official of a State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e961-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an eligible entity that will carry out program activities in a State or region in which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf036e962-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an animal pest or disease is a Federal concern; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf036e963-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary determines a potential exists for the spread of an animal pest or disease after taking into consideration—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf036e964-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agricultural industries in the State or region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf036e965-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" factors contributing to animal pest or disease in the State or region, such as the climate, natural resources, and geography of, and native and exotic wildlife species and other disease vectors in, the State or region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf036e966-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/4/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the movement of animals in the State or region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e967-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of setting priorities under this subsection, the Secretary shall consult with eligible entities specified in paragraph (3). The Federal Advisory Committee Act (5 U.S.C. App.) ","children":[{"tag":"ref","attrib":{"idref":"fn002362"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002362"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall not apply to consultation carried out under this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e968-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf036e969-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity specified in paragraph (3) seeking to enter into an agreement under the Program shall submit to the Secretary an application containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e96a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall notify each applicant of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf036e96b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements to be imposed on the eligible entity that is the recipient of funds under the Program for auditing of, and reporting on, the use of such funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf036e96c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the criteria to be used to ensure activities supported using such funds are based on sound scientific data or thorough risk assessments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e96d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal contributions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When deciding whether to enter into an agreement under the Program with an eligible entity described in paragraph (3), the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf036e96e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/6/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may take into consideration an eligible entity’s ability to contribute non-Federal funds to carry out such an agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf036e96f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/6/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not require such an eligible entity to make such a contribution as a condition to enter into an agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e970-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf036e971-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use consistent with terms of cooperative agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The recipient of funds under the Program shall use the funds for the purposes and in the manner provided in the agreement under which the funds are provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e972-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sub-agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section prevents an eligible entity from using funds received under the Program to enter into sub-agreements with another eligible entity or with a political subdivision of a State that has legal responsibilities relating to animal disease prevention, surveillance, or rapid response.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e973-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the date of completion of an activity conducted using funds provided under the Program, the recipient of such funds shall submit to the Secretary a report that describes the purposes and results of the activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf036e974-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Animal Vaccine Bank","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf036e975-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a national animal vaccine and veterinary countermeasures bank (to be known as the National Animal Vaccine and Veterinary Countermeasures Bank and referred to in this subsection as the “Vaccine Bank”) to benefit the domestic interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e976-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements of Vaccine Bank","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Through the Vaccine Bank, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf036e977-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain sufficient quantities of veterinary countermeasures to appropriately and rapidly respond to the most damaging animal diseases affecting or with potential to affect human health or the economy of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e978-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage, when appropriate, the mechanisms and infrastructure that have been developed for the management, storage, and distribution of the National Veterinary Stockpile.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e979-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority for response to foot and mouth disease","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prioritize the acquisition and maintenance of sufficient quantities of foot and mouth disease vaccine and accompanying diagnostic products for the Vaccine Bank. As part of such prioritization, the Secretary may offer to enter into one or more contracts with one or more entities that are capable of producing foot and mouth disease vaccine and that have surge production capacity of the vaccine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf036e97a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf036e97b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf036e97c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal years 2019 through 2022","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds of the Commodity Credit Corporation, the Secretary shall make available to carry out this section $120,000,000 for the period of fiscal years 2019 through 2022, of which not less than $5,000,000 shall be made available for each of those fiscal years to carry out subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e97d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal years 2023 through 2025","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds of the Commodity Credit Corporation, the Secretary shall make available to carry out this section $30,000,000 for each of fiscal years 2023 through 2025, of which not less than $18,000,000 shall be made available for each of those fiscal years to carry out subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e97e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal years 2026 through 2030","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds of the Commodity Credit Corporation, the Secretary shall make available to carry out this section $233,000,000 for each of fiscal years 2026 through 2030, of which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf036e97f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $10,000,000 shall be made available for each such fiscal year to carry out subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf036e980-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $70,000,000 shall be made available for each such fiscal year to carry out subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf036e981-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/d/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $153,000,000 shall be made available for each such fiscal year to carry out subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e982-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent fiscal years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds of the Commodity Credit Corporation, the Secretary shall make available to carry out this section $75,000,000 for fiscal year 2031 and each fiscal year thereafter, of which not less than $45,000,000 shall be made available for each of those fiscal years to carry out subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e983-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf036e984-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National animal health laboratory network","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the funds made available under paragraph (1), there is authorized to be appropriated $30,000,000 for each of fiscal years 2019 through 2023 to carry out subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e985-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Animal Disease Preparedness and Response Program; National Animal Vaccine and Veterinary Countermeasures Bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the funds made available under paragraph (1), there is authorized to be appropriated such sums as are necessary for each of fiscal years 2019 through 2023 to carry out subsections (b) and (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e986-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additionality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The funds authorized for appropriation under this paragraph are in addition to any funds authorized or otherwise made available under this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8316"},"text":"section 8316 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e987-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf036e988-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds made available under this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8316"},"text":"section 8316 of this title","children":[],"tail":" to carry out the National Animal Health Laboratory Network under subsection (a) and the National Animal Disease Preparedness and Response Program under subsection (b), not more than 4 percent may be retained by the Secretary to pay administrative costs incurred by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e989-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds made available under this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8316"},"text":"section 8316 of this title","children":[],"tail":" to carry out the National Animal Disease Preparedness and Response Program under subsection (b), not more than 10 percent may be retained by an eligible entity that receives funds under any agreement entered into under such subsection, including any sub-agreement under paragraph (7)(B) of such subsection to pay administrative costs incurred by the eligible entity to carry out activities under the Program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e98a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under this subsection, including any proceeds credited under paragraph (5), shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e98b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proceeds from veterinary countermeasures sales","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any proceeds of a sale of veterinary countermeasures from the Vaccine Bank shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf036e98c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposited into the Treasury of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e98d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" credited to the account for the operation of the Vaccine Bank to be made available for expenditure without further appropriation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e98e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on use of funds for certain purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under the National Animal Health Laboratory Network, the National Animal Disease Preparedness and Response Program, and the Vaccine Bank shall not be used for the construction of a new building or facility or the acquisition or expansion of an existing building or facility, including site grading and improvement and architect fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf036e98f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability and purpose of funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf036e990-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Using the funds made available under subsection (d), the Secretary of Agriculture shall offer to enter into contracts, grants, cooperative agreements, or other legal instruments under subsections (a) through (c) during each of the fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e991-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8308a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraph (1) shall be construed to terminate a contract, grant, cooperative agreement, or other legal instrument entered into during the period specified in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf036e992-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10409A"},"text":"Pub. L. 107–171, title X, § 10409A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tXII/s12105"},"text":"Pub. L. 113–79, title XII, § 12105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/980"},"text":"128 Stat. 980","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12101/b"},"text":"Pub. L. 115–334, title XII, § 12101(b)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4937-4940"},"text":"132 Stat. 4937–4940","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10607/a"},"text":"Pub. L. 119–21, title I, § 10607(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/110"},"text":"139 Stat. 110","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf036e993-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf036e994-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf036e995-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Advisory Committee Act, referred to in subsec. (b)(5), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/463"},"text":"Pub. L. 92–463","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-06"},"text":"Oct. 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/770"},"text":"86 Stat. 770","children":[],"tail":", which was set out in the Appendix to Title 5, Government Organization and Employees, and was substantially repealed and restated in chapter 10 (§ 1001 et seq.) of Title 5 by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(a), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4197"},"text":"136 Stat. 4197","children":[],"tail":", 4361. For disposition of sections of the Act into chapter 10 of Title 5, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf036e996-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10607/a/1"},"text":"Pub. L. 119–21, § 10607(a)(1)","children":[],"tail":", substituted “Fiscal years 2023 through 2025” for “Subsequent fiscal years” in heading and “each of fiscal years 2023 through 2025” for “fiscal year 2023 and each fiscal year thereafter” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10607/a/2"},"text":"Pub. L. 119–21, § 10607(a)(2)","children":[],"tail":", added subpars. (C) and (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12101/b/1"},"text":"Pub. L. 115–334, § 12101(b)(1)","children":[],"tail":", substituted “Animal disease prevention and management” for “National animal health laboratory network” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12101/b/2"},"text":"Pub. L. 115–334, § 12101(b)(2)","children":[],"tail":", (4), substituted “National Animal Health Laboratory Network” for “Definition of eligible laboratory” in heading, inserted par. (1) designation and heading and substituted “In this subsection,” for “In this section,”, redesignated subsecs. (b) and (c) as pars. (2) and (3), respectively, and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12101/b/3/B"},"text":"Pub. L. 115–334, § 12101(b)(3)(B)","children":[],"tail":", redesignated pars. (1) to (3) of former subsec. (b) as subpars. (A) to (C), respectively, and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12101/b/3/A"},"text":"Pub. L. 115–334, § 12101(b)(3)(A)","children":[],"tail":", redesignated subpars. (A) to (E) of former subsec. (b)(2) as cls. (i) to (v), respectively, and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12101/b/5"},"text":"Pub. L. 115–334, § 12101(b)(5)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (a)(2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12101/c"},"text":"Pub. L. 115–334, § 12101(c)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (a)(3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12101/d"},"text":"Pub. L. 115–334, § 12101(d)","children":[],"tail":", added subsecs. (d) and (e) and struck out former subsec. (d) which authorized to be appropriated to carry out this section $15,000,000 for each of fiscal years 2014 through 2018."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
