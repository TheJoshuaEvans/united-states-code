{"tag":"section","attrib":{"id":"idefdc4786-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6109"},"text":null,"children":[{"tag":"num","attrib":{"value":"6109"},"text":"§ 6109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter may be construed to preempt or supersede any other program relating to mushroom promotion, research, consumer information, or industry information organized and operated under the laws of the United States or any State.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefdc4787-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1930"},"text":"Pub. L. 101–624, title XIX, § 1930","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3865"},"text":"104 Stat. 3865","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
