{"tag":"section","attrib":{"id":"ideea8a89b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1444e–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1444e–1"},"text":"§ 1444e–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans and purchases for 1986 through 1996 crops of corn","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideea8a89c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1444e–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of law, effective only for each of the 1986 through 1996 crops of feed grains, the Secretary of Agriculture may make available loans and purchases, as provided in this section, to producers on a farm who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideea8a89d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1444e–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for silage—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideea8a89e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1444e–1/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cut corn (including mutilated corn) that the producers have produced in such crop year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideea8a89f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1444e–1/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase or exchange corn (including mutilated corn) that has been produced in such crop year by another producer (including a producer that is not participating in an acreage limitation or set-aside program for such crop established by the Secretary); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideea8a8a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1444e–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in an acreage limitation or set-aside program for such crop of corn established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideea8a8a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1444e–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such loans and purchases may be made on a quantity of corn of the same crop, other than the corn obtained for silage, acquired by the producer equivalent to a quantity determined by multiplying—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideea8a8a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1444e–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acreage of corn obtained for silage; by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideea8a8a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1444e–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lower of the farm program payment yield or the actual yield on a field, as determined by the Secretary, that is similar to the field from which such silage was obtained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideea8a8a4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tIV/s403"},"text":"Pub. L. 99–198, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1406"},"text":"99 Stat. 1406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tIV/s403"},"text":"Pub. L. 101–624, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3419"},"text":"104 Stat. 3419","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideea8a8a5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideea8a8a6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideea8a8a7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food Security Act of 1985, and not as part of the Agricultural Act of 1949 which is classified principally to this chapter. For complete classification of the 1949 Act to the Code, see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideea8a8a8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" substituted “1996” for “1990” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideea8a8a9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideea8a8aa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" effective beginning with 1991 crop of an agricultural commodity, with provision for prior crops, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1171"},"text":"section 1171 of Pub. L. 101–624","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
