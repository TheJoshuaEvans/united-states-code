{"tag":"section","attrib":{"id":"idf0026bf5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7258"},"text":null,"children":[{"tag":"num","attrib":{"value":"7258"},"text":"§ 7258.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standby authority to indicate entity best suited to provide international market development and export services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0026bf6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7258/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indication of entity best suited to assist international market development for and export of United States dairy products","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture shall indicate which entity or entities autonomous of the Government of the United States, which seeks such a designation, is best suited to facilitate the international market development for and exportation of United States dairy products, if the Secretary determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0026bf7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7258/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States dairy industry has not established an export trading company under the Export Trading Company Act of 1982 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4001"},"text":"15 U.S.C. 4001","children":[],"tail":" et seq.) for the purpose of facilitating the international market development for an exportation of dairy products produced in the United States on or before "},{"tag":"date","attrib":{"date":"1997-06-30"},"text":"June 30, 1997","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0026bf8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7258/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of exports of United States dairy products during the 12-month period preceding ","children":[{"tag":"date","attrib":{"date":"1998-07-01"},"text":"July 1, 1998","children":[],"tail":" does not exceed the quantity of exports of United States dairy products during the 12-month period preceding "},{"tag":"date","attrib":{"date":"1997-07-01"},"text":"July 1, 1997","children":[],"tail":" by 1.5 billion pounds (milk equivalent, total solids basis)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0026bf9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7258/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding of export activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall assist the entity or entities identified under subsection (a) in identifying sources of funding for the activities specified in subsection (a) from within the dairy industry and elsewhere.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0026bfa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7258/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply only during the period beginning on ","children":[{"tag":"date","attrib":{"date":"1997-07-01"},"text":"July 1, 1997","children":[],"tail":" and ending on "},{"tag":"date","attrib":{"date":"2000-09-30"},"text":"September 30, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0026bfb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s150"},"text":"Pub. L. 104–127, title I, § 150","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/921"},"text":"110 Stat. 921","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0026bfc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0026bfd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf0026bfe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Export Trading Company Act of 1982, referred to in subsec. (a)(1), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/290"},"text":"Pub. L. 97–290","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-08"},"text":"Oct. 8, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1233"},"text":"96 Stat. 1233","children":[],"tail":", which is classified generally to subchapter I (§ 4001 et seq.) of chapter 66 of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4001"},"text":"section 4001 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
