{"tag":"section","attrib":{"id":"idee2324e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s251"},"text":null,"children":[{"tag":"num","attrib":{"value":"251"},"text":"§ 251.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for delivery of agricultural products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee2324e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s251/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prompt delivery","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the absence of a lawful excuse, a warehouse operator shall, without unnecessary delay, deliver the agricultural product stored or handled in the warehouse on a demand made by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee2324ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s251/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the holder of the receipt for the agricultural product; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee2324eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s251/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person that deposited the product, if no receipt has been issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee2324ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s251/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment to accompany demand","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to delivery of the agricultural product, payment of the accrued charges associated with the storage of the agricultural product, including satisfaction of the warehouseman’s lien, shall be made if requested by the warehouse operator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee2324ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s251/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surrender of receipt","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When the holder of a receipt requests delivery of an agricultural product covered by the receipt, the holder shall surrender the receipt to the warehouse operator, in the manner prescribed by the Secretary, to obtain the agricultural product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee2324ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s251/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cancellation of receipt","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A warehouse operator shall cancel each receipt returned to the warehouse operator upon the delivery of the agricultural product for which the receipt was issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee2324ef-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, § 12, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/472/tII/s201"},"text":"Pub. L. 106–472, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2067"},"text":"114 Stat. 2067","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee2324f0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee2324f1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee2324f2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 251, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, § 10, "},{"tag":"ref","attrib":{"href":"/us/stat/39/487"},"text":"39 Stat. 487","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1931-03-02/ch366/s5"},"text":"Mar. 2, 1931, ch. 366, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/1464"},"text":"46 Stat. 1464","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tI/s158/a/1"},"text":"Pub. L. 97–35, title I, § 158(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/375"},"text":"95 Stat. 375","children":[],"tail":", authorized fee for warehouse examination, inspection, and licensing, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/472"},"text":"Pub. L. 106–472","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s243"},"text":"section 243 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 12 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"act Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s253"},"text":"section 253 of this title","children":[],"tail":", prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/472"},"text":"Pub. L. 106–472","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
