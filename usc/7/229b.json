{"tag":"section","attrib":{"id":"idee20b435-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s229b"},"text":null,"children":[{"tag":"num","attrib":{"value":"229b"},"text":"§ 229b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to discuss terms of contract","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee20b436-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s229b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee20b437-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s229b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “producer” means any person engaged in the raising and caring for livestock or poultry for slaughter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee20b438-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s229b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Processor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “processor” means any person engaged in the business of obtaining livestock or poultry for the purpose of slaughtering the livestock or poultry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee20b439-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s229b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No prohibition of discussion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding a provision in any contract between a producer and a processor for the production of livestock or poultry, or in any marketing agreement between a producer and a processor for the sale of livestock or poultry for a term of 1 year or more, that provides that information contained in the contract is confidential, a party to the contract shall not be prohibited from discussing any terms or details of the contract with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee20b43a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s229b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal or State agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee20b43b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s229b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a legal adviser to the party;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee20b43c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s229b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lender to the party;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee20b43d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s229b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an accountant hired by the party;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee20b43e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s229b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an executive or manager of the party;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee20b43f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s229b/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a landlord of the party; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee20b440-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s229b/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the immediate family of the party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee20b441-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s229b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on State laws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (b) does not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee20b442-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s229b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preempt any State law that addresses confidentiality provisions in contracts for the sale or production of livestock or poultry, except any provision of State law that makes lawful a contract provision that prohibits a party from, or limits a party in, engaging in discussion that subsection (b) requires to be permitted; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee20b443-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s229b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deprive any State court of jurisdiction under any such State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee20b444-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s229b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section applies to each contract described in subsection (b) that is entered into, amended, renewed, or extended after ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee20b445-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10503"},"text":"Pub. L. 107–171, title X, § 10503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/510"},"text":"116 Stat. 510","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee20b446-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee20b447-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee20b448-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Farm Security and Rural Investment Act of 2002, and not as part of the Packers and Stockyards Act, 1921, which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
