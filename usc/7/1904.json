{"tag":"section","attrib":{"id":"idef00da84-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1904"},"text":null,"children":[{"tag":"num","attrib":{"value":"1904"},"text":"§ 1904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methods research; designation of methods","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In furtherance of the policy expressed herein the Secretary is authorized and directed—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef00da85-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct, assist, and foster research, investigation, and experimentation to develop and determine methods of slaughter and the handling of livestock in connection with slaughter which are practicable with reference to the speed and scope of slaughtering operations and humane with reference to other existing methods and then current scientific knowledge; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef00da86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on or before ","children":[{"tag":"date","attrib":{"date":"1959-03-01"},"text":"March 1, 1959","children":[],"tail":", and at such times thereafter as he deems advisable, to designate methods of slaughter and of handling in connection with slaughter which, with respect to each species of livestock, conform to the policy stated in this chapter. If he deems it more effective, the Secretary may make any such designation by designating methods which are not in conformity with such policy. Designations by the Secretary subsequent to "},{"tag":"date","attrib":{"date":"1959-03-01"},"text":"March 1, 1959","children":[],"tail":", shall become effective 180 days after their publication in the Federal Register."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef00da87-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/765/s4"},"text":"Pub. L. 85–765, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-27"},"text":"Aug. 27, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/863"},"text":"72 Stat. 863","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/445/s5/b"},"text":"Pub. L. 95–445, § 5(b)","children":[],"tail":"–(e), "},{"tag":"date","attrib":{"date":"1978-10-10"},"text":"Oct. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1069"},"text":"92 Stat. 1069","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef00da88-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef00da89-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef00da8a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Par. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/445/s5/d"},"text":"Pub. L. 95–445, § 5(d)","children":[],"tail":", inserted “and” after the semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/445/s5/c"},"text":"Pub. L. 95–445, § 5(c)","children":[],"tail":", (e), struck out “for purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1903"},"text":"section 1903 of this title","children":[],"tail":"” before “180 days”, and substituted a period for the semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/445/s5/b"},"text":"Pub. L. 95–445, § 5(b)","children":[],"tail":", repealed par. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef00da8b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef00da8c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/445"},"text":"Pub. L. 95–445","children":[],"tail":" effective one year after "},{"tag":"date","attrib":{"date":"1978-10-10"},"text":"Oct. 10, 1978","children":[],"tail":", and nonapplicability during not to exceed additional 18 months in hardship cases, see sec. 7 of "},{"tag":"ref","attrib":{"href":"/us/pl/95/445"},"text":"Pub. L. 95–445","children":[],"tail":" set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s603"},"text":"section 603 of Title 21","children":[],"tail":", Food and Drugs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
