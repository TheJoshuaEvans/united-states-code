{"tag":"section","attrib":{"id":"idefd9d64b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007"},"text":null,"children":[{"tag":"num","attrib":{"value":"6007"},"text":"§ 6007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefd9d64c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the effective period of a plan issued pursuant to this chapter, assessments shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd9d64d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" levied on all pecans produced in, and all pecans imported into, the United States and marketed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d64e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deducted from the payment made to a grower for all pecans sold to a first handler.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd9d64f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No more than one assessment may be assessed under subsection (a) on a grower (as remitted by a first handler), grower-sheller, or importer, for any lot of pecans handled or imported.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd9d650-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remitting assessments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd9d651-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assessments required under subsection (a) shall be remitted to the Board by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd9d652-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a first handler; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd9d653-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an importer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d654-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Times to remit assessment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd9d655-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First handlers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each first handler who is not a grower-sheller and who is required to remit an assessment under paragraph (1) shall remit such assessment to the Board no later than the last day of the month following the month that the pecans being assessed were purchased or marketed by such first handler.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd9d656-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grower-shellers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each first handler who is a grower-sheller and who is required to remit an assessment under paragraph (1) shall remit such assessment to the Board, to the extent practicable, in payments of one-third of the total annual amount of such assessment due to the Board on January 31, March 31, and May 10, or such dates as may be recommended by the Board and approved by the Secretary, during the fiscal year that the pecans being assessed were harvested.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd9d657-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Importers of pecans into the United States shall pay the assessment at the time the pecans enter the United States and shall remit such assessment to the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd9d658-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment rate","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd9d659-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), assessment rates shall be recommended by the Board and approved by the Secretary, except that the maximum assessment shall not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd9d65a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the period commencing on the effective date of the issuance of a plan and ending on the date the referendum is conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6011/a"},"text":"section 6011(a) of this title","children":[],"tail":", one-half cent per pound for in-shell pecans as determined by the Board and approved by the Secretary; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd9d65b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after such period, 2 cents per pound for in-shell pecans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d65c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjusting rate for shelled pecans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rate of assessment of shelled pecans shall be twice the rate established for in-shell pecans pursuant to paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d65d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special State assessment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd9d65e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, with the approval of the Secretary and if authorized by State law and requested by such State, a special assessment of one-quarter cent per pound for in-shell pecans, and an appropriate per-pound assessment for shelled pecans as adjusted under paragraph (2), shall be remitted to the Board for the purpose of utilizing such funds by a State pecan marketing board for research projects to promote pecans pursuant to State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd9d65f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection and remittance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall collect such assessments and upon receipt of such assessments shall remit such assessments to the State, within a time period mutually agreed upon between the State and the Board, and approved by the Secretary. In the collection of such State assessments, neither the Board nor the Secretary shall in any manner enforce the collection or remittance of any such payment by producers of such State assessments or investigate nonpayment of such State assessments, except to provide to a State the names of growers from whom such assessments were collected and the respective amounts of assessments collected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd9d660-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make such regulations as may be necessary to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd9d661-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Late-payment charge","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd9d662-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be a late-payment charge imposed on any person who fails to remit, on or before the due date established by the Board under subsection (c)(2), to the Board the total amount for which such person is liable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d663-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of charge","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the late-payment charge imposed under paragraph (1) shall be prescribed by the Board with the approval of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd9d664-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refund of assessments from escrow account","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd9d665-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of escrow account","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the period beginning on the effective date of a plan first issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6003"},"text":"section 6003 of this title","children":[],"tail":" and ending on the date the referendum is conducted under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6011/a"},"text":"section 6011(a) of this title","children":[],"tail":", the Board shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd9d666-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish an escrow account to be used for assessment refunds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd9d667-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" place funds in such account in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d668-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Placement of funds in account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall place in such account, from assessments collected during the period referred to in paragraph (1), an amount equal to the product obtained by multiplying the total amount of assessments collected during such period by 10 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d669-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to receive refund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraphs (4), (5), and (6), any grower, grower-sheller, or importer shall have the right to demand and receive from the Board a one-time refund of assessments paid by or on behalf of such grower, grower-sheller, or importer during the period referred to in paragraph (1) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd9d66a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such grower, grower-sheller, or importer is required to pay such assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd9d66b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such grower, grower-sheller, or importer does not support the program established under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd9d66c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such grower, grower-sheller, or importer demands such refund prior to the conduct of the referendum under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6011/a"},"text":"section 6011(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd9d66d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/f/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan is not approved pursuant to the referendum conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6011/a"},"text":"section 6011(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d66e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of demand","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such demand shall be made in accordance with regulations, on a form, and within a time period prescribed by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d66f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Making of refund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such refund shall be made on submission of proof satisfactory to the Board that such grower, grower-sheller, or importer paid the assessment for which refund is demanded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d670-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd9d671-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/f/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount in the escrow account required by paragraph (1) is not sufficient to refund the total amount of assessments demanded by eligible growers, grower-shellers, or importers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd9d672-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/f/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan is not approved pursuant to the referendum conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6011/a"},"text":"section 6011(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Board shall prorate the amount of such refunds among all eligible growers, grower-shellers, and importers who demand such refund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d673-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6007/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program approved","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the plan is approved pursuant to the referendum conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6011/a"},"text":"section 6011(a) of this title","children":[],"tail":", all funds in the escrow account shall be returned to the Board for use by the Board in accordance with this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefd9d674-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1912"},"text":"Pub. L. 101–624, title XIX, § 1912","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3848"},"text":"104 Stat. 3848","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
