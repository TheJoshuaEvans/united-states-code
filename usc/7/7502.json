{"tag":"section","attrib":{"id":"idf00e53e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7502"},"text":null,"children":[{"tag":"num","attrib":{"value":"7502"},"text":"§ 7502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of CCC commodities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf00e53e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, in order to complement the domestic nutrition programs, make maximum use of the Nation’s agricultural abundance, and expand and improve the domestic distribution of price-supported commodities, commodities acquired by the Commodity Credit Corporation that the Secretary of Agriculture (hereinafter referred to as the “Secretary”) determines, in his discretion, are in excess of quantities needed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00e53e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out other domestic donation programs,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet other domestic obligations (including quantities needed to carry out a payment-in-kind acreage diversion program),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7502/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet international market development and food aid commitments, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7502/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out the farm price and income stabilization purposes of the Agricultural Adjustment Act of 1938 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1281"},"text":"7 U.S.C. 1281","children":[],"tail":" et seq.], the Agricultural Act of 1949 ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"7 U.S.C. 1421","children":[],"tail":" et seq.], and the Commodity Credit Corporation Charter Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s714"},"text":"15 U.S.C. 714","children":[],"tail":" et seq.],"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be made available by the Secretary, without charge or credit for such commodities, for use by eligible recipient agencies for food assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e53ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXV/s1565/a/2"},"text":"Pub. L. 99–198, title XV, § 1565(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1591"},"text":"99 Stat. 1591","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e53ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional commodities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any commodities described in subsection (a), in carrying out this chapter, the Secretary may use agricultural commodities and the products thereof made available under clause (2) of the second sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s612c"},"text":"section 612c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e53ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Varieties of commodities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Commodities made available under this chapter shall include a variety of commodities and products thereof that are most useful to eligible recipient agencies, including, but not be ","children":[{"tag":"ref","attrib":{"idref":"fn002340"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002340"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “be” probably should not appear."}],"tail":" limited to, dairy products, wheat or the products thereof, rice, honey, and cornmeal."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e53f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7502/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"1986-04-01"},"text":"April 1, 1986","children":[],"tail":", the Secretary shall submit semiannually to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report on the types and amounts of commodities made available for distribution under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e53f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7502/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the programs authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s713a–14"},"text":"section 713a–14 of title 15","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002341"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002341"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" and section 1163 of the Food Security Act of 1985 shall not be operated in a manner that will, in any way, reduce the quantities of dairy products that traditionally are made available to carry out this chapter or any other domestic feeding program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e53f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7502/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donations to emergency feeding organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00e53f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7502/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever commodities acquired by the Commodity Credit Corporation are made available for donation to domestic food programs in quantities that exceed Federal obligations, the Secretary shall give equal consideration to making donations of such commodities to emergency feeding organizations participating in the program authorized by this chapter as is given to other commodity recipient agencies, taking into account the types and amounts of commodities available and appropriate for distribution to these organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7502/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In determining the commodities that will be made available to emergency feeding organizations under this chapter, the Secretary may distribute commodities that become available on a seasonal or irregular basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e53f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7502/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Kosher and Halal food","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":", the Secretary shall finalize and implement a plan—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00e53f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7502/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the purchase of Kosher and Halal food from food manufacturers with a Kosher or Halal certification to carry out the program established under this chapter if the Kosher and Halal food purchased is cost neutral as compared to food that is not from food manufacturers with a Kosher or Halal certification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7502/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to modify the labeling of the commodities list used to carry out the program in a manner that enables Kosher and Halal distribution entities to identify which commodities to obtain from local food banks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf00e53f8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/8/tII/s202"},"text":"Pub. L. 98–8, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-03-24"},"text":"Mar. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/35"},"text":"97 Stat. 35","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/92/s2/3"},"text":"Pub. L. 98–92, § 2(3)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"1983-09-02"},"text":"Sept. 2, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/609"},"text":"97 Stat. 609","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXV"},"text":"Pub. L. 99–198, title XV","children":[],"tail":", §§ 1564(a), 1565(a), "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1591"},"text":"99 Stat. 1591","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/77/tVIII/s811"},"text":"Pub. L. 100–77, title VIII, § 811","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/536"},"text":"101 Stat. 536","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/435/tI/s101"},"text":"Pub. L. 100–435, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-19"},"text":"Sept. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1647"},"text":"102 Stat. 1647","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVII/s1772/b"},"text":"Pub. L. 101–624, title XVII, § 1772(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3808"},"text":"104 Stat. 3808","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIV/s4207"},"text":"Pub. L. 113–79, title IV, § 4207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/826"},"text":"128 Stat. 826","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf00e53f9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf00e53fa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf00e53fb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Agricultural Adjustment Act of 1938, referred to in subsec. (a)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"act Feb. 16, 1938, ch. 30","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/31"},"text":"52 Stat. 31","children":[],"tail":", which is classified principally to chapter 35 (§ 1281 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1281"},"text":"section 1281 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Agricultural Act of 1949, referred to in subsec. (a)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-31/ch792"},"text":"act Oct. 31, 1949, ch. 792","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/1051"},"text":"63 Stat. 1051","children":[],"tail":", which is classified principally to chapter 35A (§ 1421 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Commodity Credit Corporation Charter Act, referred to in subsec. (a)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-29/ch704"},"text":"act June 29, 1948, ch. 704","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/1070"},"text":"62 Stat. 1070","children":[],"tail":", which is classified generally to subchapter II (§ 714 et seq.) of chapter 15 of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s714"},"text":"section 714 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s713a–14"},"text":"Section 713a–14 of title 15","children":[],"tail":", referred to in subsec. (f), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1423/a"},"text":"Pub. L. 113–79, title I, § 1423(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/695"},"text":"128 Stat. 695","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1163 of the Food Security Act of 1985, referred to in subsec. (f), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1163"},"text":"section 1163 of Pub. L. 99–198","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1731"},"text":"section 1731 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf00e53fc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/435"},"text":"Pub. L. 100–435","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/s811/b"},"text":"Pub. L. 100–77, § 811(b)","children":[],"tail":", inserted subsec. (a) designation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/s811/a"},"text":"Pub. L. 100–77, § 811(a)","children":[],"tail":", inserted “a variety of commodities and products thereof that are most useful to eligible recipient agencies, including” after “shall include”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1565/a"},"text":"Pub. L. 99–198, § 1565(a)","children":[],"tail":", struck out subsec. (a) designation and struck out subsec. (b) which read as follows: “Notwithstanding any other provision of law, if wheat stocks acquired by the Commodity Credit Corporation are not available for the purposes of this chapter, up to 300,000 metric tons of wheat designated under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1736f–1/b/1"},"text":"section 1736f–1(b)(1) of this title","children":[],"tail":" may be used for the purposes of this chapter. Any amount of wheat used from the Food Security Wheat Reserve under this chapter shall be replenished by an equivalent quantity of wheat under the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1736f–1/b"},"text":"section 1736f–1(b) of this title","children":[],"tail":" as soon as practicable, but before "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"October 1, 1985","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1564/a"},"text":"Pub. L. 99–198, § 1564(a)","children":[],"tail":", added subsecs. (c) to (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/92/s2/3"},"text":"Pub. L. 98–92, § 2(3)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “Notwithstanding any other provision of law, commodities acquired by the Commodity Credit Corporation that are in excess of quantities needed for the fiscal year to carry out a payment-in-kind acreage diversion program, maintain U.S. share of world markets, and meet international market development and food aid commitments, shall be made available by the Secretary of Agriculture (hereinafter in this chapter referred to as the ‘Secretary’) without charge or credit in such fiscal year for use by eligible recipient agencies. Upon request, commodities provided by the CCC shall be provided in a form suitable for individual household or institutional use.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/92/s2/4"},"text":"Pub. L. 98–92, § 2(4)","children":[],"tail":", substituted “may be used” for “shall be used” and directed the substitution of “"},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"October 1, 1985","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1983-12-01"},"text":"December 1, 1983","children":[],"tail":"”, which was executed by making the substitution for “"},{"tag":"date","attrib":{"date":"1983-12-31"},"text":"December 31, 1983","children":[],"tail":"” to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf010c3fd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf010c3fe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/435"},"text":"Pub. L. 100–435","children":[],"tail":" to be effective and implemented on "},{"tag":"date","attrib":{"date":"1988-09-19"},"text":"Sept. 19, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/435/s701/b/1"},"text":"section 701(b)(1) of Pub. L. 100–435","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2012"},"text":"section 2012 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf010c3ff-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/92/s2"},"text":"Pub. L. 98–92, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-02"},"text":"Sept. 2, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/608"},"text":"97 Stat. 608","children":[],"tail":", provided in part that the amendment made by section 2 is effective "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"Oct. 1, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
