{"tag":"section","attrib":{"id":"idedcd3d70-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"7b–2"},"text":"§ 7b–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idedcd3d71-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment as financial institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 509(3)(B) of the Gramm-Leach-Bliley Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6809/3/B"},"text":"15 U.S.C. 6809(3)(B)","children":[],"tail":"], any futures commission merchant, commodity trading advisor, commodity pool operator, or introducing broker that is subject to the jurisdiction of the Commission under this chapter with respect to any financial activity shall be treated as a financial institution for purposes of title V of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6801"},"text":"15 U.S.C. 6801","children":[],"tail":" et seq.] with respect to such financial activity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedcd3d72-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7b–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of CFTC as Federal functional regulator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of title V of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6801"},"text":"15 U.S.C. 6801","children":[],"tail":" et seq.], the Commission shall be treated as a Federal functional regulator within the meaning of section 509(2) of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6809/2"},"text":"15 U.S.C. 6809(2)","children":[],"tail":"] and shall prescribe regulations under such title within 6 months after "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"December 21, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idedcd3d73-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369/s5g"},"text":"Sept. 21, 1922, ch. 369, § 5g","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tI/s124"},"text":"Pub. L. 106–554, § 1(a)(5) [title I, § 124]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–411.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idedcd3d74-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idedcd3d75-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idedcd3d76-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Gramm-Leach-Bliley Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102"},"text":"Pub. L. 106–102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1338"},"text":"113 Stat. 1338","children":[],"tail":". Title V of the Act is classified principally to chapter 94 (§ 6801 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title of 1999 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1811"},"text":"section 1811 of Title 12","children":[],"tail":", Banks and Banking, and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
