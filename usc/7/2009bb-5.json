{"tag":"section","attrib":{"id":"idef2e2c88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009bb–5"},"text":"§ 2009bb–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distressed counties and areas and nondistressed counties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef2e2c89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", and annually thereafter, the Authority, in accordance with such criteria as the Authority may establish, shall designate—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2e2c8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as distressed counties, counties in the region that are the most severely and persistently distressed and underdeveloped and have high rates of poverty, unemployment, or outmigration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2c8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as nondistressed counties, counties in the region that are not designated as distressed counties under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2c8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–5/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as isolated areas of distress, areas located in nondistressed counties (as designated under paragraph (2)) that have high rates of poverty, unemployment, or outmigration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2e2c8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distressed counties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2e2c8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority shall allocate at least 50 percent of the appropriations made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009bb–12"},"text":"section 2009bb–12 of this title","children":[],"tail":" for programs and projects designed to serve the needs of distressed counties and isolated areas of distress in the region."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2c8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The funding limitations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009bb–3/b"},"text":"section 2009bb–3(b) of this title","children":[],"tail":" shall not apply to a project to provide transportation or telecommunication or basic public services to residents of 1 or more distressed counties or isolated areas of distress in the region."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2e2c90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation, telecommunication, renewable energy, and basic public infrastructure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority shall allocate at least 50 percent of any funds made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009bb–12"},"text":"section 2009bb–12 of this title","children":[],"tail":" for transportation, telecommunication, renewable energy, and basic public infrastructure projects authorized under paragraphs (1) and (3) of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009bb–2/a"},"text":"section 2009bb–2(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef2e2c91-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s383G"},"text":"Pub. L. 87–128, title III, § 383G","children":[],"tail":", formerly § 383F, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6028"},"text":"Pub. L. 107–171, title VI, § 6028","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/384"},"text":"116 Stat. 384","children":[],"tail":"; renumbered § 383G and amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVI/s6026/c/1/A"},"text":"Pub. L. 110–234, title VI, § 6026(c)(1)(A)","children":[],"tail":", (2)(D), (g), "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 