{"tag":"section","attrib":{"id":"idef88cf5c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2661"},"text":null,"children":[{"tag":"num","attrib":{"value":"2661"},"text":"§ 2661.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of purposes and goals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef88cf5d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2661/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The overall purpose of this subchapter is to foster a balanced national development that provides opportunities for increased numbers of the people of the United States to work and enjoy a high quality of life dispersed throughout our Nation by providing the essential knowledge necessary for successful programs of rural development. It is further the purpose of this subchapter to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef88cf5e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2661/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide multistate regional agencies, States, counties, cities, multicounty planning and development districts, businesses, industries, Indian tribes on Federal and State reservations or other federally recognized Indian tribal groups and others involved with public services and investments in rural areas or that provide or may provide employment in these areas the best available scientific, technical, economic, organizational, environmental, and management information and knowledge useful to them, and to assist and encourage them in the interpretation and application of this information to practical problems and needs in rural development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf5f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2661/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide research and investigations in all fields that have as their purpose the development of useful knowledge and information to assist those planning, carrying out, managing, or investing in facilities, services, businesses, or other enterprises, public and private, that may contribute to rural development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf60-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2661/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the capabilities of, and encourage, colleges and universities to perform the vital public service roles of research, and the transfer and practical application of knowledge, in support of rural development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf61-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2661/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand small farm research and extend training and technical assistance to small farm families in assessing their needs and opportunities and in using the best available knowledge on sound economic approaches to small farm operations and on existing services offered by the Department of Agriculture and other public and private agencies and organizations to improve their income and to gain access to essential facilities and services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf62-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2661/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support activities to supplement and extend programs that address special research and education needs in States experiencing rapid social and economic adjustments or unique problems caused by rural isolation and that address national and regional rural development policies, strategies, issues, and programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef88cf63-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2661/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the ","children":[{"tag":"ref","attrib":{"idref":"fn002263"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002263"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Should be capitalized."}],"tail":" goals of this subchapter are to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef88cf64-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2661/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage and support rural United States, in order to help make it a better place to live, work, and enjoy life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf65-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2661/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase income and improve employment for persons in rural areas, including the owners or operators of small farms, small businesses, and rural youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf66-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2661/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the quality and availability of essential community services and facilities in rural areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf67-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2661/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the quantity and quality of rural housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf68-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2661/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the rural management of natural resources so that the growth and development of rural communities needed to support the family farm may be accommodated with minimum effect on the natural environment and the agricultural land base;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf69-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2661/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the data base for rural development decisionmaking at local, State, and national levels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf6a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2661/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" improve the problem solving and development capacities and effectiveness of rural governments, officials, institutions, communities, community leaders, and citizen groups in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef88cf6b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2661/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving access to Federal programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef88cf6c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2661/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving targeting and delivery of technical assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef88cf6d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2661/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving coordination among Federal agencies, other levels of government, and institutions and private organizations in rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef88cf6e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2661/b/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and disseminating better information about rural conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef88cf6f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/419/tV/s501"},"text":"Pub. L. 92–419, title V, § 501","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXIV/s1444/a"},"text":"Pub. L. 97–98, title XIV, § 1444(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1322"},"text":"95 Stat. 1322","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef88cf70-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef88cf71-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idef88cf72-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2661, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/419/tV/s501"},"text":"Pub. L. 92–419, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-08-30"},"text":"Aug. 30, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/671"},"text":"86 Stat. 671","children":[],"tail":", stated Congressional statement of purposes, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXIV/s1444/a"},"text":"Pub. L. 97–98, title XIV, § 1444(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1326"},"text":"95 Stat. 1326","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef88cf73-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idef88cf74-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1801"},"text":"section 1801 of Pub. L. 97–98","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idef88cf75-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2390/a"},"text":"Pub. L. 101–624, title XXIII, § 2390(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4055"},"text":"104 Stat. 4055","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/624/tXXIII/s2390/a"},"text":"“This section [amending sections 2662 and 2663 of this title] may be cited as the ‘Rural Health and Safety Education Act of 1990’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idef88cf76-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/219/s1"},"text":"Pub. L. 100–219, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-29"},"text":"Dec. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1456"},"text":"101 Stat. 1456","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/219/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2662"},"text":"section 2662 of this title","children":[],"tail":"] may be cited as the ‘Rural Crisis Recovery Program Act of 1987’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef88cf77-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Northern Great Plains Rural Development","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/318"},"text":"Pub. L. 103–318","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-26"},"text":"Aug. 26, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1781"},"text":"108 Stat. 1781","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/327/s2"},"text":"Pub. L. 104–327, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4003"},"text":"110 Stat. 4003","children":[],"tail":", established Northern Great Plains Rural Development Commission to study and make recommendations regarding economic needs and economic development of rural Northern Great Plains by seeking and encouraging participation of interested citizens, public officials, groups, agencies, businesses, and other entities in developing 10-year rural economic development plan for Northern Great Plains, defined terms, provided for membership and organization of Commission, duties and powers of Commission, compensation of members, administrative provisions, interim and final reports to Congress, appropriations, and for termination of Commission on "},{"tag":"date","attrib":{"date":"1997-09-30"},"text":"Sept. 30, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
