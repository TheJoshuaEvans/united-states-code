{"tag":"section","attrib":{"id":"idf01ef445-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7751"},"text":null,"children":[{"tag":"num","attrib":{"value":"7751"},"text":"§ 7751.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf01ef446-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7751/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may cooperate with other Federal agencies or entities, States or political subdivisions of States, national governments, local governments of other nations, domestic or international organizations, domestic or international associations, and other persons to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01ef447-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7751/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The individual or entity cooperating with the Secretary under subsection (a) shall be responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01ef448-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7751/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority necessary to conduct the operations or take measures on all land and properties within the foreign country or State, other than those owned or controlled by the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01ef449-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7751/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other facilities and means as the Secretary determines necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01ef44a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7751/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of biological control methods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may transfer to a State, Federal agency, or other person biological control methods using biological control organisms against plant pests or noxious weeds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01ef44b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7751/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation in program administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may cooperate with State authorities or other persons in the administration of programs for the improvement of plants, plant products, and biological control organisms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01ef44c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7751/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Phytosanitary issues","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that phytosanitary issues involving imports and exports are addressed based on sound science and consistent with applicable international agreements. To accomplish these goals, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01ef44d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7751/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct direct negotiations with plant health officials or other appropriate officials of other countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01ef44e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7751/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance, training, and guidance to any country requesting such assistance in the development of agricultural health protection systems and import/export systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01ef44f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7751/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" maintain plant health and quarantine expertise in other countries—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01ef450-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7751/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the establishment of phytosanitary systems and the resolution of phytosanitary issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01ef451-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7751/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist those countries with agricultural health protection activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01ef452-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7751/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide general liaison on agricultural health issues with the plant health or other appropriate officials of the country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01ef453-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7751/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of cooperative agreement fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01ef454-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7751/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may provide to a unit of local government in the State described in paragraph (2) any cost-sharing assistance or financing mechanism provided to the State under a cooperative agreement entered into under this Act between the Secretary and the State relating to the eradication, prevention, control, or suppression of plant pests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01ef455-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7751/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for assistance or financing under paragraph (1), a unit of local government shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01ef456-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7751/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaged in any activity relating to the eradication, prevention, control, or suppression of the plant pest infestation covered under the cooperative agreement between the Secretary and the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01ef457-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7751/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" capable of documenting each plant pest infestation eradication, prevention, control, or suppression activity generally carried out by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf01ef458-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7751/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Agriculture; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf01ef459-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7751/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State department of agriculture that has jurisdiction over the unit of local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf01ef45a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/tIV/s431"},"text":"Pub. L. 106–224, title IV, § 431","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/451"},"text":"114 Stat. 451","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tX/s10206"},"text":"Pub. L. 110–234, title X, § 10206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1346"},"text":"122 Stat. 1346","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title X, § 10206, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2107.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf01ef45b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf01ef45c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf01ef45d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this title”, meaning title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224"},"text":"Pub. L. 106–224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/438"},"text":"114 Stat. 438","children":[],"tail":", known as the Plant Protection Act, which is classified principally to this chapter. For complete classification of title IV to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7701"},"text":"section 7701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (f)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224"},"text":"Pub. L. 106–224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/358"},"text":"114 Stat. 358","children":[],"tail":", known as the Agricultural Risk Protection Act of 2000. For complete classification of this Act to the Code, see Short Title of 2000 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"section 1501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf01ef45e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf01ef45f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s10206"},"text":"Pub. L. 110–246, § 10206","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf01ef460-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf01ef461-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idf01ef462-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of the Secretary of Agriculture relating to agricultural import and entry inspection activities under this chapter to the Secretary of Homeland Security, and for treatment of related references, see sections 231, 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
