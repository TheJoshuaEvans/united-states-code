{"tag":"section","attrib":{"id":"ideedf6fcb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1636f"},"text":"§ 1636f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of information on retail purchase prices for representative meat products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideedf6fcc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1999-10-22"},"text":"October 22, 1999","children":[],"tail":", the Secretary shall compile and publish at least monthly (weekly, if practicable) information on retail prices for representative food products made from beef, pork, chicken, turkey, veal, or lamb."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf6fcd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report published by the Secretary under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf6fce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on retail prices for each representative food product described in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6fcf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on total sales quantity (in pounds and dollars) for each representative food product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf6fd0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meat Price Spreads Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the period ending 2 years after the initial publication of the report required under subsection (a), the Secretary shall continue to publish the Meat Price Spreads Report in the same manner as the Report was published before ","children":[{"tag":"date","attrib":{"date":"1999-10-22"},"text":"October 22, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf6fd1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information collection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf6fd2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To ensure the accuracy of the reports required under subsection (a), the Secretary shall obtain the information for the reports from one or more sources including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedf6fd3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636f/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consistently representative set of retail transactions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf6fd4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636f/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" both prices and sales quantities for the transactions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6fd5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedf6fd6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636f/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain the information from retailers or commercial information sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf6fd7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636f/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use valid statistical sampling procedures, if necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6fd8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636f/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing information on retail prices under this section, the Secretary may make adjustments to take into account differences in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedf6fd9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636f/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographic location of consumption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf6fda-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636f/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location of the principal source of supply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf6fdb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636f/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distribution costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf6fdc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636f/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other factors as the Secretary determines reflect a verifiable comparative retail price for a representative food product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf6fdd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf6fde-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636f/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall collect information under this section only on a voluntary basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6fdf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636f/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not impose a penalty on a person for failure to provide the information or otherwise compel a person to provide the information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideedf6fe0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 257, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tIX/s911/2"},"text":"Pub. L. 106–78, title IX, § 911(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1204"},"text":"113 Stat. 1204","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
