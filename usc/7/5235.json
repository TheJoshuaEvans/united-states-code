{"tag":"section","attrib":{"id":"idefc47918-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5235"},"text":null,"children":[{"tag":"num","attrib":{"value":"5235"},"text":"§ 5235.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of additional appropriations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated for the Service, in addition to any sums otherwise authorized to be appropriated by any provision of law other than this section, $20,000,000 for each of the fiscal years 1988, 1989, and 1990 for market development activities, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc47919-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5235/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expansion of the agricultural attache service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc4791a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5235/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expansion of international trade policy activities of the Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc4791b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5235/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancement of the Service worldwide market information system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc4791c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5235/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the number of trade shows and exhibitions conducted by the Service and upgrading the quality of United States representation at trade shows and exhibitions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc4791d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5235/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing markets for value-added beef, pork, and poultry products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefc4791e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tIV/s4215"},"text":"Pub. L. 100–418, title IV, § 4215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1395"},"text":"102 Stat. 1395","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
